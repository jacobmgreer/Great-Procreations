":[]}],"lifeSummary":"When William Flegg was born in 1400, in Dereham, Norfolk, England, his father, John Flegg, was 30 and his mother, Mrs. Flegg, was 29. He married Margaret Elizabeth Hayfield in 1428. They were the parents of at least 3 sons and 2 daughters. He died in 1447, in Norfolk, England, at the age of 47."},"et":{"1400–1447":"1400–1447","1404–1442":"1404–1442","1430–1479":"1430–1479","1433–1490":"1433–1490","1435–1481":"1435–1481","1438–1480":"1438–1480","1440–1527":"1440–1527","1370–1400":"1370–1400","1372–Female":"1372–Surnud","1440":"1440","1372":"1372","1481":"1481","1370":"1370","1480":"1480","1490":"1490","1404":"1404","1447":"1447","1435":"1435","1479":"1479","1400":"1400","Abt 1399":"umbes 1399","1433":"1433","about 1438":"umbes 1438","about 1435":"umbes 1435","1442":"1442","1430":"1430","about 1433":"umbes 1433","about 1430":"umbes 1430","1428":"1428","1527":"1527","1438":"1438","Norfolk, Norfolk, England":"Norfolk, England","Dereham, Norfolk, England":"Dereham, Norfolk, England","Shipdham, Norfolk, England":"Shipdham, Norfolk, England","East Dereham, Breckland, Norfolk, England, United Kingdom":"Dereham, Norfolk, Inglismaa, United Kingdom","East Dereham, Norfolk, England":"Dereham, Norfolk, England"},"fi":{"1400–1447":"1400–1447","1404–1442":"1404–1442","1430–1479":"1430–1479","1433–1490":"1433–1490","1435–1481":"1435–1481","1438–1480":"1438–1480","1440–1527":"1440–1527","1370–1400":"1370–1400","1372–Female":"1372–Kuollut","1440":"1440","1372":"1372","1481":"1481","1370":"1370","1480":"1480","1490":"1490","1404":"1404","1447":"1447","1435":"1435","1479":"1479","1400":"1400","Abt 1399":"noin 1399","1433":"1433","about 1438":"noin 1438","about 1435":"noin 1435","1442":"1442","1430":"1430","about 1433":"noin 1433","about 1430":"noin 1430","1428":"1428","1527":"1527","1438":"1438","Norfolk, Norfolk, England":"Norfolk, England","Dereham, Norfolk, England":"Dereham, Norfolk, England","Shipdham, Norfolk, England":"Shipdham, Norfolk, England","East Dere