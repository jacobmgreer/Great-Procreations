on.","jurisdictionLevel":1}],"lifeSummary":"Anne was born in 1446, in Essex, England. She had at least 1 son with Sir Nicholas Clere. She died in Corby, Northamptonshire, England."},"et":{"1446–":"1446–Surnud","1442–1500":"1442–1500","1462–1520":"1462–1520","1446–Female":"1446–Surnud","1558":"1558","1446":"1446","1500":"1500","1455":"1455","1520":"1520","1442":"1442","1462":"1462","1549":"1549","England":"Inglismaa, United Kingdom","Corby, Northamptonshire, England":"Corby, Northamptonshire, England","Essex, England":"Essex, England"},"fi":{"1446–":"1446–Kuollut","1442–1500":"1442–1500","1462–1520":"1462–1520","1446–Female":"1446–Kuollut","1558":"1558","1446":"1446","1500":"1500","1455":"1455","1520":"1520","1442":"1442","1462":"1462","1549":"1549","England":"Englanti, Yhdistynyt kuningaskunta","Corby, Northamptonshire, England":"Corby, Northamptonshire, England","Essex, England":"Essex, England"},"fr":{"1446–":"1446–Décédée","1442–1500":"1442–1500","1462–1520":"1462–1520","1446–Female":"1446–Décédée","1558":"1558","1446":"1446","1500":"1500","1455":"1455","1520":"1520","1442":"1442","1462":"1462","1549":"1549","England":"Angleterre, Royaume-Uni","Corby, Northamptonshire, England":"Corby, Northamptonshire, Angleterre","Essex, England":"Essex, Angleterre","lifeSummary":"Anne est née en 1446, à Essex, Angleterre. Elle a eu au moins 1 fils avec Sir Nicholas Clere. Elle est décédée à Corby, Northamptonshire, Angleterre."},"de":{"1446–":"1446–Verstorben","1442–1500":"1442–1500","1462–1520":"1462–1520","1446–Female":"1446–Verstorben","1558":"1558","1446":"1446","1500":"1500","1455":"1455","1520":"1520","1442":"1442","1462":"1462","1549":"1549","England":"England, United Kingdom","Corby, Northamptonshire, England":"Corby, Northamptonshire, England","Essex, England":"Essex, England","lifeSummary":"Anne wurde 1446 in Essex, England geboren. Sie hatte mit Sir Nicholas Clere mindestens 1 Sohn. Sie starb in Corby, Northamptonshire, England."},"ht":{"1446–":"1446–Desede","1442–1