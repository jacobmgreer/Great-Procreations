:{"1445–1496":"1445–1496","1447–Female":"1447–Overleden","1470–1530":"1470–1530","1420–Male":"1420–Overleden","1425–Female":"1425–Overleden","1425":"1425","1447":"1447","1445":"1445","1455":"1455","1420":"1420","1530":"1530","1496":"1496","1470":"1470","Yorkshire, England":"Yorkshire, England","England":"England"},"en":{"1445–1496":"1445–1496","1447–Female":"1447–Deceased","1470–1530":"1470–1530","1420–Male":"1420–Deceased","1425–Female":"1425–Deceased","1425":"1425","1447":"1447","1445":"1445","1455":"1455","1420":"1420","1530":"1530","1496":"1496","1470":"1470","Yorkshire, England":"Yorkshire, England","England":"England","nameMeanings":[{"name":"Kilham","type":"LAST","attribution":"Dictionary of Family Names in Britain and Ireland © University of the West of England 2016","meanings":["English: locative name from Kilham (ER Yorks), Kilham in Cantley (WR Yorks), or Kilham in Kirknewton (Northumb)."],"variants":[{"name":"Killham","meanings":["English: from any of several places in northern England called Kilham, most of which are recorded as <i>Killum</i> in medieval documents, from an Old English prepositional phrase meaning ‘at the kilns’."]},{"name":"Killam","meanings":["English (mainly Yorkshire): variant of <b>Kilham</b>, a habitational name from any of the places in Northumberland and Yorkshire, so named either from Old English <i>cylnum</i> ‘(at) the kilns’, dative plural of <i>cyln</i>, or from Old English <i>cyln</i> ‘kiln’ or the personal name <i>Cylla</i> + Old Norse <i>holmr</i> ‘small island, water meadow’. This surname is rare in Britain."]}]},{"name":"Peter","type":"FIRST","attribution":"Dictionary of First Names © Patrick Hanks and Flavia Hodges 1990, 2003, 2006.","meanings":["form of the name of the best-known of all Christ's apostles, traditionally regarded as the founder of the Christian Church. The name derives, via Latin, from Greek <i>petros</i> ‘stone, rock’. This is used as a translation of the Aramaic byname <i>Cephas</i>, given to the apostle  Simon  son of Jona, to distinguish him from another of the same name (  Simon Zelotes ). ‘When Jesus beheld him, he said, Thou art Simon the son of Jona: thou shalt be called Cephas, which is by interpretation, A stone’ (John 1:42). According to Matthew 16:17–18, Christ says more explicitly, ‘Blessed art thou, Simon Bar-jona … thou art Peter, and upon this rock I will build my church’. The name has been in continuous use since the Middle Ages."],"variants":[]}],"historicEvents":[{"id":1705197,"age":10,"year":"1455","julianDay":2252488,"title":"Wars of the Roses","description":"Wars of the Roses was a series of English civil wars for control of the throne of England between the royal families House of Lancaster and the House of York. The name of the war was derived as the red rose was the symbol of the Lancastrians and the white rose was the symbol of the Yorks.","url":"https://www.history.com/topics/british-history/wars-of-the-roses","urlTitle":"History - Wars of the Roses","jurisdictionLevel":0}],"lifeSummary":"When Peter Kilham was born in 1445, in Yorkshire, England, his father, Maurice Kilham, was 25 and his mother, Tyssanda, was 20. He had at least 1 son with Mrs Peter Kilham. He died in 1496, in England, at the age of 51."},"et":{"1445–1496":"1445–1496","1447–Female":"1447–Surnud","1470–1530":"1470–1530","1420–Male":"1420–Surnud","1425–Female":"1425–Surnud","1425":"1425","1447":"1447","1445":"1445","1455":"1455","1420":"1420","1530":"1530","1496":"1496","1470":"1470","Yorkshire, England":"Yorkshire, England","England":"England"},"fi":{"1445–1496":"1445–1496","1447–Female":"1447–Kuollut","1470–1530":"1470–1530","1420–Male":"1420–Kuollut","1425–Female":"1425–Kuollut","1425":"1425","1447":"1447","1445":"1445","1455":"1455","1420":"1420","1530":"1530","1496":"1496","1470":"1470","Yorkshire, England":"Yorkshire, England","England":"England"},"fr":{"1445–1496":"1445–1496","1447–Female":"1447–Décédée","1470–1530":"1470–1530","1420–Male":"1420–Décédé","1425–Female