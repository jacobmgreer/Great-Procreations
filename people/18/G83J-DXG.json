53":"1453","1475":"1475","1551":"1551","1509":"1509","25 November 1545":"25 november 1545","1549":"1549","1537":"1537","Nonington, Kent, England":"Nonington, Kent, England","Wellingore, Lincolnshire, England":"Wellingore, Lincolnshire, England","Goodnestone, Kent, England":"Goodnestone, Kent, Engeland, Verenigd Koninkrijk","England":"England","Burton by Lincoln, Lincolnshire, England":"Burton by Lincoln, Lincolnshire, England","Kent, England":"Kent, Engeland, Verenigd Koninkrijk","Lincolnshire, England":"Lincolnshire, England","St Leonard, Middlesex, England":"Middlesex, England","Saint Leonard, Middlesex, England":"Middlesex, England"},"en":{"1480–1551":"1480–1551","1475–1545":"1475–1545","1509–1537":"1509–1537","1453–1480":"1453–1480","1460–Female":"1460–Deceased","1482":"1482","1460":"1460","1480":"1480","about 1509":"about 1509","about 1508":"about 1508","1545":"1545","about 1537":"about 1537","1453":"1453","1475":"1475","1551":"1551","1509":"1509","25 November 1545":"25 November 1545","1549":"1549","1537":"1537","Nonington, Kent, England":"Nonington, Kent, England","Wellingore, Lincolnshire, England":"Wellingore, Lincolnshire, England","Goodnestone, Kent, England":"Goodnestone, Kent, England, United Kingdom","England":"England","Burton by Lincoln, Lincolnshire, England":"Burton by Lincoln, Lincolnshire, England","Kent, England":"Kent, England, United Kingdom","Lincolnshire, England":"Lincolnshire, England","St Leonard, Middlesex, England":"Middlesex, England","Saint Leonard, Middlesex, England":"Middlesex, England","nameMeanings":[{"name":"Boys","type":"LAST","attribution":"Dictionary of American Family Names © Patrick Hanks 2003, 2006.","meanings":["English: variant of   Boyce   and   Boyes  .","Probably also an Americanized form of French   Bois  ."],"variants":[{"name":"Boyce","meanings":["English and Irish (mainly Donegal): of Norman origin, a habitational name from from one or more places in Normandy named with Old French <i>bois</i> ‘wood, grove’, especially Bois-Arnault and Bus-Saint-Rémy (Eure), and Bosc-le-Hard (Seine-Maritime), each of which is known to have given its name to an aristocratic Norman family in England. The name was taken by the Normans from England to Ireland, where it was also adopted to Anglicize Irish <b>Ó Buadhaigh</b> (see   Bogue  ).","English: variant of   Bush  , influenced by Old French <i>bois</i> in 1 above, or else a translation of this term.","Americanized form of French   Bois  ."]}]},{"name":"Elizabeth","type":"FIRST","attribution":"Dictionary of First Names © Patrick Hanks and Flavia Hodges 1990, 2003, 2006.","meanings":["The usual spelling of   Elisabeth   in English. It is recorded in the medieval period, but was made popular by being borne by  Queen Elizabeth I  of England (  1533–1603 ). In the 20th century it again became extremely fashionable, partly because it was the name of  Elizabeth Bowes-Lyon  (  1900–2002 ), who in  1936  became Queen Elizabeth as the wife of King George VI, and after his death in  1952  achieved great public affection as Queen Mother for nearly half a century. Even more influentially, it is the name of her daughter  Queen Elizabeth II  (  b. 1926 )."],"variants":[{"name":"Elisabeth","meanings":["The spelling of   Elizabeth   used in the Authorized Version of the New Testament, and in most modern European languages. This was the name of the mother of John the Baptist (Luke 1:60). Etymologically, the name means ‘God is my oath’, and is therefore identical with <i>Elisheba</i>, the name of the wife of Aaron according to the genealogy at Exodus 6:23. The final element seems to have been altered by association with Hebrew <i>shabbāth</i> ‘Sabbath’."]}]}],"historicEvents":[{"id":1705201,"age":69,"year":"1549","julianDay":2286821,"title":"Book of Common Prayer","description":"Book of Common Prayer, a product of the English Reformation, was published in 1549 for assistance in the administration of the sacraments and other rites and ceremonies of the church according to the use of the Church of England. The book outlined morning, evening, and communion prayers and orders for baptism and marriage, thus making England a truly Protestant state.","url":"https://en.wikipedia.org/wiki/Book_of_Common_Prayer","urlTitle":"Wikipedia - Book of Common Prayer","jurisdictionLevel":2}],"lifeSummary":"When Elizabeth Boys was born in 1480, in Goodnestone, Kent, England, United Kingdom, her father, Thomas Boys, was 28 and her mother, Joan Nix Nicholes, was 20. She married Robert Sutton about 1508, in England. They were the parents of at least 1 son. She died in 1551, in Middlesex, England, at the age of 71, and was buried in Middlesex, England."},"et":{"1480–1551":"1480–1551","1475–1545":"1475–1545","1509–1537":"1509–1537","1453–1480":"1453–1480","1460–Female":"1460–Surnud","1482":"1482","1460":"1460","1480":"1480","about 1509":"umbes 1509","about 1508":"umbes 1508","1545":"1545","about 1537":"umbes 1537","1453":"1453","1475":"1475","1551":"1551","1509":"1509","25 November 1545":"25. november 1545","1549":"1549","1537":"1537","Nonington, Kent, England":"Nonington, Kent, England","Wellingore, Lincolnshire, England":"Wellingore, Lincolnshire, England","Goodnestone, Kent, England":"Goodnestone, Kent, Inglismaa, United Kingdom","England":"England","Burton by Lincoln, Lincolnshire, England":"Burton by Lincoln, Lincolnshire, England","Kent, England":"Kent, Inglismaa, United Kingdom","Lincolnshire, England":"Lincolnshire, England","St Leonard, Middlesex, England":"Middlesex, England","Saint Leonard, Middlesex, England":"Middlesex, England"},"fi":{"1480–1551":"1480–1551","1475–1545":"1475–1545","1509–1537":"1509–1537","1453–1480":"1453–1480","1460–Female":"1460–Kuollut","1482":"1482","1460":"1460","1480":"1480","about 1509":"noin 1509","about 1508":"noin 1508","1545":"1545","about 1537":"noin 1537","1453":"1453","1475":"1475","1551":"1551","1509":"1509","25 November 1545":"25. marraskuuta 1545","1549":"1549","1537":"1537","Nonington, Kent, Englan