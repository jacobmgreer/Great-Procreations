ark, Monmouthshire, Wales":"威尔士蒙姆爾皮爾費爾德 帕克","Stevington, Bedfordshire, England":"英国貝德福爾斯迪分頓","Monmouthshire, Wales":"威尔士蒙姆爾","lifeSummary":"当William Morris于大约1580年出生在威尔士蒙姆爾皮爾費爾德 帕克时，他的父亲Anthony William Morris24岁，母亲Grace Wrighte27岁。他和Lucy Walters至少有1个儿子。他去世于1650年在威尔士蒙姆爾享年71岁。"},"hr":{"about 1580–1650":"oko 1580.–1650.","1575–Male":"1575–preminuo","1580–1650":"1580–1650.","1555–Female":"1555–preminula","1609–1682":"1609–1682","1557–1650":"1557–1650.","about 1580":"oko 1580.","1557":"1557","1555":"1555","22 January 1609":"22. siječnja 1609.","21 June 1573":"21. lipnja 1573.","1575":"1575","1650":"1650.","1682":"1682","1609":"1609","1580":"1580","Bolton, Lancashire, England":"Bolton, Lancashire, Engleska, United Kingdom","Piercefield Park, Monmouthshire, Wales":"Piercefield Park, Monmouthshire, Wales","Stevington, Bedfordshire, England":"Stevington, Bedfordshire, England","Monmouthshire, Wales":"Monmouthshire, Wales"},"cs":{"about 1580–1650":"okolo 1580–1650","1575–Male":"1575–Zesnulý","1580–1650":"1580–1650","1555–Female":"1555–Zesnulá","1609–1682":"1609–1682","1557–1650":"1557–1650","about 1580":"okolo 1580","1557":"1557","1555":"1555","22 January 1609":"22. ledna 1609","21 June 1573":"21. června 1573","1575":"1575","1650":"1650","1682":"1682","1609":"1609","1580":"1580","Bolton, Lancashire, England":"Bolton, Lancashire, Anglie, United Kingdom","Piercefield Park, Monmouthshire, Wales":"Piercefield Park, Monmouthshire, Wales","Stevington, Bedfordshire, England":"Stevington, Bedfordshire, Anglie","Monmouthshire, Wales":"Monmouthshire, Wales"},"da":{"about 1580–1650":"omkring 1580–1650","1575–Male":"1575–Afdød","1580–1650":"1580–1650","1555–Female":"1555–Afdød","1609–1682":"1609–1682","1557–1650":"1557–1650","about 1580":"omkring 1580","1557":"1557","1555":"1555","22 January 1609":"22. januar 1609","21 June 1573":"21. juni 1573","1575":"1575","1650":"1650","1682":"1682","1609":"1609","1580":"1580","Bolton, Lancashire, England":"Bolton, Lancashire, England, United Kingdom","Piercefield Park, Monmouthshire, Wales":"Piercefield Park, Monmouthshire, Wales","Stevington, Bedfordshire, England":"Stevington, Bedfordshire, England","Monmouthshire, Wales":"Monmouthshire, Wales"},"nl":{"about 1580–1650":"circa 1580–1650","1575–Male":"1575–Overleden","1580–1650":"1580–1650","1555–Female":"1555–Overleden","1609–1682":"1609–1682","1557–1650":"1557–1650","about 1580":"circa 1580","1557":"1557","1555":"1555","22 January 1609":"22 januari 1609","21 June 1573":"21 juni 1573","1575":"1575","1650":"1650","1682":"1682","1609":"1609","1580":"1580","Bolton, Lancashire, England":"Bolton, Lancashire, Engeland, Verenigd Koninkrijk","Piercefield Park, Monmouthshire, Wales":"Piercefield Park, Monmouthshire, Wales","Stevington, Bedfordshire, England":"Stevington, Bedfordshire, England","Monmouthshire, Wales":"Monmouthshire, Wales"},"en":{"about 1580–1650":"about 1580–1650","1575–Male":"1575–Deceased","1580–1650":"1580–1650","1555–Female":"1555–Deceased","1609–1682":"1609–1682","1557–1650":"1557–1650","about 1580":"about 1580","1557":"1557","1555":"1555","22 January 1609":"22 January 1609","21 June 1573":"21 June 1573","1575":"1575","1650":"1650","1682":"1682","1609":"1609","1580":"1580","Bolton, Lancashire, England":"Bolton, Lancashire, England, United Kingdom","Piercefield Park, Monmouthshire, Wales":"Piercefield Park, Monmouthshire, Wales","Stevington, Bedfordshire, England":"Stevington, Bedfordshire, England","Monmouthshire, Wales":"Monmouthshire, Wales","nameMeanings":[{"name":"Morris","type":"LAST","attribution":"Dictionary of American Family Names © Patrick Hanks 2003, 2006.","meanings":["English and Scottish: from <i>Maurice</i>, an Old French personal name introduced to Britain by the Normans. It is derived from Latin <i>Mauritius</i>, a derivative of <i>Maurus</i> (see   Moore  ). This was the name of several early Christian saints. In some cases it may be a nickname of the same derivation for someone with a swarthy complexion.","Irish: Anglicized form of Gaelic <b>Ó Muirghis</b>, a variant of <b>Ó Muirgheasa</b> (see   Morrissey  ).","Welsh: Anglicized form of the personal name <i>Meurig</i> (from Latin <i>Mauritius</i>), which was gradually superseded in Wales by <i>Morus</i>, <i>Morys</i>, a derivative of the Anglo-Norman French form of the name (see 1 above)."],"variants":[{"name":"Moore","meanings":["English: from Middle English <i>more</i> ‘moor, marsh, fen’ (Old English <i>mōr</i>), hence a topographic name for someone who lived in such a place, or a habitational name from any of various places called with this word, as for example Moore in Cheshire or More in Shropshire.","English (of Norman origin): ethnic name from Old French <i>more</i> ‘Moor’, either someone from North Africa or, more often, a nickname for someone thought to resemble a Moor. Compare   Morrell   and   Moreau  .","English (of Norman origin): from the Middle English personal name <i>More</i> (Old French <i>More</i>, <i>Maur</i>, Latin <i>Maurus</i>), originally denoting either ‘Moor’ or someone with a swarthy complexion (compare   Morrell  ,   Morrin  ,   Morris  , and sense 2 above). There was a 6th-century Christian saint of this name."]},{"name":"Mauritz","meanings":["Some characteristic forenames:  German Fritz, Armin, Frieda, Helmut, Kurt, Reinhold, Wolfgang.","German and Dutch: from the personal name <i>Mauritz</i>, from Latin <i>Mauritius</i> (see   Morris  )."]},{"name":"Mauricio","meanings":["Some characteristic forenames:  Spanish Jose, Manuel, Juan, Carlos, Mario, Roberto, Lilia, Luis, Adela, Andres, Antero, Cipriano.  Portuguese Manoel.","Portuguese (<b>Maurício</b>) and Spanish: from the personal name <i>Maurício</i> (Portuguese), <i>Mauricio</i> (Spanish), derived from the Latin name <i>Mauritius</i> (see   Morris  )."]},{"name":"Maurice","meanings":["Some characteristic forenames:  French Andre, Pierre, Armand, Denys, Gabrielle, Antoine, Benoit, Camille, Cecile, Francois, Gaston, Germain.","French, English, Welsh, Scottish, and Irish: from the Old French personal name <i>Maurice</i>, Latin <i>Mauritius</i> (see   Morris  )."]},{"name":"McMorris","meanings":["Scottish and Irish: Anglicized form of Gaelic <b>Mac Muiris</b>, a patronymic from a Gaelicized form of   Morris  . In some cases this is a Gaelicized form of   Fitzmaurice  .","Scottish and Irish: Anglicized form of Gaelic <b>Mac Muirgheasa</b> ‘son of <i>Muirgheas</i>’, a Gaelic personal name meaning ‘sea valor’ or ‘sea choice’. Compare   Morrissey  ."]},{"name":"Morici","meanings":["Some characteristic forenames:  Italian Salvatore, Antonio, Gasper, Aldo, Angelo, Annamarie, Elvio, Giuseppe, Sal, Santo, Vito.","Italian: patronymic or plural form of a variant of the personal name <i>Maurice</i> (see   Morris  ).","Hungarian: patronymic from the personal name <i>Móric</i>, Hungarian form of   Morris  ."]},{"name":"Moris","meanings":["English: variant of   Morris  .","French, Luxembourgish, Flemish, Walloon, North German, and Dutch: from a vernacular form of the French personal name <i>Maurice</i> (see   Morris  ). In North America, the surname <i>Moris</i> may also be an altered form of French   Maurice  .","Americanized form of German   Moritz  ."]},{"name":"Merrick","meanings":["Welsh: from the personal name <i>Meuric</i>, the Middle Welsh form of <i>Maurice</i> (see   Morris  ).","Irish: borrowed from Welsh. In Ireland, when this is not the Welsh name, it might be adopted for Irish <b>Ó Mearadhaigh</b>, see   Merry   2."]},{"name":"Maurizio","meanings":["Some characteristic forenames:  Italian Carlo, Marcello, Marco, Mario, Fernando, Matteo, Natale, Sal, Valentino, Vito.","Italian: from the personal name <i>Maurizio</i>, from Latin <i>Mauritius</i> (see   Morris   1)."]},{"name":"Morehouse","meanings":["English (Yorkshire): habitational name from any of the many places called Moorhouse in Yorkshire or Durham (from Old English <i>mōr</i> ‘moor’ + <i>hūs</i> ‘house’). In some cases the surname may have become   Morris  . This name is also established in Ireland."]}]},{"name":"William","type":"FIRST","attribution":"Dictionary of First Names © Patrick Hanks and Flavia Hodges 1990, 2003, 2006.","meanings":["Probably the most successful of all the Old French names of Germanic origin that were introduced to England by the Normans. It is derived from Germanic <i>wil</i> ‘will, desire’ + <i>helm</i> ‘helmet, protection’. The fact that it was borne by the Conqueror himself does not seem to have inhibited its favour with the ‘conquered’ population: in the first century after the Conquest it was the commonest male name of all, and not only among the Normans. In the later Middle Ages it was overtaken by   John  , but continued to run second to that name until the 20th century, when the picture became more fragmented."],"variants":[]}],"lifeSummary":"When William Morris was born about 1580, in Piercefield Park, Monmouthshire, Wales, his father, Anthony William Morris, was 24 and his mother, Grace Wrighte, was 27. He had at least 1 son with Lucy Walters. He died in 1650, in Monmouthshire, Wales, at the age of 71."},"et":{"about 1580–1650":"umbes 1580–1650","1575–Male":"1575–Surnud","1580–1650":"1580–1650","1555–Female":"1555–Surnud","1609–1682":"1609–1682","1557–1650":"1557–1650","about 1580":"umbes 1580","1557":"1557","1555":"1555","22 January 1609":"22. jaanuar 1609","21 June 1573":"21. juuni 1573","1575":"1575","1650":"1650","1682":"1682","1609":"1609","1580":"1580","Bolton, Lancashire, England":"Bolton, Lancashire, Inglismaa, United Kingdom","Piercefield Park, Monmouthshire, Wales":"Piercefield Park, Monmouthshire, Wales","Stevington, Bedfordshire, England":"Stevington, Bedfordshire, England","Monmouthshire, Wales":"Monmouthshire, Wales"},"fi":{"about 1580–1650":"noin 1580–1650","1575–Male":"1575–Kuollut","1580–1650":"1580–1650","1555–Female":"1555–Kuollut","1609–1682":"1609–1682","1557–1650":"1557–1650","about 1580":"noin 1580","1557":"1557","1555":"1555","22 January 1609":"22. tammikuuta 1609","