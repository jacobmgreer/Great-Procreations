’."]}]},{"name":"Rissa","type":"FIRST","attribution":"Dictionary of First Names © Patrick Hanks and Flavia Hodges 1990, 2003, 2006.","meanings":["Short form of   Melissa .   See also  Lyssa ."],"variants":[]}],"lifeSummary":"Elizabeth Rissa Kirke was born in 1560, in Kilwinning, Ayrshire, Scotland, United Kingdom as the daughter of Bertal Rissa Kirke. She had at least 1 son with John Lynn."},"et":{"1560–":"1560–Surnud","1560–Female":"1560–Surnud","1560–1625":"1560–1625","1585–1635":"1585–1635","1530–Male":"1530–Surnud","1635":"1635","1585":"1585","1530":"1530","1560":"1560","1625":"1625","Loch Lynn, Ayrshire, Scotland":"Ayrshire, Šotimaa, United Kingdom","Kilwinning, Ayrshire, Scotland":"Kilwinning, Ayrshire, Šotimaa, United Kingdom"},"fi":{"1560–":"1560–Kuollut","1560–Female":"1560–Kuollut","1560–1625":"1560–1625","1585–1635":"1585–1635","1530–Male":"1530–Kuollut","1635":"1635","1585":"1585","1530":"1530","1560":"1560","1625":"1625","Loch Lynn, Ayrshire, Scotland":"Ayrshire, Skotlanti, Yhdistynyt kuningaskunta","Kilwinning, Ayrshire, Scotland":"Kilwinning, Ayrshire, Skotlanti, Yhdistynyt kuningaskunta"},"fr":{"1560–":"1560–Décédée","1560–Female":"1560–Décédée","1560–1625":"1560–1625","1585–1635":"1585–1635","1530–Male":"1530–Décédé","1635":"1635","1585":"1585","1530":"1530","1560":"1560","1625":"1625","Loch Lynn, Ayrshire, Scotland":"Ayrshire, Écosse, Royaume-Uni","Kilwinning, Ayrshire, Scotland":"Kilwinning, Ayrshire, Écosse, Royaume-Uni","lifeSummary":"Elizabeth Rissa Kirke est née en 1560, à Kilwinning, Ayrshire, Écosse, Royaume-Uni, fille de Bertal Rissa Kirke. Elle a eu au moins 1 fils avec John Lynn."},"de":{"1560–":"1560–Verstorben","1560–Female":"1560–Verstorben","1560–1625":"1560–1625","1585–1635":"1585–1635","1530–Male":"1530–Verstorben","1635":"1635","1585":"1585","1530":"1530","1560":"1560","1625":"1625","Loch Lynn, Ayrshire, Scotland":"Ayrshire, Schottland, United Kingdom","Kilwinning, Ayrshire, Scotland":"Kilwinning, Ayrshire, Schottland, United Kingd