ett在英国英格兰素福爾可萊哈姆结婚。他们至少是2个儿子和5个女儿的父母。她去世于1574年之后。"},"hr":{"Abt 1535–Aft 1574":"oko 1535.–nakon 1574.","1529–1571":"1529–1571.","1559–1602":"1559–1602","1559–1625":"1559–1625","1561–1602":"1561–1602","1568–1579":"1568–1579","1570–1639":"1570–1639","1571–1580":"1571.–1580","1579–1579":"1579–1579","1535–1574":"1535–1574","16 May 1559":"16. svibnja 1559.","Aft 1574":"nakon 1574.","Abt 1535":"oko 1535.","1561":"1561","1571":"1571.","1570":"1570","1580":"1580","Abt 1558":"oko 1558.","1602":"1602","1535":"1535","1579":"1579","1568":"1568","1574":"1574","30 August 1561":"30. kolovoza 1561.","1639":"1639","1529":"1529","29 September 1568":"29. rujna 1568.","1 August 1570":"1. kolovoza 1570.","Bef 11 November 1571":"prije 11. studenog 1571.","1625":"1625","1559":"1559","Nayland, Suffolk, England":"Nayland, Suffolk, Engleska, United Kingdom","Layham, Suffolk, England":"Layham, Suffolk, Engleska, United Kingdom","England":"Engleska, United Kingdom","Heathfield,Sussex,England":"Heathfield, Sussex, Engleska, United Kingdom"},"cs":{"Abt 1535–Aft 1574":"okolo 1535–po 1574","1529–1571":"1529–1571","1559–1602":"1559–1602","1559–1625":"1559–1625","1561–1602":"1561–1602","1568–1579":"1568–1579","1570–1639":"1570–1639","1571–1580":"1571–1580","1579–1579":"1579–1579","1535–1574":"1535–1574","16 May 1559":"16. května 1559","Aft 1574":"po 1574","Abt 1535":"okolo 1535","1561":"1561","1571":"1571","1570":"1570","1580":"1580","Abt 1558":"okolo 1558","1602":"1602","1535":"1535","1579":"1579","1568":"1568","1574":"1574","30 August 1561":"30. srpna 1561","1639":"1639","1529":"1529","29 September 1568":"29. září 1568","1 August 1570":"1. srpna 1570","Bef 11 November 1571":"před 11. listopadu 1571","1625":"1625","1559":"1559","Nayland, Suffolk, England":"Nayland, Suffolk, Anglie, United Kingdom","Layham, Suffolk, England":"Layham, Suffolk, Anglie, United Kingdom","England":"Anglie, United Kingdom","Heathfield,Sussex,England":"Heathfield, Sussex, Anglie, United Kingdom"},"da":{"Abt 1535–Aft 1574":"