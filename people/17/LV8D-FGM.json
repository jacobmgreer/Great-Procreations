nd":"Suffolk, Anglie"},"da":{"1470–1530":"1470–1530","1475–Female":"1475–Afdød","1495–1550":"1495–1550","1503–1553":"1503–1553","1445–1496":"1445–1496","1447–Female":"1447–Afdød","1503":"1503","1447":"1447","1445":"1445","1553":"1553","1530":"1530","1475":"1475","1496":"1496","1495":"1495","1550":"1550","1470":"1470","Bury St. Edmonds, Suffolk, England":"Suffolk, England, United Kingdom","England":"England","Suffolk, England":"Suffolk, England"},"nl":{"1470–1530":"1470–1530","1475–Female":"1475–Overleden","1495–1550":"1495–1550","1503–1553":"1503–1553","1445–1496":"1445–1496","1447–Female":"1447–Overleden","1503":"1503","1447":"1447","1445":"1445","1553":"1553","1530":"1530","1475":"1475","1496":"1496","1495":"1495","1550":"1550","1470":"1470","Bury St. Edmonds, Suffolk, England":"Suffolk, Engeland, Verenigd Koninkrijk","England":"England","Suffolk, England":"Suffolk, England"},"en":{"1470–1530":"1470–1530","1475–Female":"1475–Deceased","1495–1550":"1495–1550","1503–1553":"1503–1553","1445–1496":"1445–1496","1447–Female":"1447–Deceased","1503":"1503","1447":"1447","1445":"1445","1553":"1553","1530":"1530","1475":"1475","1496":"1496","1495":"1495","1550":"1550","1470":"1470","Bury St. Edmonds, Suffolk, England":"Suffolk, England, United Kingdom","England":"England","Suffolk, England":"Suffolk, England","nameMeanings":[{"name":"Kilham","type":"LAST","attribution":"Dictionary of Family Names in Britain and Ireland © University of the West of England 2016","meanings":["English: locative name from Kilham (ER Yorks), Kilham in Cantley (WR Yorks), or Kilham in Kirknewton (Northumb)."],"variants":[{"name":"Killham","meanings":["English: from any of several places in northern England called Kilham, most of which are recorded as <i>Killum</i> in medieval documents, from an Old English prepositional phrase meaning ‘at the kilns’."]},{"name":"Killam","meanings":["English (mainly Yorkshire): variant of <b>Kilham</b>, a habitational name from any of the places in Northumberland and Yorkshire, so named either from Old English <i>cylnum</i> ‘(at) the kilns’, dative plural of <i>cyln</i>, or from Old English <i>cyln</i> ‘kiln’ or the personal name <i>Cylla</i> + Old Norse <i>holmr</i> ‘small island, water meadow’. This surname is rare in Britain."]}]},{"name":"Peter","type":"FIRST","attribution":"Dictionary of First Names © Patrick Hanks and Flavia Hodges 1990, 2003, 2006.","meanings":["form of the name of the best-known of all Christ's apostles, traditionally regarded as the founder of the Christian Church. The name derives, via Latin, from Greek <i>petros</i> ‘stone, rock’. This is used as a translation of the Aramaic byname <i>Cephas</i>, given to the apostle  Simon  son of Jona, to distinguish him from another of the same name (  Simon Zelotes ). ‘When Jesus beheld him, he said, Thou art Simon the son of Jona: thou shalt be called Cephas, which is by interpretation, A stone’ (John 1:42). According to Matthew 16:17–18, Christ says more explicitly, ‘Blessed art thou, Simon Bar-jona … thou art Peter, and upon this rock I will build my church’. The name has been in continuous use since the Middle Ages."],"variants":[]}],"lifeSummary":"When Peter Kilham was born in 1470, in England, his father, Peter Kilham, was 25 and his mother, Mrs Peter Kilham, was 24. He had at least 1 son and 1 daughter with Susan. He died in 1530, in his hometown, at the age of 60."},"et":{"1470–1530":"1470–1530","1475–Female":"1475–Surnud","1495–1550":"1495–1550","1503–1553":"1503–1553","1445–1496":"1445–1496","1447–Female":"1447–Surnud","1503":"1503","1447":"1447","1445":"1445","1553":"1553","1530":"1530","1475":"1475","1496":"1496","1495":"1495","1550":"1550","1470":"1470","Bury St. Edmonds, Suffolk, England":"Suffolk, Inglismaa, United Kingdom","England":"England","Suffolk, England":"Suffolk, England"},"fi":{"1470–1530":"1470–1530","1475–Female":"1475–Kuollut","1495–1550":"1495–1550","1503–1553":"1503–1553","1445–1496":"1445–1496","1447–Female":"1447–Kuollut","1503":