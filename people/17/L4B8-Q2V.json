lamenco","meanings":["Spanish: ethnic name from <i>flamenco</i> ‘Fleming, Flemish person’ (see   Fleming  )."]}]},{"name":"John","type":"FIRST","meanings":["Greek: the Lord gave graciously; whom Jehovah gave; whom Jehovah bestowed."],"variants":[]}],"lifeSummary":"John Fleming was born in Swansea, Swansea, Wales, United Kingdom as the son of Thomas Fleming and Angharad ferch Jenkin. He had at least 1 son with Maesod Ddu."},"et":{"–":"Surnud","–Male":"Surnud","–Female":"Surnud","1536–1585":"1536–1585","1485–Male":"1485–Surnud","1487–Female":"1487–Surnud","1536":"1536","1487":"1487","1585":"1585","1485":"1485","Llangennith, Glamorgan, Wales":"Llangennith, Glamorgan, Wales","of,Abertawe,Glamorganshire,Wales":"Swansea, Swansea, Wales, United Kingdom"},"fi":{"–":"Kuollut","–Male":"Kuollut","–Female":"Kuollut","1536–1585":"1536–1585","1485–Male":"1485–Kuollut","1487–Female":"1487–Kuollut","1536":"1536","1487":"1487","1585":"1585","1485":"1485","Llangennith, Glamorgan, Wales":"Llangennith, Glamorgan, Wales","of,Abertawe,Glamorganshire,Wales":"Swansea, Swansea, Wales, Yhdistynyt kuningaskunta"},"fr":{"–":"Décédé","–Male":"Décédé","–Female":"Décédée","1536–1585":"1536–1585","1485–Male":"1485–Décédé","1487–Female":"1487–Décédée","1536":"1536","1487":"1487","1585":"1585","1485":"1485","Llangennith, Glamorgan, Wales":"Llangennith, Glamorgan, Galles","of,Abertawe,Glamorganshire,Wales":"Swansea, Swansea, Pays de Galles, Royaume-Uni","lifeSummary":"John Fleming est né à Swansea, Swansea, Pays de Galles, Royaume-Uni, fils de Thomas Fleming et Angharad ferch Jenkin. Il a eu au moins 1 fils avec Maesod Ddu."},"de":{"–":"Verstorben","–Male":"Verstorben","–Female":"Verstorben","1536–1585":"1536–1585","1485–Male":"1485–Verstorben","1487–Female":"1487–Verstorben","1536":"1536","1487":"1487","1585":"1585","1485":"1485","Llangennith, Glamorgan, Wales":"Llangennith, Glamorgan, Wales","of,Abertawe,Glamorganshire,Wales":"Swansea, Swansea, Wales, United Kingdom","lifeSummary":"John Fleming wur