land":"Hollingbourne, Kent, England"},"nl":{"1484–1548":"1484–1548","1480–1550":"1480–1550","1516–1576":"1516–1576","1518–1576":"1518–1576","1522–1580":"1522–1580","1524–1570":"1524–1570","1526–Female":"1526–Overleden","1484":"1484","1550":"1550","1570":"1570","1580":"1580","1480":"1480","about 1518":"circa 1518","1524":"1524","1522":"1522","1576":"1576","1518":"1518","1516":"1516","1515":"1515","1526":"1526","1548":"1548","Southwick, Hampshire, England":"Southwick, Hampshire, England","London, Middlesex, England":"London, Middlesex, England","London, Canterbury, Kent, England, United Kingdom":"Diocese of London, Canterbury, Kent, Engeland, Verenigd Koninkrijk","Ilkeston, Derbyshire, England":"Ilkeston, Derbyshire, England","Hollingbourne, Kent, England":"Hollingbourne, Kent, England"},"en":{"1484–1548":"1484–1548","1480–1550":"1480–1550","1516–1576":"1516–1576","1518–1576":"1518–1576","1522–1580":"1522–1580","1524–1570":"1524–1570","1526–Female":"1526–Deceased","1484":"1484","1550":"1550","1570":"1570","1580":"1580","1480":"1480","about 1518":"about 1518","1524":"1524","1522":"1522","1576":"1576","1518":"1518","1516":"1516","1515":"1515","1526":"1526","1548":"1548","Southwick, Hampshire, England":"Southwick, Hampshire, England","London, Middlesex, England":"London, Middlesex, England","London, Canterbury, Kent, England, United Kingdom":"Diocese of London, Canterbury, Kent, England, United Kingdom","Ilkeston, Derbyshire, England":"Ilkeston, Derbyshire, England","Hollingbourne, Kent, England":"Hollingbourne, Kent, England","nameMeanings":[{"name":"Chapman","type":"LAST","attribution":"Dictionary of American Family Names © Patrick Hanks 2003, 2006.","meanings":["English: occupational name for a merchant or trader, Middle English <i>chap(pe)man</i>, <i>chepman</i>, Old English <i>cēapmann</i>, <i>cēpemann</i>, a compound of <i>cēap</i> ‘barter, bargain, price, property’ + <i>mann</i> ‘man’.","Jewish: adopted probably for a like-sounding or like-meaning name in some other European language; see for example   Kaufman  .","History: This name was brought independently to North America from England by numerous different bearers from the 17th century onward. John Chapmen (sic) was one of the free planters who assented to the ‘Fundamental Agreement’ of the New Haven Colony on June 4, 1639."],"variants":[{"name":"Chatman","meanings":["English: altered form of   Chapman  ."]},{"name":"Kaufman","meanings":["Some characteristic forenames:  Jewish Hyman, Meyer, Chaim, Emanuel, Moshe, Eytan, Herschel, Zvi, Ari, Aron.","Americanized form of German   Kaufmann  , and a variant of the same Jewish surname.","Jewish (Ashkenazic): from the personal name <i>Kaufman</i> meaning ‘merchant’. Compare   Koyfman   2."]},{"name":"Chipman","meanings":["English: from Middle English <i>chipman</i> (Old English <i>cȳp(e)mann</i>), a side form of <i>chapman</i>, <i>chepman</i> ‘merchant, trader’; see   Chapman  , with which this name was interchangeable."]},{"name":"Copeman","meanings":["English (Norfolk and Suffolk): patronymic from the early Middle English personal name <i>Cop(e)man</i>, an Anglicized form of Old Scandinavian <i>Kaupmaðr</i>. It is a transferred use of Old Scandinavian <i>kaupmaðr</i> (Old Danish <i>køpman</i>) ‘merchant’, cognate with Old English <i>cēapmann</i> (see   Chapman  ), but there is no evidence for the occupational term in Middle English.","Americanized form of North German   Koopmann   or Dutch   Koopman  ."]}]},{"name":"Dorothy","type":"FIRST","attribution":"Dictionary of First Names © Patrick Hanks and Flavia Hodges 1990, 2003, 2006.","meanings":["Usual English form of   Dorothea .  The name was not used in the Middle Ages, but was taken up in the 15th century and became common thereafter. It was borne by the American film star  Dorothy Lamour  (  1914–1996 , born  Dorothy Kaumeyer )."],"variants":[{"name":"Dorothee","meanings":["Usual English form of   Dorothea .  The name was not used in the Middle Ages, but was taken up in the 15th century and became common thereafter. It was borne by the American film star  Dorothy Lamour  (  1914–1996 , born  Dorothy Kaumeyer )."]},{"name":"Dorothie","meanings":["Usual English form of   Dorothea .  The name was not used in the Middle Ages, but was taken up in the 15th century and became common thereafter. It was borne by the American film star  Dorothy Lamour  (  1914–1996 , born  Dorothy Kaumeyer )."]}]}],"lifeSummary":"Dorothy Chapman was born in 1484, in Ilkeston, Derbyshire, England. She married Sir Stephen Barnham of Southwick in 1515, in Southwick, Hampshire, England. They were the parents of at least 2 sons and 3 daughters. She died in 1548, in London, Middlesex, England, at the age of 64."},"et":{"1484–1548":"1484–1548","1480–1550":"1480–1550","1516–1576":"1516–1576","1518–1576":"1518–1576","1522–1580":"1522–1580","1524–1570":"1524–1570","1526–Female":"1526–Surnud","1484":"1484","1550":"1550","1570":"1570","1580":"1580","1480":"1480","about 1518":"umbes 1518","1524":"1524","1522":"1522","1576":"1576","1518":"1518","1516":"1516","1515":"1515","1526":"1526","1548":"1548","Southwick, Hampshire, England":"Southwick, Hampshire, England","London, Middlesex, England":"London, Middlesex, England","London, Canterbury, Kent, England, United Kingdom":"Diocese of London, Canterbury, Kent, Inglismaa, United Kingdom","Ilkeston, Derbyshire, England":"Ilkeston, Derbyshire, England","Hollingbourne, Kent, England":"Hollingbourne, Kent, England"},"fi":{"1484–1548":"1484–1548","1480–1550":"1480–1550","1516–1576":"1516–1576","1518–1576":"1518–1576","1522–1580":"1522–1580","1524–1570":"1524–1570","1526–Female":"1526–Kuollut","1484":"1484","1550":"1550","1570":"1570","1580":"1580","1480":"1480","about 1518":"noin 1518","1524":"1524","1522":"1522","1576":"1576","1518":"1518","1516":"1516","1515":"1515","1526":"1526","1548":"1548","Southwick, Hampshire, England":"Southwick, Hampshire, England","London, Middlesex, England":"London, Middlesex, England","London, Canterbu