ber 1540":"15. september 1540","19 February 1542":"19. februar 1542","1542":"1542","1541":"1541","1540":"1540","1562":"1562","about 1531":"omkring 1531","1617":"1617","1549":"1549","1515":"1515","Walsham le Willows, Suffolk, England":"Walsham le Willows, Suffolk, England","Walsham Le Willows, Suffolk, England":"Walsham le Willows, Suffolk, England","Suffolk, England":"Suffolk, England"},"nl":{"about 1515–1558":"circa 1515–1558","1510–1557":"1510–1557","1532–1562":"1532–1562","1534–Female":"1534–Overleden","1535–1617":"1535–1617","1540–Female":"1540–Overleden","1541–1560":"1541–1560","1542–Male":"1542–Overleden","1515–1558":"1515–1558","1560":"1560","1558":"1558","1535":"1535","1557":"1557","1534":"1534","1532":"1532","1510":"1510","about 1515":"circa 1515","15 September 1540":"15 september 1540","19 February 1542":"19 februari 1542","1542":"1542","1541":"1541","1540":"1540","1562":"1562","about 1531":"circa 1531","1617":"1617","1549":"1549","1515":"1515","Walsham le Willows, Suffolk, England":"Walsham le Willows, Suffolk, England","Walsham Le Willows, Suffolk, England":"Walsham le Willows, Suffolk, England","Suffolk, England":"Suffolk, England"},"en":{"about 1515–1558":"about 1515–1558","1510–1557":"1510–1557","1532–1562":"1532–1562","1534–Female":"1534–Deceased","1535–1617":"1535–1617","1540–Female":"1540–Deceased","1541–1560":"1541–1560","1542–Male":"1542–Deceased","1515–1558":"1515–1558","1560":"1560","1558":"1558","1535":"1535","1557":"1557","1534":"1534","1532":"1532","1510":"1510","about 1515":"about 1515","15 September 1540":"15 September 1540","19 February 1542":"19 February 1542","1542":"1542","1541":"1541","1540":"1540","1562":"1562","about 1531":"about 1531","1617":"1617","1549":"1549","1515":"1515","Walsham le Willows, Suffolk, England":"Walsham le Willows, Suffolk, England","Walsham Le Willows, Suffolk, England":"Walsham le Willows, Suffolk, England","Suffolk, England":"Suffolk, England","nameMeanings":[{"name":"Chapman","type":"LAST","attribution":"Dictionary of American Family Names © Patrick Hanks 2003, 2006.","meanings":["English: occupational name for a merchant or trader, Middle English <i>chap(pe)man</i>, <i>chepman</i>, Old English <i>cēapmann</i>, <i>cēpemann</i>, a compound of <i>cēap</i> ‘barter, bargain, price, property’ + <i>mann</i> ‘man’.","Jewish: adopted probably for a like-sounding or like-meaning name in some other European language; see for example   Kaufman  .","History: This name was brought independently to North America from England by numerous different bearers from the 17th century onward. John Chapmen (sic) was one of the free planters who assented to the ‘Fundamental Agreement’ of the New Haven Colony on June 4, 1639."],"variants":[{"name":"Chatman","meanings":["English: altered form of   Chapman  ."]},{"name":"Kaufman","meanings":["Some characteristic forenames:  Jewish Hyman, Meyer, Chaim, Emanuel, Moshe, Eytan, Herschel, Zvi, Ari, Aron.","Americanized form of German   Kaufmann  , and a variant of the same Jewish surname.","Jewish (Ashkenazic): from the personal name <i>Kaufman</i> meaning ‘merchant’. Compare   Koyfman   2."]},{"name":"Chipman","meanings":["English: from Middle English <i>chipman</i> (Old English <i>cȳp(e)mann</i>), a side form of <i>chapman</i>, <i>chepman</i> ‘merchant, trader’; see   Chapman  , with which this name was interchangeable."]},{"name":"Copeman","meanings":["English (Norfolk and Suffolk): patronymic from the early Middle English personal name <i>Cop(e)man</i>, an Anglicized form of Old Scandinavian <i>Kaupmaðr</i>. It is a transferred use of Old Scandinavian <i>kaupmaðr</i> (Old Danish <i>køpman</i>) ‘merchant’, cognate with Old English <i>cēapmann</i> (see   Chapman  ), but there is no evidence for the occupational term in Middle English.","Americanized form of North German   Koopmann   or Dutch   Koopman  ."]}]},{"name":"Susan","type":"FIRST","attribution":"Dictionary of First Names © Patrick Hanks and Flavia Hodges 1990, 2003, 2006.","meanings":["vernacular form of   Susanna .  Among well-known bearers are the American film stars  Susan Hayward  (  1918–75 ) and  Susan Sarandon  (  b. 1946  as  Susan Tomalin )."],"variants":[{"name":"Suzan","meanings":["vernacular form of   Susanna .  Among well-known bearers are the American film stars  Susan Hayward  (  1918–75 ) and  Susan Sarandon  (  b. 1946  as  Susan Tomalin )."]},{"name":"Susanna","meanings":["New Testament form (Luke 8:3) of the Hebrew name <i>Shoshana</i> (from <i>shoshan</i> ‘lily’, which in modern Hebrew also means ‘rose’)."]}]}],"historicEvents":[{"id":1705201,"age":34,"year":"1549","julianDay":2286821,"title":"Book of Common Prayer","description":"Book of Common Prayer, a product of the English Reformation, was published in 1549 for assistance in the administration of the sacraments and other rites and ceremonies of the church according to the use of the Church of England. The book outlined morning, evening, and communion prayers and orders for baptism and marriage, thus making England a truly Protestant state.","url":"https://en.wikipedia.org/wiki/Book_of_Common_Prayer","urlTitle":"Wikipedia - Book of Common Prayer","jurisdictionLevel":2},{"id":1705202,"age":43,"year":"1558","julianDay":2290108,"title":"Act of Uniformity","description":"The Act of Uniformity was passed by the Parliament of England and required all people to go to church once a week. The consequence of not attending church was a fine of 12 pence, which was a considerable amount for a poor person.","jurisdictionLevel":2}],"lifeSummary":"Susan Chapman was born about 1515. She married Nicholas Waller about 1531, in Walsham le Willows, Suffolk, England. They were the parents of at least 3 sons and 3 daughters. She died in 1558, in Walsham le Willows, Suffolk, England, at the age of 44."},"et":{"about 1515–1558":"umbes 1515–1558","1510–1557":"1510–1557","1532–1562":"1532–1562","1534–Female":"1534–Surnud","1535–1617":"1535–1617","1540–Female":"1540–Surnud","1541–1560":"1541–1560","1542–M