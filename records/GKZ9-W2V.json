eval kings of Scotland."],"variants":[]}],"lifeSummary":"Sir David Caunton was born about 1283, in Caunton, Nottinghamshire, England, United Kingdom. He had at least 1 son."},"et":{"about 1283–":"umbes 1283–Surnud","1309–1335":"1309–1335","1283–Male":"1283–Surnud","about 1283":"umbes 1283","1335":"1335","1283":"1283","1309":"1309","Caunton,Nottinghamshire,England.":"Caunton, Nottinghamshire, Inglismaa, United Kingdom"},"fi":{"about 1283–":"noin 1283–Kuollut","1309–1335":"1309–1335","1283–Male":"1283–Kuollut","about 1283":"noin 1283","1335":"1335","1283":"1283","1309":"1309","Caunton,Nottinghamshire,England.":"Caunton, Nottinghamshire, Englanti, Yhdistynyt kuningaskunta"},"fr":{"about 1283–":"environ 1283–Décédé","1309–1335":"1309–1335","1283–Male":"1283–Décédé","about 1283":"environ 1283","1335":"1335","1283":"1283","1309":"1309","Caunton,Nottinghamshire,England.":"Caunton, Nottinghamshire, Angleterre, Royaume-Uni","lifeSummary":"Sir David Caunton est né environ 1283, à Caunton, Nottinghamshire, Angleterre, Royaume-Uni. Il a eu au moins 1 fils."},"de":{"about 1283–":"um 1283–Verstorben","1309–1335":"1309–1335","1283–Male":"1283–Verstorben","about 1283":"um 1283","1335":"1335","1283":"1283","1309":"1309","Caunton,Nottinghamshire,England.":"Caunton, Nottinghamshire, England, United Kingdom","lifeSummary":"Sir David Caunton wurde um 1283 in Caunton, Nottinghamshire, England, United Kingdom geboren. Er hatte mindestens 1 Sohn."},"ht":{"about 1283–":"about 1283–Desede","1309–1335":"1309–1335","1283–Male":"1283–Desede","about 1283":"about 1283","1335":"1335","1283":"1283","1309":"1309","Caunton,Nottinghamshire,England.":"Caunton, Nottinghamshire, Angletè, United Kingdom"},"hu":{"about 1283–":"1283 körül–elhunyt","1309–1335":"1309–1335","1283–Male":"1283–elhunyt","about 1283":"1283 körül","1335":"1335","1283":"1283","1309":"1309","Caunton,Nottinghamshire,England.":"Caunton, Nottinghamshire, Anglia, United Kingdom"},"id":{"about 1283–":"sekitar 1283–Telah Meninggal","1309–1