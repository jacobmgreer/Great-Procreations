s":[{"name":"Emma","type":"FIRST","attribution":"Dictionary of First Names © Patrick Hanks and Flavia Hodges 1990, 2003, 2006.","meanings":["Old French name, of Germanic (Frankish) origin, originally a short form of compound names such as   Ermintrude   containing the word <i>erm(en)</i>, <i>irm(en)</i> ‘entire’. It was adopted by the Normans and introduced by them to Britain, but its popularity in medieval England was greatly enhanced by the fact that it had been borne by the mother of Edward the Confessor, herself a Norman. In modern times, it was only in moderate use early in the 20th century but rose sharply in favour in the 1970s and has since remained perennially popular."],"variants":[]},{"name":"fitz","type":"FIRST","attribution":"Dictionary of First Names © Patrick Hanks and Flavia Hodges 1990, 2003, 2006.","meanings":["Either a short form of any of the numerous names representing a transferred use of a surname formed with the Anglo-Norman French prefix <i>fi(t)z</i> ‘son of ’, as for example   Fitzgerald  ,   Fitzroy  , or a transferred use of the surname <i>Fitz</i>, which may be of the same derivation, but applied originally to distinguish a son from a father bearing the same given name, or a local name from Fitz in Shropshire, named with the Old English personal name <i>Fitt</i> + <i>hōh</i> ‘hill spur’."],"variants":[]},{"name":"Hubert","type":"FIRST","attribution":"Dictionary of First Names © Patrick Hanks and Flavia Hodges 1990, 2003, 2006.","meanings":["Old French name of Germanic (Frankish) origin, derived from <i>hug</i> ‘heart, mind, spirit’ + <i>berht</i> ‘bright, famous’. It was popular among the Normans, who introduced it to Britain, where it was later reinforced by settlers from the Low Countries. An 8th-century  St Hubert  succeeded  St Lambert  as bishop of Maastricht and is regarded as the patron of hunters, since, like  St Eustace , he is supposed to have seen a vision of Christ crucified between the antlers of a stag."],"variants":[{"name":"Hupprecht","meanings":["Old French name of Germanic (Frankish) origin, derived from <i>hug</i> ‘heart, mind, spirit’ + <i>berht</i> ‘bright, famous’. It was popular among the Normans, who introduced it to Britain, where it was later reinforced by settlers from the Low Countries. An 8th-century  St Hubert  succeeded  St Lambert  as bishop of Maastricht and is regarded as the patron of hunters, since, like  St Eustace , he is supposed to have seen a vision of Christ crucified between the antlers of a stag."]},{"name":"Huppert","meanings":["Old French name of Germanic (Frankish) origin, derived from <i>hug</i> ‘heart, mind, spirit’ + <i>berht</i> ‘bright, famous’. It was popular among the Normans, who introduced it to Britain, where it was later reinforced by settlers from the Low Countries. An 8th-century  St Hubert  succeeded  St Lambert  as bishop of Maastricht and is regarded as the patron of hunters, since, like  St Eustace , he is supposed to have seen a vision of Christ crucified between the antlers of a stag."]},{"name":"Hugbert","meanings":["Old French name of Germanic (Frankish) origin, derived from <i>hug</i> ‘heart, mind, spirit’ + <i>berht</i> ‘bright, famous’. It was popular among the Normans, who introduced it to Britain, where it was later reinforced by settlers from the Low Countries. An 8th-century  St Hubert  succeeded  St Lambert  as bishop of Maastricht and is regarded as the patron of hunters, since, like  St Eustace , he is supposed to have seen a vision of Christ crucified between the antlers of a stag."]}]},{"name":"of","type":"FIRST","attribution":"Dictionary of First Names © Patrick Hanks and Flavia Hodges 1990, 2003, 2006.","meanings":["Short form of   Oswald   or any of the various other names beginning with <i>Os-</i>."],"variants":[]},{"name":"Criche","type":"LAST","attribution":"Dictionary of American Family Names © Patrick Hanks 2003, 2006.","meanings":["French: from a regional (Picard) form of Old French <i>clice</i> ‘braided wicker’, used as a metonymic occupational name for a maker. Compare   Clish  ."],"variants":[{"name":"Clish","meanings":["English (Durham): perhaps a nominalization of the Scots verb <i>clish</i> ‘chatter’. Alternatively, perhaps a shortened form of Scottish   McLeish  . The surname is strongly associated with County Durham.","Americanized form of French   Cliche  ."]}]}],"lifeSummary":"Emma fitz Hubert of Criche was born about 1220, in Crich, Derbyshire, England, United Kingdom as the daughter of Hubert fitz Ralph of Criche and Edelina FitzWilliam. She married Peter de Wakebridge I. They were the parents of at least 1 son."},"et":{"about 1220–":"umbes 1220–Surnud","1220–Female":"1220–Surnud","1222–Female":"1222–Surnud","1200–Male":"1200–Surnud","1240–Male":"1240–Surnud","1195–Male":"1195–Surnud","–Female":"Surnud","before 1220":"enne 1220","1200":"1200","1222":"1222","1220":"1220","1240":"1240","1195":"1195","about 1220":"umbes 1220","about 1240":"umbes 1240","Wakebridge, Derbyshire, England":"Derbyshire, Inglismaa, United Kingdom","Europe":"Europe","Criche, Derbyshire, England":"Crich, Derbyshire, Inglismaa, United Kingdom"},"fi":{"about 1220–":"noin 1220–Kuollut","1220–Female":"1220–Kuollut","1222–Female":"1222–Kuollut","1200–Male":"1200–Kuollut","1240–Male":"1240–Kuollut","1195–Male":"1195–Kuollut","–Female":"Kuollut","before 1220":"ennen vuotta 1220","1200":"1200","1222":"1222","1220":"1220","1240":"1240","1195":"1195","about 1220":"noin 1220","about 1240":"noin 1240","Wakebridge, Derbyshire, England":"Derbyshire, Englanti, Yhdistynyt kuningaskunta","Europe":"Europe","Criche, Derbyshire, England":"Crich, Derbyshire, Englanti, Yhdistynyt kuningaskunta"},"fr":{"about 1220–":"environ 1220–Décédée","1220–Female":"1220–Décédée","1222–Female":"1222–Décédée","1200–Male":"1200–Décédé","1240–Male":"1240–Décédé","1195–Male":"1195–Décédé","–Female":"Décédée","before 1220":"avant 1220","1200":"1200","1222":"1222","1220":"1220","1240":"1240","1195":"1195","about 1220":"environ 1