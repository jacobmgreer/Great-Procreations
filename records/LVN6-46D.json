ale":"1158–Afdød","1159–Male":"1159–Afdød","1160–Male":"1160–Afdød","1182–1220":"1182–1220","1182–Female":"1182–Afdød","1162–1200":"1162–1200","1120–1162":"1120–1162","1136–1161":"1136–1161","1190":"1190","1220":"1220","1120":"1120","1153":"1153","1162":"1162","1161":"1161","1182":"1182","1160":"1160","1159":"1159","1158":"1158","1136":"1136","1235":"1235","1200":"1200","1156":"1156","1155":"1155","Lochowe, Argyllshire, Scotland":"Lochawe, Argyll, Skotland, United Kingdom","Lochawe, Argyll, Scotland":"Lochawe, Argyll, Skotland"},"nl":{"1158–":"1158–Overleden","1153–1235":"1153–1235","1155–Male":"1155–Overleden","1156–1190":"1156–1190","1158–Male":"1158–Overleden","1159–Male":"1159–Overleden","1160–Male":"1160–Overleden","1182–1220":"1182–1220","1182–Female":"1182–Overleden","1162–1200":"1162–1200","1120–1162":"1120–1162","1136–1161":"1136–1161","1190":"1190","1220":"1220","1120":"1120","1153":"1153","1162":"1162","1161":"1161","1182":"1182","1160":"1160","1159":"1159","1158":"1158","1136":"1136","1235":"1235","1200":"1200","1156":"1156","1155":"1155","Lochowe, Argyllshire, Scotland":"Lochawe, Argyll, Schotland, Verenigd Koninkrijk","Lochawe, Argyll, Scotland":"Lochawe, Argyll, Schotland"},"en":{"1158–":"1158–Deceased","1153–1235":"1153–1235","1155–Male":"1155–Deceased","1156–1190":"1156–1190","1158–Male":"1158–Deceased","1159–Male":"1159–Deceased","1160–Male":"1160–Deceased","1182–1220":"1182–1220","1182–Female":"1182–Deceased","1162–1200":"1162–1200","1120–1162":"1120–1162","1136–1161":"1136–1161","1190":"1190","1220":"1220","1120":"1120","1153":"1153","1162":"1162","1161":"1161","1182":"1182","1160":"1160","1159":"1159","1158":"1158","1136":"1136","1235":"1235","1200":"1200","1156":"1156","1155":"1155","Lochowe, Argyllshire, Scotland":"Lochawe, Argyll, Scotland, United Kingdom","Lochawe, Argyll, Scotland":"Lochawe, Argyll, Scotland","nameMeanings":[{"name":"Campbell","type":"LAST","attribution":"Dictionary of American Family Names © Patrick Hanks 2003, 2006.","meanings":["Scottish: nickname from Gaelic <i>cam</i> ‘crooked, bent’ + <i>beul</i> ‘mouth’. As a result of folk etymology, the surname was often represented in Latin documents as <i>de bello campo</i> ‘of the fair field’, which led to the name sometimes being ‘translated’ into Anglo-Norman French as   Beauchamp  .","Irish (North Armagh): adopted for Gaelic <b>Mac Cathmhaoil</b> ‘son of Cathmhaol’ (literally ‘battle chief’): see   Caulfield   and   Cowell  .","English: variant of   Camel  , under the influence of the Scottish name (see 1 above)."],"variants":[{"name":"Camble","meanings":["Scottish: variant of   Campbell  ."]},{"name":"Campbel","meanings":["Scottish: variant of   Campbell  ."]},{"name":"Cambell","meanings":["(1997: 229;2007: 1415; 2010: NA)","Scottish: variant of   Campbell  ."]},{"name":"Campell","meanings":["(2007: 398; 2010: NA)","Scottish (Lanarkshire) and English: variant of   Campbell   (see also   Camel  )."]},{"name":"Beauchamp","meanings":["Some characteristic forenames:  French Antoine, Jacques, Yves, Andre, Armand, Emile, Fernand, Marcel, Marthe, Remi, Alcide, Camille.","English (of Norman origin) and French: habitational name from any of several places in France, for example in Manche and Somme, that are named with Old French <i>beu</i>, <i>bel</i> ‘fair, lovely’ + <i>champ(s)</i> ‘field, plain’ (from Latin <i>bello campo</i> ‘beautiful field’). In English the surname is generally pronounced   Beecham  . Compare   Bushaw  .","English: in some cases, an Anglo-Norman French adaptation of Scottish   Campbell  , by translation into French of the folk etymology <i>de campo bello</i> ‘from the fair field’."]},{"name":"Camel","meanings":["Some characteristic forenames:  French Andre, Napoleon, Patrice.","English (of Norman origin) and French: nickname from Norman French <i>came(i)l</i> ‘camel’ (from Latin <i>camelus</i>, classical Greek <i>kamēlos</i>), possibly denoting a clumsy person or someone with long legs. It may also be a topographic or habitational name referring to a house with a sign depicting a camel (although surnames derived from house and inn signs are rare in English); compare 5 below.","English: possibly a habitational name from Queen Camel and West Camel in Somerset, early recorded as <i>Camel(le)</i>, possibly a Celtic name from <i>canto-</i> ‘border, district’ and <i>mēl</i> ‘bare hill’."]}]},{"name":"Archibald","type":"FIRST","attribution":"Dictionary of First Names © Patrick Hanks and Flavia Hodges 1990, 2003, 2006.","meanings":["Of Norman French origin, from a Germanic (Frankish) personal name derived from <i>ercan</i> ‘genuine’ + <i>bald</i> ‘bold, brave’. It has long been associated with Scotland, where it is in regular use as the English equivalent of Gaelic <i>Gilleasbaig</i> (  see  Gillespie  )."],"variants":[{"name":"Archibold","meanings":["Of Norman French origin, from a Germanic (Frankish) personal name derived from <i>ercan</i> ‘genuine’ + <i>bald</i> ‘bold, brave’. It has long been associated with Scotland, where it is in regular use as the English equivalent of Gaelic <i>Gilleasbaig</i> (  see  Gillespie  )."]}]}],"lifeSummary":"When Sir Archibald Campbell was born in 1158, in Lochawe, Argyll, Scotland, his father, Sir Archibald Gillespic Campbell - Fifth Lord of Lochawe, Knight, was 11155 and his mother, Finetta Fraser, was 22. He had at least 1 son with Anna McDonald."},"et":{"1158–":"1158–Surnud","1153–1235":"1153–1235","1155–Male":"1155–Surnud","1156–1190":"1156–1190","1158–Male":"1158–Surnud","1159–Male":"1159–Surnud","1160–Male":"1160–Surnud","1182–1220":"1182–1220","1182–Female":"1182–Surnud","1162–1200":"1162–1200","1120–1162":"1120–1162","1136–1161":"1136–1161","1190":"1190","1220":"1220","1120":"1120","1153":"1153","1162":"1162","1161":"1161","1182":"1182","1160":"1160","1159":"1159","1158":"1158","1136":"1136","1235":"1235","1200":"1200","1156":"1156","1155":"1155","Lochowe, Argyllshire, Scotland":"Lochawe, Argyll, Šotimaa, United Kingdom","Lochawe, Argyll, Scotla