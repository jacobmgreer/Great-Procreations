년 1월 5일 영국 켄트 애딩턴에서 태어났을 때, 그의 아버지 Robert de Stepvans(은)는 16세였고, 그의 어머니 Matilda(은)는 23세였다. 그는 Matilda(와)과 적어도 한 명의 딸을 두었다. 그는 1250년 1월 3일 영국 잉글랜드 켄트 쿠링에서 34세의 나이로 사망했으며 영국 잉글랜드에 묻혔다."},"lv":{"5 January 1215–3 January 1250":"1215. gada 5. janvāris–1250. gada 3. janvāris","1215–1250":"1215–1250.gads","–1249":"–1249.gads","1241–1298":"1241.gads–1298","1238–1322":"1238–1322","1250–1304":"1250.gads–1304","1200–1249":"1200–1249.gads","1193–1253":"1193–1253","Aft 1249":"pēc 1249. gada","1253":"1253","5 January 1215":"1215. gada 5. janvāris","1241":"1241. gads","1250":"1250. gads","3 January 1250":"1250. gada 3. janvāris","1193":"1193","1249":"1249. gads","1304":"1304","1238":"1238","1215":"1215","1224":"1224","1322":"1322","1200":"1200","1298":"1298","Cooling, Kent, England, United Kingdom":"Cooling, Kent, Anglija, Lielbritānija","Kent, England":"Kent, Anglija, Lielbritānija","Addington, Kent, England":"Addington, Kent, England","England, United Kingdom":"Anglija, Lielbritānija"},"mg":{"5 January 1215–3 January 1250":"5 janoary 1215–3 janoary 1250","1215–1250":"1215–1250","–1249":"–1249","1241–1298":"1241–1298","1238–1322":"1238–1322","1250–1304":"1250–1304","1200–1249":"1200–1249","1193–1253":"1193–1253","Aft 1249":"taorian'ny 1249","1253":"1253","5 January 1215":"5 janoary 1215","1241":"1241","1250":"1250","3 January 1250":"3 janoary 1250","1193":"1193","1249":"1249","1304":"1304","1238":"1238","1215":"1215","1224":"1224","1322":"1322","1200":"1200","1298":"1298","Cooling, Kent, England, United Kingdom":"Cooling, Kent, Angletera, United Kingdom","Kent, England":"Kent, Angletera, United Kingdom","Addington, Kent, England":"Addington, Kent, England","England, United Kingdom":"Angletera, United Kingdom"},"ms":{"5 January 1215–3 January 1250":"5 Januari 1215–3 Januari 1250","1215–1250":"1215–1250","–1249":"–1249","1241–1298":"1241–1298","1238–1322":"1238–1322","1250–1304":"1250–1304","1200–1249":"1200–1249","1193–1253":"1193–1253","Aft 1249":"selepas 1249","1253":"1253","5 J