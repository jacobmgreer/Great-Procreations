,"1163":"1163年","1141":"1141年","1194":"1194年","1172":"1172年","1193":"1193年","1139":"1139年","1200":"1200年","1166":"1166年","about 1166":"大約1166年","about 1164":"大約1164年","Northamptonshire, England":"英國諾薩普頓史爾","Winwick, Northamptonshire, England":"英國諾薩普頓史爾文維其可","lifeSummary":"當Sir, Thomas Andrews , II, Knight於1163年出生在英國諾薩普頓史爾文維其可時，他的父親Sir, Thomas Andrews , I24歲，母親Lady, Anne Cortney23歲。他於1193年與Lady Johanna Cantilupe Breasey在英國諾薩普頓史爾結婚。他們至少是1個兒子的父母。他去世於1200年在他的家鄉享年37歲。"},"zh-hans":{"1163–1200":"1163年–1200年","1165–Male":"1165年–殁","1172–1194":"1172年–1194年","1194–Male":"1194年–殁","1139–1164":"1139年–1164年","1141–1166":"1141年–1166年","about 1162":"大约1162年","1165":"1165年","1164":"1164年","1163":"1163年","1141":"1141年","1194":"1194年","1172":"1172年","1193":"1193年","1139":"1139年","1200":"1200年","1166":"1166年","about 1166":"大约1166年","about 1164":"大约1164年","Northamptonshire, England":"英国諾薩普頓史爾","Winwick, Northamptonshire, England":"英国諾薩普頓史爾文維其可","lifeSummary":"当Sir, Thomas Andrews , II, Knight于1163年出生在英国諾薩普頓史爾文維其可时，他的父亲Sir, Thomas Andrews , I24岁，母亲Lady, Anne Cortney23岁。他于1193年与Lady Johanna Cantilupe Breasey在英国諾薩普頓史爾结婚。他们至少是1个儿子的父母。他去世于1200年在他的家乡享年37岁。"},"hr":{"1163–1200":"1163.–1200.","1165–Male":"1165–preminuo","1172–1194":"1172–1194.","1194–Male":"1194.–preminuo","1139–1164":"1139–1164","1141–1166":"1141–1166","about 1162":"oko 1162.","1165":"1165","1164":"1164","1163":"1163.","1141":"1141","1194":"1194.","1172":"1172","1193":"1193.","1139":"1139","1200":"1200.","1166":"1166","about 1166":"oko 1166.","about 1164":"oko 1164.","Northamptonshire, England":"Northamptonshire, England","Winwick, Northamptonshire, England":"Winwick, Northamptonshire, England"},"cs":{"1163–1200":"1163–1200","1165–Male":"1165–Zesnulý","1172–1194":"1172–1194","1194–Male":"1194–Zesnulý","1139–1164":"1139–1164","1141–1166":"1141–1166","about 1162":"okolo 1162","1165":"1165","1164":"1164","1163":"1163","1141":"1141","1194":"1194","1172":"1172","1193":"1193","1139":"1139","1200":"1200","1166":"1166","about 1166":"okolo 1166","about 1164":"okolo 1164","Northamptonshire, England":"Northamptonshire, Anglie","Winwick, Northamptonshire, England":"Winwick, Northamptonshire, Anglie"},"da":{"1163–1200":"1163–1200","1165–Male":"1165–Afdød","1172–1194":"1172–1194","1194–Male":"1194–Afdød","1139–1164":"1139–1164","1141–1166":"1141–1166","about 1162":"omkring 1162","1165":"1165","1164":"1164","1163":"1163","1141":"1141","1194":"1194","1172":"1172","1193":"1193","1139":"1139","1200":"1200","1166":"1166","about 1166":"omkring 1166","about 1164":"omkring 1164","Northamptonshire, England":"Northamptonshire, England","Winwick, Northamptonshire, England":"Winwick, Northamptonshire, England"},"nl":{"1163–1200":"1163–1200","1165–Male":"1165–Overleden","1172–1194":"1172–1194","1194–Male":"1194–Overleden","1139–1164":"1139–1164","1141–1166":"1141–1166","about 1162":"circa 1162","1165":"1165","1164":"1164","1163":"1163","1141":"1141","1194":"1194","1172":"1172","1193":"1193","1139":"1139","1200":"1200","1166":"1166","about 1166":"circa 1166","about 1164":"circa 1164","Northamptonshire, England":"Northamptonshire, England","Winwick, Northamptonshire, England":"Winwick, Northamptonshire, England"},"en":{"1163–1200":"1163–1200","1165–Male":"1165–Deceased","1172–1194":"1172–1194","1194–Male":"1194–Deceased","1139–1164":"1139–1164","1141–1166":"1141–1166","about 1162":"about 1162","1165":"1165","1164":"1164","1163":"1163","1141":"1141","1194":"1194","1172":"1172","1193":"1193","1139":"1139","1200":"1200","1166":"1166","about 1166":"about 1166","about 1164":"about 1164","Northamptonshire, England":"Northamptonshire, England","Winwick, Northamptonshire, England":"Winwick, Northamptonshire, England","nameMeanings":[{"name":"Andrews","type":"LAST","attribution":"Dictionary of American Family Names © Patrick Hanks 2003, 2006.","meanings":["English: variant of   Andrew  , with genitival or post-medieval excrescent <i>-s</i>. This is the usual southern English patronymic form, also found in Wales; the Scottish and northern English form is   Anderson  . In North America, this surname has absorbed various cognates from other languages, e.g. Polish   Andrzejewski  , Slovenian <b>Andrejčič</b>, Serbian and Croatian <b>Andrić</b> (see   Andric  ), and Czech <b>Ondráček</b> (see   Ondracek  ).","Irish and Scottish: Anglicized form of Scottish Gaelic <b>Mac Aindreis</b> or Irish <b>Mac Aindriú</b>, see   McAndrew  .","History: This was a common name among the early settlers in New England. Robert Andrews emigrated in 1635 from Norwich, England, to Ipswich, MA. Even before 1635, one Thomas Andrews is recorded as being established in Hingham. A certain William Andrews was a member of John Davenport's company, which sailed from Boston in 1638 to found the New Haven colony."],"variants":[{"name":"Andrus","meanings":["English: variant of   Andrews  .","History: William Andrus came to Boston in 1635 and moved to New Haven in 1639, where he died in 1676."]},{"name":"Andrew","meanings":["English and Scottish: from the usual vernacular English form (recorded from the 13th century onward) of the New Testament Greek personal name   Andreas  . In North America, the English form of the surname has absorbed many cognates from other languages, e.g. Czech <b>Ondřej</b> (see   Ondrey  ) and Albanian   Ndreu  , and also their patronymics and other derivatives (see examples at   Andrews  ).","History: The surname Andrew was first brought to North America from England by Robert Andrew (died 1668), who settled in Boxford, MA."]},{"name":"Andros","meanings":["English: variant of   Andrews  . This surname is very rare in Britain.","American shortened form of Greek <b>Andronikos</b> (see   Andron   2) or of any other surname based on a personal name beginning with <i>Andr-</i> (from <i>andros</i>, genitive of <i>anēr</i> ‘man, male’), e.g. <b>Androutsos</b>, including their patronymics and other derivatives, such as <b>Andronikidis</b>.","History: William Andros came to VA in 1617 and died there <i>c.</i> 1655. Sir Edmund Andros (1637–1714) was the British colonial governor of several provinces in America between 1674 and 1698, most notably NY (1674–81)."]}]},{"name":"Thomas","type":"FIRST","attribution":"Dictionary of First Names © Patrick Hanks and Flavia Hodges 1990, 2003, 2006.","meanings":["New Testament name, borne by one of Christ's twelve apostles, referred to as ‘Thomas, called Didymus’ (John 11:16; 20:24). <i>Didymos</i> is the Greek word for ‘twin’, and the name is the Greek form of an Aramaic byname meaning ‘twin’. The given name has always been popular throughout Christendom, in part because St Thomas's doubts have made him seem a very human character."],"variants":[]}],"lifeSummary":"When Sir, Thomas Andrews , II, Knight was born in 1163, in Winwick, Northamptonshire, England, his father, Sir, Thomas Andrews , I, was 24 and his mother, Lady, Anne Cortney, was 23. He married Lady Johanna Cantilupe Breasey in 1193, in Northamptonshire, England. They were the parents of at least 1 son. He died in 1200, in his hometown, at the age of 37."},"et":{"1163–1200":"1163–1200","1165–Male":"1165–Surnud","1172–1194":"1172–1194","1194–Male":"1194–Surnud","1139–1164":"1139–1164","1141–1166":"1141–1166","about 1162":"umbes 1162","1165":"1165","1164":"1164","1163":"1163","1141":"1141","1194":"1194","1172":"1172","1193":"1193","1139":"1139","1200":"1200","1166":"1166","about 1166":"umbes 1166","about 1164":"umbes 1164","Northamptonshire, England":"Northamptonshire, England","Winwick, Northamptonshire, England":"Winwick, Northamptonshire, England"},"fi":{"1163–1200":"1163–1200","1165–Male":"1165–Kuollut","1172–1194":"1172–1194","1194–Male":"1194–Kuollut","1139–1164":"1139–1164","1141–1166":"1141–1166","about 1162":"noin 1162","1165":"1165","1164":"1164","1163":"1163","1141":"1141","1194":"1194","1172":"1172","1193":"1193","1139":"1139","1200":"1200","1166":"1166","about 1166":"noin 1166","about 1164":"noin 1164","Northamptonshire, England":"Northamptonshire, England","Winwick, Northamptonshire, England":"Winwick, Northamptonshire, England"},"fr":{"1163–1200":"1163–1200","1165–Male":"1165–Décédé","1172–1194":"1172–1194","1194–Male":"1194–Décédé","1139–1164":"1139–1164","1141–1166":"1141–1166","about 1162":"environ 1162","1165":"1165","1164":"1164","1163":"1163","1141":"1141","1194":"1194","1172":"1172","1193":"1193","1139":"1139","1200":"1200","1166":"1166","about 1166":"environ 1166","about 1164":"environ 1164","Northamptonshire, England":"Northamptonshire, Angleterre","Winwick, Northamptonshire, England":"Winwick, Northamptonshire, Angleterre","lifeSummary":"Lorsque Sir, Thomas Andrews , II, Knight est né en 1163, à Winwick, Northamptonshire, Angleterre, son père, Sir, Thomas Andrews , I, avait 24 ans et sa mère, Lady, Anne Cortney, avait 23 ans. Il a épousé Lady Johanna Cantilupe Breasey en 1193, à Northamptonshire, Angleterre. Ils ont eu au moins 1 fils. Il est décédé en 1200, dans sa ville natale, à l’âge de 37 ans."},"de":{"1163–1200":"1163–1200","1165–Male":"1165–Verstorben","1172–1194":"1172–1194","1194–Male":"1194–Verstorben","1139–1164":"1139–1164","1141–1166":"1141–1166","about 1162":"um 1162","1165":"1165","1164":"1164","1163":"1163","1141":"1141","1194":"1194","1172":"1172","1193":"1193","1139":"1139","1200":"1200","1166":"1166","about 1166":"um 1166","about 1164":"um 1164","Northamptonshire, England":"Northamptonshire, England","Winwick, Northamptonshire, England":"Winwick, Northamptonshire, England","lifeSummary":"Als Sir, Thomas Andrews , II, Knight 1163 in Winwick, Northamptonshire, England geboren wurde, war sein Vater Sir, Thomas Andrews , I 24 und seine Mutter Lady, Anne Cortney 23. Er hat 1193 in Northamptonshire, England Lady Johanna Cantilupe Breasey geheiratet. Sie hatten mindestens 1 Sohn. Er starb 1200 im Alter von 37 Jahren in seinem Geburtsort."},"ht":{"1163–1200":"1163–1200","1165–Male":"1165–Desede","1172–1194":"1172–1194","1194–Male":"1194–Desede","1139–1164":"1139–1164","1141–1166":"1141–1166","abo