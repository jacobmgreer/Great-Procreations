ngs":["English (Essex): variant of   Sandford  ."]},{"name":"Sanderford","meanings":["English: variant of   Sandford  ."]},{"name":"Sanford","meanings":["English (Devon): variant of   Sandford  ."]},{"name":"Sandiford","meanings":["English (Lancashire): variant of   Sandifer  ."]}]},{"name":"Joan","type":"FIRST","attribution":"Dictionary of First Names © Patrick Hanks and Flavia Hodges 1990, 2003, 2006.","meanings":["Contracted form of Old French <i>Jo(h)anne</i>, from Latin <i>Io(h)anna</i> (  see  Joanna  ). In England this was the usual feminine form of   John   from the Middle English period onwards and was extremely popular, but in the 16th and 17th centuries it steadily lost ground to   Jane .  It was strongly revived in the first part of the 20th century, partly under the influence of  George Bernard Shaw's  play St Joan (  1923 ), based on the life of  Joan of Arc  (  1412–31 ). Claiming to be guided by the voices of the saints, she persuaded the French dauphin to defy the occupying English forces and have himself crowned, and she led the French army that raised the siege of Orleans in  1429 . The following year she was captured by the Burgundians and sold to the English, and a year later she was burned at the stake for witchcraft at the age of 18 or 19. Her story has captured the imagination of many writers, and she is variously portrayed as a national and political hero, a model of apolitical straightforwardness and honesty, and a religious heroine. She was canonized in  1920 . More recent influences have included the American film actress  Joan Crawford  (  1908–77 , born  Lucille le Sueur ), the British actress  Joan Collins  (  b. 1933 ), the American comedienne  Joan Rivers  (  b. 1933 ), and the West Indian pop singer  Joan Armatrading  (  b. 1950 )."],"variants":[{"name":"John","meanings":["Greek: the Lord gave graciously; whom Jehovah gave; whom Jehovah bestowed."]}]},{"name":"de","type":"FIRST","attribution":"Dictionary of First Names © Patrick Hanks and Flavia Hodges 1990, 2003, 2006.","meanings":["‘Attainment’."],"variants":[]}],"lifeSummary":"Baron Joan de Sandford was born in 1235, in Sussex, England, United Kingdom. She had at least 1 son with Waleran de  Monceaux."},"et":{"1235–":"1235–Surnud","–Male":"Surnud","1280–1351":"1280–1351","1235–Female":"1235–Surnud","about 1280":"umbes 1280","1235":"1235","1351":"1351","1280":"1280","Herstmonceux, Sussex, England":"Herstmonceux, Sussex, England","Sussex, England":"Sussex, Inglismaa, United Kingdom"},"fi":{"1235–":"1235–Kuollut","–Male":"Kuollut","1280–1351":"1280–1351","1235–Female":"1235–Kuollut","about 1280":"noin 1280","1235":"1235","1351":"1351","1280":"1280","Herstmonceux, Sussex, England":"Herstmonceux, Sussex, England","Sussex, England":"Sussex, Englanti, Yhdistynyt kuningaskunta"},"fr":{"1235–":"1235–Décédée","–Male":"Décédé","1280–1351":"1280–1351","1235–Female":"1235–Décédée","about 1280":"environ 1280","1235":"1235","1351":"1351","1280":"1280","Herstmonceux, Sussex, England":"Herstmonceux, Sussex, Angleterre","Sussex, England":"Sussex, Angleterre, Royaume-Uni","lifeSummary":"Baron Joan de Sandford est née en 1235, à Sussex, Angleterre, Royaume-Uni. Elle a eu au moins 1 fils avec Waleran de  Monceaux."},"de":{"1235–":"1235–Verstorben","–Male":"Verstorben","1280–1351":"1280–1351","1235–Female":"1235–Verstorben","about 1280":"um 1280","1235":"1235","1351":"1351","1280":"1280","Herstmonceux, Sussex, England":"Herstmonceux, Sussex, England","Sussex, England":"Sussex, England, United Kingdom","lifeSummary":"Baron Joan de Sandford wurde 1235 in Sussex, England, United Kingdom geboren. Sie hatte mit Waleran de  Monceaux mindestens 1 Sohn."},"ht":{"1235–":"1235–Desede","–Male":"Desede","1280–1351":"1280–1351","1235–Female":"1235–Desede","about 1280":"about 1280","1235":"1235","1351":"1351","1280":"1280","Herstmonceux, Sussex, England":"Herstmonceux, Sussex, England","Sussex, England":"Sussex, Angletè, United Kingdom"},"hu":{"1235–":"1235–elhunyt","–Male":"