nts":[{"name":"McKnelly","meanings":["Scottish: variant of   McNelly  ."]},{"name":"McNeilly","meanings":["Irish (Antrim): Anglicized form of Gaelic <b>Mac an Fhilidh</b> ‘son of the poet’."]}]},{"name":"Margaret","type":"FIRST","attribution":"Dictionary of First Names © Patrick Hanks and Flavia Hodges 1990, 2003, 2006.","meanings":["An extremely common given name from the Middle Ages onwards, derived via Old French <i>Marguerite</i> and Latin <i>Margarita</i> from Greek <i>Margarītēs</i>, from <i>margaron</i> ‘pearl’, a word ultimately of Hebrew origin. The name was always understood to mean ‘pearl’ throughout the Middle Ages. The first  St Margaret  was martyred at Antioch in Pisidia during the persecution instigated by the  Emperor Diocletian  in the early 4th century. However, there is some doubt about her name, as the same saint is venerated in the Orthodox Church as   Marina .  There were several other saintly bearers of the name, including St Margaret of Scotland (  d. 1093 ), wife of  King Malcolm Canmore  and daughter of Edmund Ironside of England. It was also the name of the wife of  Henry VI  of England,  Margaret of Anjou  (  1430–82 ), and of  Margaret Tudor  (  1489–1541 ), sister of  Henry VIII , who married James IV of Scotland and ruled as regent there after his death.  See also  Margery  ,   Marjorie ."],"variants":[{"name":"Margareta","meanings":["From the Latin form of Greek <i>Margarītēs</i>.  See  <b>Margaret</b>   ."]},{"name":"Margaretta","meanings":["Formed from Margaret."]}]}],"historicEvents":[{"id":1705197,"age":20,"year":"1455","julianDay":2252488,"title":"Wars of the Roses","description":"Wars of the Roses was a series of English civil wars for control of the throne of England between the royal families House of Lancaster and the House of York. The name of the war was derived as the red rose was the symbol of the Lancastrians and the white rose was the symbol of the Yorks.","url":"https://www.history.com/topics/british-history/wars-of-the-roses","urlTitle":"History - Wars of the Roses","jurisdictionLevel":2}],"lifeSummary":"Margaret W McNelly was born in 1435, in South Crosland, Yorkshire, England. She had at least 1 son with Hugh Crossland. She died in 1455, at the age of 20."},"et":{"1435–1455":"1435–1455","1429–1455":"1429–1455","1456–1513":"1456–1513","1513":"1513","1435":"1435","1456":"1456","1455":"1455","1429":"1429","Crossland Yorkshire, England":"South Crosland, Yorkshire, England","Crossland, Almondbury, West Yorkshire, England":"Almondbury, Yorkshire, Inglismaa, United Kingdom"},"fi":{"1435–1455":"1435–1455","1429–1455":"1429–1455","1456–1513":"1456–1513","1513":"1513","1435":"1435","1456":"1456","1455":"1455","1429":"1429","Crossland Yorkshire, England":"South Crosland, Yorkshire, England","Crossland, Almondbury, West Yorkshire, England":"Almondbury, Yorkshire, Englanti, Yhdistynyt kuningaskunta"},"fr":{"1435–1455":"1435–1455","1429–1455":"1429–1455","1456–1513":"1456–1513","1513":"1513","1435":"1435","1456":"1456","1455":"1455","1429":"1429","Crossland Yorkshire, England":"South Crosland, Everwyck, Angleterre","Crossland, Almondbury, West Yorkshire, England":"Almondbury, Everwyck, Angleterre, Royaume-Uni","lifeSummary":"Margaret W McNelly est née en 1435, à South Crosland, Everwyck, Angleterre. Elle a eu au moins 1 fils avec Hugh Crossland. Elle est décédée en 1455, à l’âge de 20 ans."},"de":{"1435–1455":"1435–1455","1429–1455":"1429–1455","1456–1513":"1456–1513","1513":"1513","1435":"1435","1456":"1456","1455":"1455","1429":"1429","Crossland Yorkshire, England":"South Crosland, Yorkshire, England","Crossland, Almondbury, West Yorkshire, England":"Almondbury, Yorkshire, England, United Kingdom","lifeSummary":"Margaret W McNelly wurde 1435 in South Crosland, Yorkshire, England geboren. Sie hatte mit Hugh Crossland mindestens 1 Sohn. Sie starb 1455 im Alter von 20 Jahren."},"ht":{"1435–1455":"1435–1455","1429–1455":"1429–1455","1456–1513":"1456–1513","1513":"1513","1435":"1435","1456":"