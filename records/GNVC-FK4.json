 1310","1307":"1307","Yorkshire, England":"Yorkshire, England","Bracewell, Yorkshire, England":"Bracewell, Yorkshire, England","nameMeanings":[{"name":"Isabel","type":"FIRST","attribution":"Dictionary of First Names © Patrick Hanks and Flavia Hodges 1990, 2003, 2006.","meanings":["Originally a Spanish version of   Elizabeth  , which was coined by deletion of the first syllable and alteration of the final consonant sound to one that can normally end a word in Spanish. The name was imported into France in the early Middle Ages, and thence into England. It was a royal name, and its enduring popularity may have been enhanced by the fact that it was borne by a queen of England—  Isabella  (  1296–1358 ), daughter of  Philip IV  of France—even though she led a turbulent life and eventually had her husband,  Edward II , murdered."],"variants":[{"name":"Isabell","meanings":["Originally a Spanish version of   Elizabeth  , which was coined by deletion of the first syllable and alteration of the final consonant sound to one that can normally end a word in Spanish. The name was imported into France in the early Middle Ages, and thence into England. It was a royal name, and its enduring popularity may have been enhanced by the fact that it was borne by a queen of England—  Isabella  (  1296–1358 ), daughter of  Philip IV  of France—even though she led a turbulent life and eventually had her husband,  Edward II , murdered."]},{"name":"Isabelle","meanings":["form of   Isabel  , now in frequent use in the English-speaking world."]},{"name":"Isobella","meanings":["form of   Isabel  , which has been popular in England since the 18th century and has recently become the preferred form of the name."]},{"name":"Isobelle","meanings":["Originally a Spanish version of   Elizabeth  , which was coined by deletion of the first syllable and alteration of the final consonant sound to one that can normally end a word in Spanish. The name was imported into France in the early Middle Ages, and thence into England. It was a royal name, and its enduring popularity may have been enhanced by the fact that it was borne by a queen of England—  Isabella  (  1296–1358 ), daughter of  Philip IV  of France—even though she led a turbulent life and eventually had her husband,  Edward II , murdered."]},{"name":"Isobel","meanings":["Variant spelling of   Isabel ."]}]}],"lifeSummary":"Isabel was born about 1294. She had at least 3 sons and 1 daughter with Sir John Tempest."},"et":{"about 1294–":"umbes 1294–Surnud","1283–1356":"1283–1356","1307–1383":"1307–1383","1310–1379":"1310–1379","1315–Female":"1315–Surnud","1316–1361":"1316–1361","1294–Female":"1294–Surnud","about 1294":"umbes 1294","1361":"1361","1383":"1383","1294":"1294","1283":"1283","1316":"1316","1315":"1315","about 1307":"umbes 1307","1379":"1379","about 1316":"umbes 1316","1356":"1356","1310":"1310","about 1315":"umbes 1315","about 1310":"umbes 1310","1307":"1307","Yorkshire, England":"Yorkshire, England","Bracewell, Yorkshire, England":"Bracewell, Yorkshire, England"},"fi":{"about 1294–":"noin 1294–Kuollut","1283–1356":"1283–1356","1307–1383":"1307–1383","1310–1379":"1310–1379","1315–Female":"1315–Kuollut","1316–1361":"1316–1361","1294–Female":"1294–Kuollut","about 1294":"noin 1294","1361":"1361","1383":"1383","1294":"1294","1283":"1283","1316":"1316","1315":"1315","about 1307":"noin 1307","1379":"1379","about 1316":"noin 1316","1356":"1356","1310":"1310","about 1315":"noin 1315","about 1310":"noin 1310","1307":"1307","Yorkshire, England":"Yorkshire, England","Bracewell, Yorkshire, England":"Bracewell, Yorkshire, England"},"fr":{"about 1294–":"environ 1294–Décédée","1283–1356":"1283–1356","1307–1383":"1307–1383","1310–1379":"1310–1379","1315–Female":"1315–Décédée","1316–1361":"1316–1361","1294–Female":"1294–Décédée","about 1294":"environ 1294","1361":"1361","1383":"1383","1294":"1294","1283":"1283","1316":"1316","1315":"1315","about 1307":"environ 1307","1379":"1379","about 1316":"environ 1316","1356":"1356",