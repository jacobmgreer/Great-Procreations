astilla y León, Espanha":"Castilla y León, Spanje","Spain":"Spanje"},"en":{"1175–":"1175–Deceased","1175–Female":"1175–Deceased","–1252":"–1252","–1218":"–1218","1172–Male":"1172–Deceased","1166–1209":"1166–1209","1185–Female":"1185–Deceased","–Female":"Deceased","–1229":"–1229","1130–Male":"1130–Deceased","1131–Female":"1131–Deceased","1200":"1200","1166":"1166","1175":"1175","1131":"1131","1252":"1252","1185":"1185","1130":"1130","1172":"1172","1209":"1209","1229":"1229","1218":"1218","Becerreá, Lugo, Galicia, Spain":"Becerreá, Lugo, Galicia, Spain","Castilla y León, Espanha":"Castilla y León, Spain","Spain":"Spain","nameMeanings":[{"name":"Pérez","type":"LAST","attribution":"Dictionary of American Family Names © Patrick Hanks 2003, 2006.","meanings":["Some characteristic forenames:  Spanish Juan, Manuel, Carlos, Luis, Jesus, Francisco, Pedro, Miguel, Jorge, Ramon, Rafael, Mario.","Spanish (<b>Pérez</b>): patronymic from the personal name <i>Pedro</i>, an equivalent of   Peter  . This surname is also found in France. Compare   De Perez  .","Breton (<b>Pérez</b>): variant of <b>Pérès</b> (see   Peres  )."],"variants":[{"name":"Parez","meanings":["Hispanic: altered form of Spanish <b>Pérez</b> (see   Perez  ).","Czech (<b>Pařez</b>): nickname from <i>pařez</i> ‘(tree) stump’.","In some cases possibly also French (Nord), Walloon, and Flemish: variant of <b>Paré</b> (see   Pare  ) or   Paret  ."]},{"name":"Peter","meanings":["Some characteristic forenames:  German Hans, Kurt, Otto, Ernst, Fritz, Heinz, Helmut, Horst, Kaspar, Klaus, Siegfried, Wolfgang.","English, Scottish, German, Dutch, French (Alsace and Lorraine), Czech (Moravian), Slovak, Croatian, and Slovenian; Hungarian (<b>Péter</b>): from the personal name <i>Peter</i> (Greek <i>Petros</i>, from <i>petra</i> ‘rock’). The personal name was popular throughout Christian Europe in the Middle Ages, having been bestowed by Christ as a byname on the apostle Simon bar Jonah, the brother of Andrew. The name was chosen by Christ for its symbolic significance (John 1:42, Matt. 16:18); Saint Peter is regarded as the founding head of the Christian Church in view of Christ's saying, ‘Thou art Peter and upon this rock I will build my Church’. In Christian Germany in the early Middle Ages this was the most frequent personal name of non-ancient Germanic origin until the 14th century. In North America, this surname has also absorbed cognates from other languages, for example Czech   Petr  , Polish <b>Piotr</b> and <b>Pietr</b>, Albanian <b>Pjetri</b> (from the personal name <i>Pjetër</i>, definite form <i>Pjetri</i>), and also their derivatives (see examples at   Peterson  ). It has also been adopted as a surname by Ashkenazic Jews."]}]},{"name":"de","type":"LAST","attribution":"Dictionary of American Family Names © Patrick Hanks 2003, 2006.","meanings":["Some characteristic forenames:  Indian Dilip, Anirban, Gopal, Alok, Anindya, Arunava, Asit, Asok, Dibyendu, Goutam, Indra, Indranil.","Indian: variant of   Dey  ."],"variants":[{"name":"Dey","meanings":["Some characteristic forenames:  Indian Ashit, Indu, Naina, Partha, Soumya, Ajit, Anjan, Anjana, Anup, Arjun, Arun, Ashim.","English, Scottish, and Welsh: variant of   Day  .","German: topographic name from a field name in North Rhine-Westphalia, denoting a sizeable piece of land, from Middle Low German <i>dē</i> ‘thigh’ (referring to the shape of the property)."]}]},{"name":"Carrión","type":"LAST","attribution":"Dictionary of American Family Names © Patrick Hanks 2003, 2006.","meanings":["Some characteristic forenames:  Spanish Jose, Juan, Carlos, Luis, Ramon, Angel, Manuel, Ramiro, Ricardo, Enrique, Fernando, Julio.","Spanish (<b>Carrión</b>): habitational name from Carrión de los Condes in Palencia or Carrión in Valladolid, from Carrión in the province of Ciudad Real, or Carrión de los Céspedes in Seville."],"variants":[{"name":"Carreon","meanings":["Some characteristic forenames:  Spanish Jose, Juan, Manuel, Arturo, Enrique, Fernando, Jesus, Alfredo, Luis, Juana, Alberto, Carlos.","Spanish (<b>Carreón</b>): variant of name   Carrion  ."]}]}],"historicEvents":[{"id":1354684,"age":25,"year":"1200","julianDay":2159351,"description":"The Christian territory controlled the Kingdoms of Aragon, Navarre, and Castile.","jurisdictionLevel":3}],"lifeSummary":"When Aldonza Pérez de Carrión was born in 1175, in Becerreá, Lugo, Galicia, Spain, her father, Don Pedro Muñoz Corna, was 45 and her mother, Tereza Rodiguez, was 44. She had at least 4 daughters with Rodrigo Fernández de Toroño. She died in Castilla y León, Spain."},"et":{"1175–":"1175–Surnud","1175–Female":"1175–Surnud","–1252":"–1252","–1218":"–1218","1172–Male":"1172–Surnud","1166–1209":"1166–1209","1185–Female":"1185–Surnud","–Female":"Surnud","–1229":"–1229","1130–Male":"1130–Surnud","1131–Female":"1131–Surnud","1200":"1200","1166":"1166","1175":"1175","1131":"1131","1252":"1252","1185":"1185","1130":"1130","1172":"1172","1209":"1209","1229":"1229","1218":"1218","Becerreá, Lugo, Galicia, Spain":"Becerreá, Lugo, Galicia, Hispaania","Castilla y León, Espanha":"Castilla y León, Hispaania","Spain":"Hispaania"},"fi":{"1175–":"1175–Kuollut","1175–Female":"1175–Kuollut","–1252":"–1252","–1218":"–1218","1172–Male":"1172–Kuollut","1166–1209":"1166–1209","1185–Female":"1185–Kuollut","–Female":"Kuollut","–1229":"–1229","1130–Male":"1130–Kuollut","1131–Female":"1131–Kuollut","1200":"1200","1166":"1166","1175":"1175","1131":"1131","1252":"1252","1185":"1185","1130":"1130","1172":"1172","1209":"1209","1229":"1229","1218":"1218","Becerreá, Lugo, Galicia, Spain":"Becerreá, Lugo, Galicia, Espanja","Castilla y León, Espanha":"Castilla y León, Espanja","Spain":"Espanja"},"fr":{"1175–":"1175–Décédée","1175–Female":"1175–Décédée","–1252":"–1252","–1218":"–1218","1172–Male":"1172–Décédé","1166–1209":"1166–1209","1185–Female":"1185–Décédée","–Female":"Décédée","–1229":"–1229","1130–Male":"1130–Décédé","1131–Female":"1131–Décédée","1200":"1200","1166":"1166","1175":"11