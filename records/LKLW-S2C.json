 Kingdom","lifeSummary":"Quando Gerald FitzMaurice Fitzgerald nasceu aproximadamente 1215, em Adare, County Limerick, Irlanda, seu pai, Maurice FitzGerald de Berminham 2nd Lord of Offaly, tinha 22 anos e sua mãe, Juliana Cogan, tinha 17 anos. Ele casou-se com Mrs. Gerald fitz Maurice aproximadamente 1238, em Irlanda. Eles tiveram pelo menos 1 filho e 1 filha. Ele faleceu em 1243, em Gascogne, França, com 29 anos."},"ro":{"about 1215–1243":"aproximativ 1215–1243","1215–1243":"1215–1243","1216–1271":"1216–1271","1218–1277":"1218–1277","1221–Male":"1221–Decedat","1229–1271":"1229–1271","–Female":"Decedată","1240–1309":"1240–1309","–1268":"–1268","1194–1257":"1194–1257","1200–1257":"1200–1257","1240":"1240","1194":"1194","1271":"1271","1216":"1216","1215":"1215","1214":"1214","1257":"1257","1268":"1268","about 1215":"aproximativ 1215","1200":"1200","1277":"1277","1243":"1243","1221":"1221","circa 1238":"aproximativ 1238","1309":"1309","about 1240":"aproximativ 1240","1229":"1229","1218":"1218","Bampton, Devon, England":"Bampton, Devon, England","Of, Adare, Limerick, Ireland":"Adare, County Limerick, Irlanda","Ireland":"Irlanda","Gascogne, France":"Gascogne, Franţa","Aberdare, Mid Glamorgan, Wales":"Aberdare, Mid Glamorgan, Țara Galilor, United Kingdom"},"ru":{"about 1215–1243":"около 1215 г.–1243 г.","1215–1243":"1215г.–1243г.","1216–1271":"1216г.–1271г.","1218–1277":"1218г.–1277г.","1221–Male":"1221г.–Умерший","1229–1271":"1229г.–1271г.","–Female":"Умершая","1240–1309":"1240г.–1309г.","–1268":"–1268г.","1194–1257":"1194г.–1257г.","1200–1257":"1200г.–1257г.","1240":"1240 г.","1194":"1194 г.","1271":"1271 г.","1216":"1216 г.","1215":"1215 г.","1214":"1214 г.","1257":"1257 г.","1268":"1268 г.","about 1215":"около 1215 г.","1200":"1200 г.","1277":"1277 г.","1243":"1243 г.","1221":"1221 г.","circa 1238":"около 1238 г.","1309":"1309 г.","about 1240":"около 1240 г.","1229":"1229 г.","1218":"1218 г.","Bampton, Devon, England":"бамптон, девон, Англия","Of, Adare, Limerick, Irel