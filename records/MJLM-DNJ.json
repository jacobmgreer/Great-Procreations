н, девон, Англия","lifeSummary":"Когда John de Pyn Judge of Assize родился в 1302 г. в местности уптон пин, девон, Англия, его отцу по имени Sir. Herbert IV de Pyn Knight было 68 лет, а матери, которую звали Mrs Herbert de Pyn, 33. Он женился на женщине по имени Mrs. Lady Margery de Pyn в 1326 г. в местности уптон пин, девон, Англия. У них было по крайней мере 3 сына. Он умер около 1335 г. в возрасте 34 лет."},"sm":{"1302–about 1335":"1302–e tusa o le 1335","1302–1335":"1302–1335","1304–Female":"1304–Ua Maliu","1327–1363":"1327–1363","–Male":"UaMaliu","1235–1309":"1235–1309","1270–Female":"1270–Ua Maliu","1363":"1363","1270":"1270","1327":"1327","1326":"1326","1315":"1315","1304":"1304","1302":"1302","1335":"1335","1235":"1235","about 1335":"e tusa o le 1335","1309":"1309","1328":"1328","1317":"1317","Ham, Morwenstow, Cornwall, England":"Morwenstow, Cornwall, Egelani, United Kingdom","Upton Pyne, Devon, England":"Upton Pyne, Devon, Egelani"},"sk":{"1302–about 1335":"1302–okolo 1335","1302–1335":"1302–1335","1304–Female":"1304–Zosnulá","1327–1363":"1327–1363","–Male":"Zosnulý","1235–1309":"1235–1309","1270–Female":"1270–Zosnulá","1363":"1363","1270":"1270","1327":"1327","1326":"1326","1315":"1315","1304":"1304","1302":"1302","1335":"1335","1235":"1235","about 1335":"okolo 1335","1309":"1309","1328":"1328","1317":"1317","Ham, Morwenstow, Cornwall, England":"Morwenstow, Cornwall, Anglicko, Spojené kráľovstvo","Upton Pyne, Devon, England":"Upton Pyne, Devon, England"},"es":{"1302–about 1335":"1302–aproximadamente 1335","1302–1335":"1302–1335","1304–Female":"1304–Fallecida","1327–1363":"1327–1363","–Male":"Fallecido","1235–1309":"1235–1309","1270–Female":"1270–Fallecida","1363":"1363","1270":"1270","1327":"1327","1326":"1326","1315":"1315","1304":"1304","1302":"1302","1335":"1335","1235":"1235","about 1335":"aproximadamente 1335","1309":"1309","1328":"1328","1317":"1317","Ham, Morwenstow, Cornwall, England":"Morwenstow, Cornwall, Inglaterra, Reino Unido","Upton Pyne, Dev