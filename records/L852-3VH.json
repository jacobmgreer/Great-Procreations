":"1304","1303":"1303","1302":"1302","1236":"1236","1301":"1301","1367":"1367","November 1367":"november 1367","1289":"1289","3 October 1330":"3. oktober 1330","Saint Quivox, Prestwick, Ayr, Scotland, United Kingdom":"St Quivox, Ayrshire, Skotland, United Kingdom","Perth, Perthshire, Scotland":"Perth, Perthshire, Skotland","Perth, , Perth, Scotland":"Perth, Perthshire, Skotland, United Kingdom","St Quivox, Ayrshire, Scotland":"St Quivox, Ayrshire, Skotland"},"nl":{"1280–27 November 1367":"1280–27 november 1367","1280–1367":"1280–1367","1289–1330":"1289–1330","1302–1349":"1302–1349","1304–Male":"1304–Overleden","1236–1303":"1236–1303","1240–Female":"1240–Overleden","1330":"1330","18 May 1303":"18 mei 1303","27 November 1367":"27 november 1367","1240":"1240","1260":"1260","1280":"1280","1349":"1349","1304":"1304","1303":"1303","1302":"1302","1236":"1236","1301":"1301","1367":"1367","November 1367":"november 1367","1289":"1289","3 October 1330":"3 oktober 1330","Saint Quivox, Prestwick, Ayr, Scotland, United Kingdom":"St Quivox, Ayrshire, Schotland, Verenigd Koninkrijk","Perth, Perthshire, Scotland":"Perth, Perthshire, Schotland","Perth, , Perth, Scotland":"Perth, Perthshire, Schotland, Verenigd Koninkrijk","St Quivox, Ayrshire, Scotland":"St Quivox, Ayrshire, Schotland"},"en":{"1280–27 November 1367":"1280–27 November 1367","1280–1367":"1280–1367","1289–1330":"1289–1330","1302–1349":"1302–1349","1304–Male":"1304–Deceased","1236–1303":"1236–1303","1240–Female":"1240–Deceased","1330":"1330","18 May 1303":"18 May 1303","27 November 1367":"27 November 1367","1240":"1240","1260":"1260","1280":"1280","1349":"1349","1304":"1304","1303":"1303","1302":"1302","1236":"1236","1301":"1301","1367":"1367","November 1367":"November 1367","1289":"1289","3 October 1330":"3 October 1330","Saint Quivox, Prestwick, Ayr, Scotland, United Kingdom":"St Quivox, Ayrshire, Scotland, United Kingdom","Perth, Perthshire, Scotland":"Perth, Perthshire, Scotland","Perth, , Perth, Scotland":"Perth, Perthshire, Scotland, United Kingdom","St Quivox, Ayrshire, Scotland":"St Quivox, Ayrshire, Scotland","nameMeanings":[{"name":"Dempster","type":"LAST","attribution":"Dictionary of American Family Names © Patrick Hanks 2003, 2006.","meanings":["English, Manx, and Scottish: occupational name for a judge or arbiter of minor disputes, from Middle English <i>demester(e)</i> ‘judge’. Although this was originally a feminine form of the masculine <i>dēmere</i> (see   Deamer  ), by the Middle English period the suffix <i>-stre</i> had lost its feminine force, and the term was used of both sexes. The surname is not common in England, where the term was early replaced by Anglo-Norman French <i>juge</i> (see   Judge  ), but relatively frequent in Scotland, where until 1747 every laird of a barony could have certain offenses within his territory tried by his <i>dempster</i>, and on the Isle of Man, where <i>deemsters</i> also played an important part in the administration of justice."],"variants":[{"name":"Deamer","meanings":["English (Hertfordshire and Bedfordshire): from Middle English <i>demere</i> ‘judge,' later used as a nickname for a censorious person, a self-appointed judge; compare   Deem   and   Dempster  .","Americanized form of German   Diemer  ."]},{"name":"Judge","meanings":["English: occupational name for an officer of justice or a nickname for a solemn and authoritative person thought to behave like a judge, from Middle English, Old French <i>juge</i> ‘judge’ (from Latin <i>iudex</i>, from <i>ius</i> ‘law’ + <i>dicere</i> ‘to say’), which replaced the Old English term <i>dēma</i>. Compare   Dempster  .","Irish (Mayo): part translation of Gaelic <b>Mac an Bhreitheamhain</b>, later <b>Mac an Bhreithimh</b> ‘son of the judge (<i>breitheamhnach</i>)’. Compare   Brain  ."]}]},{"name":"Thomas","type":"FIRST","attribution":"Dictionary of First Names © Patrick Hanks and Flavia Hodges 1990, 2003, 2006.","meanings":["New Testament name, borne by one of Christ's twelve apostles, referred to as ‘Thomas, called Didymus’ (John 11:16; 20:24). <i>Didymos</i> is the Greek word for ‘twin’, and the name is the Greek form of an Aramaic byname meaning ‘twin’. The given name has always been popular throughout Christendom, in part because St Thomas's doubts have made him seem a very human character."],"variants":[]}],"lifeSummary":"When Thomas Dempster Laird of Murisk was born in 1280, in Perth, Perthshire, Scotland, United Kingdom, his father, James Dempster, was 44 and his mother, Mary McCuthon, was 40. He married Eleanor Forbes in 1301, in Perth, Perthshire, Scotland. They were the parents of at least 1 son and 1 daughter. He died on 27 November 1367, in St Quivox, Ayrshire, Scotland, at the age of 87, and was buried in St Quivox, Ayrshire, Scotland, United Kingdom."},"et":{"1280–27 November 1367":"1280–27. november 1367","1280–1367":"1280–1367","1289–1330":"1289–1330","1302–1349":"1302–1349","1304–Male":"1304–Surnud","1236–1303":"1236–1303","1240–Female":"1240–Surnud","1330":"1330","18 May 1303":"18. mai 1303","27 November 1367":"27. november 1367","1240":"1240","1260":"1260","1280":"1280","1349":"1349","1304":"1304","1303":"1303","1302":"1302","1236":"1236","1301":"1301","1367":"1367","November 1367":"november 1367","1289":"1289","3 October 1330":"3. oktoober 1330","Saint Quivox, Prestwick, Ayr, Scotland, United Kingdom":"St Quivox, Ayrshire, Šotimaa, United Kingdom","Perth, Perthshire, Scotland":"Perth, Perthshire, Scotland","Perth, , Perth, Scotland":"Perth, Perthshire, Šotimaa, United Kingdom","St Quivox, Ayrshire, Scotland":"St Quivox, Ayrshire, Scotland"},"fi":{"1280–27 November 1367":"1280–27. marraskuuta 1367","1280–1367":"1280–1367","1289–1330":"1289–1330","1302–1349":"1302–1349","1304–Male":"1304–Kuollut","1236–1303":"1236–1303","1240–Female":"1240–Kuollut","1330":"1330","18 May 1303":"18. toukokuuta 1303","27 November 1367":"27. marraskuuta 1367","1240":"1240","1260":"1260","1280":"1280","1349":"1349","1304":"1304","1303":"1303","130