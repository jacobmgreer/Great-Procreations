191년 영국 잉글랜드 수폴크에서 Mrs Maud De William(와)과 결혼했다. 그들은 적어도 두 명의 아들과 한 명의 딸을 두었다. 그는 1242년 영국 잉글랜드 노르폴크에서 67세의 나이로 사망했다."},"lv":{"1175–1242":"1175.gads–1242.gads","1174–1244":"1174–1244","1192–1229":"1192–1229","1212–Female":"1212.gads–mirusi","1218–1277":"1218.gads–1277","1155–1197":"1155–1197","–Female":"mirusi","about 1191":"ap 1191. gadu","AFT 1229":"pēc 1229. gada","1242":"1242. gads","1175":"1175. gads","1197":"1197","1174":"1174","1192":"1192","1215":"1215","1224":"1224","1212":"1212. gads","1277":"1277","1244":"1244","1155":"1155","before 1175":"pirms 1175. gada","Aft 1197":"pēc 1197. gada","ABT 1192":"ap 1192. gadu","1218":"1218. gads","1229":"1229","Aslacton, Norfolk, England":"Aslacton, Norfolk, England","Depwade Dist, Norfolk, England":"Norfolk, Anglija, Lielbritānija","Of,Framlingham,Suffolk,England":"Framlingham, Suffolk, Anglija, Lielbritānija","England":"England","Bressingham, Norfolk, England":"Bressingham, Norfolk, England",", Suffolkshire, England":"Suffolk, Anglija, Lielbritānija"},"mg":{"1175–1242":"1175–1242","1174–1244":"1174–1244","1192–1229":"1192–1229","1212–Female":"1212–Maty","1218–1277":"1218–1277","1155–1197":"1155–1197","–Female":"Maty","about 1191":"tany ho any amin'ny 1191","AFT 1229":"taorian'ny 1229","1242":"1242","1175":"1175","1197":"1197","1174":"1174","1192":"1192","1215":"1215","1224":"1224","1212":"1212","1277":"1277","1244":"1244","1155":"1155","before 1175":"talohan'ny 1175","Aft 1197":"taorian'ny 1197","ABT 1192":"tany ho any amin'ny 1192","1218":"1218","1229":"1229","Aslacton, Norfolk, England":"Aslacton, Norfolk, England","Depwade Dist, Norfolk, England":"Norfolk, Angletera, United Kingdom","Of,Framlingham,Suffolk,England":"Framlingham, Suffolk, Angletera, United Kingdom","England":"England","Bressingham, Norfolk, England":"Bressingham, Norfolk, England",", Suffolkshire, England":"Suffolk, Angletera, United Kingdom"},"ms":{"1175–1242":"1175–1242","1174–1244":"1174–1244","1192–1229":"1192–1229","1212–Female":"1212–Mati","121