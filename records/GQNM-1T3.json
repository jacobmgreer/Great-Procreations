d, Cherwell, Oxfordshire, England":"Cottisford, Oxfordshire, Engeland, Verenigd Koninkrijk"},"en":{"1380–":"1380–Deceased","1377–Male":"1377–Deceased","1373–1421":"1373–1421","1400–Male":"1400–Deceased","1380–Female":"1380–Deceased","1400":"1400","1421":"1421","1377":"1377","1373":"1373","1380":"1380","England":"England, United Kingdom","Cottisford, Cherwell, Oxfordshire, England":"Cottisford, Oxfordshire, England, United Kingdom","nameMeanings":[{"name":"Vernon","type":"LAST","attribution":"Dictionary of American Family Names © Patrick Hanks 2003, 2006.","meanings":["English (of Norman origin): habitational name from Vernon in Eure, France, named from the Gaulish element <i>ver(n)</i> ‘alder’ + the Gallo-Roman locative suffix <i>-o</i> (genitive <i>-ōnis</i>).","French: habitational name from the same place as in 1 above or from any of several other places in France with the same name and etymology."],"variants":[{"name":"Varnon","meanings":["English (Leicestershire and Northamptonshire): variant of   Vernon  ."]}]},{"name":"Rose","type":"FIRST","attribution":"Dictionary of First Names © Patrick Hanks and Flavia Hodges 1990, 2003, 2006.","meanings":["Ostensibly from the vocabulary word denoting the flower (Latin <i>rosa</i>). However, the name was in use throughout the Middle Ages, long before any of the other girls' names derived from flowers, which are generally of 19th-century origin. In part it may refer to the flower as a symbol of the Virgin Mary, but it seems more likely that it also has a Germanic origin, probably as a short form of various girls' names based on <i>hros</i> ‘horse’ or <i>hrōd</i> ‘fame’. The Latinate form <i>Rohesia</i> is commonly found in documents of the Middle Ages. As well as being a name in its own right, it is currently used as a short form of   Rosemary   and, less often (because of their different pronunciation), of other names beginning <i>Ros-</i>, such as   Rosalind   and   Rosamund ."],"variants":[]}],"lifeSummary":"Rose Vernon was born in 1380, in England, United Kingdom. She had at least 2 sons with Thomas de Arden. She died in her hometown."},"et":{"1380–":"1380–Surnud","1377–Male":"1377–Surnud","1373–1421":"1373–1421","1400–Male":"1400–Surnud","1380–Female":"1380–Surnud","1400":"1400","1421":"1421","1377":"1377","1373":"1373","1380":"1380","England":"Inglismaa, United Kingdom","Cottisford, Cherwell, Oxfordshire, England":"Cottisford, Oxfordshire, Inglismaa, United Kingdom"},"fi":{"1380–":"1380–Kuollut","1377–Male":"1377–Kuollut","1373–1421":"1373–1421","1400–Male":"1400–Kuollut","1380–Female":"1380–Kuollut","1400":"1400","1421":"1421","1377":"1377","1373":"1373","1380":"1380","England":"Englanti, Yhdistynyt kuningaskunta","Cottisford, Cherwell, Oxfordshire, England":"Cottisford, Oxfordshire, Englanti, Yhdistynyt kuningaskunta"},"fr":{"1380–":"1380–Décédée","1377–Male":"1377–Décédé","1373–1421":"1373–1421","1400–Male":"1400–Décédé","1380–Female":"1380–Décédée","1400":"1400","1421":"1421","1377":"1377","1373":"1373","1380":"1380","England":"Angleterre, Royaume-Uni","Cottisford, Cherwell, Oxfordshire, England":"Cottisford, Oxfordshire, Angleterre, Royaume-Uni","lifeSummary":"Rose Vernon est née en 1380, à Angleterre, Royaume-Uni. Elle a eu au moins 2 fils avec Thomas de Arden. Elle est décédée dans sa ville natale."},"de":{"1380–":"1380–Verstorben","1377–Male":"1377–Verstorben","1373–1421":"1373–1421","1400–Male":"1400–Verstorben","1380–Female":"1380–Verstorben","1400":"1400","1421":"1421","1377":"1377","1373":"1373","1380":"1380","England":"England, United Kingdom","Cottisford, Cherwell, Oxfordshire, England":"Cottisford, Oxfordshire, England, United Kingdom","lifeSummary":"Rose Vernon wurde 1380 in England, United Kingdom geboren. Sie hatte mit Thomas de Arden mindestens 2 Söhne. Sie starb in ihrem Geburtsort."},"ht":{"1380–":"1380–Desede","1377–Male":"1377–Desede","1373–1421":"1373–1421","1400–Male":"1400–Desede","1380–Female":"1380–Desede","1400":"1400","1421":"1421","1377":"1377","1