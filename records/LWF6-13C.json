ales":"Llansannor, Glamorgan, Wales"},"nl":{"about 1346–":"circa 1346–Overleden","1302–Male":"1302–Overleden","1346–Male":"1346–Overleden","1350–Female":"1350–Overleden","1372–Female":"1372–Overleden","1375–Male":"1375–Overleden","1377–Female":"1377–Overleden","1272–Male":"1272–Overleden","1296–Female":"1296–Overleden","Abt 1372":"circa 1372","1346":"1346","1302":"1302","1377":"1377","1375":"1375","about 1346":"circa 1346","1296":"1296","1372":"1372","1350":"1350","about 1377":"circa 1377","1272":"1272","about 1375":"circa 1375","Of Breigan, Llansanwyr, Glamorganshire, Wales":"Glamorgan, Wales, Verenigd Koninkrijk","Llansannor, Glamorgan, Wales":"Llansannor, Glamorgan, Wales"},"en":{"about 1346–":"about 1346–Deceased","1302–Male":"1302–Deceased","1346–Male":"1346–Deceased","1350–Female":"1350–Deceased","1372–Female":"1372–Deceased","1375–Male":"1375–Deceased","1377–Female":"1377–Deceased","1272–Male":"1272–Deceased","1296–Female":"1296–Deceased","Abt 1372":"about 1372","1346":"1346","1302":"1302","1377":"1377","1375":"1375","about 1346":"about 1346","1296":"1296","1372":"1372","1350":"1350","about 1377":"about 1377","1272":"1272","about 1375":"about 1375","Of Breigan, Llansanwyr, Glamorganshire, Wales":"Glamorgan, Wales, United Kingdom","Llansannor, Glamorgan, Wales":"Llansannor, Glamorgan, Wales","nameMeanings":[{"name":"ap","type":"LAST","attribution":"Dictionary of American Family Names © Patrick Hanks 2003, 2006.","meanings":["German: variant of   Abt  .","Jewish (eastern Ashkenazic): habitational name from Apt, the Yiddish name of Opatów in Świętokrzyskie Voivodeship, Poland. The placename (in German, Yiddish, and Polish) is from a root meaning ‘abbot’, the place having been named for the local abbey. Compare   Abt  ."],"variants":[{"name":"Abt","meanings":["Some characteristic forenames:  German Helmut, Horst, Johann, Kurt.","German and Dutch: from Middle Low German or Middle Dutch <i>abt</i> ‘abbot’, hence a metonymic occupational name for a servant of an abbot or a nickname for someone thought to resemble an abbot in some way. In some instances it may have been a topographic or habitational name referring to a house named with this word.","Jewish (eastern Ashkenazic): variant of   Abt  , a habitational name from Opatów in Poland."]},{"name":"Apter","meanings":["Some characteristic forenames:  Jewish Avrohom, Bronya, Eliezer, Naftali.","Jewish (Ashkenazic): habitational name for someone from Apt (see   Apt  ).","English: habitational name from Aptor in Marldon, Devon, composed of Old English <i>uppe</i> ‘up, above’ + <i>torr</i> ‘rocky outcrop’."]}]},{"name":"Wyllams","type":"LAST","attribution":"Dictionary of American Family Names © Patrick Hanks 2003, 2006.","meanings":["(1997: 223;2007: 1220; 2010: NA)","English: variant of   Williams  ."],"variants":[{"name":"Williams","meanings":["English: variant of   William  , with genitival or post-medieval excrescent <i>-s</i>. This form of the surname is also common in Wales. In North America, this surname has also absorbed some cognates from other languages, such as Dutch   Willems  . <i>Williams</i> is the third most frequent surname in the US. It is also very common among African Americans and Native Americans.","History: This surname was brought to North America from southern England and Wales independently by many different bearers from the 17th century onward. Roger Williams, born in London in 1603, came to MA in 1630, but the clergyman was banished from the colony for his criticism of the Puritan government; he fled to RI and founded Providence."]}]},{"name":"Thomas","type":"FIRST","attribution":"Dictionary of First Names © Patrick Hanks and Flavia Hodges 1990, 2003, 2006.","meanings":["New Testament name, borne by one of Christ's twelve apostles, referred to as ‘Thomas, called Didymus’ (John 11:16; 20:24). <i>Didymos</i> is the Greek word for ‘twin’, and the name is the Greek form of an Aramaic byname meaning ‘twin’. The given name has always been popular throughout Christendom, in part because St Thomas's doubts have made him seem a very human character."],"variants":[]}],"lifeSummary":"When Thomas ap Wyllams was born about 1346, in Llansannor, Glamorgan, Wales, his father, Thomas Ap Ieuan, was 76 and his mother, Mrs. Thomas ap Ieuan, was 52. He had at least 1 son and 2 daughters with Mrs. Thomas ap Wyllams."},"et":{"about 1346–":"umbes 1346–Surnud","1302–Male":"1302–Surnud","1346–Male":"1346–Surnud","1350–Female":"1350–Surnud","1372–Female":"1372–Surnud","1375–Male":"1375–Surnud","1377–Female":"1377–Surnud","1272–Male":"1272–Surnud","1296–Female":"1296–Surnud","Abt 1372":"umbes 1372","1346":"1346","1302":"1302","1377":"1377","1375":"1375","about 1346":"umbes 1346","1296":"1296","1372":"1372","1350":"1350","about 1377":"umbes 1377","1272":"1272","about 1375":"umbes 1375","Of Breigan, Llansanwyr, Glamorganshire, Wales":"Glamorgan, Wales, United Kingdom","Llansannor, Glamorgan, Wales":"Llansannor, Glamorgan, Wales"},"fi":{"about 1346–":"noin 1346–Kuollut","1302–Male":"1302–Kuollut","1346–Male":"1346–Kuollut","1350–Female":"1350–Kuollut","1372–Female":"1372–Kuollut","1375–Male":"1375–Kuollut","1377–Female":"1377–Kuollut","1272–Male":"1272–Kuollut","1296–Female":"1296–Kuollut","Abt 1372":"noin 1372","1346":"1346","1302":"1302","1377":"1377","1375":"1375","about 1346":"noin 1346","1296":"1296","1372":"1372","1350":"1350","about 1377":"noin 1377","1272":"1272","about 1375":"noin 1375","Of Breigan, Llansanwyr, Glamorganshire, Wales":"Glamorgan, Wales, Yhdistynyt kuningaskunta","Llansannor, Glamorgan, Wales":"Llansannor, Glamorgan, Wales"},"fr":{"about 1346–":"environ 1346–Décédé","1302–Male":"1302–Décédé","1346–Male":"1346–Décédé","1350–Female":"1350–Décédée","1372–Female":"1372–Décédée","1375–Male":"1375–Décédé","1377–Female":"1377–Décédée","1272–Male":"1272–Décédé","1296–Female":"1296–Décédée","Abt 1372":"environ 1372","1346":"1346","1302":"1302","1377":"1377","1375":"1375","about 1346":"environ 1346","1296":"1296","1372":"1372","13