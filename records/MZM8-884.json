 England":"Penrhos, Herefordshire, England, United Kingdom","Llansannor, Glamorgan, Wales":"Llansannor, Glamorgan, Wales","Llanenddwyn, Merionethshire, Wales":"Llanenddwyn, Merionethshire, Wales"},"nl":{"about 1375–":"circa 1375–Overleden","1372–Female":"1372–Overleden","1375–Male":"1375–Overleden","1377–Female":"1377–Overleden","1379–Female":"1379–Overleden","1397–Female":"1397–Overleden","1398–1440":"1398–1440","1346–Male":"1346–Overleden","1350–Female":"1350–Overleden","1346":"1346","1379":"1379","1377":"1377","1398":"1398","1397":"1397","1375":"1375","1440":"1440","1350":"1350","1372":"1372","about 1375":"circa 1375","about 1397":"circa 1397","Penrhos, Herefordshire, England":"Penrhos, Herefordshire, Engeland, Verenigd Koninkrijk","Llansannor, Glamorgan, Wales":"Llansannor, Glamorgan, Wales","Llanenddwyn, Merionethshire, Wales":"Llanenddwyn, Merionethshire, Wales"},"en":{"about 1375–":"about 1375–Deceased","1372–Female":"1372–Deceased","1375–Male":"1375–Deceased","1377–Female":"1377–Deceased","1379–Female":"1379–Deceased","1397–Female":"1397–Deceased","1398–1440":"1398–1440","1346–Male":"1346–Deceased","1350–Female":"1350–Deceased","1346":"1346","1379":"1379","1377":"1377","1398":"1398","1397":"1397","1375":"1375","1440":"1440","1350":"1350","1372":"1372","about 1375":"about 1375","about 1397":"about 1397","Penrhos, Herefordshire, England":"Penrhos, Herefordshire, England, United Kingdom","Llansannor, Glamorgan, Wales":"Llansannor, Glamorgan, Wales","Llanenddwyn, Merionethshire, Wales":"Llanenddwyn, Merionethshire, Wales","nameMeanings":[{"name":"William","type":"LAST","attribution":"Dictionary of American Family Names © Patrick Hanks 2003, 2006.","meanings":["English (of Norman origin): from the Middle English personal name <i>William</i>, <i>Willam</i>, <i>Willem</i>, an Old Picard and Norman French form of ancient Germanic <i>Willihelm</i>, composed of the elements <i>wil-</i> ‘will, desire’ + <i>helm-</i> ‘helmet, protection’. This Norman personal name became widely used in England, Scotland and Wales after the Conquest, mainly no doubt in honor of the Conqueror himself. By the 13th century it had already become the most popular personal name in England. A Parisian form of the name <i>Guillaume</i> was also sometimes used (see   Gillam  ), which in medieval Wales was adopted as <i>Gwilym</i> (see   Gwilliam  ).","Americanized form (translation into English) of French   Guillaume  ."],"variants":[{"name":"Memoli","meanings":["Some characteristic forenames:  Italian Ciro, Francesco, Luciano, Natale, Nino.","Italian:","patronymic or plural form of a pet form of thepersonal name <b>Guglielmo</b>, Italian form of   William  ."]},{"name":"McElligott","meanings":["Some characteristic forenames:  Irish Brigid, Brendan, Seamus.","Irish: Anglicized form of Gaelic <b>Mac Uileagóid</b>, a patronymic from a pet form of the Gaelic form of the personal name   William  ."]},{"name":"McWilliam","meanings":["Some characteristic forenames:  Scottish Iain, Morag.","Scottish and Irish: Anglicized form of Gaelic <b>Mac Uilleim</b>, a patronymic from a Gaelicized form of   William  , also Anglicized as   Williamson   in Scotland. The name is thought to be mainly Scottish in Ulster, though there has been some confusion with   McQuillan   in County Down. In Connacht, McWilliam was a branch of   Burke  ."]},{"name":"Wilcock","meanings":["English (Lancashire and Yorkshire): from the Middle English personal name <i>Wilcoc</i>, a pet form of   William   (composed of the elements   Will   1 + the hypocoristic suffix <i>-cok</i>; see   Cocke  )."]},{"name":"McWilliams","meanings":["Irish (northern): Anglicized form of Gaelic <b>Mac Uilleim</b>, a patronymic from a Gaelicized form of   William  , with excrescent English <i>-s</i>. In Ireland it sometimes represents a partial Gaelicization of Welsh   Williams  ."]},{"name":"Lemmo","meanings":["Some characteristic forenames:  Italian Angelo, Donato, Gino.","Italian (southern): from the personal name <i>Lemmo</i>, a pet form of <i>Guglielmo</i>, an equivalent of   William  . Compare   Lembo  ."]},{"name":"Wilk","meanings":["Some characteristic forenames:  Polish Mariusz, Stanislaw, Tadeusz, Zygmunt, Andrzej, Bogdan, Boguslaw, Casimir, Krzysztof, Stanislawa, Boleslaw, Darek.","Polish: from the vocabulary word <i>wilk</i> ‘wolf’, probably applied as a nickname for someone thought to resemble a wolf or connected with wolves in some way. Alternatively, from an Old Slavic personal name based on <i>vlъkъ</i> ‘wolf’.","English (Staffordshire): from Middle English <i>Wilke</i>, a pet form of   William   and probably a shortening of   Wilkin  . The usage was very likely Flemish in origin."]},{"name":"Wilkin","meanings":["English: from the Middle English personal name <i>Wilkin</i>, a pet form of   William   introduced to England and Scotland by Flemings and Picards after the Norman Conquest.","North German: variant of   Wilken  ."]},{"name":"Gillam","meanings":["English: variant of   Gilliam  .","Welsh: Anglicized form of   Gwilliam  ."]},{"name":"Lembo","meanings":["Some characteristic forenames:  Italian Salvatore, Angelo, Carmelo, Domenic, Pietro, Alfio, Amelio, Antonio, Biagio, Dante, Giovani, Giovanni.","Italian (southern): from a hypercorrected form of <i>Lemmo</i>, a pet form of <i>Guglièlmo</i>, an equivalent of   William  ."]}]},{"name":"Hywel","type":"FIRST","attribution":"Dictionary of First Names © Patrick Hanks and Flavia Hodges 1990, 2003, 2006.","meanings":["Traditional: originally a byname from a vocabulary word meaning ‘eminent, conspicuous’; it was common in the Middle Ages and was revived in the 20th-century."],"variants":[{"name":"Hywell","meanings":["Traditional: originally a byname from a vocabulary word meaning ‘eminent, conspicuous’; it was common in the Middle Ages and was revived in the 20th-century."]},{"name":"Howell","meanings":["Anglicized form of the Welsh name Hywel , or a transferred use of the surname derived from that name."]}]},{"name":"