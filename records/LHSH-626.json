out 1302":"circa 1302","about 1285":"circa 1285","1317":"1317","1306":"1306","Settrington, Yorkshire, England":"Settrington, Yorkshire, England","Seaborough, Dorset, England":"Seaborough, Dorset, England","Dorset, England":"Dorset, England"},"en":{"about 1285–about 1323":"about 1285–about 1323","1274–1320":"1274–1320","1300–1342":"1300–1342","1302–Male":"1302–Deceased","1304–Female":"1304–Deceased","1306–Female":"1306–Deceased","1285–1323":"1285–1323","1285":"1285","1274":"1274","1290":"1290","1315":"1315","1304":"1304","1302":"1302","1323":"1323","1300":"1300","about 1306":"about 1306","about 1304":"about 1304","1320":"1320","1342":"1342","about 1323":"about 1323","about 1302":"about 1302","about 1285":"about 1285","1317":"1317","1306":"1306","Settrington, Yorkshire, England":"Settrington, Yorkshire, England","Seaborough, Dorset, England":"Seaborough, Dorset, England","Dorset, England":"Dorset, England","nameMeanings":[{"name":"Joan","type":"FIRST","attribution":"Dictionary of First Names © Patrick Hanks and Flavia Hodges 1990, 2003, 2006.","meanings":["Contracted form of Old French <i>Jo(h)anne</i>, from Latin <i>Io(h)anna</i> (  see  Joanna  ). In England this was the usual feminine form of   John   from the Middle English period onwards and was extremely popular, but in the 16th and 17th centuries it steadily lost ground to   Jane .  It was strongly revived in the first part of the 20th century, partly under the influence of  George Bernard Shaw's  play St Joan (  1923 ), based on the life of  Joan of Arc  (  1412–31 ). Claiming to be guided by the voices of the saints, she persuaded the French dauphin to defy the occupying English forces and have himself crowned, and she led the French army that raised the siege of Orleans in  1429 . The following year she was captured by the Burgundians and sold to the English, and a year later she was burned at the stake for witchcraft at the age of 18 or 19. Her story has captured the imagination of many writers, and she is variously portrayed as a national and political hero, a model of apolitical straightforwardness and honesty, and a religious heroine. She was canonized in  1920 . More recent influences have included the American film actress  Joan Crawford  (  1908–77 , born  Lucille le Sueur ), the British actress  Joan Collins  (  b. 1933 ), the American comedienne  Joan Rivers  (  b. 1933 ), and the West Indian pop singer  Joan Armatrading  (  b. 1950 )."],"variants":[{"name":"John","meanings":["As a boy's name this represents a revival of Middle English <i>Jan</i>, a by‐form of   John  , or an adoption of the common European form with this spelling. As a girl's name it is a short form of names such as   Janet   and   Janice ."]}]}],"historicEvents":[{"id":1705190,"age":5,"year":"1290","julianDay":2192224,"title":"Jews Expelled From England","description":"After years of anti-Semitic behavior, King Edward I expelled Jews from England in 1290.","jurisdictionLevel":2},{"id":1705191,"age":30,"year":"1315","toYear":"1317","julianDay":2201354,"title":"Famine Strikes Europe","description":"A famine caused by cold winters and wet summers across Europe caused millions to die due to starvation. Desperation from hunger caused high levels of crime, stampedes in bread lines in London, infanticide, and even cannibalism throughout Europe.","jurisdictionLevel":2}],"lifeSummary":"Lady Joan was born about 1285, in Settrington, Yorkshire, England. She had at least 2 sons and 2 daughters with John Gould. She died about 1323, in Seaborough, Dorset, England, at the age of 40."},"et":{"about 1285–about 1323":"umbes 1285–umbes 1323","1274–1320":"1274–1320","1300–1342":"1300–1342","1302–Male":"1302–Surnud","1304–Female":"1304–Surnud","1306–Female":"1306–Surnud","1285–1323":"1285–1323","1285":"1285","1274":"1274","1290":"1290","1315":"1315","1304":"1304","1302":"1302","1323":"1323","1300":"1300","about 1306":"umbes 1306","about 1304":"umbes 1304","1320":"1320","1342":"1342","about 1323":"umbes 1323","ab