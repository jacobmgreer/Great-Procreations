and":"Perth, Perthshire, Scotland, United Kingdom","Ruthven, Perthshire, Scotland":"Ruthven, Perthshire, Scotland","Scotland":"Scotland, United Kingdom","nameMeanings":[{"name":"de","type":"LAST","attribution":"Dictionary of American Family Names © Patrick Hanks 2003, 2006.","meanings":["Some characteristic forenames:  Indian Dilip, Anirban, Gopal, Alok, Anindya, Arunava, Asit, Asok, Dibyendu, Goutam, Indra, Indranil.","Indian: variant of   Dey  ."],"variants":[{"name":"Dey","meanings":["Some characteristic forenames:  Indian Ashit, Indu, Naina, Partha, Soumya, Ajit, Anjan, Anjana, Anup, Arjun, Arun, Ashim.","English, Scottish, and Welsh: variant of   Day  .","German: topographic name from a field name in North Rhine-Westphalia, denoting a sizeable piece of land, from Middle Low German <i>dē</i> ‘thigh’ (referring to the shape of the property)."]}]},{"name":"Ruthven","type":"LAST","attribution":"Dictionary of American Family Names © Patrick Hanks 2003, 2006.","meanings":["Scottish: habitational name, traditionally pronounced ‘Ri-ven’, from Ruthven by Huntingtower (Perthshire); also possibly from Ruthven (Angus) and various other places of that name throughout Scotland, named either with Gaelic <i>ruadh</i> ‘red’ + <i>mhaighin</i> ‘place’ or with a cognate of Welsh <i>rhudd faen</i> ‘red stone’. The oldest family of this name, the lords of the barony of Ruthven by Perth, were descended from Thor, son of Swain, lord of Tranent in Lothian and first sheriff of Edinburgh on record in the mid 12th century. The family eventually gained the title of Earl of Gowrie, but because of what became known as ‘the Gowrie Conspiracy’ the title was forfeited and from 1600 to 1641 the surname itself was proscribed. The title was later restored to the family, and the present Earl of Gowrie bears the surname <i>Ruthven</i>."],"variants":[]},{"name":"Walter","type":"FIRST","attribution":"Dictionary of First Names © Patrick Hanks and Flavia Hodges 1990, 2003, 2006.","meanings":["From an Old French personal name of Germanic (Frankish) origin, derived from <i>wald</i> ‘rule’ + <i>heri</i>, <i>hari</i> ‘army’. This was adopted by the Normans and introduced by them to England, superseding the native Old English form, <i>Wealdhere</i>. It was a very popular name in medieval England, normally pronounced ‘Water’."],"variants":[{"name":"Walther","meanings":["from <i>wald</i> ‘rule’ + <i>heri</i> ‘army’; name of the famous medieval minnesinger  Walther von der Vogelweide  (  <i>c.</i>1170– <i>c.</i>1230 )."]}]}],"lifeSummary":"Walter de Ruthven was born in Ruthven, Perthshire, Scotland, United Kingdom as the son of Alan Ruthven, 1st Lord of Ruthven. He had at least 1 son with Cecilia Strathearn. In 1313, his occupation is listed as sheriff of st. johnston (appointed by robert the bruce). He died about 1272, in Perth, Perthshire, Scotland, United Kingdom."},"et":{"–Abt 1272":"–umbes 1272","1180–Male":"1180–Surnud","1188–Male":"1188–Surnud","–1272":"–1272","1180–1250":"1180–1250","1225–1298":"1225–1298","1165–1240":"1165–1240","Abt 1272":"umbes 1272","1225":"1225","1298":"1298","1188":"1188","1165":"1165","Aft 1250":"pärast 1250","Abt 1225":"umbes 1225","1240":"1240","1250":"1250","1272":"1272","1180":"1180","Perth, Perthshire, Scotland":"Perth, Perthshire, Šotimaa, United Kingdom","Ruthven, Perthshire, Scotland":"Ruthven, Perthshire, Scotland","Scotland":"Šotimaa, United Kingdom"},"fi":{"–Abt 1272":"–noin 1272","1180–Male":"1180–Kuollut","1188–Male":"1188–Kuollut","–1272":"–1272","1180–1250":"1180–1250","1225–1298":"1225–1298","1165–1240":"1165–1240","Abt 1272":"noin 1272","1225":"1225","1298":"1298","1188":"1188","1165":"1165","Aft 1250":"1250 jälkeen","Abt 1225":"noin 1225","1240":"1240","1250":"1250","1272":"1272","1180":"1180","Perth, Perthshire, Scotland":"Perth, Perthshire, Skotlanti, Yhdistynyt kuningaskunta","Ruthven, Perthshire, Scotland":"Ruthven, Perthshire, Scotland","Scotland":"Skotlanti, Yhdistynyt kuningaskunta"},"fr":{"–Abt 1272":"–environ 1272