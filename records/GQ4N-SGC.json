549":"1549","Kent, England":"Kent, England","Canterbury, Kent, England":"Canterbury, Kent, England, United Kingdom","nameMeanings":[{"name":"Stella","type":"FIRST","attribution":"Dictionary of First Names © Patrick Hanks and Flavia Hodges 1990, 2003, 2006.","meanings":["From Latin <i>stella</i> ‘star’. This was not used as a given name before the 16th century, when  Sir Philip Sidney  seems to have been the first to use it (as a name deliberately far removed from the prosaic range of everyday names) in the sonnets addressed by Astrophel to his lady, Stella. <i>Stella Maris</i> ‘star of the sea’ was, however, established long before that as a byname of the Virgin Mary, and may have had some influence on the choice of the word as a name."],"variants":[]}],"historicEvents":[{"id":1705201,"age":29,"year":"1549","julianDay":2286821,"title":"Book of Common Prayer","description":"Book of Common Prayer, a product of the English Reformation, was published in 1549 for assistance in the administration of the sacraments and other rites and ceremonies of the church according to the use of the Church of England. The book outlined morning, evening, and communion prayers and orders for baptism and marriage, thus making England a truly Protestant state.","url":"https://en.wikipedia.org/wiki/Book_of_Common_Prayer","urlTitle":"Wikipedia - Book of Common Prayer","jurisdictionLevel":1},{"id":1705202,"age":38,"year":"1558","julianDay":2290108,"title":"Act of Uniformity","description":"The Act of Uniformity was passed by the Parliament of England and required all people to go to church once a week. The consequence of not attending church was a fine of 12 pence, which was a considerable amount for a poor person.","jurisdictionLevel":1},{"id":1705205,"age":49,"year":"1569","julianDay":2294126,"title":"State Lottery","description":"A State Lottery was recorded in 1569. The tickets were sold at St. Paul's Cathedral in London.","jurisdictionLevel":1}],"lifeSummary":"Stella was born about 1520, in Kent, England. She had at least 1 daughter with Lett Earl Lott."},"et":{"about 1520–":"umbes 1520–Surnud","1520–Male":"1520–Surnud","1546–1611":"1546–1611","1520–Female":"1520–Surnud","1569":"1569","1558":"1558","1546":"1546","1611":"1611","1520":"1520","30 Jun 1546":"30. juuni 1546","about 1520":"umbes 1520","1549":"1549","Kent, England":"Kent, England","Canterbury, Kent, England":"Canterbury, Kent, Inglismaa, United Kingdom"},"fi":{"about 1520–":"noin 1520–Kuollut","1520–Male":"1520–Kuollut","1546–1611":"1546–1611","1520–Female":"1520–Kuollut","1569":"1569","1558":"1558","1546":"1546","1611":"1611","1520":"1520","30 Jun 1546":"30. kesäkuuta 1546","about 1520":"noin 1520","1549":"1549","Kent, England":"Kent, England","Canterbury, Kent, England":"Canterbury, Kent, Englanti, Yhdistynyt kuningaskunta"},"fr":{"about 1520–":"environ 1520–Décédée","1520–Male":"1520–Décédé","1546–1611":"1546–1611","1520–Female":"1520–Décédée","1569":"1569","1558":"1558","1546":"1546","1611":"1611","1520":"1520","30 Jun 1546":"30 juin 1546","about 1520":"environ 1520","1549":"1549","Kent, England":"Kent, Angleterre","Canterbury, Kent, England":"Canterbury, Kent, Angleterre, Royaume-Uni","lifeSummary":"Stella est née environ 1520, à Kent, Angleterre. Elle a eu au moins 1 fille avec Lett Earl Lott."},"de":{"about 1520–":"um 1520–Verstorben","1520–Male":"1520–Verstorben","1546–1611":"1546–1611","1520–Female":"1520–Verstorben","1569":"1569","1558":"1558","1546":"1546","1611":"1611","1520":"1520","30 Jun 1546":"30. Juni 1546","about 1520":"um 1520","1549":"1549","Kent, England":"Kent, England","Canterbury, Kent, England":"Canterbury, Kent, England, United Kingdom","lifeSummary":"Stella wurde um 1520 in Kent, England geboren. Sie hatte mit Lett Earl Lott mindestens 1 Tochter."},"ht":{"about 1520–":"about 1520–Desede","1520–Male":"1520–Desede","1546–1611":"1546–1611","1520–Female":"1520–Desede","1569":"1569","1558":"1558","1546":"1546","1611":"1611","1520":"1520","30 Jun 1546":"30 June 1546",