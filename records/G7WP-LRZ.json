nuary 1410–":"1. siječnja 1410.–preminuo","1420–Female":"1420–preminula","1440–1493":"1440.–1493","1410–Male":"1410–preminuo","1455":"1455","1410":"1410","1420":"1420","1440":"1440.","1493":"1493","1 January 1410":"1. siječnja 1410.","Horbling, Lincolnshire, England":"Horbling, Lincolnshire, England"},"cs":{"1 January 1410–":"1. ledna 1410–Zesnulý","1420–Female":"1420–Zesnulá","1440–1493":"1440–1493","1410–Male":"1410–Zesnulý","1455":"1455","1410":"1410","1420":"1420","1440":"1440","1493":"1493","1 January 1410":"1. ledna 1410","Horbling, Lincolnshire, England":"Horbling, Lincolnshire, Anglie"},"da":{"1 January 1410–":"1. januar 1410–Afdød","1420–Female":"1420–Afdød","1440–1493":"1440–1493","1410–Male":"1410–Afdød","1455":"1455","1410":"1410","1420":"1420","1440":"1440","1493":"1493","1 January 1410":"1. januar 1410","Horbling, Lincolnshire, England":"Horbling, Lincolnshire, England"},"nl":{"1 January 1410–":"1 januari 1410–Overleden","1420–Female":"1420–Overleden","1440–1493":"1440–1493","1410–Male":"1410–Overleden","1455":"1455","1410":"1410","1420":"1420","1440":"1440","1493":"1493","1 January 1410":"1 januari 1410","Horbling, Lincolnshire, England":"Horbling, Lincolnshire, England"},"en":{"1 January 1410–":"1 January 1410–Deceased","1420–Female":"1420–Deceased","1440–1493":"1440–1493","1410–Male":"1410–Deceased","1455":"1455","1410":"1410","1420":"1420","1440":"1440","1493":"1493","1 January 1410":"1 January 1410","Horbling, Lincolnshire, England":"Horbling, Lincolnshire, England","nameMeanings":[{"name":"Pickworth","type":"LAST","attribution":"Dictionary of American Family Names © Patrick Hanks 2003, 2006.","meanings":["English: habitational name from either of two places called Pickworth, in Lincolnshire and Rutland. The placenames derive from an Old English personal name <i>Pīca</i> + Old English <i>worth</i> ‘enclosure’."],"variants":[]},{"name":"Thomas","type":"FIRST","attribution":"Dictionary of First Names © Patrick Hanks and Flavia Hodges 1990, 2003, 2006.","meanings":["New Testament name, borne by one of Christ's twelve apostles, referred to as ‘Thomas, called Didymus’ (John 11:16; 20:24). <i>Didymos</i> is the Greek word for ‘twin’, and the name is the Greek form of an Aramaic byname meaning ‘twin’. The given name has always been popular throughout Christendom, in part because St Thomas's doubts have made him seem a very human character."],"variants":[]},{"name":"Herbert","type":"FIRST","attribution":"Dictionary of First Names © Patrick Hanks and Flavia Hodges 1990, 2003, 2006.","meanings":["From an Old French name of Germanic (Frankish) origin, introduced to Britain by the Normans. It is derived from <i>heri</i>, <i>hari</i> ‘army’ + <i>berht</i> ‘bright, famous’. An Old English form, <i>Herebeorht</i>, existed in England before the Conquest, but was superseded by the Norman form, which gave rise to an important surname. The family in question were earls of Pembroke in the 16th and 17th centuries; they included the poet  George Herbert . By the end of the Middle Ages <i>Herbert</i> was little used, although it remained a favourite with some families, notably the Saint Quintins of East Yorkshire. Its greater frequency in Britain from the 19th century onwards is due partly to the trend for the revival of medieval names of Germanic origin and partly to the trend for the transferred use of surnames."],"variants":[{"name":"Heribert","meanings":["From an Old French name of Germanic (Frankish) origin, introduced to Britain by the Normans. It is derived from <i>heri</i>, <i>hari</i> ‘army’ + <i>berht</i> ‘bright, famous’. An Old English form, <i>Herebeorht</i>, existed in England before the Conquest, but was superseded by the Norman form, which gave rise to an important surname. The family in question were earls of Pembroke in the 16th and 17th centuries; they included the poet  George Herbert . By the end of the Middle Ages <i>Herbert</i> was little used, although it remained a favourite with some families, notably the Saint Quintins of East Yorkshire. Its greater frequency in Britain from the 19th century onwards is due partly to the trend for the revival of medieval names of Germanic origin and partly to the trend for the transferred use of surnames."]}]}],"historicEvents":[{"id":1705197,"age":45,"year":"1455","julianDay":2252488,"title":"Wars of the Roses","description":"Wars of the Roses was a series of English civil wars for control of the throne of England between the royal families House of Lancaster and the House of York. The name of the war was derived as the red rose was the symbol of the Lancastrians and the white rose was the symbol of the Yorks.","url":"https://www.history.com/topics/british-history/wars-of-the-roses","urlTitle":"History - Wars of the Roses","jurisdictionLevel":2}],"lifeSummary":"Thomas Herbert Pickworth was born on 1 January 1410, in Horbling, Lincolnshire, England. He had at least 1 son with Matilda Jane."},"et":{"1 January 1410–":"1. jaanuar 1410–Surnud","1420–Female":"1420–Surnud","1440–1493":"1440–1493","1410–Male":"1410–Surnud","1455":"1455","1410":"1410","1420":"1420","1440":"1440","1493":"1493","1 January 1410":"1. jaanuar 1410","Horbling, Lincolnshire, England":"Horbling, Lincolnshire, England"},"fi":{"1 January 1410–":"1. tammikuuta 1410–Kuollut","1420–Female":"1420–Kuollut","1440–1493":"1440–1493","1410–Male":"1410–Kuollut","1455":"1455","1410":"1410","1420":"1420","1440":"1440","1493":"1493","1 January 1410":"1. tammikuuta 1410","Horbling, Lincolnshire, England":"Horbling, Lincolnshire, England"},"fr":{"1 January 1410–":"1 janvier 1410–Décédé","1420–Female":"1420–Décédée","1440–1493":"1440–1493","1410–Male":"1410–Décédé","1455":"1455","1410":"1410","1420":"1420","1440":"1440","1493":"1493","1 January 1410":"1 janvier 1410","Horbling, Lincolnshire, England":"Horbling, Lincolnshire, Angleterre","lifeSummary":"Thomas Herbert Pickworth est né le 1 janvier 1410, à Horbling, Lincolnshire, Angleterre. Il a eu au moins 1 fils avec Matilda Jane."}