,"1404":"1404","1348":"1348","Abt 1366":"okolo 1366","1455":"1455","1345":"1345","1366":"1366","about 1348":"okolo 1348","1382":"1382","Barton, Westmorland, England":"Barton, Westmorland, Anglie","Sockbridge, Westmorland, England":"Sockbridge and Tirril, Westmorland, Anglie","Smerdale, Westmorland, England":"Westmorland, Anglie"},"da":{"about 1348–":"omkring 1348–Afdød","1345–Male":"1345–Afdød","1366–1404":"1366–1404","1348–Female":"1348–Afdød","1404":"1404","1348":"1348","Abt 1366":"omkring 1366","1455":"1455","1345":"1345","1366":"1366","about 1348":"omkring 1348","1382":"1382","Barton, Westmorland, England":"Barton, Westmorland, England","Sockbridge, Westmorland, England":"Sockbridge and Tirril, Westmorland, England","Smerdale, Westmorland, England":"Westmorland, England"},"nl":{"about 1348–":"circa 1348–Overleden","1345–Male":"1345–Overleden","1366–1404":"1366–1404","1348–Female":"1348–Overleden","1404":"1404","1348":"1348","Abt 1366":"circa 1366","1455":"1455","1345":"1345","1366":"1366","about 1348":"circa 1348","1382":"1382","Barton, Westmorland, England":"Barton, Westmorland, England","Sockbridge, Westmorland, England":"Sockbridge and Tirril, Westmorland, England","Smerdale, Westmorland, England":"Westmorland, England"},"en":{"about 1348–":"about 1348–Deceased","1345–Male":"1345–Deceased","1366–1404":"1366–1404","1348–Female":"1348–Deceased","1404":"1404","1348":"1348","Abt 1366":"about 1366","1455":"1455","1345":"1345","1366":"1366","about 1348":"about 1348","1382":"1382","Barton, Westmorland, England":"Barton, Westmorland, England","Sockbridge, Westmorland, England":"Sockbridge and Tirril, Westmorland, England","Smerdale, Westmorland, England":"Westmorland, England","nameMeanings":[{"name":"Warcop","type":"LAST","attribution":"Dictionary of American Family Names © Patrick Hanks 2003, 2006.","meanings":["English: habitational name from either of two places in Nottinghamshire: Warsop and Worksop. There was confusion between these two placenames from an early date."],"variants":[]},{"name":"Margaret","type":"FIRST","attribution":"Dictionary of First Names © Patrick Hanks and Flavia Hodges 1990, 2003, 2006.","meanings":["An extremely common given name from the Middle Ages onwards, derived via Old French <i>Marguerite</i> and Latin <i>Margarita</i> from Greek <i>Margarītēs</i>, from <i>margaron</i> ‘pearl’, a word ultimately of Hebrew origin. The name was always understood to mean ‘pearl’ throughout the Middle Ages. The first  St Margaret  was martyred at Antioch in Pisidia during the persecution instigated by the  Emperor Diocletian  in the early 4th century. However, there is some doubt about her name, as the same saint is venerated in the Orthodox Church as   Marina .  There were several other saintly bearers of the name, including St Margaret of Scotland (  d. 1093 ), wife of  King Malcolm Canmore  and daughter of Edmund Ironside of England. It was also the name of the wife of  Henry VI  of England,  Margaret of Anjou  (  1430–82 ), and of  Margaret Tudor  (  1489–1541 ), sister of  Henry VIII , who married James IV of Scotland and ruled as regent there after his death.  See also  Margery  ,   Marjorie ."],"variants":[{"name":"Margareta","meanings":["From the Latin form of Greek <i>Margarītēs</i>.  See  <b>Margaret</b>   ."]},{"name":"Margaretta","meanings":["An extremely common given name from the Middle Ages onwards, derived via Old French <i>Marguerite</i> and Latin <i>Margarita</i> from Greek <i>Margarītēs</i>, from <i>margaron</i> ‘pearl’, a word ultimately of Hebrew origin. The name was always understood to mean ‘pearl’ throughout the Middle Ages. The first  St Margaret  was martyred at Antioch in Pisidia during the persecution instigated by the  Emperor Diocletian  in the early 4th century. However, there is some doubt about her name, as the same saint is venerated in the Orthodox Church as   Marina .  There were several other saintly bearers of the name, including St Margaret of Scotland (  d. 1093 ), wife of  King Malcolm Canmore  and daughter of Edmund Ironside of England. It was also the name of the wife of  Henry VI  of England,  Margaret of Anjou  (  1430–82 ), and of  Margaret Tudor  (  1489–1541 ), sister of  Henry VIII , who married James IV of Scotland and ruled as regent there after his death.  See also  Margery  ,   Marjorie ."]}]}],"historicEvents":[{"id":1705195,"age":34,"year":"1382","julianDay":2225826,"title":"Wycliffe's Bible","description":"John Wycliffe, English theologian and professor at the University of Oxford, completed a translation of the Bible from the Latin Vulgate into Middle English. This translation is known as Wycliffe's Bible and was completed around 1382.","url":"https://en.wikipedia.org/wiki/Wycliffe%27s_Bible","urlTitle":"Wikipedia - Wycliffe's Bible","jurisdictionLevel":2},{"id":1705197,"age":107,"year":"1455","julianDay":2252488,"title":"Wars of the Roses","description":"Wars of the Roses was a series of English civil wars for control of the throne of England between the royal families House of Lancaster and the House of York. The name of the war was derived as the red rose was the symbol of the Lancastrians and the white rose was the symbol of the Yorks.","url":"https://www.history.com/topics/british-history/wars-of-the-roses","urlTitle":"History - Wars of the Roses","jurisdictionLevel":2}],"lifeSummary":"Margaret Warcop was born about 1348, in Westmorland, England. She died in Barton, Westmorland, England."},"et":{"about 1348–":"umbes 1348–Surnud","1345–Male":"1345–Surnud","1366–1404":"1366–1404","1348–Female":"1348–Surnud","1404":"1404","1348":"1348","Abt 1366":"umbes 1366","1455":"1455","1345":"1345","1366":"1366","about 1348":"umbes 1348","1382":"1382","Barton, Westmorland, England":"Barton, Westmorland, England","Sockbridge, Westmorland, England":"Sockbridge and Tirril, Westmorland, England","Smerdale, Westmorland, England":"Westmorland, England"},"fi":{"about 1348–":"noin 1348–Kuollut","1345–Male":"1345–Kuollut","1366–1404":"1