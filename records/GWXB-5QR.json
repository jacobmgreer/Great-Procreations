ard em 1534, em Runton, Norfolk, Inglaterra, United Kingdom. Eles tiveram pelo menos 1 filho. Ela faleceu em 10 de janeiro de 1567, em Holbrook, Suffolk, Inglaterra, com 58 anos, e foi sepultada em Auckland St Andrew, Durham, Inglaterra, United Kingdom."},"ro":{"about 1510–10 January 1567":"aproximativ 1510–10 ianuarie 1567","1510–1567":"1510–1567","1516–Female":"1516–Decedată","1510–1572":"1510–1572","1535–1613":"1535–1613","1471–Male":"1471–Decedat","1473–1532":"1473–1532","10 January 1567":"10 ianuarie 1567","1473":"1473","1572":"1572","21 November 1535":"21 noiembrie 1535","1471":"1471","1558":"1558","1613":"1613","1535":"1535","1534":"1534","1567":"1567","1532":"1532","1510":"1510","about 1510":"aproximativ 1510","26 December 1884":"26 decembrie 1884","1549":"1549","1516":"1516","1504":"1504","Auckland St Andrew, Durham, England, United Kingdom":"Auckland St Andrew, Durham, Anglia, United Kingdom","Runton, Norfolk, England":"Runton, Norfolk, Anglia, United Kingdom","Holbrook, Suffolk, England":"Holbrook, Suffolk, England","Suffolk, England":"Suffolk, Anglia, United Kingdom"},"ru":{"about 1510–10 January 1567":"около 1510 г.–10 января 1567 г.","1510–1567":"1510г.–1567г.","1516–Female":"1516г.–Умершая","1510–1572":"1510г.–1572г.","1535–1613":"1535г.–1613г.","1471–Male":"1471г.–Умерший","1473–1532":"1473г.–1532г.","10 January 1567":"10 января 1567 г.","1473":"1473 г.","1572":"1572 г.","21 November 1535":"21 ноября 1535 г.","1471":"1471 г.","1558":"1558 г.","1613":"1613 г.","1535":"1535 г.","1534":"1534 г.","1567":"1567 г.","1532":"1532 г.","1510":"1510 г.","about 1510":"около 1510 г.","26 December 1884":"26 декабря 1884 г.","1549":"1549 г.","1516":"1516 г.","1504":"1504 г.","Auckland St Andrew, Durham, England, United Kingdom":"ауккланд ст андрю, дурам, Англия, Великобритания","Runton, Norfolk, England":"рунтон, норфолк, Англия, Великобритания","Holbrook, Suffolk, England":"холбрук, суффолк, Англия","Suffolk, England":"суффолк, Англия, Великобритания","lifeSummary