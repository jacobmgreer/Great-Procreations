1":"1352–1381","1377–1404":"1377–1404","1379–Male":"1379–Afdød","1325–1420":"1325–1420","1325–1401":"1325–1401","1352":"1352","1350":"1350","1381":"1381","1404":"1404","1348":"1348","1325":"1325","1401":"1401","1379":"1379","1377":"1377","1420":"1420","about 1348":"omkring 1348","about 1379":"omkring 1379","about 1377":"omkring 1377","Deighton, Yorkshire, England":"Deighton, Jórvík, England, United Kingdom","YORKSHIRE, ENGLAND":"Jórvík, England, United Kingdom"},"nl":{"1350–1381":"1350–1381","1348–Male":"1348–Overleden","1352–1381":"1352–1381","1377–1404":"1377–1404","1379–Male":"1379–Overleden","1325–1420":"1325–1420","1325–1401":"1325–1401","1352":"1352","1350":"1350","1381":"1381","1404":"1404","1348":"1348","1325":"1325","1401":"1401","1379":"1379","1377":"1377","1420":"1420","about 1348":"circa 1348","about 1379":"circa 1379","about 1377":"circa 1377","Deighton, Yorkshire, England":"Deighton, Yorkshire, Engeland, Verenigd Koninkrijk","YORKSHIRE, ENGLAND":"Yorkshire, Engeland, Verenigd Koninkrijk"},"en":{"1350–1381":"1350–1381","1348–Male":"1348–Deceased","1352–1381":"1352–1381","1377–1404":"1377–1404","1379–Male":"1379–Deceased","1325–1420":"1325–1420","1325–1401":"1325–1401","1352":"1352","1350":"1350","1381":"1381","1404":"1404","1348":"1348","1325":"1325","1401":"1401","1379":"1379","1377":"1377","1420":"1420","about 1348":"about 1348","about 1379":"about 1379","about 1377":"about 1377","Deighton, Yorkshire, England":"Deighton, Yorkshire, England, United Kingdom","YORKSHIRE, ENGLAND":"Yorkshire, England, United Kingdom","nameMeanings":[{"name":"de","type":"LAST","attribution":"Dictionary of American Family Names © Patrick Hanks 2003, 2006.","meanings":["Some characteristic forenames:  Indian Dilip, Anirban, Gopal, Alok, Anindya, Arunava, Asit, Asok, Dibyendu, Goutam, Indra, Indranil.","Indian: variant of   Dey  ."],"variants":[{"name":"Dey","meanings":["Some characteristic forenames:  Indian Ashit, Indu, Naina, Partha, Soumya, Ajit, Anjan, Anjana, Anup, Arjun, Arun, Ashim.","English, Scottish, and Welsh: variant of   Day  .","German: topographic name from a field name in North Rhine-Westphalia, denoting a sizeable piece of land, from Middle Low German <i>dē</i> ‘thigh’ (referring to the shape of the property)."]}]},{"name":"Deighton","type":"LAST","attribution":"Dictionary of American Family Names © Patrick Hanks 2003, 2006.","meanings":["English (Yorkshire and Durham): habitational name from any of several places in Yorkshire named Deighton, from Old English <i>dīc</i> ‘ditch, dike’ + <i>tūn</i> ‘settlement, enclosure’. See also   Ditton  ."],"variants":[{"name":"Ditton","meanings":["English (Kent): habitational name from any of numerous places called Ditton, for example Ditton in Kent, Buckinghamshire, and Lancashire; Fen Ditton or Wood Ditton in Cambridgeshire; or Thames Ditton or Long Ditton in Surrey, all from Old English <i>dīc</i> ‘ditch, dike’ + <i>tūn</i> ‘enclosure, settlement, farmstead’."]},{"name":"Deaton","meanings":["English (Middlesex): variant of   Deighton  ."]},{"name":"Dinsdale","meanings":["English (northern): habitational name from Over Dinsdale (North Yorkshire) or Low Dinsdale (Durham), which stand on opposite sides of the Tees river. The name arises from Old English <i>Dīctūneshalh</i> ‘nook, recess (Old English <i>halh</i>) belonging to   Deighton  ’."]},{"name":"Deyton","meanings":["English: variant of   Deighton  ."]},{"name":"Dighton","meanings":["English (Huntingdonshire): variant of   Deighton  ."]},{"name":"Dayton","meanings":["English: variant of   Deighton  ."]}]},{"name":"Robert","type":"FIRST","attribution":"Dictionary of First Names © Patrick Hanks and Flavia Hodges 1990, 2003, 2006.","meanings":["One of the many French names of Germanic origin that were introduced into Britain by the Normans; it has since remained in continuous use. It is derived from the nearly synonymous elements <i>hrōd</i> ‘fame’ + <i>berht</i> ‘bright, famous’, and had a native Old English predecessor of similar form (<i>Hreodbeorht</i>), which was supplanted by the Norman name. Two dukes of Normandy in the 11th century bore the name: the father of  William the Conqueror  (sometimes identified with the legendary Robert the Devil), and his eldest son. It was borne also by three kings of Scotland, notably  Robert the Bruce  (  1274–1329 ), who freed Scotland from English domination. The altered short form <i>Bob</i> is very common, but <i>Hob</i> and <i>Dob</i>, which were common in the Middle Ages and gave rise to surnames, are extinct.  See also  Rupert ."],"variants":[]}],"lifeSummary":"When Robert de Deighton was born in 1350, in Deighton, Yorkshire, England, his father, John de Deighton, was 26 and his mother, Alice, was 25. He married Alice De Greystroke about 1377. They were the parents of at least 2 sons. He died in 1381, at the age of 31."},"et":{"1350–1381":"1350–1381","1348–Male":"1348–Surnud","1352–1381":"1352–1381","1377–1404":"1377–1404","1379–Male":"1379–Surnud","1325–1420":"1325–1420","1325–1401":"1325–1401","1352":"1352","1350":"1350","1381":"1381","1404":"1404","1348":"1348","1325":"1325","1401":"1401","1379":"1379","1377":"1377","1420":"1420","about 1348":"umbes 1348","about 1379":"umbes 1379","about 1377":"umbes 1377","Deighton, Yorkshire, England":"Deighton, Yorkshire, Inglismaa, United Kingdom","YORKSHIRE, ENGLAND":"Yorkshire, Inglismaa, United Kingdom"},"fi":{"1350–1381":"1350–1381","1348–Male":"1348–Kuollut","1352–1381":"1352–1381","1377–1404":"1377–1404","1379–Male":"1379–Kuollut","1325–1420":"1325–1420","1325–1401":"1325–1401","1352":"1352","1350":"1350","1381":"1381","1404":"1404","1348":"1348","1325":"1325","1401":"1401","1379":"1379","1377":"1377","1420":"1420","about 1348":"noin 1348","about 1379":"noin 1379","about 1377":"noin 1377","Deighton, Yorkshire, England":"Deighton, Yorkshire, Englanti, Yhdistynyt kuningaskunta","YORKSHIRE, ENGLAND":"Yorkshire, Englanti, Yhdistynyt kuningaskunta"},"fr":{"1350–1381":"1350–1381","1348–Male":"1348–Décédé