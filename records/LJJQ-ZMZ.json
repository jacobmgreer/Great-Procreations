{"version":"1.2","person":{"datePublished":"2023-12-28","name":"Aymery VII de Rochechouart","nameForms":[{"lang":"fr","fullText":"Aymery VII de Rochechouart","parts":[{"type":"http://gedcomx.org/Given","value":"Aymery VII"},{"type":"http://gedcomx.org/Surname","value":"de Rochechouart"}],"order":"EUROTYPIC"}],"gender":"Male","lifespan":"1179–1243","fullLifespan":"1179–1243","portrait":{"url":"https://tree-portraits-pgp.familysearchcdn.org/eby4l/thumb200s.jpg","@type":"ImageObject"},"memoryArtifacts":[{"memoryType":"PHOTO","url":"https://sg30p0.familysearch.org/service/records/storage/dascloud/patron/v2/TH-7767-126693-4296-29/dist.png?ctx=ArtCtxPublic","memoryUrl":"https://www.familysearch.org/photos/artifacts/177758473","thumbnailUrl":"https://sg30p0.familysearch.org/service/records/storage/dascloud/patron/v2/TH-7767-126693-4296-29/thumb200s.jpg?ctx=ArtCtxPublic","deepZoomUrl":"https://sg30p0.familysearch.org/service/records/storage/deepzoomcloud/dzpatron/v1/TH-7767-126693-4296-29/scale?ctx=ArtCtxPublic","headline":"rochechouart Fascé ondé et enté d'argent et de gueules de six pièces.","@type":"ImageObject"}],"birthDate":"+1179","birthPlace":{"address":"Rochechouart, Haute-Vienne, Nouvelle-Aquitaine, France","geo":{"latitude":45.75,"longitude":0.8333,"@type":"GeoCoordinates"},"@type":"Place"},"deathDate":"+1243","deathPlace":{"address":"Rochechouart, Haute-Vienne, Nouvelle-Aquitaine, France","geo":{"latitude":45.75,"longitude":0.8333,"@type":"GeoCoordinates"},"@type":"Place"},"userCertifiedLifeSummary":"Armoirie de la famille de Rochechouart :\n Fascé, ondé et enté d'argent et de gueules de 6 pièces.\ndevise : \nANTE MARE UNDAE\nAVANT QUE LA MER FUT AU MONDE, ROCHECHOUART PORTAIT LES ONDES\nAymeric, 7ème du nom, vicomte de Rochechouard, dit le jeune, fit hommage-lige au roi, en 1234, du château de Buissac. Il était marié, l’an 1205, avec Alix, héritière de Mortemar, fille de Guillaume, seigneur de Mortemar, d’Availles et de Saint-Germain ; elle testa en 1247 et vivait encore en 1255, elle était veuve. De ce mariage naquirent :\n1° Aymeric VIII ;\n2° Foucaud de Rochechouard, seigneur de Saint-Germain, qui fut père, suivant un mémoire de Guy de Rochechouard, lequel de Sibille de Vivonne, eut Guillaume de Rochechouard\n3° Simon de Rochechouard, seigneur d’Availles.\nSources : \n- Nobiliaire du diocèse et de la généralité de Limoges - Tome 4 – page 42 ;\nrelevé JPR Teyssier Chalancon Mangas\n\n","events":[{"name":"Birth","sources":"0","year":"1179","date":"1179","place":"Rochechouart, Haute-Vienne, Nouvelle-Aquitaine, France"},{"name":"Marriage","sources":"0","year":"1205","date":"1205","place":"Rochechouart, Haute-Vienne, Nouvelle-Aquitaine, France","type":"Spousal","age":"26","id":"9CHH-N26"},{"name":"Birth of Child","sources":"0","year":"1210","date":"1210","place":"Rochechouart, Haute-Vienne, Nouvelle-Aquitaine, France","age":"31","id":"LZ85-8KB"},{"name":"Birth of Child","sources":"0","year":"1210","date":"ABT 1210","place":"Rochechouart, Haute-Vienne, Nouvelle-Aquitaine, France","age":"31","id":"9CHC-XJY"},{"name":"TitleOfNobility","sources":"0","year":"1230","date":"from 1230 to 1243","age":"64"},{"name":"Death of Parent","sources":"0","year":"1230","date":"1230","place":"Rochechouart, Limousin, Kingdom of France","age":"51","id":"L7G3-XLN"},{"name":"Death","sources":"0","year":"1243","date":"1243","place":"Rochechouart, Haute-Vienne, Nouvelle-Aquitaine, France","age":"64"},{"name":"Marriage","sources":"0","year":"1180","date":"1180","place":"Rochechouart, Haute-Vienne, Nouvelle-Aquitaine, France","type":"Parental"}],"parent":[{"name":"Aimery VI de Rochechouart Vicomte de Rochechouart","gender":"Male","lifespan":"1155–1230","birthDate":"A+1155","deathDate":"+1230","age":75,"portrait":{"url":"https://tree-portraits-pgp.familysearchcdn.org/1dy4l/thumb64.jpg","@type":"ImageObject"},"@type":"Person","identifier":"L7G3-XLN","url":"https://ancestors.familysearch.org/en/L7G3-XLN/aimery-vi-de-rochechouart-vicomte-de-rochechouart-11