1195":"1195","1195 ":"1195","Normandy, France or Hereford England":"Normandie, Frankrig","Rouen, Seine-Maritime, Normandy, France":"Rouen, Seine-Maritime, Normandie, Frankrig","Normandy, France":"Normandie, Frankrig","Herefordshire, England":"Herefordshire, England","Maldon, Essex, England":"Maldon, Essex, England"},"nl":{"from 1000 to 1020–":"van 1000 to 1020–Overleden","1000–Male":"1000–Overleden","1020–Female":"1020–Overleden","1045–Male":"1045–Overleden","1195–1213":"1195–1213","0950–1015":"0950–1015","0960–Female":"0960–Overleden","0950":"0950","1015":"1015","1213":"1213","0960":"0960","1045":"1045","1000":"1000","from 1000 to 1020":"van 1000 to 1020","from 0980 to 1000":"van 0980 to 1000","1020":"1020","1195":"1195","1195 ":"1195","Normandy, France or Hereford England":"Normandie, Frankrijk","Rouen, Seine-Maritime, Normandy, France":"Rouen, Seine-Maritime, Normandie, Frankrijk","Normandy, France":"Normandie, Frankrijk","Herefordshire, England":"Herefordshire, England","Maldon, Essex, England":"Maldon, Essex, England"},"en":{"from 1000 to 1020–":"from 1000 to 1020–Deceased","1000–Male":"1000–Deceased","1020–Female":"1020–Deceased","1045–Male":"1045–Deceased","1195–1213":"1195–1213","0950–1015":"0950–1015","0960–Female":"0960–Deceased","0950":"0950","1015":"1015","1213":"1213","0960":"0960","1045":"1045","1000":"1000","from 1000 to 1020":"from 1000 to 1020","from 0980 to 1000":"from 0980 to 1000","1020":"1020","1195":"1195","1195 ":"1195","Normandy, France or Hereford England":"Normandy, France","Rouen, Seine-Maritime, Normandy, France":"Rouen, Seine-Maritime, Normandy, France","Normandy, France":"Normandy, France","Herefordshire, England":"Herefordshire, England","Maldon, Essex, England":"Maldon, Essex, England","nameMeanings":[{"name":"Osborne","type":"LAST","attribution":"Dictionary of American Family Names © Patrick Hanks 2003, 2006.","meanings":["English: from the Middle English personal name <i>Osbern</i>, partly from late Old English <i>Ōsbern</i>, an Anglicized form of Old Norse <i>Ásbiǫrn</i> (from <i>áss</i> ‘god’ + <i>biǫrn</i> ‘bear’), but more usually from Norman use of the cognate ancient Germanic <i>Ōsbern</i>. <i>Osbern</i> was often treated as an alternative form of <i>Osbert</i>. For pet forms see   Hoskin   and   Opie  . The surname has also been established in Ireland (Waterford, Tipperary) since the mid 16th century."],"variants":[{"name":"Osbon","meanings":["English (Sussex): variant of   Osborne  ."]},{"name":"Osbourn","meanings":["English: variant of   Osborne  ."]},{"name":"Osbourne","meanings":["English: variant of   Osborne  ."]},{"name":"Oborne","meanings":["English:","habitational name from Oborne in Dorset. The placename derives from Old English <i>wōh</i> ‘twisted, crooked’ + <i>burna</i> ‘spring, stream’.","possibly from the Middle English personal name <i>Obern</i>, an Anglo-Norman French form of <i>Osbern</i> (see   Osborne  )."]},{"name":"Orsburn","meanings":["English: variant of   Osborne  ."]},{"name":"Osbun","meanings":["English: variant of   Osborne  ."]},{"name":"Hoskin","meanings":["English: from the Middle English personal name <i>Osekin</i> with prosthetic <i>H-</i>, a pet form of Anglo-Norman French names beginning with <i>Os-</i> (particularly <i>Osbert</i>, as well as <i>Osbern</i>, and <i>Osmund</i>) + the Flemish diminutive suffix <i>-kin</i>. All three personal names were current in medieval Cornwall or Devon; see   Osborne  ,   Osmond  , and   Opie   (a pet form of <i>Osbert</i>). Old English <i>Ōsbeorn</i>, <i>Ōsbeohrt</i>, and <i>Ōsmund</i> may also have contributed in a minor way to Middle English usage; Middle English   Oswald   is another possible source, but the name was very rare in the late 14th century. For the excrescent initial <i>H-</i>, compare   Herrick  ."]},{"name":"Osborn","meanings":["English: variant of   Osborne  ."]},{"name":"Orsborn","meanings":["English: variant of   Osborne  ."]},{"name":"Oborn","meanings":["English (Somerset): habitational name chiefly from Oborne in Dorset, or perhaps occasionally from Howbourne Farm in Hadlow Down, Sussex, Woburn in Bedfordshire, Woburn Park in Surrey, or Wooburn in Buckinghamshire. The placenames derive from Old English <i>wōh</i> ‘twisted, crooked’ + <i>burna</i> ‘spring, stream’, except Wooburn in Buckinghamshire, which is of uncertain etymology.","English (of Norman origin): perhaps from the Middle English personal name <i>Obern</i>, an Anglo-Norman French form of <i>Osbern</i> (see   Osborne  )."]}]},{"name":"Gilbert","type":"FIRST","attribution":"Dictionary of First Names © Patrick Hanks and Flavia Hodges 1990, 2003, 2006.","meanings":["Old French name of Germanic (Frankish) origin, derived from <i>gisil</i> ‘pledge’ + <i>berht</i> ‘bright, famous’. It was adopted by the Normans and introduced by them to Britain. This was the name of the founder of the only native British religious order (abolished at the Dissolution of the Monasteries),  St Gilbert  of Sempringham (  ?1083–1189 ), in whose honour it is still sometimes bestowed, especially among Roman Catholics. It gained a wider currency in the 19th century."],"variants":[]}],"lifeSummary":"When Count of Brionne Gilbert Osborne was born from 1000 to 1020, in Normandy, France, his father, Count of Eu Geoffrey Osbern or Osborne, was 70 and his mother, Daughter of Fitzgorlin de Rouen, was 60. He married Rohese Gifford in 1045, in Normandy, France. They were the parents of at least 1 son and 1 daughter."},"et":{"from 1000 to 1020–":"1000 kuni 1020–Surnud","1000–Male":"1000–Surnud","1020–Female":"1020–Surnud","1045–Male":"1045–Surnud","1195–1213":"1195–1213","0950–1015":"0950–1015","0960–Female":"0960–Surnud","0950":"0950","1015":"1015","1213":"1213","0960":"0960","1045":"1045","1000":"1000","from 1000 to 1020":"1000 kuni 1020","from 0980 to 1000":"0980 kuni 1000","1020":"1020","1195":"1195","1195 ":"1195","Normandy, France or Hereford England":"Normandie, Prantsusmaa","Rouen, Seine-Maritime, Normandy, France":"Rouen, Sein