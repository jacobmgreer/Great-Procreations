2","24 February 1444":"24. februar 1444","1395":"1395","1340":"1340","1382":"1382","1360":"1360","1446":"1446","1379":"1379","1400":"1400","1455":"1455","1444":"1444","1365":"1365","1420":"1420","about 1379":"omkring 1379","Sawbridgeworth, Hertfordshire, England, United Kingdom":"Sawbridgeworth, Hertfordshire, England, United Kingdom","England":"England, United Kingdom","Warwickshire, England":"Warwickshire, England, United Kingdom","England, United Kingdom":"England, United Kingdom","Penhurst, Sussex, England":"Penhurst, Sussex, England, United Kingdom"},"nl":{"1365–1455":"1365–1455","1379–Female":"1379–Overleden","1360–1444":"1360–1444","1360–Male":"1360–Overleden","1395–1446":"1395–1446","1400–1420":"1400–1420","1340–1382":"1340–1382","1340–1379":"1340–1379","about 1382":"circa 1382","24 February 1444":"24 februari 1444","1395":"1395","1340":"1340","1382":"1382","1360":"1360","1446":"1446","1379":"1379","1400":"1400","1455":"1455","1444":"1444","1365":"1365","1420":"1420","about 1379":"circa 1379","Sawbridgeworth, Hertfordshire, England, United Kingdom":"Sawbridgeworth, Hertfordshire, Engeland, Verenigd Koninkrijk","England":"Engeland, Verenigd Koninkrijk","Warwickshire, England":"Warwickshire, Engeland, Verenigd Koninkrijk","England, United Kingdom":"Engeland, Verenigd Koninkrijk","Penhurst, Sussex, England":"Penhurst, Sussex, Engeland, Verenigd Koninkrijk"},"en":{"1365–1455":"1365–1455","1379–Female":"1379–Deceased","1360–1444":"1360–1444","1360–Male":"1360–Deceased","1395–1446":"1395–1446","1400–1420":"1400–1420","1340–1382":"1340–1382","1340–1379":"1340–1379","about 1382":"about 1382","24 February 1444":"24 February 1444","1395":"1395","1340":"1340","1382":"1382","1360":"1360","1446":"1446","1379":"1379","1400":"1400","1455":"1455","1444":"1444","1365":"1365","1420":"1420","about 1379":"about 1379","Sawbridgeworth, Hertfordshire, England, United Kingdom":"Sawbridgeworth, Hertfordshire, England, United Kingdom","England":"England, United Kingdom","Warwickshire, England":"Warwickshire, England, United Kingdom","England, United Kingdom":"England, United Kingdom","Penhurst, Sussex, England":"Penhurst, Sussex, England, United Kingdom","nameMeanings":[{"name":"Matham","type":"LAST","attribution":"Dictionary of Family Names in Britain and Ireland © University of the West of England 2016","meanings":["1  English: locative name from Mattins Farm in Radwinter or Martinfield Green in Saffron Walden (both Essex).","2  English: locative name from Mathon (Worcs).","3  English: nickname possibly from Middle English  <i>mathme</i>,  <i>mathom</i> ‘treasure, precious gift’ (Old English  <i>māðm</i>,  <i>maððum</i>), though the early bearers cited here may rather belong to (1) or (2)."],"variants":[{"name":"Mattam","meanings":["English: possibly a variant of   Matham  ."]},{"name":"Matthams","meanings":["English: variant of   Matham   with post-medieval excrescent  <i>-s</i>."]}]},{"name":"Margaret","type":"FIRST","attribution":"Dictionary of First Names © Patrick Hanks and Flavia Hodges 1990, 2003, 2006.","meanings":["An extremely common given name from the Middle Ages onwards, derived via Old French <i>Marguerite</i> and Latin <i>Margarita</i> from Greek <i>Margarītēs</i>, from <i>margaron</i> ‘pearl’, a word ultimately of Hebrew origin. The name was always understood to mean ‘pearl’ throughout the Middle Ages. The first  St Margaret  was martyred at Antioch in Pisidia during the persecution instigated by the  Emperor Diocletian  in the early 4th century. However, there is some doubt about her name, as the same saint is venerated in the Orthodox Church as   Marina .  There were several other saintly bearers of the name, including St Margaret of Scotland (  d. 1093 ), wife of  King Malcolm Canmore  and daughter of Edmund Ironside of England. It was also the name of the wife of  Henry VI  of England,  Margaret of Anjou  (  1430–82 ), and of  Margaret Tudor  (  1489–1541 ), sister of  Henry VIII , who married James IV of Scotland and ruled as regent there after his death.  See also  Margery  ,   Marjorie ."],"variants":[{"name":"Margareta","meanings":["From the Latin form of Greek <i>Margarītēs</i>.  See  <b>Margaret</b>   ."]},{"name":"Margaretta","meanings":["An extremely common given name from the Middle Ages onwards, derived via Old French <i>Marguerite</i> and Latin <i>Margarita</i> from Greek <i>Margarītēs</i>, from <i>margaron</i> ‘pearl’, a word ultimately of Hebrew origin. The name was always understood to mean ‘pearl’ throughout the Middle Ages. The first  St Margaret  was martyred at Antioch in Pisidia during the persecution instigated by the  Emperor Diocletian  in the early 4th century. However, there is some doubt about her name, as the same saint is venerated in the Orthodox Church as   Marina .  There were several other saintly bearers of the name, including St Margaret of Scotland (  d. 1093 ), wife of  King Malcolm Canmore  and daughter of Edmund Ironside of England. It was also the name of the wife of  Henry VI  of England,  Margaret of Anjou  (  1430–82 ), and of  Margaret Tudor  (  1489–1541 ), sister of  Henry VIII , who married James IV of Scotland and ruled as regent there after his death.  See also  Margery  ,   Marjorie ."]}]}],"lifeSummary":"When Margaret Matham was born in 1365, in Penhurst, Sussex, England, United Kingdom, her father, Hamelin Matham, was 25 and her mother, Ceciley de Lyons, was 26. She had at least 2 daughters with John Mitchell Esq. She died in 1455, in Warwickshire, England, United Kingdom, at the age of 90."},"et":{"1365–1455":"1365–1455","1379–Female":"1379–Surnud","1360–1444":"1360–1444","1360–Male":"1360–Surnud","1395–1446":"1395–1446","1400–1420":"1400–1420","1340–1382":"1340–1382","1340–1379":"1340–1379","about 1382":"umbes 1382","24 February 1444":"24. veebruar 1444","1395":"1395","1340":"1340","1382":"1382","1360":"1360","1446":"1446","1379":"1379","1400":"1400","1455":"1455","1444":"1444","1365":"1365","1420":"1420","about 1379":"umbes 1379","