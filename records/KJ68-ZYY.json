rthamptonshire, England":"Walgrave, Northamptonshire, England"},"en":{"about 1302–":"about 1302–Deceased","1270–1327":"1270–1327","1300–1330":"1300–1330","1302–Female":"1302–Deceased","1302–Male":"1302–Deceased","1303–1338":"1303–1338","1290–1334":"1290–1334","1324–Male":"1324–Deceased","1328–1393":"1328–1393","1271–1330":"1271–1330","1290–1346":"1290–1346","1330":"1330","1382":"1382","1393":"1393","1271":"1271","1270":"1270","1290":"1290","1338":"1338","1327":"1327","1337":"1337","1315":"1315","1303":"1303","1346":"1346","1324":"1324","1302":"1302","1334":"1334","1300":"1300","1453":"1453","about 1302":"about 1302","about 1324":"about 1324","5 February 1328":"5 February 1328","1317":"1317","1328":"1328","Burrough Green, Cambridgeshire, England":"Burrough Green, Cambridgeshire, England","Europe":"Europe","Walgrave, Northamptonshire, England":"Walgrave, Northamptonshire, England","nameMeanings":[{"name":"Waldegrave","type":"LAST","attribution":"Dictionary of Family Names in Britain and Ireland © University of the West of England 2016","meanings":["English: locative name from Walgrave (Northants), which is recorded as  <i>Waldgrave</i> in 1086."],"variants":[{"name":"Woolgrove","meanings":["English: unexplained, possibly a late variant of   Waldegrave  ."]},{"name":"Allgrove","meanings":["English: unexplained, possibly a variant of   Waldegrave  ."]},{"name":"Walgrave","meanings":["English:  see  Waldegrave  ."]},{"name":"Walgrove","meanings":["English:  see  Waldegrave  ."]}]},{"name":"Margaret","type":"FIRST","attribution":"Dictionary of First Names © Patrick Hanks and Flavia Hodges 1990, 2003, 2006.","meanings":["An extremely common given name from the Middle Ages onwards, derived via Old French <i>Marguerite</i> and Latin <i>Margarita</i> from Greek <i>Margarītēs</i>, from <i>margaron</i> ‘pearl’, a word ultimately of Hebrew origin. The name was always understood to mean ‘pearl’ throughout the Middle Ages. The first  St Margaret  was martyred at Antioch in Pisidia during the persecution instigated by the  Emperor Diocletian  in the early 4th century. However, there is some doubt about her name, as the same saint is venerated in the Orthodox Church as   Marina .  There were several other saintly bearers of the name, including St Margaret of Scotland (  d. 1093 ), wife of  King Malcolm Canmore  and daughter of Edmund Ironside of England. It was also the name of the wife of  Henry VI  of England,  Margaret of Anjou  (  1430–82 ), and of  Margaret Tudor  (  1489–1541 ), sister of  Henry VIII , who married James IV of Scotland and ruled as regent there after his death.  See also  Margery  ,   Marjorie ."],"variants":[{"name":"Margareta","meanings":["From the Latin form of Greek <i>Margarītēs</i>.  See  <b>Margaret</b>   ."]},{"name":"Margaretta","meanings":["An extremely common given name from the Middle Ages onwards, derived via Old French <i>Marguerite</i> and Latin <i>Margarita</i> from Greek <i>Margarītēs</i>, from <i>margaron</i> ‘pearl’, a word ultimately of Hebrew origin. The name was always understood to mean ‘pearl’ throughout the Middle Ages. The first  St Margaret  was martyred at Antioch in Pisidia during the persecution instigated by the  Emperor Diocletian  in the early 4th century. However, there is some doubt about her name, as the same saint is venerated in the Orthodox Church as   Marina .  There were several other saintly bearers of the name, including St Margaret of Scotland (  d. 1093 ), wife of  King Malcolm Canmore  and daughter of Edmund Ironside of England. It was also the name of the wife of  Henry VI  of England,  Margaret of Anjou  (  1430–82 ), and of  Margaret Tudor  (  1489–1541 ), sister of  Henry VIII , who married James IV of Scotland and ruled as regent there after his death.  See also  Margery  ,   Marjorie ."]}]},{"name":"de","type":"FIRST","attribution":"Dictionary of First Names © Patrick Hanks and Flavia Hodges 1990, 2003, 2006.","meanings":["‘Bright’."],"variants":[]}],"historicEvents":[{"id":1705191,"age":13,"year":"1315","toYear":"1317","julianDay":2201354,"title":"Famine Strikes Europe","description":"A famine caused by cold winters and wet summers across Europe caused millions to die due to starvation. Desperation from hunger caused high levels of crime, stampedes in bread lines in London, infanticide, and even cannibalism throughout Europe.","jurisdictionLevel":2},{"id":1705192,"age":26,"year":"1328","julianDay":2206102,"title":"First War of Scottish Independence","description":"The First War of Scottish Independence began after England invaded Scotland in 1296. The Treaty of Edinburgh was signed in 1328 which declared peace between the two kingdoms and brought the war to an end.","jurisdictionLevel":2},{"id":1705193,"age":35,"year":"1337","toYear":"1453","julianDay":2209390,"title":"The Hundred Years' War","description":"The Hundred Years' War between France and England was largely due to the question of legitimate succession to the French crown.","jurisdictionLevel":2},{"id":1705195,"age":80,"year":"1382","julianDay":2225826,"title":"Wycliffe's Bible","description":"John Wycliffe, English theologian and professor at the University of Oxford, completed a translation of the Bible from the Latin Vulgate into Middle English. This translation is known as Wycliffe's Bible and was completed around 1382.","url":"https://en.wikipedia.org/wiki/Wycliffe%27s_Bible","urlTitle":"Wikipedia - Wycliffe's Bible","jurisdictionLevel":2}],"lifeSummary":"When Margaret de Waldegrave was born about 1302, in Walgrave, Northamptonshire, England, her father, Walter Waldegrave, was 32 and her mother, Elizabeth de Neville, was 13. She had at least 2 sons with Thomas de Burgh."},"et":{"about 1302–":"umbes 1302–Surnud","1270–1327":"1270–1327","1300–1330":"1300–1330","1302–Female":"1302–Surnud","1302–Male":"1302–Surnud","1303–1338":"1303–1338","1290–1334":"1290–1334","1324–Male":"1324–Surnud","1328–1393":"1328–1393","1271–1330":"1271–1330","1290–1346":"1290–1346","1330":"133