m":"Derbyshire, Engeland, Verenigd Koninkrijk","Derbyshire, England":"Derbyshire, England","Edensor, Derbyshire, England":"Edensor, Derbyshire, England"},"en":{"about 1105–":"about 1105–Deceased","1105–Male":"1105–Deceased","1130–1086":"1130–1086","–Female":"Deceased","1135–Male":"1135–Deceased","1150–Female":"1150–Deceased","–1166":"–1166","–1192":"–1192","–Male":"Deceased","0990–1086":"0990–1086","about 1150":"about 1150","1086":"1086","1130":"1130","1150":"1150","1192":"1192","1106":"1106","1215":"1215","1105":"1105","1224":"1224","1135":"1135","about 1105":"about 1105","0990":"0990","1166":"1166","about 1135":"about 1135","Derbyshire, England, United Kingdom":"Derbyshire, England, United Kingdom","Derbyshire, England":"Derbyshire, England","Edensor, Derbyshire, England":"Edensor, Derbyshire, England","nameMeanings":[{"name":"Edensor","type":"LAST","attribution":"Dictionary of Family Names in Britain and Ireland © University of the West of England 2016","meanings":["English: locative name from Edensor (Derbys)."],"variants":[{"name":"Endsor","meanings":["English:  see  Edensor  ."]},{"name":"Henser","meanings":["English: variant of   Edensor   with prosthetic  <i>H-</i>."]},{"name":"Enzor","meanings":["English (Derbyshire): variant of   Ensor  . This form of the surname is now rare in Britain."]},{"name":"Enser","meanings":["Some characteristic forenames:  German Heribert.","German: habitational named for someone from any of several places called Ense.","English (Oxfordshire): variant of   Ensor  ."]},{"name":"Hensor","meanings":["English: variant of   Edensor   with prosthetic  <i>H-</i>."]},{"name":"Ensor","meanings":["English: habitational name from Edensor (Derbyshire), from the genitive case of the Old English personal name <i>Ēadin</i> + Old English <i>ofer</i> ‘sloping ridge’."]},{"name":"Enzer","meanings":["English:  see  Edensor  ."]}]},{"name":"Fulcher","type":"LAST","attribution":"Dictionary of American Family Names © Patrick Hanks 2003, 2006.","meanin