75–1212","1155–Female":"1155–Overleden","about 1173":"circa 1173","1212":"1212","1135":"1135","Abt 1155":"circa 1155","1155":"1155","1175":"1175","1150":"1150","1170":"1170","Albon, Drôme, Auvergne-Rhône-Alpes, France":"Albon, Drôme, Auvergne-Rhône-Alpes, Frankrijk","Chamalières, Puy-de-Dôme, Auvergne-Rhône-Alpes, France":"Chamalières, Puy-de-Dôme, Auvergne-Rhône-Alpes, Frankrijk","France":"Frankrijk"},"en":{"Abt 1155–":"about 1155–Deceased","1150–Male":"1150–Deceased","1135–1170":"1135–1170","1175–1212":"1175–1212","1155–Female":"1155–Deceased","about 1173":"about 1173","1212":"1212","1135":"1135","Abt 1155":"about 1155","1155":"1155","1175":"1175","1150":"1150","1170":"1170","Albon, Drôme, Auvergne-Rhône-Alpes, France":"Albon, Drôme, Auvergne-Rhône-Alpes, France","Chamalières, Puy-de-Dôme, Auvergne-Rhône-Alpes, France":"Chamalières, Puy-de-Dôme, Auvergne-Rhône-Alpes, France","France":"France","nameMeanings":[{"name":"D'albon","type":"LAST","attribution":"Dictionary of American Family Names © Patrick Hanks 2003, 2006.","meanings":["English (Staffordshire): nickname or habitational name from Norman French <i>Malbanc</i>, which may be from Old French <i>mal banc</i> ‘bad bench’, but if so the reason for the use of this expression as a surname is unknown. Possibly it derives from a lost placename, in which <i>banc</i> may mean ‘steep crag’. The second part of the name, <i>-banc</i>, survives in   Maybank  , but medieval forms in <i>-ban(e)</i>, <i>-bon(e)</i>, or <i>-bun</i> are also common and are sometimes later re-interpreted as <i>-born</i> and <i>-bourne</i>, leading to confusion with   Melbourne  ."],"variants":[{"name":"Mabon","meanings":["Scottish: from a Brittonic personal name <i>Mabon</i> or <i>Maban</i>, apparently derivatives of <i>Maponos</i>, the name of an ancient Celtic god.","Possibly also English (of Norman origin): variant of   Malbon   with loss of <i>-l-</i>.","In some cases possibly also Breton: ultimately of the same origin as the Scottish name (see 1 above)."]},{"name":"Maybank","meanings":["English (of Norman origin): variant of   Malbon  ."]}]},{"name":"Marquise","type":"FIRST","attribution":"Dictionary of First Names © Patrick Hanks and Flavia Hodges 1990, 2003, 2006.","meanings":["Mainly U.S.: taken from the vocabulary word denoting the rank of nobility (  compare  Earl  ,   Prince  ,   King  ). This derives from Old French <i>marchis</i>, i.e. ‘lord of the marches (border districts)’. The spelling was later influenced by the Provençal and Spanish equivalents. Use as a given name may also have been influenced by the Scottish surname <i>McMarquis</i>, Gaelic <i>Mac Marcuis</i>, a patronymic from   Marcus ."],"variants":[]}],"lifeSummary":"Marquise D'albon was born about 1155, in Albon, Drôme, Auvergne-Rhône-Alpes, France. She married Guillaume De Chamalieres about 1173, in France. They were the parents of at least 2 daughters. She died in Chamalières, Puy-de-Dôme, Auvergne-Rhône-Alpes, France."},"et":{"Abt 1155–":"umbes 1155–Surnud","1150–Male":"1150–Surnud","1135–1170":"1135–1170","1175–1212":"1175–1212","1155–Female":"1155–Surnud","about 1173":"umbes 1173","1212":"1212","1135":"1135","Abt 1155":"umbes 1155","1155":"1155","1175":"1175","1150":"1150","1170":"1170","Albon, Drôme, Auvergne-Rhône-Alpes, France":"Albon, Drôme, Auvergne-Rhône-Alpes, Prantsusmaa","Chamalières, Puy-de-Dôme, Auvergne-Rhône-Alpes, France":"Chamalières, Puy-de-Dôme, Auvergne-Rhône-Alpes, Prantsusmaa","France":"Prantsusmaa"},"fi":{"Abt 1155–":"noin 1155–Kuollut","1150–Male":"1150–Kuollut","1135–1170":"1135–1170","1175–1212":"1175–1212","1155–Female":"1155–Kuollut","about 1173":"noin 1173","1212":"1212","1135":"1135","Abt 1155":"noin 1155","1155":"1155","1175":"1175","1150":"1150","1170":"1170","Albon, Drôme, Auvergne-Rhône-Alpes, France":"Albon, Drôme, Auvergne-Rhône-Alpes, Ranska","Chamalières, Puy-de-Dôme, Auvergne-Rhône-Alpes, France":"Chamalières, Puy-de-Dôme, Auvergne-Rhône-Alpes, Ranska","France":"Ranska"},"fr":{"Abt 1155–