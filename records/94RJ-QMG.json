."]}]}],"lifeSummary":"de Turberville was born in 1205, in Breconshire, Wales, United Kingdom as the daughter of Brim de Turberville of Crucywel. She had at least 2 daughters with Sir David Burchill of Llanfair Cilgedin. She died in Wales."},"et":{"1205–":"1205–Surnud","1205–Female":"1205–Surnud","1202–1272":"1202–1272","1240–Male":"1240–Surnud","1225–1300":"1225–1300","1230–Female":"1230–Surnud","–Female":"Surnud","1180–1281":"1180–1281","1205":"1205","1225":"1225","1202":"1202","1300":"1300","1230":"1230","1240":"1240","1272":"1272","1281":"1281","1180":"1180","Wales":"Wales","Crucywel, Llangatwg, Breconshire, Wales":"Breconshire, Wales, United Kingdom"},"fi":{"1205–":"1205–Kuollut","1205–Female":"1205–Kuollut","1202–1272":"1202–1272","1240–Male":"1240–Kuollut","1225–1300":"1225–1300","1230–Female":"1230–Kuollut","–Female":"Kuollut","1180–1281":"1180–1281","1205":"1205","1225":"1225","1202":"1202","1300":"1300","1230":"1230","1240":"1240","1272":"1272","1281":"1281","1180":"1180","Wales":"Wales","Crucywel, Llangatwg, Breconshire, Wales":"Breconshire, Wales, Yhdistynyt kuningaskunta"},"fr":{"1205–":"1205–Décédée","1205–Female":"1205–Décédée","1202–1272":"1202–1272","1240–Male":"1240–Décédé","1225–1300":"1225–1300","1230–Female":"1230–Décédée","–Female":"Décédée","1180–1281":"1180–1281","1205":"1205","1225":"1225","1202":"1202","1300":"1300","1230":"1230","1240":"1240","1272":"1272","1281":"1281","1180":"1180","Wales":"Galles","Crucywel, Llangatwg, Breconshire, Wales":"Breconshire, Pays de Galles, Royaume-Uni","lifeSummary":"de Turberville est née en 1205, à Breconshire, Pays de Galles, Royaume-Uni, fille de Brim de Turberville of Crucywel. Elle a eu au moins 2 filles avec Sir David Burchill of Llanfair Cilgedin. Elle est décédée à Galles."},"de":{"1205–":"1205–Verstorben","1205–Female":"1205–Verstorben","1202–1272":"1202–1272","1240–Male":"1240–Verstorben","1225–1300":"1225–1300","1230–Female":"1230–Verstorben","–Female":"Verstorben","1180–1281":"1180–1281","1205":