fter 1297":"na 1297","1317":"1317","Somerset, England":"Somerset, Engeland, Verenigd Koninkrijk","Pawlett, Somerset, England":"Pawlett, Somerset, England"},"en":{"ABT 1271–1325":"about 1271–1325","1271–1325":"1271–1325","1271–Male":"1271–Deceased","1275–1297":"1275–1297","1297–1356":"1297–1356","1245–1281":"1245–1281","1245–Female":"1245–Deceased","1297":"1297","1275":"1275","1296":"1296","1271":"1271","1281":"1281","1290":"1290","ABT 1271":"about 1271","1315":"1315","About 1281":"about 1281","1325":"1325","1356":"1356","1245":"1245","after 1297":"after 1297","1317":"1317","Somerset, England":"Somerset, England, United Kingdom","Pawlett, Somerset, England":"Pawlett, Somerset, England","nameMeanings":[{"name":"Paulet","type":"LAST","attribution":"Dictionary of American Family Names © Patrick Hanks 2003, 2006.","meanings":["Spanish: habitational name from any of several places called Paules in the provinces of Zaragoza and Huesca in Aragon, and Albacete.","Americanized form of Greek   Pavlis  ."],"variants":[{"name":"Pavlis","meanings":["Some characteristic forenames:  Greek Despina, Nikolaos, Vasilios.","Greek: from a derivative of the personal name <i>Pavlos</i> (see   Paul  ), or a shortened form of any of various patronymics derived from this name. Compare   Paules   and   Paulis  .","Czech and Slovak (also <b>Pavliš</b>); Croatian (<b>Pavliš</b>): derivative of the personal name   Pavel   (Slovak commonly <i>Pavol</i>, Croatian commonly <i>Pavao</i>), an equivalent of   Paul  . Compare   Paulis  ."]}]},{"name":"William","type":"FIRST","attribution":"Dictionary of First Names © Patrick Hanks and Flavia Hodges 1990, 2003, 2006.","meanings":["Probably the most successful of all the Old French names of Germanic origin that were introduced to England by the Normans. It is derived from Germanic <i>wil</i> ‘will, desire’ + <i>helm</i> ‘helmet, protection’. The fact that it was borne by the Conqueror himself does not seem to have inhibited its favour with the ‘conquered’ population: in the first century after the Conquest it was the commonest male name of all, and not only among the Normans. In the later Middle Ages it was overtaken by   John  , but continued to run second to that name until the 20th century, when the picture became more fragmented."],"variants":[]}],"historicEvents":[{"id":1705190,"age":19,"year":"1290","julianDay":2192224,"title":"Jews Expelled From England","description":"After years of anti-Semitic behavior, King Edward I expelled Jews from England in 1290.","jurisdictionLevel":1},{"id":1705191,"age":44,"year":"1315","toYear":"1317","julianDay":2201354,"title":"Famine Strikes Europe","description":"A famine caused by cold winters and wet summers across Europe caused millions to die due to starvation. Desperation from hunger caused high levels of crime, stampedes in bread lines in London, infanticide, and even cannibalism throughout Europe.","jurisdictionLevel":1}],"lifeSummary":"When Sir William Paulet was born about 1271, in Somerset, England, his father, Walter Paulet, was 28 and his mother, Mrs. Walter Paulet, was 28. He married Idones de Kayle in 1296, in Somerset, England. They were the parents of at least 1 son. He died in 1325, in Somerset, England, United Kingdom, at the age of 55."},"et":{"ABT 1271–1325":"umbes 1271–1325","1271–1325":"1271–1325","1271–Male":"1271–Surnud","1275–1297":"1275–1297","1297–1356":"1297–1356","1245–1281":"1245–1281","1245–Female":"1245–Surnud","1297":"1297","1275":"1275","1296":"1296","1271":"1271","1281":"1281","1290":"1290","ABT 1271":"umbes 1271","1315":"1315","About 1281":"umbes 1281","1325":"1325","1356":"1356","1245":"1245","after 1297":"pärast 1297","1317":"1317","Somerset, England":"Somerset, Inglismaa, United Kingdom","Pawlett, Somerset, England":"Pawlett, Somerset, England"},"fi":{"ABT 1271–1325":"noin 1271–1325","1271–1325":"1271–1325","1271–Male":"1271–Kuollut","1275–1297":"1275–1297","1297–1356":"1297–1356","1245–1281":"1245–1281","1245–Female":"1245–Kuollut","129