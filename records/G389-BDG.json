r de Chandos III 27 und seine Mutter Margaret Giffard 28. Er hat um 1127 in Snodhill, Herefordshire, England Emma of Snodhill geheiratet. Sie hatten mindestens 2 Söhne. Er starb 1193 im Alter von 91 Jahren in Snodhill, Herefordshire, England und wurde in Peterchurch, Herefordshire, England begraben."},"ht":{"1102–1193":"1102–1193","1105–1213":"1105–1213","1107–Female":"1107–Desede","1126–1156":"1126–1156","1128–1196":"1128–1196","1075–1139":"1075–1139","1075–1142":"1075–1142","after 1193":"after 1193","1142":"1142","1075":"1075","1196":"1196","1193":"1193","1107":"1107","1139":"1139","1106":"1106","1128":"1128","1105":"1105","1126":"1126","1213":"1213","1102":"1102","about 1127":"about 1127","1156":"1156","about 1128":"about 1128","about 1156":"about 1156","Newport, Monmouthshire, Wales":"Newport, Monmouthshire, Wales","Newport, Pembrokeshire, Wales":"Newport, Pembrokeshire, Wales","Snodhill, Herefordshire, England":"Snodhill, Herefordshire, England","Peterchurch, Herefordshire, England":"Peterchurch, Herefordshire, England","Goldcliff, Monmouthshire, Wales":"Goldcliff, Monmouthshire, Wales"},"hu":{"1102–1193":"1102–1193","1105–1213":"1105–1213","1107–Female":"1107–elhunyt","1126–1156":"1126–1156","1128–1196":"1128–1196","1075–1139":"1075–1139","1075–1142":"1075–1142","after 1193":"1193 után","1142":"1142","1075":"1075","1196":"1196","1193":"1193","1107":"1107","1139":"1139","1106":"1106","1128":"1128","1105":"1105","1126":"1126","1213":"1213","1102":"1102","about 1127":"1127 körül","1156":"1156","about 1128":"1128 körül","about 1156":"1156 körül","Newport, Monmouthshire, Wales":"Newport, Monmouthshire, Wales","Newport, Pembrokeshire, Wales":"Newport, Pembrokeshire, Wales","Snodhill, Herefordshire, England":"Snodhill, Herefordshire, England","Peterchurch, Herefordshire, England":"Peterchurch, Herefordshire, England","Goldcliff, Monmouthshire, Wales":"Goldcliff, Monmouthshire, Wales"},"id":{"1102–1193":"1102–1193","1105–1213":"1105–1213","1107–Female":"1107–Telah Men