pton Ash, Northamptonshire, England,":"Brampton Ash, Northamptonshire, England, United Kingdom","Burley, Oakham, Rutland, England":"Burley, Rutland, England, United Kingdom","Northamptonshire, England":"Northamptonshire, England","nameMeanings":[{"name":"Picot","type":"LAST","attribution":"Dictionary of American Family Names © Patrick Hanks 2003, 2006.","meanings":["Some characteristic forenames:  French Pierre, Francois, Jacques, Jeanpaul, Luc, Pascal, Yves.  Spanish Esperanza, Aida, Alicia, Ana, Felipe, Luis.","French: from Old French <i>picot</i> ‘pointed object, pickaxe’, a nickname for someone who used such an implement. This surname is also found in Haiti.","Catalan: nickname from Valencian dialect <i>picot</i> ‘(sheep or goat) bell’."],"variants":[{"name":"Pickett","meanings":["English:","from the Middle English, Old French personal name <i>Picot</i>, <i>Pigot</i>, a pet form of <i>Pic</i> (see   Pike   6). In Middle English, the form <i>Piket</i> (Old French <i>Picquet</i>) was also common.","sometimes a late development of   Pickard   1 or 2."]},{"name":"Picotte","meanings":["Some characteristic forenames:  French Honore, Andre, Jacques, Serge.","Altered form of French   Picot  , reflecting the Canadian and American French practice of sounding the final <i>-t</i>."]}]},{"name":"Alice","type":"FIRST","attribution":"Dictionary of First Names © Patrick Hanks and Flavia Hodges 1990, 2003, 2006.","meanings":["Originally a variant of   Adelaide  , representing an Old French spelling of a reduced form of Germanic <i>Adalheidis</i>. <i>Alice</i> and <i>Adelaide</i> were already regarded as distinct names in English during the medieval period. <i>Alice</i> enjoyed a surge of popularity in the 19th century and periods of favour ever since. It was the name of the central character of  Lewis Carroll's  Alice's Adventures in Wonderland (  1865 ) and Through the Looking Glass (  1872 ), who was based on his child friend  Alice Liddell , daughter of the Dean of Christ Church, Oxford."],"variants":[{"name":"Alys","meanings":["Variant spelling of   Alice ."]},{"name":"Alis","meanings":["equivalent of <b>Alice</b> ."]}]}],"historicEvents":[{"id":1705189,"age":33,"year":"1259","julianDay":2180901,"title":"100 Years of Conflict Between England and France Ends","description":"Treaty of Paris was signed on December 4, 1259, which ended 100 years of conflict between England and France.","url":"https://en.wikipedia.org/wiki/Treaty_of_Paris_(1259)","urlTitle":"Wikipedia - Treaty of Paris 1259","jurisdictionLevel":1}],"lifeSummary":"When Alice Picot was born in 1226, in Northamptonshire, England, her father, Peter Picot, was 41 and her mother, Muriel de Somery, was 36. She had at least 1 daughter with Henry d'Armentiers. She died in 1266, in her hometown, at the age of 40."},"et":{"1226–1266":"1226–1266","1315–Male":"1315–Surnud","1224–1255":"1224–1255","–1318":"–1318","1185–1265":"1185–1265","1190–Female":"1190–Surnud","1190":"1190","1315":"1315","1226":"1226","1259":"1259","1224":"1224","1266":"1266","1255":"1255","1265":"1265","before March 1255":"enne märtsi 1255","1185":"1185","1318":"1318","Brampton Ash, Northamptonshire, England,":"Brampton Ash, Northamptonshire, Inglismaa, United Kingdom","Burley, Oakham, Rutland, England":"Burley, Rutland, Inglismaa, United Kingdom","Northamptonshire, England":"Northamptonshire, England"},"fi":{"1226–1266":"1226–1266","1315–Male":"1315–Kuollut","1224–1255":"1224–1255","–1318":"–1318","1185–1265":"1185–1265","1190–Female":"1190–Kuollut","1190":"1190","1315":"1315","1226":"1226","1259":"1259","1224":"1224","1266":"1266","1255":"1255","1265":"1265","before March 1255":"ennen vuotta maaliskuu 1255","1185":"1185","1318":"1318","Brampton Ash, Northamptonshire, England,":"Brampton Ash, Northamptonshire, Englanti, Yhdistynyt kuningaskunta","Burley, Oakham, Rutland, England":"Burley, Rutland, Englanti, Yhdistynyt kuningaskunta","Northamptonshire, England":"Northamptonshire, England"},"fr":{"1226–1266":"1226–12