":"1270–1318","1270–1363":"1270–1363","1275–1363":"1275–1363","–1299":"–1299","1272–1305":"1272–1305","1300–1358":"1300–1358","1235–1299":"1235–1299","1240–1310":"1240–1310","about 1260":"1260","Cir 1305":"1305","1275":"1275","1363":"1363","1240":"1240","1272":"1272","1270":"1270","1290":"1290","1305":"1305","1315":"1315","1358":"1358","1235":"1235","Bef 1299":"vóór 1299","1300":"1300","1310":"1310","1299":"1299","1318":"1318","1317":"1317","Bury, , Lancashire, England - Pilsworth":"Pilsworth, Lancashire, England","Radcliffe, Lancaster, England":"Radcliffe, Lancashire, Engeland, Verenigd Koninkrijk","Lancashire, England":"Lancashire, England","Haslingden, Lancashire, England":"Haslingden, Lancashire, Engeland, Verenigd Koninkrijk"},"en":{"1270–1318":"1270–1318","1270–1363":"1270–1363","1275–1363":"1275–1363","–1299":"–1299","1272–1305":"1272–1305","1300–1358":"1300–1358","1235–1299":"1235–1299","1240–1310":"1240–1310","about 1260":"1260","Cir 1305":"1305","1275":"1275","1363":"1363","1240":"1240","1272":"1272","1270":"1270","1290":"1290","1305":"1305","1315":"1315","1358":"1358","1235":"1235","Bef 1299":"before 1299","1300":"1300","1310":"1310","1299":"1299","1318":"1318","1317":"1317","Bury, , Lancashire, England - Pilsworth":"Pilsworth, Lancashire, England","Radcliffe, Lancaster, England":"Radcliffe, Lancashire, England, United Kingdom","Lancashire, England":"Lancashire, England","Haslingden, Lancashire, England":"Haslingden, Lancashire, England, United Kingdom","nameMeanings":[{"name":"Margaret","type":"FIRST","attribution":"Dictionary of First Names © Patrick Hanks and Flavia Hodges 1990, 2003, 2006.","meanings":["An extremely common given name from the Middle Ages onwards, derived via Old French <i>Marguerite</i> and Latin <i>Margarita</i> from Greek <i>Margarītēs</i>, from <i>margaron</i> ‘pearl’, a word ultimately of Hebrew origin. The name was always understood to mean ‘pearl’ throughout the Middle Ages. The first  St Margaret  was martyred at Antioch in Pisidia during the persecution instigated by the  Emperor Diocletian  in the early 4th century. However, there is some doubt about her name, as the same saint is venerated in the Orthodox Church as   Marina .  There were several other saintly bearers of the name, including St Margaret of Scotland (  d. 1093 ), wife of  King Malcolm Canmore  and daughter of Edmund Ironside of England. It was also the name of the wife of  Henry VI  of England,  Margaret of Anjou  (  1430–82 ), and of  Margaret Tudor  (  1489–1541 ), sister of  Henry VIII , who married James IV of Scotland and ruled as regent there after his death.  See also  Margery  ,   Marjorie ."],"variants":[{"name":"Margareta","meanings":["From the Latin form of Greek <i>Margarītēs</i>.  See  <b>Margaret</b>   ."]},{"name":"Margaretta","meanings":["An extremely common given name from the Middle Ages onwards, derived via Old French <i>Marguerite</i> and Latin <i>Margarita</i> from Greek <i>Margarītēs</i>, from <i>margaron</i> ‘pearl’, a word ultimately of Hebrew origin. The name was always understood to mean ‘pearl’ throughout the Middle Ages. The first  St Margaret  was martyred at Antioch in Pisidia during the persecution instigated by the  Emperor Diocletian  in the early 4th century. However, there is some doubt about her name, as the same saint is venerated in the Orthodox Church as   Marina .  There were several other saintly bearers of the name, including St Margaret of Scotland (  d. 1093 ), wife of  King Malcolm Canmore  and daughter of Edmund Ironside of England. It was also the name of the wife of  Henry VI  of England,  Margaret of Anjou  (  1430–82 ), and of  Margaret Tudor  (  1489–1541 ), sister of  Henry VIII , who married James IV of Scotland and ruled as regent there after his death.  See also  Margery  ,   Marjorie ."]}]}],"historicEvents":[{"id":1705190,"age":20,"year":"1290","julianDay":2192224,"title":"Jews Expelled From England","description":"After years of anti-Semitic behavior, King Edward I