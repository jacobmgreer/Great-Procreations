31":"1364–1431","1361–Female":"1361–Zesnulá","about 1382":"okolo 1382","1361":"1361","1383":"1383","6 December 1431":"6. prosince 1431","1392":"1392","1458":"1458","1412":"1412","1431":"1431","1 January 1418":"1. ledna 1418","1364":"1364","about 1412":"okolo 1412","1418":"1418","about 1383":"okolo 1383","1439":"1439","Cheshire, England":"Cheshire, Anglie","Haslington, Cheshire, England, United Kingdom":"Haslington, Cheshire, Anglie, United Kingdom","Haslington, Cheshire, England":"Haslington, Cheshire, Anglie, United Kingdom"},"da":{"about 1383–1439":"omkring 1383–1439","1383–1439":"1383–1439","1392–Female":"1392–Afdød","1412–Male":"1412–Afdød","1418–1458":"1418–1458","1364–1431":"1364–1431","1361–Female":"1361–Afdød","about 1382":"omkring 1382","1361":"1361","1383":"1383","6 December 1431":"6. december 1431","1392":"1392","1458":"1458","1412":"1412","1431":"1431","1 January 1418":"1. januar 1418","1364":"1364","about 1412":"omkring 1412","1418":"1418","about 1383":"omkring 1383","1439":"1439","Cheshire, England":"Cheshire, England","Haslington, Cheshire, England, United Kingdom":"Haslington, Cheshire, England, United Kingdom","Haslington, Cheshire, England":"Haslington, Cheshire, England, United Kingdom"},"nl":{"about 1383–1439":"circa 1383–1439","1383–1439":"1383–1439","1392–Female":"1392–Overleden","1412–Male":"1412–Overleden","1418–1458":"1418–1458","1364–1431":"1364–1431","1361–Female":"1361–Overleden","about 1382":"circa 1382","1361":"1361","1383":"1383","6 December 1431":"6 december 1431","1392":"1392","1458":"1458","1412":"1412","1431":"1431","1 January 1418":"1 januari 1418","1364":"1364","about 1412":"circa 1412","1418":"1418","about 1383":"circa 1383","1439":"1439","Cheshire, England":"Cheshire, England","Haslington, Cheshire, England, United Kingdom":"Haslington, Cheshire, Engeland, Verenigd Koninkrijk","Haslington, Cheshire, England":"Haslington, Cheshire, Engeland, Verenigd Koninkrijk"},"en":{"about 1383–1439":"about 1383–1439","1383–1439":"1383–1439","1392–Female":"1392–Deceased","1412–Male":"1412–Deceased","1418–1458":"1418–1458","1364–1431":"1364–1431","1361–Female":"1361–Deceased","about 1382":"about 1382","1361":"1361","1383":"1383","6 December 1431":"6 December 1431","1392":"1392","1458":"1458","1412":"1412","1431":"1431","1 January 1418":"1 January 1418","1364":"1364","about 1412":"about 1412","1418":"1418","about 1383":"about 1383","1439":"1439","Cheshire, England":"Cheshire, England","Haslington, Cheshire, England, United Kingdom":"Haslington, Cheshire, England, United Kingdom","Haslington, Cheshire, England":"Haslington, Cheshire, England, United Kingdom","nameMeanings":[{"name":"Vernon","type":"LAST","attribution":"Dictionary of American Family Names © Patrick Hanks 2003, 2006.","meanings":["English (of Norman origin): habitational name from Vernon in Eure, France, named from the Gaulish element <i>ver(n)</i> ‘alder’ + the Gallo-Roman locative suffix <i>-o</i> (genitive <i>-ōnis</i>).","French: habitational name from the same place as in 1 above or from any of several other places in France with the same name and etymology."],"variants":[{"name":"Varnon","meanings":["English (Leicestershire and Northamptonshire): variant of   Vernon  ."]}]},{"name":"Richard","type":"FIRST","attribution":"Dictionary of First Names © Patrick Hanks and Flavia Hodges 1990, 2003, 2006.","meanings":["One of the most enduringly successful of the Old French personal names introduced into Britain by the Normans. It is of Germanic (Frankish) origin, derived from <i>rīc</i> ‘power’ + <i>hard</i> ‘strong, hardy’. It has enjoyed continuous popularity in England from the Conquest to the present day, influenced by the fact that it was borne by three kings of England, in particular  Richard I  (  1157–99 ). He was king for only ten years (  1189–99 ), most of which he spent in warfare abroad, taking part in the Third Crusade and costing the people of England considerable sums in taxes. Nevertheless, he achieved the status of a folk hero, and was never in England long enough to disappoint popular faith in his goodness and justice. He was also Duke of Aquitaine and Normandy and Count of Anjou, fiefs which he held at a time of maximum English expansion in France. His exploits as a leader of the Third Crusade earned him the nickname ‘Coeur de Lion’ or ‘Lionheart’ and a permanent place in popular imagination, in which he was even more firmly enshrined by  Sir Walter Scott's  novel Ivanhoe (  1820 )."],"variants":[{"name":"Rikert","meanings":["One of the most enduringly successful of the Old French personal names introduced into Britain by the Normans. It is of Germanic (Frankish) origin, derived from <i>rīc</i> ‘power’ + <i>hard</i> ‘strong, hardy’. It has enjoyed continuous popularity in England from the Conquest to the present day, influenced by the fact that it was borne by three kings of England, in particular  Richard I  (  1157–99 ). He was king for only ten years (  1189–99 ), most of which he spent in warfare abroad, taking part in the Third Crusade and costing the people of England considerable sums in taxes. Nevertheless, he achieved the status of a folk hero, and was never in England long enough to disappoint popular faith in his goodness and justice. He was also Duke of Aquitaine and Normandy and Count of Anjou, fiefs which he held at a time of maximum English expansion in France. His exploits as a leader of the Third Crusade earned him the nickname ‘Coeur de Lion’ or ‘Lionheart’ and a permanent place in popular imagination, in which he was even more firmly enshrined by  Sir Walter Scott's  novel Ivanhoe (  1820 )."]},{"name":"Rickert","meanings":["One of the most enduringly successful of the Old French personal names introduced into Britain by the Normans. It is of Germanic (Frankish) origin, derived from <i>rīc</i> ‘power’ + <i>hard</i> ‘strong, hardy’. It has enjoyed continuous popularity in England from the Conquest to the present day, influenced by the fact that it was borne by three kings of England, in particular  Richard I  (  1157–99 ). He was king for only ten years (  1189–99 ), most of which he spent in warfare abroad, taking part in the Third Crusade and costing the people of England considerable sums in taxes. Nevertheless, he achieved the status of a folk hero, and was never in England long enough to disappoint popular faith in his goodness and justice. He was also Duke of Aquitaine and Normandy and Count of Anjou, fiefs which he held at a time of maximum English expansion in France. His exploits as a leader of the Third Crusade earned him the nickname ‘Coeur de Lion’ or ‘Lionheart’ and a permanent place in popular imagination, in which he was even more firmly enshrined by  Sir Walter Scott's  novel Ivanhoe (  1820 )."]}]}],"lifeSummary":"When Lord Richard Vernon was born about 1383, in Haslington, Cheshire, England, United Kingdom, his father, Baron Jacob Vernon, was 20 and his mother, Margaret Minshull, was 24. He had at least 2 sons with Jane Tarbock. He died in 1439, in Cheshire, England, United Kingdom, at the age of 57."},"et":{"about 1383–1439":"umbes 1383–1439","1383–1439":"1383–1439","1392–Female":"1392–Surnud","1412–Male":"1412–Surnud","1418–1458":"1418–1458","1364–1431":"1364–1431","1361–Female":"1361–Surnud","about 1382":"umbes 1382","1361":"1361","1383":"1383","6 December 1431":"6. detsember 1431","1392":"1392","1458":"1458","1412":"1412","1431":"1431","1 January 1418":"1. jaanuar 1418","1364":"1364","about 1412":"umbes 1412","1418":"1418","about 1383":"umbes 1383","1439":"1439","Cheshire, England":"Cheshire, England","Haslington, Cheshire, England, United Kingdom":"Haslington, Cheshire, Inglismaa, United Kingdom","Haslington, Cheshire, England":"Haslington, Cheshire, Inglismaa, United Kingdom"},"fi":{"about 1383–1439":"noin 1383–1439","1383–1439":"1383–1439","1392–Female":"1392–Kuollut","1412–Male":"1412–Kuollut","1418–1458":"1418–1458","1364–1431":"1364–1431","1361–Female":"1361–Kuollut","about 1382":"noin 1382","1361":