ffe, Durham, England":"Egglescliffe, Durham, England, United Kingdom","Northumberland, England":"Northumberland, England","Hepple, Northumberland, England":"Hepple, Northumberland, England"},"nl":{"1299–":"1299–Overleden","1299–Female":"1299–Overleden","1315–1365":"1315–1365","1335–1369":"1335–1369","1337–Male":"1337–Overleden","1339–Male":"1339–Overleden","1255–Male":"1255–Overleden","1262–Female":"1262–Overleden","Abt 1335":"circa 1335","1262":"1262","1337":"1337","1315":"1315","1369":"1369","1335":"1335","1322":"1322","about 1339":"circa 1339","1299":"1299","1255":"1255","1365":"1365","about 1337":"circa 1337","1339":"1339","Egglescliffe, Durham, England":"Egglescliffe, Durham, Engeland, Verenigd Koninkrijk","Northumberland, England":"Northumberland, England","Hepple, Northumberland, England":"Hepple, Northumberland, England"},"en":{"1299–":"1299–Deceased","1299–Female":"1299–Deceased","1315–1365":"1315–1365","1335–1369":"1335–1369","1337–Male":"1337–Deceased","1339–Male":"1339–Deceased","1255–Male":"1255–Deceased","1262–Female":"1262–Deceased","Abt 1335":"about 1335","1262":"1262","1337":"1337","1315":"1315","1369":"1369","1335":"1335","1322":"1322","about 1339":"about 1339","1299":"1299","1255":"1255","1365":"1365","about 1337":"about 1337","1339":"1339","Egglescliffe, Durham, England":"Egglescliffe, Durham, England, United Kingdom","Northumberland, England":"Northumberland, England","Hepple, Northumberland, England":"Hepple, Northumberland, England","nameMeanings":[{"name":"Margaret","type":"FIRST","attribution":"Dictionary of First Names © Patrick Hanks and Flavia Hodges 1990, 2003, 2006.","meanings":["An extremely common given name from the Middle Ages onwards, derived via Old French <i>Marguerite</i> and Latin <i>Margarita</i> from Greek <i>Margarītēs</i>, from <i>margaron</i> ‘pearl’, a word ultimately of Hebrew origin. The name was always understood to mean ‘pearl’ throughout the Middle Ages. The first  St Margaret  was martyred at Antioch in Pisidia during the persecution instigated by the  Emperor Diocletian  in the early 4th century. However, there is some doubt about her name, as the same saint is venerated in the Orthodox Church as   Marina .  There were several other saintly bearers of the name, including St Margaret of Scotland (  d. 1093 ), wife of  King Malcolm Canmore  and daughter of Edmund Ironside of England. It was also the name of the wife of  Henry VI  of England,  Margaret of Anjou  (  1430–82 ), and of  Margaret Tudor  (  1489–1541 ), sister of  Henry VIII , who married James IV of Scotland and ruled as regent there after his death.  See also  Margery  ,   Marjorie ."],"variants":[{"name":"Margareta","meanings":["From the Latin form of Greek <i>Margarītēs</i>.  See  <b>Margaret</b>   ."]},{"name":"Margaretta","meanings":["Formed from Margaret."]}]}],"lifeSummary":"When Margaret Egglescliffe was born in 1299, in Egglescliffe, Durham, England, United Kingdom, her father, Thomas Egglescliffe, was 45 and her mother, Mrs. Thomas Egglescliffe, was 37. She married William Tailboys in 1322, in Northumberland, England. They were the parents of at least 3 sons."},"et":{"1299–":"1299–Surnud","1299–Female":"1299–Surnud","1315–1365":"1315–1365","1335–1369":"1335–1369","1337–Male":"1337–Surnud","1339–Male":"1339–Surnud","1255–Male":"1255–Surnud","1262–Female":"1262–Surnud","Abt 1335":"umbes 1335","1262":"1262","1337":"1337","1315":"1315","1369":"1369","1335":"1335","1322":"1322","about 1339":"umbes 1339","1299":"1299","1255":"1255","1365":"1365","about 1337":"umbes 1337","1339":"1339","Egglescliffe, Durham, England":"Egglescliffe, Durham, Inglismaa, United Kingdom","Northumberland, England":"Northumberland, England","Hepple, Northumberland, England":"Hepple, Northumberland, England"},"fi":{"1299–":"1299–Kuollut","1299–Female":"1299–Kuollut","1315–1365":"1315–1365","1335–1369":"1335–1369","1337–Male":"1337–Kuollut","1339–Male":"1339–Kuollut","1255–Male":"1255–Kuollut","1262–Female":"1262–Kuollut","Abt 1335":"noin