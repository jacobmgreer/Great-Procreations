, em Kent, Inglaterra, United Kingdom. Eles tiveram pelo menos 1 filho e 1 filha. Ele faleceu aproximadamente 1225, em Kingsdown, Kent, Inglaterra, com 74 anos."},"ro":{"about 1153–about 1225":"aproximativ 1153–aproximativ 1225","1153–1225":"1153–1225","1154–1184":"1154–1184","1175–1214":"1175–1214","1175–1254":"1175–1254","1125–1184":"1125–1184","1130–1165":"1130–1165","about 1184":"aproximativ 1184","1165":"1165","1154":"1154","1175":"1175","1153":"1153","1130":"1130","1173":"1173","1184":"1184","1215":"1215","1214":"1214","1225":"1225","1224":"1224","1125":"1125","1254":"1254","about 1225":"aproximativ 1225","about 1165":"aproximativ 1165","about 1153":"aproximativ 1153","about 1175":"aproximativ 1175","11 December 1214":"11 decembrie 1214","Kingsdown, Kent, England":"Kingsdown, Kent, England","Kingsdown, Kent, England, United Kingdom":"Kingsdown, Kent, Anglia, United Kingdom","Kent, England, United Kingdom":"Kent, Anglia, United Kingdom","Tong Castle, Kent, England":"Tong Castle, Kent, England","Badlesmere, Kent, England":"Badlesmere, Kent, England","Picquigny, Somme, Picardie, France":"Picquigny, Somme, Picardie, Franţa"},"ru":{"about 1153–about 1225":"около 1153 г.–около 1225 г.","1153–1225":"1153г.–1225г.","1154–1184":"1154г.–1184г.","1175–1214":"1175г.–1214г.","1175–1254":"1175г.–1254г.","1125–1184":"1125г.–1184г.","1130–1165":"1130г.–1165г.","about 1184":"около 1184 г.","1165":"1165 г.","1154":"1154 г.","1175":"1175 г.","1153":"1153 г.","1130":"1130 г.","1173":"1173 г.","1184":"1184 г.","1215":"1215 г.","1214":"1214 г.","1225":"1225 г.","1224":"1224 г.","1125":"1125 г.","1254":"1254 г.","about 1225":"около 1225 г.","about 1165":"около 1165 г.","about 1153":"около 1153 г.","about 1175":"около 1175 г.","11 December 1214":"11 декабря 1214 г.","Kingsdown, Kent, England":"кингсдоун, кэнт, Англия","Kingsdown, Kent, England, United Kingdom":"кингсдоун, кэнт, Англия, Великобритания","Kent, England, United Kingdom":"кэнт, Англия, Великобритания","Tong Castle, Kent, 