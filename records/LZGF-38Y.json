0":"1180–1240","1230":"1230","1240":"1240","1261":"1261","1260":"1260","1293":"1293","1193":"1193","1180":"1180","1201":"1201","1200":"1200","1232":"1232","Abt. 1232":"omkring 1232","1229":"1229","10 November 1897":"10. november 1897","Bispham, Lancashire, England":"Bispham, Lancashire, England, United Kingdom","England":"England","Lancashire, England":"Lancashire, England","Dalton, Yorkshire, England":"Dalton, Jórvík, England, United Kingdom"},"nl":{"1201–1261":"1201–1261","1193–Male":"1193–Overleden","1200–Male":"1200–Overleden","1200–1260":"1200–1260","1230–1293":"1230–1293","1180–1232":"1180–1232","1180–1240":"1180–1240","1230":"1230","1240":"1240","1261":"1261","1260":"1260","1293":"1293","1193":"1193","1180":"1180","1201":"1201","1200":"1200","1232":"1232","Abt. 1232":"circa 1232","1229":"1229","10 November 1897":"10 november 1897","Bispham, Lancashire, England":"Bispham, Lancashire, Engeland, Verenigd Koninkrijk","England":"England","Lancashire, England":"Lancashire, England","Dalton, Yorkshire, England":"Dalton, Yorkshire, Engeland, Verenigd Koninkrijk"},"en":{"1201–1261":"1201–1261","1193–Male":"1193–Deceased","1200–Male":"1200–Deceased","1200–1260":"1200–1260","1230–1293":"1230–1293","1180–1232":"1180–1232","1180–1240":"1180–1240","1230":"1230","1240":"1240","1261":"1261","1260":"1260","1293":"1293","1193":"1193","1180":"1180","1201":"1201","1200":"1200","1232":"1232","Abt. 1232":"about 1232","1229":"1229","10 November 1897":"10 November 1897","Bispham, Lancashire, England":"Bispham, Lancashire, England, United Kingdom","England":"England","Lancashire, England":"Lancashire, England","Dalton, Yorkshire, England":"Dalton, Yorkshire, England, United Kingdom","nameMeanings":[{"name":"Dalton","type":"LAST","attribution":"Dictionary of American Family Names © Patrick Hanks 2003, 2006.","meanings":["English and Irish: habitational name from any of various places called Dalton in Westmorland, Durham, Lancashire, Northumberland, and Yorkshire, from Old English <i>dæl</i> ‘valley’ (see   Dale  ) + <i>tūn</i> ‘enclosure, settlement’.","History: The surname was taken to Ireland by English traders in the early 13th century ."],"variants":[{"name":"Daughton","meanings":["English (Lincolnshire) and Irish (Kilkenny and Tipperary): variant of   Dalton  ."]},{"name":"Dale","meanings":["English: from Middle English <i>dal</i>, <i>dale</i>, <i>daile</i> ‘dale, valley’ (Old English <i>dæl</i>, reinforced in northern England by the cognate Old Norse <i>dalr</i>), a topographic name for someone who lived in a valley, or a habitational name from any of numerous minor places called with this word, such as Dale in Cumbria and Yorkshire.","Norwegian: habitational name from a common farm named from Old Norse <i>dali</i>, the dative case of <i>dalr</i> ‘valley’.","Americanized form of German   Diehl  ."]},{"name":"Dolton","meanings":["English: variant of   Dalton  ."]},{"name":"Daulton","meanings":["English (Kent): variant of   Dalton  ."]}]},{"name":"Richard","type":"FIRST","attribution":"Dictionary of First Names © Patrick Hanks and Flavia Hodges 1990, 2003, 2006.","meanings":["One of the most enduringly successful of the Old French personal names introduced into Britain by the Normans. It is of Germanic (Frankish) origin, derived from <i>rīc</i> ‘power’ + <i>hard</i> ‘strong, hardy’. It has enjoyed continuous popularity in England from the Conquest to the present day, influenced by the fact that it was borne by three kings of England, in particular  Richard I  (  1157–99 ). He was king for only ten years (  1189–99 ), most of which he spent in warfare abroad, taking part in the Third Crusade and costing the people of England considerable sums in taxes. Nevertheless, he achieved the status of a folk hero, and was never in England long enough to disappoint popular faith in his goodness and justice. He was also Duke of Aquitaine and Normandy and Count of Anjou, fiefs which he held at a time of maximum English expansion in France. His exploits as a leader of the Third Crusade earned him the nickname ‘Coeur de Lion’ or ‘Lionheart’ and a permanent place in popular imagination, in which he was even more firmly enshrined by  Sir Walter Scott's  novel Ivanhoe (  1820 )."],"variants":[{"name":"Rikert","meanings":["One of the most enduringly successful of the Old French personal names introduced into Britain by the Normans. It is of Germanic (Frankish) origin, derived from <i>rīc</i> ‘power’ + <i>hard</i> ‘strong, hardy’. It has enjoyed continuous popularity in England from the Conquest to the present day, influenced by the fact that it was borne by three kings of England, in particular  Richard I  (  1157–99 ). He was king for only ten years (  1189–99 ), most of which he spent in warfare abroad, taking part in the Third Crusade and costing the people of England considerable sums in taxes. Nevertheless, he achieved the status of a folk hero, and was never in England long enough to disappoint popular faith in his goodness and justice. He was also Duke of Aquitaine and Normandy and Count of Anjou, fiefs which he held at a time of maximum English expansion in France. His exploits as a leader of the Third Crusade earned him the nickname ‘Coeur de Lion’ or ‘Lionheart’ and a permanent place in popular imagination, in which he was even more firmly enshrined by  Sir Walter Scott's  novel Ivanhoe (  1820 )."]},{"name":"Rickert","meanings":["One of the most enduringly successful of the Old French personal names introduced into Britain by the Normans. It is of Germanic (Frankish) origin, derived from <i>rīc</i> ‘power’ + <i>hard</i> ‘strong, hardy’. It has enjoyed continuous popularity in England from the Conquest to the present day, influenced by the fact that it was borne by three kings of England, in particular  Richard I  (  1157–99 ). He was king for only ten years (  1189–99 ), most of which he spent in warfare abroad, taking part in the Third Crusade and costing the people of England considerable sums in taxes. Nevertheless, he achieved the status of a folk hero, and was never in England long enough to disappoint popular faith in his goodness and justice. He was also Duke of Aquitaine and Normandy and Count of Anjou, fiefs which he held at a time of maximum English expansion in France. His exploits as a leader of the Third Crusade earned him the nickname ‘Coeur de Lion’ or ‘Lionheart’ and a permanent place in popular imagination, in which he was even more firmly enshrined by  Sir Walter Scott's  novel Ivanhoe (  1820 )."]}]}],"lifeSummary":"When Sir Richard Dalton II was born in 1201, in Bispham, Lancashire, England, United Kingdom, his father, Sir Richard Dalton I, was 22 and his mother, McCormick, was 21. He married Lady Mary Latymer in 1229, in Lancashire, England. They were the parents of at least 1 son. He died in 1261, in his hometown, at the age of 60, and was buried in Bispham, Lancashire, England, United Kingdom."},"et":{"1201–1261":"1201–1261","1193–Male":"1193–Surnud","1200–Male":"1200–Surnud","1200–1260":"1200–1260","1230–1293":"1230–1293","1180–1232":"1180–1232","1180–1240":"1180–1240","1230":"1230","1240":"1240","1261":"1261","1260":"1260","1293":"1293","1193":"1193","1180":"1180","1201":"1201","1200":"1200","1232":"1232","Abt. 1232":"umbes 1232","1229":"1229","10 November 1897":"10 november 1897","Bispham, Lancashire, England":"Bispham, Lancashire, Inglismaa, United Kingdom","England":"England","Lancashire, England":"Lancashire, England","Dalton, Yorkshire, England":"Dalton, Yorkshire, Inglismaa, United Kingdom"},"fi":{"1201–1261":"1201–1261","1193–Male":"1193–Kuollut","1200–Male":"1200–Kuollut","1200–1260":"1200–1260","1230–1293":"1230–1293","1180–1232":"1180–1232","1180–1240":"1180–1240","1230":"1230","1240":"1240","1261":"1261","1260":"1260","1293":"1293","1193":"1193","1180":"1180","1201":"1201","1200":"1200","1232":"1232","Abt. 1232":"noin 1232","1229":"1229","10 November 1897":"10. marraskuuta 1897","Bispham, Lancashire, England":"Bispham, Lancashire, Engla