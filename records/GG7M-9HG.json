24":"1324","1389":"1389","1366":"1366","1453":"1453","1341":"1341","about 1324":"circa 1324","1382":"1382","about 1341":"circa 1341","1328":"1328","1290":"1290","Chrishall, Essex, England":"Chrishall, Essex, England","Castle Ashby, Northamptonshire, England":"Castle Ashby, Northamptonshire, England"},"en":{"about 1324–":"about 1324–Deceased","1324–Female":"1324–Deceased","–1349":"–1349","1324–1366":"1324–1366","1341–1389":"1341–1389","1290–Male":"1290–Deceased","1349":"1349","1337":"1337","1324":"1324","1389":"1389","1366":"1366","1453":"1453","1341":"1341","about 1324":"about 1324","1382":"1382","about 1341":"about 1341","1328":"1328","1290":"1290","Chrishall, Essex, England":"Chrishall, Essex, England","Castle Ashby, Northamptonshire, England":"Castle Ashby, Northamptonshire, England","nameMeanings":[{"name":"Peverell","type":"LAST","attribution":"Dictionary of Family Names in Britain and Ireland © University of the West of England 2016","meanings":["Norman, English:  see  Peverall  ."],"variants":[{"name":"Peverall","meanings":["Norman, English: relationship name from Old French  <i>Peurel</i> (Latin  <i>Piperellus</i>), a diminutive of Old French  <i>pevre</i> ‘pepper’ (Anglo-Norman French  <i>peivere</i>, Latin  <i>piper</i>), originally perhaps used as a nickname on the Continent but used as a personal name in Anglo-Norman England."]}]},{"name":"Margaret","type":"FIRST","attribution":"Dictionary of First Names © Patrick Hanks and Flavia Hodges 1990, 2003, 2006.","meanings":["An extremely common given name from the Middle Ages onwards, derived via Old French <i>Marguerite</i> and Latin <i>Margarita</i> from Greek <i>Margarītēs</i>, from <i>margaron</i> ‘pearl’, a word ultimately of Hebrew origin. The name was always understood to mean ‘pearl’ throughout the Middle Ages. The first  St Margaret  was martyred at Antioch in Pisidia during the persecution instigated by the  Emperor Diocletian  in the early 4th century. However, there is some doubt about her name, as the same saint is venerated in the Orthodox Church as   Marina .  There were several other saintly bearers of the name, including St Margaret of Scotland (  d. 1093 ), wife of  King Malcolm Canmore  and daughter of Edmund Ironside of England. It was also the name of the wife of  Henry VI  of England,  Margaret of Anjou  (  1430–82 ), and of  Margaret Tudor  (  1489–1541 ), sister of  Henry VIII , who married James IV of Scotland and ruled as regent there after his death.  See also  Margery  ,   Marjorie ."],"variants":[{"name":"Margareta","meanings":["From the Latin form of Greek <i>Margarītēs</i>.  See  <b>Margaret</b>   ."]},{"name":"Margaretta","meanings":["An extremely common given name from the Middle Ages onwards, derived via Old French <i>Marguerite</i> and Latin <i>Margarita</i> from Greek <i>Margarītēs</i>, from <i>margaron</i> ‘pearl’, a word ultimately of Hebrew origin. The name was always understood to mean ‘pearl’ throughout the Middle Ages. The first  St Margaret  was martyred at Antioch in Pisidia during the persecution instigated by the  Emperor Diocletian  in the early 4th century. However, there is some doubt about her name, as the same saint is venerated in the Orthodox Church as   Marina .  There were several other saintly bearers of the name, including St Margaret of Scotland (  d. 1093 ), wife of  King Malcolm Canmore  and daughter of Edmund Ironside of England. It was also the name of the wife of  Henry VI  of England,  Margaret of Anjou  (  1430–82 ), and of  Margaret Tudor  (  1489–1541 ), sister of  Henry VIII , who married James IV of Scotland and ruled as regent there after his death.  See also  Margery  ,   Marjorie ."]}]}],"historicEvents":[{"id":1705192,"age":4,"year":"1328","julianDay":2206102,"title":"First War of Scottish Independence","description":"The First War of Scottish Independence began after England invaded Scotland in 1296. The Treaty of Edinburgh was signed in 1328 which declared peace between the two kingdoms and brought the war to an end.","jurisdictionLevel":2},{"id":1705193,"age":13,"year":"1337","toYear":"1453","julianDay":2209390,"title":"The Hundred Years' War","description":"The Hundred Years' War between France and England was largely due to the question of legitimate succession to the French crown.","jurisdictionLevel":2},{"id":1705195,"age":58,"year":"1382","julianDay":2225826,"title":"Wycliffe's Bible","description":"John Wycliffe, English theologian and professor at the University of Oxford, completed a translation of the Bible from the Latin Vulgate into Middle English. This translation is known as Wycliffe's Bible and was completed around 1382.","url":"https://en.wikipedia.org/wiki/Wycliffe%27s_Bible","urlTitle":"Wikipedia - Wycliffe's Bible","jurisdictionLevel":2}],"lifeSummary":"Margaret Peverell was born about 1324, in Castle Ashby, Northamptonshire, England as the daughter of Sir Edmund Peverel. She had at least 1 son with William de la Pole."},"et":{"about 1324–":"umbes 1324–Surnud","1324–Female":"1324–Surnud","–1349":"–1349","1324–1366":"1324–1366","1341–1389":"1341–1389","1290–Male":"1290–Surnud","1349":"1349","1337":"1337","1324":"1324","1389":"1389","1366":"1366","1453":"1453","1341":"1341","about 1324":"umbes 1324","1382":"1382","about 1341":"umbes 1341","1328":"1328","1290":"1290","Chrishall, Essex, England":"Chrishall, Essex, England","Castle Ashby, Northamptonshire, England":"Castle Ashby, Northamptonshire, England"},"fi":{"about 1324–":"noin 1324–Kuollut","1324–Female":"1324–Kuollut","–1349":"–1349","1324–1366":"1324–1366","1341–1389":"1341–1389","1290–Male":"1290–Kuollut","1349":"1349","1337":"1337","1324":"1324","1389":"1389","1366":"1366","1453":"1453","1341":"1341","about 1324":"noin 1324","1382":"1382","about 1341":"noin 1341","1328":"1328","1290":"1290","Chrishall, Essex, England":"Chrishall, Essex, England","Castle Ashby, Northamptonshire, England":"Castle Ashby, Northamptonshire, England"},"fr":{"about 1324–":"environ 1324–Décédée","1324–Female"