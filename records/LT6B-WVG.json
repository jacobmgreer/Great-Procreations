es":"Wales","of,Ystlwyf cmt,Carmarthenshire,Wales":"Carmarthenshire, Wales, United Kingdom","nameMeanings":[{"name":"Llwyd","type":"LAST","meanings":["Same as Lhuyd, q v."],"variants":[]},{"name":"ap","type":"LAST","attribution":"Dictionary of American Family Names © Patrick Hanks 2003, 2006.","meanings":["Some characteristic forenames:  Hungarian Geza, Jeno, Arpad, Attila, Csaba.","Hungarian: variant of   Papp  , meaning ‘priest (of the Catholic or Orthodox Church)’. This surname is also found in Romania, Slovakia, Croatia, and Serbia, and also among Rusyns (in Serbia and Croatia). See also   Pop   2 and   Popa  .","English: variant of   Pape   1."],"variants":[{"name":"Papp","meanings":["Some characteristic forenames:  Hungarian Laszlo, Zoltan, Geza, Istvan, Gabor, Miklos, Tibor, Arpad, Denes, Imre, Attila.","German (Bavaria, Tyrol): from Middle High German <i>pap</i> ‘baby food’, Dutch <i>pap</i> ‘porridge, pap’, hence perhaps a nickname denoting someone who had lost his teeth or subsisted on a meager diet.","Hungarian: from <i>pap</i> ‘priest (of the Catholic or Orthodox Church)’, probably an occupational name for someone in the service of a priest or a nickname for a pious person. This surname is also found in Romania and Slovakia, and also among Rusyns. Compare   Pap   and   Pop  ."]}]},{"name":"Cyner,","type":"LAST","attribution":"Dictionary of American Family Names © Patrick Hanks 2003, 2006.","meanings":["English: unexplained."],"variants":[]},{"name":"ap","type":"LAST","attribution":"Dictionary of American Family Names © Patrick Hanks 2003, 2006.","meanings":["Some characteristic forenames:  Hungarian Geza, Jeno, Arpad, Attila, Csaba.","Hungarian: variant of   Papp  , meaning ‘priest (of the Catholic or Orthodox Church)’. This surname is also found in Romania, Slovakia, Croatia, and Serbia, and also among Rusyns (in Serbia and Croatia). See also   Pop   2 and   Popa  .","English: variant of   Pape   1."],"variants":[{"name":"Papp","meanings":["Some charact