":"1315","about 1307":"circa 1307","about 1329":"circa 1329","1382":"1382","1308":"1308","1307":"1307","1339":"1339","1328":"1328","1317":"1317","Sussex, England":"Sussex, England","Warwickshire, England":"Warwickshire, England"},"en":{"about 1307–":"about 1307–Deceased","1308–Male":"1308–Deceased","1339–Male":"1339–Deceased","1307–Female":"1307–Deceased","1315":"1315","about 1307":"about 1307","about 1329":"about 1329","1382":"1382","1308":"1308","1307":"1307","1339":"1339","1328":"1328","1317":"1317","Sussex, England":"Sussex, England","Warwickshire, England":"Warwickshire, England","nameMeanings":[{"name":"Palmer","type":"LAST","attribution":"Dictionary of American Family Names © Patrick Hanks 2003, 2006.","meanings":["English: nickname from Middle English <i>palmer(e)</i> ‘palmer, pilgrim to the Holy Land’ (Anglo-Norman French <i>palmer</i>, Old French <i>pa(l)mer</i>, <i>paum(i)er</i>), so called from the palm branch carried by such pilgrims. The term was also used to denote an itinerant monk who traveled from shrine to shrine under a vow of poverty. This surname is also common in Ireland, where it has been recorded from the 13th century onward.","Irish: when not of English origin (see 1 above), a surname adopted for Gaelic <b>Ó Maolfhoghmhair</b> (see   Milford  ), the name of an ecclesiastical family.","Swedish (mainly <b>Palmér</b>): ornamental name formed with <i>palm</i> ‘palm tree’ + the suffix <i>-ér</i> (a derivative of Latin <i>-erius</i>) or <i>-er</i> (from German)."],"variants":[{"name":"Milford","meanings":["English (mainly Devon): habitational name from any of the many places called Milford, deriving from Old English <i>myln</i> ‘mill’ + <i>ford</i> ‘ford’.","Irish (Antrim and Galway): Anglicized form of Gaelic <b>Ó Maolfhoghmhair</b> ‘descendant of <i>Maolgfhoghmhair</i>’, a personal name meaning ‘chief of harvest’. The Irish name was first Anglicized as <b>Mullover</b>, which was later assimilated to <i>Milford</i>. See also   Palmer  ."]},{"name":"Palmiere","meanings":["Some characteristic forenames:  Italian Angelo, Dante, Enrico, Nicola, Salvatore, Vittorio.","Italian: from <i>palmiere</i> ‘palmer, pilgrim’. See   Palmer  ."]},{"name":"Parmer","meanings":["English: variant of   Palmer  .","Indian (northern states): variant of   Parmar  ."]},{"name":"Palmore","meanings":["Probably an altered form of English   Palmer   or an Americanized form of South German   Balmer  ."]}]},{"name":"Ralph","type":"FIRST","attribution":"Dictionary of First Names © Patrick Hanks and Flavia Hodges 1990, 2003, 2006.","meanings":["From a Norman French name, <i>Raulf</i>, a contracted form of the Germanic personal name <i>Radulf</i>, derived from <i>rād</i> ‘counsel’ + <i>wulf</i> ‘wolf’. The spelling with <i>-ph</i> is due to classical influence in the 18th century."],"variants":[{"name":"Ralf","meanings":["From a Norman French name, <i>Raulf</i>, a contracted form of the Germanic personal name <i>Radulf</i>, derived from <i>rād</i> ‘counsel’ + <i>wulf</i> ‘wolf’. The spelling with <i>-ph</i> is due to classical influence in the 18th century."]}]}],"historicEvents":[{"id":1705191,"age":8,"year":"1315","toYear":"1317","julianDay":2201354,"title":"Famine Strikes Europe","description":"A famine caused by cold winters and wet summers across Europe caused millions to die due to starvation. Desperation from hunger caused high levels of crime, stampedes in bread lines in London, infanticide, and even cannibalism throughout Europe.","jurisdictionLevel":1},{"id":1705192,"age":21,"year":"1328","julianDay":2206102,"title":"First War of Scottish Independence","description":"The First War of Scottish Independence began after England invaded Scotland in 1296. The Treaty of Edinburgh was signed in 1328 which declared peace between the two kingdoms and brought the war to an end.","jurisdictionLevel":1},{"id":1705195,"age":75,"year":"1382","julianDay":2225826,"title":"Wycliffe's Bible","description":"John Wycliffe, English theologian and professor at the University of Oxford, completed a translation of the Bible from the Latin Vulgate into Middle English. This translation is known as Wycliffe's Bible and was completed around 1382.","url":"https://en.wikipedia.org/wiki/Wycliffe%27s_Bible","urlTitle":"Wikipedia - Wycliffe's Bible","jurisdictionLevel":1}],"lifeSummary":"Mrs. Ralph Palmer was born about 1307, in Sussex, England. She married Ralph Palmer about 1329, in Warwickshire, England. They were the parents of at least 1 son."},"et":{"about 1307–":"umbes 1307–Surnud","1308–Male":"1308–Surnud","1339–Male":"1339–Surnud","1307–Female":"1307–Surnud","1315":"1315","about 1307":"umbes 1307","about 1329":"umbes 1329","1382":"1382","1308":"1308","1307":"1307","1339":"1339","1328":"1328","1317":"1317","Sussex, England":"Sussex, England","Warwickshire, England":"Warwickshire, England"},"fi":{"about 1307–":"noin 1307–Kuollut","1308–Male":"1308–Kuollut","1339–Male":"1339–Kuollut","1307–Female":"1307–Kuollut","1315":"1315","about 1307":"noin 1307","about 1329":"noin 1329","1382":"1382","1308":"1308","1307":"1307","1339":"1339","1328":"1328","1317":"1317","Sussex, England":"Sussex, England","Warwickshire, England":"Warwickshire, England"},"fr":{"about 1307–":"environ 1307–Décédée","1308–Male":"1308–Décédé","1339–Male":"1339–Décédé","1307–Female":"1307–Décédée","1315":"1315","about 1307":"environ 1307","about 1329":"environ 1329","1382":"1382","1308":"1308","1307":"1307","1339":"1339","1328":"1328","1317":"1317","Sussex, England":"Sussex, Angleterre","Warwickshire, England":"Warwickshire, Angleterre","lifeSummary":"Mrs. Ralph Palmer est née environ 1307, à Sussex, Angleterre. Elle a épousé Ralph Palmer environ 1329, à Warwickshire, Angleterre. Ils ont eu au moins 1 fils."},"de":{"about 1307–":"um 1307–Verstorben","1308–Male":"1308–Verstorben","1339–Male":"1339–Verstorben","1307–Female":"1307–Verstorben","1315":"1315","about 1307":"um 1307","about 1329":"um 1329","1382":"1382","1308":"1308","1307":"1307","1339":"1339"