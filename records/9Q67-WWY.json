ngland":"Westmorland, England","England":"England"},"nl":{"about 1363–":"circa 1363–Overleden","1353–1440":"1353–1440","1355–Male":"1355–Overleden","1363–Female":"1363–Overleden","1365–1448":"1365–1448","1360–Male":"1360–Overleden","1377–Male":"1377–Overleden","1340–1379":"1340–1379","1340–1398":"1340–1398","1363":"1363","1440":"1440","1362":"1362","1340":"1340","1382":"1382","1360":"1360","1448":"1448","1379":"1379","1455":"1455","1377":"1377","1355":"1355","1398":"1398","1365":"1365","1353":"1353","about 1376":"circa 1376","about 1363":"circa 1363","Westmorland, England":"Westmorland, England","England":"England"},"en":{"about 1363–":"about 1363–Deceased","1353–1440":"1353–1440","1355–Male":"1355–Deceased","1363–Female":"1363–Deceased","1365–1448":"1365–1448","1360–Male":"1360–Deceased","1377–Male":"1377–Deceased","1340–1379":"1340–1379","1340–1398":"1340–1398","1363":"1363","1440":"1440","1362":"1362","1340":"1340","1382":"1382","1360":"1360","1448":"1448","1379":"1379","1455":"1455","1377":"1377","1355":"1355","1398":"1398","1365":"1365","1353":"1353","about 1376":"about 1376","about 1363":"about 1363","Westmorland, England":"Westmorland, England","England":"England","nameMeanings":[{"name":"Salkeld","type":"LAST","attribution":"Dictionary of American Family Names © Patrick Hanks 2003, 2006.","meanings":["English (northern): habitational name from Salkeld (Cumberland), probably from Old English <i>salh</i> ‘willow, sallow’ + <i>hylte</i> ‘wood’, though the final element may have been confused with Old Norse <i>kelda</i> ‘spring, marshy place’. Alternatively, the final element may be an Old English <i>hilde</i>, a variant of <i>helde</i> ‘slope’. This surname has been present (though never common) in Ireland for centuries."],"variants":[]},{"name":"Margaret","type":"FIRST","attribution":"Dictionary of First Names © Patrick Hanks and Flavia Hodges 1990, 2003, 2006.","meanings":["An extremely common given name from the Middle Ages onwards, derived via Old French <i>Marguerite</i> and Latin <i>Margarita</i> from Greek <i>Margarītēs</i>, from <i>margaron</i> ‘pearl’, a word ultimately of Hebrew origin. The name was always understood to mean ‘pearl’ throughout the Middle Ages. The first  St Margaret  was martyred at Antioch in Pisidia during the persecution instigated by the  Emperor Diocletian  in the early 4th century. However, there is some doubt about her name, as the same saint is venerated in the Orthodox Church as   Marina .  There were several other saintly bearers of the name, including St Margaret of Scotland (  d. 1093 ), wife of  King Malcolm Canmore  and daughter of Edmund Ironside of England. It was also the name of the wife of  Henry VI  of England,  Margaret of Anjou  (  1430–82 ), and of  Margaret Tudor  (  1489–1541 ), sister of  Henry VIII , who married James IV of Scotland and ruled as regent there after his death.  See also  Margery  ,   Marjorie ."],"variants":[{"name":"Margareta","meanings":["From the Latin form of Greek <i>Margarītēs</i>.  See  <b>Margaret</b>   ."]},{"name":"Margaretta","meanings":["An extremely common given name from the Middle Ages onwards, derived via Old French <i>Marguerite</i> and Latin <i>Margarita</i> from Greek <i>Margarītēs</i>, from <i>margaron</i> ‘pearl’, a word ultimately of Hebrew origin. The name was always understood to mean ‘pearl’ throughout the Middle Ages. The first  St Margaret  was martyred at Antioch in Pisidia during the persecution instigated by the  Emperor Diocletian  in the early 4th century. However, there is some doubt about her name, as the same saint is venerated in the Orthodox Church as   Marina .  There were several other saintly bearers of the name, including St Margaret of Scotland (  d. 1093 ), wife of  King Malcolm Canmore  and daughter of Edmund Ironside of England. It was also the name of the wife of  Henry VI  of England,  Margaret of Anjou  (  1430–82 ), and of  Margaret Tudor  (  1489–1541 ), sister of  Henry VIII , who married James IV of Scotland and ruled as regent there after his death.  See also  Margery  ,   Marjorie ."]}]}],"historicEvents":[{"id":1705195,"age":19,"year":"1382","julianDay":2225826,"title":"Wycliffe's Bible","description":"John Wycliffe, English theologian and professor at the University of Oxford, completed a translation of the Bible from the Latin Vulgate into Middle English. This translation is known as Wycliffe's Bible and was completed around 1382.","url":"https://en.wikipedia.org/wiki/Wycliffe%27s_Bible","urlTitle":"Wikipedia - Wycliffe's Bible","jurisdictionLevel":1},{"id":1705197,"age":92,"year":"1455","julianDay":2252488,"title":"Wars of the Roses","description":"Wars of the Roses was a series of English civil wars for control of the throne of England between the royal families House of Lancaster and the House of York. The name of the war was derived as the red rose was the symbol of the Lancastrians and the white rose was the symbol of the Yorks.","url":"https://www.history.com/topics/british-history/wars-of-the-roses","urlTitle":"History - Wars of the Roses","jurisdictionLevel":1}],"lifeSummary":"When Margaret Salkeld was born about 1363, in Westmorland, England, her father, Hugh Salkeld, was 24 and her mother, Christiana Rosgill, was 24. She married Robert de Bellingham about 1376, in England. They were the parents of at least 1 son."},"et":{"about 1363–":"umbes 1363–Surnud","1353–1440":"1353–1440","1355–Male":"1355–Surnud","1363–Female":"1363–Surnud","1365–1448":"1365–1448","1360–Male":"1360–Surnud","1377–Male":"1377–Surnud","1340–1379":"1340–1379","1340–1398":"1340–1398","1363":"1363","1440":"1440","1362":"1362","1340":"1340","1382":"1382","1360":"1360","1448":"1448","1379":"1379","1455":"1455","1377":"1377","1355":"1355","1398":"1398","1365":"1365","1353":"1353","about 1376":"umbes 1376","about 1363":"umbes 1363","Westmorland, England":"Westmorland, England","England":"England"},"fi":{"about 1363–":"noin 1363–Kuollut","1353–1440":"1353–1440","1355–Male":"1355–Kuollut