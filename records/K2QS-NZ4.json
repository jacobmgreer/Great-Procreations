gland":"Yorkshire, England"},"en":{"about 1174–":"about 1174–Deceased","1100–Male":"1100–Deceased","1115–Female":"1115–Deceased","1150–1200":"1150–1200","1174–Male":"1174–Deceased","1174–Female":"1174–Deceased","1200–1260":"1200–1260","1068–Male":"1068–Deceased","1087–Female":"1087–Deceased","1087":"1087","1174":"1174","1260":"1260","1150":"1150","1259":"1259","1215":"1215","1115":"1115","1224":"1224","1068":"1068","1200":"1200","1100":"1100","about 1200":"about 1200","about 1174":"about 1174","South Cave, Yorkshire, England":"South Cave, Yorkshire, England","Yorkshire, England":"Yorkshire, England","nameMeanings":[{"name":"Cave","type":"LAST","attribution":"Dictionary of American Family Names © Patrick Hanks 2003, 2006.","meanings":["English: habitational name from a place in East Yorkshire called Cave, apparently from a river name derived from Old English <i>cāf</i> ‘swift’.","English (of Norman origin): nickname from Norman and Picard Old French <i>cauf</i> (from Latin <i>calvus</i>) ‘bald’.","French: topographic name for someone who lived in or near a cave, from Old French <i>cave</i> ‘cave’, ‘cellar’ (from Latin <i>cavea</i>, a derivative of <i>cavus</i> ‘hollow’)."],"variants":[{"name":"Cavin","meanings":["Scottish (Wigtownshire): variant of <b>Caveen</b>, a shortened form of Manx <i>Mac Dhaimhín</i>, son of <i>Daimhín</i>. The personal name is a diminutive of Gaelic <i>damh</i> ‘bard, poet’.","French: diminutive of   Cave  ."]},{"name":"Caves","meanings":["English: variant of   Cave  , with post-medieval excrescent <i>-s</i>."]},{"name":"Keeve","meanings":["English: perhaps a variant of   Cave  . This surname is rare in Britain."]},{"name":"Chaffee","meanings":["English (of Norman origin): descriptive nickname from a derivative of Old French <i>chauf</i> ‘bald’ (from Latin <i>calvus</i>). Compare   Cave  ."]},{"name":"Cavett","meanings":["Scottish (of French origin): altered form of French <b>Cavet</b>, which is either a diminutive of   Cave   3 or a metonymic occupational name for a laborer, one who used a <i>cavet</i>, an Old Occitan word for a tool for clearing ground for cultivation."]}]},{"name":"Robert","type":"FIRST","attribution":"Dictionary of First Names © Patrick Hanks and Flavia Hodges 1990, 2003, 2006.","meanings":["One of the many French names of Germanic origin that were introduced into Britain by the Normans; it has since remained in continuous use. It is derived from the nearly synonymous elements <i>hrōd</i> ‘fame’ + <i>berht</i> ‘bright, famous’, and had a native Old English predecessor of similar form (<i>Hreodbeorht</i>), which was supplanted by the Norman name. Two dukes of Normandy in the 11th century bore the name: the father of  William the Conqueror  (sometimes identified with the legendary Robert the Devil), and his eldest son. It was borne also by three kings of Scotland, notably  Robert the Bruce  (  1274–1329 ), who freed Scotland from English domination. The altered short form <i>Bob</i> is very common, but <i>Hob</i> and <i>Dob</i>, which were common in the Middle Ages and gave rise to surnames, are extinct.  See also  Rupert ."],"variants":[]},{"name":"de","type":"FIRST","attribution":"Dictionary of First Names © Patrick Hanks and Flavia Hodges 1990, 2003, 2006.","meanings":["‘Attainment’."],"variants":[]}],"historicEvents":[{"id":1705187,"age":41,"year":"1215","julianDay":2164830,"title":"Magna Carta","description":"King John of England agreed to a charter of rights called the Magna Carta. The document was originally drafted by the Archbishop of Canterbury to establish peace between King John and a group of rebel barons. The Magna Carta was completed in 1215 and is now considered to be one of the greatest constitutional documents of all time.","url":"https://www.nationalarchives.gov.uk/education/medieval/magna-carta/","urlTitle":"National Archives - Magna Carta","jurisdictionLevel":2},{"id":1705188,"age":50,"year":"1224","julianDay":2168117,"title":"France Declares War on England","description":"France declared war on England as Louis VIII of France attacked Poitou and northern Gascony.","jurisdictionLevel":2},{"id":1705189,"age":85,"year":"1259","julianDay":2180901,"title":"100 Years of Conflict Between England and France Ends","description":"Treaty of Paris was signed on December 4, 1259, which ended 100 years of conflict between England and France.","url":"https://en.wikipedia.org/wiki/Treaty_of_Paris_(1259)","urlTitle":"Wikipedia - Treaty of Paris 1259","jurisdictionLevel":2}],"lifeSummary":"When Robert de Cave was born about 1174, in South Cave, Yorkshire, England, his father, Bryan de Cave, was 108 and his mother, Joan de Metham, was 89. He had at least 1 son with De Haldanby."},"et":{"about 1174–":"umbes 1174–Surnud","1100–Male":"1100–Surnud","1115–Female":"1115–Surnud","1150–1200":"1150–1200","1174–Male":"1174–Surnud","1174–Female":"1174–Surnud","1200–1260":"1200–1260","1068–Male":"1068–Surnud","1087–Female":"1087–Surnud","1087":"1087","1174":"1174","1260":"1260","1150":"1150","1259":"1259","1215":"1215","1115":"1115","1224":"1224","1068":"1068","1200":"1200","1100":"1100","about 1200":"umbes 1200","about 1174":"umbes 1174","South Cave, Yorkshire, England":"South Cave, Yorkshire, England","Yorkshire, England":"Yorkshire, England"},"fi":{"about 1174–":"noin 1174–Kuollut","1100–Male":"1100–Kuollut","1115–Female":"1115–Kuollut","1150–1200":"1150–1200","1174–Male":"1174–Kuollut","1174–Female":"1174–Kuollut","1200–1260":"1200–1260","1068–Male":"1068–Kuollut","1087–Female":"1087–Kuollut","1087":"1087","1174":"1174","1260":"1260","1150":"1150","1259":"1259","1215":"1215","1115":"1115","1224":"1224","1068":"1068","1200":"1200","1100":"1100","about 1200":"noin 1200","about 1174":"noin 1174","South Cave, Yorkshire, England":"South Cave, Yorkshire, England","Yorkshire, England":"Yorkshire, England"},"fr":{"about 1174–":"environ 1174–Décédé","1100–Male":"1100–Décédé","1115–Female":"1115–Décédée","1150–1200":"1150–1200","1174–Male":"1174–Décédé","1174–