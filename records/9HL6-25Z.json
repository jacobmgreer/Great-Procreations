35":"1335","1355":"1355","1410":"1410","1353":"1353","1298":"1298","1397":"1397","2 October 1372":"2. oktober 1372","1329":"1329","Leyland, Lancashire, England":"Leyland, Lancashire, England, United Kingdom","Worden Hall, Leyland, , Lancashire, England":"Worden Hall, Lancashire, England","Worden Hall, Lancashire, England":"Worden Hall, Lancashire, England, United Kingdom","Farington, Lancashire, England":"Farington, Lancashire, England, United Kingdom","Farington, Lancashire, England, United Kingdom":"Farington, Lancashire, England, United Kingdom","Lancashire, England":"Lancashire, England, United Kingdom"},"nl":{"1326–2 October 1372":"1326–2 oktober 1372","1326–1372":"1326–1372","1335–1397":"1335–1397","1353–1412":"1353–1412","1355–1410":"1355–1410","1298–1360":"1298–1360","1302–1329":"1302–1329","about 1360":"circa 1360","1372":"1372","1360":"1360","1326":"1326","1302":"1302","1412":"1412","1335":"1335","1355":"1355","1410":"1410","1353":"1353","1298":"1298","1397":"1397","2 October 1372":"2 oktober 1372","1329":"1329","Leyland, Lancashire, England":"Leyland, Lancashire, Engeland, Verenigd Koninkrijk","Worden Hall, Leyland, , Lancashire, England":"Worden Hall, Lancashire, England","Worden Hall, Lancashire, England":"Worden Hall, Lancashire, Engeland, Verenigd Koninkrijk","Farington, Lancashire, England":"Farington, Lancashire, Engeland, Verenigd Koninkrijk","Farington, Lancashire, England, United Kingdom":"Farington, Lancashire, Engeland, Verenigd Koninkrijk","Lancashire, England":"Lancashire, Engeland, Verenigd Koninkrijk"},"en":{"1326–2 October 1372":"1326–2 October 1372","1326–1372":"1326–1372","1335–1397":"1335–1397","1353–1412":"1353–1412","1355–1410":"1355–1410","1298–1360":"1298–1360","1302–1329":"1302–1329","about 1360":"about 1360","1372":"1372","1360":"1360","1326":"1326","1302":"1302","1412":"1412","1335":"1335","1355":"1355","1410":"1410","1353":"1353","1298":"1298","1397":"1397","2 October 1372":"2 October 1372","1329":"1329","Leyland, Lancashire, England":"Leyland, Lancashire, England, United Kingdom","Worden Hall, Leyland, , Lancashire, England":"Worden Hall, Lancashire, England","Worden Hall, Lancashire, England":"Worden Hall, Lancashire, England, United Kingdom","Farington, Lancashire, England":"Farington, Lancashire, England, United Kingdom","Farington, Lancashire, England, United Kingdom":"Farington, Lancashire, England, United Kingdom","Lancashire, England":"Lancashire, England, United Kingdom","nameMeanings":[{"name":"Farrington","type":"LAST","attribution":"Dictionary of American Family Names © Patrick Hanks 2003, 2006.","meanings":["English: habitational name from Farrington in Lancashire, but perhaps occasionally from Farrington Gurney in Somerset. Both are named from Old English <i>fearn</i> ‘fern’ + <i>tūn</i> ‘settlement’. The surname also probably reached America via Ireland, where it is recorded as early as the 14th century."],"variants":[{"name":"Fearrington","meanings":["Perhaps an altered form of   Farrington  ."]},{"name":"Ferrington","meanings":["English (Shropshire): variant of   Farrington  ."]}]},{"name":"William","type":"FIRST","attribution":"Dictionary of First Names © Patrick Hanks and Flavia Hodges 1990, 2003, 2006.","meanings":["Probably the most successful of all the Old French names of Germanic origin that were introduced to England by the Normans. It is derived from Germanic <i>wil</i> ‘will, desire’ + <i>helm</i> ‘helmet, protection’. The fact that it was borne by the Conqueror himself does not seem to have inhibited its favour with the ‘conquered’ population: in the first century after the Conquest it was the commonest male name of all, and not only among the Normans. In the later Middle Ages it was overtaken by   John  , but continued to run second to that name until the 20th century, when the picture became more fragmented."],"variants":[]},{"name":"de","type":"FIRST","attribution":"Dictionary of First Names © Patrick Hanks and Flavia Hodges 1990, 2003, 2006.","meanings":["Short form of the various boys' names with the first syllable <i>Ed-</i>, especially   Edward ."],"variants":[{"name":"Edward","meanings":["From an Old English personal name derived from <i>ēad</i> ‘prosperity, riches’ + <i>weard</i> ‘guard’. This has been one of the most successful of all Old English names, in frequent use from before the Conquest to the present day, and even being exported into other European languages. It was the name of three Anglo-Saxon kings and has been borne by eight kings of England since the Norman Conquest. It is also the name of the youngest son of  Queen Elizabeth II . The most influential early bearer was  King Edward  the Confessor (  ?1002–66 ; ruled  1042–66 ). In a troubled period of English history, he contrived to rule fairly and (for a time at any rate) firmly. But in the latter part of his reign he paid more attention to his religion than to his kingdom. He died childless, and his death sparked off conflicting claims to his throne, which were resolved by the victory of William the Conqueror at the Battle of Hastings. His memory was honoured by Normans and English alike, for his fairness and his piety. Edward's mother was Norman; he had spent part of his youth in Normandy; and William claimed to have been nominated by Edward as his successor. Edward was canonized in the 12th century, and came to be venerated throughout Europe as a model of a Christian king."]}]}],"lifeSummary":"When William de Farrington was born in 1326, in Worden Hall, Lancashire, England, United Kingdom, his father, William de Farrington, was 28 and his mother, Jennet Dalton, was 25. He married Dorothy de Standish in 1353, in Leyland, Lancashire, England, United Kingdom. They were the parents of at least 2 sons. He died on 2 October 1372, in Leyland, Lancashire, England, United Kingdom, at the age of 46."},"et":{"1326–2 October 1372":"1326–2. oktoober 1372","1326–1372":"1326–1372","1335–1397":"1335–1397","1353–1412":"1353–1412","1355–1410":"1355–1410","1298–136