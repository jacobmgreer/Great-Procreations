1174":"1174年","1096":"1096年","1094":"1094年","1070":"1070年","1038":"1038年","Abt 1100":"約1100年","1068":"1068年","1111":"1111年","1100":"1100年","about 1068":"約1068年","after 1100":"1100年以後","Norfolk, England":"イギリスイギリスノーフォルク","Hunstanton, Norfolk, England":"イギリスノーフォルクハンスタントン","England":"イギリス","Old Hunstanton, Norfolk, England":"イギリスノーフォルクオルド ハンスタントン","lifeSummary":"Ralph fitz Herluin alias Ralph de Hunstantonは約1068年にイギリスノーフォルクハンスタントンでHerluin fitz Ivo of Panworthの息子として生まれた。彼はHelowise de Plaizとの間に少なくとも2人の息子と2人の娘をもうけた。彼は1100年以後にイギリスで死去した。"},"ko":{"about 1068–after 1100":"대략 1068년–1100년 이후","1068–1100":"1068년–1100년","1070–1120":"1070년–1120년","1094–1120":"1094년–1120년","1094–1164":"1094년–1164년","1097–1174":"1097년–1174년","1100–1164":"1100년–1164년","1111–Female":"1111년–사망","1038–Male":"1038년–사망","about 1094":"대략 1094년","1164":"1164년","1120":"1120년","1086":"1086년","1097":"1097년","1174":"1174년","1096":"1096년","1094":"1094년","1070":"1070년","1038":"1038년","Abt 1100":"대략 1100년","1068":"1068년","1111":"1111년","1100":"1100년","about 1068":"대략 1068년","after 1100":"1100년 이후","Norfolk, England":"영국 잉글랜드 노르폴크","Hunstanton, Norfolk, England":"영국 노르폴크 헌스탠턴","England":"영국","Old Hunstanton, Norfolk, England":"영국 노르폴크 드 헌스탠턴","lifeSummary":"Ralph fitz Herluin alias Ralph de Hunstanton(은)는 대략 1068년 영국 노르폴크 헌스탠턴에서 Herluin fitz Ivo of Panworth의 아들로 태어났다. 그는 Helowise de Plaiz(와)과 적어도 두 명의 아들과 두 명의 딸을 두었다. 그는 1100년 이후 영국에서 사망했다."},"lv":{"about 1068–after 1100":"ap 1068. gadu–pēc 1100. gada","1068–1100":"1068–1100","1070–1120":"1070–1120","1094–1120":"1094.gads–1120","1094–1164":"1094.gads–1164","1097–1174":"1097.gads–1174","1100–1164":"1100–1164","1111–Female":"1111–mirusi","1038–Male":"1038–miris","about 1094":"ap 1094. gadu","1164":"1164","1120":"1120","1086":"1086. gads","1097":"1097. gads","1174":"1174","1096":"1096","1094":"1094. gads","1070":"1070","1038":"1038","Abt 1100":"ap 1100. gadu","1068":"1068","1111":"1111","1100":"1100","about 1068":"ap 1068. gadu","after 1100":"pēc 1100. gada","Norfolk,