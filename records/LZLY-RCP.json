ý","1260–Female":"1260–Zesnulá","about 1282":"okolo 1282","1330":"1330","1385":"1385","Abt 1312":"okolo 1312","1283":"1283","1260":"1260","1282":"1282","1348":"1348","1314":"1314","1346":"1346","1257":"1257","1312":"1312","1300":"1300","about 1314":"okolo 1314","1375":"1375","about 1299":"okolo 1299","about 1300":"okolo 1300","about 1330":"okolo 1330","Pandy, Monmouthshire, Wales":"Pandy, Monmouthshire, Wales","Hereford, Herefordshire, England":"Hereford, Herefordshire, Anglie","Herefordshire, England":"Herefordshire, Anglie"},"da":{"about 1282–1346":"omkring 1282–1346","1282–1346":"1282–1346","1283–1348":"1283–1348","1300–Female":"1300–Afdød","1300–1375":"1300–1375","1312–1385":"1312–1385","1314–Male":"1314–Afdød","1330–Female":"1330–Afdød","1257–Male":"1257–Afdød","1260–Female":"1260–Afdød","about 1282":"omkring 1282","1330":"1330","1385":"1385","Abt 1312":"omkring 1312","1283":"1283","1260":"1260","1282":"1282","1348":"1348","1314":"1314","1346":"1346","1257":"1257","1312":"1312","1300":"1300","about 1314":"omkring 1314","1375":"1375","about 1299":"omkring 1299","about 1300":"omkring 1300","about 1330":"omkring 1330","Pandy, Monmouthshire, Wales":"Pandy, Monmouthshire, Wales","Hereford, Herefordshire, England":"Hereford, Herefordshire, England","Herefordshire, England":"Herefordshire, England"},"nl":{"about 1282–1346":"circa 1282–1346","1282–1346":"1282–1346","1283–1348":"1283–1348","1300–Female":"1300–Overleden","1300–1375":"1300–1375","1312–1385":"1312–1385","1314–Male":"1314–Overleden","1330–Female":"1330–Overleden","1257–Male":"1257–Overleden","1260–Female":"1260–Overleden","about 1282":"circa 1282","1330":"1330","1385":"1385","Abt 1312":"circa 1312","1283":"1283","1260":"1260","1282":"1282","1348":"1348","1314":"1314","1346":"1346","1257":"1257","1312":"1312","1300":"1300","about 1314":"circa 1314","1375":"1375","about 1299":"circa 1299","about 1300":"circa 1300","about 1330":"circa 1330","Pandy, Monmouthshire, Wales":"Pandy, Monmouthshire, Wales","Hereford, Herefordshire, England":"Hereford, Herefordshire, England","Herefordshire, England":"Herefordshire, England"},"en":{"about 1282–1346":"about 1282–1346","1282–1346":"1282–1346","1283–1348":"1283–1348","1300–Female":"1300–Deceased","1300–1375":"1300–1375","1312–1385":"1312–1385","1314–Male":"1314–Deceased","1330–Female":"1330–Deceased","1257–Male":"1257–Deceased","1260–Female":"1260–Deceased","about 1282":"about 1282","1330":"1330","1385":"1385","Abt 1312":"about 1312","1283":"1283","1260":"1260","1282":"1282","1348":"1348","1314":"1314","1346":"1346","1257":"1257","1312":"1312","1300":"1300","about 1314":"about 1314","1375":"1375","about 1299":"about 1299","about 1300":"about 1300","about 1330":"about 1330","Pandy, Monmouthshire, Wales":"Pandy, Monmouthshire, Wales","Hereford, Herefordshire, England":"Hereford, Herefordshire, England","Herefordshire, England":"Herefordshire, England","nameMeanings":[{"name":"Pembridge","type":"LAST","attribution":"Dictionary of Family Names in Britain and Ireland © University of the West of England 2016","meanings":["English: locative name from Pembridge (Herefs), which is recorded as  <i>Penebrug(g)e</i> from the 11th to 14th centuries. The place-name derives from an Old English personal name * <i>Pena</i> + Old English  <i>brycg</i> ‘bridge’. In some cases the surname may be from Pen Bridge in Shipley (Sussex), which derives from an uncertain first element + Old English  <i>brycg</i>."],"variants":[{"name":"Pember","meanings":["English: perhaps a variant of <b>Pamber</b>, a habitational name from a place in Hampshire named Pamber, from Old English <i>penn</i> ‘fold, enclosure’ + <i>beorg</i> ‘hill’."]}]},{"name":"Richard","type":"FIRST","attribution":"Dictionary of First Names © Patrick Hanks and Flavia Hodges 1990, 2003, 2006.","meanings":["One of the most enduringly successful of the Old French personal names introduced into Britain by the Normans. It is of Germanic (Frankish) origin, derived from <i>rīc</i> ‘power’ + <i>hard</i> ‘strong, hardy’. It has enjoyed continuous popularity in England from the Conquest to the present day, influenced by the fact that it was borne by three kings of England, in particular  Richard I  (  1157–99 ). He was king for only ten years (  1189–99 ), most of which he spent in warfare abroad, taking part in the Third Crusade and costing the people of England considerable sums in taxes. Nevertheless, he achieved the status of a folk hero, and was never in England long enough to disappoint popular faith in his goodness and justice. He was also Duke of Aquitaine and Normandy and Count of Anjou, fiefs which he held at a time of maximum English expansion in France. His exploits as a leader of the Third Crusade earned him the nickname ‘Coeur de Lion’ or ‘Lionheart’ and a permanent place in popular imagination, in which he was even more firmly enshrined by  Sir Walter Scott's  novel Ivanhoe (  1820 )."],"variants":[{"name":"Rikert","meanings":["One of the most enduringly successful of the Old French personal names introduced into Britain by the Normans. It is of Germanic (Frankish) origin, derived from <i>rīc</i> ‘power’ + <i>hard</i> ‘strong, hardy’. It has enjoyed continuous popularity in England from the Conquest to the present day, influenced by the fact that it was borne by three kings of England, in particular  Richard I  (  1157–99 ). He was king for only ten years (  1189–99 ), most of which he spent in warfare abroad, taking part in the Third Crusade and costing the people of England considerable sums in taxes. Nevertheless, he achieved the status of a folk hero, and was never in England long enough to disappoint popular faith in his goodness and justice. He was also Duke of Aquitaine and Normandy and Count of Anjou, fiefs which he held at a time of maximum English expansion in France. His exploits as a leader of the Third Crusade earned him the nickname ‘Coeur de Lion’ or ‘Lionheart’ and a permanent place in popular imagination, in which he was even more firmly enshrined by  Sir Walter Scott's  novel Ivanhoe (  1820 )."]},{"name":"Rickert","meanings":["One of the most enduringly successful of the Old French personal names introduced into Britain by the Normans. It is of Germanic (Frankish) origin, derived from <i>rīc</i> ‘power’ + <i>hard</i> ‘strong, hardy’. It has enjoyed continuous popularity in England from the Conquest to the present day, influenced by the fact that it was borne by three kings of England, in particular  Richard I  (  1157–99 ). He was king for only ten years (  1189–99 ), most of which he spent in warfare abroad, taking part in the Third Crusade and costing the people of England considerable sums in taxes. Nevertheless, he achieved the status of a folk hero, and was never in England long enough to disappoint popular faith in his goodness and justice. He was also Duke of Aquitaine and Normandy and Count of Anjou, fiefs which he held at a time of maximum English expansion in France. His exploits as a leader of the Third Crusade earned him the nickname ‘Coeur de Lion’ or ‘Lionheart’ and a permanent place in popular imagination, in which he was even more firmly enshrined by  Sir Walter Scott's  novel Ivanhoe (  1820 )."]}]}],"lifeSummary":"When Richard Pembridge was born about 1282, in Pandy, Monmouthshire, Wales, his father, Richard Pembridge, was 27 and his mother, Mrs. Richard Pembridge, was 24. He married Lady Petronella Pembridge about 1299, in Pandy, Monmouthshire, Wales. They were the parents of at least 2 sons and 2 daughters. He died in 1346, in his hometown, at the age of 65."},"et":{"about 1282–1346":"umbes 1282–1346","1282–1346":"1282–1346","1283–1348":"1283–1348","1300–Female":"1300–Surnud","1300–1375":"1300–1375","1312–1385":"1312–1385","1314–Male":"1314–Surnud","1330–Female":"1330–Surnud","1257–Male":"1257–Surnud","1260–Female":"1260–Surnud","about 1282":"umbes 1282","1330":"1330","1385":"1385","Abt 1312":"umbes 1312","1283":"1283","1260":"1260","1282":"1282","1348":"1348","1314":"1314