en","1285–Female":"1285–Overleden","1285–1339":"1285–1339","1338–1410":"1338–1410","1270–Male":"1270–Overleden","1338":"1338","1315":"1315","1410":"1410","1285":"1285","1270":"1270","about 1285":"circa 1285","1328":"1328","1317":"1317","1290":"1290","1339":"1339","Yorkshire, England":"Yorkshire, England","England":"England"},"en":{"about 1285–":"about 1285–Deceased","1285–Female":"1285–Deceased","1285–1339":"1285–1339","1338–1410":"1338–1410","1270–Male":"1270–Deceased","1338":"1338","1315":"1315","1410":"1410","1285":"1285","1270":"1270","about 1285":"about 1285","1328":"1328","1317":"1317","1290":"1290","1339":"1339","Yorkshire, England":"Yorkshire, England","England":"England","nameMeanings":[{"name":"Fixby","type":"LAST","attribution":"Dictionary of American Family Names © Patrick Hanks 2003, 2006.","meanings":["English (Suffolk and Essex): habitational name, perhaps from Bittesby in Leicestershire. The village was depopulated in 1494 to make way for sheep pastures. The pronunciation of the surname as <i>Bekysby</i> (1459) and <i>Bixby</i> (1539) would have arisen when bearers of the name migrated away from Leicestershire. Alternatively, <i>Bixby</i> might be an altered form of   Bigby   or <b>Bixley</b>, a Suffolk name."],"variants":[{"name":"Bigsby","meanings":["English (Essex): habitational name from a now abandoned settlement. See   Bixby  ."]},{"name":"Bigby","meanings":["English: habitational name from a place in Lincolnshire named Bigby, from an Old Danish personal name <i>Bekki</i> + Old Norse <i>bȳ</i> ‘settlement, farmstead’."]}]},{"name":"Sybil","type":"FIRST","attribution":"Dictionary of First Names © Patrick Hanks and Flavia Hodges 1990, 2003, 2006.","meanings":["From the name (Greek <i>Sibylla</i> or <i>Sybilla</i>, with confusion over the vowels from an early period) of a class of ancient prophetesses inspired by Apollo. According to medieval theology, they were pagans denied the knowledge of Christ but blessed by God with some insight into things to come and accordingly admitted to heaven. It was thus regarded as a respectable name to be borne by Christians. This name was introduced to England by the Normans and enjoyed considerable popularity in the Middle Ages."],"variants":[{"name":"Sybilla","meanings":["From the name (Greek <i>Sibylla</i> or <i>Sybilla</i>, with confusion over the vowels from an early period) of a class of ancient prophetesses inspired by Apollo. According to medieval theology, they were pagans denied the knowledge of Christ but blessed by God with some insight into things to come and accordingly admitted to heaven. It was thus regarded as a respectable name to be borne by Christians. This name was introduced to England by the Normans and enjoyed considerable popularity in the Middle Ages."]},{"name":"Sibilla","meanings":["From the name (Greek <i>Sibylla</i> or <i>Sybilla</i>, with confusion over the vowels from an early period) of a class of ancient prophetesses inspired by Apollo. According to medieval theology, they were pagans denied the knowledge of Christ but blessed by God with some insight into things to come and accordingly admitted to heaven. It was thus regarded as a respectable name to be borne by Christians. This name was introduced to England by the Normans and enjoyed considerable popularity in the Middle Ages."]},{"name":"Sybille","meanings":["From Greek.  See  <b>Sybil</b> ."]},{"name":"Sibella","meanings":["From the name (Greek <i>Sibylla</i> or <i>Sybilla</i>, with confusion over the vowels from an early period) of a class of ancient prophetesses inspired by Apollo. According to medieval theology, they were pagans denied the knowledge of Christ but blessed by God with some insight into things to come and accordingly admitted to heaven. It was thus regarded as a respectable name to be borne by Christians. This name was introduced to England by the Normans and enjoyed considerable popularity in the Middle Ages."]}]}],"historicEvents":[{"id":1705190,"age":5,"year":"1290"