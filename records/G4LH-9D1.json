5","1320–1386":"1320–1386","1322–1415":"1322–1415","1325–1383":"1325–1383","1323–1386":"1323–1386","1356–1449":"1356–1449","1290–1386":"1290–1386","1295–Female":"1295–Decedată","1385":"1385","1295":"1295","1383":"1383","1382":"1382","1290":"1290","1415":"1415","1348":"1348","1337":"1337","1325":"1325","1356":"1356","1323":"1323","1322":"1322","1453":"1453","1386":"1386","1320":"1320","23 April 1320":"23 aprilie 1320","March 1386":"martie 1386","18 March 1386":"18 martie 1386","1328":"1328","1449":"1449",", , Devonshire, England":"Devon, Anglia, United Kingdom","Bedfordshire, England":"Bedfordshire, England","Chalgrave, Bedfordshire, England":"Chalgrave, Bedfordshire, England"},"ru":{"23 April 1320–18 March 1386":"23 апреля 1320 г.–18 марта 1386 г.","1320–1385":"1320г.–1385г.","1320–1386":"1320г.–1386г.","1322–1415":"1322г.–1415г.","1325–1383":"1325г.–1383г.","1323–1386":"1323г.–1386г.","1356–1449":"1356г.–1449г.","1290–1386":"1290г.–1386г.","1295–Female":"1295г.–Умершая","1385":"1385 г.","1295":"1295 г.","1383":"1383 г.","1382":"1382 г.","1290":"1290 г.","1415":"1415 г.","1348":"1348 г.","1337":"1337 г.","1325":"1325 г.","1356":"1356 г.","1323":"1323 г.","1322":"1322 г.","1453":"1453 г.","1386":"1386 г.","1320":"1320 г.","23 April 1320":"23 апреля 1320 г.","March 1386":"марта 1386 г.","18 March 1386":"18 марта 1386 г.","1328":"1328 г.","1449":"1449 г.",", , Devonshire, England":"девон, Англия, Великобритания","Bedfordshire, England":"бедфордшир, Англия","Chalgrave, Bedfordshire, England":"халграв, бедфордшир, Англия","lifeSummary":"Когда Nigel Loring родился 23 апреля 1320 г. в местности халграв, бедфордшир, Англия, его отцу по имени Roger Loring было 30 лет, а матери, которую звали Cassandra Perrott, 26. Он женился на женщине по имени Margaret Beaupel в местности девон, Англия, Великобритания. У них была по крайней мере 1 дочь. В 1348 году, в возрасте 28 лет,  он работал по профессии knight of the garter. Он умер 18 марта 1386 г. в его родном городе в возрасте 65 лет и был похоронен в местности халграв, бедфордшир, Англия."},"sm":{"23 April 1320–18 March 1386":"23 Aperila 1320–18 Mati 1386","1320–1385":"1320–1385","1320–1386":"1320–1386","1322–1415":"1322–1415","1325–1383":"1325–1383","1323–1386":"1323–1386","1356–1449":"1356–1449","1290–1386":"1290–1386","1295–Female":"1295–Ua Maliu","1385":"1385","1295":"1295","1383":"1383","1382":"1382","1290":"1290","1415":"1415","1348":"1348","1337":"1337","1325":"1325","1356":"1356","1323":"1323","1322":"1322","1453":"1453","1386":"1386","1320":"1320","23 April 1320":"23 Aperila 1320","March 1386":"Mati 1386","18 March 1386":"18 Mati 1386","1328":"1328","1449":"1449",", , Devonshire, England":"Devon, Egelani, United Kingdom","Bedfordshire, England":"Bedfordshire, Egelani","Chalgrave, Bedfordshire, England":"Chalgrave, Bedfordshire, Egelani"},"sk":{"23 April 1320–18 March 1386":"23. apríl 1320–18. marec 1386","1320–1385":"1320–1385","1320–1386":"1320–1386","1322–1415":"1322–1415","1325–1383":"1325–1383","1323–1386":"1323–1386","1356–1449":"1356–1449","1290–1386":"1290–1386","1295–Female":"1295–Zosnulá","1385":"1385","1295":"1295","1383":"1383","1382":"1382","1290":"1290","1415":"1415","1348":"1348","1337":"1337","1325":"1325","1356":"1356","1323":"1323","1322":"1322","1453":"1453","1386":"1386","1320":"1320","23 April 1320":"23. apríl 1320","March 1386":"marec 1386","18 March 1386":"18. marec 1386","1328":"1328","1449":"1449",", , Devonshire, England":"Devon, Anglicko, Spojené kráľovstvo","Bedfordshire, England":"Bedfordshire, England","Chalgrave, Bedfordshire, England":"Chalgrave, Bedfordshire, England"},"es":{"23 April 1320–18 March 1386":"23 de abril de 1320–18 de marzo de 1386","1320–1385":"1320–1385","1320–1386":"1320–1386","1322–1415":"1322–1415","1325–1383":"1325–1383","1323–1386":"1323–1386","1356–1449":"1356–1449","1290–1386":"1290–1386","1295–Female":"1295–Fallecida","1385":"1385","1295":"1295","1383":"1383","1382":"1382","1290":"1290","1415":"1415","1348":"1348","1337":"1337",