land":"Somerby, Lincolnshire, England","Pinchbeck, Lincolnshire, England":"Pinchbeck, Lincolnshire, England, United Kingdom","Whaplode, Lincolnshire, England":"Whaplode, Lincolnshire, England"},"nl":{"1350–":"1350–Overleden","1350–Female":"1350–Overleden","1345–1386":"1345–1386","1380–1492":"1380–1492","–1492":"–1492","–Male":"Overleden","1325–Male":"1325–Overleden","1330–Female":"1330–Overleden","1325":"1325","1455":"1455","1345":"1345","1386":"1386","1330":"1330","1350":"1350","1382":"1382","1492":"1492","1370":"1370","1380":"1380","Somerby, Lincolnshire, England":"Somerby, Lincolnshire, England","Pinchbeck, Lincolnshire, England":"Pinchbeck, Lincolnshire, Engeland, Verenigd Koninkrijk","Whaplode, Lincolnshire, England":"Whaplode, Lincolnshire, England"},"en":{"1350–":"1350–Deceased","1350–Female":"1350–Deceased","1345–1386":"1345–1386","1380–1492":"1380–1492","–1492":"–1492","–Male":"Deceased","1325–Male":"1325–Deceased","1330–Female":"1330–Deceased","1325":"1325","1455":"1455","1345":"1345","1386":"1386","1330":"1330","1350":"1350","1382":"1382","1492":"1492","1370":"1370","1380":"1380","Somerby, Lincolnshire, England":"Somerby, Lincolnshire, England","Pinchbeck, Lincolnshire, England":"Pinchbeck, Lincolnshire, England, United Kingdom","Whaplode, Lincolnshire, England":"Whaplode, Lincolnshire, England","nameMeanings":[{"name":"Bawde","type":"LAST","attribution":"Dictionary of American Family Names © Patrick Hanks 2003, 2006.","meanings":["North German and Danish: variant of   Bade  ."],"variants":[{"name":"Bade","meanings":["English (North Yorkshire) and Scottish: probably from a Middle English survival of the Old English personal name <i>Bad(d)a</i>, which is perhaps a short form of various compound names with the first element <i>beadu</i> ‘battle’.","North German: from a short form of an ancient Germanic personal name composed with <i>badu</i> ‘strife, battle’.","North German: occupational name from Middle Low German <i>bade</i> ‘messenger’."]}]},{"name":"Joan","type":"FIRST","attribution":"Dictionary of First Names © Patrick Hanks and Flavia Hodges 1990, 2003, 2006.","meanings":["Contracted form of Old French <i>Jo(h)anne</i>, from Latin <i>Io(h)anna</i> (  see  Joanna  ). In England this was the usual feminine form of   John   from the Middle English period onwards and was extremely popular, but in the 16th and 17th centuries it steadily lost ground to   Jane .  It was strongly revived in the first part of the 20th century, partly under the influence of  George Bernard Shaw's  play St Joan (  1923 ), based on the life of  Joan of Arc  (  1412–31 ). Claiming to be guided by the voices of the saints, she persuaded the French dauphin to defy the occupying English forces and have himself crowned, and she led the French army that raised the siege of Orleans in  1429 . The following year she was captured by the Burgundians and sold to the English, and a year later she was burned at the stake for witchcraft at the age of 18 or 19. Her story has captured the imagination of many writers, and she is variously portrayed as a national and political hero, a model of apolitical straightforwardness and honesty, and a religious heroine. She was canonized in  1920 . More recent influences have included the American film actress  Joan Crawford  (  1908–77 , born  Lucille le Sueur ), the British actress  Joan Collins  (  b. 1933 ), the American comedienne  Joan Rivers  (  b. 1933 ), and the West Indian pop singer  Joan Armatrading  (  b. 1950 )."],"variants":[{"name":"John","meanings":["As a boy's name this represents a revival of Middle English <i>Jan</i>, a by‐form of   John  , or an adoption of the common European form with this spelling. As a girl's name it is a short form of names such as   Janet   and   Janice ."]}]}],"historicEvents":[{"id":1705195,"age":32,"year":"1382","julianDay":2225826,"title":"Wycliffe's Bible","description":"John Wycliffe, English theologian and professor at the University of Oxford, completed a translation of the Bible from the Latin Vulgate into Middle English. This translation is known as Wycliffe's Bible and was completed around 1382.","url":"https://en.wikipedia.org/wiki/Wycliffe%27s_Bible","urlTitle":"Wikipedia - Wycliffe's Bible","jurisdictionLevel":2},{"id":1705197,"age":105,"year":"1455","julianDay":2252488,"title":"Wars of the Roses","description":"Wars of the Roses was a series of English civil wars for control of the throne of England between the royal families House of Lancaster and the House of York. The name of the war was derived as the red rose was the symbol of the Lancastrians and the white rose was the symbol of the Yorks.","url":"https://www.history.com/topics/british-history/wars-of-the-roses","urlTitle":"History - Wars of the Roses","jurisdictionLevel":2}],"lifeSummary":"When Lady Joan Bawde was born in 1350, in Somerby, Lincolnshire, England, her father, Sir. William Bawde Knight, was 25 and her mother, Mrs. Lady William Bawde, was 20. She married Sir Thomas Sarsonne de Pinchbeck in 1370, in Whaplode, Lincolnshire, England. They were the parents of at least 4 sons. She died in Whaplode, Lincolnshire, England."},"et":{"1350–":"1350–Surnud","1350–Female":"1350–Surnud","1345–1386":"1345–1386","1380–1492":"1380–1492","–1492":"–1492","–Male":"Surnud","1325–Male":"1325–Surnud","1330–Female":"1330–Surnud","1325":"1325","1455":"1455","1345":"1345","1386":"1386","1330":"1330","1350":"1350","1382":"1382","1492":"1492","1370":"1370","1380":"1380","Somerby, Lincolnshire, England":"Somerby, Lincolnshire, England","Pinchbeck, Lincolnshire, England":"Pinchbeck, Lincolnshire, Inglismaa, United Kingdom","Whaplode, Lincolnshire, England":"Whaplode, Lincolnshire, England"},"fi":{"1350–":"1350–Kuollut","1350–Female":"1350–Kuollut","1345–1386":"1345–1386","1380–1492":"1380–1492","–1492":"–1492","–Male":"Kuollut","1325–Male":"1325–Kuollut","1330–Female":"1330–Kuollut","1325":"1325","1455":"1455","1345":"1345","1386":"1386","1330":"1330","1350":"1350","1382":"1382",