lcullen, Kildare, Ireland":"Kilcullen, County Kildare, Irland"},"nl":{"1415–December 1462":"1415–december 1462","1400–Female":"1400–Overleden","1415–1462":"1415–1462","1432–1496":"1432–1496","1457–1495":"1457–1495","1381–1454":"1381–1454","1380–1456":"1380–1456","December 1462":"december 1462","1495":"1495","1462":"1462","1381":"1381","1380":"1380","1415":"1415","1457":"1457","1456":"1456","1400":"1400","1454":"1454","1432":"1432","1496":"1496","25 October 1454":"25 oktober 1454","Killeen, Meath, Ireland":"Killeen, County Meath, Ierland","Kilcullen, County Kildare, Ireland":"Kilcullen, County Kildare, Ierland","Dublin, Dublin, Leinster, Ireland":"Dublin Castle, County Dublin, Ierland","Harristown, Kildare, Ireland":"Harristown, County Kildare, Ierland","Kilcullen, Kildare, Ireland":"Kilcullen, County Kildare, Ierland"},"en":{"1415–December 1462":"1415–December 1462","1400–Female":"1400–Deceased","1415–1462":"1415–1462","1432–1496":"1432–1496","1457–1495":"1457–1495","1381–1454":"1381–1454","1380–1456":"1380–1456","December 1462":"December 1462","1495":"1495","1462":"1462","1381":"1381","1380":"1380","1415":"1415","1457":"1457","1456":"1456","1400":"1400","1454":"1454","1432":"1432","1496":"1496","25 October 1454":"25 October 1454","Killeen, Meath, Ireland":"Killeen, County Meath, Ireland","Kilcullen, County Kildare, Ireland":"Kilcullen, County Kildare, Ireland","Dublin, Dublin, Leinster, Ireland":"Dublin Castle, County Dublin, Ireland","Harristown, Kildare, Ireland":"Harristown, County Kildare, Ireland","Kilcullen, Kildare, Ireland":"Kilcullen, County Kildare, Ireland","nameMeanings":[{"name":"Eustace","type":"LAST","attribution":"Dictionary of American Family Names © Patrick Hanks 2003, 2006.","meanings":["English: from the Middle English personal name <i>Eustace</i> (male and female), via Old French <i>Eustace</i> (male) from Latin <i>Eustachius</i>, <i>Eustacius</i>, from Greek <i>Eustachios</i>, composed of the elements <i>eu</i> ‘good’ and <i>stachys</i> ‘ear (of grain)’, hence ‘fruitful’. The name was borne by various early Christian saints, but little is known of the most famous Saint Eustace, patron saint of hunters, said to have been converted by the vision of a crucifix between the antlers of a hunted stag. In North America, this surname form of the name may have absorbed Greek surnames based on the similar personal name <i>Efstathios</i>, such as <b>Efstathiadis</b> and   Efstathiou  . See also   Stacey  ."],"variants":[{"name":"Heustis","meanings":["English: perhaps a variant of   Eustace  ."]},{"name":"Estacio","meanings":["Some characteristic forenames:  Spanish Carlos, Jose, Manuel, Adolfo, Aida, Benigno, Carolina, Celedonio, Cosme, Edgardo, Emilio, Enrique.","Portuguese, Galician, and Spanish: variant of <b>Eustacio</b> (see   Eustace  )."]},{"name":"Eustice","meanings":["English (Cornwall): variant of   Eustace  ."]},{"name":"Eustache","meanings":["French and West Indian (mainly Haiti): from the French personal name <i>Eustache</i>, from Latin <i>Eustachius</i> (see   Eustace  ). This surname was brought to the US mainly from Haiti."]},{"name":"Astacio","meanings":["Some characteristic forenames:  Spanish Jose, Miguel, Jorge, Julio, Justo, Luis, Aida, Alberto, Andres, Angel, Carlos, Domingo.","Spanish: probably from a variant of the personal name <i>Estacio</i> (Latin <i>Eustachius</i>; see   Eustace  ). This surname is found mainly in the Dominican Republic. In Spain, it is concentrated in Alcalá de Guadaira, in Seville province."]},{"name":"Eustaquio","meanings":["Spanish and Portuguese: from the personal name <i>Eustaquio</i> (see   Eustace  )."]},{"name":"Eustis","meanings":["English (Glamorgan): variant of   Eustace  . This form of the surname is now rare in Britain."]},{"name":"Efstathiou","meanings":["Greek: patronymic from the genitive case of the personal name <i>Efstathios</i>, classical Greek <i>Eustathios</i> ‘well-grounded, firm, steadfast’ (from <i>eu</i> ‘well’ + <i>stathēs</i> ‘standing’, a derivative of <i>histēmi</i> ‘to stand’). <i>Eustathios</i> was the name of several saints and patriarchs of the Eastern Church. In the early Middle Ages this name became confused in the Western Church with <i>Eustachios</i> ‘fruitful’ (see   Eustace  )."]},{"name":"Huestis","meanings":["Perhaps an altered form of English   Eustace  . Compare   Heustis  ."]}]},{"name":"Rowland","type":"FIRST","attribution":"Dictionary of First Names © Patrick Hanks and Flavia Hodges 1990, 2003, 2006.","meanings":["Variant spelling of   Roland  , or a transferred use of the surname derived from that given name in the Middle Ages."],"variants":[{"name":"Roland","meanings":["From an Old French personal name of Germanic (Frankish) origin, from <i>hrōd</i> ‘fame’ + <i>land</i> ‘land, territory’. This was adopted by the Normans and introduced by them to Britain. In Old French literature it is borne by a legendary Frankish hero, a vassal of Charlemagne, whose exploits are told in the <i>Chanson de Roland</i>. The subject of the poem is Roland's death at the Battle of Roncesvalles in the Pyrenees in  778 , while protecting the rearguard of the Frankish army on its retreat from Spain. Roland is depicted in literature and legend as headstrong and impulsive. His devoted friendship with the prudent  Oliver  is also legendary."]}]}],"lifeSummary":"When Rowland Eustace 1st and last Baron Portlester was born in 1415, his father, Sir Edward FitzEustace, was 34 and his mother, Maud Margaret D'Artois, was 35. He had at least 1 daughter with Margaret Maude d'Artois. He died in December 1462, in Kilcullen, County Kildare, Ireland, at the age of 47."},"et":{"1415–December 1462":"1415–detsember 1462","1400–Female":"1400–Surnud","1415–1462":"1415–1462","1432–1496":"1432–1496","1457–1495":"1457–1495","1381–1454":"1381–1454","1380–1456":"1380–1456","December 1462":"detsember 1462","1495":"1495","1462":"1462","1381":"1381","1380":"1380","1415":"1415","1457":"1457","1456":"1456","1400":"1400","1454":"1454","1432