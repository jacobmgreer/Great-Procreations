ncolnshire, England":"Kirkby, Lincolnshire, Anglie","Grande-Bretagne":"United Kingdom","Harrold, Bedfordshire, England, United Kingdom":"Harrold, Bedfordshire, Anglie, United Kingdom"},"da":{"1255–after 1281":"1255–efter 1281","1254–Female":"1254–Afdød","1255–1281":"1255–1281","1250–1304":"1250–1304","1278–1332":"1278–1332","1280–1352":"1280–1352","1295–Male":"1295–Afdød","1329–1330":"1329–1330","–1292":"–1292","1225–1255":"1225–1255","about 1280":"omkring 1280","after 1281":"efter 1281","1330":"1330","1352":"1352","1295":"1295","1250":"1250","1292":"1292","1281":"1281","1280":"1280","1304":"1304","1225":"1225","1278":"1278","1255":"1255","1332":"1332","1254":"1254","1329":"1329","Garboldesham, Norfolk, England":"Norfolk, England, United Kingdom","Pakenham, Suffolk, England":"Pakenham, Suffolk, England","Kirkby, Lincolnshire, England":"Kirkby, Lincolnshire, England","Grande-Bretagne":"United Kingdom","Harrold, Bedfordshire, England, United Kingdom":"Harrold, Bedfordshire, England, United Kingdom"},"nl":{"1255–after 1281":"1255–na 1281","1254–Female":"1254–Overleden","1255–1281":"1255–1281","1250–1304":"1250–1304","1278–1332":"1278–1332","1280–1352":"1280–1352","1295–Male":"1295–Overleden","1329–1330":"1329–1330","–1292":"–1292","1225–1255":"1225–1255","about 1280":"circa 1280","after 1281":"na 1281","1330":"1330","1352":"1352","1295":"1295","1250":"1250","1292":"1292","1281":"1281","1280":"1280","1304":"1304","1225":"1225","1278":"1278","1255":"1255","1332":"1332","1254":"1254","1329":"1329","Garboldesham, Norfolk, England":"Norfolk, Engeland, Verenigd Koninkrijk","Pakenham, Suffolk, England":"Pakenham, Suffolk, England","Kirkby, Lincolnshire, England":"Kirkby, Lincolnshire, England","Grande-Bretagne":"Verenigd Koninkrijk","Harrold, Bedfordshire, England, United Kingdom":"Harrold, Bedfordshire, Engeland, Verenigd Koninkrijk"},"en":{"1255–after 1281":"1255–after 1281","1254–Female":"1254–Deceased","1255–1281":"1255–1281","1250–1304":"1250–1304","1278–1332":"1278–1332","1280–1352":"1280–1352","1295–Male":"1295–Deceased","1329–1330":"1329–1330","–1292":"–1292","1225–1255":"1225–1255","about 1280":"about 1280","after 1281":"after 1281","1330":"1330","1352":"1352","1295":"1295","1250":"1250","1292":"1292","1281":"1281","1280":"1280","1304":"1304","1225":"1225","1278":"1278","1255":"1255","1332":"1332","1254":"1254","1329":"1329","Garboldesham, Norfolk, England":"Norfolk, England, United Kingdom","Pakenham, Suffolk, England":"Pakenham, Suffolk, England","Kirkby, Lincolnshire, England":"Kirkby, Lincolnshire, England","Grande-Bretagne":"United Kingdom","Harrold, Bedfordshire, England, United Kingdom":"Harrold, Bedfordshire, England, United Kingdom","nameMeanings":[{"name":"Morin","type":"LAST","attribution":"Dictionary of American Family Names © Patrick Hanks 2003, 2006.","meanings":["Some characteristic forenames:  French Armand, Marcel, Lucien, Emile, Pierre, Andre, Normand, Gilles, Jacques, Fernand, Adrien, Gaetan.","French and Walloon: from a variant of the French personal name   Maurin  ; or a diminutive of   More   2, a nickname for a dark-skinned man. It is also found in England, as a surname of Huguenot origin. Compare   Moran  ,   Morang  ,   Morein  ,   Morong  ,   Morrin  , and   Morrow  .","Italian (northern): variant of   Morino  ."],"variants":[{"name":"Morain","meanings":["Irish: altered form of <b>Moran</b>.","French: variant of   Morin  ."]},{"name":"Maurin","meanings":["French: from a medieval personal name derived from the Latin name <i>Maurinus</i>, a derivative of <i>Maurus</i> ‘Moor’ (see   Mauro  ), which was the name of a 6th-century Christian martyr. This form of the surname is also found in Germany, Italy, and Slovenia (see below). Compare   Morin  .","Germanized or Americanized form of Slovenian <b>Mavrin</b>: from a personal name derived from the Latin name <i>Maurinus</i> (see above). In part, <i>Maurin</i> is a Gottscheerish (i.e. Gottschee German) surname, originating from the Kočevsko region in Lower Carniola, Slovenia (see   Kocevar  ).","Italian: rare variant of   Maurino  , a cognate of 1 above."]},{"name":"Morneau","meanings":["Some characteristic forenames:  French Andre, Armand, Lucien, Adrien, Emile, Gaston, Gilles, Henri, Herve, Hilaire, Laurent, Napoleon.","French: shortened form of <b>Morineau</b>, derived from   Morin  , hence a double diminutive of   More   2, a nickname for a dark-skinned man."]},{"name":"Morang","meanings":["Altered form of French   Morin  ."]},{"name":"Morein","meanings":["Some characteristic forenames:  Irish Donovan, Brigid.  Russian Vitaly, Gleb.","Altered form of French   Morin  . This surname is established in LA.","Irish: Anglicized form of Gaelic <b>Ó Móráin</b> (see   Moran  )."]},{"name":"Morong","meanings":["Altered form of French   Morin  ."]}]},{"name":"Joan","type":"FIRST","attribution":"Dictionary of First Names © Patrick Hanks and Flavia Hodges 1990, 2003, 2006.","meanings":["Contracted form of Old French <i>Jo(h)anne</i>, from Latin <i>Io(h)anna</i> (  see  Joanna  ). In England this was the usual feminine form of   John   from the Middle English period onwards and was extremely popular, but in the 16th and 17th centuries it steadily lost ground to   Jane .  It was strongly revived in the first part of the 20th century, partly under the influence of  George Bernard Shaw's  play St Joan (  1923 ), based on the life of  Joan of Arc  (  1412–31 ). Claiming to be guided by the voices of the saints, she persuaded the French dauphin to defy the occupying English forces and have himself crowned, and she led the French army that raised the siege of Orleans in  1429 . The following year she was captured by the Burgundians and sold to the English, and a year later she was burned at the stake for witchcraft at the age of 18 or 19. Her story has captured the imagination of many writers, and she is variously portrayed as a national and political hero, a model of apolitical straightforwardness and honesty, and a religious heroine. She was canonized in  1920 . More recent influences have included the American film actress  Joan Crawford  (  1908–77 , born  Lucille le Sueur ), the British actress  Joan Collins  (  b. 1933 ), the American comedienne  Joan Rivers  (  b. 1933 ), and the West Indian pop singer  Joan Armatrading  (  b. 1950 )."],"variants":[{"name":"John","meanings":["As a boy's name this represents a revival of Middle English <i>Jan</i>, a by‐form of   John  , or an adoption of the common European form with this spelling. As a girl's name it is a short form of names such as   Janet   and   Janice ."]}]},{"name":"de","type":"FIRST","attribution":"Dictionary of First Names © Patrick Hanks and Flavia Hodges 1990, 2003, 2006.","meanings":["Variant of   Dev ."],"variants":[{"name":"Deborah","meanings":["Biblical name (meaning ‘bee’ in Hebrew), borne by the nurse of Rebecca (Genesis 35:8) and by a woman judge and prophet (Judges 4–5) who led the Israelites to victory over the Canaanites. It has always been popular as a Jewish name. It was in use among Christians by the mid 16th century and was taken up by the Puritans in the 17th century, in part because the bee was a symbol of industriousness. Since then it has enjoyed enormous popularity, peaking in the 1960s. Among other famous bearers is the actress  Deborah Kerr  (  1921–2007 )."]}]}],"lifeSummary":"Joan de Morin was born in 1255, in United Kingdom as the daughter of Sir Ralph de Morin, Knight. She had at least 5 sons with William I de Pakenham. She died after 1281, in Norfolk, England, United Kingdom."},"et":{"1255–after 1281":"1255–pärast 1281","1254–Female":"1254–Surnud","1255–1281":"1255–1281","1250–1304":"1250–1304","1278–1332":"1278–1332","1280–1352":"1280–1352","1295–Male":"1295–Surnud","1329–1330":"1329–1330","–1292":"–1292","1225–1255":"1225–1255","about 1280":"umbes 1280","after 1281":"pärast 1281","1330":"1330","1352":"1352","1295":"1295","1250":"1250","1292":"1292","1281":"1281","1280":"1280","1304":"1304","1225":"1225"