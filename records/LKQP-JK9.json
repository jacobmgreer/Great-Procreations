":"1224","1233":"1233","1200":"1200","1213 and 1232":"fra 8. januar 1213 til 7. januar 1233","Lowdham, Nottinghamshire, England":"Lowdham, Nottinghamshire, England","Lowdham, Nottinghamshire, England, United Kingdom":"Lowdham, Nottinghamshire, England, United Kingdom","Nottinghamshire, England and Yorkshire, England":"Nottinghamshire, England, United Kingdom"},"nl":{"before 1198–1242":"vóór 1198–1242","1198–1242":"1198–1242","1200–1225":"1200–1225","1220–1272":"1220–1272","1225–1272":"1225–1272","–1326":"–1326","1150–Male":"1150–Overleden","1151–Female":"1151–Overleden","before 1198":"vóór 1198","1220":"1220","1242":"1242","1198":"1198","1151":"1151","1272":"1272","1150":"1150","1326":"1326","1215":"1215","1225":"1225","1224":"1224","1233":"1233","1200":"1200","1213 and 1232":"van 8 januari 1213 to 7 januari 1233","Lowdham, Nottinghamshire, England":"Lowdham, Nottinghamshire, England","Lowdham, Nottinghamshire, England, United Kingdom":"Lowdham, Nottinghamshire, Engeland, Verenigd Koninkrijk","Nottinghamshire, England and Yorkshire, England":"Nottinghamshire, Engeland, Verenigd Koninkrijk"},"en":{"before 1198–1242":"before 1198–1242","1198–1242":"1198–1242","1200–1225":"1200–1225","1220–1272":"1220–1272","1225–1272":"1225–1272","–1326":"–1326","1150–Male":"1150–Deceased","1151–Female":"1151–Deceased","before 1198":"before 1198","1220":"1220","1242":"1242","1198":"1198","1151":"1151","1272":"1272","1150":"1150","1326":"1326","1215":"1215","1225":"1225","1224":"1224","1233":"1233","1200":"1200","1213 and 1232":"from 8 January 1213 to 7 January 1233","Lowdham, Nottinghamshire, England":"Lowdham, Nottinghamshire, England","Lowdham, Nottinghamshire, England, United Kingdom":"Lowdham, Nottinghamshire, England, United Kingdom","Nottinghamshire, England and Yorkshire, England":"Nottinghamshire, England, United Kingdom","nameMeanings":[{"name":"Loudham","type":"LAST","attribution":"Dictionary of Family Names in Britain and Ireland © University of the West of England 2016","meanings":["English: locative name from Ludham (Norfolk)."],"variants":[]},{"name":"Eustace","type":"FIRST","attribution":"Dictionary of First Names © Patrick Hanks and Flavia Hodges 1990, 2003, 2006.","meanings":["From the Old French form of the Late Greek names <i>Eustakhios</i> and <i>Eustathios</i>. These were evidently of separate origin, the former derived from <i>eu</i> ‘well, good’ + <i>stakhys</i> ‘grapes’, the latter from <i>eu</i> + <i>stēnai</i> ‘to stand’. However, the tradition is very confused. The name was introduced in this form to Britain by the Normans, among whom it was popular as a result of the fame of  St Eustace , a Norman nobleman who was said to have been converted to Christianity by the vision of a crucifix between the antlers of the stag he was hunting."],"variants":[]}],"historicEvents":[{"id":1705187,"age":17,"year":"1215","julianDay":2164830,"title":"Magna Carta","description":"King John of England agreed to a charter of rights called the Magna Carta. The document was originally drafted by the Archbishop of Canterbury to establish peace between King John and a group of rebel barons. The Magna Carta was completed in 1215 and is now considered to be one of the greatest constitutional documents of all time.","url":"https://www.nationalarchives.gov.uk/education/medieval/magna-carta/","urlTitle":"National Archives - Magna Carta","jurisdictionLevel":2},{"id":1705188,"age":26,"year":"1224","julianDay":2168117,"title":"France Declares War on England","description":"France declared war on England as Louis VIII of France attacked Poitou and northern Gascony.","jurisdictionLevel":2}],"lifeSummary":"When Eustace Loudham was born before 1198, in Lowdham, Nottinghamshire, England, his father, Herbert Loudham, was 47 and his mother, Dama En Blanco, was 46. He married Lady Helyas of Midhope in 1220, in Lowdham, Nottinghamshire, England, United Kingdom. They were the parents of at least 2 sons and 1 daughter. In 1233, his occupation is listed as high sheriff of nottingham . He died in 1242, in his hometown."},"et":{"before 1198–1242":"enne 1198–1242","1198–1242":"1198–1242","1200–1225":"1200–1225","1220–1272":"1220–1272","1225–1272":"1225–1272","–1326":"–1326","1150–Male":"1150–Surnud","1151–Female":"1151–Surnud","before 1198":"enne 1198","1220":"1220","1242":"1242","1198":"1198","1151":"1151","1272":"1272","1150":"1150","1326":"1326","1215":"1215","1225":"1225","1224":"1224","1233":"1233","1200":"1200","1213 and 1232":"8. jaanuar 1213 kuni 7. jaanuar 1233","Lowdham, Nottinghamshire, England":"Lowdham, Nottinghamshire, England","Lowdham, Nottinghamshire, England, United Kingdom":"Lowdham, Nottinghamshire, Inglismaa, United Kingdom","Nottinghamshire, England and Yorkshire, England":"Nottinghamshire, Inglismaa, United Kingdom"},"fi":{"before 1198–1242":"ennen vuotta 1198–1242","1198–1242":"1198–1242","1200–1225":"1200–1225","1220–1272":"1220–1272","1225–1272":"1225–1272","–1326":"–1326","1150–Male":"1150–Kuollut","1151–Female":"1151–Kuollut","before 1198":"ennen vuotta 1198","1220":"1220","1242":"1242","1198":"1198","1151":"1151","1272":"1272","1150":"1150","1326":"1326","1215":"1215","1225":"1225","1224":"1224","1233":"1233","1200":"1200","1213 and 1232":"vuodesta 8. tammikuuta 1213 vuoteen 7. tammikuuta 1233","Lowdham, Nottinghamshire, England":"Lowdham, Nottinghamshire, England","Lowdham, Nottinghamshire, England, United Kingdom":"Lowdham, Nottinghamshire, Englanti, Yhdistynyt kuningaskunta","Nottinghamshire, England and Yorkshire, England":"Nottinghamshire, Englanti, Yhdistynyt kuningaskunta"},"fr":{"before 1198–1242":"avant 1198–1242","1198–1242":"1198–1242","1200–1225":"1200–1225","1220–1272":"1220–1272","1225–1272":"1225–1272","–1326":"–1326","1150–Male":"1150–Décédé","1151–Female":"1151–Décédée","before 1198":"avant 1198","1220":"1220","1242":"1242","1198":"1198","1151":"1151","1272":"1272","1150":"1150","1326":"1326","1215":"1215","1225":"1225","1224":"1224","1233":"1233","1200":"1200","1213 and 1232":"du 8