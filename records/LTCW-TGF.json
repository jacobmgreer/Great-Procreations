{"version":"1.2","person":{"datePublished":"2023-12-13","name":"Henry de Tregoz","nameForms":[{"lang":"en","fullText":"Henry de Tregoz","parts":[{"type":"http://gedcomx.org/Given","value":"Henry"},{"type":"http://gedcomx.org/Surname","value":"de Tregoz"}],"order":"EUROTYPIC"}],"gender":"Male","lifespan":"1181–1256","fullLifespan":"Bef 1181–Bef 1256","birthPlace":{"address":"Sussex, England","geo":{"latitude":50.981,"longitude":-0.3385,"@type":"GeoCoordinates"},"@type":"Place"},"deathPlace":{"address":"England","geo":{"latitude":52.4379,"longitude":-1.6496,"@type":"GeoCoordinates"},"@type":"Place"},"userCertifiedLifeSummary":"«b»Biography«/b»\nHENRY DE TREGOZ, brother and heir of John, d. 1197, was mentioned in connection with Goring in 1201, was a knight in Sussex in 1206, a juryman for a forest perambulation in Sussex in 1225 and a Commissioner of oyer and terminer in that county in 1226. He was involved in numerous lawsuits, some with his brother Thomas, between 1202 and 1226. He died possibly between 1243 and 1256.","sourceList":[{"title":"Henry (Tregoz) de Tregoz on WikiTree","sourceType":"DEFAULT","sourceLink":"http://www.wikitree.com/wiki/Tregoz-43","sourceUri":"3LRN-XSW"}],"events":[{"name":"Birth","sources":"0","year":"1181","date":"Bef 1181","place":"Sussex, England"},{"name":"Death of Parent","sources":"0","year":"1188","date":"1188","place":"England, United Kingdom","age":"8","id":"GSTB-PTG"},{"name":"Death of Parent","sources":"0","year":"1195","date":"Bef 8 April 1195","place":"England","age":"14","id":"GHBK-XMC"},{"name":"Birth of Child","sources":"0","year":"1203","date":"about 1203","place":"East Preston, Sussex, England","age":"23","id":"G649-MNF"},{"name":"Death","sources":"0","year":"1256","date":"Bef 1256","place":"England","age":"74"},{"name":"Marriage","sources":"0","year":"1181","date":"before 1181","type":"Parental"}],"parent":[{"name":"John de Tregoz","gender":"Male","lifespan":"1137–1195","birthDate":"/+1137","deathDate":"/+1195-04-08","age