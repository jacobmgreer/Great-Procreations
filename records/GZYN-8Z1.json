eanings":[{"name":"de","type":"LAST","attribution":"Dictionary of American Family Names © Patrick Hanks 2003, 2006.","meanings":["Some characteristic forenames:  Indian Dilip, Anirban, Gopal, Alok, Anindya, Arunava, Asit, Asok, Dibyendu, Goutam, Indra, Indranil.","Indian: variant of   Dey  ."],"variants":[{"name":"Dey","meanings":["Some characteristic forenames:  Indian Ashit, Indu, Naina, Partha, Soumya, Ajit, Anjan, Anjana, Anup, Arjun, Arun, Ashim.","English, Scottish, and Welsh: variant of   Day  .","German: topographic name from a field name in North Rhine-Westphalia, denoting a sizeable piece of land, from Middle Low German <i>dē</i> ‘thigh’ (referring to the shape of the property)."]}]},{"name":"Tregoz","type":"LAST","attribution":"Dictionary of American Family Names © Patrick Hanks 2003, 2006.","meanings":["Cornish (Cornwall and Devon): habitational name from Treago in Crantock (Cornwall). The placename derives from Middle Cornish <i>tre</i> ‘estate, farmstead’ + uncertain final element.","Altered form of French   Tricot   or of some other similar (like-sounding) surname. It was reportedly brought to North America from England. Today it is found mainly in PA and OH. Compare   Trago  .","History: This surname (see 2 above) is listed in the (US) National Huguenot Society's register of qualified Huguenot ancestors and also in the similar register of the Huguenot Society of America."],"variants":[{"name":"Tricot","meanings":["(2010: NA)","French:","nickname from a diminutive of <i>trique</i> ‘cudgel’."]},{"name":"Trago","meanings":["Variant of   Trego  , a surname of Cornish and French origin. In the US, it is found mainly in PA and OH."]}]},{"name":"Albreda","type":"FIRST","attribution":"Dictionary of First Names © Patrick Hanks and Flavia Hodges 1990, 2003, 2006.","meanings":["Variant of   Elfreda  , but now probably taken as a feminine equivalent of   Alfred ."],"variants":[]}],"lifeSummary":"Albreda de Tregoz was born in 1068, in Mount Bures, Essex, England,