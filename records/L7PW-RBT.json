le":"1300–Overleden","1333–Female":"1333–Overleden","1338–Male":"1338–Overleden","1312–Female":"1312–Overleden","1338":"1338","1315":"1315","1346":"1346","1312":"1312","abt 1338":"circa 1338","1333":"1333","1300":"1300","1382":"1382","1328":"1328","1317":"1317","Somerset, England":"Somerset, England","Nunney, Somerset, England, United Kingdom":"Nunney, Somerset, Engeland, Verenigd Koninkrijk","England":"England","of Norton, Hants, Eng.":"Hampshire, Engeland, Verenigd Koninkrijk"},"en":{"1312–":"1312–Deceased","1312–1346":"1312–1346","1300–Male":"1300–Deceased","1333–Female":"1333–Deceased","1338–Male":"1338–Deceased","1312–Female":"1312–Deceased","1338":"1338","1315":"1315","1346":"1346","1312":"1312","abt 1338":"about 1338","1333":"1333","1300":"1300","1382":"1382","1328":"1328","1317":"1317","Somerset, England":"Somerset, England","Nunney, Somerset, England, United Kingdom":"Nunney, Somerset, England, United Kingdom","England":"England","of Norton, Hants, Eng.":"Hampshire, England, United Kingdom","nameMeanings":[{"name":"de","type":"LAST","attribution":"Dictionary of American Family Names © Patrick Hanks 2003, 2006.","meanings":["Some characteristic forenames:  Indian Dilip, Anirban, Gopal, Alok, Anindya, Arunava, Asit, Asok, Dibyendu, Goutam, Indra, Indranil.","Indian: variant of   Dey  ."],"variants":[{"name":"Dey","meanings":["Some characteristic forenames:  Indian Ashit, Indu, Naina, Partha, Soumya, Ajit, Anjan, Anjana, Anup, Arjun, Arun, Ashim.","English, Scottish, and Welsh: variant of   Day  .","German: topographic name from a field name in North Rhine-Westphalia, denoting a sizeable piece of land, from Middle Low German <i>dē</i> ‘thigh’ (referring to the shape of the property)."]}]},{"name":"Hampshire","type":"LAST","attribution":"Dictionary of American Family Names © Patrick Hanks 2003, 2006.","meanings":["English:","(Yorkshire): habitational name from the southern English county so called, which derives its name from <i>Hampton</i> (i.e. the port of Southampton) + Old English <i>scīr</i> ‘division, district’. The County was formerly called <i>Southamptonshire</i>.","(Surrey and Kent): habitational name from the area of Hallamshire in southern Yorkshire, named from   Hallam   + Middle English <i>schir</i> ‘division’, ‘administrative region’ (Old English <i>scīr</i>). The surname is most common in Yorkshire, where this second derivation is most likely to be the source."],"variants":[{"name":"Hallam","meanings":["English (North Midlands): habitational name from Halam (Nottinghamshire) or from Kirk or West Hallam (Derbyshire), all named with the Old English dative plural <i>halum</i> ‘(at the) nooks or corners of land’ (from Old English <i>halh</i> ‘nook, recess’; see   Hale   1). The name may also be derived from Hallam in Sheffield (Yorkshire), sometimes called <i>Hallamshire</i>, named from Old English <i>hallum</i> ‘(at the) rocks’, the dative plural of Old English <i>hall</i> ‘stone, rock’, Old Norse <i>hallr</i>.","English: possibly a variant of   Allam   with prosthetic <i>H-</i>."]},{"name":"Homsher","meanings":["Perhaps an altered form of English   Hampshire  ."]},{"name":"Hamsher","meanings":["English (Worcestershire): variant of   Hampshire  ."]},{"name":"Hanshaw","meanings":["English: variant of   Hampshire  .","Possibly also an Americanized form of German   Handschuh  ."]}]},{"name":"Margaret","type":"FIRST","attribution":"Dictionary of First Names © Patrick Hanks and Flavia Hodges 1990, 2003, 2006.","meanings":["An extremely common given name from the Middle Ages onwards, derived via Old French <i>Marguerite</i> and Latin <i>Margarita</i> from Greek <i>Margarītēs</i>, from <i>margaron</i> ‘pearl’, a word ultimately of Hebrew origin. The name was always understood to mean ‘pearl’ throughout the Middle Ages. The first  St Margaret  was martyred at Antioch in Pisidia during the persecution instigated by the  Emperor Diocletian  in the early 4th century. However, there is some doubt about her name, as the same saint is venerated in the Orthodox Church as   Marina .  There were several other saintly bearers of the name, including St Margaret of Scotland (  d. 1093 ), wife of  King Malcolm Canmore  and daughter of Edmund Ironside of England. It was also the name of the wife of  Henry VI  of England,  Margaret of Anjou  (  1430–82 ), and of  Margaret Tudor  (  1489–1541 ), sister of  Henry VIII , who married James IV of Scotland and ruled as regent there after his death.  See also  Margery  ,   Marjorie ."],"variants":[{"name":"Margareta","meanings":["From the Latin form of Greek <i>Margarītēs</i>.  See  <b>Margaret</b>   ."]},{"name":"Margaretta","meanings":["An extremely common given name from the Middle Ages onwards, derived via Old French <i>Marguerite</i> and Latin <i>Margarita</i> from Greek <i>Margarītēs</i>, from <i>margaron</i> ‘pearl’, a word ultimately of Hebrew origin. The name was always understood to mean ‘pearl’ throughout the Middle Ages. The first  St Margaret  was martyred at Antioch in Pisidia during the persecution instigated by the  Emperor Diocletian  in the early 4th century. However, there is some doubt about her name, as the same saint is venerated in the Orthodox Church as   Marina .  There were several other saintly bearers of the name, including St Margaret of Scotland (  d. 1093 ), wife of  King Malcolm Canmore  and daughter of Edmund Ironside of England. It was also the name of the wife of  Henry VI  of England,  Margaret of Anjou  (  1430–82 ), and of  Margaret Tudor  (  1489–1541 ), sister of  Henry VIII , who married James IV of Scotland and ruled as regent there after his death.  See also  Margery  ,   Marjorie ."]}]}],"historicEvents":[{"id":1705191,"age":3,"year":"1315","toYear":"1317","julianDay":2201354,"title":"Famine Strikes Europe","description":"A famine caused by cold winters and wet summers across Europe caused millions to die due to starvation. Desperation from hunger caused high levels of crime, stampedes in bread lines in London, infanticide, and even cannibalism throughout Europe.","jurisdictionLevel":1},{"id":1705192,"age":16,"year":"1328","julianDay":2206102,"title":"First War of Scottish Independence","description":"The First War of Scottish Independence began after England invaded Scotland in 1296. The Treaty of Edinburgh was signed in 1328 which declared peace between the two kingdoms and brought the war to an end.","jurisdictionLevel":1},{"id":1705195,"age":70,"year":"1382","julianDay":2225826,"title":"Wycliffe's Bible","description":"John Wycliffe, English theologian and professor at the University of Oxford, completed a translation of the Bible from the Latin Vulgate into Middle English. This translation is known as Wycliffe's Bible and was completed around 1382.","url":"https://en.wikipedia.org/wiki/Wycliffe%27s_Bible","urlTitle":"Wikipedia - Wycliffe's Bible","jurisdictionLevel":1}],"lifeSummary":"Margaret de Hampshire was born in 1312, in Somerset, England. She had at least 1 son and 1 daughter with Thomas de Norton. She died in England."},"et":{"1312–":"1312–Surnud","1312–1346":"1312–1346","1300–Male":"1300–Surnud","1333–Female":"1333–Surnud","1338–Male":"1338–Surnud","1312–Female":"1312–Surnud","1338":"1338","1315":"1315","1346":"1346","1312":"1312","abt 1338":"umbes 1338","1333":"1333","1300":"1300","1382":"1382","1328":"1328","1317":"1317","Somerset, England":"Somerset, England","Nunney, Somerset, England, United Kingdom":"Nunney, Somerset, Inglismaa, United Kingdom","England":"England","of Norton, Hants, Eng.":"Hampshire, Inglismaa, United Kingdom"},"fi":{"1312–":"1312–Kuollut","1312–1346":"1312–1346","1300–Male":"1300–Kuollut","1333–Female":"1333–Kuollut","1338–Male":"1338–Kuollut","1312–Female":"1312–Kuollut","1338":"1338","1315":"1315","1346":"1346","1312":"1312","abt 1338":"noin 1338","1333":"1333","1300":"1300","1382":"1382","1328":"1328","1317":"1317","Somerset, England":"Somerset, England","Nunney, Somerset, England, United Kingdom":"Nunney, Somerset, Englanti, 