ud Burghill于1392年出生在英国英格兰萊希斯特斯爾可爾德 牛頓时，她的父亲John Burghill24岁，母亲Ann Bulfynche13岁。她于1412年与Walter Weaver III在英国英格兰賀特福爾结婚。他们至少是1个儿子的父母。她去世于大约1416年在威尔士拉德諾斯爾普雷斯泰尼享年25岁。"},"hr":{"1392–about 1416":"1392.–oko 1416.","1392–1416":"1392.–1416","1411–Male":"1411–preminuo","1415–Male":"1415–preminuo","1440–1502":"1440–1502","1591–1591":"1591–1591","1388–1413":"1388–1413.","1413–1503":"1413.–1503","1369–1414":"1369–1414","1379–Female":"1379–preminula","1440":"1440","May 1414":"svibanj 1414.","1591":"1591","1392":"1392.","1503":"1503","1415":"1415","1414":"1414","1502":"1502","1413":"1413.","1369":"1369","1412":"1412.","1379":"1379","1411":"1411","about 1416":"oko 1416.","1388":"1388","about 1413":"oko 1413.","1416":"1416",", Hertfordshire, England":"Hertfordshire, Engleska, United Kingdom","England":"England","Presteigne with Discoed, Radnorshire, Wales":"Presteigne, Radnorshire, Wales","Newton, Leicestershire, England":"Cold Newton, Leicestershire, Engleska, United Kingdom","Herefordshire, England":"Herefordshire, Engleska, United Kingdom"},"cs":{"1392–about 1416":"1392–okolo 1416","1392–1416":"1392–1416","1411–Male":"1411–Zesnulý","1415–Male":"1415–Zesnulý","1440–1502":"1440–1502","1591–1591":"1591–1591","1388–1413":"1388–1413","1413–1503":"1413–1503","1369–1414":"1369–1414","1379–Female":"1379–Zesnulá","1440":"1440","May 1414":"květen 1414","1591":"1591","1392":"1392","1503":"1503","1415":"1415","1414":"1414","1502":"1502","1413":"1413","1369":"1369","1412":"1412","1379":"1379","1411":"1411","about 1416":"okolo 1416","1388":"1388","about 1413":"okolo 1413","1416":"1416",", Hertfordshire, England":"Hertfordshire, Anglie, United Kingdom","England":"Anglie","Presteigne with Discoed, Radnorshire, Wales":"Presteigne, Radnorshire, Wales","Newton, Leicestershire, England":"Cold Newton, Leicestershire, Anglie, United Kingdom","Herefordshire, England":"Herefordshire, Anglie, United Kingdom"},"da":{"1392–about 1416":"1392–omkring 1416","1392–1416":"1392–1416","1411–Male":"1411–Afdød","141