edo, New Castile, Spain":"Toledo, Castilla-La Mancha, Spanien","España":"Spanien","Spain":"Spanien","lifeSummary":"Als Doña Luna Estevanes de Toledo 1206 in Diócesis de Toledo, Spanien geboren wurde, war ihr Vater Esteban Illán de San Román Bermey de Toledo 80 und ihre Mutter Elisabeth Luna   Estevanez 23. Sie hat um 1228 in Toledo, Castilla-La Mancha, Spanien Fernán Pérez  Suárez de Toledo geheiratet. Sie hatten mindestens 2 Söhne. Sie starb 1239 im Alter von 33 Jahren in Spanien."},"ht":{"Cir 1206–1239":"1206–1239","1205–Female":"1205–Desede","1205–Male":"1205–Desede","1206–1239":"1206–1239","1207–Female":"1207–Desede","1203–1256":"1203–1256","1226–1260":"1226–1260","1234–Male":"1234–Desede","1127–1208":"1127–1208","1183–1277":"1183–1277","Cir 1206":"1206","aproximadamente 1226":"about 1226","ABT 1228":"about 1228","1183":"1183","1260":"1260","1239":"1239","1206":"1206","1205":"1205","1127":"1127","1226":"1226","1203":"1203","11 de noviembre de 1208":"11 November 1208","1234":"1234","1256":"1256","1277":"1277","1208":"1208","1207":"1207","Toledo, Castilla-La Mancha, España":"Toledo, Castilla-La Mancha, Espagne","Toledo, New Castile, Spain":"Toledo, Castilla-La Mancha, Espagne","España":"Espagne","Spain":"Espagne"},"hu":{"Cir 1206–1239":"1206–1239","1205–Female":"1205–elhunyt","1205–Male":"1205–elhunyt","1206–1239":"1206–1239","1207–Female":"1207–elhunyt","1203–1256":"1203–1256","1226–1260":"1226–1260","1234–Male":"1234–elhunyt","1127–1208":"1127–1208","1183–1277":"1183–1277","Cir 1206":"1206","aproximadamente 1226":"1226 körül","ABT 1228":"1228 körül","1183":"1183","1260":"1260","1239":"1239","1206":"1206","1205":"1205","1127":"1127","1226":"1226","1203":"1203","11 de noviembre de 1208":"1208. november 11.","1234":"1234","1256":"1256","1277":"1277","1208":"1208","1207":"1207","Toledo, Castilla-La Mancha, España":"Toledo, Castilla-La Mancha, Spanyolország","Toledo, New Castile, Spain":"Toledo, Castilla-La Mancha, Spanyolország","España":"Spanyolország","Spain":"Spa