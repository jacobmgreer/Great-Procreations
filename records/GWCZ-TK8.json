215":"1215","1136":"1136","1224":"1224","1189":"1189","1187":"1187","about 1189":"omkring 1189","1185":"1185","1140":"1140","about 1187":"omkring 1187","about 1185":"omkring 1185","1218":"1218","Erdington, Warwickshire, England":"Erdington, Warwickshire, England","Erdington, Warwickshire, England, United Kingdom":"Erdington, Warwickshire, England, United Kingdom"},"nl":{"1136–":"1136–Overleden","1140–1190":"1140–1190","1185–1218":"1185–1218","1187–Male":"1187–Overleden","1189–Male":"1189–Overleden","1136–Female":"1136–Overleden","1190":"1190","1215":"1215","1136":"1136","1224":"1224","1189":"1189","1187":"1187","about 1189":"circa 1189","1185":"1185","1140":"1140","about 1187":"circa 1187","about 1185":"circa 1185","1218":"1218","Erdington, Warwickshire, England":"Erdington, Warwickshire, England","Erdington, Warwickshire, England, United Kingdom":"Erdington, Warwickshire, Engeland, Verenigd Koninkrijk"},"en":{"1136–":"1136–Deceased","1140–1190":"1140–1190","1185–1218":"1185–1218","1187–Male":"1187–Deceased","1189–Male":"1189–Deceased","1136–Female":"1136–Deceased","1190":"1190","1215":"1215","1136":"1136","1224":"1224","1189":"1189","1187":"1187","about 1189":"about 1189","1185":"1185","1140":"1140","about 1187":"about 1187","about 1185":"about 1185","1218":"1218","Erdington, Warwickshire, England":"Erdington, Warwickshire, England","Erdington, Warwickshire, England, United Kingdom":"Erdington, Warwickshire, England, United Kingdom","nameMeanings":[{"name":"Corbet","type":"LAST","attribution":"Dictionary of American Family Names © Patrick Hanks 2003, 2006.","meanings":["Scottish: variant of   Corbett  .","History: Walter Corbet, a royal knight in 12th-century Scotland, was the first of that name in that kingdom. His 13th-century descendants were major landholders in the Borders, and in the 14th century they acquired lands in the North of Scotland."],"variants":[{"name":"Corbett","meanings":["English (West Midlands, of Norman origin): nickname from Old French <i>corbet</i> ‘raven’, probably denoting someone with dark hair or a dark complexion.","History: This is the name of a family descended from Hugh <i>Corbet</i>, a Norman baron who settled in Shropshire following the Norman Conquest. One of his descendants, Sir Richard Corbet, was granted land near Shrewsbury in 1223; since the 13th century, this place has been known as Moreton Corbet. The name was taken from Shropshire to Scotland in the 12th century and to northern Ireland in the 17th century, and thence to North America by at least one group of bearers of the name."]}]},{"name":"Margaret","type":"FIRST","attribution":"Dictionary of First Names © Patrick Hanks and Flavia Hodges 1990, 2003, 2006.","meanings":["An extremely common given name from the Middle Ages onwards, derived via Old French <i>Marguerite</i> and Latin <i>Margarita</i> from Greek <i>Margarītēs</i>, from <i>margaron</i> ‘pearl’, a word ultimately of Hebrew origin. The name was always understood to mean ‘pearl’ throughout the Middle Ages. The first  St Margaret  was martyred at Antioch in Pisidia during the persecution instigated by the  Emperor Diocletian  in the early 4th century. However, there is some doubt about her name, as the same saint is venerated in the Orthodox Church as   Marina .  There were several other saintly bearers of the name, including St Margaret of Scotland (  d. 1093 ), wife of  King Malcolm Canmore  and daughter of Edmund Ironside of England. It was also the name of the wife of  Henry VI  of England,  Margaret of Anjou  (  1430–82 ), and of  Margaret Tudor  (  1489–1541 ), sister of  Henry VIII , who married James IV of Scotland and ruled as regent there after his death.  See also  Margery  ,   Marjorie ."],"variants":[{"name":"Margareta","meanings":["From the Latin form of Greek <i>Margarītēs</i>.  See  <b>Margaret</b>   ."]},{"name":"Margaretta","meanings":["Formed from Margaret."]}]},{"name":"De","type":"FIRST","attribution":"Dictionary of First Names © Patrick Hanks and Flavia Hodges 1990, 2003, 2006.","meanings":["‘Attainment’."],"variants":[]},{"name":"Brampton,","type":"LAST","attribution":"Dictionary of Family Names in Britain and Ireland © University of the West of England 2016","meanings":["English: locative name from one or more of the many places called  <i>Brampton</i> (Northants, Hunts, Herefs, Derbys, Lincs, WR Yorks, Norfolk, Suffolk, Westm, Cumb). There is a distinct early bias towards the E Midlands, E Anglia and Yorks."],"variants":[{"name":"Brunton","meanings":["Mainly U.S.: variant of   Brandon   or transferred use of the surname <i>Branton</i>. This is a local name from places in Northumberland and West Yorkshire so named from Old English <i>brōm</i> ‘broom, gorse’ + <i>tūn</i> ‘enclosure, settlement’."]},{"name":"Brompton","meanings":["1  English: locative name from Brompton (ER Yorks, NR Yorks, Middx, Shrops).","2  English: variant of   Brampton  ."]},{"name":"Brumpton","meanings":["English:  see  Brompton  ."]},{"name":"Bronton","meanings":["Mainly U.S.: variant of   Brandon   or transferred use of the surname <i>Branton</i>. This is a local name from places in Northumberland and West Yorkshire so named from Old English <i>brōm</i> ‘broom, gorse’ + <i>tūn</i> ‘enclosure, settlement’."]},{"name":"Branton","meanings":["Mainly U.S.: variant of   Brandon   or transferred use of the surname <i>Branton</i>. This is a local name from places in Northumberland and West Yorkshire so named from Old English <i>brōm</i> ‘broom, gorse’ + <i>tūn</i> ‘enclosure, settlement’."]}]},{"name":"Baroness","type":"LAST","attribution":"Dictionary of American Family Names © Patrick Hanks 2003, 2006.","meanings":["Norwegian: old variant of <b>Bartnes</b> (and, in North America, probably also an altered form of this), a habitational name from Trøndelag, a form of Old Norse <i>burkn</i> ‘fern’ + <i>nes</i> ‘promontary, headland’.","In some cases possibly also an altered form of German   Bartmess  ."],"variants":[{"name":"Bartmess","meanings":["American shortened form of German   Barthelmess  ."]}]}],"historicEvents":[{"id":1705187,"age":79,"year":"1215","julianDay":2164830,"title":"Magna Carta","description":"King John of England agreed to a charter of rights called the Magna Carta. The document was originally drafted by the Archbishop of Canterbury to establish peace between King John and a group of rebel barons. The Magna Carta was completed in 1215 and is now considered to be one of the greatest constitutional documents of all time.","url":"https://www.nationalarchives.gov.uk/education/medieval/magna-carta/","urlTitle":"National Archives - Magna Carta","jurisdictionLevel":2},{"id":1705188,"age":88,"year":"1224","julianDay":2168117,"title":"France Declares War on England","description":"France declared war on England as Louis VIII of France attacked Poitou and northern Gascony.","jurisdictionLevel":2}],"lifeSummary":"Lady Margaret De Brampton, Baroness Corbet was born in 1136, in Erdington, Warwickshire, England. She had at least 3 sons with William Erdington."},"et":{"1136–":"1136–Surnud","1140–1190":"1140–1190","1185–1218":"1185–1218","1187–Male":"1187–Surnud","1189–Male":"1189–Surnud","1136–Female":"1136–Surnud","1190":"1190","1215":"1215","1136":"1136","1224":"1224","1189":"1189","1187":"1187","about 1189":"umbes 1189","1185":"1185","1140":"1140","about 1187":"umbes 1187","about 1185":"umbes 1185","1218":"1218","Erdington, Warwickshire, England":"Erdington, Warwickshire, England","Erdington, Warwickshire, England, United Kingdom":"Erdington, Warwickshire, Inglismaa, United Kingdom"},"fi":{"1136–":"1136–Kuollut","1140–1190":"1140–1190","1185–1218":"1185–1218","1187–Male":"1187–Kuollut","1189–Male":"1189–Kuollut","1136–Female":"1136–Kuollut","1190":"1190","1215":"1215","1136":"1136","1224":"1224","1189":"1189","1187":"1187","about 1189":"noin 1189","1185":"1185","1140":"1140","about 1187":"noin 1187","about 1185":"noin 1185","1218":"1218","Erdington, Warwickshire, England":"Erdington, Warwickshire, Eng