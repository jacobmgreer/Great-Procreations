436":"1400–1436","1402–Male":"1402–Overleden","1403–Female":"1403–Overleden","1420–Male":"1420–Overleden","–Male":"Overleden","1348–Female":"1348–Overleden","about 1371":"circa 1371","1382":"1382","1371":"1371","1403":"1403","1348":"1348","1436":"1436","1402":"1402","1413":"1413","1400":"1400","1420":"1420","1365":"1365","about 1400":"circa 1400","about 1401":"circa 1401","Cudham, Kent, England":"Cudham, Kent, England","England":"Engeland, Verenigd Koninkrijk","Kent, England":"Kent, England"},"en":{"about 1371–1403":"about 1371–1403","1371–1403":"1371–1403","1365–1413":"1365–1413","1400–1436":"1400–1436","1402–Male":"1402–Deceased","1403–Female":"1403–Deceased","1420–Male":"1420–Deceased","–Male":"Deceased","1348–Female":"1348–Deceased","about 1371":"about 1371","1382":"1382","1371":"1371","1403":"1403","1348":"1348","1436":"1436","1402":"1402","1413":"1413","1400":"1400","1420":"1420","1365":"1365","about 1400":"about 1400","about 1401":"about 1401","Cudham, Kent, England":"Cudham, Kent, England","England":"England, United Kingdom","Kent, England":"Kent, England","nameMeanings":[{"name":"Walden","type":"LAST","attribution":"Dictionary of American Family Names © Patrick Hanks 2003, 2006.","meanings":["English: habitational name from Kings Walden and Saint Pauls Walden (Hertfordshire), Saffron Waldon (Essex), Waldon in Milton Damerel (Devon), and Walden (North Yorkshire). The placenames derives from Old English <i>walh</i> ‘foreigner, Briton, serf’ (genitive plural <i>wala</i>) + <i>denu</i> ‘valley’.","German: patronymic from   Wald   3.","Americanized form of Norwegian   Wolden   or   Volden  ."],"variants":[{"name":"Wald","meanings":["Some characteristic forenames:  German Fritz, Arno, Gerhard, Guenther, Gunther, Hans, Inge, Ingeborg, Liesl, Markus, Mathias, Udo.","German and English: topographic name for someone who lived in or near a forest (Old High German <i>wald</i>, northern Middle English <i>wald</i>).","Jewish (Ashkenazic): artificial name from German <i>Wald</i> ‘forest’. Very few Jews would have been living anywhere near a forest at the time when they acquired surnames, so as a Jewish name its origins are unlikely to be topographic."]},{"name":"Waldon","meanings":["English: variant of   Walden  ."]}]},{"name":"Alice","type":"FIRST","attribution":"Dictionary of First Names © Patrick Hanks and Flavia Hodges 1990, 2003, 2006.","meanings":["Originally a variant of   Adelaide  , representing an Old French spelling of a reduced form of Germanic <i>Adalheidis</i>. <i>Alice</i> and <i>Adelaide</i> were already regarded as distinct names in English during the medieval period. <i>Alice</i> enjoyed a surge of popularity in the 19th century and periods of favour ever since. It was the name of the central character of  Lewis Carroll's  Alice's Adventures in Wonderland (  1865 ) and Through the Looking Glass (  1872 ), who was based on his child friend  Alice Liddell , daughter of the Dean of Christ Church, Oxford."],"variants":[{"name":"Alys","meanings":["Variant spelling of   Alice ."]},{"name":"Alis","meanings":["equivalent of <b>Alice</b> ."]}]}],"historicEvents":[{"id":1705195,"age":11,"year":"1382","julianDay":2225826,"title":"Wycliffe's Bible","description":"John Wycliffe, English theologian and professor at the University of Oxford, completed a translation of the Bible from the Latin Vulgate into Middle English. This translation is known as Wycliffe's Bible and was completed around 1382.","url":"https://en.wikipedia.org/wiki/Wycliffe%27s_Bible","urlTitle":"Wikipedia - Wycliffe's Bible","jurisdictionLevel":1}],"lifeSummary":"Alice Walden was born about 1371, in Kent, England as the daughter of Walden of County Kent and Phillipa de Roet. She married John Manning about 1401, in Cudham, Kent, England. They were the parents of at least 5 sons and 1 daughter. She died in 1403, in Cudham, Kent, England, at the age of 33."},"et":{"about 1371–1403":"umbes 1371–1403","1371–1403":"1371–1403","1365–1413":"1365–1413","1400–1436":"140