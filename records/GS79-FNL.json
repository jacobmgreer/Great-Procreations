5.–1231.","1135–1231":"1135–1231.","1141–Female":"1141.–preminula","1160–1251":"1160.–1251","1066–1141":"1066–1141.","1099–Female":"1099–preminula","1215":"1215","1159":"1159.","1224":"1224","1135":"1135","1231":"1231.","1099":"1099","1066":"1066","1141":"1141.","1251":"1251","about 1135":"oko 1135.","1160":"1160.","Winchcomb, Gretton, Gloucestershire, England":"Winchcombe, Gloucestershire, England","Winchcomb, Gloucestershire, England":"Winchcombe, Gloucestershire, England"},"cs":{"about 1135–1231":"okolo 1135–1231","1135–1231":"1135–1231","1141–Female":"1141–Zesnulá","1160–1251":"1160–1251","1066–1141":"1066–1141","1099–Female":"1099–Zesnulá","1215":"1215","1159":"1159","1224":"1224","1135":"1135","1231":"1231","1099":"1099","1066":"1066","1141":"1141","1251":"1251","about 1135":"okolo 1135","1160":"1160","Winchcomb, Gretton, Gloucestershire, England":"Winchcombe, Gloucestershire, Anglie","Winchcomb, Gloucestershire, England":"Winchcombe, Gloucestershire, Anglie"},"da":{"about 1135–1231":"omkring 1135–1231","1135–1231":"1135–1231","1141–Female":"1141–Afdød","1160–1251":"1160–1251","1066–1141":"1066–1141","1099–Female":"1099–Afdød","1215":"1215","1159":"1159","1224":"1224","1135":"1135","1231":"1231","1099":"1099","1066":"1066","1141":"1141","1251":"1251","about 1135":"omkring 1135","1160":"1160","Winchcomb, Gretton, Gloucestershire, England":"Winchcombe, Gloucestershire, England","Winchcomb, Gloucestershire, England":"Winchcombe, Gloucestershire, England"},"nl":{"about 1135–1231":"circa 1135–1231","1135–1231":"1135–1231","1141–Female":"1141–Overleden","1160–1251":"1160–1251","1066–1141":"1066–1141","1099–Female":"1099–Overleden","1215":"1215","1159":"1159","1224":"1224","1135":"1135","1231":"1231","1099":"1099","1066":"1066","1141":"1141","1251":"1251","about 1135":"circa 1135","1160":"1160","Winchcomb, Gretton, Gloucestershire, England":"Winchcombe, Gloucestershire, England","Winchcomb, Gloucestershire, England":"Winchcombe, Gloucestershire, England"},"en":{"about 1135–1231":"about 1135–1231","1135–1231":"1135–1231","1141–Female":"1141–Deceased","1160–1251":"1160–1251","1066–1141":"1066–1141","1099–Female":"1099–Deceased","1215":"1215","1159":"1159","1224":"1224","1135":"1135","1231":"1231","1099":"1099","1066":"1066","1141":"1141","1251":"1251","about 1135":"about 1135","1160":"1160","Winchcomb, Gretton, Gloucestershire, England":"Winchcombe, Gloucestershire, England","Winchcomb, Gloucestershire, England":"Winchcombe, Gloucestershire, England","nameMeanings":[{"name":"Wise","type":"LAST","attribution":"Dictionary of American Family Names © Patrick Hanks 2003, 2006.","meanings":["English: nickname for a wise or learned person, from Middle English <i>wise</i>, <i>wisse</i> ‘wise’ (Old English <i>wīs</i>). This name has also absorbed Dutch <b>Wijs</b> and <b>De Wijs</b>, a nickname meaning ‘(the) wise’, and possibly cognates in other languages.","English: topographic name for someone who lived by the withies or willows, from Middle English <i>withi</i>, Old English <i>wīthig</i> ‘withy, willow’.","Americanized form of German and Jewish (Ashkenazic)   Weiss   ‘white’."],"variants":[{"name":"Weiss","meanings":["Some characteristic forenames:  German Kurt, Otto, Erwin, Hans, Gerhard, Fritz, Manfred, Egon, Armin, Arno, Gunther, Heinz.  Jewish Chaim, Moshe, Emanuel, Aron, Meyer, Mendel, Hyman, Isadore, Zvi, Shlomo.","German and Jewish (Ashkenazic): nickname for someone with white hair or a remarkably pale complexion, from Middle High German <i>wīz</i>, German <i>weiss</i> ‘white’. This surname is also found in Poland, Czechia, Slovakia, Slovenia, and Croatia, often as a German translation of a corresponding Slavic surnames, e.g. Slovenian   Belec   and <b>Bele</b> (see   Belle  ). It is also found in France (mainly Alsace and Lorraine), Denmark, and the Netherlands.","German: variant of   Weis  ."]},{"name":"Wiseman","meanings":["English: nickname from Middle English <i>wise</i> ‘wise, discreet’ (see   Wise   1) + <i>man</i>, also <i>wise-man</i> ‘wise, thoughtful, rational, skilled, or intelligent person, a cunning man’ (Old English <i>wīs</i> + <i>mann</i>). The name may also have been used ironically.","Americanized form of German   Weismann  ."]},{"name":"Wyse","meanings":["English and Irish (Waterford and Cork): mainly Irish and Scottish spelling of   Wise  . The name has been established in Ireland since the 13th century where it was also Gaelicized as <b>de Uidheas</b>.","Altered form of German   Weise  ."]}]},{"name":"William","type":"FIRST","attribution":"Dictionary of First Names © Patrick Hanks and Flavia Hodges 1990, 2003, 2006.","meanings":["Probably the most successful of all the Old French names of Germanic origin that were introduced to England by the Normans. It is derived from Germanic <i>wil</i> ‘will, desire’ + <i>helm</i> ‘helmet, protection’. The fact that it was borne by the Conqueror himself does not seem to have inhibited its favour with the ‘conquered’ population: in the first century after the Conquest it was the commonest male name of all, and not only among the Normans. In the later Middle Ages it was overtaken by   John  , but continued to run second to that name until the 20th century, when the picture became more fragmented."],"variants":[]}],"historicEvents":[{"id":1705187,"age":80,"year":"1215","julianDay":2164830,"title":"Magna Carta","description":"King John of England agreed to a charter of rights called the Magna Carta. The document was originally drafted by the Archbishop of Canterbury to establish peace between King John and a group of rebel barons. The Magna Carta was completed in 1215 and is now considered to be one of the greatest constitutional documents of all time.","url":"https://www.nationalarchives.gov.uk/education/medieval/magna-carta/","urlTitle":"National Archives - Magna Carta","jurisdictionLevel":2},{"id":1705188,"age":89,"year":"1224","julianDay":2168117,"title":"France Declares War on England","description":"France declared war on England as Louis VIII of France attacked Poitou and northern Gascony.","jurisdictionLevel":2}],"lifeSummary":"When William Wise I was born about 1135, in Winchcombe, Gloucestershire, England, United Kingdom, his father, Oliver Wise II, was 70 and his mother, Mrs. Oliver Wise, was 37. He married Mrs. William Wise in 1159, in Winchcombe, Gloucestershire, England. They were the parents of at least 1 son. He died in 1231, in Winchcombe, Gloucestershire, England, at the age of 97."},"et":{"about 1135–1231":"umbes 1135–1231","1135–1231":"1135–1231","1141–Female":"1141–Surnud","1160–1251":"1160–1251","1066–1141":"1066–1141","1099–Female":"1099–Surnud","1215":"1215","1159":"1159","1224":"1224","1135":"1135","1231":"1231","1099":"1099","1066":"1066","1141":"1141","1251":"1251","about 1135":"umbes 1135","1160":"1160","Winchcomb, Gretton, Gloucestershire, England":"Winchcombe, Gloucestershire, England","Winchcomb, Gloucestershire, England":"Winchcombe, Gloucestershire, England"},"fi":{"about 1135–1231":"noin 1135–1231","1135–1231":"1135–1231","1141–Female":"1141–Kuollut","1160–1251":"1160–1251","1066–1141":"1066–1141","1099–Female":"1099–Kuollut","1215":"1215","1159":"1159","1224":"1224","1135":"1135","1231":"1231","1099":"1099","1066":"1066","1141":"1141","1251":"1251","about 1135":"noin 1135","1160":"1160","Winchcomb, Gretton, Gloucestershire, England":"Winchcombe, Gloucestershire, England","Winchcomb, Gloucestershire, England":"Winchcombe, Gloucestershire, England"},"fr":{"about 1135–1231":"environ 1135–1231","1135–1231":"1135–1231","1141–Female":"1141–Décédée","1160–1251":"1160–1251","1066–1141":"1066–1141","1099–Female":"1099–Décédée","1215":"1215","1159":"1159","1224":"1224","1135":"1135","1231":"1231","1099":"1099","1066":"1066","1141":"1141","1251":"1251","about 1135":"environ 1135","1160":"1160","Winchcomb, Gretton, Gloucestershire, England":"Winchcombe, Gloucestershire, Angleterre","Winchcomb, Gloucestershire, England":"Winchcombe, Gloucestershire, Angleterre","lifeSummar