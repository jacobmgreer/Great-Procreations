1175":"1175","1273":"1273","1293":"1293","1170":"1170","1215":"1215","1224":"1224","1200":"1200","1255":"1255","1233":"1233","1244":"1244","1232":"1232","1320":"1320","after 1233":"na 1233","Studley, Warwickshire, England":"Studley, Warwickshire, England","Chillington, Staffordshire, England":"Chillington, Staffordshire, England"},"en":{"1200–1255":"1200–1255","–1293":"–1293","1244–1320":"1244–1320","1255–1273":"1255–1273","–1273":"–1273","1170–1232":"1170–1232","1175–1233":"1175–1233","before 1232":"before 1232","1175":"1175","1273":"1273","1293":"1293","1170":"1170","1215":"1215","1224":"1224","1200":"1200","1255":"1255","1233":"1233","1244":"1244","1232":"1232","1320":"1320","after 1233":"after 1233","Studley, Warwickshire, England":"Studley, Warwickshire, England","Chillington, Staffordshire, England":"Chillington, Staffordshire, England","nameMeanings":[{"name":"William","type":"FIRST","attribution":"Dictionary of First Names © Patrick Hanks and Flavia Hodges 1990, 2003, 2006.","meanings":["Probably the most successful of all the Old French names of Germanic origin that were introduced to England by the Normans. It is derived from Germanic <i>wil</i> ‘will, desire’ + <i>helm</i> ‘helmet, protection’. The fact that it was borne by the Conqueror himself does not seem to have inhibited its favour with the ‘conquered’ population: in the first century after the Conquest it was the commonest male name of all, and not only among the Normans. In the later Middle Ages it was overtaken by   John  , but continued to run second to that name until the 20th century, when the picture became more fragmented."],"variants":[]},{"name":"IV","type":"FIRST","attribution":"Dictionary of First Names © Patrick Hanks and Flavia Hodges 1990, 2003, 2006.","meanings":["Short form of   Vivian   and   Vivien ."],"variants":[{"name":"Vivien","meanings":["Earlier generally taken as a variant of the boy's name   Vivian  , but now also rarely used for boys. This spelling was quite common in Old French. Its use as a girl's name in the English-speaking world was influenced by  Tennyson's  Merlin and Vivien (  1859 ). This name, from Arthurian legend, may represent an altered form of a Celtic name (perhaps akin to the Irish Gaelic name <i>Béibhinn</i> ‘white lady’, pronounced ‘bee-<b>veen</b>’). The actress  Vivien Leigh  (  1913–67 ) was christened <i>Vivian</i>."]},{"name":"Vivian","meanings":["Originally a boy's name, from an Old French form of the Latin name <i>Vivianus</i> (probably a derivative of <i>vivus</i> ‘alive’), but now more frequent as a girl's name. The name was borne by a 5th-century bishop of Saintes in western France, remembered for protecting his people during the invasion of the Visigoths."]}]}],"historicEvents":[{"id":1705187,"age":15,"year":"1215","julianDay":2164830,"title":"Magna Carta","description":"King John of England agreed to a charter of rights called the Magna Carta. The document was originally drafted by the Archbishop of Canterbury to establish peace between King John and a group of rebel barons. The Magna Carta was completed in 1215 and is now considered to be one of the greatest constitutional documents of all time.","url":"https://www.nationalarchives.gov.uk/education/medieval/magna-carta/","urlTitle":"National Archives - Magna Carta","jurisdictionLevel":2},{"id":1705188,"age":24,"year":"1224","julianDay":2168117,"title":"France Declares War on England","description":"France declared war on England as Louis VIII of France attacked Poitou and northern Gascony.","jurisdictionLevel":2}],"lifeSummary":"When William IV Corbucion was born in 1200, in Studley, Warwickshire, England, his father, William Corbucion III, was 31 and his mother, Amice, was 25. He had at least 2 sons and 2 daughters. He died in 1255, in Chillington, Staffordshire, England, at the age of 55."},"et":{"1200–1255":"1200–1255","–1293":"–1293","1244–1320":"1244–1320","1255–1273":"1255–1273","–1273":"–1273","1170–1232":"1170–1232","1175–1233":"1175–1233","be