4–Afdød","1275–1308":"1275–1308","1281–1354":"1281–1354","1284–Female":"1284–Afdød","1276–1313":"1276–1313","1300–1361":"1300–1361","1249–1308":"1249–1308","1250–1284":"1250–1284","20 July 1300":"20. juli 1300","1275":"1275","1361":"1361","1284":"1284","1382":"1382","1250":"1250","1281":"1281","1290":"1290","1315":"1315","1249":"1249","1313":"1313","1300":"1300","um 1273":"omkring 1273","1354":"1354","1276":"1276","1308":"1308","about 1284":"omkring 1284","1328":"1328","1317":"1317","Yorkshire, England":"Jórvík, England","Mulgrave Castle, Yorkshire, England":"Mulgrave Castle, Jórvík, England"},"nl":{"about 1284–":"circa 1284–Overleden","1275–1308":"1275–1308","1281–1354":"1281–1354","1284–Female":"1284–Overleden","1276–1313":"1276–1313","1300–1361":"1300–1361","1249–1308":"1249–1308","1250–1284":"1250–1284","20 July 1300":"20 juli 1300","1275":"1275","1361":"1361","1284":"1284","1382":"1382","1250":"1250","1281":"1281","1290":"1290","1315":"1315","1249":"1249","1313":"1313","1300":"1300","um 1273":"circa 1273","1354":"1354","1276":"1276","1308":"1308","about 1284":"circa 1284","1328":"1328","1317":"1317","Yorkshire, England":"Yorkshire, England","Mulgrave Castle, Yorkshire, England":"Mulgrave Castle, Yorkshire, England"},"en":{"about 1284–":"about 1284–Deceased","1275–1308":"1275–1308","1281–1354":"1281–1354","1284–Female":"1284–Deceased","1276–1313":"1276–1313","1300–1361":"1300–1361","1249–1308":"1249–1308","1250–1284":"1250–1284","20 July 1300":"20 July 1300","1275":"1275","1361":"1361","1284":"1284","1382":"1382","1250":"1250","1281":"1281","1290":"1290","1315":"1315","1249":"1249","1313":"1313","1300":"1300","um 1273":"about 1273","1354":"1354","1276":"1276","1308":"1308","about 1284":"about 1284","1328":"1328","1317":"1317","Yorkshire, England":"Yorkshire, England","Mulgrave Castle, Yorkshire, England":"Mulgrave Castle, Yorkshire, England","nameMeanings":[{"name":"Mauley","type":"LAST","attribution":"Dictionary of American Family Names © Patrick Hanks 2003, 2006.","meanings":["Americanized form of Americanized form of Swiss German <b>Mägli</b> (see   Magley  )."],"variants":[{"name":"Magley","meanings":["Americanized form of Swiss German <b>Mägli</b>: from the ancient Germanic personal name <i>Macco</i>, <i>Makko</i>, a pet form of a compound name with the first element <i>māg-</i> ‘kinsman’."]}]},{"name":"Margaret","type":"FIRST","attribution":"Dictionary of First Names © Patrick Hanks and Flavia Hodges 1990, 2003, 2006.","meanings":["An extremely common given name from the Middle Ages onwards, derived via Old French <i>Marguerite</i> and Latin <i>Margarita</i> from Greek <i>Margarītēs</i>, from <i>margaron</i> ‘pearl’, a word ultimately of Hebrew origin. The name was always understood to mean ‘pearl’ throughout the Middle Ages. The first  St Margaret  was martyred at Antioch in Pisidia during the persecution instigated by the  Emperor Diocletian  in the early 4th century. However, there is some doubt about her name, as the same saint is venerated in the Orthodox Church as   Marina .  There were several other saintly bearers of the name, including St Margaret of Scotland (  d. 1093 ), wife of  King Malcolm Canmore  and daughter of Edmund Ironside of England. It was also the name of the wife of  Henry VI  of England,  Margaret of Anjou  (  1430–82 ), and of  Margaret Tudor  (  1489–1541 ), sister of  Henry VIII , who married James IV of Scotland and ruled as regent there after his death.  See also  Margery  ,   Marjorie ."],"variants":[{"name":"Margareta","meanings":["From the Latin form of Greek <i>Margarītēs</i>.  See  <b>Margaret</b>   ."]},{"name":"Margaretta","meanings":["An extremely common given name from the Middle Ages onwards, derived via Old French <i>Marguerite</i> and Latin <i>Margarita</i> from Greek <i>Margarītēs</i>, from <i>margaron</i> ‘pearl’, a word ultimately of Hebrew origin. The name was always understood to mean ‘pearl’ throughout the Middle Ages. The first  St Margaret  was martyred at Antioch in Pisidia during the persecution instigated by the  Emperor Diocletian  in the early 4th century. However, there is some doubt about her name, as the same saint is venerated in the Orthodox Church as   Marina .  There were several other saintly bearers of the name, including St Margaret of Scotland (  d. 1093 ), wife of  King Malcolm Canmore  and daughter of Edmund Ironside of England. It was also the name of the wife of  Henry VI  of England,  Margaret of Anjou  (  1430–82 ), and of  Margaret Tudor  (  1489–1541 ), sister of  Henry VIII , who married James IV of Scotland and ruled as regent there after his death.  See also  Margery  ,   Marjorie ."]}]}],"historicEvents":[{"id":1705190,"age":6,"year":"1290","julianDay":2192224,"title":"Jews Expelled From England","description":"After years of anti-Semitic behavior, King Edward I expelled Jews from England in 1290.","jurisdictionLevel":1},{"id":1705191,"age":31,"year":"1315","toYear":"1317","julianDay":2201354,"title":"Famine Strikes Europe","description":"A famine caused by cold winters and wet summers across Europe caused millions to die due to starvation. Desperation from hunger caused high levels of crime, stampedes in bread lines in London, infanticide, and even cannibalism throughout Europe.","jurisdictionLevel":1},{"id":1705192,"age":44,"year":"1328","julianDay":2206102,"title":"First War of Scottish Independence","description":"The First War of Scottish Independence began after England invaded Scotland in 1296. The Treaty of Edinburgh was signed in 1328 which declared peace between the two kingdoms and brought the war to an end.","jurisdictionLevel":1},{"id":1705195,"age":98,"year":"1382","julianDay":2225826,"title":"Wycliffe's Bible","description":"John Wycliffe, English theologian and professor at the University of Oxford, completed a translation of the Bible from the Latin Vulgate into Middle English. This translation is known as Wycliffe's Bible and was completed around 1382.","url":"https://en.wikipedia.o