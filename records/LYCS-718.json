":"1263","1252":"1252","1195":"1195","1194":"1194","1191":"1191","1215":"1215","1224":"1224","1199":"1199","1155":"1155","1 FEB 1252":"1. února 1252","about 1252":"okolo 1252","Bedfordshire, England":"Bedfordshire, Anglie, United Kingdom","Hatch Beauchamp, Somerset, England":"Hatch Beauchamp, Somerset, Anglie, United Kingdom","Glastonbury, Somerset, England":"Glastonbury, Somerset, Anglie"},"da":{"1 SEP 1191–1 FEB 1252":"1. september 1191–1. februar 1252","1191–1252":"1191–1252","1194–Male":"1194–Afdød","1195–1220":"1195–1220","1220–1263":"1220–1263","1155–1199":"1155–1199","–Female":"Afdød","1 SEP 1191":"1. september 1191","Aft 1220":"efter 1220","before 1220":"før 1220","1220":"1220","1263":"1263","1252":"1252","1195":"1195","1194":"1194","1191":"1191","1215":"1215","1224":"1224","1199":"1199","1155":"1155","1 FEB 1252":"1. februar 1252","about 1252":"omkring 1252","Bedfordshire, England":"Bedfordshire, England, United Kingdom","Hatch Beauchamp, Somerset, England":"Hatch Beauchamp, Somerset, England, United Kingdom","Glastonbury, Somerset, England":"Glastonbury, Somerset, England"},"nl":{"1 SEP 1191–1 FEB 1252":"1 september 1191–1 februari 1252","1191–1252":"1191–1252","1194–Male":"1194–Overleden","1195–1220":"1195–1220","1220–1263":"1220–1263","1155–1199":"1155–1199","–Female":"Overleden","1 SEP 1191":"1 september 1191","Aft 1220":"na 1220","before 1220":"vóór 1220","1220":"1220","1263":"1263","1252":"1252","1195":"1195","1194":"1194","1191":"1191","1215":"1215","1224":"1224","1199":"1199","1155":"1155","1 FEB 1252":"1 februari 1252","about 1252":"circa 1252","Bedfordshire, England":"Bedfordshire, Engeland, Verenigd Koninkrijk","Hatch Beauchamp, Somerset, England":"Hatch Beauchamp, Somerset, Engeland, Verenigd Koninkrijk","Glastonbury, Somerset, England":"Glastonbury, Somerset, England"},"en":{"1 SEP 1191–1 FEB 1252":"1 September 1191–1 February 1252","1191–1252":"1191–1252","1194–Male":"1194–Deceased","1195–1220":"1195–1220","1220–1263":"1220–1263","1155–1199":"1155–1199","–Female":"Deceased","1 SEP 1191":"1 September 1191","Aft 1220":"after 1220","before 1220":"before 1220","1220":"1220","1263":"1263","1252":"1252","1195":"1195","1194":"1194","1191":"1191","1215":"1215","1224":"1224","1199":"1199","1155":"1155","1 FEB 1252":"1 February 1252","about 1252":"about 1252","Bedfordshire, England":"Bedfordshire, England, United Kingdom","Hatch Beauchamp, Somerset, England":"Hatch Beauchamp, Somerset, England, United Kingdom","Glastonbury, Somerset, England":"Glastonbury, Somerset, England","nameMeanings":[{"name":"Beauchamp","type":"LAST","attribution":"Dictionary of American Family Names © Patrick Hanks 2003, 2006.","meanings":["Some characteristic forenames:  French Antoine, Jacques, Yves, Andre, Armand, Emile, Fernand, Marcel, Marthe, Remi, Alcide, Camille.","English (of Norman origin) and French: habitational name from any of several places in France, for example in Manche and Somme, that are named with Old French <i>beu</i>, <i>bel</i> ‘fair, lovely’ + <i>champ(s)</i> ‘field, plain’ (from Latin <i>bello campo</i> ‘beautiful field’). In English the surname is generally pronounced   Beecham  . Compare   Bushaw  .","English: in some cases, an Anglo-Norman French adaptation of Scottish   Campbell  , by translation into French of the folk etymology <i>de campo bello</i> ‘from the fair field’."],"variants":[{"name":"Beecham","meanings":["English (Lincolnshire): variant of   Beauchamp  , reflecting the normal English pronunciation."]},{"name":"Beachem","meanings":["English (Somerset and Gloucestershire): variant of   Beauchamp  ."]},{"name":"Beachum","meanings":["Altered form of English   Beauchamp  ."]},{"name":"Bagent","meanings":["English:","possibly a colloquial pronunciation of   Beauchamp   or   Beecham  . Old French <i>Beau-</i> often appears as <i>Be(e)-</i> in English surnames. The <i>-ch-</i> has been voiced and excrescent <i>-t</i> has been added.","perhaps an Anglicized form of a French or Flemish surname such as <b>Beaujean</b> and <b>Bejean</b>, from Old French <i>bel Jehan</i> ‘handsome John’ + excrescent <i>-t</i>. It could have been introduced to England in the 15th or 16th century by Flemish migrants."]},{"name":"Beacham","meanings":["English (of Norman origin): variant of   Beauchamp  ."]},{"name":"Campbell","meanings":["Scottish: nickname from Gaelic <i>cam</i> ‘crooked, bent’ + <i>beul</i> ‘mouth’. As a result of folk etymology, the surname was often represented in Latin documents as <i>de bello campo</i> ‘of the fair field’, which led to the name sometimes being ‘translated’ into Anglo-Norman French as   Beauchamp  .","Irish (North Armagh): adopted for Gaelic <b>Mac Cathmhaoil</b> ‘son of Cathmhaol’ (literally ‘battle chief’): see   Caulfield   and   Cowell  .","English: variant of   Camel  , under the influence of the Scottish name (see 1 above)."]},{"name":"Bushaw","meanings":["Americanized form of French   Beauchamp   and   Bouchard  ."]},{"name":"Beacom","meanings":["English (Somerset) and Irish (Fermanagh): of Norman origin, a variant of   Beauchamp  ."]}]},{"name":"Robert","type":"FIRST","attribution":"Dictionary of First Names © Patrick Hanks and Flavia Hodges 1990, 2003, 2006.","meanings":["One of the many French names of Germanic origin that were introduced into Britain by the Normans; it has since remained in continuous use. It is derived from the nearly synonymous elements <i>hrōd</i> ‘fame’ + <i>berht</i> ‘bright, famous’, and had a native Old English predecessor of similar form (<i>Hreodbeorht</i>), which was supplanted by the Norman name. Two dukes of Normandy in the 11th century bore the name: the father of  William the Conqueror  (sometimes identified with the legendary Robert the Devil), and his eldest son. It was borne also by three kings of Scotland, notably  Robert the Bruce  (  1274–1329 ), who freed Scotland from English domination. The altered short form <i>Bob</i> is very common, but <i>Hob</i> and <i>Dob</i>, which were common in the Middle Ages and gave rise to surnames, are extinct.  See also  Rupert ."],"variants":[]},{"name":"IV","type":"FIRST","attribution":"Dictionary of First Names © Patrick Hanks and Flavia Hodges 1990, 2003, 2006.","meanings":["Short form of   Vivian   and   Vivien ."],"variants":[{"name":"Vivien","meanings":["Earlier generally taken as a variant of the boy's name   Vivian  , but now also rarely used for boys. This spelling was quite common in Old French. Its use as a girl's name in the English-speaking world was influenced by  Tennyson's  Merlin and Vivien (  1859 ). This name, from Arthurian legend, may represent an altered form of a Celtic name (perhaps akin to the Irish Gaelic name <i>Béibhinn</i> ‘white lady’, pronounced ‘bee-<b>veen</b>’). The actress  Vivien Leigh  (  1913–67 ) was christened <i>Vivian</i>."]},{"name":"Vivian","meanings":["Originally a boy's name, from an Old French form of the Latin name <i>Vivianus</i> (probably a derivative of <i>vivus</i> ‘alive’), but now more frequent as a girl's name. The name was borne by a 5th-century bishop of Saintes in western France, remembered for protecting his people during the invasion of the Visigoths."]}]}],"historicEvents":[{"id":1705187,"age":23,"year":"1215","julianDay":2164830,"title":"Magna Carta","description":"King John of England agreed to a charter of rights called the Magna Carta. The document was originally drafted by the Archbishop of Canterbury to establish peace between King John and a group of rebel barons. The Magna Carta was completed in 1215 and is now considered to be one of the greatest constitutional documents of all time.","url":"https://www.nationalarchives.gov.uk/education/medieval/magna-carta/","urlTitle":"National Archives - Magna Carta","jurisdictionLevel":2},{"id":1705188,"age":32,"year":"1224","julianDay":2168117,"title":"France Declares War on England","description":"France declared war on England as Louis VIII of France attacked Poitou and northern Gascony.","jurisdictionLevel":2}],"lifeSummary":"Robert IV Beauchamp Lord of Hatch Beauchamp was born on 1 September 1191, in Hatch Beauchamp, Somerset, England, United Kingdom as the son of Simon de Valletort and Isabella Muriel. He had at least 1 son with Juliana le Brett of Dourton. He died on 1 February 1252, in his hometown, at the age of 60, and was buried in Glastonbury, Somerset, England."},"et":{"1 SEP 1191–1 FEB 1252":"1. september 1191–1. veebruar 1252","1191–1252":"1191–1252","1194–Male":"1194–Surnud","1195–1220":"1195–1220","1220–1263":"1220–1263","1155–1199":"1155–1199","–Female":"Surnud","1 SEP 1191":"1. september 1191","Aft 1220":"pärast 1220","before 1220":"enne 1220","1220":"1220","1263":"1263","1252":"1252","1195":"1195","1194":"1194","1191":"1191","1215":"1215","1224":"1224","1199":"1199","1155":"1155","1 FEB 1252":"1. veebruar 1252","about 1252":"umbes 1252","Bedfordshire, England":"Bedfordshire, Inglismaa, United Kingdom","Hatch Beauchamp, Somerset, England":"Hatch Beauchamp, Somerset, Inglismaa, United Kingdom","Glastonbury, Somerset, England":"Glastonbury, Somerset, England"},"fi":{"1 SEP 1191–1 FEB 1252":"1. syyskuuta 1191–1. helmikuuta 1252","1191–1252":"1191–1252","1194–Male":"1194–Kuollut","1195–1220":"1195–1220","1220–1263":"1220–1263","1155–1199":"1155–1199","–Female":"Kuollut","1 SEP 1191":"1. syyskuuta 1191","Aft 1220":"1220 jälkeen","before 1220":"ennen vuotta 1220","1220":"1220","1263":"1263","1252":"1252","1195":"1195","1194":"1194","1191":"1191","1215":"1215","1224":"1224","1199":"1199","1155":"1155","1 FEB 1252":"1. helmikuuta 1252","about 1252":"noin 1252","Bedfordshire, England":"Bedfordshire, Englanti, Yhdistynyt kuningaskunta","Hatch Beauchamp, Somerset, England":"Hatch Beauchamp, Somerset, Englanti, Yhdistynyt kuningaskunta","Glastonbury, Somerset, England":"Glastonbury, Somerset, England"},"fr":{"1 SEP 1191–1 FEB 1252":"1 septembre 1191–1 février 1252","1191–1252":"1191–1252","1194–Male":"1194–Décédé","1195–1220":"1195–1220","1220–1263":"1220–1263","1155–1199":"1155