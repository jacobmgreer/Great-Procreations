ale":"1426.–preminula","1426":"1426.","1455":"1455","1450":"1450","abt 1450":"oko 1450.","West Riding, Yorkshire, England":"Yorkshire, England","Wakefield, Yorks, Eng.":"Wakefield, Yorkshire, Engleska, United Kingdom"},"cs":{"1426–":"1426–Zesnulá","–Male":"Zesnulý","1450–Male":"1450–Zesnulý","1426–Female":"1426–Zesnulá","1426":"1426","1455":"1455","1450":"1450","abt 1450":"okolo 1450","West Riding, Yorkshire, England":"Yorkshire, Anglie","Wakefield, Yorks, Eng.":"Wakefield, Yorkshire, Anglie, United Kingdom"},"da":{"1426–":"1426–Afdød","–Male":"Afdød","1450–Male":"1450–Afdød","1426–Female":"1426–Afdød","1426":"1426","1455":"1455","1450":"1450","abt 1450":"omkring 1450","West Riding, Yorkshire, England":"Jórvík, England","Wakefield, Yorks, Eng.":"Wakefield, Jórvík, England, United Kingdom"},"nl":{"1426–":"1426–Overleden","–Male":"Overleden","1450–Male":"1450–Overleden","1426–Female":"1426–Overleden","1426":"1426","1455":"1455","1450":"1450","abt 1450":"circa 1450","West Riding, Yorkshire, England":"Yorkshire, England","Wakefield, Yorks, Eng.":"Wakefield, Yorkshire, Engeland, Verenigd Koninkrijk"},"en":{"1426–":"1426–Deceased","–Male":"Deceased","1450–Male":"1450–Deceased","1426–Female":"1426–Deceased","1426":"1426","1455":"1455","1450":"1450","abt 1450":"about 1450","West Riding, Yorkshire, England":"Yorkshire, England","Wakefield, Yorks, Eng.":"Wakefield, Yorkshire, England, United Kingdom","nameMeanings":[{"name":"Murphy","type":"LAST","attribution":"Dictionary of American Family Names © Patrick Hanks 2003, 2006.","meanings":["Some characteristic forenames:  Irish Brendan, Liam, Aileen, Kieran, Brigid, Donal, Siobhan, Eamon, Aidan, Dermot, John Patrick, Declan.","Irish: Anglicized form of Gaelic <b>Ó Murchadha</b> ‘descendant of <i>Murchadh</i>’, a personal name composed of the elements <i>muir</i> ‘sea’ + <i>cath</i> ‘battle’, i.e. ‘sea warrior’. This was an important family in Tyrone. For the surname with <i>mac</i>, see also   McMurrough   (Leinster).","English: variant of <b>Morphey</b> (see   Morphew  )."],"variants":[{"name":"McMurrough","meanings":["Irish:","Anglicized form (in Leinster) of <b>Mac Murchadha</b> ‘son of <i>Murchadh</i>’, a personal name meaning ‘sea warrior’. The spelling <i>gh</i> indicates the original guttural fricative sound of the internal <i>-ch-</i>. Elsewhere, in Roscommon and Tyrone, the usual Anglicized form was   Murphy   (the same phonetic change as in English <i>laugh, cough</i> etc.). Diarmait Mac Murchadha (Dermot McMurrough) was intermittently king of Leinster from 1126–71. After being deposed in 1166 he requested help from Henry II to reclaim his kingdom, which resulted in the Norman invasion of Ireland in 1169 under the leadership of Richard de Clare, Earl of Pembroke (known as ‘Strongbow’), an event that brought many Anglo-Norman surnames to Ireland. A powerful Irish family of this lineage were also known as   Kavanagh  , after Dermot's son.","Anglicized form (in Leinster) of <b>Mac Murchadha</b> ‘son of <i>Murchadh</i>’, a personal name meaning ‘sea warrior’. A powerful family of this name were also known as   Kavanagh  . The spelling <i>gh</i> indicates the original guttural fricative sound of the internal <i>-ch-</i>. Elsewhere (especially in Roscommon and Tyrone) the usual Anglicized form of the Irish name was   Murphy  ."]},{"name":"Morken","meanings":["Some characteristic forenames:  Scandinavian Knut.","Norwegian: habitational name from any of numerous farmsteads so named, from the definite form of Old Norse <i>mǫrk</i> ‘outlying pasture, wood’.","Irish: Anglicized form of Gaelic <b>Ó Murcháin</b> ‘descendant of <i>Murchán</i>’, a diminutive of the personal name <i>Murchadh</i> (see   Murphy  )."]},{"name":"McMurphy","meanings":["Irish: Anglicized form of Gaelic <b>Mac Murchadha</b>, a patronymic from the personal name <i>Murchadh</i> ‘sea warrior’, from <i>muir</i> ‘sea’ + <i>cath</i> ‘battle’. Compare   Murphy  ,   McMorrow  ,   McMurdo  ."]},{"name":"Murphrey","meanings":["Probably Irish: variant of   Murphy  ."]},{"name":"Morphis","meanings":["Irish: variant of   Murphy  ."]},{"name":"Morphy","meanings":["Some characteristic forenames:  Spanish Augusto, Jaime, Javier, Luis, Patricio.  Irish Donovan.","Scottish: variant of   Murphy  .","English (northern): variant of <b>Morphey</b> (see   Morphew  )."]},{"name":"Murphey","meanings":["Irish: variant of   Murphy  .","English (mainly northern): variant of <b>Morphey</b> (see   Morphew  )."]},{"name":"Murphree","meanings":["Probably Irish: variant of   Murphy  ."]},{"name":"Morahan","meanings":["Irish: Anglicized form of Gaelic <b>Ó Murcháin</b> ‘descendant of <i>Murchán</i>’, a personal name, a pet form of <i>Murchadh</i> ‘sea-warrior’. See   Murphy  ."]}]},{"name":"Mary","type":"FIRST","attribution":"Dictionary of First Names © Patrick Hanks and Flavia Hodges 1990, 2003, 2006.","meanings":["From Latin <i>Maria</i> via Old Welsh <i>Meir</i>.  See  <b>Mary</b> ."],"variants":[]}],"historicEvents":[{"id":1705197,"age":29,"year":"1455","julianDay":2252488,"title":"Wars of the Roses","description":"Wars of the Roses was a series of English civil wars for control of the throne of England between the royal families House of Lancaster and the House of York. The name of the war was derived as the red rose was the symbol of the Lancastrians and the white rose was the symbol of the Yorks.","url":"https://www.history.com/topics/british-history/wars-of-the-roses","urlTitle":"History - Wars of the Roses","jurisdictionLevel":1}],"lifeSummary":"Mary Murphy was born in 1426, in Yorkshire, England. She had at least 1 son with Michael Lyster."},"et":{"1426–":"1426–Surnud","–Male":"Surnud","1450–Male":"1450–Surnud","1426–Female":"1426–Surnud","1426":"1426","1455":"1455","1450":"1450","abt 1450":"umbes 1450","West Riding, Yorkshire, England":"Yorkshire, England","Wakefield, Yorks, Eng.":"Wakefield, Yorkshire, Inglismaa, United Kingdom"},"fi":{"1426–":"1426–Kuollut","–Male":"Kuollut","1450–Male":"1450–Kuollut