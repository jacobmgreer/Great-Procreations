"1255":"1255年","about 1188":"大约1188年","Beveren, Beveren-Waas, East Flanders, Belgium":"比利时奧斯吉福拉安德倫貝福倫-瓦阿斯","Boves, Somme, France":"法国皮卡迪索姆波福斯","Belgium":"比利时","Diksmuide, Diksmuide, West Flanders, Belgium":"比利时維斯吉福拉安德倫迪可斯姆德","lifeSummary":"当Dietrich III van Beveren于1184年出生在比利时奧斯吉福拉安德倫貝福倫-瓦阿斯时，他的父亲Diederik II VAN BEVEREN32岁，母亲Ade de Coucy27岁。他去世于1240年10月在比利时維斯吉福拉安德倫迪可斯姆德享年56岁。"},"hr":{"1184–Before Oct 1240":"1184.–listopad 1240.","1184–1240":"1184.–1240.","1190–1230":"1190–1230","1190–1240":"1190–1240.","1215–1274":"1215–1274","1190–1255":"1190–1255","1152–1203":"1152–1203","1157–1195":"1157–1195.","Before Oct 1240":"listopad 1240.","1190":"1190","after April 1203":"nakon travnja 1203.","1274":"1274","1230":"1230","ABT 1215":"oko 1215.","1240":"1240.","1152":"1152","1184":"1184.","1195":"1195.","1215":"1215","1203":"1203","1157":"1157","1255":"1255","about 1188":"oko 1188.","Beveren, Beveren-Waas, East Flanders, Belgium":"Beveren-Waas, Oost-Vlaanderen, Belgija","Boves, Somme, France":"Boves, Somme, Picardie, Francuska","Belgium":"Belgija","Diksmuide, Diksmuide, West Flanders, Belgium":"Diksmuide, West-Vlaanderen, Belgija"},"cs":{"1184–Before Oct 1240":"1184–říjen 1240","1184–1240":"1184–1240","1190–1230":"1190–1230","1190–1240":"1190–1240","1215–1274":"1215–1274","1190–1255":"1190–1255","1152–1203":"1152–1203","1157–1195":"1157–1195","Before Oct 1240":"říjen 1240","1190":"1190","after April 1203":"po duben 1203","1274":"1274","1230":"1230","ABT 1215":"okolo 1215","1240":"1240","1152":"1152","1184":"1184","1195":"1195","1215":"1215","1203":"1203","1157":"1157","1255":"1255","about 1188":"okolo 1188","Beveren, Beveren-Waas, East Flanders, Belgium":"Beveren-Waas, Oost-Vlaanderen, Belgie","Boves, Somme, France":"Boves, Somme, Picardie, Francie","Belgium":"Belgie","Diksmuide, Diksmuide, West Flanders, Belgium":"Diksmuide, West-Vlaanderen, Belgie"},"da":{"1184–Before Oct 1240":"1184–oktober 1240","1184–1240":"1184–1240","1190–1230":"1190–1230","1190–1240":"1190–1240","1215