,"1426":"1426","1403":"1403","1325":"1325","1379":"1379","1400":"1400","1422":"1422","1410":"1410","1498":"1498","1431":"1431","1342":"1342","1439":"1439","Salisbury, Wiltshire, England":"Salisbury, Wiltshire, England","Exeter, Devon, England":"Exeter, Devon, Engeland, Verenigd Koninkrijk","Suffolk, England":"Suffolk, England","Cornwall, England":"Cornwall, England","Haverhill, Suffolk, England":"Haverhill, Suffolk, Engeland, Verenigd Koninkrijk"},"en":{"1372–1400":"1372–1400","1380–1439":"1380–1439","1381–Male":"1381–Deceased","1384–1426":"1384–1426","1370–1431":"1370–1431","1395–1498":"1395–1498","1410–Female":"1410–Deceased","1325–1403":"1325–1403","1342–1422":"1342–1422","1395":"1395","1384":"1384","1372":"1372","1382":"1382","1370":"1370","1381":"1381","1380":"1380","1390":"1390","1426":"1426","1403":"1403","1325":"1325","1379":"1379","1400":"1400","1422":"1422","1410":"1410","1498":"1498","1431":"1431","1342":"1342","1439":"1439","Salisbury, Wiltshire, England":"Salisbury, Wiltshire, England","Exeter, Devon, England":"Exeter, Devon, England, United Kingdom","Suffolk, England":"Suffolk, England","Cornwall, England":"Cornwall, England","Haverhill, Suffolk, England":"Haverhill, Suffolk, England, United Kingdom","nameMeanings":[{"name":"de","type":"LAST","attribution":"Dictionary of American Family Names © Patrick Hanks 2003, 2006.","meanings":["Some characteristic forenames:  Indian Dilip, Anirban, Gopal, Alok, Anindya, Arunava, Asit, Asok, Dibyendu, Goutam, Indra, Indranil.","Indian: variant of   Dey  ."],"variants":[{"name":"Dey","meanings":["Some characteristic forenames:  Indian Ashit, Indu, Naina, Partha, Soumya, Ajit, Anjan, Anjana, Anup, Arjun, Arun, Ashim.","English, Scottish, and Welsh: variant of   Day  .","German: topographic name from a field name in North Rhine-Westphalia, denoting a sizeable piece of land, from Middle Low German <i>dē</i> ‘thigh’ (referring to the shape of the property)."]}]},{"name":"Peverell","type":"LAST","attribution":"Dictionary of Family Names in Britain and Ireland © University of the West of England 2016","meanings":["Norman, English:  see  Peverall  ."],"variants":[{"name":"Peverall","meanings":["Norman, English: relationship name from Old French  <i>Peurel</i> (Latin  <i>Piperellus</i>), a diminutive of Old French  <i>pevre</i> ‘pepper’ (Anglo-Norman French  <i>peivere</i>, Latin  <i>piper</i>), originally perhaps used as a nickname on the Continent but used as a personal name in Anglo-Norman England."]}]},{"name":"Margaret","type":"FIRST","attribution":"Dictionary of First Names © Patrick Hanks and Flavia Hodges 1990, 2003, 2006.","meanings":["An extremely common given name from the Middle Ages onwards, derived via Old French <i>Marguerite</i> and Latin <i>Margarita</i> from Greek <i>Margarītēs</i>, from <i>margaron</i> ‘pearl’, a word ultimately of Hebrew origin. The name was always understood to mean ‘pearl’ throughout the Middle Ages. The first  St Margaret  was martyred at Antioch in Pisidia during the persecution instigated by the  Emperor Diocletian  in the early 4th century. However, there is some doubt about her name, as the same saint is venerated in the Orthodox Church as   Marina .  There were several other saintly bearers of the name, including St Margaret of Scotland (  d. 1093 ), wife of  King Malcolm Canmore  and daughter of Edmund Ironside of England. It was also the name of the wife of  Henry VI  of England,  Margaret of Anjou  (  1430–82 ), and of  Margaret Tudor  (  1489–1541 ), sister of  Henry VIII , who married James IV of Scotland and ruled as regent there after his death.  See also  Margery  ,   Marjorie ."],"variants":[{"name":"Margareta","meanings":["From the Latin form of Greek <i>Margarītēs</i>.  See  <b>Margaret</b>   ."]},{"name":"Margaretta","meanings":["An extremely common given name from the Middle Ages onwards, derived via Old French <i>Marguerite</i> and Latin <i>Margarita</i> from Greek <i>Margarītēs</i>, from <i>margaron</i> ‘pearl’, a word ultimately of Hebrew origin. The name was always understood to mean ‘pearl’ throughout the Middle Ages. The first  St Margaret  was martyred at Antioch in Pisidia during the persecution instigated by the  Emperor Diocletian  in the early 4th century. However, there is some doubt about her name, as the same saint is venerated in the Orthodox Church as   Marina .  There were several other saintly bearers of the name, including St Margaret of Scotland (  d. 1093 ), wife of  King Malcolm Canmore  and daughter of Edmund Ironside of England. It was also the name of the wife of  Henry VI  of England,  Margaret of Anjou  (  1430–82 ), and of  Margaret Tudor  (  1489–1541 ), sister of  Henry VIII , who married James IV of Scotland and ruled as regent there after his death.  See also  Margery  ,   Marjorie ."]}]},{"name":"Mary","type":"FIRST","attribution":"Dictionary of First Names © Patrick Hanks and Flavia Hodges 1990, 2003, 2006.","meanings":["From Latin <i>Maria</i> via Old Welsh <i>Meir</i>.  See  <b>Mary</b> ."],"variants":[]}],"historicEvents":[{"id":1705195,"age":10,"year":"1382","julianDay":2225826,"title":"Wycliffe's Bible","description":"John Wycliffe, English theologian and professor at the University of Oxford, completed a translation of the Bible from the Latin Vulgate into Middle English. This translation is known as Wycliffe's Bible and was completed around 1382.","url":"https://en.wikipedia.org/wiki/Wycliffe%27s_Bible","urlTitle":"Wikipedia - Wycliffe's Bible","jurisdictionLevel":2}],"lifeSummary":"When Margaret Mary de Peverell was born in 1372, in Cornwall, England, her father, Sir Thomas Peverell, was 47 and her mother, Margaret de Courtenay, was 31. She married Edward Turner in 1390, in Suffolk, England. They were the parents of at least 1 son and 1 daughter. She died in 1400, in Salisbury, Wiltshire, England, at the age of 28."},"et":{"1372–1400":"1372–1400","1380–1439":"1380–1439","1381–Male":"1381–Surnud","1384–1426":"1384–1426","1370–1431":"1370–1431","13