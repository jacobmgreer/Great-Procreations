100":"1100","1067":"1067","1045":"1045","Salisbury, Wiltshire, England":"Salisbury, Wiltshire, England","Scotland":"Scotland","Flanders, Belgium":"Vlaanderen, Belgija","Herefordshire, England":"Herefordshire, Engleska, United Kingdom","France":"Francuska"},"cs":{"1034–1086":"1034–1086","1045–Male":"1045–Zesnulý","1059–Female":"1059–Zesnulá","1066–Male":"1066–Zesnulý","1066–Female":"1066–Zesnulá","1067–1157":"1067–1157","1067–Male":"1067–Zesnulý","1070–1112":"1070–1112","1100–1130":"1100–1130","1033–1085":"1033–1085","1037–1066":"1037–1066","1066":"1066","1055":"1055","1033":"1033","1086":"1086","1130":"1130","1085":"1085","1070":"1070","1037":"1037","1059":"1059","1157":"1157","1112":"1112","1034":"1034","1100":"1100","1067":"1067","1045":"1045","Salisbury, Wiltshire, England":"Salisbury, Wiltshire, Anglie","Scotland":"Scotland","Flanders, Belgium":"Vlaanderen, Belgie","Herefordshire, England":"Herefordshire, Anglie, United Kingdom","France":"Francie"},"da":{"1034–1086":"1034–1086","1045–Male":"1045–Afdød","1059–Female":"1059–Afdød","1066–Male":"1066–Afdød","1066–Female":"1066–Afdød","1067–1157":"1067–1157","1067–Male":"1067–Afdød","1070–1112":"1070–1112","1100–1130":"1100–1130","1033–1085":"1033–1085","1037–1066":"1037–1066","1066":"1066","1055":"1055","1033":"1033","1086":"1086","1130":"1130","1085":"1085","1070":"1070","1037":"1037","1059":"1059","1157":"1157","1112":"1112","1034":"1034","1100":"1100","1067":"1067","1045":"1045","Salisbury, Wiltshire, England":"Salisbury, Wiltshire, England","Scotland":"Skotland","Flanders, Belgium":"Vlaanderen, Belgien","Herefordshire, England":"Herefordshire, England, United Kingdom","France":"Frankrig"},"nl":{"1034–1086":"1034–1086","1045–Male":"1045–Overleden","1059–Female":"1059–Overleden","1066–Male":"1066–Overleden","1066–Female":"1066–Overleden","1067–1157":"1067–1157","1067–Male":"1067–Overleden","1070–1112":"1070–1112","1100–1130":"1100–1130","1033–1085":"1033–1085","1037–1066":"1037–1066","1066":"1066","1055":"1055","1033":"1033","1086":"1086","1130":"1130","1085":"1085","1070":"1070","1037":"1037","1059":"1059","1157":"1157","1112":"1112","1034":"1034","1100":"1100","1067":"1067","1045":"1045","Salisbury, Wiltshire, England":"Salisbury, Wiltshire, England","Scotland":"Schotland","Flanders, Belgium":"Vlaanderen, België","Herefordshire, England":"Herefordshire, Engeland, Verenigd Koninkrijk","France":"Frankrijk"},"en":{"1034–1086":"1034–1086","1045–Male":"1045–Deceased","1059–Female":"1059–Deceased","1066–Male":"1066–Deceased","1066–Female":"1066–Deceased","1067–1157":"1067–1157","1067–Male":"1067–Deceased","1070–1112":"1070–1112","1100–1130":"1100–1130","1033–1085":"1033–1085","1037–1066":"1037–1066","1066":"1066","1055":"1055","1033":"1033","1086":"1086","1130":"1130","1085":"1085","1070":"1070","1037":"1037","1059":"1059","1157":"1157","1112":"1112","1034":"1034","1100":"1100","1067":"1067","1045":"1045","Salisbury, Wiltshire, England":"Salisbury, Wiltshire, England","Scotland":"Scotland","Flanders, Belgium":"Flanders, Belgium","Herefordshire, England":"Herefordshire, England, United Kingdom","France":"France","nameMeanings":[{"name":"d'Evereux","type":"LAST","attribution":"Dictionary of American Family Names © Patrick Hanks 2003, 2006.","meanings":["Some characteristic forenames:  Irish Dermot, Sean.","English and Irish: of Norman origin, a habitational name for someone from Évreux in Eure, France, with the preposition <i>d(e)</i>. See also   Everest   for the name without the preposition.","History: This was the surname of the Earls of Essex from 1572 to 1641. Walter <i>Devereux</i>, 1st Earl of Essex, led an attempted colonization of Ulster, and his son, Robert, 2nd Earl of Essex, briefly held the position of lord lieutenant of Ireland in 1599."],"variants":[{"name":"Devereaux","meanings":["English and Irish: of Norman origin, a variant of   Devereux  ."]},{"name":"Everest","meanings":["English (southeastern): of Norman origin, a variant of   Devereux   without the fused preposition (Old French <i>de</i>). Compare   Evers  ."]},{"name":"Evers","meanings":["English: perhaps a variant of   Devereux   without the fused preposition (Old French <i>de</i>).","English: de-aspirated variant of <b>Heaver</b>, with post-medieval excrescent <i>-s</i>, a habitational name from Hever (Kent), named from Old English <i>hēah</i> ‘high’ + (Kentish) Old English <i>ēfre</i> ‘edge or brow of a hill’. Alternatively, the name may derive from some minor place in southeastern England named with Old English <i>ȳfre</i>, (Kentish) Old English <i>ēfre</i>, Middle English <i>evere</i> ‘edge or brow of a hill, tip of a promontory’, with the addition of a prosthetic <i>H-</i>.","North German and Dutch: genitivized patronymic from the personal name   Evert  , which lost its <i>t</i> in pronunciation and spelling subsequently; compare   Everts  . Compare also   Avers  ."]},{"name":"Deveraux","meanings":["Some characteristic forenames:  Irish Dermot.","English and Irish: of Norman origin, a variant of   Devereux  ."]},{"name":"Devery","meanings":["Some characteristic forenames:  Irish Kieran, Brendan, Clancy.","Irish (Offaly): of Norman origin, a variant of   Devereux  ."]},{"name":"Devary","meanings":["Probably Irish: variant of <b>Devery</b>, a variant of   Devereux   in counties Leix and Offaly."]},{"name":"Debrow","meanings":["Altered form of English or Irish   Devereux  ."]}]},{"name":"Richard","type":"FIRST","attribution":"Dictionary of First Names © Patrick Hanks and Flavia Hodges 1990, 2003, 2006.","meanings":["One of the most enduringly successful of the Old French personal names introduced into Britain by the Normans. It is of Germanic (Frankish) origin, derived from <i>rīc</i> ‘power’ + <i>hard</i> ‘strong, hardy’. It has enjoyed continuous popularity in England from the Conquest to the present day, influenced by the fact that it was borne by three kings of England, in particular  Richard I  (  1157–99 ). He was king for only ten years (  1189–99 ), most of which he spent in warfare abroad, taking part in the Third Crusade and costing the people of England considerable sums in taxes. Nevertheless, he achieved the status of a folk hero, and was never in England long enough to disappoint popular faith in his goodness and justice. He was also Duke of Aquitaine and Normandy and Count of Anjou, fiefs which he held at a time of maximum English expansion in France. His exploits as a leader of the Third Crusade earned him the nickname ‘Coeur de Lion’ or ‘Lionheart’ and a permanent place in popular imagination, in which he was even more firmly enshrined by  Sir Walter Scott's  novel Ivanhoe (  1820 )."],"variants":[{"name":"Rikert","meanings":["One of the most enduringly successful of the Old French personal names introduced into Britain by the Normans. It is of Germanic (Frankish) origin, derived from <i>rīc</i> ‘power’ + <i>hard</i> ‘strong, hardy’. It has enjoyed continuous popularity in England from the Conquest to the present day, influenced by the fact that it was borne by three kings of England, in particular  Richard I  (  1157–99 ). He was king for only ten years (  1189–99 ), most of which he spent in warfare abroad, taking part in the Third Crusade and costing the people of England considerable sums in taxes. Nevertheless, he achieved the status of a folk hero, and was never in England long enough to disappoint popular faith in his goodness and justice. He was also Duke of Aquitaine and Normandy and Count of Anjou, fiefs which he held at a time of maximum English expansion in France. His exploits as a leader of the Third Crusade earned him the nickname ‘Coeur de Lion’ or ‘Lionheart’ and a permanent place in popular imagination, in which he was even more firmly enshrined by  Sir Walter Scott's  novel Ivanhoe (  1820 )."]},{"name":"Rickert","meanings":["One of the most enduringly successful of the Old French personal names introduced into Britain by the Normans. It is of Germanic (Frankish) origin, derived from <i>rīc</i> ‘power’ + <i>hard</i> ‘strong, hardy’. It has enjoyed continuous popularity in England from the Conquest to the present day, influenced by the fact that it was borne by three kings of England, in particular  Richard I  (  1157–99 ). He was king for only ten years (  1189–99 ), most of which he spent in warfare abroad, taking part in the Third Crusade and costing the people of England considerable sums in taxes. Nevertheless, he achieved the status of a folk hero, and was never in England long enough to disappoint popular faith in his goodness and justice. He was also Duke of Aquitaine and Normandy and Count of Anjou, fiefs which he held at a time of maximum English expansion in France. His exploits as a leader of the Third Crusade earned him the nickname ‘Coeur de Lion’ or ‘Lionheart’ and a permanent place in popular imagination, in which he was even more firmly enshrined by  Sir Walter Scott's  novel Ivanhoe (  1820 )."]}]}],"lifeSummary":"When Forester Richard d'Evereux was born in 1034, in Flanders, Belgium, his father, Walter d'Evreux, was 2 and his mother, Philippa Normandie, was -2. He married Barfulf deWhitern in 1095. They were the parents of at least 1 son. He died in 1086, in Scotland, at the age of 52."},"et":{"1034–1086":"1034–1086","1045–Male":"1045–Surnud","1059–Female":"1059–Surnud","1066–Male":"1066–Surnud","1066–Female":"1066–Surnud","1067–1157":"1067–1157","1067–Male":"1067–Surnud","1070–1112":"1070–1112","1100–1130":"1100–1130","1033–1085":"1033–1085","1037–1066":"1037–1066","1066":"1066","1055":"1055","1033":"1033","1086":"1086","1130":"1130","1085":"1085","1070":"1070","1037":"1037","1059":"1059","1157":"1157","1112":"1112","1034":"1034","1100":"1100","1067":"1067","1045":"1045","Salisbury, Wiltshire, England":"Salisbury, Wiltshire, England","Scotland":"Scotland","Flanders, Belgium":"Vlaanderen, Belgia","Herefordshire, England":"Herefordshire, Inglismaa, United Kingdom","France":"Prantsusmaa"},"fi":{"1034–1086":"1034–1086","1045–Male":"1045