:"1185–Afdød","1180–Male":"1180–Afdød","1205–Male":"1205–Afdød","1160–Male":"1160–Afdød","1165–Female":"1165–Afdød","1205":"1205","1259":"1259","1215":"1215","1224":"1224","1165":"1165","1185":"1185","1160":"1160","1180":"1180","Newton, Yorkshire, England":"Newton, Jórvík, England"},"nl":{"1185–Deceased":"1185–Overleden","1185–Female":"1185–Overleden","1180–Male":"1180–Overleden","1205–Male":"1205–Overleden","1160–Male":"1160–Overleden","1165–Female":"1165–Overleden","1205":"1205","1259":"1259","1215":"1215","1224":"1224","1165":"1165","1185":"1185","1160":"1160","1180":"1180","Newton, Yorkshire, England":"Newton, Yorkshire, England"},"en":{"1185–Deceased":"1185–Deceased","1185–Female":"1185–Deceased","1180–Male":"1180–Deceased","1205–Male":"1205–Deceased","1160–Male":"1160–Deceased","1165–Female":"1165–Deceased","1205":"1205","1259":"1259","1215":"1215","1224":"1224","1165":"1165","1185":"1185","1160":"1160","1180":"1180","Newton, Yorkshire, England":"Newton, Yorkshire, England","nameMeanings":[{"name":"Norton","type":"LAST","attribution":"Dictionary of American Family Names © Patrick Hanks 2003, 2006.","meanings":["English: habitational name from any of the many places so called, from Old English <i>north</i> ‘north’ + <i>tūn</i> ‘enclosure, settlement’. In some cases it is a variant of   Norrington  .","Irish: altered form of   Naughton  , assimilated to the English name (see 1 above).","Jewish (American): adoption of the English surname (see 1 above) in place of some similar (like-sounding) original Ashkenazic surname."],"variants":[{"name":"Norrington","meanings":["English:","(southeastern): from Norringtonend in Redbourn (Hertforshire), Northingtown Farm in Grimley (Worcestershire), or Norrington in Alvediston (Wiltshire). All three names are from Old English <i>north in tūne</i> ‘to the north of the village’.","possibly a variant of <b>Northampton</b>, a habitational name from the city of this name, which was named with Old English <i>north</i> ‘north’ + <i>hām</i> + <i>tūn</i> ‘homestead, home farm’."]}]},{"name":"Margaret","type":"FIRST","attribution":"Dictionary of First Names © Patrick Hanks and Flavia Hodges 1990, 2003, 2006.","meanings":["An extremely common given name from the Middle Ages onwards, derived via Old French <i>Marguerite</i> and Latin <i>Margarita</i> from Greek <i>Margarītēs</i>, from <i>margaron</i> ‘pearl’, a word ultimately of Hebrew origin. The name was always understood to mean ‘pearl’ throughout the Middle Ages. The first  St Margaret  was martyred at Antioch in Pisidia during the persecution instigated by the  Emperor Diocletian  in the early 4th century. However, there is some doubt about her name, as the same saint is venerated in the Orthodox Church as   Marina .  There were several other saintly bearers of the name, including St Margaret of Scotland (  d. 1093 ), wife of  King Malcolm Canmore  and daughter of Edmund Ironside of England. It was also the name of the wife of  Henry VI  of England,  Margaret of Anjou  (  1430–82 ), and of  Margaret Tudor  (  1489–1541 ), sister of  Henry VIII , who married James IV of Scotland and ruled as regent there after his death.  See also  Margery  ,   Marjorie ."],"variants":[{"name":"Margareta","meanings":["From the Latin form of Greek <i>Margarītēs</i>.  See  <b>Margaret</b>   ."]},{"name":"Margaretta","meanings":["Formed from Margaret."]}]}],"historicEvents":[{"id":1705187,"age":30,"year":"1215","julianDay":2164830,"title":"Magna Carta","description":"King John of England agreed to a charter of rights called the Magna Carta. The document was originally drafted by the Archbishop of Canterbury to establish peace between King John and a group of rebel barons. The Magna Carta was completed in 1215 and is now considered to be one of the greatest constitutional documents of all time.","url":"https://www.nationalarchives.gov.uk/education/medieval/magna-carta/","urlTitle":"National Archives - Magna Carta","jurisdictionLevel":2},{"id":1705188,"age":39,"year":"1224","julianDay":2168117,"title":"France Declares War on England","description":"France declared war on England as Louis VIII of France attacked Poitou and northern Gascony.","jurisdictionLevel":2},{"id":1705189,"age":74,"year":"1259","julianDay":2180901,"title":"100 Years of Conflict Between England and France Ends","description":"Treaty of Paris was signed on December 4, 1259, which ended 100 years of conflict between England and France.","url":"https://en.wikipedia.org/wiki/Treaty_of_Paris_(1259)","urlTitle":"Wikipedia - Treaty of Paris 1259","jurisdictionLevel":2}],"lifeSummary":"When Margaret Norton was born in 1185, in Newton, Yorkshire, England, her father, Hugh Norton, was 25 and her mother, Mrs. Hugh Norton, was 21. She married John Mauleverer about 1204, in Newton, Yorkshire, England. They were the parents of at least 1 son."},"et":{"1185–Deceased":"1185–Surnud","1185–Female":"1185–Surnud","1180–Male":"1180–Surnud","1205–Male":"1205–Surnud","1160–Male":"1160–Surnud","1165–Female":"1165–Surnud","1205":"1205","1259":"1259","1215":"1215","1224":"1224","1165":"1165","1185":"1185","1160":"1160","1180":"1180","Newton, Yorkshire, England":"Newton, Yorkshire, England"},"fi":{"1185–Deceased":"1185–Kuollut","1185–Female":"1185–Kuollut","1180–Male":"1180–Kuollut","1205–Male":"1205–Kuollut","1160–Male":"1160–Kuollut","1165–Female":"1165–Kuollut","1205":"1205","1259":"1259","1215":"1215","1224":"1224","1165":"1165","1185":"1185","1160":"1160","1180":"1180","Newton, Yorkshire, England":"Newton, Yorkshire, England"},"fr":{"1185–Deceased":"1185–Décédée","1185–Female":"1185–Décédée","1180–Male":"1180–Décédé","1205–Male":"1205–Décédé","1160–Male":"1160–Décédé","1165–Female":"1165–Décédée","1205":"1205","1259":"1259","1215":"1215","1224":"1224","1165":"1165","1185":"1185","1160":"1160","1180":"1180","Newton, Yorkshire, England":"Newton, Everwyck, Angleterre","lifeSummary":"Lorsque Margaret Norton est née en 1185, à Newton, Everwyck, Angleterre, son père, Hugh Norton, ava