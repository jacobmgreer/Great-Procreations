0","1152":"1152","1262":"1262","1250":"1250","1160":"1160","1182":"1182","1170":"1170","1180":"1180","1290":"1290","1227":"1227","1259":"1259","1215":"1215","1224":"1224","1179":"1179","1200":"1200","Bef 1220":"vóór 1220","Sussex, England":"Sussex, England","Woolcombe, Dorsetshire, England":"Lewcombe, Dorset, Engeland, Verenigd Koninkrijk","Ashburnham, Sussex, England":"Ashburnham, Sussex, Engeland, Verenigd Koninkrijk"},"en":{"1180–":"1180–Deceased","1179–1262":"1179–1262","1180–Female":"1180–Deceased","1182–1250":"1182–1250","1200–Male":"1200–Deceased","1170–Male":"1170–Deceased","1220–Male":"1220–Deceased","1160–1190":"1160–1190","1152–1227":"1152–1227","1190":"1190","about 1173":"about 1173","1220":"1220","1152":"1152","1262":"1262","1250":"1250","1160":"1160","1182":"1182","1170":"1170","1180":"1180","1290":"1290","1227":"1227","1259":"1259","1215":"1215","1224":"1224","1179":"1179","1200":"1200","Bef 1220":"before 1220","Sussex, England":"Sussex, England","Woolcombe, Dorsetshire, England":"Lewcombe, Dorset, England, United Kingdom","Ashburnham, Sussex, England":"Ashburnham, Sussex, England, United Kingdom","nameMeanings":[{"name":"Maltravers","type":"LAST","attribution":"Dictionary of Family Names in Britain and Ireland © University of the West of England 2016","meanings":["Norman, English:  see  Matravers  ."],"variants":[{"name":"Matravers","meanings":["Norman, English: locative name from Mautravert in Chérencé-le-Héron (Manche)."]}]},{"name":"Margaret","type":"FIRST","attribution":"Dictionary of First Names © Patrick Hanks and Flavia Hodges 1990, 2003, 2006.","meanings":["An extremely common given name from the Middle Ages onwards, derived via Old French <i>Marguerite</i> and Latin <i>Margarita</i> from Greek <i>Margarītēs</i>, from <i>margaron</i> ‘pearl’, a word ultimately of Hebrew origin. The name was always understood to mean ‘pearl’ throughout the Middle Ages. The first  St Margaret  was martyred at Antioch in Pisidia during the persecution instigated by the  Emperor Diocletian  in the early 4th century. However, there is some doubt about her name, as the same saint is venerated in the Orthodox Church as   Marina .  There were several other saintly bearers of the name, including St Margaret of Scotland (  d. 1093 ), wife of  King Malcolm Canmore  and daughter of Edmund Ironside of England. It was also the name of the wife of  Henry VI  of England,  Margaret of Anjou  (  1430–82 ), and of  Margaret Tudor  (  1489–1541 ), sister of  Henry VIII , who married James IV of Scotland and ruled as regent there after his death.  See also  Margery  ,   Marjorie ."],"variants":[{"name":"Margareta","meanings":["From the Latin form of Greek <i>Margarītēs</i>.  See  <b>Margaret</b>   ."]},{"name":"Margaretta","meanings":["An extremely common given name from the Middle Ages onwards, derived via Old French <i>Marguerite</i> and Latin <i>Margarita</i> from Greek <i>Margarītēs</i>, from <i>margaron</i> ‘pearl’, a word ultimately of Hebrew origin. The name was always understood to mean ‘pearl’ throughout the Middle Ages. The first  St Margaret  was martyred at Antioch in Pisidia during the persecution instigated by the  Emperor Diocletian  in the early 4th century. However, there is some doubt about her name, as the same saint is venerated in the Orthodox Church as   Marina .  There were several other saintly bearers of the name, including St Margaret of Scotland (  d. 1093 ), wife of  King Malcolm Canmore  and daughter of Edmund Ironside of England. It was also the name of the wife of  Henry VI  of England,  Margaret of Anjou  (  1430–82 ), and of  Margaret Tudor  (  1489–1541 ), sister of  Henry VIII , who married James IV of Scotland and ruled as regent there after his death.  See also  Margery  ,   Marjorie ."]}]}],"historicEvents":[{"id":1705187,"age":35,"year":"1215","julianDay":2164830,"title":"Magna Carta","description":"King John of England agreed to a charter of rights called the Magna Carta. The document was originally d