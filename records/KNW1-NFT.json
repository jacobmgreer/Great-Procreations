nigd Koninkrijk"},"en":{"1256–":"1256–Deceased","1256–Male":"1256–Deceased","1280–Male":"1280–Deceased","1295–1348":"1295–1348","1302–Male":"1302–Deceased","1256–Female":"1256–Deceased","1348":"1348","about 1280":"about 1280","about 1270":"about 1270","1302":"1302","1256":"1256","abt. 1302":"about 1302","1295":"1295","1280":"1280","Nunney, Somersetshire, England":"Nunney, Somerset, England, United Kingdom","Nunney, Somerset, England":"Nunney, Somerset, England","of Nunney, Somerset, England":"Nunney, Somerset, England, United Kingdom","Tattershall, Lincolnshire, England":"Tattershall, Lincolnshire, England, United Kingdom","nameMeanings":[{"name":"Somerset","type":"LAST","attribution":"Dictionary of American Family Names © Patrick Hanks 2003, 2006.","meanings":["English:","habitational name from the English county of Somerset, which takes its name from Somerton in Somerset (see   Summerton  ) + Old English <i>sǣte</i> ‘settlers, dwellers’. The <i>Somerset</i> family who are Dukes of Beaufort are descended from the Plantagenets. The surname was assumed by Charles <i>Somerset</i> (1460–1520), illegitimate son of Henry Beaufort, Duke of Somerset. The latter was himself descended illegitimately from Edward III through John of Gaunt. A later member of the family was Fitzroy <i>Somerset</i> (1788–1855), who, as Lord Raglan, was the commander of British forces in the Crimea, one of the men responsible for the charge of the Light Brigade.","possibly a habitational name from one or more places called with Old Norse <i>sumar</i> ‘summer’ + <i>sætr</i> ‘shieling, hill pasture’, such as Summerseat in Elton (Lancashire), but decisive northern early bearers are lacking."],"variants":[{"name":"Summerton","meanings":["English: habitational name from any of various places called Somerton, particularly in Oxfordshire and Somerset, but also in Lincolnshire and Norfolk, named with Old English <i>sumor</i> ‘summer’ + <i>tūn</i> ‘farmstead, estate’."]},{"name":"Summersett","meanings":["English (Yorkshire): variant of   Somerset  ."]}]},{"name":"Margery","type":"FIRST","attribution":"Dictionary of First Names © Patrick Hanks and Flavia Hodges 1990, 2003, 2006.","meanings":["The usual medieval vernacular form of   Margaret   (now also commonly spelled   Marjorie  ). This form of the name is preserved in the nursery rhyme ‘See-saw, Margery Daw’."],"variants":[]}],"lifeSummary":"Margery Somerset was born in 1256, in Nunney, Somerset, England, United Kingdom. She married Sir Elias de la Mare about 1270, in Nunney, Somerset, England. They were the parents of at least 2 sons and 1 daughter."},"et":{"1256–":"1256–Surnud","1256–Male":"1256–Surnud","1280–Male":"1280–Surnud","1295–1348":"1295–1348","1302–Male":"1302–Surnud","1256–Female":"1256–Surnud","1348":"1348","about 1280":"umbes 1280","about 1270":"umbes 1270","1302":"1302","1256":"1256","abt. 1302":"umbes 1302","1295":"1295","1280":"1280","Nunney, Somersetshire, England":"Nunney, Somerset, Inglismaa, United Kingdom","Nunney, Somerset, England":"Nunney, Somerset, England","of Nunney, Somerset, England":"Nunney, Somerset, Inglismaa, United Kingdom","Tattershall, Lincolnshire, England":"Tattershall, Lincolnshire, Inglismaa, United Kingdom"},"fi":{"1256–":"1256–Kuollut","1256–Male":"1256–Kuollut","1280–Male":"1280–Kuollut","1295–1348":"1295–1348","1302–Male":"1302–Kuollut","1256–Female":"1256–Kuollut","1348":"1348","about 1280":"noin 1280","about 1270":"noin 1270","1302":"1302","1256":"1256","abt. 1302":"noin 1302","1295":"1295","1280":"1280","Nunney, Somersetshire, England":"Nunney, Somerset, Englanti, Yhdistynyt kuningaskunta","Nunney, Somerset, England":"Nunney, Somerset, England","of Nunney, Somerset, England":"Nunney, Somerset, Englanti, Yhdistynyt kuningaskunta","Tattershall, Lincolnshire, England":"Tattershall, Lincolnshire, Englanti, Yhdistynyt kuningaskunta"},"fr":{"1256–":"1256–Décédée","1256–Male":"1256–Décédé","1280–Male":"1280–Décédé","1295–1348":"1295–1348","1302–Male":"1302–Décédé","1256–Fem