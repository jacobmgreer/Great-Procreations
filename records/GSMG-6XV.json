om","West Worlington, Devon, England":"West Worlington, Devon, England","Bratton Clovelly, Devon, England":"Bratton Clovelly, Devon, England"},"cs":{"1385–1440":"1385–1440","1380–1438":"1380–1438","1389–Male":"1389–Zesnulý","1393–1471":"1393–1471","1395–1438":"1395–1438","1385–1467":"1385–1467","1404–1467":"1404–1467","1373–1467":"1373–1467","1377–1408":"1377–1408","1385":"1385","1440":"1440","1373":"1373","1395":"1395","1471":"1471","1393":"1393","1380":"1380","1404":"1404","1467":"1467","1389":"1389","1377":"1377","1408":"1408","1438":"1438","Affeton, West Worlington, Devonshire, England":"West Worlington, Devon, Anglie, United Kingdom","Affeton, Devon, England, United Kingdom":"Devon, Anglie, United Kingdom","West Worlington, Devon, England":"West Worlington, Devon, Anglie","Bratton Clovelly, Devon, England":"Bratton Clovelly, Devon, Anglie"},"da":{"1385–1440":"1385–1440","1380–1438":"1380–1438","1389–Male":"1389–Afdød","1393–1471":"1393–1471","1395–1438":"1395–1438","1385–1467":"1385–1467","1404–1467":"1404–1467","1373–1467":"1373–1467","1377–1408":"1377–1408","1385":"1385","1440":"1440","1373":"1373","1395":"1395","1471":"1471","1393":"1393","1380":"1380","1404":"1404","1467":"1467","1389":"1389","1377":"1377","1408":"1408","1438":"1438","Affeton, West Worlington, Devonshire, England":"West Worlington, Devon, England, United Kingdom","Affeton, Devon, England, United Kingdom":"Devon, England, United Kingdom","West Worlington, Devon, England":"West Worlington, Devon, England","Bratton Clovelly, Devon, England":"Bratton Clovelly, Devon, England"},"nl":{"1385–1440":"1385–1440","1380–1438":"1380–1438","1389–Male":"1389–Overleden","1393–1471":"1393–1471","1395–1438":"1395–1438","1385–1467":"1385–1467","1404–1467":"1404–1467","1373–1467":"1373–1467","1377–1408":"1377–1408","1385":"1385","1440":"1440","1373":"1373","1395":"1395","1471":"1471","1393":"1393","1380":"1380","1404":"1404","1467":"1467","1389":"1389","1377":"1377","1408":"1408","1438":"1438","Affeton, West Worlington, Devonshire, England":"West Worlington, Devon, Engeland, Verenigd Koninkrijk","Affeton, Devon, England, United Kingdom":"Devon, Engeland, Verenigd Koninkrijk","West Worlington, Devon, England":"West Worlington, Devon, England","Bratton Clovelly, Devon, England":"Bratton Clovelly, Devon, England"},"en":{"1385–1440":"1385–1440","1380–1438":"1380–1438","1389–Male":"1389–Deceased","1393–1471":"1393–1471","1395–1438":"1395–1438","1385–1467":"1385–1467","1404–1467":"1404–1467","1373–1467":"1373–1467","1377–1408":"1377–1408","1385":"1385","1440":"1440","1373":"1373","1395":"1395","1471":"1471","1393":"1393","1380":"1380","1404":"1404","1467":"1467","1389":"1389","1377":"1377","1408":"1408","1438":"1438","Affeton, West Worlington, Devonshire, England":"West Worlington, Devon, England, United Kingdom","Affeton, Devon, England, United Kingdom":"Devon, England, United Kingdom","West Worlington, Devon, England":"West Worlington, Devon, England","Bratton Clovelly, Devon, England":"Bratton Clovelly, Devon, England","nameMeanings":[{"name":"Bratton","type":"LAST","attribution":"Dictionary of American Family Names © Patrick Hanks 2003, 2006.","meanings":["English: habitational name from any of the places called Bratten (in Shropshire, Somerset, and Wiltshire) or from Bratton Clovelly or Bratton Fleming in Devon. The Shropshire and Somerset places are named with Old English <i>brōc</i> ‘brook’ + <i>tūn</i> ‘settlement’. The Wiltshire and Devon names are from Old English <i>brǣc</i> ‘newly cultivated ground’ + <i>tūn</i>."],"variants":[{"name":"Brattin","meanings":["Scottish (Wigtownshire): variant of   Bratton  ."]},{"name":"Bratten","meanings":["English: variant of   Bratton  .","Swedish (<b>Brattén</b>): ornamental name composed of the personal name   Bratt   + the adjectival suffix <i>-én</i>, from Latin <i>-enius</i> ‘relating to’.","Norwegian: variant of   Braaten  ."]}]},{"name":"Joan","type":"FIRST","attribution":"Dictionary of First Names © Patrick Hanks and Flavia Hodges 1990, 2003, 2006.","meanings":["Contracted form of Old French <i>Jo(h)anne</i>, from Latin <i>Io(h)anna</i> (  see  Joanna  ). In England this was the usual feminine form of   John   from the Middle English period onwards and was extremely popular, but in the 16th and 17th centuries it steadily lost ground to   Jane .  It was strongly revived in the first part of the 20th century, partly under the influence of  George Bernard Shaw's  play St Joan (  1923 ), based on the life of  Joan of Arc  (  1412–31 ). Claiming to be guided by the voices of the saints, she persuaded the French dauphin to defy the occupying English forces and have himself crowned, and she led the French army that raised the siege of Orleans in  1429 . The following year she was captured by the Burgundians and sold to the English, and a year later she was burned at the stake for witchcraft at the age of 18 or 19. Her story has captured the imagination of many writers, and she is variously portrayed as a national and political hero, a model of apolitical straightforwardness and honesty, and a religious heroine. She was canonized in  1920 . More recent influences have included the American film actress  Joan Crawford  (  1908–77 , born  Lucille le Sueur ), the British actress  Joan Collins  (  b. 1933 ), the American comedienne  Joan Rivers  (  b. 1933 ), and the West Indian pop singer  Joan Armatrading  (  b. 1950 )."],"variants":[{"name":"John","meanings":["Contracted form of Old French <i>Jo(h)anne</i>, from Latin <i>Io(h)anna</i> (  see  Joanna  ). In England this was the usual feminine form of   John   from the Middle English period onwards and was extremely popular, but in the 16th and 17th centuries it steadily lost ground to   Jane .  It was strongly revived in the first part of the 20th century, partly under the influence of  George Bernard Shaw's  play St Joan (  1923 ), based on the life of  Joan of Arc  (  1412–31 ). Claiming to be guided by the voices of the saints, she persuaded the French dauphin to defy the occupying English forces and have himself crowned, and she led the French army that raised the siege of Orleans in  1429 . The following year she was captured by the Burgundians and sold to the English, and a year later she was burned at the stake for witchcraft at the age of 18 or 19. Her story has captured the imagination of many writers, and she is variously portrayed as a national and political hero, a model of apolitical straightforwardness and honesty, and a religious heroine. She was canonized in  1920 . More recent influences have included the American film actress  Joan Crawford  (  1908–77 , born  Lucille le Sueur ), the British actress  Joan Collins  (  b. 1933 ), the American comedienne  Joan Rivers  (  b. 1933 ), and the West Indian pop singer  Joan Armatrading  (  b. 1950 )."]}]}],"lifeSummary":"When Joan Bratton was born in 1385, in Bratton Clovelly, Devon, England, her father, Thomas Bratton, was 12 and her mother, Joan De Sydenham, was 8. She married John De Affeton in 1404, in West Worlington, Devon, England, United Kingdom. They were the parents of at least 1 daughter. She died in 1440, in West Worlington, Devon, England, at the age of 55."},"et":{"1385–1440":"1385–1440","1380–1438":"1380–1438","1389–Male":"1389–Surnud","1393–1471":"1393–1471","1395–1438":"1395–1438","1385–1467":"1385–1467","1404–1467":"1404–1467","1373–1467":"1373–1467","1377–1408":"1377–1408","1385":"1385","1440":"1440","1373":"1373","1395":"1395","1471":"1471","1393":"1393","1380":"1380","1404":"1404","1467":"1467","1389":"1389","1377":"1377","1408":"1408","1438":"1438","Affeton, West Worlington, Devonshire, England":"West Worlington, Devon, Inglismaa, United Kingdom","Affeton, Devon, England, United Kingdom":"Devon, Inglismaa, United Kingdom","West Worlington, Devon, England":"West Worlington, Devon, England","Bratton Clovelly, Devon, England":"Bratton Clovelly, Devon, England"},"fi":{"1385–1440":"1385–1440","1380–1438":"1380–1438","1389–Male":"