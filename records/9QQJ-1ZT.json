om":"Cathcart, Glasgow, Schotland, Verenigd Koninkrijk",", AYRSHIRE, SCOTLAND":"Ayrshire, Schotland, Verenigd Koninkrijk"},"en":{"ABT 1280–":"about 1280–Deceased","1278–Male":"1278–Deceased","1308–Female":"1308–Deceased","1280–Female":"1280–Deceased","1278":"1278","Abt 1308":"about 1308","1308":"1308","ABT 1280":"about 1280","1280":"1280","Cathcart, City of Glasgow, Lanark, Scotland, United Kingdom":"Cathcart, Glasgow, Scotland, United Kingdom",", AYRSHIRE, SCOTLAND":"Ayrshire, Scotland, United Kingdom","nameMeanings":[{"name":"Carleton","type":"LAST","attribution":"Dictionary of American Family Names © Patrick Hanks 2003, 2006.","meanings":["English (northern and eastern England): variant of   Carlton  .","Irish (Ulster): adopted in Northern Ireland as an Anglicized form of <b>Ó Cairealláin</b>, see   Carolan   2."],"variants":[{"name":"Carlton","meanings":["English (northern and eastern England): habitational name from any of various places called Carlton (Bedfordshire, Cambridgeshire, Durham, Lincolnshire, Leicestershire, Nottinghamshire, Northamptonshire, Suffolk, East Yorkshire, Yorkshire, and North Yorkshire) or Carleton (Cumberland, Lancashire, Norfolk, Yorkshire). All come from Old Norse <i>karl</i> ‘common man, peasant’ + Old English <i>tūn</i> ‘settlement’ (compare   Charlton  ). Places spelled <i>Carl(e)ton</i> (as opposed to <i>Charlton</i>) are in areas of Scandinavian settlement, mostly in northern England.","Irish (Antrim): variant of   Carleton   2."]}]},{"name":"William","type":"FIRST","attribution":"Dictionary of First Names © Patrick Hanks and Flavia Hodges 1990, 2003, 2006.","meanings":["Probably the most successful of all the Old French names of Germanic origin that were introduced to England by the Normans. It is derived from Germanic <i>wil</i> ‘will, desire’ + <i>helm</i> ‘helmet, protection’. The fact that it was borne by the Conqueror himself does not seem to have inhibited its favour with the ‘conquered’ population: in the first century after the Conquest it was the commonest male name of all, and not only among the Normans. In the later Middle Ages it was overtaken by   John  , but continued to run second to that name until the 20th century, when the picture became more fragmented."],"variants":[]}],"lifeSummary":"Mrs William Carleton was born about 1280, in Ayrshire, Scotland, United Kingdom. She had at least 1 daughter with William Carleton."},"et":{"ABT 1280–":"umbes 1280–Surnud","1278–Male":"1278–Surnud","1308–Female":"1308–Surnud","1280–Female":"1280–Surnud","1278":"1278","Abt 1308":"umbes 1308","1308":"1308","ABT 1280":"umbes 1280","1280":"1280","Cathcart, City of Glasgow, Lanark, Scotland, United Kingdom":"Cathcart, Glasgow, Šotimaa, United Kingdom",", AYRSHIRE, SCOTLAND":"Ayrshire, Šotimaa, United Kingdom"},"fi":{"ABT 1280–":"noin 1280–Kuollut","1278–Male":"1278–Kuollut","1308–Female":"1308–Kuollut","1280–Female":"1280–Kuollut","1278":"1278","Abt 1308":"noin 1308","1308":"1308","ABT 1280":"noin 1280","1280":"1280","Cathcart, City of Glasgow, Lanark, Scotland, United Kingdom":"Cathcart, Glasgow, Skotlanti, Yhdistynyt kuningaskunta",", AYRSHIRE, SCOTLAND":"Ayrshire, Skotlanti, Yhdistynyt kuningaskunta"},"fr":{"ABT 1280–":"environ 1280–Décédée","1278–Male":"1278–Décédé","1308–Female":"1308–Décédée","1280–Female":"1280–Décédée","1278":"1278","Abt 1308":"environ 1308","1308":"1308","ABT 1280":"environ 1280","1280":"1280","Cathcart, City of Glasgow, Lanark, Scotland, United Kingdom":"Cathcart, Glasgow, Écosse, Royaume-Uni",", AYRSHIRE, SCOTLAND":"Ayrshire, Écosse, Royaume-Uni","lifeSummary":"Mrs William Carleton est née environ 1280, à Ayrshire, Écosse, Royaume-Uni. Elle a eu au moins 1 fille avec William Carleton."},"de":{"ABT 1280–":"um 1280–Verstorben","1278–Male":"1278–Verstorben","1308–Female":"1308–Verstorben","1280–Female":"1280–Verstorben","1278":"1278","Abt 1308":"um 1308","1308":"1308","ABT 1280":"um 1280","1280":"1280","Cathcart, City of Glasgow, Lanark, Scotland, United Kingdom":"Cathc