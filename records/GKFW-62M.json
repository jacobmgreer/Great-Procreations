land":"Laxfield, Suffolk, England, United Kingdom","nameMeanings":[{"name":"Margaret","type":"FIRST","attribution":"Dictionary of First Names © Patrick Hanks and Flavia Hodges 1990, 2003, 2006.","meanings":["An extremely common given name from the Middle Ages onwards, derived via Old French <i>Marguerite</i> and Latin <i>Margarita</i> from Greek <i>Margarītēs</i>, from <i>margaron</i> ‘pearl’, a word ultimately of Hebrew origin. The name was always understood to mean ‘pearl’ throughout the Middle Ages. The first  St Margaret  was martyred at Antioch in Pisidia during the persecution instigated by the  Emperor Diocletian  in the early 4th century. However, there is some doubt about her name, as the same saint is venerated in the Orthodox Church as   Marina .  There were several other saintly bearers of the name, including St Margaret of Scotland (  d. 1093 ), wife of  King Malcolm Canmore  and daughter of Edmund Ironside of England. It was also the name of the wife of  Henry VI  of England,  Margaret of Anjou  (  1430–82 ), and of  Margaret Tudor  (  1489–1541 ), sister of  Henry VIII , who married James IV of Scotland and ruled as regent there after his death.  See also  Margery  ,   Marjorie ."],"variants":[{"name":"Margareta","meanings":["From the Latin form of Greek <i>Margarītēs</i>.  See  <b>Margaret</b>   ."]},{"name":"Margaretta","meanings":["An extremely common given name from the Middle Ages onwards, derived via Old French <i>Marguerite</i> and Latin <i>Margarita</i> from Greek <i>Margarītēs</i>, from <i>margaron</i> ‘pearl’, a word ultimately of Hebrew origin. The name was always understood to mean ‘pearl’ throughout the Middle Ages. The first  St Margaret  was martyred at Antioch in Pisidia during the persecution instigated by the  Emperor Diocletian  in the early 4th century. However, there is some doubt about her name, as the same saint is venerated in the Orthodox Church as   Marina .  There were several other saintly bearers of the name, including St Margaret of Scotland (  d. 1093 ), wife of  King Malcolm Canmore  and daughter of Edmund Ironside of England. It was also the name of the wife of  Henry VI  of England,  Margaret of Anjou  (  1430–82 ), and of  Margaret Tudor  (  1489–1541 ), sister of  Henry VIII , who married James IV of Scotland and ruled as regent there after his death.  See also  Margery  ,   Marjorie ."]}]}],"lifeSummary":"Margaret had at least 1 son with William Dalling."},"et":{"–":"Surnud","1424–1473":"1424–1473","1454–1535":"1454–1535","–Female":"Surnud","1535":"1535","1424":"1424","1454":"1454","1473":"1473","Laxfield, Suffolk, England":"Laxfield, Suffolk, Inglismaa, United Kingdom"},"fi":{"–":"Kuollut","1424–1473":"1424–1473","1454–1535":"1454–1535","–Female":"Kuollut","1535":"1535","1424":"1424","1454":"1454","1473":"1473","Laxfield, Suffolk, England":"Laxfield, Suffolk, Englanti, Yhdistynyt kuningaskunta"},"fr":{"–":"Décédée","1424–1473":"1424–1473","1454–1535":"1454–1535","–Female":"Décédée","1535":"1535","1424":"1424","1454":"1454","1473":"1473","Laxfield, Suffolk, England":"Laxfield, Suffolk, Angleterre, Royaume-Uni","lifeSummary":"Margaret a eu au moins 1 fils avec William Dalling."},"de":{"–":"Verstorben","1424–1473":"1424–1473","1454–1535":"1454–1535","–Female":"Verstorben","1535":"1535","1424":"1424","1454":"1454","1473":"1473","Laxfield, Suffolk, England":"Laxfield, Suffolk, England, United Kingdom","lifeSummary":"Margaret hatte mit William Dalling mindestens 1 Sohn."},"ht":{"–":"Desede","1424–1473":"1424–1473","1454–1535":"1454–1535","–Female":"Desede","1535":"1535","1424":"1424","1454":"1454","1473":"1473","Laxfield, Suffolk, England":"Laxfield, Suffolk, Angletè, United Kingdom"},"hu":{"–":"elhunyt","1424–1473":"1424–1473","1454–1535":"1454–1535","–Female":"elhunyt","1535":"1535","1424":"1424","1454":"1454","1473":"1473","Laxfield, Suffolk, England":"Laxfield, Suffolk, Anglia, United Kingdom"},"id":{"–":"Telah Meninggal","1424–1473":"1424–1473","1454–1535":"1454–1535","–Femal