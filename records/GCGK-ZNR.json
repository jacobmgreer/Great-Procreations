ony.","jurisdictionLevel":1}],"lifeSummary":"When Michael L' Arcedekne was born about 1179, in Cornwall, England, his father, Thomas le' Arcedekne I, was 25 and his mother, Mrs. Alice Le' Arcedekne, was 20. He married Mrs Michael I'Arcedenke before 1230, in England. They were the parents of at least 2 sons and 1 daughter. He died after 1242."},"et":{"about 1179–after 1242":"umbes 1179–pärast 1242","1179–1242":"1179–1242","1183–1233":"1183–1233","1215–1277":"1215–1277","1217–1277":"1217–1277","1225–1278":"1225–1278","1155–Male":"1155–Surnud","1160–Female":"1160–Surnud","Cir 1215":"1215","1242":"1242","Abt 1225":"umbes 1225","1183":"1183","1160":"1160","1217":"1217","1215":"1215","1225":"1225","about 1217":"umbes 1217","1224":"1224","1278":"1278","1179":"1179","1277":"1277","1233":"1233","1155":"1155","before 1230":"enne 1230","about 1233":"umbes 1233","about 1179":"umbes 1179","after 1242":"pärast 1242","Shobrooke, Crediton, Devon, England":"Shobrooke, Devon, England","England":"England","Mendlesham, Suffolk, England, United Kingdom":"Mendlesham, Suffolk, Inglismaa, United Kingdom","Cornwall, England":"Cornwall, England"},"fi":{"about 1179–after 1242":"noin 1179–1242 jälkeen","1179–1242":"1179–1242","1183–1233":"1183–1233","1215–1277":"1215–1277","1217–1277":"1217–1277","1225–1278":"1225–1278","1155–Male":"1155–Kuollut","1160–Female":"1160–Kuollut","Cir 1215":"1215","1242":"1242","Abt 1225":"noin 1225","1183":"1183","1160":"1160","1217":"1217","1215":"1215","1225":"1225","about 1217":"noin 1217","1224":"1224","1278":"1278","1179":"1179","1277":"1277","1233":"1233","1155":"1155","before 1230":"ennen vuotta 1230","about 1233":"noin 1233","about 1179":"noin 1179","after 1242":"1242 jälkeen","Shobrooke, Crediton, Devon, England":"Shobrooke, Devon, England","England":"England","Mendlesham, Suffolk, England, United Kingdom":"Mendlesham, Suffolk, Englanti, Yhdistynyt kuningaskunta","Cornwall, England":"Cornwall, England"},"fr":{"about 1179–after 1242":"environ 1179–après 12