ngland":"Sherford, Devon, England","Lelant, Cornwall, England":"Lelant, Cornwall, England","Kenedon Manor, Sherford, Devon, England":"Sherford, Devon, England","Plymouth, Devon, England":"Plymouth, Devon, England"},"en":{"about 1323–Aft 1405":"about 1323–after 1405","1321–Male":"1321–Deceased","1323–1405":"1323–1405","1327–1417":"1327–1417","1349–1417":"1349–1417","1351–1417":"1351–1417","1297–1370":"1297–1370","1315–1373":"1315–1373","1297":"1297","1373":"1373","1351":"1351","1382":"1382","1370":"1370","Aft 1405":"after 1405","1349":"1349","1327":"1327","1348":"1348","1337":"1337","1315":"1315","about 1349":"about 1349","1323":"1323","1453":"1453","1321":"1321","about 1323":"about 1323","1417":"1417","about 1351":"about 1351","1328":"1328","1405":"1405","Sherford, Devon, England":"Sherford, Devon, England","Lelant, Cornwall, England":"Lelant, Cornwall, England","Kenedon Manor, Sherford, Devon, England":"Sherford, Devon, England","Plymouth, Devon, England":"Plymouth, Devon, England","nameMeanings":[{"name":"Hals","type":"LAST","attribution":"Dictionary of American Family Names © Patrick Hanks 2003, 2006.","meanings":["English: variant of   Hall  , with plural or post-medieval excrescent <i>-s</i>."],"variants":[{"name":"Hall","meanings":["English, Scottish, Irish, German, Norwegian, and Danish: from Middle English <i>hall</i> (Old English <i>heall</i>), Middle High German <i>halle</i>, Old Norse <i>hǫll</i> all meaning ‘hall’ (a spacious residence), hence a topographic name for someone who lived in or near a hall or an occupational name for a servant employed at a hall. In some cases it may be a habitational name from any of the places called with this word, which in some parts of Germany and Austria in the Middle Ages also denoted a salt mine. Hall is one of the commonest and most widely distributed of English surnames, bearing witness to the importance of the hall as a feature of the medieval village. The English surname has been established in Ireland since the 14th century, and, according to MacLysaght, has become numerous in Ulster since the 17th century.","Swedish: ornamental or topographic name from <i>hall</i> ‘hall’ (a spacious residence), or a habitational name from a placename containing the element <i>hall</i> ‘rock’ (from Old Norse <i>hallr</i>).","Chinese: variant Romanization of the surnames 何 and 賀, see   He   1 and 2."]},{"name":"Alls","meanings":["English: variant of   Halls   with loss of initial <i>H-</i>."]}]},{"name":"David","type":"FIRST","attribution":"Dictionary of First Names © Patrick Hanks and Flavia Hodges 1990, 2003, 2006.","meanings":["Biblical name, borne by the greatest of all the kings of Israel, whose history is recounted with great vividness in the first and second books of Samuel and elsewhere. As a boy he killed the giant Philistine Goliath with his slingshot. As king of Judah, and later of all Israel, he expanded the power of the Israelites and established the security of their kingdom. He was also noted as a poet, many of the Psalms being attributed to him. The Hebrew derivation of the name is uncertain; it is said by some to represent a nursery word meaning ‘darling’. It is a very popular Jewish name, but is almost equally common among Gentiles in the English-speaking world. It is particularly common in Wales and Scotland, having been borne by the patron saint of Wales (  see  Dewi   ) and by two medieval kings of Scotland."],"variants":[]}],"historicEvents":[{"id":1705192,"age":5,"year":"1328","julianDay":2206102,"title":"First War of Scottish Independence","description":"The First War of Scottish Independence began after England invaded Scotland in 1296. The Treaty of Edinburgh was signed in 1328 which declared peace between the two kingdoms and brought the war to an end.","jurisdictionLevel":2},{"id":1705193,"age":14,"year":"1337","toYear":"1453","julianDay":2209390,"title":"The Hundred Years' War","description":"The Hundred Years' War between France and England was largely due to the question of legitimate succession to the French crown.","jurisdictionLevel":2},{"id":1705195,"age":59,"year":"1382","julianDay":2225826,"title":"Wycliffe's Bible","description":"John Wycliffe, English theologian and professor at the University of Oxford, completed a translation of the Bible from the Latin Vulgate into Middle English. This translation is known as Wycliffe's Bible and was completed around 1382.","url":"https://en.wikipedia.org/wiki/Wycliffe%27s_Bible","urlTitle":"Wikipedia - Wycliffe's Bible","jurisdictionLevel":2}],"lifeSummary":"When David Hals was born about 1323, in Plymouth, Devon, England, his father, Richard Hals, was 27 and his mother, Margaret de Esse, was 10. He married Mathilda Bevill in 1348, in Sherford, Devon, England. They were the parents of at least 2 sons. He died after 1405, in Lelant, Cornwall, England."},"et":{"about 1323–Aft 1405":"umbes 1323–pärast 1405","1321–Male":"1321–Surnud","1323–1405":"1323–1405","1327–1417":"1327–1417","1349–1417":"1349–1417","1351–1417":"1351–1417","1297–1370":"1297–1370","1315–1373":"1315–1373","1297":"1297","1373":"1373","1351":"1351","1382":"1382","1370":"1370","Aft 1405":"pärast 1405","1349":"1349","1327":"1327","1348":"1348","1337":"1337","1315":"1315","about 1349":"umbes 1349","1323":"1323","1453":"1453","1321":"1321","about 1323":"umbes 1323","1417":"1417","about 1351":"umbes 1351","1328":"1328","1405":"1405","Sherford, Devon, England":"Sherford, Devon, England","Lelant, Cornwall, England":"Lelant, Cornwall, England","Kenedon Manor, Sherford, Devon, England":"Sherford, Devon, England","Plymouth, Devon, England":"Plymouth, Devon, England"},"fi":{"about 1323–Aft 1405":"noin 1323–1405 jälkeen","1321–Male":"1321–Kuollut","1323–1405":"1323–1405","1327–1417":"1327–1417","1349–1417":"1349–1417","1351–1417":"1351–1417","1297–1370":"1297–1370","1315–1373":"1315–1373","1297":"1297","1373":"1373","1351":"1351","1382":"1382","1370":"1370","Aft 1405":"1405 jälkeen","1349":"1349","1327":"1327","1348":"1348",