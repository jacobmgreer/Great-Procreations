land":"Rufford, Lancashire, Engeland, Verenigd Koninkrijk","Lancashire, England":"Lancashire, England"},"en":{"1320–1378":"1320–1378","–Female":"Deceased","1336–1379":"1336–1379","1360–Male":"1360–Deceased","1374–1441":"1374–1441","–Male":"Deceased","1276–1334":"1276–1334","1283–1354":"1283–1354","1336":"1336","1379":"1379","1334":"1334","1378":"1378","1354":"1354","from about 1250 to 1650":"from about 1250 to 1650","1320":"1320","1276":"1276","1441":"1441","1374":"1374","1360":"1360","1283":"1283","Gawsworth, Cheshire, England, United Kingdom":"Gawsworth, Cheshire, England, United Kingdom","Barton-Upon-Irwell, Lancashire, England":"Barton upon Irwell, Lancashire, England","Gawsworth, Cheshire, England":"Gawsworth, Cheshire, England","Rufford, Lancashire, England":"Rufford, Lancashire, England, United Kingdom","Lancashire, England":"Lancashire, England","nameMeanings":[{"name":"Hesketh","type":"LAST","attribution":"Dictionary of American Family Names © Patrick Hanks 2003, 2006.","meanings":["English (Lancashire and Cheshire): habitational name from Hesketh (Lancashire), Hesketh Grange in Felixkirk (North Yorkshire), or Hesket in the Forest (Cumberland). The placenames derive from Old Norse <i>hestr</i> ‘horse, stallion’ + <i>skeith</i> ‘course, track, race course’. The ancient Scandinavians were fond of horse-racing and horse-fighting, and introduced both pastimes to England."],"variants":[{"name":"Heskett","meanings":["English (Cumberland and Lancashire): variant of   Hesketh  ."]}]},{"name":"William","type":"FIRST","attribution":"Dictionary of First Names © Patrick Hanks and Flavia Hodges 1990, 2003, 2006.","meanings":["Probably the most successful of all the Old French names of Germanic origin that were introduced to England by the Normans. It is derived from Germanic <i>wil</i> ‘will, desire’ + <i>helm</i> ‘helmet, protection’. The fact that it was borne by the Conqueror himself does not seem to have inhibited its favour with the ‘conquered’ population: in the first century after the Conquest it was the commonest male name of all, and not only among the Normans. In the later Middle Ages it was overtaken by   John  , but continued to run second to that name until the 20th century, when the picture became more fragmented."],"variants":[]}],"lifeSummary":"When Lord William Hesketh was born in 1320, in Gawsworth, Cheshire, England, United Kingdom, his father, Lord John Hesketh of Rufford, was 45 and his mother, Alice de Radcliffe, was 38. He had at least 2 sons and 1 daughter with Marcella De Thweng. He died in 1378, in his hometown, at the age of 58."},"et":{"1320–1378":"1320–1378","–Female":"Surnud","1336–1379":"1336–1379","1360–Male":"1360–Surnud","1374–1441":"1374–1441","–Male":"Surnud","1276–1334":"1276–1334","1283–1354":"1283–1354","1336":"1336","1379":"1379","1334":"1334","1378":"1378","1354":"1354","from about 1250 to 1650":"from about 1250 to 1650","1320":"1320","1276":"1276","1441":"1441","1374":"1374","1360":"1360","1283":"1283","Gawsworth, Cheshire, England, United Kingdom":"Gawsworth, Cheshire, Inglismaa, United Kingdom","Barton-Upon-Irwell, Lancashire, England":"Barton upon Irwell, Lancashire, England","Gawsworth, Cheshire, England":"Gawsworth, Cheshire, England","Rufford, Lancashire, England":"Rufford, Lancashire, Inglismaa, United Kingdom","Lancashire, England":"Lancashire, England"},"fi":{"1320–1378":"1320–1378","–Female":"Kuollut","1336–1379":"1336–1379","1360–Male":"1360–Kuollut","1374–1441":"1374–1441","–Male":"Kuollut","1276–1334":"1276–1334","1283–1354":"1283–1354","1336":"1336","1379":"1379","1334":"1334","1378":"1378","1354":"1354","from about 1250 to 1650":"vuodesta noin 1250 vuoteen 1650","1320":"1320","1276":"1276","1441":"1441","1374":"1374","1360":"1360","1283":"1283","Gawsworth, Cheshire, England, United Kingdom":"Gawsworth, Cheshire, Englanti, Yhdistynyt kuningaskunta","Barton-Upon-Irwell, Lancashire, England":"Barton upon Irwell, Lancashire, England","Gawsworth, Cheshire, England":"Gawsworth, Ch