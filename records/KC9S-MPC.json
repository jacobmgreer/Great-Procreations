15-2697-35/dist.pdf?ctx=ArtCtxPublic","memoryUrl":"https://www.familysearch.org/photos/artifacts/123303331","thumbnailUrl":"https://sg30p0.familysearch.org/service/records/storage/dascloud/patron/v2/TH-7708-106215-2697-35/thumb200s.jpg?ctx=ArtCtxPublic","headline":"Renaud, Giselbert I and Ebles de Roucy, Comtes de Roucy, in the Foundation for Medieval Genealogy","description":"Renaud, Giselbert I and Ebles de Roucy, Comtes de Roucy, in the Foundation for Medieval Genealogy\n~http://shop.fmg.ac/Projects/MedLands/nfralaoncou.htm#GiselbertRoucydied9911000A","@type":"ImageObject"},{"memoryType":"PHOTO","url":"https://sg30p0.familysearch.org/service/records/storage/dascloud/patron/v2/TH-7708-106339-641-25/dist.jpg?ctx=ArtCtxPublic","memoryUrl":"https://www.familysearch.org/photos/artifacts/123624187","thumbnailUrl":"https://sg30p0.familysearch.org/service/records/storage/dascloud/patron/v2/TH-7708-106339-641-25/thumb200s.jpg?ctx=ArtCtxPublic","deepZoomUrl":"https://sg30p0.familysearch.org/service/records/storage/deepzoomcloud/dzpatron/v1/TH-7708-106339-641-25/scale?ctx=ArtCtxPublic","@type":"ImageObject"},{"memoryType":"PHOTO","url":"https://sg30p0.familysearch.org/service/records/storage/dascloud/patron/v2/TH-7713-120576-1655-32/dist.png?ctx=ArtCtxPublic","memoryUrl":"https://www.familysearch.org/photos/artifacts/160860379","thumbnailUrl":"https://sg30p0.familysearch.org/service/records/storage/dascloud/patron/v2/TH-7713-120576-1655-32/thumb200s.jpg?ctx=ArtCtxPublic","deepZoomUrl":"https://sg30p0.familysearch.org/service/records/storage/deepzoomcloud/dzpatron/v1/TH-7713-120576-1655-32/scale?ctx=ArtCtxPublic","@type":"ImageObject"},{"memoryType":"PHOTO","url":"https://sg30p0.familysearch.org/service/records/storage/dascloud/patron/v2/TH-7714-123844-179-49/dist.png?ctx=ArtCtxPublic","memoryUrl":"https://www.familysearch.org/photos/artifacts/164766651","thumbnailUrl":"https://sg30p0.familysearch.org/service/records/storage/dascloud/patron/v2/TH-7714-123844-179-49/thumb200s.jpg?ctx=ArtCtxPublic","deepZoomUrl":"https://sg30p0.familysearch.org/service/records/storage/deepzoomcloud/dzpatron/v1/TH-7714-123844-179-49/scale?ctx=ArtCtxPublic","@type":"ImageObject"}],"popularStory":{"memoryType":"STORY","url":"https://sg30p0.familysearch.org/service/records/storage/dascloud/patron/v2/TH-904-64565-1031-79/dist.txt?ctx=ArtCtxPublic","memoryUrl":"https://www.familysearch.org/photos/artifacts/26563141","headline":"William David Jackson Thrash ","description":"orth Carolina, USA\n\nWilliam David Jackson Thrash married Elizabeth Green August 18, 1847 in Clarke County, Alabama. Jackson served with Co. C 40th Alabama Infantry during the civil war. He died of wou …","@type":"MediaObject"},"birthDate":"+1010-06-22","birthPlace":{"address":"Montdidier, Somme, Picardie, France","geo":{"latitude":49.6461,"longitude":2.5675,"@type":"GeoCoordinates"},"@type":"Place"},"christeningPlace":{"address":"Roucy, Aisne, Picardie, France","geo":{"latitude":49.3728,"longitude":3.8158,"@type":"GeoCoordinates"},"@type":"Place"},"deathDate":"+1063-11-15","deathPlace":{"address":"Ramerupt, Aube, Champagne-Ardennnes, France","geo":{"latitude":48.5198,"longitude":4.2907,"@type":"GeoCoordinates"},"@type":"Place"},"userCertifiedLifeSummary":"Hilduin IV (d. 1063), Count of Mondidier and Seigneur de Ramerupt, son of Hilduin III, Count of Montdidier, member of the House of Montdidier. Hilduin was also Count of Roucy by virtue of his marriage to the daughter of Ebles I, Count of Roucy.\n\nLittle is known about Hilduin despite his many renown children and grandchildren. Hermann Monacii of Laon records that Philip I of France appointed Hilduin as an ambassador to Rome (date unknown).\n\nHildiun married Adelaide (Alice) de Roucy, daughter of Ebles I, Count of Roucy, and Beatrix of Hainaut. They had nine children:\n\n1.) Ebles II, Count of Roucy, married Sibylle de Apulia, daughter of Robert Guiscard, Duke of Apulia and Sichelgaita de Salerno\n\n2.) Andre (d. after 1118), Seigneur de Ramerupt and of Arcis-sur-Aube, married Guisemode, widow of Hugh, Siegneur of Pleurs. Their son Eble de Roucy was Bishop of Châlons (1122-1127) and daughter Alix married Erard I, Count of Brienne.\n\n3.) Beatrix de Ramerupt (d. after 1129), married Geoffrey II, Count of Perche\n\n4.) Marguerite de Ramerupt, married Hugh, Count of Clermont-en-Beauvaisis\n\n5.) Ermentrude de Ramerupt (d. after 1102), married Thibaut, Count of Reynel, son of Olri, Count of Reynel.\n\n6.) Ada de Ramerupt (d. after 1121), married first Geoffroy, Seigneur de Guise, and second Gauthier, Seigneur de Ath\n\n7.) Adélaïs, married Arnold I, Count of Chiny\n\n8.) Aelis de Ramerupt, married Conan \"Falcon\" de la Sarraz. Their son was Barthélemy de Jur, Bishop of Laon.\n\n9.) Felicia of Roucy, married Sancho I, King of Aragon.\n\nHilduin was apparently the last Count of Montdidier, the line being continued with the Counts of Roucy.","sourceList":[{"title":"Wikipedia (F) - Hilduin IV de Montdidier","sourceType":"DEFAULT","sourceLink":"https://fr.m.wikipedia.org/wiki/Hilduin_IV_de_Montdidier","sourceUri":"Q8R9-9VD"},{"title":"Genealogical Families of Montdidiet","sourceType":"DEFAULT","sourceLink":"http://racineshistoire.free.fr/LGN/PDF/Montdidier-Dammartin-Ramerupt.pdf","sourceUri":"Q91V-PFM"},{"title":"Hilduin III Conte de Montdidier - Wikipedia","sourceType":"DEFAULT","sourceLink":"https://en.wikipedia.org/wiki/Hilduin_III,_Count_of_Montdidier","sourceUri":"3FN9-1YP"}],"events":[{"name":"Birth","sources":"2","year":"1010","date":"22 June 1010","place":"Montdidier, Somme, Picardie, France"},{"name":"Christening","sources":"0","place":"Roucy, Aisne, Picardie, France"},{"name":"Title of Nobility","sources":"0","year":"1033","date":"1033-1063","type":"USER_DEFINED","age":"53"},{"name":"Death of Parent","sources":"0","year":"1037","date":"about 1037","place":"Ramerupt, Aube, Champagne-Ardenne, France","age":"27","id":"G23C-HT1"},{"name":"Death of Parent","sources":"0","year":"1058","date":"1058","ag