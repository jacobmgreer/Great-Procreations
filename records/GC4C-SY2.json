2–1158":"1122–1158","1120–1180":"1120–1180","about 1140":"circa 1140","before 1179":"vóór 1179","about 1180":"circa 1180","1120":"1120","1140":"1140","1150":"1150","1181":"1181","1191":"1191","1180":"1180","1158":"1158","1235":"1235","1145":"1145","1122":"1122","before 1140":"vóór 1140","after 1158":"na 1158","Ardlamont, Argyll, Scotland":"Argyll, Schotland","Iverchaolain, Argyll, Scotland":"Argyll, Schotland","Barra, Inverness-shire, Scotland":"Barra, Inverness-shire, Schotland","Scotland":"Schotland","Argyll, Scotland":"Argyll, Schotland","Glassary, Argyll, Scotland, United Kingdom":"Glassary, Argyll, Schotland, Verenigd Koninkrijk"},"en":{"about 1140–1191":"about 1140–1191","1140–1191":"1140–1191","1145–Male":"1145–Deceased","1150–Female":"1150–Deceased","1181–1235":"1181–1235","–1235":"–1235","–Male":"Deceased","1122–1158":"1122–1158","1120–1180":"1120–1180","about 1140":"about 1140","before 1179":"before 1179","about 1180":"about 1180","1120":"1120","1140":"1140","1150":"1150","1181":"1181","1191":"1191","1180":"1180","1158":"1158","1235":"1235","1145":"1145","1122":"1122","before 1140":"before 1140","after 1158":"after 1158","Ardlamont, Argyll, Scotland":"Argyll, Scotland","Iverchaolain, Argyll, Scotland":"Argyll, Scotland","Barra, Inverness-shire, Scotland":"Barra, Inverness-shire, Scotland","Scotland":"Scotland","Argyll, Scotland":"Argyll, Scotland","Glassary, Argyll, Scotland, United Kingdom":"Glassary, Argyll, Scotland, United Kingdom","nameMeanings":[{"name":"MacNeil","type":"LAST","attribution":"Dictionary of American Family Names © Patrick Hanks 2003, 2006.","meanings":["Irish and Scottish:  see  McNeil  ."],"variants":[{"name":"McNeil","meanings":["Scottish and Irish: Anglicized form of Gaelic <b>Mac Néill</b>, a patronymic from the personal name <i>Niall</i> (genitive <i>Néill</i>), see   Neil   and also <i>Neilson</i>, which was sometimes substituted for <i>McNeil</i> in Lowland Scotland.","History: The Scottish Clan McNeil claims descent from the early Irish king Niall of the Nine Hostages (see   O'Neill  ), and the name is associated in particular with the island of Barra in the Hebrides, having been brought there from Ireland in 1049. Some members of this clan later migrated to Antrim and Derry in Ireland. A different Scottish Clan MacNeill (spelled with two l's) has a traditional ancestral home on the island of Gigha."]}]},{"name":"Ferchar","type":"FIRST","attribution":"Dictionary of First Names © Patrick Hanks and Flavia Hodges 1990, 2003, 2006.","meanings":["Traditional: from Gaelic <i>fear</i> ‘man’ + <i>char</i> ‘dear, loving’."],"variants":[]},{"name":"mic’","type":"LAST","attribution":"Dictionary of American Family Names © Patrick Hanks 2003, 2006.","meanings":["North German and Dutch: metonymic occupational name from Middle Low German and Middle Dutch <i>micke</i> ‘(wheat or rye) bread’. In North America, this surname is also an altered form of the Dutch variant <b>Mik</b>, which is the only variant found in the Netherlands today.","North German: nickname related to Middle Low German <i>micke</i> ‘forked stick’.","Germanized form of Sorbian and Polish <b>Mik</b>: from an Upper Sorbian and Polish short form of the personal name <i>Mikławš</i> (Sorbian), <i>Mikołaj</i> (Polish), equivalents of   Nicholas  ."],"variants":[{"name":"Nicholas","meanings":["form of the post-classical Greek personal name <i>Nikolaos</i>, derived from <i>nikē</i> ‘victory’ + <i>laos</i> ‘people’. The spelling with <i>-ch-</i> first occurred as early as the 12th century, and became firmly established at the time of the Reformation, although  <b>Nicolas</b>  is still occasionally found.  St Nicholas  was a 4th-century bishop of Myra in Lycia, about whom virtually nothing factual is known, although a vast body of legend grew up around him, and he became the patron saint of Greece and of Russia, as well as of children, sailors, merchants, and pawnbrokers. His feast day is  6 December , and among the many roles which legend has assigned to him is that of bringer of Christmas presents, in the guise of ‘Santa Claus’ (an alteration of the Dutch form of his name, <i>Sinterklaas</i>)."]},{"name":"Micke","meanings":["Pet form of   Michael  , now occasionally used independently."]}]}],"lifeSummary":"When Ferchar ‘Fearchair mic’ MacNeil was born about 1140, in Barra, Inverness-shire, Scotland, his father, Duinsleibhe O'Neill Lord of Knapdale, was 19 and his mother, Ingen MacGillebride of Lamont, was 22. He married Katherine Somerled before 1179, in Scotland. They were the parents of at least 4 sons. He died in 1191, in Argyll, Scotland, at the age of 52, and was buried in Argyll, Scotland."},"et":{"about 1140–1191":"umbes 1140–1191","1140–1191":"1140–1191","1145–Male":"1145–Surnud","1150–Female":"1150–Surnud","1181–1235":"1181–1235","–1235":"–1235","–Male":"Surnud","1122–1158":"1122–1158","1120–1180":"1120–1180","about 1140":"umbes 1140","before 1179":"enne 1179","about 1180":"umbes 1180","1120":"1120","1140":"1140","1150":"1150","1181":"1181","1191":"1191","1180":"1180","1158":"1158","1235":"1235","1145":"1145","1122":"1122","before 1140":"enne 1140","after 1158":"pärast 1158","Ardlamont, Argyll, Scotland":"Argyll, Scotland","Iverchaolain, Argyll, Scotland":"Argyll, Scotland","Barra, Inverness-shire, Scotland":"Barra, Inverness-shire, Scotland","Scotland":"Scotland","Argyll, Scotland":"Argyll, Scotland","Glassary, Argyll, Scotland, United Kingdom":"Glassary, Argyll, Šotimaa, United Kingdom"},"fi":{"about 1140–1191":"noin 1140–1191","1140–1191":"1140–1191","1145–Male":"1145–Kuollut","1150–Female":"1150–Kuollut","1181–1235":"1181–1235","–1235":"–1235","–Male":"Kuollut","1122–1158":"1122–1158","1120–1180":"1120–1180","about 1140":"noin 1140","before 1179":"ennen vuotta 1179","about 1180":"noin 1180","1120":"1120","1140":"1140","1150":"1150","1181":"1181","1191":"1191","1180":"1180","1158":"1158","1235":"1235","1145":"1145","1122":"1122","before 1140":"ennen vuotta 1140","after 1158":"1158 jälkeen","Ar