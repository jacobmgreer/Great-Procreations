hshire, Scotland":"Springwood House, Roxburghshire, Scotland","Rouen, Normandie, France":"Archidiocèse de Rouen, Francie"},"da":{"1090–1150":"1090–1150","1120–1180":"1120–1180","1140–1206":"1140–1206","1141–1221":"1141–1221","1142–Male":"1142–Afdød","1144–Male":"1144–Afdød","1070–1090":"1070–1090","1055–1090":"1055–1090","1090":"1090","1055":"1055","1142":"1142","1120":"1120","1141":"1141","1140":"1140","1150":"1150","1070":"1070","1180":"1180","1206":"1206","before 1090":"før 1090","1144":"1144","1221":"1221","Atholl, Perthshire, Scotland":"Atholl, Perthshire, Skotland","Perthshire, Scotland":"Perthshire, Skotland","France":"Frankrig","Springwood House, Roxburghshire, Scotland":"Springwood House, Roxburghshire, Skotland","Rouen, Normandie, France":"Archidiocèse de Rouen, Frankrig"},"nl":{"1090–1150":"1090–1150","1120–1180":"1120–1180","1140–1206":"1140–1206","1141–1221":"1141–1221","1142–Male":"1142–Overleden","1144–Male":"1144–Overleden","1070–1090":"1070–1090","1055–1090":"1055–1090","1090":"1090","1055":"1055","1142":"1142","1120":"1120","1141":"1141","1140":"1140","1150":"1150","1070":"1070","1180":"1180","1206":"1206","before 1090":"vóór 1090","1144":"1144","1221":"1221","Atholl, Perthshire, Scotland":"Atholl, Perthshire, Schotland","Perthshire, Scotland":"Perthshire, Schotland","France":"Frankrijk","Springwood House, Roxburghshire, Scotland":"Springwood House, Roxburghshire, Schotland","Rouen, Normandie, France":"Archidiocèse de Rouen, Frankrijk"},"en":{"1090–1150":"1090–1150","1120–1180":"1120–1180","1140–1206":"1140–1206","1141–1221":"1141–1221","1142–Male":"1142–Deceased","1144–Male":"1144–Deceased","1070–1090":"1070–1090","1055–1090":"1055–1090","1090":"1090","1055":"1055","1142":"1142","1120":"1120","1141":"1141","1140":"1140","1150":"1150","1070":"1070","1180":"1180","1206":"1206","before 1090":"before 1090","1144":"1144","1221":"1221","Atholl, Perthshire, Scotland":"Atholl, Perthshire, Scotland","Perthshire, Scotland":"Perthshire, Scotland","France":"France","Springwood House, Roxburghshire, Scotland":"Springwood House, Roxburghshire, Scotland","Rouen, Normandie, France":"Archdiocese of Rouen, France","nameMeanings":[{"name":"Maccus","type":"FIRST","attribution":"Dictionary of First Names © Patrick Hanks and Flavia Hodges 1990, 2003, 2006.","meanings":["The original Latin form of   Mark  , of unknown derivation; it may possibly be connected with <i>Mars</i>, the name of the Roman god of war, or the adjective <i>mas</i> ‘male, virile’ (genitive <i>maris</i>). This was one of the very small number of Roman given names of the classical period. There were only about a dozen of these in general use, with perhaps another dozen confined to particular families. <i>Marcus</i> has been in use in the English-speaking world since the 16th century if not earlier; in the 20th century it enjoyed a considerable increase in popularity. As an African-American name it is sometimes bestowed in honour of the Black Consciousness leader  Marcus Garvey  (  1887–1940 )."],"variants":[]}],"lifeSummary":"When Maccus was born in 1090, in Springwood House, Roxburghshire, Scotland, his father, Undwin, was 21 and his mother, Platitudinous Lady de Norseman, was 35. He had at least 5 sons. He died in 1150, in France, at the age of 60, and was buried in Archdiocese of Rouen, France."},"et":{"1090–1150":"1090–1150","1120–1180":"1120–1180","1140–1206":"1140–1206","1141–1221":"1141–1221","1142–Male":"1142–Surnud","1144–Male":"1144–Surnud","1070–1090":"1070–1090","1055–1090":"1055–1090","1090":"1090","1055":"1055","1142":"1142","1120":"1120","1141":"1141","1140":"1140","1150":"1150","1070":"1070","1180":"1180","1206":"1206","before 1090":"enne 1090","1144":"1144","1221":"1221","Atholl, Perthshire, Scotland":"Atholl, Perthshire, Scotland","Perthshire, Scotland":"Perthshire, Scotland","France":"Prantsusmaa","Springwood House, Roxburghshire, Scotland":"Springwood House, Roxburghshire, Scotland","Rouen, Normandie, France":"Archidiocèse de Rouen, Prantsus