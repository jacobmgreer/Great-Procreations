and":"Birmingham, Warwickshire, Engeland, Verenigd Koninkrijk","Fulwood, Warwickshire, England":"Warwickshire, Engeland, Verenigd Koninkrijk"},"en":{"1364–1434":"1364–1434","1390–Male":"1390–Deceased","1355–1415":"1355–1415","1396–Male":"1396–Deceased","1399–Female":"1399–Deceased","1342–Male":"1342–Deceased","1342–Female":"1342–Deceased","1415":"1415","1434":"1434","1399":"1399","1355":"1355","1364":"1364","Abt 1396":"about 1396","1342":"1342","1396":"1396","1395":"1395","1382":"1382","1390":"1390","Tamworth, Staffordshire, England":"Tamworth, Staffordshire, England","Warwick Castle, Warwick, Warwickshire, England":"Warwick Castle, Warwick, Warwickshire, England","London, Middlesex, England":"London, Middlesex, England","Tamworth Castle,Tamworth, Staffordshire, England":"Tamworth, Staffordshire, England","Clay Hall, Tanworth, Warwickshire, England":"Warwickshire, England","Fullwood, Birmingham, Warwickshire, England":"Birmingham, Warwickshire, England, United Kingdom","Fulwood, Warwickshire, England":"Warwickshire, England, United Kingdom","nameMeanings":[{"name":"Joan","type":"FIRST","attribution":"Dictionary of First Names © Patrick Hanks and Flavia Hodges 1990, 2003, 2006.","meanings":["Contracted form of Old French <i>Jo(h)anne</i>, from Latin <i>Io(h)anna</i> (  see  Joanna  ). In England this was the usual feminine form of   John   from the Middle English period onwards and was extremely popular, but in the 16th and 17th centuries it steadily lost ground to   Jane .  It was strongly revived in the first part of the 20th century, partly under the influence of  George Bernard Shaw's  play St Joan (  1923 ), based on the life of  Joan of Arc  (  1412–31 ). Claiming to be guided by the voices of the saints, she persuaded the French dauphin to defy the occupying English forces and have himself crowned, and she led the French army that raised the siege of Orleans in  1429 . The following year she was captured by the Burgundians and sold to the English, and a year later she was burned at the stake for witchcraft at the age of 18 or 19. Her story has captured the imagination of many writers, and she is variously portrayed as a national and political hero, a model of apolitical straightforwardness and honesty, and a religious heroine. She was canonized in  1920 . More recent influences have included the American film actress  Joan Crawford  (  1908–77 , born  Lucille le Sueur ), the British actress  Joan Collins  (  b. 1933 ), the American comedienne  Joan Rivers  (  b. 1933 ), and the West Indian pop singer  Joan Armatrading  (  b. 1950 )."],"variants":[{"name":"John","meanings":["New Testament: ‘God is gracious’.  See  <b>John</b> ."]}]}],"historicEvents":[{"id":1705195,"age":18,"year":"1382","julianDay":2225826,"title":"Wycliffe's Bible","description":"John Wycliffe, English theologian and professor at the University of Oxford, completed a translation of the Bible from the Latin Vulgate into Middle English. This translation is known as Wycliffe's Bible and was completed around 1382.","url":"https://en.wikipedia.org/wiki/Wycliffe%27s_Bible","urlTitle":"Wikipedia - Wycliffe's Bible","jurisdictionLevel":3}],"lifeSummary":"When Lady Joan Sidenhall Baroness was born in 1364, in Tamworth, Staffordshire, England, her father, Robert Sidenhall, was 22 and her mother, Mrs Robert Sidenhall, was 23. She married William de Fulwood Baron of Clay Hall in 1395, in Birmingham, Warwickshire, England, United Kingdom. They were the parents of at least 1 son and 1 daughter. She died in 1434, in Warwick Castle, Warwick, Warwickshire, England, at the age of 70."},"et":{"1364–1434":"1364–1434","1390–Male":"1390–Surnud","1355–1415":"1355–1415","1396–Male":"1396–Surnud","1399–Female":"1399–Surnud","1342–Male":"1342–Surnud","1342–Female":"1342–Surnud","1415":"1415","1434":"1434","1399":"1399","1355":"1355","1364":"1364","Abt 1396":"umbes 1396","1342":"1342","1396":"1396","1395":"1395","1382":"1382","1390":"1390","Tamworth, Staffordshire, England":"Tamw