1","1005":"1005","0940":"0940","0995":"0995","961":"0961","0992":"0992","10 JAN 987":"10 January 0987","1036":"1036","0928":"0928","0989":"0989","0987":"0987","1009":"1009","Venezia, Venezia, Veneto, Olaszország":"Venice, Venice, Veneto, Italy","Venice, Veneto, Italy":"Venice, Veneto, Italy","Venezia,Venezia,Italy":"Venice, Venice, Veneto, Italy","abbey of Saint-Michel-de-Cuxa, Codalet, Occitanie France":"Codalet, Pyrénées-Orientales, Occitanie, France","nameMeanings":[{"name":"Pietro","type":"FIRST","attribution":"Dictionary of First Names © Patrick Hanks and Flavia Hodges 1990, 2003, 2006.","meanings":["From Greek.  See  <b>Peter</b>   ."],"variants":[{"name":"Piero","meanings":["form of the name of the best-known of all Christ's apostles, traditionally regarded as the founder of the Christian Church. The name derives, via Latin, from Greek <i>petros</i> ‘stone, rock’. This is used as a translation of the Aramaic byname <i>Cephas</i>, given to the apostle  Simon  son of Jona, to distinguish him from another of the same name (  Simon Zelotes ). ‘When Jesus beheld him, he said, Thou art Simon the son of Jona: thou shalt be called Cephas, which is by interpretation, A stone’ (John 1:42). According to Matthew 16:17–18, Christ says more explicitly, ‘Blessed art thou, Simon Bar-jona … thou art Peter, and upon this rock I will build my church’. The name has been in continuous use since the Middle Ages."]},{"name":"Peter","meanings":["form of the name of the best-known of all Christ's apostles, traditionally regarded as the founder of the Christian Church. The name derives, via Latin, from Greek <i>petros</i> ‘stone, rock’. This is used as a translation of the Aramaic byname <i>Cephas</i>, given to the apostle  Simon  son of Jona, to distinguish him from another of the same name (  Simon Zelotes ). ‘When Jesus beheld him, he said, Thou art Simon the son of Jona: thou shalt be called Cephas, which is by interpretation, A stone’ (John 1:42). According to Matthew 16:17–18, Christ says more explicitly, ‘Blessed art thou, Simon Bar-jona … thou art Peter, and upon this rock I will build my church’. The name has been in continuous use since the Middle Ages."]}]},{"name":"II","type":"FIRST","attribution":"Dictionary of First Names © Patrick Hanks and Flavia Hodges 1990, 2003, 2006.","meanings":["1  ♂ ‘Wondrous’ or ‘enlightenment’.","2  ♀ ‘Fine jade’."],"variants":[]}],"lifeSummary":"When Pietro II Orseolo was born in 0961, in Venice, Veneto, Italy, his father, Peter 23th doge of Venice, was 33 and his mother, Felicita Malipiero Badoer, was 21. He had at least 4 sons and 1 daughter with Maria Candiano. He died in 1009, in his hometown, at the age of 48, and was buried in Venice, Veneto, Italy."},"et":{"961–1009":"0961–1009","0961–1009":"0961–1009","–Female":"Surnud","0983–1005":"0983–1005","0989–1036":"0989–1036","0992–1032":"0992–1032","0995–Male":"0995–Surnud","0928–0987":"0928–0987","0940–Female":"0940–Surnud","Abt 0995":"umbes 0995","1032":"1032","Abt 0983":"umbes 0983","991":"0991","992":"0992","0983":"0983","0961":"0961","1005":"1005","0940":"0940","0995":"0995","961":"0961","0992":"0992","10 JAN 987":"10. jaanuar 0987","1036":"1036","0928":"0928","0989":"0989","0987":"0987","1009":"1009","Venezia, Venezia, Veneto, Olaszország":"Venezia, Venezia, Veneto, Itaalia","Venice, Veneto, Italy":"Venezia, Veneto, Itaalia","Venezia,Venezia,Italy":"Venezia, Venezia, Veneto, Itaalia","abbey of Saint-Michel-de-Cuxa, Codalet, Occitanie France":"Codalet, Pyrénées-Orientales, Occitanie, Prantsusmaa"},"fi":{"961–1009":"0961–1009","0961–1009":"0961–1009","–Female":"Kuollut","0983–1005":"0983–1005","0989–1036":"0989–1036","0992–1032":"0992–1032","0995–Male":"0995–Kuollut","0928–0987":"0928–0987","0940–Female":"0940–Kuollut","Abt 0995":"noin 0995","1032":"1032","Abt 0983":"noin 0983","991":"0991","992":"0992","0983":"0983","0961":"0961","1005":"1005","0940":"0940","0995":"0995","961":"0961","0992":"0992","10 JAN 987":"10. tammikuuta 0987","1036":"1036","0