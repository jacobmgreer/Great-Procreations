out 1309":"circa 1309","1315":"1315","1358":"1358","1336":"1336","Abt 1310":"circa 1310","1310":"1310","1353":"1353","1276":"1276","1309":"1309","Abt 1280":"circa 1280","about 1296":"circa 1296","1328":"1328","1317":"1317","Worcestershire, England":"Worcestershire, England","Stanford Wasseborne, Worcestershire, England":"Stanford on Teme, Worcestershire, Engeland, Verenigd Koninkrijk","Stanford on Teme, Worcestershire, England":"Stanford on Teme, Worcestershire, England"},"en":{"Abt 1280–":"about 1280–Deceased","1276–1353":"1276–1353","1309–1336":"1309–1336","1310–1358":"1310–1358","1280–Female":"1280–Deceased","1382":"1382","1280":"1280","1290":"1290","about 1309":"about 1309","1315":"1315","1358":"1358","1336":"1336","Abt 1310":"about 1310","1310":"1310","1353":"1353","1276":"1276","1309":"1309","Abt 1280":"about 1280","about 1296":"about 1296","1328":"1328","1317":"1317","Worcestershire, England":"Worcestershire, England","Stanford Wasseborne, Worcestershire, England":"Stanford on Teme, Worcestershire, England, United Kingdom","Stanford on Teme, Worcestershire, England":"Stanford on Teme, Worcestershire, England","nameMeanings":[{"name":"Margarett","type":"FIRST","attribution":"Dictionary of First Names © Patrick Hanks and Flavia Hodges 1990, 2003, 2006.","meanings":["from Greek.  See  <b>Margaret</b>   ."],"variants":[{"name":"Margaret","meanings":["An extremely common given name from the Middle Ages onwards, derived via Old French <i>Marguerite</i> and Latin <i>Margarita</i> from Greek <i>Margarītēs</i>, from <i>margaron</i> ‘pearl’, a word ultimately of Hebrew origin. The name was always understood to mean ‘pearl’ throughout the Middle Ages. The first  St Margaret  was martyred at Antioch in Pisidia during the persecution instigated by the  Emperor Diocletian  in the early 4th century. However, there is some doubt about her name, as the same saint is venerated in the Orthodox Church as   Marina .  There were several other saintly bearers of the name, including St Margaret of Scotland (  d. 1093 ), wife of  King Malcolm Canmore  and daughter of Edmund Ironside of England. It was also the name of the wife of  Henry VI  of England,  Margaret of Anjou  (  1430–82 ), and of  Margaret Tudor  (  1489–1541 ), sister of  Henry VIII , who married James IV of Scotland and ruled as regent there after his death.  See also  Margery  ,   Marjorie ."]},{"name":"Margareta","meanings":["From the Latin form of Greek <i>Margarītēs</i>.  See  <b>Margaret</b>   ."]},{"name":"Margaretha","meanings":["from Greek.  See  <b>Margaret</b>   ."]},{"name":"Margarethe","meanings":["from Greek.  See  <b>Margaret</b>   ."]}]}],"historicEvents":[{"id":1705190,"age":10,"year":"1290","julianDay":2192224,"title":"Jews Expelled From England","description":"After years of anti-Semitic behavior, King Edward I expelled Jews from England in 1290.","jurisdictionLevel":1},{"id":1705191,"age":35,"year":"1315","toYear":"1317","julianDay":2201354,"title":"Famine Strikes Europe","description":"A famine caused by cold winters and wet summers across Europe caused millions to die due to starvation. Desperation from hunger caused high levels of crime, stampedes in bread lines in London, infanticide, and even cannibalism throughout Europe.","jurisdictionLevel":1},{"id":1705192,"age":48,"year":"1328","julianDay":2206102,"title":"First War of Scottish Independence","description":"The First War of Scottish Independence began after England invaded Scotland in 1296. The Treaty of Edinburgh was signed in 1328 which declared peace between the two kingdoms and brought the war to an end.","jurisdictionLevel":1},{"id":1705195,"age":102,"year":"1382","julianDay":2225826,"title":"Wycliffe's Bible","description":"John Wycliffe, English theologian and professor at the University of Oxford, completed a translation of the Bible from the Latin Vulgate into Middle English. This translation is known as Wycliffe's Bible and was completed around 1382.","url":"https://en.wikipedia.org/wiki/Wycliffe%27s_Bible","urlTitle":"Wikipedia - Wycliffe's Bible","jurisdictionLevel":1}],"lifeSummary":"Margarett was born about 1280. She married Roger de Wasseborne Coroner Lord of Washbourne and of Stanford about 1296, in Stanford on Teme, Worcestershire, England. They were the parents of at least 2 sons. She died in Worcestershire, England."},"et":{"Abt 1280–":"umbes 1280–Surnud","1276–1353":"1276–1353","1309–1336":"1309–1336","1310–1358":"1310–1358","1280–Female":"1280–Surnud","1382":"1382","1280":"1280","1290":"1290","about 1309":"umbes 1309","1315":"1315","1358":"1358","1336":"1336","Abt 1310":"umbes 1310","1310":"1310","1353":"1353","1276":"1276","1309":"1309","Abt 1280":"umbes 1280","about 1296":"umbes 1296","1328":"1328","1317":"1317","Worcestershire, England":"Worcestershire, England","Stanford Wasseborne, Worcestershire, England":"Stanford on Teme, Worcestershire, Inglismaa, United Kingdom","Stanford on Teme, Worcestershire, England":"Stanford on Teme, Worcestershire, England"},"fi":{"Abt 1280–":"noin 1280–Kuollut","1276–1353":"1276–1353","1309–1336":"1309–1336","1310–1358":"1310–1358","1280–Female":"1280–Kuollut","1382":"1382","1280":"1280","1290":"1290","about 1309":"noin 1309","1315":"1315","1358":"1358","1336":"1336","Abt 1310":"noin 1310","1310":"1310","1353":"1353","1276":"1276","1309":"1309","Abt 1280":"noin 1280","about 1296":"noin 1296","1328":"1328","1317":"1317","Worcestershire, England":"Worcestershire, England","Stanford Wasseborne, Worcestershire, England":"Stanford on Teme, Worcestershire, Englanti, Yhdistynyt kuningaskunta","Stanford on Teme, Worcestershire, England":"Stanford on Teme, Worcestershire, England"},"fr":{"Abt 1280–":"environ 1280–Décédée","1276–1353":"1276–1353","1309–1336":"1309–1336","1310–1358":"1310–1358","1280–Female":"1280–Décédée","1382":"1382","1280":"1280","1290":"1290","about 1309":"environ 1309","1315":"1315","1358":"1358","1336":"1336","Abt 1310":"environ 1310","1310":"1310","1353":"1353","1276":"1276","1309":"1309","Abt