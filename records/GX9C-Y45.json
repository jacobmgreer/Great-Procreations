,"1256":"1256","1134":"1134","1200":"1200","Worcestershire, England":"Worcestershire, England","Worcester, Worcestershire, England":"Worcester, Worcestershire, Engeland, Verenigd Koninkrijk","Elmley Castle, Worcestershire, England":"Elmley Castle, Worcestershire, Engeland, Verenigd Koninkrijk","Abergavenny, Monmouthshire, Wales":"Abergavenny, Monmouthshire, Wales","England":"England","Elmley, Worcestershire, England":"Worcestershire, Engeland, Verenigd Koninkrijk"},"en":{"1150–1235":"1150–1235","1151–1200":"1151–1200","1165–1212":"1165–1212","1180–1256":"1180–1256","1192–1236":"1192–1236","1130–1197":"1130–1197","1134–1192":"1134–1192","about 1192":"about 1192","1165":"1165","1197":"1197","1130":"1130","1151":"1151","1150":"1150","1192":"1192","1180":"1180","19 November 1200":"19 November 1200","1236":"1236","1235":"1235","1212":"1212","1256":"1256","1134":"1134","1200":"1200","Worcestershire, England":"Worcestershire, England","Worcester, Worcestershire, England":"Worcester, Worcestershire, England, United Kingdom","Elmley Castle, Worcestershire, England":"Elmley Castle, Worcestershire, England, United Kingdom","Abergavenny, Monmouthshire, Wales":"Abergavenny, Monmouthshire, Wales","England":"England","Elmley, Worcestershire, England":"Worcestershire, England, United Kingdom","nameMeanings":[{"name":"Beauchamp","type":"LAST","attribution":"Dictionary of American Family Names © Patrick Hanks 2003, 2006.","meanings":["Some characteristic forenames:  French Antoine, Jacques, Yves, Andre, Armand, Emile, Fernand, Marcel, Marthe, Remi, Alcide, Camille.","English (of Norman origin) and French: habitational name from any of several places in France, for example in Manche and Somme, that are named with Old French <i>beu</i>, <i>bel</i> ‘fair, lovely’ + <i>champ(s)</i> ‘field, plain’ (from Latin <i>bello campo</i> ‘beautiful field’). In English the surname is generally pronounced   Beecham  . Compare   Bushaw  .","English: in some cases, an Anglo-Norman French adaptation of Scottish   Campbell  , by translation into French of the folk etymology <i>de campo bello</i> ‘from the fair field’."],"variants":[{"name":"Beecham","meanings":["English (Lincolnshire): variant of   Beauchamp  , reflecting the normal English pronunciation."]},{"name":"Beachem","meanings":["English (Somerset and Gloucestershire): variant of   Beauchamp  ."]},{"name":"Beachum","meanings":["Altered form of English   Beauchamp  ."]},{"name":"Bagent","meanings":["English:","possibly a colloquial pronunciation of   Beauchamp   or   Beecham  . Old French <i>Beau-</i> often appears as <i>Be(e)-</i> in English surnames. The <i>-ch-</i> has been voiced and excrescent <i>-t</i> has been added.","perhaps an Anglicized form of a French or Flemish surname such as <b>Beaujean</b> and <b>Bejean</b>, from Old French <i>bel Jehan</i> ‘handsome John’ + excrescent <i>-t</i>. It could have been introduced to England in the 15th or 16th century by Flemish migrants."]},{"name":"Beacham","meanings":["English (of Norman origin): variant of   Beauchamp  ."]},{"name":"Campbell","meanings":["Scottish: nickname from Gaelic <i>cam</i> ‘crooked, bent’ + <i>beul</i> ‘mouth’. As a result of folk etymology, the surname was often represented in Latin documents as <i>de bello campo</i> ‘of the fair field’, which led to the name sometimes being ‘translated’ into Anglo-Norman French as   Beauchamp  .","Irish (North Armagh): adopted for Gaelic <b>Mac Cathmhaoil</b> ‘son of Cathmhaol’ (literally ‘battle chief’): see   Caulfield   and   Cowell  .","English: variant of   Camel  , under the influence of the Scottish name (see 1 above)."]},{"name":"Bushaw","meanings":["Americanized form of French   Beauchamp   and   Bouchard  ."]},{"name":"Beacom","meanings":["English (Somerset) and Irish (Fermanagh): of Norman origin, a variant of   Beauchamp  ."]}]},{"name":"Walter","type":"FIRST","attribution":"Dictionary of First Names © Patrick Hanks and Flavia Hodges 1990, 2003, 2006.","meanings":["From an Old French personal name of Germanic (Frankish) origin, derived from <i>wald</i> ‘rule’ + <i>heri</i>, <i>hari</i> ‘army’. This was adopted by the Normans and introduced by them to England, superseding the native Old English form, <i>Wealdhere</i>. It was a very popular name in medieval England, normally pronounced ‘Water’."],"variants":[{"name":"Walther","meanings":["from <i>wald</i> ‘rule’ + <i>heri</i> ‘army’; name of the famous medieval minnesinger  Walther von der Vogelweide  (  <i>c.</i>1170– <i>c.</i>1230 )."]}]}],"lifeSummary":"When Sir Walter Beauchamp was born in 1150, in Elmley Castle, Worcestershire, England, United Kingdom, his father, Sir William de Beauchamp, was 21 and his mother, Joan de St-Valery, was 16. He had at least 3 sons with Bertha de Braose. He died in 1235, in his hometown, at the age of 85, and was buried in Worcester, Worcestershire, England, United Kingdom."},"et":{"1150–1235":"1150–1235","1151–1200":"1151–1200","1165–1212":"1165–1212","1180–1256":"1180–1256","1192–1236":"1192–1236","1130–1197":"1130–1197","1134–1192":"1134–1192","about 1192":"umbes 1192","1165":"1165","1197":"1197","1130":"1130","1151":"1151","1150":"1150","1192":"1192","1180":"1180","19 November 1200":"19. november 1200","1236":"1236","1235":"1235","1212":"1212","1256":"1256","1134":"1134","1200":"1200","Worcestershire, England":"Worcestershire, England","Worcester, Worcestershire, England":"Worcester, Worcestershire, Inglismaa, United Kingdom","Elmley Castle, Worcestershire, England":"Elmley Castle, Worcestershire, Inglismaa, United Kingdom","Abergavenny, Monmouthshire, Wales":"Abergavenny, Monmouthshire, Wales","England":"England","Elmley, Worcestershire, England":"Worcestershire, Inglismaa, United Kingdom"},"fi":{"1150–1235":"1150–1235","1151–1200":"1151–1200","1165–1212":"1165–1212","1180–1256":"1180–1256","1192–1236":"1192–1236","1130–1197":"1130–1197","1134–1192":"1134–1192","about 1192":"noin 1192","1165":"1165","1197":"1197","1130":"1130","1151":"1151","1150":"1150","1192