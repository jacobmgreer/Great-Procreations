male":"1344–Overleden","1382":"1382","1370":"1370","1390":"1390","1404":"1404","1415":"1415","1368":"1368","1401":"1401","1389":"1389","1455":"1455","1388":"1388","1344":"1344","1364":"1364","1342":"1342","1406":"1406","Helston, Cornwall, England":"Helston, Cornwall, England","Cornwall, England":"Cornwall, England"},"en":{"1368–":"1368–Deceased","1368–Male":"1368–Deceased","1370–1406":"1370–1406","1389–1415":"1389–1415","1390–Male":"1390–Deceased","1401–Female":"1401–Deceased","1404–Female":"1404–Deceased","1342–Male":"1342–Deceased","1344–Female":"1344–Deceased","1382":"1382","1370":"1370","1390":"1390","1404":"1404","1415":"1415","1368":"1368","1401":"1401","1389":"1389","1455":"1455","1388":"1388","1344":"1344","1364":"1364","1342":"1342","1406":"1406","Helston, Cornwall, England":"Helston, Cornwall, England","Cornwall, England":"Cornwall, England","nameMeanings":[{"name":"Gerveis","type":"LAST","attribution":"Dictionary of American Family Names © Patrick Hanks 2003, 2006.","meanings":["Some characteristic forenames:  French Marcel, Normand, Armand, Aime, Andre, Emile, Pierre, Raoul, Alain, Alcide, Camille, Cecile.","French: from the personal name <i>Gervais</i> (see   Jarvis   1). Compare   Jarvey   2 and   Jarvis   3.","Altered form of French <b>Gervaise</b>, a variant of 1 above."],"variants":[{"name":"Fasse","meanings":["Some characteristic forenames:  German Arno, Bodo, Fritz, Ingeborg, Kurt.","German: from the personal name <i>Fass</i> or <i>Vass</i>, a vernacular short form of the Late Latin personal name <i>Gervasius</i> (see   Gervais  )."]},{"name":"Jarvis","meanings":["English (of Norman origin): from the Old French personal name <i>Gervais(e)</i>, itself from ancient Germanic <i>Gervas</i>, with <i>gair</i> ‘spear’ as the first element and an uncertain second, perhaps a borrowing of Celtic <i>wass-</i> ‘servant, vassal’. The Latinized name <i>Gervasius</i> was borne by a Christian saint, martyred under the Roman Emperor Domitian, who became one of the patrons of Milan.","English: in Yorkshire, sometimes a habitational name from Jervaulx in East Witton (North Yorkshire). The place takes its name from the river Ure + Old French <i>val</i>, <i>vals</i> ‘valley’.","Americanized form of French   Gervais   and of its variant <b>Gervaise</b>, cognates of 1 above."]},{"name":"Fasel","meanings":["Swiss German and German:","from Middle High German <i>vasel</i> ‘young male breeding animal’ or ‘brood, offspring’, applied as a metonymic occupational name for the man who kept a breeding animal (for the village); or as a nickname for a man with a large family and wealth.","pet form of the personal name <i>Gervasius</i> (see   Gervais  )."]},{"name":"Fausey","meanings":["Possibly an Americanized form of Swiss German <b>Fasi</b>, from a pet form of <i>Gervasius</i> (see   Gervais  ).","Altered form of Swiss German <b>Fausi</b>, a nickname for a prankster."]}]},{"name":"Jacobus","type":"FIRST","attribution":"Dictionary of First Names © Patrick Hanks and Flavia Hodges 1990, 2003, 2006.","meanings":["form of the biblical name <i>Yaakov</i>;  see  Jacob ."],"variants":[]}],"historicEvents":[{"id":1705195,"age":14,"year":"1382","julianDay":2225826,"title":"Wycliffe's Bible","description":"John Wycliffe, English theologian and professor at the University of Oxford, completed a translation of the Bible from the Latin Vulgate into Middle English. This translation is known as Wycliffe's Bible and was completed around 1382.","url":"https://en.wikipedia.org/wiki/Wycliffe%27s_Bible","urlTitle":"Wikipedia - Wycliffe's Bible","jurisdictionLevel":1},{"id":1705197,"age":87,"year":"1455","julianDay":2252488,"title":"Wars of the Roses","description":"Wars of the Roses was a series of English civil wars for control of the throne of England between the royal families House of Lancaster and the House of York. The name of the war was derived as the red rose was the symbol of the Lancastrians and the white rose was the symbol of the Yorks.","url":"htt