 de Dive-13岁，母亲Mrs William de Dive-14岁。他于1154年与Helewise Unknown在法国巴-諾門迪卡爾瓦多斯迪武-素-梅结婚。他们至少是1个儿子和1个女儿的父母。"},"hr":{"about 1075–":"oko 1075.–preminuo","1075–Male":"1075–preminuo","1125–1190":"1125–1190","1116–Female":"1116–preminula","1130–1190":"1130–1190","1142–1199":"1142–1199","1090–Male":"1090–preminuo","1091–Female":"1091–preminula","1091":"1091","1190":"1190","1090":"1090","1154":"1154.","1142":"1142","1130":"1130","1075":"1075","1116":"1116","1125":"1125","1199":"1199","about 1075":"oko 1075.","about 1130":"oko 1130.","about 1142":"oko 1142.","East Haddon, Northamptonshire, England":"East Haddon, Northamptonshire, England","Dives-sur-Mer, Calvados, Normandy, France":"Dives-sur-Mer, Calvados, Normandie, Francuska","Dives-sur-Mer, Calvados, Lower Normandy, France":"Dives-sur-Mer, Calvados, Basse-Normandie, Francuska"},"cs":{"about 1075–":"okolo 1075–Zesnulý","1075–Male":"1075–Zesnulý","1125–1190":"1125–1190","1116–Female":"1116–Zesnulá","1130–1190":"1130–1190","1142–1199":"1142–1199","1090–Male":"1090–Zesnulý","1091–Female":"1091–Zesnulá","1091":"1091","1190":"1190","1090":"1090","1154":"1154","1142":"1142","1130":"1130","1075":"1075","1116":"1116","1125":"1125","1199":"1199","about 1075":"okolo 1075","about 1130":"okolo 1130","about 1142":"okolo 1142","East Haddon, Northamptonshire, England":"East Haddon, Northamptonshire, Anglie","Dives-sur-Mer, Calvados, Normandy, France":"Dives-sur-Mer, Calvados, Normandie, Francie","Dives-sur-Mer, Calvados, Lower Normandy, France":"Dives-sur-Mer, Calvados, Basse-Normandie, Francie"},"da":{"about 1075–":"omkring 1075–Afdød","1075–Male":"1075–Afdød","1125–1190":"1125–1190","1116–Female":"1116–Afdød","1130–1190":"1130–1190","1142–1199":"1142–1199","1090–Male":"1090–Afdød","1091–Female":"1091–Afdød","1091":"1091","1190":"1190","1090":"1090","1154":"1154","1142":"1142","1130":"1130","1075":"1075","1116":"1116","1125":"1125","1199":"1199","about 1075":"omkring 1075","about 1130":"omkring 1130","about 1142":"omkring 1142","East Hadd