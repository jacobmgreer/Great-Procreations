6","1420–1500":"1420–1500","1367–1411":"1367–1411","1372–Female":"1372–Afdød","1372":"1372","1393":"1393","1415":"1415","1500":"1500","1411":"1411","1367":"1367","1389":"1389","1421":"1421","1476":"1476","1420":"1420","about 1414":"omkring 1414","about 1411":"omkring 1411","1419":"1419","Ipswich, Suffolk, England":"Ipswich, Suffolk, England","Shotley, Suffolk, England":"Shotley, Suffolk, England","Colchester, Essex, England, United Kingdom":"Colchester, Essex, England, United Kingdom"},"nl":{"1393–1421":"1393–1421","1389–1419":"1389–1419","1415–1476":"1415–1476","1420–1500":"1420–1500","1367–1411":"1367–1411","1372–Female":"1372–Overleden","1372":"1372","1393":"1393","1415":"1415","1500":"1500","1411":"1411","1367":"1367","1389":"1389","1421":"1421","1476":"1476","1420":"1420","about 1414":"circa 1414","about 1411":"circa 1411","1419":"1419","Ipswich, Suffolk, England":"Ipswich, Suffolk, England","Shotley, Suffolk, England":"Shotley, Suffolk, England","Colchester, Essex, England, United Kingdom":"Colchester, Essex, Engeland, Verenigd Koninkrijk"},"en":{"1393–1421":"1393–1421","1389–1419":"1389–1419","1415–1476":"1415–1476","1420–1500":"1420–1500","1367–1411":"1367–1411","1372–Female":"1372–Deceased","1372":"1372","1393":"1393","1415":"1415","1500":"1500","1411":"1411","1367":"1367","1389":"1389","1421":"1421","1476":"1476","1420":"1420","about 1414":"about 1414","about 1411":"about 1411","1419":"1419","Ipswich, Suffolk, England":"Ipswich, Suffolk, England","Shotley, Suffolk, England":"Shotley, Suffolk, England","Colchester, Essex, England, United Kingdom":"Colchester, Essex, England, United Kingdom","nameMeanings":[{"name":"Margareth","type":"FIRST","attribution":"Dictionary of First Names © Patrick Hanks and Flavia Hodges 1990, 2003, 2006.","meanings":["from Greek.  See  <b>Margaret</b>   ."],"variants":[{"name":"Margaret","meanings":["An extremely common given name from the Middle Ages onwards, derived via Old French <i>Marguerite</i> and Latin <i>Margarita</i> from Greek <i>Margarītēs</i>, from <i>margaron</i> ‘pearl’, a word ultimately of Hebrew origin. The name was always understood to mean ‘pearl’ throughout the Middle Ages. The first  St Margaret  was martyred at Antioch in Pisidia during the persecution instigated by the  Emperor Diocletian  in the early 4th century. However, there is some doubt about her name, as the same saint is venerated in the Orthodox Church as   Marina .  There were several other saintly bearers of the name, including St Margaret of Scotland (  d. 1093 ), wife of  King Malcolm Canmore  and daughter of Edmund Ironside of England. It was also the name of the wife of  Henry VI  of England,  Margaret of Anjou  (  1430–82 ), and of  Margaret Tudor  (  1489–1541 ), sister of  Henry VIII , who married James IV of Scotland and ruled as regent there after his death.  See also  Margery  ,   Marjorie ."]},{"name":"Margareta","meanings":["From the Latin form of Greek <i>Margarītēs</i>.  See  <b>Margaret</b>   ."]},{"name":"Margaretha","meanings":["An extremely common given name from the Middle Ages onwards, derived via Old French <i>Marguerite</i> and Latin <i>Margarita</i> from Greek <i>Margarītēs</i>, from <i>margaron</i> ‘pearl’, a word ultimately of Hebrew origin. The name was always understood to mean ‘pearl’ throughout the Middle Ages. The first  St Margaret  was martyred at Antioch in Pisidia during the persecution instigated by the  Emperor Diocletian  in the early 4th century. However, there is some doubt about her name, as the same saint is venerated in the Orthodox Church as   Marina .  There were several other saintly bearers of the name, including St Margaret of Scotland (  d. 1093 ), wife of  King Malcolm Canmore  and daughter of Edmund Ironside of England. It was also the name of the wife of  Henry VI  of England,  Margaret of Anjou  (  1430–82 ), and of  Margaret Tudor  (  1489–1541 ), sister of  Henry VIII , who married James IV of Scotland and ruled as regent there after his death.  See also  Margery  ,   Marjorie ."]},{"name":"Margarethe","meanings":["from Greek.  See  <b>Margaret</b>   ."]}]}],"lifeSummary":"When Margareth Visedolou was born in 1393, in Shotley, Suffolk, England, her father, Thomas Visdelou III, was 26 and her mother, Joan Spring, was 21. She married Thomas Mosell about 1414, in Shotley, Suffolk, England. They were the parents of at least 2 daughters. She died in 1421, in Ipswich, Suffolk, England, at the age of 28."},"et":{"1393–1421":"1393–1421","1389–1419":"1389–1419","1415–1476":"1415–1476","1420–1500":"1420–1500","1367–1411":"1367–1411","1372–Female":"1372–Surnud","1372":"1372","1393":"1393","1415":"1415","1500":"1500","1411":"1411","1367":"1367","1389":"1389","1421":"1421","1476":"1476","1420":"1420","about 1414":"umbes 1414","about 1411":"umbes 1411","1419":"1419","Ipswich, Suffolk, England":"Ipswich, Suffolk, England","Shotley, Suffolk, England":"Shotley, Suffolk, England","Colchester, Essex, England, United Kingdom":"Colchester, Essex, Inglismaa, United Kingdom"},"fi":{"1393–1421":"1393–1421","1389–1419":"1389–1419","1415–1476":"1415–1476","1420–1500":"1420–1500","1367–1411":"1367–1411","1372–Female":"1372–Kuollut","1372":"1372","1393":"1393","1415":"1415","1500":"1500","1411":"1411","1367":"1367","1389":"1389","1421":"1421","1476":"1476","1420":"1420","about 1414":"noin 1414","about 1411":"noin 1411","1419":"1419","Ipswich, Suffolk, England":"Ipswich, Suffolk, England","Shotley, Suffolk, England":"Shotley, Suffolk, England","Colchester, Essex, England, United Kingdom":"Colchester, Essex, Englanti, Yhdistynyt kuningaskunta"},"fr":{"1393–1421":"1393–1421","1389–1419":"1389–1419","1415–1476":"1415–1476","1420–1500":"1420–1500","1367–1411":"1367–1411","1372–Female":"1372–Décédée","1372":"1372","1393":"1393","1415":"1415","1500":"1500","1411":"1411","1367":"1367","1389":"1389","1421":"1421","1476":"1476","1420":"1420","about 1414":"environ 1414","about 1411":"environ 1411","1419":"1419","Ipswich, Suffolk, England":"Ipswich, Su