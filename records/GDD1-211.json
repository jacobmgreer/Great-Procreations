ification’."],"variants":[]}],"historicEvents":[{"id":1702076,"age":15,"year":"1436","julianDay":2245548,"title":"The Engelbrekt Rebellion","description":"Engelbrekt Engelbrektsson, a Swedish mine owner and statesman, led a rebellion against Eric of Pomerania, King of the Kalmar Union. Sweden was upset with the Danes' interference with Swedish exports and unjust collection of taxes. The Engelbrekt Rebellion led to the deposing of Eric of Pomerania and the eventual dissolution of the Kalmar Union.","jurisdictionLevel":0},{"id":1357051,"age":74,"year":"1495","julianDay":2267098,"description":"Russians forces invade Sweden.","jurisdictionLevel":0},{"id":1702078,"age":74,"year":"1495","toYear":"1497","julianDay":2267098,"title":"The Russo-Swedish War","description":"While in an alliance with Grand Prince Ivan III of Moscow, King Hans of Denmark and Norway invaded Sweden and was declared King of Sweden.","url":"https://en.wikipedia.org/wiki/Russo-Swedish_War_(1495%E2%80%931497)","urlTitle":"Wikipedia - Swedish War","jurisdictionLevel":0},{"id":1702079,"age":99,"year":"1520","julianDay":2276228,"title":"The Stockholm Bloodbath","description":"A mass execution of Swedish nobles by Danish king Christian II is known as the Stockholm Bloodbath. Christian II invaded Sweden in 1519 and took hold of Stockholm in September 1520. Over 80 nobles were executed for heresy on November 8 and 9. The outrage from the executions led to the Swedish removal of support of the Kalmar Union.","url":"https://www.britannica.com/event/Stockholm-Bloodbath","urlTitle":"Britannica - Stockholm Bloodbath","jurisdictionLevel":0},{"id":1702080,"age":102,"year":"1523","julianDay":2277324,"title":"Swedish War of Liberation","description":"The Swedish War of Liberation was a civil war led by nobleman Gustav Vasa. As Christian II heard of the rebellion, he confronted Vasa's men, who won the battle at Brunbacks Ferry. Christian II was defeated by the Swedes in Stockholm and a truce was agreed upon. Vasa was given as a hostage as a show of good faith until the treaty was signed. The Danish King did not keep his word and Vasa was held as a prisoner for two years until his escape. A bounty was placed on Vasa's head. Vasa worked to inspire many to join his cause and lived under disguise until the Danes surrendered in 1525.","url":"https://www.sweden.org.za/swedish-monarchy-gustav-vasa.html","urlTitle":"Sweden.org - Swedish Monarchy Gustav Vasa","jurisdictionLevel":0}],"lifeSummary":"Ingeborg Bengtsdotter was born in Sweden as the daughter of Bengt Laurensson rödbälke and Margit Clausdotter Dowt. She married Bengt Tomasson before 1440."},"et":{"–":"Surnud","–Female":"Surnud","–1473":"–1473","–Male":"Surnud","1442–1509":"1442–1509","–1490":"–1490","1377–1420":"1377–1420","1436":"1436","1523":"1523","1520":"1520","1377":"1377","1442":"1442","1497":"1497","1420":"1420","1495":"1495","1473":"1473","21 January 1442":"21. jaanuar 1442","1509":"1509","1490":"1490","Sweden":"Rootsi"},"fi":{"–":"Kuollut","–Female":"Kuollut","–1473":"–1473","–Male":"Kuollut","1442–1509":"1442–1509","–1490":"–1490","1377–1420":"1377–1420","1436":"1436","1523":"1523","1520":"1520","1377":"1377","1442":"1442","1497":"1497","1420":"1420","1495":"1495","1473":"1473","21 January 1442":"21. tammikuuta 1442","1509":"1509","1490":"1490","Sweden":"Ruotsi"},"fr":{"–":"Décédée","–Female":"Décédée","–1473":"–1473","–Male":"Décédé","1442–1509":"1442–1509","–1490":"–1490","1377–1420":"1377–1420","1436":"1436","1523":"1523","1520":"1520","1377":"1377","1442":"1442","1497":"1497","1420":"1420","1495":"1495","1473":"1473","21 January 1442":"21 janvier 1442","1509":"1509","1490":"1490","Sweden":"Suède","lifeSummary":"Ingeborg Bengtsdotter est née à Suède, fille de Bengt Laurensson rödbälke et Margit Clausdotter Dowt. Elle a épousé Bengt Tomasson avant 1440."},"de":{"–":"Verstorben","–Female":"Verstorben","–1473":"–1473","–Male":"Verstorben","1442–1509":"1442–1509","–1490":"–1490","1377–1420":"1377–1420","1436":"1436","