n":{"1397–":"1397–Deceased","1397–Female":"1397–Deceased","1397–1446":"1397–1446","1424–1483":"1424–1483","1430–Female":"1430–Deceased","1375–Male":"1375–Deceased","1376–Female":"1376–Deceased","1424":"1424","1446":"1446","1423":"1423","1376":"1376","1397":"1397","1375":"1375","1430":"1430","1396":"1396","1483":"1483","sbt 1430":"1430","East Down, Barnstaple, Devonshire, England":"East Down, Devon, England, United Kingdom","Ilcombe, Kilkhampton, Cornwall, England":"Kilkhampton, Cornwall, England","Kent, England":"Kent, England","East Down, Devon, England":"East Down, Devon, England","nameMeanings":[{"name":"Ilcombe","type":"LAST","attribution":"Dictionary of Family Names in Britain and Ireland © University of the West of England 2016","meanings":["1  English: locative name from Elcombe in Wroughton (Wilts), recorded as  <i>Elecome</i> in   Domesday Book  , or, less likely, from Elcombe in Uley (Gloucs), Elcombe in Alvediston (Wilts), or Elcombe in Bisley (Gloucs).","2  English: possibly a variant of   Welcome   with loss of initial  <i>W-</i>."],"variants":[{"name":"Elcome","meanings":["English:  see  Elcombe  ."]},{"name":"Domesday Book","meanings":["English, Welsh: locative name, apparently from Humby (Lincs) or Hanby in Welton (Lincs); the latter is recorded as  <i>Humbi</i> in   Domesday Book  ."]},{"name":"Welcome","meanings":["English: habitational name from Welcombe (Devon) or Welcombe in Stratford (Warwickshire). The placenames derive from Old English <i>wella</i> ‘well, spring, stream’ + <i>cumb</i> ‘valley’.","English: nickname from Middle English <i>welcum</i> ‘welcome’ (Old English <i>wilcume</i>), applied to someone who habitually used this expression.","English: perhaps an altered form of the medieval name <i>Welkempt</i>, from Middle English <i>wel kempt</i> literally ‘well-combed’, extended to mean ‘neat, well-dressed’."]}]},{"name":"Thomazine","type":"FIRST","meanings":["Female names formed from Thomas"],"variants":[]}],"lifeSummary":"When Thomazine