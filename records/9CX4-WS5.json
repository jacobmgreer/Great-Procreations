":{"about 1222–":"omkring 1222–Afdød","1218–1272":"1218–1272","1220–Male":"1220–Afdød","1222–Male":"1222–Afdød","1227–Female":"1227–Afdød","1257–Male":"1257–Afdød","1192–1254":"1192–1254","1197–Female":"1197–Afdød","1220":"1220","1197":"1197","1272":"1272","1192":"1192","1290":"1290","1315":"1315","1227":"1227","1259":"1259","1224":"1224","1257":"1257","about 1215":"omkring 1215","1222":"1222","1254":"1254","about 1257":"omkring 1257","about 1247":"omkring 1247","about 1222":"omkring 1222","1328":"1328","1317":"1317","1218":"1218","Weston Subedge, Gloucestershire, England":"Weston Subedge, Gloucestershire, England","Pandy, Monmouthshire, Wales":"Pandy, Monmouthshire, Wales"},"nl":{"about 1222–":"circa 1222–Overleden","1218–1272":"1218–1272","1220–Male":"1220–Overleden","1222–Male":"1222–Overleden","1227–Female":"1227–Overleden","1257–Male":"1257–Overleden","1192–1254":"1192–1254","1197–Female":"1197–Overleden","1220":"1220","1197":"1197","1272":"1272","1192":"1192","1290":"1290","1315":"1315","1227":"1227","1259":"1259","1224":"1224","1257":"1257","about 1215":"circa 1215","1222":"1222","1254":"1254","about 1257":"circa 1257","about 1247":"circa 1247","about 1222":"circa 1222","1328":"1328","1317":"1317","1218":"1218","Weston Subedge, Gloucestershire, England":"Weston Subedge, Gloucestershire, England","Pandy, Monmouthshire, Wales":"Pandy, Monmouthshire, Wales"},"en":{"about 1222–":"about 1222–Deceased","1218–1272":"1218–1272","1220–Male":"1220–Deceased","1222–Male":"1222–Deceased","1227–Female":"1227–Deceased","1257–Male":"1257–Deceased","1192–1254":"1192–1254","1197–Female":"1197–Deceased","1220":"1220","1197":"1197","1272":"1272","1192":"1192","1290":"1290","1315":"1315","1227":"1227","1259":"1259","1224":"1224","1257":"1257","about 1215":"about 1215","1222":"1222","1254":"1254","about 1257":"about 1257","about 1247":"about 1247","about 1222":"about 1222","1328":"1328","1317":"1317","1218":"1218","Weston Subedge, Gloucestershire, England":"Weston Subedge, Gloucestershire, England","Pandy, Monmouthshire, Wales":"Pandy, Monmouthshire, Wales","nameMeanings":[{"name":"Pembridge","type":"LAST","attribution":"Dictionary of Family Names in Britain and Ireland © University of the West of England 2016","meanings":["English: locative name from Pembridge (Herefs), which is recorded as  <i>Penebrug(g)e</i> from the 11th to 14th centuries. The place-name derives from an Old English personal name * <i>Pena</i> + Old English  <i>brycg</i> ‘bridge’. In some cases the surname may be from Pen Bridge in Shipley (Sussex), which derives from an uncertain first element + Old English  <i>brycg</i>."],"variants":[{"name":"Pember","meanings":["English: perhaps a variant of <b>Pamber</b>, a habitational name from a place in Hampshire named Pamber, from Old English <i>penn</i> ‘fold, enclosure’ + <i>beorg</i> ‘hill’."]}]},{"name":"Richard","type":"FIRST","attribution":"Dictionary of First Names © Patrick Hanks and Flavia Hodges 1990, 2003, 2006.","meanings":["One of the most enduringly successful of the Old French personal names introduced into Britain by the Normans. It is of Germanic (Frankish) origin, derived from <i>rīc</i> ‘power’ + <i>hard</i> ‘strong, hardy’. It has enjoyed continuous popularity in England from the Conquest to the present day, influenced by the fact that it was borne by three kings of England, in particular  Richard I  (  1157–99 ). He was king for only ten years (  1189–99 ), most of which he spent in warfare abroad, taking part in the Third Crusade and costing the people of England considerable sums in taxes. Nevertheless, he achieved the status of a folk hero, and was never in England long enough to disappoint popular faith in his goodness and justice. He was also Duke of Aquitaine and Normandy and Count of Anjou, fiefs which he held at a time of maximum English expansion in France. His exploits as a leader of the Third Crusade earned him the nickname ‘Coeur de Lion’ or ‘Lionheart’ and a permanent place in popular imagination, in which he was even more firmly enshrined by  Sir Walter Scott's  novel Ivanhoe (  1820 )."],"variants":[{"name":"Rikert","meanings":["One of the most enduringly successful of the Old French personal names introduced into Britain by the Normans. It is of Germanic (Frankish) origin, derived from <i>rīc</i> ‘power’ + <i>hard</i> ‘strong, hardy’. It has enjoyed continuous popularity in England from the Conquest to the present day, influenced by the fact that it was borne by three kings of England, in particular  Richard I  (  1157–99 ). He was king for only ten years (  1189–99 ), most of which he spent in warfare abroad, taking part in the Third Crusade and costing the people of England considerable sums in taxes. Nevertheless, he achieved the status of a folk hero, and was never in England long enough to disappoint popular faith in his goodness and justice. He was also Duke of Aquitaine and Normandy and Count of Anjou, fiefs which he held at a time of maximum English expansion in France. His exploits as a leader of the Third Crusade earned him the nickname ‘Coeur de Lion’ or ‘Lionheart’ and a permanent place in popular imagination, in which he was even more firmly enshrined by  Sir Walter Scott's  novel Ivanhoe (  1820 )."]},{"name":"Rickert","meanings":["One of the most enduringly successful of the Old French personal names introduced into Britain by the Normans. It is of Germanic (Frankish) origin, derived from <i>rīc</i> ‘power’ + <i>hard</i> ‘strong, hardy’. It has enjoyed continuous popularity in England from the Conquest to the present day, influenced by the fact that it was borne by three kings of England, in particular  Richard I  (  1157–99 ). He was king for only ten years (  1189–99 ), most of which he spent in warfare abroad, taking part in the Third Crusade and costing the people of England considerable sums in taxes. Nevertheless, he achieved the status of a folk hero, and was never in England long enough to disappoint popular faith in his goodness and justice. He was also Duke of Aquitaine and Normandy and Count of Anjou, fiefs which he held at a time of maximum English expansion in France. His exploits as a leader of the Third Crusade earned him the nickname ‘Coeur de Lion’ or ‘Lionheart’ and a permanent place in popular imagination, in which he was even more firmly enshrined by  Sir Walter Scott's  novel Ivanhoe (  1820 )."]}]}],"historicEvents":[{"id":1705188,"age":2,"year":"1224","julianDay":2168117,"title":"France Declares War on England","description":"France declared war on England as Louis VIII of France attacked Poitou and northern Gascony.","jurisdictionLevel":2},{"id":1705189,"age":37,"year":"1259","julianDay":2180901,"title":"100 Years of Conflict Between England and France Ends","description":"Treaty of Paris was signed on December 4, 1259, which ended 100 years of conflict between England and France.","url":"https://en.wikipedia.org/wiki/Treaty_of_Paris_(1259)","urlTitle":"Wikipedia - Treaty of Paris 1259","jurisdictionLevel":2},{"id":1705190,"age":68,"year":"1290","julianDay":2192224,"title":"Jews Expelled From England","description":"After years of anti-Semitic behavior, King Edward I expelled Jews from England in 1290.","jurisdictionLevel":2},{"id":1705191,"age":93,"year":"1315","toYear":"1317","julianDay":2201354,"title":"Famine Strikes Europe","description":"A famine caused by cold winters and wet summers across Europe caused millions to die due to starvation. Desperation from hunger caused high levels of crime, stampedes in bread lines in London, infanticide, and even cannibalism throughout Europe.","jurisdictionLevel":2},{"id":1705192,"age":106,"year":"1328","julianDay":2206102,"title":"First War of Scottish Independence","description":"The First War of Scottish Independence began after England invaded Scotland in 1296. The Treaty of Edinburgh was signed in 1328 which declared peace between the two kingdoms and brought the war to an end.","jurisdictionLevel":2}],"lifeSummary":"When Richa