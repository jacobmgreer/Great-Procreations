"1404":"1404","1359":"1359","1413":"1413","1347":"1347","about 1391":"circa 1391","1400":"1400","about 1404":"circa 1404","1455":"1455","1486":"1486","1441":"1441","1382":"1382","1391":"1391","Thorpe Waterville, Northamptonshire, England":"Thorpe Waterville, Northamptonshire, England","Northamptonshire, England":"Northamptonshire, England"},"en":{"1359–":"1359–Deceased","1347–1413":"1347–1413","1391–Male":"1391–Deceased","1400–1486":"1400–1486","1404–1441":"1404–1441","1359–Female":"1359–Deceased","1404":"1404","1359":"1359","1413":"1413","1347":"1347","about 1391":"about 1391","1400":"1400","about 1404":"about 1404","1455":"1455","1486":"1486","1441":"1441","1382":"1382","1391":"1391","Thorpe Waterville, Northamptonshire, England":"Thorpe Waterville, Northamptonshire, England","Northamptonshire, England":"Northamptonshire, England","nameMeanings":[{"name":"Margaret","type":"FIRST","attribution":"Dictionary of First Names © Patrick Hanks and Flavia Hodges 1990, 2003, 2006.","meanings":["An extremely common given name from the Middle Ages onwards, derived via Old French <i>Marguerite</i> and Latin <i>Margarita</i> from Greek <i>Margarītēs</i>, from <i>margaron</i> ‘pearl’, a word ultimately of Hebrew origin. The name was always understood to mean ‘pearl’ throughout the Middle Ages. The first  St Margaret  was martyred at Antioch in Pisidia during the persecution instigated by the  Emperor Diocletian  in the early 4th century. However, there is some doubt about her name, as the same saint is venerated in the Orthodox Church as   Marina .  There were several other saintly bearers of the name, including St Margaret of Scotland (  d. 1093 ), wife of  King Malcolm Canmore  and daughter of Edmund Ironside of England. It was also the name of the wife of  Henry VI  of England,  Margaret of Anjou  (  1430–82 ), and of  Margaret Tudor  (  1489–1541 ), sister of  Henry VIII , who married James IV of Scotland and ruled as regent there after his death.  See also  Margery  ,   Marjorie ."],"variants":[{"name":"Margareta","meanings":["From the Latin form of Greek <i>Margarītēs</i>.  See  <b>Margaret</b>   ."]},{"name":"Margaretta","meanings":["An extremely common given name from the Middle Ages onwards, derived via Old French <i>Marguerite</i> and Latin <i>Margarita</i> from Greek <i>Margarītēs</i>, from <i>margaron</i> ‘pearl’, a word ultimately of Hebrew origin. The name was always understood to mean ‘pearl’ throughout the Middle Ages. The first  St Margaret  was martyred at Antioch in Pisidia during the persecution instigated by the  Emperor Diocletian  in the early 4th century. However, there is some doubt about her name, as the same saint is venerated in the Orthodox Church as   Marina .  There were several other saintly bearers of the name, including St Margaret of Scotland (  d. 1093 ), wife of  King Malcolm Canmore  and daughter of Edmund Ironside of England. It was also the name of the wife of  Henry VI  of England,  Margaret of Anjou  (  1430–82 ), and of  Margaret Tudor  (  1489–1541 ), sister of  Henry VIII , who married James IV of Scotland and ruled as regent there after his death.  See also  Margery  ,   Marjorie ."]}]}],"historicEvents":[{"id":1705195,"age":23,"year":"1382","julianDay":2225826,"title":"Wycliffe's Bible","description":"John Wycliffe, English theologian and professor at the University of Oxford, completed a translation of the Bible from the Latin Vulgate into Middle English. This translation is known as Wycliffe's Bible and was completed around 1382.","url":"https://en.wikipedia.org/wiki/Wycliffe%27s_Bible","urlTitle":"Wikipedia - Wycliffe's Bible","jurisdictionLevel":2},{"id":1705197,"age":96,"year":"1455","julianDay":2252488,"title":"Wars of the Roses","description":"Wars of the Roses was a series of English civil wars for control of the throne of England between the royal families House of Lancaster and the House of York. The name of the war was derived as the red rose was the symbol of the Lancastrians and the white rose was the symbol of the Yorks.","url":"https://www.history.com/topics/british-history/wars-of-the-roses","urlTitle":"History - Wars of the Roses","jurisdictionLevel":2}],"lifeSummary":"Margaret was born in 1359, in Thorpe Waterville, Northamptonshire, England. She had at least 1 son and 2 daughters with John de Holand."},"et":{"1359–":"1359–Surnud","1347–1413":"1347–1413","1391–Male":"1391–Surnud","1400–1486":"1400–1486","1404–1441":"1404–1441","1359–Female":"1359–Surnud","1404":"1404","1359":"1359","1413":"1413","1347":"1347","about 1391":"umbes 1391","1400":"1400","about 1404":"umbes 1404","1455":"1455","1486":"1486","1441":"1441","1382":"1382","1391":"1391","Thorpe Waterville, Northamptonshire, England":"Thorpe Waterville, Northamptonshire, England","Northamptonshire, England":"Northamptonshire, England"},"fi":{"1359–":"1359–Kuollut","1347–1413":"1347–1413","1391–Male":"1391–Kuollut","1400–1486":"1400–1486","1404–1441":"1404–1441","1359–Female":"1359–Kuollut","1404":"1404","1359":"1359","1413":"1413","1347":"1347","about 1391":"noin 1391","1400":"1400","about 1404":"noin 1404","1455":"1455","1486":"1486","1441":"1441","1382":"1382","1391":"1391","Thorpe Waterville, Northamptonshire, England":"Thorpe Waterville, Northamptonshire, England","Northamptonshire, England":"Northamptonshire, England"},"fr":{"1359–":"1359–Décédée","1347–1413":"1347–1413","1391–Male":"1391–Décédé","1400–1486":"1400–1486","1404–1441":"1404–1441","1359–Female":"1359–Décédée","1404":"1404","1359":"1359","1413":"1413","1347":"1347","about 1391":"environ 1391","1400":"1400","about 1404":"environ 1404","1455":"1455","1486":"1486","1441":"1441","1382":"1382","1391":"1391","Thorpe Waterville, Northamptonshire, England":"Thorpe Waterville, Northamptonshire, Angleterre","Northamptonshire, England":"Northamptonshire, Angleterre","lifeSummary":"Margaret est née en 1359, à Thorpe Waterville, Northamptonshire, Angleterre. Elle a eu au moins 1 fils et 2 filles avec John de Holand."},"de":{"13