:"1420","1397":"1397","1329":"1329","Hove, Sussex, England":"Hove, Sussex, England","Dudley, Staffordshire, England":"Dudley, Staffordshire, England","France":"Frankrig","London, England":"London, England","Sutton, Essex, England":"Sutton, Essex, England, United Kingdom","Langley Marish, Buckinghamshire, England":"Langley, Buckinghamshire, England"},"nl":{"1361–1420":"1361–1420","1360–1420":"1360–1420","1361–1397":"1361–1397","1360–1400":"1360–1400","1380–1460":"1380–1460","1329–1369":"1329–1369","1335–Female":"1335–Overleden","25 December 1357":"25 december 1357","about 1380":"circa 1380","24 September 1369":"24 september 1369","1361":"1361","1460":"1460","1382":"1382","1360":"1360","1380":"1380","1369":"1369","1335":"1335","1378":"1378","1400":"1400","1420":"1420","1397":"1397","1329":"1329","Hove, Sussex, England":"Hove, Sussex, England","Dudley, Staffordshire, England":"Dudley, Staffordshire, England","France":"Frankrijk","London, England":"London, England","Sutton, Essex, England":"Sutton, Essex, Engeland, Verenigd Koninkrijk","Langley Marish, Buckinghamshire, England":"Langley, Buckinghamshire, England"},"en":{"1361–1420":"1361–1420","1360–1420":"1360–1420","1361–1397":"1361–1397","1360–1400":"1360–1400","1380–1460":"1380–1460","1329–1369":"1329–1369","1335–Female":"1335–Deceased","25 December 1357":"25 December 1357","about 1380":"about 1380","24 September 1369":"24 September 1369","1361":"1361","1460":"1460","1382":"1382","1360":"1360","1380":"1380","1369":"1369","1335":"1335","1378":"1378","1400":"1400","1420":"1420","1397":"1397","1329":"1329","Hove, Sussex, England":"Hove, Sussex, England","Dudley, Staffordshire, England":"Dudley, Staffordshire, England","France":"France","London, England":"London, England","Sutton, Essex, England":"Sutton, Essex, England, United Kingdom","Langley Marish, Buckinghamshire, England":"Langley, Buckinghamshire, England","nameMeanings":[{"name":"Sutton","type":"LAST","attribution":"Dictionary of American Family Names © Patrick Hanks 2003, 2006.","meanings":["English: habitational name from any of numerous places called Sutton, named with Old English <i>sūth</i> ‘south, southern’ + <i>tūn</i> ‘farmstead, estate’. The English surname is also common in Ireland (Wexford, Kildare), where it has been established since the 13th century and Gaelicized as <b>de Sutún</b>.","Jewish (from the former Ottoman Empire, including Syria): unexplained.","English: topographic name from Middle English <i>(bi) suthentune</i> ‘(at the place to the) south of the village’."],"variants":[{"name":"Setton","meanings":["Some characteristic forenames:  Jewish Avi, Ronit, Yossef.  French Andree, Henri, Jacques, Maryse.","Jewish (from the Ottoman Empire): altered form of   Sutton  .","English (Middlesex): variant of   Seaton  ."]}]},{"name":"Margaret","type":"FIRST","attribution":"Dictionary of First Names © Patrick Hanks and Flavia Hodges 1990, 2003, 2006.","meanings":["An extremely common given name from the Middle Ages onwards, derived via Old French <i>Marguerite</i> and Latin <i>Margarita</i> from Greek <i>Margarītēs</i>, from <i>margaron</i> ‘pearl’, a word ultimately of Hebrew origin. The name was always understood to mean ‘pearl’ throughout the Middle Ages. The first  St Margaret  was martyred at Antioch in Pisidia during the persecution instigated by the  Emperor Diocletian  in the early 4th century. However, there is some doubt about her name, as the same saint is venerated in the Orthodox Church as   Marina .  There were several other saintly bearers of the name, including St Margaret of Scotland (  d. 1093 ), wife of  King Malcolm Canmore  and daughter of Edmund Ironside of England. It was also the name of the wife of  Henry VI  of England,  Margaret of Anjou  (  1430–82 ), and of  Margaret Tudor  (  1489–1541 ), sister of  Henry VIII , who married James IV of Scotland and ruled as regent there after his death.  See also  Margery  ,   Marjorie ."],"variants":[{"name":"Margareta","meanings":["From the Latin form of Greek <i>Margarītēs</i>.  See  <b>Margaret</b>   ."]},{"name":"Margaretta","meanings":["An extremely common given name from the Middle Ages onwards, derived via Old French <i>Marguerite</i> and Latin <i>Margarita</i> from Greek <i>Margarītēs</i>, from <i>margaron</i> ‘pearl’, a word ultimately of Hebrew origin. The name was always understood to mean ‘pearl’ throughout the Middle Ages. The first  St Margaret  was martyred at Antioch in Pisidia during the persecution instigated by the  Emperor Diocletian  in the early 4th century. However, there is some doubt about her name, as the same saint is venerated in the Orthodox Church as   Marina .  There were several other saintly bearers of the name, including St Margaret of Scotland (  d. 1093 ), wife of  King Malcolm Canmore  and daughter of Edmund Ironside of England. It was also the name of the wife of  Henry VI  of England,  Margaret of Anjou  (  1430–82 ), and of  Margaret Tudor  (  1489–1541 ), sister of  Henry VIII , who married James IV of Scotland and ruled as regent there after his death.  See also  Margery  ,   Marjorie ."]}]}],"historicEvents":[{"id":1705195,"age":21,"year":"1382","julianDay":2225826,"title":"Wycliffe's Bible","description":"John Wycliffe, English theologian and professor at the University of Oxford, completed a translation of the Bible from the Latin Vulgate into Middle English. This translation is known as Wycliffe's Bible and was completed around 1382.","url":"https://en.wikipedia.org/wiki/Wycliffe%27s_Bible","urlTitle":"Wikipedia - Wycliffe's Bible","jurisdictionLevel":2}],"lifeSummary":"When Margaret Sutton was born in 1361, in Dudley, Staffordshire, England, her father, Sir John Sutton III, was 32 and her mother, Katherine Stafford, was 26. She married Thomas Harberger in 1378, in Sutton, Essex, England, United Kingdom. They were the parents of at least 1 daughter. She died in 1420, in Hove, Sussex, England, at the age of 59."},"et":{"1361–1420":"1361–1420","1360–1420":"1360–142