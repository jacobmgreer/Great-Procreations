:"1393–1470","1331–1368":"1331–1368","about 1393":"omkring 1393","about 1360":"omkring 1360","1372":"1372","1382":"1382","1470":"1470","1393":"1393","1360":"1360","about May 1397":"omkring maj 1397","1415":"1415","Abt 1360":"omkring 1360","1368":"1368","1331":"1331","25 September 1415":"25. september 1415","Pennington, Lancashire, England":"Pennington, Lancashire, England","Preston Richard, Westmorland, England":"Preston Richard, Westmorland, England","Lancashire, England":"Lancashire, England","England, United Kingdom":"England, United Kingdom"},"nl":{"Abt 1360–25 September 1415":"circa 1360–25 september 1415","1360–1415":"1360–1415","1372–1393":"1372–1393","–Female":"Overleden","1393–1470":"1393–1470","1331–1368":"1331–1368","about 1393":"circa 1393","about 1360":"circa 1360","1372":"1372","1382":"1382","1470":"1470","1393":"1393","1360":"1360","about May 1397":"circa mei 1397","1415":"1415","Abt 1360":"circa 1360","1368":"1368","1331":"1331","25 September 1415":"25 september 1415","Pennington, Lancashire, England":"Pennington, Lancashire, England","Preston Richard, Westmorland, England":"Preston Richard, Westmorland, England","Lancashire, England":"Lancashire, England","England, United Kingdom":"Engeland, Verenigd Koninkrijk"},"en":{"Abt 1360–25 September 1415":"about 1360–25 September 1415","1360–1415":"1360–1415","1372–1393":"1372–1393","–Female":"Deceased","1393–1470":"1393–1470","1331–1368":"1331–1368","about 1393":"about 1393","about 1360":"about 1360","1372":"1372","1382":"1382","1470":"1470","1393":"1393","1360":"1360","about May 1397":"about May 1397","1415":"1415","Abt 1360":"about 1360","1368":"1368","1331":"1331","25 September 1415":"25 September 1415","Pennington, Lancashire, England":"Pennington, Lancashire, England","Preston Richard, Westmorland, England":"Preston Richard, Westmorland, England","Lancashire, England":"Lancashire, England","England, United Kingdom":"England, United Kingdom","nameMeanings":[{"name":"Pennington","type":"LAST","attribution":"Dictionary of American Family Names © Patrick Hanks 2003, 2006.","meanings":["English (mainly Lancashire and Cumbria):","habitational name from Pennington in Furness (Lancashire), which derives from Old English <i>pening</i> ‘penny’ + <i>tūn</i> ‘farmstead, estate’, or from Pennington in Leigh (Lancashire), which probably derives from the Old English personal name <i>Pinna</i> + the Old English groupname suffix <i>-ingas</i> (genitive <i>-inga-</i>) + Old English <i>tūn</i>.","habitational name from Pennington (Hampshire), or from Penton Grafton or Penton Mewsey (both Hampshire); see   Penton  . All have the same etymology as Pennington in Furness; see 1 above."],"variants":[{"name":"Penington","meanings":["English (Lancashire): variant of   Pennington  . This form of the surname is rare in Britain and Ireland.","History: Edward Penington, born in 1667 in Amersham, Buckinghamshire, England, was appointed surveyor-general of the province of PA in 1698 and accompanied William Penn to Philadelphia."]},{"name":"Penton","meanings":["English (mainly Hampshire):","habitational name from Penton Grafton or Penton Mewsey (both Hanmpshire), or from a shortened form of   Pennington   2. The placenames denoted a farm or estate for which a penny tax was payable (Old English <i>pening</i> ‘penny’ + <i>tūn</i>).","in north-west England, a shortened form of   Pennington   1, from either of the places called Pennington in Lancashire."]}]},{"name":"Alan","type":"FIRST","attribution":"Dictionary of First Names © Patrick Hanks and Flavia Hodges 1990, 2003, 2006.","meanings":["Of Celtic origin and uncertain derivation (possibly a diminutive of a word meaning ‘rock’). It was introduced into England by  Breton  followers of  William the Conqueror , most notably  Alan , Earl of Brittany, who was rewarded for his services with vast estates in the newly conquered kingdom. In Britain the variants  <b>Allan</b>  and  <b>Allen</b>  are considerably less frequent, and generally represent transferred uses of surname forms, whereas in America all three forms of the name are approximately equally common.  See also  Alun ."],"variants":[]}],"historicEvents":[{"id":1705195,"age":22,"year":"1382","julianDay":2225826,"title":"Wycliffe's Bible","description":"John Wycliffe, English theologian and professor at the University of Oxford, completed a translation of the Bible from the Latin Vulgate into Middle English. This translation is known as Wycliffe's Bible and was completed around 1382.","url":"https://en.wikipedia.org/wiki/Wycliffe%27s_Bible","urlTitle":"Wikipedia - Wycliffe's Bible","jurisdictionLevel":2}],"lifeSummary":"When Sir Alan Pennington was born about 1360, in Preston Richard, Westmorland, England, his father, Sir William Pennington, was 30 and his mother, Elizabeth Malton, was 30. He married Katherine Preston about 1393. They were the parents of at least 1 son. He died on 25 September 1415, in his hometown, at the age of 56."},"et":{"Abt 1360–25 September 1415":"umbes 1360–25. september 1415","1360–1415":"1360–1415","1372–1393":"1372–1393","–Female":"Surnud","1393–1470":"1393–1470","1331–1368":"1331–1368","about 1393":"umbes 1393","about 1360":"umbes 1360","1372":"1372","1382":"1382","1470":"1470","1393":"1393","1360":"1360","about May 1397":"umbes mai 1397","1415":"1415","Abt 1360":"umbes 1360","1368":"1368","1331":"1331","25 September 1415":"25. september 1415","Pennington, Lancashire, England":"Pennington, Lancashire, England","Preston Richard, Westmorland, England":"Preston Richard, Westmorland, England","Lancashire, England":"Lancashire, England","England, United Kingdom":"Inglismaa, United Kingdom"},"fi":{"Abt 1360–25 September 1415":"noin 1360–25. syyskuuta 1415","1360–1415":"1360–1415","1372–1393":"1372–1393","–Female":"Kuollut","1393–1470":"1393–1470","1331–1368":"1331–1368","about 1393":"noin 1393","about 1360":"noin 1360","1372":"1372","1382":"1382","1470":"1470","1393":"1393","1360":"1360","about May 1397":"noin toukokuu 1397","1415"