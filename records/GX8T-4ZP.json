ants":[{"name":"Koeller","meanings":["Some characteristic forenames:  German Klaus, Kurt, Reinhard, Wolfram.","German (<b>Köller</b>): see   Koller   1 and 3."]},{"name":"Kohler","meanings":["Some characteristic forenames:  German Kurt, Otto, Erwin, Hans, Fritz, Gunter, Heinz, Arno, Georg, Gerhard, Irmgard, Konrad.","German (also <b>Köhler</b>): occupational name for a charcoal burner, from Middle High German <i>kol</i> ‘(char)coal’ + the agent suffix <i>-er</i>. The form <i>Kohler</i> is typically South German. Compare   Koehler  .","Germanized form of Czech <b>Kolář</b>, Slovak <b>Kolár</b>, Sorbian <b>Kołaŕ</b>, <b>Kółaŕ</b>, and Slovenian and Croatian   Kolar   ‘wheelwright, cartwright’."]}]},{"name":"Claus","type":"FIRST","attribution":"Dictionary of First Names © Patrick Hanks and Flavia Hodges 1990, 2003, 2006.","meanings":["Variant spelling of   Klaus ."],"variants":[]},{"name":"von","type":"FIRST","attribution":"Dictionary of First Names © Patrick Hanks and Flavia Hodges 1990, 2003, 2006.","meanings":["Simplified spelling of   John   or a short form of   Jonathan .  The name is borne by the Canadian singer  Jon Vickers  (  b. 1926 ) and the American actor  Jon Voight  (  b. 1938 )."],"variants":[{"name":"Jonathan","meanings":["Biblical name, meaning ‘God has given’, composed of the same elements as those of   Matthew  , but in reverse order. This is the name of several characters in the Bible, most notably a son of King Saul, who was a devoted friend and supporter of the young David, even when David and Saul were themselves at loggerheads (1 Samuel 31; 2 Samuel 1:19–26). The name is often taken as symbolic of steadfast friendship and loyalty. Well-known bearers of the name include the Irish clergyman and writer  Jonathan Swift  (  1667-1745 ), British theatre director  Jonathan Miller  (  b. 1934 ), British actor  Jonathan Pryce  (  b. 1947 ), and British television presenter  Jonathan Ross  (  b. 1960 )."]},{"name":"Jonn","meanings":["Variant spelling of   Jon   or  <b>John</b> ."]},{"name":"John","meanings":["As a boy's name this represents a revival of Middle English <i>Jan</i>, a by‐form of   John  , or an adoption of the common European form with this spelling. As a girl's name it is a short form of names such as   Janet   and   Janice ."]}]}],"lifeSummary":"Claus von Kjoller was born before 1450, in Germany as the son of Rasmus Van Koller  Kjoller. He married Margarethe von Lepel in 1479. They were the parents of at least 5 sons. He died after 1500, in his hometown."},"et":{"before 1450–Aft 1500":"enne 1450–pärast 1500","1450–1500":"1450–1500","1465–1540":"1465–1540","1480–1530":"1480–1530","1480–1547":"1480–1547","1490–1568":"1490–1568","1500–1584":"1500–1584","1424–Male":"1424–Surnud","about 1480":"umbes 1480","Aft 1500":"pärast 1500","1450":"1450","1480":"1480","1490":"1490","1547":"1547","1568":"1568","1479":"1479","1424":"1424","1500":"1500","1465":"1465","circa 1480":"umbes 1480","Abt. 1500":"umbes 1500","1530":"1530","1584":"1584","1540":"1540","before 1450":"enne 1450","before 1490":"enne 1490","Pommern, Prussia, Germany":"Pommern, Preußen, Saksamaa","Pomerania, Prussia":"Pommern, Preußen, Saksamaa","Pommeren, Germany":"Saksamaa","Pomerania, Prussia, Germany":"Pommern, Preußen, Saksamaa","Scotland":"Scotland"},"fi":{"before 1450–Aft 1500":"ennen vuotta 1450–1500 jälkeen","1450–1500":"1450–1500","1465–1540":"1465–1540","1480–1530":"1480–1530","1480–1547":"1480–1547","1490–1568":"1490–1568","1500–1584":"1500–1584","1424–Male":"1424–Kuollut","about 1480":"noin 1480","Aft 1500":"1500 jälkeen","1450":"1450","1480":"1480","1490":"1490","1547":"1547","1568":"1568","1479":"1479","1424":"1424","1500":"1500","1465":"1465","circa 1480":"noin 1480","Abt. 1500":"noin 1500","1530":"1530","1584":"1584","1540":"1540","before 1450":"ennen vuotta 1450","before 1490":"ennen vuotta 1490","Pommern, Prussia, Germany":"Pommern, Preußen, Saksa","Pomerania, Prussia":"Pommern, Preußen, Saksa","Pommeren, Germany":"Saksa","Pomerani