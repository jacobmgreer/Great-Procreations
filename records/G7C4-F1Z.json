69","1334":"1334","1487":"1487","1420":"1420","after 1419":"na 1419","1430":"1430","1419":"1419","1406":"1406","1405":"1405","Leicestershire, England":"Leicestershire, England","England":"England","Bretton, Flintshire, Wales":"Bretton, Flintshire, Wales","Bretton, Flint, Wales":"Bretton, Flintshire, Wales, Verenigd Koninkrijk"},"en":{"1370–after 1419":"1370–after 1419","1370–1419":"1370–1419","1350–1405":"1350–1405","1382–1430":"1382–1430","1406–1487":"1406–1487","1420–Female":"1420–Deceased","1330–1369":"1330–1369","1334–Female":"1334–Deceased","about 1382":"about 1382","1330":"1330","1350":"1350","1382":"1382","1370":"1370","abt 1420":"about 1420","after 1369":"after 1369","1369":"1369","1334":"1334","1487":"1487","1420":"1420","after 1419":"after 1419","1430":"1430","1419":"1419","1406":"1406","1405":"1405","Leicestershire, England":"Leicestershire, England","England":"England","Bretton, Flintshire, Wales":"Bretton, Flintshire, Wales","Bretton, Flint, Wales":"Bretton, Flintshire, Wales, United Kingdom","nameMeanings":[{"name":"Skeffington","type":"LAST","attribution":"Dictionary of American Family Names © Patrick Hanks 2003, 2006.","meanings":["Some characteristic forenames:  Irish Fitzpatrick.","English: habitational name from Skeffington (Leicestershire), from an Old English personal name <i>Sceaft</i> + Old English connective <i>-ing-</i> + <i>tūn</i> ‘farmstead, estate’. The initial consonant <i>Sh-</i> was changed to <i>Sk-</i> due to Scandinavian influence. The surname was later brought to Ireland in 1529 by Sir William Skeffington, Lord Deputy of Ireland under Henry VIII."],"variants":[{"name":"Skiffington","meanings":["Some characteristic forenames:  Irish Aidan.","English and Scottish (Lanarkshire): variant of   Skeffington  ."]}]},{"name":"Rose","type":"FIRST","attribution":"Dictionary of First Names © Patrick Hanks and Flavia Hodges 1990, 2003, 2006.","meanings":["Ostensibly from the vocabulary word denoting the flower (Latin <i>rosa</i>). However, the name was in use throughout the Middle Ages, long before any of the other girls' names derived from flowers, which are generally of 19th-century origin. In part it may refer to the flower as a symbol of the Virgin Mary, but it seems more likely that it also has a Germanic origin, probably as a short form of various girls' names based on <i>hros</i> ‘horse’ or <i>hrōd</i> ‘fame’. The Latinate form <i>Rohesia</i> is commonly found in documents of the Middle Ages. As well as being a name in its own right, it is currently used as a short form of   Rosemary   and, less often (because of their different pronunciation), of other names beginning <i>Ros-</i>, such as   Rosalind   and   Rosamund ."],"variants":[]}],"historicEvents":[{"id":1705195,"age":12,"year":"1382","julianDay":2225826,"title":"Wycliffe's Bible","description":"John Wycliffe, English theologian and professor at the University of Oxford, completed a translation of the Bible from the Latin Vulgate into Middle English. This translation is known as Wycliffe's Bible and was completed around 1382.","url":"https://en.wikipedia.org/wiki/Wycliffe%27s_Bible","urlTitle":"Wikipedia - Wycliffe's Bible","jurisdictionLevel":1}],"lifeSummary":"When Rose Skeffington was born in 1370, in Leicestershire, England, her father, Lord John Skeffington of Bretton, was 41 and her mother, Mary of Clotsworthy, was 37. She had at least 3 daughters with Ralph de Holland. She died after 1419."},"et":{"1370–after 1419":"1370–pärast 1419","1370–1419":"1370–1419","1350–1405":"1350–1405","1382–1430":"1382–1430","1406–1487":"1406–1487","1420–Female":"1420–Surnud","1330–1369":"1330–1369","1334–Female":"1334–Surnud","about 1382":"umbes 1382","1330":"1330","1350":"1350","1382":"1382","1370":"1370","abt 1420":"umbes 1420","after 1369":"pärast 1369","1369":"1369","1334":"1334","1487":"1487","1420":"1420","after 1419":"pärast 1419","1430":"1430","1419":"1419","1406":"1406","1405":"1405","Leicestershire, England":"Leicestershire, England","England":