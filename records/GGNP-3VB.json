tney, Oxfordshire, England":"Witney, Oxfordshire, England","England":"England"},"en":{"about 1350–":"about 1350–Deceased","1340–1465":"1340–1465","1375–1415":"1375–1415","1350–Male":"1350–Deceased","1415":"1415","1455":"1455","1465":"1465","1375":"1375","1340":"1340","1350":"1350","1382":"1382","abt 1375":"about 1375","about 1350":"about 1350","Witney, Oxfordshire, England":"Witney, Oxfordshire, England","England":"England","nameMeanings":[{"name":"Fermore","type":"LAST","attribution":"Dictionary of Family Names in Britain and Ireland © University of the West of England 2016","meanings":["English:  see  Farmer  ."],"variants":[{"name":"Farmer","meanings":["English: occupational name from Middle English <i>fermo(u)r</i>, <i>fermer</i> and Anglo-Norman French <i>fermer</i> (Old French <i>fermier</i>, medieval Latin <i>firmarius</i>). The term denoted in the first instance a tax farmer, one who undertook the collection of taxes, revenues, and imposts, paying a fixed (Latin <i>firmus</i>) sum for the proceeds, and only secondarily someone who rented land for the purpose of cultivation; it was not applied to an owner of cultivated land before the 17th century.","Irish: Anglicized (part translated) form of Gaelic <b>Mac an Scolóige</b> ‘son of the husbandman’, a rare surname of northern and western Ireland.","Americanized form (translation into English) of French   Terrien   ‘owner of a farmland’ or of its altered form   Therrien  . Compare   Pharmer  ."]}]},{"name":"Henry","type":"FIRST","attribution":"Dictionary of First Names © Patrick Hanks and Flavia Hodges 1990, 2003, 2006.","meanings":["A perennially popular given name, of Continental Germanic origin, from <i>haim</i> ‘home’ + <i>rīc</i> ‘power, ruler’. It was an Old French name, adopted by the Normans and introduced by them to Britain. It has been borne by eight kings of England. Not until the 17th century did the form <i>Henry</i> (as opposed to   Harry  ) become the standard vernacular form, mainly under the influence of the Latin form <i>Henricus</i> and French <i>Henri</i>."],"variants":[]}],"historicEvents":[{"id":1705195,"age":32,"year":"1382","julianDay":2225826,"title":"Wycliffe's Bible","description":"John Wycliffe, English theologian and professor at the University of Oxford, completed a translation of the Bible from the Latin Vulgate into Middle English. This translation is known as Wycliffe's Bible and was completed around 1382.","url":"https://en.wikipedia.org/wiki/Wycliffe%27s_Bible","urlTitle":"Wikipedia - Wycliffe's Bible","jurisdictionLevel":2},{"id":1705197,"age":105,"year":"1455","julianDay":2252488,"title":"Wars of the Roses","description":"Wars of the Roses was a series of English civil wars for control of the throne of England between the royal families House of Lancaster and the House of York. The name of the war was derived as the red rose was the symbol of the Lancastrians and the white rose was the symbol of the Yorks.","url":"https://www.history.com/topics/british-history/wars-of-the-roses","urlTitle":"History - Wars of the Roses","jurisdictionLevel":2}],"lifeSummary":"Henry Fermore was born about 1350, in Witney, Oxfordshire, England. He had at least 1 son with Agnes Whitney Fermor Langford. He died in his hometown."},"et":{"about 1350–":"umbes 1350–Surnud","1340–1465":"1340–1465","1375–1415":"1375–1415","1350–Male":"1350–Surnud","1415":"1415","1455":"1455","1465":"1465","1375":"1375","1340":"1340","1350":"1350","1382":"1382","abt 1375":"umbes 1375","about 1350":"umbes 1350","Witney, Oxfordshire, England":"Witney, Oxfordshire, England","England":"England"},"fi":{"about 1350–":"noin 1350–Kuollut","1340–1465":"1340–1465","1375–1415":"1375–1415","1350–Male":"1350–Kuollut","1415":"1415","1455":"1455","1465":"1465","1375":"1375","1340":"1340","1350":"1350","1382":"1382","abt 1375":"noin 1375","about 1350":"noin 1350","Witney, Oxfordshire, England":"Witney, Oxfordshire, England","England":"England"},"fr":{"about 1350–":"environ 1350–Décédé","1340–1465":