260–1298","1265–1290":"1265–1290","1385":"1385","1383":"1383","1295":"1295","1382":"1382","1260":"1260","1290":"1290","1415":"1415","1315":"1315","1325":"1325","January 1298":"januari 1298","1322":"1322","1265":"1265","1298":"1298","1320":"1320","1386":"1386","23 April 1320":"23 april 1320","March 1386":"maart 1386","18 March 1385":"18 maart 1385","about 1322":"circa 1322","1328":"1328","1317":"1317","Bedfordshire, England, United Kingdom":"Bedfordshire, Engeland, Verenigd Koninkrijk","Bedfordshire, England":"Bedfordshire, England","Chalgrave, Bedfordshire, England":"Chalgrave, Bedfordshire, England"},"en":{"1290–March 1386":"1290–March 1386","1290–1386":"1290–1386","1295–Female":"1295–Deceased","1320–1385":"1320–1385","1320–1386":"1320–1386","1322–1415":"1322–1415","1325–1383":"1325–1383","1260–1298":"1260–1298","1265–1290":"1265–1290","1385":"1385","1383":"1383","1295":"1295","1382":"1382","1260":"1260","1290":"1290","1415":"1415","1315":"1315","1325":"1325","January 1298":"January 1298","1322":"1322","1265":"1265","1298":"1298","1320":"1320","1386":"1386","23 April 1320":"23 April 1320","March 1386":"March 1386","18 March 1385":"18 March 1385","about 1322":"about 1322","1328":"1328","1317":"1317","Bedfordshire, England, United Kingdom":"Bedfordshire, England, United Kingdom","Bedfordshire, England":"Bedfordshire, England","Chalgrave, Bedfordshire, England":"Chalgrave, Bedfordshire, England","nameMeanings":[{"name":"Loring","type":"LAST","attribution":"Dictionary of American Family Names © Patrick Hanks 2003, 2006.","meanings":["English: ethnic name from Old French <i>Lohereng</i> ‘man fromLorraine’ (see   Lorraine  )."],"variants":[{"name":"Lorne","meanings":["Scottish: habitational name from the district of Lorn (Argyll).","English: perhaps a shortened form of   Loring  , a surname which is well evidenced in medieval southwestern England, where <i>Lorne</i> is later recorded."]},{"name":"Lorraine","meanings":["Some characteristic forenames:  French Armand, Emile, Perrine, Pierre.","French and English: habitational name from Lorraine, a region in the northeastern part of France. Its name derives from the name of the medieval kingdom of Lotharingia, which in turn was named for its sovereign <i>Lothar</i> (a personal name composed of the elements <i>hlūd</i> ‘famous, renowned’ + <i>hari</i>, <i>heri</i> ‘army’).","Altered form of French   Lorrain  , a variant of 1 above."]}]},{"name":"Roger","type":"FIRST","attribution":"Dictionary of First Names © Patrick Hanks and Flavia Hodges 1990, 2003, 2006.","meanings":["From an Old French personal name, <i>Rog(i)er</i>, of Germanic (Frankish) origin, from <i>hrōd</i> ‘fame’ + <i>gār</i>, <i>gēr</i> ‘spear’. This was adopted by the Normans and introduced by them to Britain, replacing the native Old English form <i>Hrōðgār</i>. <i>Roger</i> was one of the most popular boys' names throughout the medieval period, but less so after the Reformation, though it has continued in regular use to the present day.  Roger, Count of Sicily  (  <i>c.</i>1031–1101 ), son of Tancred, recovered Sicily from the Arabs. His son, also called Roger, ruled Sicily as king, presiding over a court noted for its splendour and patronage of the arts."],"variants":[{"name":"Rodger","meanings":["Variant spelling of   Roger  , in part from the surname derived from the given name in the Middle Ages."]}]}],"historicEvents":[{"id":1705190,"age":0,"year":"1290","julianDay":2192224,"title":"Jews Expelled From England","description":"After years of anti-Semitic behavior, King Edward I expelled Jews from England in 1290.","jurisdictionLevel":1},{"id":1705191,"age":25,"year":"1315","toYear":"1317","julianDay":2201354,"title":"Famine Strikes Europe","description":"A famine caused by cold winters and wet summers across Europe caused millions to die due to starvation. Desperation from hunger caused high levels of crime, stampedes in bread lines in London, infanticide, and even cannibalism throughout Europe.","jurisdictionLevel":1},{"id":1705192,"age":38,"year":"1328","julianDay":2206102,"title":"First War of Scottish Independence","description":"The First War of Scottish Independence began after England invaded Scotland in 1296. The Treaty of Edinburgh was signed in 1328 which declared peace between the two kingdoms and brought the war to an end.","jurisdictionLevel":1},{"id":1705195,"age":92,"year":"1382","julianDay":2225826,"title":"Wycliffe's Bible","description":"John Wycliffe, English theologian and professor at the University of Oxford, completed a translation of the Bible from the Latin Vulgate into Middle English. This translation is known as Wycliffe's Bible and was completed around 1382.","url":"https://en.wikipedia.org/wiki/Wycliffe%27s_Bible","urlTitle":"Wikipedia - Wycliffe's Bible","jurisdictionLevel":1}],"lifeSummary":"When Roger Loring was born in 1290, in Bedfordshire, England, his father, Peter Loring, was 30 and his mother, Jane Morteyn, was 26. He had at least 4 sons with Cassandra Perrott. He died in March 1386, in his hometown, at the age of 96."},"et":{"1290–March 1386":"1290–märts 1386","1290–1386":"1290–1386","1295–Female":"1295–Surnud","1320–1385":"1320–1385","1320–1386":"1320–1386","1322–1415":"1322–1415","1325–1383":"1325–1383","1260–1298":"1260–1298","1265–1290":"1265–1290","1385":"1385","1383":"1383","1295":"1295","1382":"1382","1260":"1260","1290":"1290","1415":"1415","1315":"1315","1325":"1325","January 1298":"jaanuar 1298","1322":"1322","1265":"1265","1298":"1298","1320":"1320","1386":"1386","23 April 1320":"23. aprill 1320","March 1386":"märts 1386","18 March 1385":"18. märts 1385","about 1322":"umbes 1322","1328":"1328","1317":"1317","Bedfordshire, England, United Kingdom":"Bedfordshire, Inglismaa, United Kingdom","Bedfordshire, England":"Bedfordshire, England","Chalgrave, Bedfordshire, England":"Chalgrave, Bedfordshire, England"},"fi":{"1290–March 1386":"1290–maaliskuu 1386","1290–1386":"1290–1386","1295–Female":"1295–Kuollut","1320–1385":"1320–1385","13