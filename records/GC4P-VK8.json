ale":"1010–Overleden","1104":"1104","1049":"1049","1125":"1125","1065":"1065","1087":"1087","1010":"1010","1040":"1040","1070":"1070","Château-Porcien, Ardennes, Champagne-Ardenne, France":"Château-Porcien, Ardennes, Champagne-Ardenne, Frankrijk"},"en":{"1040–1087":"1040–1087","1049–1125":"1049–1125","1070–1104":"1070–1104","1010–1065":"1010–1065","1010–Female":"1010–Deceased","1104":"1104","1049":"1049","1125":"1125","1065":"1065","1087":"1087","1010":"1010","1040":"1040","1070":"1070","Château-Porcien, Ardennes, Champagne-Ardenne, France":"Château-Porcien, Ardennes, Champagne-Ardenne, France","nameMeanings":[{"name":"de","type":"LAST","attribution":"Dictionary of American Family Names © Patrick Hanks 2003, 2006.","meanings":["Some characteristic forenames:  Indian Dilip, Anirban, Gopal, Alok, Anindya, Arunava, Asit, Asok, Dibyendu, Goutam, Indra, Indranil.","Indian: variant of   Dey  ."],"variants":[{"name":"Dey","meanings":["Some characteristic forenames:  Indian Ashit, Indu, Naina, Partha, Soumya, Ajit, Anjan, Anjana, Anup, Arjun, Arun, Ashim.","English, Scottish, and Welsh: variant of   Day  .","German: topographic name from a field name in North Rhine-Westphalia, denoting a sizeable piece of land, from Middle Low German <i>dē</i> ‘thigh’ (referring to the shape of the property)."]}]},{"name":"Roger","type":"FIRST","attribution":"Dictionary of First Names © Patrick Hanks and Flavia Hodges 1990, 2003, 2006.","meanings":["From an Old French personal name, <i>Rog(i)er</i>, of Germanic (Frankish) origin, from <i>hrōd</i> ‘fame’ + <i>gār</i>, <i>gēr</i> ‘spear’. This was adopted by the Normans and introduced by them to Britain, replacing the native Old English form <i>Hrōðgār</i>. <i>Roger</i> was one of the most popular boys' names throughout the medieval period, but less so after the Reformation, though it has continued in regular use to the present day.  Roger, Count of Sicily  (  <i>c.</i>1031–1101 ), son of Tancred, recovered Sicily from the Arabs. His son, also called Roger, ruled Sicily as king, presiding over a court noted for its splendour and patronage of the arts."],"variants":[{"name":"Rodger","meanings":["Variant spelling of   Roger  , in part from the surname derived from the given name in the Middle Ages."]}]}],"lifeSummary":"When Comte de Château-Porcéan Roger de Porcien was born in 1040, in Château-Porcien, Ardennes, Champagne-Ardenne, France, his father, Rainald Château-Du-Loir, was 30 and his mother, Aelis Rethel, was 30. He had at least 1 daughter with Ermengarde de Bourbon. He died in 1087, in his hometown, at the age of 47."},"et":{"1040–1087":"1040–1087","1049–1125":"1049–1125","1070–1104":"1070–1104","1010–1065":"1010–1065","1010–Female":"1010–Surnud","1104":"1104","1049":"1049","1125":"1125","1065":"1065","1087":"1087","1010":"1010","1040":"1040","1070":"1070","Château-Porcien, Ardennes, Champagne-Ardenne, France":"Château-Porcien, Ardennes, Champagne-Ardenne, Prantsusmaa"},"fi":{"1040–1087":"1040–1087","1049–1125":"1049–1125","1070–1104":"1070–1104","1010–1065":"1010–1065","1010–Female":"1010–Kuollut","1104":"1104","1049":"1049","1125":"1125","1065":"1065","1087":"1087","1010":"1010","1040":"1040","1070":"1070","Château-Porcien, Ardennes, Champagne-Ardenne, France":"Château-Porcien, Ardennes, Champagne-Ardenne, Ranska"},"fr":{"1040–1087":"1040–1087","1049–1125":"1049–1125","1070–1104":"1070–1104","1010–1065":"1010–1065","1010–Female":"1010–Décédée","1104":"1104","1049":"1049","1125":"1125","1065":"1065","1087":"1087","1010":"1010","1040":"1040","1070":"1070","Château-Porcien, Ardennes, Champagne-Ardenne, France":"Château-Porcien, Ardennes, Champagne-Ardenne, France","lifeSummary":"Lorsque Comte de Château-Porcéan Roger de Porcien est né en 1040, à Château-Porcien, Ardennes, Champagne-Ardenne, France, son père, Rainald Château-Du-Loir, avait 30 ans et sa mère, Aelis Rethel, avait 30 ans. Il a eu au moins 1 fille avec Ermengarde de Bourbon. Il est décédé en 1087, dans sa ville natale, à l’âge de 47 ans.