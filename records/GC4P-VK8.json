{"version":"1.2","person":{"datePublished":"2024-01-05","name":"Comte de Château-Porcéan Roger de Porcien","nameForms":[{"lang":"en","fullText":"Comte de Château-Porcéan Roger de Porcien","parts":[{"type":"http://gedcomx.org/Prefix","value":"Comte de Château-Porcéan"},{"type":"http://gedcomx.org/Given","value":"Roger"},{"type":"http://gedcomx.org/Surname","value":"de Porcien"}],"order":"EUROTYPIC"}],"alternateName":"Roger de Porcien","gender":"Male","lifespan":"1040–1087","fullLifespan":"1040–1087","portrait":{"url":"https://tree-portraits-pgp.familysearchcdn.org/5q50m/thumb200s.jpg","@type":"ImageObject"},"memoryArtifacts":[{"memoryType":"DOCUMENT","url":"https://sg30p0.familysearch.org/service/records/storage/dascloud/patron/v2/TH-7724-114569-247-30/dist.pdf?ctx=ArtCtxPublic","memoryUrl":"https://www.familysearch.org/photos/artifacts/142128278","thumbnailUrl":"https://sg30p0.familysearch.org/service/records/storage/dascloud/patron/v2/TH-7724-114569-247-30/thumb200s.jpg?ctx=ArtCtxPublic","headline":"Renaud and Roger de Porcien, Comtes de Porcien in the Foundation for Medieval Genealogy","description":"Renaud and Roger de Porcien, Comtes de Porcien in the Foundation for Medieval Genealogy\n~https://fmg.ac/Projects/MedLands/champorret.htm#SibyllePorcienM1GodefroiNamurM2GuitierRe","@type":"ImageObject"}],"birthDate":"+1040","birthPlace":{"address":"Château-Porcien, Ardennes, Champagne-Ardenne, France","geo":{"latitude":49.5297,"longitude":4.2443,"@type":"GeoCoordinates"},"@type":"Place"},"deathDate":"+1087","deathPlace":{"address":"Château-Porcien, Ardennes, Champagne-Ardenne, France","geo":{"latitude":49.5297,"longitude":4.2443,"@type":"GeoCoordinates"},"@type":"Place"},"userCertifiedLifeSummary":"«b»Biography«/b»\nRoger de Porcien, comte de Porcien, was the son of Renaud de Porcien and his wife Aelis. He was married to Ermengarde (parentage unknown). \"Rogerus comes Porcensis territorii\" founded the priory of Château-Porcien and donated it to the abbey of Saint-Hubert, Ardenne, for the souls of \"Ermengardis uxoris mee et filie mee Sibilie\", by charter dated 1087. After his death, Henri Comte de Grandpré inherited part of his assets, which became the fief of Château-Porcien.","sourceList":[{"title":"Renaud and Roger de Porcien, Comtes de Porcien in the Foundation for Medieval Genealogy ~https://fmg.ac/Projects/MedLands/champorret.htm#SibyllePorcienM1GodefroiNamurM2GuitierRe [See document in the Memories section]","sourceType":"USER_UPLOADED","sourceLink":"http://familysearch.org/patron/source/photoId/142128278","sourceUri":"3JYJ-JSM"},{"title":"Godefroi, Comte de Namur, and Ermensinde de Luxembourg in the Foundation for Medieval Genealogy ~https://fmg.ac/Projects/MedLands/NAMUR.htm#Godefroidied1139 [See document in the Memories section]","sourceType":"USER_UPLOADED","sourceLink":"http://familysearch.org/patron/source/photoId/120710287","sourceUri":"3JTN-4J3"},{"title":"Porcien","sourceType":"DEFAULT","sourceLink":"http://fmg.ac/Projects/MedLands/champorret.htm#SibyllePorcienM1GodefroiNamurM2GuitierRe","sourceUri":"9KZN-3NF"}],"events":[{"name":"Birth","sources":"0","year":"1040","date":"1040","place":"Château-Porcien, Ardennes, Champagne-Ardenne, France"},{"name":"Death of Parent","sources":"0","year":"1065","date":"1065","age":"25","id":"GD5N-8XB"},{"name":"Birth of Child","sources":"0","year":"1070","date":"1070","place":"Château-Porcien, Ardennes, Champagne-Ardenne, France","age":"30","id":"K8LH-9LJ"},{"name":"Death","sources":"0","year":"1087","date":"1087","place":"Château-Porcien, Ardennes, Champagne-Ardenne, France","age":"47"}],"parent":[{"name":"Rainald Château-Du-Loir","gender":"Male","lifespan":"1010–1065","birthDate":"+1010","deathDate":"+1065","age":55,"portrait":{"url":"https://tree-portraits-pgp.familysearchcdn.org/eq50m/thumb64.jpg","@type":"ImageObject"},"@type":"Person","identifier":"GD5N-8XB","url":"https://ancestors.familysearch.org/en/GD5N-8XB/rainald-ch%C3%A2teau-du-loir-1010-1065","published":true},{"n