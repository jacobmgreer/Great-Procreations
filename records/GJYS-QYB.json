dom","Haigh Manor, Lancashire, England":"Haigh, Lancashire, Anglie, United Kingdom"},"da":{"1402–1462":"1402–1462","1408–1446":"1408–1446","1368–1426":"1368–1426","1426–1511":"1426–1511","1340–Male":"1340–Afdød","1380–Female":"1380–Afdød","12 Jul 1426":"12. juli 1426","1462":"1462","1340":"1340","1380":"1380","1426":"1426","1425":"1425","1402":"1402","1446":"1446","1511":"1511","1368":"1368","1455":"1455","8 November 1446":"8. november 1446","1408":"1408","Haigh, Lancashire, England":"Haigh, Lancashire, England, United Kingdom","Bracewell, Yorkshire, England, United Kingdom":"Bracewell, Jórvík, England, United Kingdom","Haigh Manor, Lancashire, England":"Haigh, Lancashire, England, United Kingdom"},"nl":{"1402–1462":"1402–1462","1408–1446":"1408–1446","1368–1426":"1368–1426","1426–1511":"1426–1511","1340–Male":"1340–Overleden","1380–Female":"1380–Overleden","12 Jul 1426":"12 juli 1426","1462":"1462","1340":"1340","1380":"1380","1426":"1426","1425":"1425","1402":"1402","1446":"1446","1511":"1511","1368":"1368","1455":"1455","8 November 1446":"8 november 1446","1408":"1408","Haigh, Lancashire, England":"Haigh, Lancashire, Engeland, Verenigd Koninkrijk","Bracewell, Yorkshire, England, United Kingdom":"Bracewell, Yorkshire, Engeland, Verenigd Koninkrijk","Haigh Manor, Lancashire, England":"Haigh, Lancashire, Engeland, Verenigd Koninkrijk"},"en":{"1402–1462":"1402–1462","1408–1446":"1408–1446","1368–1426":"1368–1426","1426–1511":"1426–1511","1340–Male":"1340–Deceased","1380–Female":"1380–Deceased","12 Jul 1426":"12 July 1426","1462":"1462","1340":"1340","1380":"1380","1426":"1426","1425":"1425","1402":"1402","1446":"1446","1511":"1511","1368":"1368","1455":"1455","8 November 1446":"8 November 1446","1408":"1408","Haigh, Lancashire, England":"Haigh, Lancashire, England, United Kingdom","Bracewell, Yorkshire, England, United Kingdom":"Bracewell, Yorkshire, England, United Kingdom","Haigh Manor, Lancashire, England":"Haigh, Lancashire, England, United Kingdom","nameMeanings":[{"name":"Sherburne","type":"LAST","attribution":"Dictionary of American Family Names © Patrick Hanks 2003, 2006.","meanings":["English (Lancashire): habitational name from any of several places called with Old English <i>scīr</i> ‘bright, clear’ + <i>burna</i> ‘stream’, including Sherburn in Elmet (Yorkshire), Sherburn (East Yorkshire, Durham), Shirburn (Oxfordshire), Sherborne (Dorset, Gloucestershire), Sherborne Saint John, Monk Sherborne (Hampshire), Sherbourne (Warwickshire), Sherbourne in Albury (Surrey), and Sherborne in Litton (Somerset). This surname is now rare in Britain."],"variants":[{"name":"Sherburn","meanings":["English: variant of   Sherburne  ."]},{"name":"Sherbon","meanings":["English: variant of   Sherburne   with loss of the second <i>-r-</i> by dissimilation. This form of the surname is now rare in Britain."]}]},{"name":"Alice","type":"FIRST","attribution":"Dictionary of First Names © Patrick Hanks and Flavia Hodges 1990, 2003, 2006.","meanings":["Originally a variant of   Adelaide  , representing an Old French spelling of a reduced form of Germanic <i>Adalheidis</i>. <i>Alice</i> and <i>Adelaide</i> were already regarded as distinct names in English during the medieval period. <i>Alice</i> enjoyed a surge of popularity in the 19th century and periods of favour ever since. It was the name of the central character of  Lewis Carroll's  Alice's Adventures in Wonderland (  1865 ) and Through the Looking Glass (  1872 ), who was based on his child friend  Alice Liddell , daughter of the Dean of Christ Church, Oxford."],"variants":[{"name":"Alys","meanings":["Variant spelling of   Alice ."]},{"name":"Alis","meanings":["equivalent of <b>Alice</b> ."]}]}],"historicEvents":[{"id":1705197,"age":53,"year":"1455","julianDay":2252488,"title":"Wars of the Roses","description":"Wars of the Roses was a series of English civil wars for control of the throne of England between the royal families House of Lancaster and the House of York. The name of the war was derived as the red rose was the symbol of the Lancastrians and the white rose was the symbol of the Yorks.","url":"https://www.history.com/topics/british-history/wars-of-the-roses","urlTitle":"History - Wars of the Roses","jurisdictionLevel":2}],"lifeSummary":"When Alice Sherburne was born in 1402, in Haigh, Lancashire, England, her father, Sir William Sherburne, was 62 and her mother, Agnes Harington, was 22. She married Thomas Bradshaw in 1425. They were the parents of at least 1 daughter. She died in 1462, in Bracewell, Yorkshire, England, United Kingdom, at the age of 60."},"et":{"1402–1462":"1402–1462","1408–1446":"1408–1446","1368–1426":"1368–1426","1426–1511":"1426–1511","1340–Male":"1340–Surnud","1380–Female":"1380–Surnud","12 Jul 1426":"12. juuli 1426","1462":"1462","1340":"1340","1380":"1380","1426":"1426","1425":"1425","1402":"1402","1446":"1446","1511":"1511","1368":"1368","1455":"1455","8 November 1446":"8. november 1446","1408":"1408","Haigh, Lancashire, England":"Haigh, Lancashire, Inglismaa, United Kingdom","Bracewell, Yorkshire, England, United Kingdom":"Bracewell, Yorkshire, Inglismaa, United Kingdom","Haigh Manor, Lancashire, England":"Haigh, Lancashire, Inglismaa, United Kingdom"},"fi":{"1402–1462":"1402–1462","1408–1446":"1408–1446","1368–1426":"1368–1426","1426–1511":"1426–1511","1340–Male":"1340–Kuollut","1380–Female":"1380–Kuollut","12 Jul 1426":"12. heinäkuuta 1426","1462":"1462","1340":"1340","1380":"1380","1426":"1426","1425":"1425","1402":"1402","1446":"1446","1511":"1511","1368":"1368","1455":"1455","8 November 1446":"8. marraskuuta 1446","1408":"1408","Haigh, Lancashire, England":"Haigh, Lancashire, Englanti, Yhdistynyt kuningaskunta","Bracewell, Yorkshire, England, United Kingdom":"Bracewell, Yorkshire, Englanti, Yhdistynyt kuningaskunta","Haigh Manor, Lancashire, England":"Haigh, Lancashire, Englanti, Yhdistynyt kuningaskunta"},"fr":{"1402–1462":"1402–1462","1408–1446":"1408–1446","1368–1426":"1368–1426","1426–1511":"1426–1511","1340