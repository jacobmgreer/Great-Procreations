anings":["Spanish: ethnic name from <i>flamenco</i> ‘Fleming, Flemish person’ (see   Fleming  )."]}]},{"name":"John","type":"FIRST","meanings":["Greek: the Lord gave graciously; whom Jehovah gave; whom Jehovah bestowed."],"variants":[]}],"lifeSummary":"John Fleming I was born about 1180, in Yorkshire, England, United Kingdom as the son of Reiner Fleming II. He had at least 1 son. He died before 1251, in his hometown."},"et":{"Abt 1180–Bef 1251":"umbes 1180–enne 1251","1180–1251":"1180–1251","–1228":"–1228","–1234":"–1234","1219–1274":"1219–1274","1140–1205":"1140–1205","1228":"1228","Bef 1251":"enne 1251","1205":"1205","1234":"1234","Bef 1205":"enne 1205","1274":"1274","1251":"1251","1140":"1140","Abt 1180":"umbes 1180","1219":"1219","1180":"1180","Yorkshire, England":"Yorkshire, Inglismaa, United Kingdom"},"fi":{"Abt 1180–Bef 1251":"noin 1180–ennen vuotta 1251","1180–1251":"1180–1251","–1228":"–1228","–1234":"–1234","1219–1274":"1219–1274","1140–1205":"1140–1205","1228":"1228","Bef 1251":"ennen vuotta 1251","1205":"1205","1234":"1234","Bef 1205":"ennen vuotta 1205","1274":"1274","1251":"1251","1140":"1140","Abt 1180":"noin 1180","1219":"1219","1180":"1180","Yorkshire, England":"Yorkshire, Englanti, Yhdistynyt kuningaskunta"},"fr":{"Abt 1180–Bef 1251":"environ 1180–avant 1251","1180–1251":"1180–1251","–1228":"–1228","–1234":"–1234","1219–1274":"1219–1274","1140–1205":"1140–1205","1228":"1228","Bef 1251":"avant 1251","1205":"1205","1234":"1234","Bef 1205":"avant 1205","1274":"1274","1251":"1251","1140":"1140","Abt 1180":"environ 1180","1219":"1219","1180":"1180","Yorkshire, England":"Everwyck, Angleterre, Royaume-Uni","lifeSummary":"John Fleming I est né environ 1180, à Everwyck, Angleterre, Royaume-Uni, fils de Reiner Fleming II. Il a eu au moins 1 fils. Il est décédé avant 1251, dans sa ville natale."},"de":{"Abt 1180–Bef 1251":"um 1180–vor 1251","1180–1251":"1180–1251","–1228":"–1228","–1234":"–1234","1219–1274":"1219–1274","1140–1205":"1140–1205","1228":"1228","B