, Sussex, England":"英国素可韋斯特 費爾","Sussex, England, United Kingdom":"英国英格兰素可","lifeSummary":"当John St. Claire于大约1300年出生在英国英格兰奧可福爾爾本时，他的父亲John St. Claire31岁，母亲Alice St. Philabert23岁。他与Isolda Aldham of West Firle结婚。他们至少是1个儿子的父母。他去世于1327年在英国素可韋斯特 費爾享年28岁。"},"hr":{"about 1300–1327":"oko 1300.–1327.","1300–1327":"1300–1327.","1302–Female":"1302.–preminula","1310–Female":"1310–preminula","1326–1389":"1326–1389","1330–1387":"1330–1387","1270–1329":"1270–1329","1278–1302":"1278–1302.","1330":"1330","1270":"1270","1327":"1327.","1315":"1315","1326":"1326","1302":"1302.","1389":"1389","1278":"1278","1300":"1300","1387":"1387","1310":"1310","about 1326":"oko 1326.","about 1300":"oko 1300.","1329":"1329","1317":"1317","Shirburn, Oxfordshire, England":"Shirburn, Oxfordshire, Engleska, United Kingdom","England":"England","West Firle, Sussex, England":"West Firle, Sussex, England","Sussex, England, United Kingdom":"Sussex, Engleska, United Kingdom"},"cs":{"about 1300–1327":"okolo 1300–1327","1300–1327":"1300–1327","1302–Female":"1302–Zesnulá","1310–Female":"1310–Zesnulá","1326–1389":"1326–1389","1330–1387":"1330–1387","1270–1329":"1270–1329","1278–1302":"1278–1302","1330":"1330","1270":"1270","1327":"1327","1315":"1315","1326":"1326","1302":"1302","1389":"1389","1278":"1278","1300":"1300","1387":"1387","1310":"1310","about 1326":"okolo 1326","about 1300":"okolo 1300","1329":"1329","1317":"1317","Shirburn, Oxfordshire, England":"Shirburn, Oxfordshire, Anglie, United Kingdom","England":"Anglie","West Firle, Sussex, England":"West Firle, Sussex, Anglie","Sussex, England, United Kingdom":"Sussex, Anglie, United Kingdom"},"da":{"about 1300–1327":"omkring 1300–1327","1300–1327":"1300–1327","1302–Female":"1302–Afdød","1310–Female":"1310–Afdød","1326–1389":"1326–1389","1330–1387":"1330–1387","1270–1329":"1270–1329","1278–1302":"1278–1302","1330":"1330","1270":"1270","1327":"1327","1315":"1315","1326":"1326","1302":"1302","1389":"1389","1278":"1278","1300":"1300","1387":"1387","1310":"1310",