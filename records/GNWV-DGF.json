:"1104–1175","1100–1136":"1100–1136","1190":"1190","1104":"1104","1136":"1136","1125":"1125","1100":"1100","1153":"1153","1175":"1175","Abt 1125":"omkring 1125","1150":"1150","1194":"1194","Pitney, South Somerset, Somerset, England, United Kingdom":"Pitney, Somerset, England, United Kingdom","Pitney, Somerset, England, United Kingdom":"Pitney, Somerset, England, United Kingdom","Pitney, Somerset, England":"Pitney, Somerset, England"},"nl":{"Abt 1125–1190":"circa 1125–1190","1125–1190":"1125–1190","1150–1194":"1150–1194","1153–Female":"1153–Overleden","1104–1175":"1104–1175","1100–1136":"1100–1136","1190":"1190","1104":"1104","1136":"1136","1125":"1125","1100":"1100","1153":"1153","1175":"1175","Abt 1125":"circa 1125","1150":"1150","1194":"1194","Pitney, South Somerset, Somerset, England, United Kingdom":"Pitney, Somerset, Engeland, Verenigd Koninkrijk","Pitney, Somerset, England, United Kingdom":"Pitney, Somerset, Engeland, Verenigd Koninkrijk","Pitney, Somerset, England":"Pitney, Somerset, England"},"en":{"Abt 1125–1190":"about 1125–1190","1125–1190":"1125–1190","1150–1194":"1150–1194","1153–Female":"1153–Deceased","1104–1175":"1104–1175","1100–1136":"1100–1136","1190":"1190","1104":"1104","1136":"1136","1125":"1125","1100":"1100","1153":"1153","1175":"1175","Abt 1125":"about 1125","1150":"1150","1194":"1194","Pitney, South Somerset, Somerset, England, United Kingdom":"Pitney, Somerset, England, United Kingdom","Pitney, Somerset, England, United Kingdom":"Pitney, Somerset, England, United Kingdom","Pitney, Somerset, England":"Pitney, Somerset, England","nameMeanings":[{"name":"Reynell","type":"LAST","attribution":"Dictionary of Family Names in Britain and Ireland © University of the West of England 2016","meanings":["Norman, English:  see  Reynold  ."],"variants":[{"name":"Reynold","meanings":["English (of Norman origin): from the Anglo-Norman French and Middle English personal name <i>Reinald</i>, <i>Reynaud</i> (ancient Germanic <i>Raginald</i>, from <i>ragin</i>