, at the age of 18."},"et":{"1430–1448":"1430–1448","1423–1470":"1423–1470","1447–Female":"1447–Surnud","1448–1532":"1448–1532","1451–Female":"1451–Surnud","1453–Male":"1453–Surnud","1408–1461":"1408–1461","1412–1430":"1412–1430","before 1447":"enne 1447","1451":"1451","1461":"1461","1470":"1470","1448":"1448","1447":"1447","1412":"1412","1423":"1423","1532":"1532","1453":"1453","1430":"1430","after 1430":"pärast 1430","1408":"1408","Durham, Durham, England":"Durham, Durham, England","Cambridge, Cambridgeshire, England":"Cambridge, Cambridgeshire, England","London, England":"London, England","Manor, Yorkshire, England":"Manor, Yorkshire, England"},"fi":{"1430–1448":"1430–1448","1423–1470":"1423–1470","1447–Female":"1447–Kuollut","1448–1532":"1448–1532","1451–Female":"1451–Kuollut","1453–Male":"1453–Kuollut","1408–1461":"1408–1461","1412–1430":"1412–1430","before 1447":"ennen vuotta 1447","1451":"1451","1461":"1461","1470":"1470","1448":"1448","1447":"1447","1412":"1412","1423":"1423","1532":"1532","1453":"1453","1430":"1430","after 1430":"1430 jälkeen","1408":"1408","Durham, Durham, England":"Durham, Durham, England","Cambridge, Cambridgeshire, England":"Cambridge, Cambridgeshire, England","London, England":"London, England","Manor, Yorkshire, England":"Manor, Yorkshire, England"},"fr":{"1430–1448":"1430–1448","1423–1470":"1423–1470","1447–Female":"1447–Décédée","1448–1532":"1448–1532","1451–Female":"1451–Décédée","1453–Male":"1453–Décédé","1408–1461":"1408–1461","1412–1430":"1412–1430","before 1447":"avant 1447","1451":"1451","1461":"1461","1470":"1470","1448":"1448","1447":"1447","1412":"1412","1423":"1423","1532":"1532","1453":"1453","1430":"1430","after 1430":"après 1430","1408":"1408","Durham, Durham, England":"Durham, Durham, Angleterre","Cambridge, Cambridgeshire, England":"Canteburge, Cambridgeshire, Angleterre","London, England":"Londres, Angleterre","Manor, Yorkshire, England":"Manor, Everwyck, Angleterre","lifeSummary":"Lorsque Elizabeth Del'outhe est née