om","Scotland":"Skotland","Dumbarton, Dunbartonshire, Scotland":"Dumbarton, Dunbartonshire, Skotland, United Kingdom"},"nl":{"1250–1308":"1255–1308","1255–1308":"1255–1308","1274–Male":"1274–Overleden","1250–Female":"1255–Overleden","1280–1330":"1280–1330","1220–1280":"1220–1280","1227–Female":"1227–Overleden","1227":"1227","1255":"1255","1220":"1220","1330":"1330","1274":"1274","1250":"1255","1292":"1292","1308":"1308","1280":"1280","Dunbarton, Dunbartonshire, Scotland":"Dumbarton, Dunbartonshire, Schotland","Dumbarton, West Dunbartonshire, Scotland":"Dumbarton, Dunbartonshire, Schotland, Verenigd Koninkrijk","Dumbarton, Strathclyde, Scotland, United Kingdom":"Dumbarton, Strathclyde, Schotland, Verenigd Koninkrijk","Scotland":"Schotland","Dumbarton, Dunbartonshire, Scotland":"Dumbarton, Dunbartonshire, Schotland, Verenigd Koninkrijk"},"en":{"1250–1308":"1255–1308","1255–1308":"1255–1308","1274–Male":"1274–Deceased","1250–Female":"1255–Deceased","1280–1330":"1280–1330","1220–1280":"1220–1280","1227–Female":"1227–Deceased","1227":"1227","1255":"1255","1220":"1220","1330":"1330","1274":"1274","1250":"1255","1292":"1292","1308":"1308","1280":"1280","Dunbarton, Dunbartonshire, Scotland":"Dumbarton, Dunbartonshire, Scotland","Dumbarton, West Dunbartonshire, Scotland":"Dumbarton, Dunbartonshire, Scotland, United Kingdom","Dumbarton, Strathclyde, Scotland, United Kingdom":"Dumbarton, Strathclyde, Scotland, United Kingdom","Scotland":"Scotland","Dumbarton, Dunbartonshire, Scotland":"Dumbarton, Dunbartonshire, Scotland, United Kingdom","nameMeanings":[{"name":"Colquhoun","type":"LAST","attribution":"Dictionary of American Family Names © Patrick Hanks 2003, 2006.","meanings":["Some characteristic forenames:  Scottish Alastair.","Scottish: habitational name from the barony of Colquhoun in Dumbartonshire. The name appears to derive from Gaelic <i>còil</i>, <i>cùil</i> ‘nook, corner’, or <i>coill(e)</i> ‘wood’ + <i>cumhann</i> ‘narrow’. The usual Scottish pronunciation is <i>ka-hoon</i>. This is the name of a Scottish family descended from Umfridus de Kilpatrick, who acquired lands in the barony of Colquhoun during the reign of Alexander II (1214–49)."],"variants":[{"name":"Cohoon","meanings":["English (Cheshire) and Scottish: variant of   Colquhoun  . This surname is now rare in Britain."]},{"name":"Calhoun","meanings":["Scottish: variant of   Colquhoun  .","History: This prominent early American name was brought across the Atlantic Ocean by Scotch-Irish pioneers who entered Pennsylvania <i>c.</i> 1733. The American statesman John <i>c.</i> Calhoun (1782–1850), born in Abbeville District, SC, served in both houses of Congress, was secretary of war, and vice president of the US (1825–32)."]},{"name":"Kahoun","meanings":["Irish: variant of Scottish   Colquhoun  ."]},{"name":"Cahoon","meanings":["Irish (Down and Antrim): variant (reflecting the traditional pronunciation) of Scottish   Colquhoun  ."]},{"name":"Calhoon","meanings":["Irish: variant of Scottish   Colquhoun  ."]}]}],"lifeSummary":"When Ingelram Colquhoun Ingleramus 3rd of Colquhoun was born in 1255, in Dumbarton, Dunbartonshire, Scotland, his father, Robert Colquhoun, was 35 and his mother, Jeanie Traquair, was 29. He had at least 1 son with Mrs. Katherine Colquhoun. He died in 1308, in his hometown, at the age of 53, and was buried in Dumbarton, Dunbartonshire, Scotland, United Kingdom."},"et":{"1250–1308":"1255–1308","1255–1308":"1255–1308","1274–Male":"1274–Surnud","1250–Female":"1255–Surnud","1280–1330":"1280–1330","1220–1280":"1220–1280","1227–Female":"1227–Surnud","1227":"1227","1255":"1255","1220":"1220","1330":"1330","1274":"1274","1250":"1255","1292":"1292","1308":"1308","1280":"1280","Dunbarton, Dunbartonshire, Scotland":"Dumbarton, Dunbartonshire, Scotland","Dumbarton, West Dunbartonshire, Scotland":"Dumbarton, Dunbartonshire, Šotimaa, United Kingdom","Dumbarton, Strathclyde, Scotland, United Kingdom":"Dumbarton, Strathclyde, Šotimaa, United Kingdom","Scotland":"Scotla