Halberton, Devon, Inglaterra, United Kingdom","Devon, England":"Devon, Inglaterra","lifeSummary":"Quando Henry Burton nasceu em 1352, em Halberton, Devon, Inglaterra, seu pai, Gilbert Burton, tinha 28 anos e sua mãe, Isabel Dunn, tinha 28 anos. Ele casou-se com Alice de Bois aproximadamente 1383. Eles tiveram pelo menos 1 filho e 1 filha. Ele faleceu em 31 de janeiro de 1396, em Halberton, Devon, Inglaterra, United Kingdom, com 44 anos."},"ro":{"1352–31 January 1396":"1352–31 ianuarie 1396","1352–1396":"1352–1396","1353–1407":"1353–1407","1356–1420":"1356–1420","1385–1428":"1385–1428","1400–1475":"1400–1475","1324–1357":"1324–1357","1324–1356":"1324–1356","1352":"1352","1385":"1385","1396":"1396","1350":"1350","1382":"1382","Abt 1383":"aproximativ 1383","1357":"1357","1324":"1324","1356":"1356","1400":"1400","1475":"1475","1420":"1420","1353":"1353","31 January 1396":"31 ianuarie 1396","1407":"1407","1428":"1428","Foxhall, Suffolk, England":"Foxhall, Suffolk, England","Halberton, Somersetshire, England":"Somerset, England","England":"Anglia, United Kingdom","Halberton, Devon, England":"Halberton, Devon, Anglia, United Kingdom","Devon, England":"Devon, England"},"ru":{"1352–31 January 1396":"1352 г.–31 января 1396 г.","1352–1396":"1352г.–1396г.","1353–1407":"1353г.–1407г.","1356–1420":"1356г.–1420г.","1385–1428":"1385г.–1428г.","1400–1475":"1400г.–1475г.","1324–1357":"1324г.–1357г.","1324–1356":"1324г.–1356г.","1352":"1352 г.","1385":"1385 г.","1396":"1396 г.","1350":"1350 г.","1382":"1382 г.","Abt 1383":"около 1383 г.","1357":"1357 г.","1324":"1324 г.","1356":"1356 г.","1400":"1400 г.","1475":"1475 г.","1420":"1420 г.","1353":"1353 г.","31 January 1396":"31 января 1396 г.","1407":"1407 г.","1428":"1428 г.","Foxhall, Suffolk, England":"фоксхолл, суффолк, Англия","Halberton, Somersetshire, England":"сомирсет, Англия","England":"Англия, Великобритания","Halberton, Devon, England":"хэлбиртон, девон, Англия, Великобритания","Devon, England":"девон, Англия","lifeSummary":