hire, England":"英国爾瓦明加姆","lifeSummary":"当William de Mainwaring于1110年出生在英国爾时，他的父亲Roger de Mainwaring41岁，母亲Ellen Wayborn31岁。他于1128年与Ann Thomas在英国爾瓦明加姆结婚。他们至少是1个儿子的父母。他去世于1195年在英国爾奧維 奧福享年85岁。"},"hr":{"1110–1195":"1110.–1195.","1105–Male":"1105–preminuo","1107–Male":"1107–preminuo","1100–1200":"1100–1200","1130–1195":"1130.–1195.","1070–1119":"1070–1119","1080–1159":"1080–1159.","1080":"1080","about 1195":"oko 1195.","1110":"1110.","1130":"1130.","1195":"1195.","Aft 1119":"nakon 1119.","1070":"1070","1107":"1107","1128":"1128.","1105":"1105","1159":"1159.","1200":"1200","1100":"1100","before 1095":"prije 1095.","1119":"1119","Over Peover, Middlewich, Cheshire, England":"Over Peover, Cheshire, England","Cheshire, England":"Cheshire, Engleska, United Kingdom","Leek, Staffordshire, England":"Leek, Staffordshire, England","Over Peover, Cheshire, England":"Over Peover, Cheshire, England","Warmingham, Cheshire, England":"Warmingham, Cheshire, England"},"cs":{"1110–1195":"1110–1195","1105–Male":"1105–Zesnulý","1107–Male":"1107–Zesnulý","1100–1200":"1100–1200","1130–1195":"1130–1195","1070–1119":"1070–1119","1080–1159":"1080–1159","1080":"1080","about 1195":"okolo 1195","1110":"1110","1130":"1130","1195":"1195","Aft 1119":"po 1119","1070":"1070","1107":"1107","1128":"1128","1105":"1105","1159":"1159","1200":"1200","1100":"1100","before 1095":"před 1095","1119":"1119","Over Peover, Middlewich, Cheshire, England":"Over Peover, Cheshire, Anglie","Cheshire, England":"Cheshire, Anglie, United Kingdom","Leek, Staffordshire, England":"Leek, Staffordshire, Anglie","Over Peover, Cheshire, England":"Over Peover, Cheshire, Anglie","Warmingham, Cheshire, England":"Warmingham, Cheshire, Anglie"},"da":{"1110–1195":"1110–1195","1105–Male":"1105–Afdød","1107–Male":"1107–Afdød","1100–1200":"1100–1200","1130–1195":"1130–1195","1070–1119":"1070–1119","1080–1159":"1080–1159","1080":"1080","about 1195":"omkring 1195","1110":"1110","1130":"1130","1195":"1195","Aft 1119":"efter 1119","1070":"1070","1