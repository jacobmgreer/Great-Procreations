 Oxford."],"variants":[{"name":"Alys","meanings":["Variant spelling of   Alice ."]},{"name":"Alis","meanings":["equivalent of <b>Alice</b> ."]}]}],"historicEvents":[{"id":1705187,"age":80,"year":"1215","julianDay":2164830,"title":"Magna Carta","description":"King John of England agreed to a charter of rights called the Magna Carta. The document was originally drafted by the Archbishop of Canterbury to establish peace between King John and a group of rebel barons. The Magna Carta was completed in 1215 and is now considered to be one of the greatest constitutional documents of all time.","url":"https://www.nationalarchives.gov.uk/education/medieval/magna-carta/","urlTitle":"National Archives - Magna Carta","jurisdictionLevel":1},{"id":1705188,"age":89,"year":"1224","julianDay":2168117,"title":"France Declares War on England","description":"France declared war on England as Louis VIII of France attacked Poitou and northern Gascony.","jurisdictionLevel":1}],"lifeSummary":"Alice Coupe was born in 1135, in Cheshire, England. She had at least 1 son with Richard Starkey. She died in Stretton, Cheshire, England, United Kingdom."},"et":{"1135–":"1135–Surnud","1130–1171":"1130–1171","1150–1180":"1150–1180","1135–Female":"1135–Surnud","24 May 1776":"24. mai 1776","1215":"1215","1224":"1224","1135":"1135","1130":"1130","1150":"1150","1171":"1171","1180":"1180","Stretton, Warrington Unitary authority, Cheshire, England, United Kingdom":"Stretton, Cheshire, Inglismaa, United Kingdom",", , Cheshire, England, United Kingdom":"Cheshire, England","Stretton, Warrington, Cheshire, England, United Kingdom":"Stretton, Cheshire, Inglismaa, United Kingdom"},"fi":{"1135–":"1135–Kuollut","1130–1171":"1130–1171","1150–1180":"1150–1180","1135–Female":"1135–Kuollut","24 May 1776":"24. toukokuuta 1776","1215":"1215","1224":"1224","1135":"1135","1130":"1130","1150":"1150","1171":"1171","1180":"1180","Stretton, Warrington Unitary authority, Cheshire, England, United Kingdom":"Stretton, Cheshire, En