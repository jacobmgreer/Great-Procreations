kshire, England":"Yorkshire, Anglie","Patrington, Yorkshire, England":"Patrington, Yorkshire, Anglie"},"da":{"1358–before September 1419":"1358–før september 1419","1358–1419":"1358–1419","1378–1433":"1378–1433","1362–1391":"1362–1391","1385–Male":"1385–Afdød","1337–1408":"1337–1408","1340–1419":"1340–1419","1385":"1385","1373":"1373","1340":"1340","1362":"1362","1371":"1371","1382":"1382","1391":"1391","1337":"1337","1358":"1358","1433":"1433","1378":"1378","before 3 March 1408":"før 3. marts 1408","about 1385":"omkring 1385","1408":"1408","1419":"1419","before September 1419":"før september 1419","Halsham, Yorkshire, England":"Halsham, Jórvík, England","Yorkshire, England":"Jórvík, England","Patrington, Yorkshire, England":"Patrington, Jórvík, England"},"nl":{"1358–before September 1419":"1358–vóór september 1419","1358–1419":"1358–1419","1378–1433":"1378–1433","1362–1391":"1362–1391","1385–Male":"1385–Overleden","1337–1408":"1337–1408","1340–1419":"1340–1419","1385":"1385","1373":"1373","1340":"1340","1362":"1362","1371":"1371","1382":"1382","1391":"1391","1337":"1337","1358":"1358","1433":"1433","1378":"1378","before 3 March 1408":"vóór 3 maart 1408","about 1385":"circa 1385","1408":"1408","1419":"1419","before September 1419":"vóór september 1419","Halsham, Yorkshire, England":"Halsham, Yorkshire, England","Yorkshire, England":"Yorkshire, England","Patrington, Yorkshire, England":"Patrington, Yorkshire, England"},"en":{"1358–before September 1419":"1358–before September 1419","1358–1419":"1358–1419","1378–1433":"1378–1433","1362–1391":"1362–1391","1385–Male":"1385–Deceased","1337–1408":"1337–1408","1340–1419":"1340–1419","1385":"1385","1373":"1373","1340":"1340","1362":"1362","1371":"1371","1382":"1382","1391":"1391","1337":"1337","1358":"1358","1433":"1433","1378":"1378","before 3 March 1408":"before 3 March 1408","about 1385":"about 1385","1408":"1408","1419":"1419","before September 1419":"before September 1419","Halsham, Yorkshire, England":"Halsham, Yorkshire, England","Yorkshire, England":"Yorkshire, England","Patrington, Yorkshire, England":"Patrington, Yorkshire, England","nameMeanings":[{"name":"Constable","type":"LAST","attribution":"Dictionary of American Family Names © Patrick Hanks 2003, 2006.","meanings":["English (southeastern): occupational name for the law-enforcement officer of a parish, from Middle English, Old French <i>conestable</i>, <i>cunestable</i>, from Late Latin <i>comes stabuli</i> ‘officer of the stable’. The title was also borne by various other officials during the Middle Ages, including the chief officer of a household or court, or a military officer, and this may in some cases be the source of the surname.","Americanized form of Dutch <b>Constapel</b>, an occupational name for the chief gunner aboard a ship or in the garrison of a fort."],"variants":[{"name":"Costabile","meanings":["Some characteristic forenames:  Italian Aldo, Antonio, Ciro, Nino, Agnese, Angelo, Duilio, Enrico, Ercole, Franco, Palma.","Italian (southern):","occupational name from medieval Greek <i>kontostablēs</i> ‘chamberlain’, from medieval Latin <i>comes stabuli</i>, literally ‘count of the stable’ (see   Constable  )."]}]},{"name":"William","type":"FIRST","attribution":"Dictionary of First Names © Patrick Hanks and Flavia Hodges 1990, 2003, 2006.","meanings":["Probably the most successful of all the Old French names of Germanic origin that were introduced to England by the Normans. It is derived from Germanic <i>wil</i> ‘will, desire’ + <i>helm</i> ‘helmet, protection’. The fact that it was borne by the Conqueror himself does not seem to have inhibited its favour with the ‘conquered’ population: in the first century after the Conquest it was the commonest male name of all, and not only among the Normans. In the later Middle Ages it was overtaken by   John  , but continued to run second to that name until the 20th century, when the picture became more fragmented."],"variants":[]}],"historicEvents":[{"id":1705195,"age":24,"year":"1382","julianDay":2225826,"title":"Wycliffe's Bible","description":"John Wycliffe, English theologian and professor at the University of Oxford, completed a translation of the Bible from the Latin Vulgate into Middle English. This translation is known as Wycliffe's Bible and was completed around 1382.","url":"https://en.wikipedia.org/wiki/Wycliffe%27s_Bible","urlTitle":"Wikipedia - Wycliffe's Bible","jurisdictionLevel":2}],"lifeSummary":"When Sir William Constable was born in 1358, in Halsham, Yorkshire, England, his father, Sir John Constable II, was 22 and his mother, Maud Hilton, was 19. He married Elizabeth Metham in 1385, in Halsham, Yorkshire, England. They were the parents of at least 1 son. He died before September 1419, in his hometown."},"et":{"1358–before September 1419":"1358–enne septembrit 1419","1358–1419":"1358–1419","1378–1433":"1378–1433","1362–1391":"1362–1391","1385–Male":"1385–Surnud","1337–1408":"1337–1408","1340–1419":"1340–1419","1385":"1385","1373":"1373","1340":"1340","1362":"1362","1371":"1371","1382":"1382","1391":"1391","1337":"1337","1358":"1358","1433":"1433","1378":"1378","before 3 March 1408":"enne 3. märtsi 1408","about 1385":"umbes 1385","1408":"1408","1419":"1419","before September 1419":"enne septembrit 1419","Halsham, Yorkshire, England":"Halsham, Yorkshire, England","Yorkshire, England":"Yorkshire, England","Patrington, Yorkshire, England":"Patrington, Yorkshire, England"},"fi":{"1358–before September 1419":"1358–ennen vuotta syyskuu 1419","1358–1419":"1358–1419","1378–1433":"1378–1433","1362–1391":"1362–1391","1385–Male":"1385–Kuollut","1337–1408":"1337–1408","1340–1419":"1340–1419","1385":"1385","1373":"1373","1340":"1340","1362":"1362","1371":"1371","1382":"1382","1391":"1391","1337":"1337","1358":"1358","1433":"1433","1378":"1378","before 3 March 1408":"ennen vuotta 3. maaliskuuta 1408","about 1385":"noin 1385","1408":"1408","1419":"1419","before September 1419":"ennen vuotta syyskuu 1419","Halsham, Yorkshire, 