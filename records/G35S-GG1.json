mshire, England":"Egmanton, Nottinghamshire, Engeland, Verenigd Koninkrijk"},"en":{"1239–1290":"1239–1290","1225–1281":"1225–1281","1234–1282":"1234–1282","1245–1276":"1245–1276","1276–1326":"1276–1326","1205–1242":"1205–1242","1204–Female":"1204–Deceased","1242":"1242","1282":"1282","1281":"1281","1 May 1275":"1 May 1275","1290":"1290","1239":"1239","May 1242":"May 1242","1205":"1205","1326":"1326","1259":"1259","1204":"1204","1225":"1225","22 April 1276":"22 April 1276","1245":"1245","1234":"1234","1276":"1276","Mc, Audley, Staffordshire, England":"Audley, Staffordshire, England, United Kingdom","Adlingfleet, Yorkshire, England":"Adlingfleet, Yorkshire, England","Markham Clinton, Nottinghamshire, England":"Markham Clinton, Nottinghamshire, England","Egmanton, Nottinghamshire, England":"Egmanton, Nottinghamshire, England, United Kingdom","nameMeanings":[{"name":"d'Eiville","type":"LAST","attribution":"Dictionary of American Family Names © Patrick Hanks 2003, 2006.","meanings":["English (Staffordshire):","(of Norman origin): habitational name from Déville in Seine-Maritime.","nickname from Middle English <i>devel</i> ‘devil’ (Old English <i>dēofol</i>). This may have been acquired as a pageant name or as a shortened form of a longer nickname such as that of Robert and William <i>Drepedevel</i> (‘kill the devil’), recorded in the 1301 Subsidy Rolls (Sutton Howgrave, in Kirklington, North Yorkshire)."],"variants":[{"name":"Davoll","meanings":["English: variant of   Deaville  ."]},{"name":"Dewell","meanings":["English:","variant of   Deaville  , a nickname from Middle English <i>devel</i> (Old English <i>dēofol</i>) ‘devil, Satan’, possibly acquired as a pageant name or as a shortened form of a longer nickname. Compare   Devall   and   Deeble  .","of Breton origin, a variant of   Joel   from the Old Breton personal name <i>Iudhael</i>. The personal name was seemingly reintroduced into Britain from France in the 17th century by Huguenots, and was common in Devon and Cornwall and the Breton districts of Yorkshire and the eastern counties."]}]},{"name":"John","type":"FIRST","attribution":"Dictionary of First Names © Patrick Hanks and Flavia Hodges 1990, 2003, 2006.","meanings":["Contracted form of Old French <i>Jo(h)anne</i>, from Latin <i>Io(h)anna</i> (  see  Joanna  ). In England this was the usual feminine form of   John   from the Middle English period onwards and was extremely popular, but in the 16th and 17th centuries it steadily lost ground to   Jane .  It was strongly revived in the first part of the 20th century, partly under the influence of  George Bernard Shaw's  play St Joan (  1923 ), based on the life of  Joan of Arc  (  1412–31 ). Claiming to be guided by the voices of the saints, she persuaded the French dauphin to defy the occupying English forces and have himself crowned, and she led the French army that raised the siege of Orleans in  1429 . The following year she was captured by the Burgundians and sold to the English, and a year later she was burned at the stake for witchcraft at the age of 18 or 19. Her story has captured the imagination of many writers, and she is variously portrayed as a national and political hero, a model of apolitical straightforwardness and honesty, and a religious heroine. She was canonized in  1920 . More recent influences have included the American film actress  Joan Crawford  (  1908–77 , born  Lucille le Sueur ), the British actress  Joan Collins  (  b. 1933 ), the American comedienne  Joan Rivers  (  b. 1933 ), and the West Indian pop singer  Joan Armatrading  (  b. 1950 )."],"variants":[]}],"historicEvents":[{"id":1705189,"age":20,"year":"1259","julianDay":2180901,"title":"100 Years of Conflict Between England and France Ends","description":"Treaty of Paris was signed on December 4, 1259, which ended 100 years of conflict between England and France.","url":"https://en.wikipedia.org/wiki/Treaty_of_Paris_(1259)","urlTitle":"Wikipedia - Treaty of Paris 1259","jurisdictionLevel":2},{"id":1705190,"age":51,"year":"1290","julianDay":2192224,"title":"Jews Expelled From England","description":"After years of anti-Semitic behavior, King Edward I expelled Jews from England in 1290.","jurisdictionLevel":2}],"lifeSummary":"When Sir John d'Eiville Knight was born in 1239, in Markham Clinton, Nottinghamshire, England, his father, Sir Robert Daiville, was 34 and his mother, Mrs. Robert de Eiville, was 35. He married Maud James Daudelegh on 1 May 1275, in Audley, Staffordshire, England, United Kingdom. They were the parents of at least 1 son. He died in 1290, in Egmanton, Nottinghamshire, England, United Kingdom, at the age of 51."},"et":{"1239–1290":"1239–1290","1225–1281":"1225–1281","1234–1282":"1234–1282","1245–1276":"1245–1276","1276–1326":"1276–1326","1205–1242":"1205–1242","1204–Female":"1204–Surnud","1242":"1242","1282":"1282","1281":"1281","1 May 1275":"1. mai 1275","1290":"1290","1239":"1239","May 1242":"mai 1242","1205":"1205","1326":"1326","1259":"1259","1204":"1204","1225":"1225","22 April 1276":"22. aprill 1276","1245":"1245","1234":"1234","1276":"1276","Mc, Audley, Staffordshire, England":"Audley, Staffordshire, Inglismaa, United Kingdom","Adlingfleet, Yorkshire, England":"Adlingfleet, Yorkshire, England","Markham Clinton, Nottinghamshire, England":"Markham Clinton, Nottinghamshire, England","Egmanton, Nottinghamshire, England":"Egmanton, Nottinghamshire, Inglismaa, United Kingdom"},"fi":{"1239–1290":"1239–1290","1225–1281":"1225–1281","1234–1282":"1234–1282","1245–1276":"1245–1276","1276–1326":"1276–1326","1205–1242":"1205–1242","1204–Female":"1204–Kuollut","1242":"1242","1282":"1282","1281":"1281","1 May 1275":"1. toukokuuta 1275","1290":"1290","1239":"1239","May 1242":"toukokuu 1242","1205":"1205","1326":"1326","1259":"1259","1204":"1204","1225":"1225","22 April 1276":"22. huhtikuuta 1276","1245":"1245","1234":"1234","1276":"1276","Mc, Audley, Staffordshire, England":"Audley, Staffordshire, Englanti, Yhdistynyt kuningaskunta","Adlingfleet