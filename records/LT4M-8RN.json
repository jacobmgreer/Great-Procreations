le":"1377–Overleden","1398–1449":"1398–1449","1346–Male":"1346–Overleden","1346":"1346","1455":"1455","1377":"1377","1398":"1398","1382":"1382","1449":"1449","Stoke by Nayland, Suffolk, England":"Stoke by Nayland, Suffolk, England","Crediton, Devon, England":"Crediton, Devon, England"},"en":{"1377–":"1377–Deceased","1377–Female":"1377–Deceased","1377–Male":"1377–Deceased","1398–1449":"1398–1449","1346–Male":"1346–Deceased","1346":"1346","1455":"1455","1377":"1377","1398":"1398","1382":"1382","1449":"1449","Stoke by Nayland, Suffolk, England":"Stoke by Nayland, Suffolk, England","Crediton, Devon, England":"Crediton, Devon, England","nameMeanings":[{"name":"De","type":"LAST","attribution":"Dictionary of American Family Names © Patrick Hanks 2003, 2006.","meanings":["Some characteristic forenames:  Indian Dilip, Anirban, Gopal, Alok, Anindya, Arunava, Asit, Asok, Dibyendu, Goutam, Indra, Indranil.","Indian: variant of   Dey  ."],"variants":[{"name":"Dey","meanings":["Some characteristic forenames:  Indian Ashit, Indu, Naina, Partha, Soumya, Ajit, Anjan, Anjana, Anup, Arjun, Arun, Ashim.","English, Scottish, and Welsh: variant of   Day  .","German: topographic name from a field name in North Rhine-Westphalia, denoting a sizeable piece of land, from Middle Low German <i>dē</i> ‘thigh’ (referring to the shape of the property)."]}]},{"name":"Creedy","type":"LAST","attribution":"Dictionary of Family Names in Britain and Ireland © University of the West of England 2016","meanings":["1  English: locative name from North Creedy in Sandford or Lower Creedy in Upton Hellions (Devon).","2  Scottish Gaelic: from  <b>Mac Riada</b>,  see  McCready  ."],"variants":[{"name":"McCready","meanings":["Irish: Anglicized form of Gaelic <b>Mac Riada</b> ‘son of <i>Riada</i>’, an old personal name meaning ‘traveler, rider’. The surname was found in Galloway, Scotland, in 1684, but it seems likely (with the variant <b>McGready</b>) to have originated in Ireland."]}]},{"name":"Elizabeth","type":"FIRST","attribution":"Dictionary of First Names © Patrick Hanks and Flavia Hodges 1990, 2003, 2006.","meanings":["The usual spelling of   Elisabeth   in English. It is recorded in the medieval period, but was made popular by being borne by  Queen Elizabeth I  of England (  1533–1603 ). In the 20th century it again became extremely fashionable, partly because it was the name of  Elizabeth Bowes-Lyon  (  1900–2002 ), who in  1936  became Queen Elizabeth as the wife of King George VI, and after his death in  1952  achieved great public affection as Queen Mother for nearly half a century. Even more influentially, it is the name of her daughter  Queen Elizabeth II  (  b. 1926 )."],"variants":[{"name":"Elisabeth","meanings":["The spelling of   Elizabeth   used in the Authorized Version of the New Testament, and in most modern European languages. This was the name of the mother of John the Baptist (Luke 1:60). Etymologically, the name means ‘God is my oath’, and is therefore identical with <i>Elisheba</i>, the name of the wife of Aaron according to the genealogy at Exodus 6:23. The final element seems to have been altered by association with Hebrew <i>shabbāth</i> ‘Sabbath’."]}]}],"historicEvents":[{"id":1705195,"age":5,"year":"1382","julianDay":2225826,"title":"Wycliffe's Bible","description":"John Wycliffe, English theologian and professor at the University of Oxford, completed a translation of the Bible from the Latin Vulgate into Middle English. This translation is known as Wycliffe's Bible and was completed around 1382.","url":"https://en.wikipedia.org/wiki/Wycliffe%27s_Bible","urlTitle":"Wikipedia - Wycliffe's Bible","jurisdictionLevel":2},{"id":1705197,"age":78,"year":"1455","julianDay":2252488,"title":"Wars of the Roses","description":"Wars of the Roses was a series of English civil wars for control of the throne of England between the royal families House of Lancaster and the House of York. The name of the war was derived as the red rose was the symbol of the Lancastrians and the white rose was the symbol of the Yorks.","url":"https://www.history.com/topics/british-history/wars-of-the-roses","urlTitle":"History - Wars of the Roses","jurisdictionLevel":2}],"lifeSummary":"Elizabeth De Creedy was born in 1377, in Crediton, Devon, England as the daughter of William De Creedy. She had at least 1 son with Sir John Capel."},"et":{"1377–":"1377–Surnud","1377–Female":"1377–Surnud","1377–Male":"1377–Surnud","1398–1449":"1398–1449","1346–Male":"1346–Surnud","1346":"1346","1455":"1455","1377":"1377","1398":"1398","1382":"1382","1449":"1449","Stoke by Nayland, Suffolk, England":"Stoke by Nayland, Suffolk, England","Crediton, Devon, England":"Crediton, Devon, England"},"fi":{"1377–":"1377–Kuollut","1377–Female":"1377–Kuollut","1377–Male":"1377–Kuollut","1398–1449":"1398–1449","1346–Male":"1346–Kuollut","1346":"1346","1455":"1455","1377":"1377","1398":"1398","1382":"1382","1449":"1449","Stoke by Nayland, Suffolk, England":"Stoke by Nayland, Suffolk, England","Crediton, Devon, England":"Crediton, Devon, England"},"fr":{"1377–":"1377–Décédée","1377–Female":"1377–Décédée","1377–Male":"1377–Décédé","1398–1449":"1398–1449","1346–Male":"1346–Décédé","1346":"1346","1455":"1455","1377":"1377","1398":"1398","1382":"1382","1449":"1449","Stoke by Nayland, Suffolk, England":"Stoke by Nayland, Suffolk, Angleterre","Crediton, Devon, England":"Crediton, Devon, Angleterre","lifeSummary":"Elizabeth De Creedy est née en 1377, à Crediton, Devon, Angleterre, fille de William De Creedy. Elle a eu au moins 1 fils avec Sir John Capel."},"de":{"1377–":"1377–Verstorben","1377–Female":"1377–Verstorben","1377–Male":"1377–Verstorben","1398–1449":"1398–1449","1346–Male":"1346–Verstorben","1346":"1346","1455":"1455","1377":"1377","1398":"1398","1382":"1382","1449":"1449","Stoke by Nayland, Suffolk, England":"Stoke by Nayland, Suffolk, England","Crediton, Devon, England":"Crediton, Devon, England","lifeSummary":"Elizabeth De Creedy wurde 1377 in Crediton, Devon, Engla