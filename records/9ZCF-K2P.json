rca 1260","about 1280":"circa 1280","after 1282":"na 1282","31 May 1277":"31 mei 1277","1295":"1295","1250":"1250","1282":"1282","1260":"1260","1182":"1182","1280":"1280","1325":"1325","1279":"1279","1289":"1289","1277":"1277","1255":"1255","31 May 1279":"31 mei 1279","1276":"1276","20 JUN 1289":"20 juni 1289","1308":"1308","Warmingham, Cheshire, England, United Kingdom":"Warmingham, Cheshire, Engeland, Verenigd Koninkrijk","Norfolk, England, United Kingdom":"Norfolk, Engeland, Verenigd Koninkrijk","Warmingham, Cheshire, England":"Warmingham, Cheshire, Engeland, Verenigd Koninkrijk"},"en":{"about 1260–20 JUN 1289":"about 1260–20 June 1289","1255–1289":"1255–1289","1260–1289":"1260–1289","1276–1308":"1276–1308","1277–1282":"1277–1282","1279–1282":"1279–1282","1280–1325":"1280–1325","1295–Female":"1295–Deceased","1182–1250":"1182–1250","about 1260":"about 1260","about 1280":"about 1280","after 1282":"after 1282","31 May 1277":"31 May 1277","1295":"1295","1250":"1250","1282":"1282","1260":"1260","1182":"1182","1280":"1280","1325":"1325","1279":"1279","1289":"1289","1277":"1277","1255":"1255","31 May 1279":"31 May 1279","1276":"1276","20 JUN 1289":"20 June 1289","1308":"1308","Warmingham, Cheshire, England, United Kingdom":"Warmingham, Cheshire, England, United Kingdom","Norfolk, England, United Kingdom":"Norfolk, England, United Kingdom","Warmingham, Cheshire, England":"Warmingham, Cheshire, England, United Kingdom","nameMeanings":[{"name":"William","type":"FIRST","attribution":"Dictionary of First Names © Patrick Hanks and Flavia Hodges 1990, 2003, 2006.","meanings":["Probably the most successful of all the Old French names of Germanic origin that were introduced to England by the Normans. It is derived from Germanic <i>wil</i> ‘will, desire’ + <i>helm</i> ‘helmet, protection’. The fact that it was borne by the Conqueror himself does not seem to have inhibited its favour with the ‘conquered’ population: in the first century after the Conquest it was the commonest male name of all, and not only among the Normans. In the later Middle Ages it was overtaken by   John  , but continued to run second to that name until the 20th century, when the picture became more fragmented."],"variants":[]},{"name":"Warmingham","type":"LAST","attribution":"Dictionary of Family Names in Britain and Ireland © University of the West of England 2016","meanings":["English:  see  Warmisham  ."],"variants":[{"name":"Warmisham","meanings":["English: locative name from Warmingham (Cheshire). The place-name was formerly pronounced ‘Warmincham’ (compare the current spelling of  <i>Altrincham</i>, also in Cheshire, pronounced ‘Altringham’). This could be spelt as  <i>Warmingham</i> with the  <i>-g-</i> prounced as ‘soft’ /dʒ/,  <i>Warmincham</i>, or  <i>Warminsham</i> as illustrated by the surname. In some forms the  <i>-n-</i> in the second syllable was lost, including the variant that appears in Lancs, where the final  <i>-sham</i> has been replaced by the characteristic Lancs place-name element  <i>-shaw</i>. <i>Warmiham</i> and  <i>Warminham</i> seem to be aberrations."]}]}],"lifeSummary":"William Warmingham DeMainwaring was born about 1260, in Warmingham, Cheshire, England, United Kingdom as the son of Roger de Mainwaring. He had at least 4 daughters with Agnes De Arderne. He died on 20 June 1289, in his hometown, at the age of 30."},"et":{"about 1260–20 JUN 1289":"umbes 1260–20. juuni 1289","1255–1289":"1255–1289","1260–1289":"1260–1289","1276–1308":"1276–1308","1277–1282":"1277–1282","1279–1282":"1279–1282","1280–1325":"1280–1325","1295–Female":"1295–Surnud","1182–1250":"1182–1250","about 1260":"umbes 1260","about 1280":"umbes 1280","after 1282":"pärast 1282","31 May 1277":"31. mai 1277","1295":"1295","1250":"1250","1282":"1282","1260":"1260","1182":"1182","1280":"1280","1325":"1325","1279":"1279","1289":"1289","1277":"1277","1255":"1255","31 May 1279":"31. mai 1279","1276":"1276","20 JUN 1289":"20. juuni 1289","1308":"1308","Warmingham, Cheshire, Englan