re, England":"英国諾薩普頓史爾易斯特","Lincolnshire, England":"英国林可爾史爾","lifeSummary":"当Johanna Cheney于1460年出生在英国林可爾史爾时，她的父亲Sir John Cheney37岁，母亲Elizabeth Rempston42岁。她于1474年与Sir Thomas Saye在英国英格兰艾可利斯頓结婚。他们至少是2个女儿的父母。她去世于1496年在英国艾可特洛福享年36岁。"},"hr":{"1460–1496":"1460.–1496.","1453–1547":"1453–1547","1469–1480":"1469.–1480.","1469–1538":"1469.–1538","1478–1531":"1478.–1531","1423–1489":"1423–1489","1418–Female":"1418–preminula","14 July 1489":"14. srpnja 1489.","1460":"1460.","1480":"1480.","1547":"1547","1469":"1469.","1478":"1478.","1489":"1489","1423":"1423","1531":"1531","1453":"1453","1474":"1474.","1496":"1496.","about 1454":"oko 1454.","1418":"1418","1538":"1538","Yorkshire, England":"Yorkshire, England","Pentlow, Essex, England":"Pentlow, Essex, England","Beckering, Lincolnshire, England":"Lincolnshire, Engleska, United Kingdom","Liston, Essex, England, Great Britain":"Liston, Essex, Engleska, United Kingdom","Irchester, Northamptonshire, England":"Irchester, Northamptonshire, England","Lincolnshire, England":"Lincolnshire, England"},"cs":{"1460–1496":"1460–1496","1453–1547":"1453–1547","1469–1480":"1469–1480","1469–1538":"1469–1538","1478–1531":"1478–1531","1423–1489":"1423–1489","1418–Female":"1418–Zesnulá","14 July 1489":"14. července 1489","1460":"1460","1480":"1480","1547":"1547","1469":"1469","1478":"1478","1489":"1489","1423":"1423","1531":"1531","1453":"1453","1474":"1474","1496":"1496","about 1454":"okolo 1454","1418":"1418","1538":"1538","Yorkshire, England":"Yorkshire, Anglie","Pentlow, Essex, England":"Pentlow, Essex, Anglie","Beckering, Lincolnshire, England":"Lincolnshire, Anglie, United Kingdom","Liston, Essex, England, Great Britain":"Liston, Essex, Anglie, United Kingdom","Irchester, Northamptonshire, England":"Irchester, Northamptonshire, Anglie","Lincolnshire, England":"Lincolnshire, Anglie"},"da":{"1460–1496":"1460–1496","1453–1547":"1453–1547","1469–1480":"1469–1480","1469–1538":"1469–1538","1478–1531":"1478–1531","1423–1489":"1423–1489","1418–Female