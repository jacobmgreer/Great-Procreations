rtford в местности хиртфорд, хиртфордшир, Англия, Великобритания. Он умер 7 августа 1517 г. в местности ричмонд, сурри, Англия в возрасте 27 лет и был похоронен в местности каирнарфоншир, Уэльс."},"sm":{"1490–7 August 1517":"1490–7 Aukuso 1517","1490–1517":"1490–1517","1492–1553":"1492–1553","1512–1585":"1512–1585","1471–1514":"1471–1514","1474–1501":"1474–1501","1471":"1471","1492":"1492","1490":"1490","4 June 1514":"4 Iuni 1514","4 May 1510":"4 Me 1510","1514":"1514","1513":"1513","1501":"1501","1512":"1512","1553":"1553","7 August 1517":"7 Aukuso 1517","1585":"1585","1474":"1474","1517":"1517","Caernarfon, Gwynedd, Wales":"Richmond, Surrey, Egelani","Poynings, Sussex, England":"Poynings, Sussex, Egelani, United Kingdom","Hurstmonceaux, Sussex, England":"Herstmonceux, Sussex, Egelani, United Kingdom","Scrivelsby Court, Lincolnshire, England":"Scrivelsby Court, Lincolnshire, Egelani","Gwynedd, Wales":"Gwynedd, Uelese, United Kingdom","Tredegar, Monmouthshire, Wales":"Tredegar, Monmouthshire, Wales","Caernarfonshire, Wales":"Caernarfonshire, Wales"},"sk":{"1490–7 August 1517":"1490–7. august 1517","1490–1517":"1490–1517","1492–1553":"1492–1553","1512–1585":"1512–1585","1471–1514":"1471–1514","1474–1501":"1474–1501","1471":"1471","1492":"1492","1490":"1490","4 June 1514":"4. jún 1514","4 May 1510":"4. máj 1510","1514":"1514","1513":"1513","1501":"1501","1512":"1512","1553":"1553","7 August 1517":"7. august 1517","1585":"1585","1474":"1474","1517":"1517","Caernarfon, Gwynedd, Wales":"Richmond, Surrey, England","Poynings, Sussex, England":"Poynings, Sussex, Anglicko, Spojené kráľovstvo","Hurstmonceaux, Sussex, England":"Herstmonceux, Sussex, Anglicko, Spojené kráľovstvo","Scrivelsby Court, Lincolnshire, England":"Scrivelsby Court, Lincolnshire, England","Gwynedd, Wales":"Gwynedd, Wales, Spojené kráľovstvo","Tredegar, Monmouthshire, Wales":"Tredegar, Monmouthshire, Wales","Caernarfonshire, Wales":"Caernarfonshire, Wales"},"es":{"1490–7 August 1517":"1490–7 de agosto de 