83":"1325–1383","1330–1386":"1330–1386","–1367":"–1367","1330–1387":"1330–1387","1350–Female":"1350–Overleden","1370–1427":"1370–1427","1300–Male":"1300–Overleden","1300–1387":"1300–1387","1325":"1325","1367":"1367","1300":"1300","1387":"1387","1386":"1386","1330":"1330","before 1370":"vóór 1370","1383":"1383","1350":"1350","1370":"1370","1427":"1427","Drumcar, County Louth, Ireland, United Kingdom":"Drumcar, County Louth, Ierland","Seven Glens, Antrim, Ireland, United Kingdom":"Antrim, County Antrim, Noord-Ierland, Verenigd Koninkrijk","Ireland":"Ierland","Seven Glens, Antrim, Ireland":"Antrim, County Antrim, Ierland","Ireland, United Kingdom":"Ireland, Orkney, Schotland, Verenigd Koninkrijk"},"en":{"1325–1383":"1325–1383","1330–1386":"1330–1386","–1367":"–1367","1330–1387":"1330–1387","1350–Female":"1350–Deceased","1370–1427":"1370–1427","1300–Male":"1300–Deceased","1300–1387":"1300–1387","1325":"1325","1367":"1367","1300":"1300","1387":"1387","1386":"1386","1330":"1330","before 1370":"before 1370","1383":"1383","1350":"1350","1370":"1370","1427":"1427","Drumcar, County Louth, Ireland, United Kingdom":"Drumcar, County Louth, Ireland","Seven Glens, Antrim, Ireland, United Kingdom":"Antrim, County Antrim, Northern Ireland, United Kingdom","Ireland":"Ireland","Seven Glens, Antrim, Ireland":"Antrim, County Antrim, Ireland","Ireland, United Kingdom":"Ireland, Orkney, Scotland, United Kingdom","nameMeanings":[{"name":"Bisset","type":"LAST","attribution":"Dictionary of American Family Names © Patrick Hanks 2003, 2006.","meanings":["Scottish (of Norman origin): variant of   Bissett  .","French: from a diminutive of Old French <i>bisse</i> ‘fine linen’ (see   Bisson  )."],"variants":[{"name":"Bissett","meanings":["Scottish (of Norman origin): nickname from Old French <i>biset</i> ‘dark’, a diminutive of <i>bis</i> (see   Biss  ).","Altered form of French <b>Bizet</b>: nickname for someone with a dark complexion, derived from <i>bis</i> ‘grayish-brown’. Altered ending reflects the Canadian and American French practice of sounding the final <i>-t</i>. Compare   Bissette  .","History: The surname <i>Bissett</i> (see 1 above) was brought to Scotland from Nottinghamshire <i>c.</i> 1175 by Henricus Byset, an Englishman who became a retainer of King William the Lion. — It was Jean George Bizet from Haute-Saône, France, whose surname was changed to <i>Bissett</i> (see 2 above) after his immigration to NS, Canada, in 1752."]}]},{"name":"John","type":"FIRST","meanings":["Greek: the Lord gave graciously; whom Jehovah gave; whom Jehovah bestowed."],"variants":[]}],"lifeSummary":"When Lord John Bisset was born in 1325, in Drumcar, County Louth, Ireland, his father, Sir Hugh mac Eoin Bisset, Lord of the Glens, was 25 and his mother, Sabia O'Neil, was 25. He married Sawe O'Niel before 1370, in Ireland. They were the parents of at least 1 daughter. He died in 1383, in Antrim, County Antrim, Northern Ireland, United Kingdom, at the age of 58, and was buried in Ireland, Orkney, Scotland, United Kingdom."},"et":{"1325–1383":"1325–1383","1330–1386":"1330–1386","–1367":"–1367","1330–1387":"1330–1387","1350–Female":"1350–Surnud","1370–1427":"1370–1427","1300–Male":"1300–Surnud","1300–1387":"1300–1387","1325":"1325","1367":"1367","1300":"1300","1387":"1387","1386":"1386","1330":"1330","before 1370":"enne 1370","1383":"1383","1350":"1350","1370":"1370","1427":"1427","Drumcar, County Louth, Ireland, United Kingdom":"Drumcar, County Louth, Iirimaa","Seven Glens, Antrim, Ireland, United Kingdom":"Antrim, County Antrim, Põhja-Iirimaa, United Kingdom","Ireland":"Iirimaa","Seven Glens, Antrim, Ireland":"Antrim, County Antrim, Iirimaa","Ireland, United Kingdom":"Ireland, Orkney, Šotimaa, United Kingdom"},"fi":{"1325–1383":"1325–1383","1330–1386":"1330–1386","–1367":"–1367","1330–1387":"1330–1387","1350–Female":"1350–Kuollut","1370–1427":"1370–1427","1300–Male":"1300–Kuollut","1300–1387":"1300–1387","1325":"1325","1367":"1367","1300":"1300","1387":"1387","1386":"13