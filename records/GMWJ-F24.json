–1198","1180–1218":"1180–1218","1198–1260":"1198–1260","1158–1178":"1158–1178","1163–1198":"1163–1198","before 1178":"înainte de 1178","1158":"1158","1178":"1178","before 1198":"înainte de 1198","1198":"1198","1163":"1163","about 1198":"aproximativ 1198","1260":"1260","1218":"1218","1180":"1180","Wakehurst, Kent, England":"Kent, Anglia, United Kingdom","England":"England","Kent, England":"Kent, Anglia, United Kingdom","Woodchurch, Kent, England":"Woodchurch, Kent, England"},"ru":{"1178–1198":"1178г.–1198г.","1180–1218":"1180г.–1218г.","1198–1260":"1198г.–1260г.","1158–1178":"1158г.–1178г.","1163–1198":"1163г.–1198г.","before 1178":"перед 1178 г.","1158":"1158 г.","1178":"1178 г.","before 1198":"перед 1198 г.","1198":"1198 г.","1163":"1163 г.","about 1198":"около 1198 г.","1260":"1260 г.","1218":"1218 г.","1180":"1180 г.","Wakehurst, Kent, England":"кэнт, Англия, Великобритания","England":"Англия","Kent, England":"кэнт, Англия, Великобритания","Woodchurch, Kent, England":"вудчурч, кэнт, Англия","lifeSummary":"Когда Sir Richard Rici Wakehurst родился в 1178 г. в местности кэнт, Англия, Великобритания, его отцу по имени Wakehurst было 20 лет, а матери, которую звали Mrs Wakehurst, 16. Он женился на женщине по имени Lady Wakehurst of Kent перед 1198 г. в местности Англия. У них была по крайней мере 1 дочь. Он умер в 1198 г. в его родном городе в возрасте 20 лет и был похоронен в местности Англия."},"sm":{"1178–1198":"1178–1198","1180–1218":"1180–1218","1198–1260":"1198–1260","1158–1178":"1158–1178","1163–1198":"1163–1198","before 1178":"a'e le'I oo le 1178","1158":"1158","1178":"1178","before 1198":"a'e le'I oo le 1198","1198":"1198","1163":"1163","about 1198":"e tusa o le 1198","1260":"1260","1218":"1218","1180":"1180","Wakehurst, Kent, England":"Kent, Egelani, United Kingdom","England":"Egelani","Kent, England":"Kent, Egelani, United Kingdom","Woodchurch, Kent, England":"Woodchurch, Kent, Egelani"},"sk":{"1178–1198":"1178–1198","1180–1218":"1180–1218","1198–1260":"119