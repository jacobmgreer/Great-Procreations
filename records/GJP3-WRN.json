ton(이)가 1174년 영국 체실르 킨더턴에서 태어났을 때, 그의 아버지 de Oxton(은)는 35세였고, 그의 어머니 wife de Oxton(은)는 30세였다. 그는 대략 1194년 영국 잉글랜드 체실르에서 Agnes de Longville(와)과 결혼했다. 그들은 적어도 두 명의 딸을 두었다. 그는 1240년 영국에서 66세의 나이로 사망했으며 영국 체실르 해턴에 묻혔다."},"lv":{"1174–1240":"1174.gads–1240.gads","1174–1230":"1174.gads–1230","1174–1254":"1174.gads–1254","1191–1277":"1191.gads–1277","1196–1277":"1196.gads–1277","1240–Female":"1240.gads–mirusi","1140–Male":"1140–miris","1145–Female":"1145–mirusi","1230":"1230","1174":"1174. gads","1196":"1196. gads","1240":"1240. gads","1140":"1140","1191":"1191. gads","1215":"1215","Abt 1194":"ap 1194. gadu","1224":"1224","1145":"1145","1277":"1277","1254":"1254","before 1170":"pirms 1170. gada","Cheshire, England":"Cheshire, Anglija, Lielbritānija","England":"England","Bebington, Cheshire, England":"Bebington, Cheshire, England","Kinderton, Cheshire, England":"Kinderton, Cheshire, England","Hatton, Cheshire, England":"Hatton, Cheshire, England"},"mg":{"1174–1240":"1174–1240","1174–1230":"1174–1230","1174–1254":"1174–1254","1191–1277":"1191–1277","1196–1277":"1196–1277","1240–Female":"1240–Maty","1140–Male":"1140–Maty","1145–Female":"1145–Maty","1230":"1230","1174":"1174","1196":"1196","1240":"1240","1140":"1140","1191":"1191","1215":"1215","Abt 1194":"tany ho any amin'ny 1194","1224":"1224","1145":"1145","1277":"1277","1254":"1254","before 1170":"talohan'ny 1170","Cheshire, England":"Cheshire, Angletera, United Kingdom","England":"England","Bebington, Cheshire, England":"Bebington, Cheshire, England","Kinderton, Cheshire, England":"Kinderton, Cheshire, England","Hatton, Cheshire, England":"Hatton, Cheshire, England"},"ms":{"1174–1240":"1174–1240","1174–1230":"1174–1230","1174–1254":"1174–1254","1191–1277":"1191–1277","1196–1277":"1196–1277","1240–Female":"1240–Mati","1140–Male":"1140–Mati","1145–Female":"1145–Mati","1230":"1230","1174":"1174","1196":"1196","1240":"1240","1140":"1140","1191":"1191","1215":"1215","Abt 1194":"kira-kira 1194","1224":"1224","1145":"1145","1277"