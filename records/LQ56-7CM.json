, Wiltshire, England":"英国英格兰維爾爾","lifeSummary":"Robert Banyard是Philip Baynard的儿子，于大约1380年出生在英国維爾爾。他于大约1405年与Joyce Brown在英国英格兰諾福爾可巴根斯索普结婚。他们至少是1个儿子和1个女儿的父母。他去世于1462年在英国英格兰諾福爾可諾維其享年83岁，埋葬在英国英格兰諾福爾可。"},"hr":{"about 1380–1462":"oko 1380.–1462.","1380–1462":"1380–1462.","1383–1410":"1383–1410.","1405–1504":"1405–1504","1410–Male":"1410.–preminuo","1350–1415":"1350–1415.","about 1380":"oko 1380.","1462":"1462.","1350":"1350","1383":"1383","1382":"1382","ABT 1405":"oko 1405.","1380":"1380","1415":"1415.","Abt 1410":"oko 1410.","1455":"1455","about 1405":"oko 1405.","1410":"1410.","1504":"1504","1405":"1405","Baconsthorpe,Norfolk,England":"Baconsthorpe, Norfolk, Engleska, United Kingdom","Baconsthorpe, Norfolk, England":"Baconsthorpe, Norfolk, England","Lackham, Wiltshire, England":"Wiltshire, England","Norwich, Norfolk, England, United Kingdom":"Norwich, Norfolk, Engleska, United Kingdom","Austin Friars, Nrflk., Engl.":"Norfolk, Engleska, United Kingdom","England":"Engleska, United Kingdom","Of, Lackham, Wiltshire, England":"Wiltshire, Engleska, United Kingdom"},"cs":{"about 1380–1462":"okolo 1380–1462","1380–1462":"1380–1462","1383–1410":"1383–1410","1405–1504":"1405–1504","1410–Male":"1410–Zesnulý","1350–1415":"1350–1415","about 1380":"okolo 1380","1462":"1462","1350":"1350","1383":"1383","1382":"1382","ABT 1405":"okolo 1405","1380":"1380","1415":"1415","Abt 1410":"okolo 1410","1455":"1455","about 1405":"okolo 1405","1410":"1410","1504":"1504","1405":"1405","Baconsthorpe,Norfolk,England":"Baconsthorpe, Norfolk, Anglie, United Kingdom","Baconsthorpe, Norfolk, England":"Baconsthorpe, Norfolk, Anglie","Lackham, Wiltshire, England":"Wiltshire, Anglie","Norwich, Norfolk, England, United Kingdom":"Norwich, Norfolk, Anglie, United Kingdom","Austin Friars, Nrflk., Engl.":"Norfolk, Anglie, United Kingdom","England":"Anglie, United Kingdom","Of, Lackham, Wiltshire, England":"Wiltshire, Anglie, United Kingdom"},"da":{"about 1380–1462":"omkring 1380–1462","1380–1462":"1380–1462","13