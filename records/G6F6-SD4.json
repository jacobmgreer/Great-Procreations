1340":"1340","1295":"1295","1372":"1372","1350":"1350","1392":"1392","1316":"1316","1315":"1315","1346":"1346","1400":"1400","1399":"1399","1300":"1300","1342":"1342","1364":"1364","1320":"1320","1318":"1318","1307":"1307","about 1340":"about 1340","Perth, Perthshire, Scotland":"Perth, Perthshire, Scotland, United Kingdom","Scotland":"Scotland","Wemyss, Fife, Scotland":"Wemyss, Fife, Scotland","Easter Wemyss, Fifeshire, Scotland":"Wemyss, Fife, Scotland","Inchmartine, Perthshire, Scotland":"Perthshire, Scotland","nameMeanings":[{"name":"Wemyss","type":"LAST","attribution":"Dictionary of American Family Names © Patrick Hanks 2003, 2006.","meanings":["Scottish: habitational name from Wemyss in Fife, traditionally pronounced ‘weems’. The placename is from Gaelic <i>uaimh</i> ‘cave’ + the placename forming suffix <i>–es</i>. The surname reached Ireland in the 14th century, see   Wims  ."],"variants":[{"name":"Wims","meanings":["Irish: variant of Scottish   Wemyss  , representing the usual pronunciation of that Scottish name."]},{"name":"Weems","meanings":["Scottish: variant of   Wemyss  , reflecting the usual pronunciation of that name.","History: David Weems (Wemyss) emigrated from Scotland to Herring Bay, Anne Arundel County, MD, some time before 1722. Mason Locke Weems, born near Herring Bay in 1759, was a clergyman who wrote a biography of George Washington, in which the first account of the cherry-tree story appeared."]},{"name":"Wymbs","meanings":["Irish: variant of Scottish   Wemyss  . Compare   Wims  ."]}]},{"name":"Margaret","type":"FIRST","attribution":"Dictionary of First Names © Patrick Hanks and Flavia Hodges 1990, 2003, 2006.","meanings":["An extremely common given name from the Middle Ages onwards, derived via Old French <i>Marguerite</i> and Latin <i>Margarita</i> from Greek <i>Margarītēs</i>, from <i>margaron</i> ‘pearl’, a word ultimately of Hebrew origin. The name was always understood to mean ‘pearl’ throughout the Middle Ages. The first  St Margaret  was martyred at Antioch in Pisidia during the persecution instigated by the  Emperor Diocletian  in the early 4th century. However, there is some doubt about her name, as the same saint is venerated in the Orthodox Church as   Marina .  There were several other saintly bearers of the name, including St Margaret of Scotland (  d. 1093 ), wife of  King Malcolm Canmore  and daughter of Edmund Ironside of England. It was also the name of the wife of  Henry VI  of England,  Margaret of Anjou  (  1430–82 ), and of  Margaret Tudor  (  1489–1541 ), sister of  Henry VIII , who married James IV of Scotland and ruled as regent there after his death.  See also  Margery  ,   Marjorie ."],"variants":[{"name":"Margareta","meanings":["From the Latin form of Greek <i>Margarītēs</i>.  See  <b>Margaret</b>   ."]},{"name":"Margaretta","meanings":["An extremely common given name from the Middle Ages onwards, derived via Old French <i>Marguerite</i> and Latin <i>Margarita</i> from Greek <i>Margarītēs</i>, from <i>margaron</i> ‘pearl’, a word ultimately of Hebrew origin. The name was always understood to mean ‘pearl’ throughout the Middle Ages. The first  St Margaret  was martyred at Antioch in Pisidia during the persecution instigated by the  Emperor Diocletian  in the early 4th century. However, there is some doubt about her name, as the same saint is venerated in the Orthodox Church as   Marina .  There were several other saintly bearers of the name, including St Margaret of Scotland (  d. 1093 ), wife of  King Malcolm Canmore  and daughter of Edmund Ironside of England. It was also the name of the wife of  Henry VI  of England,  Margaret of Anjou  (  1430–82 ), and of  Margaret Tudor  (  1489–1541 ), sister of  Henry VIII , who married James IV of Scotland and ruled as regent there after his death.  See also  Margery  ,   Marjorie ."]}]}],"lifeSummary":"When Margaret Wemyss was born in 1315, in Wemyss, Fife, Scotland, her father, Michael Wemyss - Lord of Wemyss, was 20 and her mother, Margaret Drumry - Heiress of Lochore, was 15. She married John Inchmartin about 1339, in Fife, Scotland, United Kingdom. She died in 1342, in Perth, Perthshire, Scotland, United Kingdom, at the age of 27."},"et":{"1315–1342":"1315–1342","1300–1350":"1300–1350","1307–Male":"1307–Surnud","1318–Female":"1318–Surnud","1316–1392":"1316–1392","1320–1372":"1320–1372","1318–1364":"1318–1364","1320–1346":"1320–1346","1340–1399":"1340–1399","1340–1400":"1340–1400","1320–1342":"1320–1342","1295–1342":"1295–1342","1300–Female":"1300–Surnud","1340":"1340","1295":"1295","1372":"1372","1350":"1350","1392":"1392","1316":"1316","1315":"1315","1346":"1346","1400":"1400","1399":"1399","1300":"1300","1342":"1342","1364":"1364","1320":"1320","1318":"1318","1307":"1307","about 1340":"umbes 1340","Perth, Perthshire, Scotland":"Perth, Perthshire, Šotimaa, United Kingdom","Scotland":"Scotland","Wemyss, Fife, Scotland":"Wemyss, Fife, Scotland","Easter Wemyss, Fifeshire, Scotland":"Wemyss, Fife, Scotland","Inchmartine, Perthshire, Scotland":"Perthshire, Scotland"},"fi":{"1315–1342":"1315–1342","1300–1350":"1300–1350","1307–Male":"1307–Kuollut","1318–Female":"1318–Kuollut","1316–1392":"1316–1392","1320–1372":"1320–1372","1318–1364":"1318–1364","1320–1346":"1320–1346","1340–1399":"1340–1399","1340–1400":"1340–1400","1320–1342":"1320–1342","1295–1342":"1295–1342","1300–Female":"1300–Kuollut","1340":"1340","1295":"1295","1372":"1372","1350":"1350","1392":"1392","1316":"1316","1315":"1315","1346":"1346","1400":"1400","1399":"1399","1300":"1300","1342":"1342","1364":"1364","1320":"1320","1318":"1318","1307":"1307","about 1340":"noin 1340","Perth, Perthshire, Scotland":"Perth, Perthshire, Skotlanti, Yhdistynyt kuningaskunta","Scotland":"Scotland","Wemyss, Fife, Scotland":"Wemyss, Fife, Scotland","Easter Wemyss, Fifeshire, Scotland":"Wemyss, Fife, Scotland","Inchmartine, Perthshire, Scotland":"Perthshire, Scotland"},"fr":{"1315–1342":"1315–1342","1300–1350":"1300–1350","1307–Male":"1307–Décédé","1