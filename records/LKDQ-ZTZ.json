76":"1111–1176","1137–1203":"1137–1203","1070–1122":"1070–1122","1203":"1203","1137":"1137","Abt 1110":"circa 1110","1122":"1122","1111":"1111","1176":"1176","1110":"1110","about 1137":"circa 1137","1141":"1141","About 1122":"circa 1122","1070":"1070","Shropshire, England":"Shropshire, England","Torquay, Devon, England":"Torquay, Devon, England","Devon, England":"Devon, Engeland, Verenigd Koninkrijk"},"en":{"Abt 1110–1141":"about 1110–1141","1110–1141":"1110–1141","1111–1176":"1111–1176","1137–1203":"1137–1203","1070–1122":"1070–1122","1203":"1203","1137":"1137","Abt 1110":"about 1110","1122":"1122","1111":"1111","1176":"1176","1110":"1110","about 1137":"about 1137","1141":"1141","About 1122":"about 1122","1070":"1070","Shropshire, England":"Shropshire, England","Torquay, Devon, England":"Torquay, Devon, England","Devon, England":"Devon, England, United Kingdom","nameMeanings":[{"name":"Briwere","type":"LAST","attribution":"Dictionary of American Family Names © Patrick Hanks 2003, 2006.","meanings":["Some characteristic forenames:  French Armand, Andre, Pierre, Adrien, Aurele, Benedicte, Benoit, Colette, Fernand, Gaston, Marcel, Micheline.","French (<b>Brière</b>): topographic name from a regional variant of Old French <i>bruiere</i> ‘heather’ (see   Bruyere  ), or a habitational name from La Brière, the name of several places mainly in the northern part of France, from the same word.","History: Jean Brière from Clarbec in Calvados, France, married Jeanne Grandin in Quebec City, QC, in 1671."],"variants":[{"name":"Bruyere","meanings":["Some characteristic forenames:  French Andre, Fernand, Jacques, Marcel.","French (<b>Bruyère</b>): from Old French <i>bruiere</i> ‘heather’, hence a topographic name for someone who lived in a place where heather grew, or a habitational name from one of the places in France (for example in Calvados) named with this word. Compare   Labruyere  .","Altered form (<b>Bruyère</b>) of French <b>Bruguier</b>: habitational name from (Le) Bruguier, the name of several places in the southeastern part of France, a cognate of 1 above."]}]},{"name":"Alice","type":"FIRST","attribution":"Dictionary of First Names © Patrick Hanks and Flavia Hodges 1990, 2003, 2006.","meanings":["Originally a variant of   Adelaide  , representing an Old French spelling of a reduced form of Germanic <i>Adalheidis</i>. <i>Alice</i> and <i>Adelaide</i> were already regarded as distinct names in English during the medieval period. <i>Alice</i> enjoyed a surge of popularity in the 19th century and periods of favour ever since. It was the name of the central character of  Lewis Carroll's  Alice's Adventures in Wonderland (  1865 ) and Through the Looking Glass (  1872 ), who was based on his child friend  Alice Liddell , daughter of the Dean of Christ Church, Oxford."],"variants":[{"name":"Alys","meanings":["Variant spelling of   Alice ."]},{"name":"Alis","meanings":["equivalent of <b>Alice</b> ."]}]}],"lifeSummary":"Alice Briwere was born about 1110, in Shropshire, England as the daughter of Maud de Bailleul. She had at least 1 son with Aldulf de Braci II. She died in 1141, in Torquay, Devon, England, at the age of 32."},"et":{"Abt 1110–1141":"umbes 1110–1141","1110–1141":"1110–1141","1111–1176":"1111–1176","1137–1203":"1137–1203","1070–1122":"1070–1122","1203":"1203","1137":"1137","Abt 1110":"umbes 1110","1122":"1122","1111":"1111","1176":"1176","1110":"1110","about 1137":"umbes 1137","1141":"1141","About 1122":"umbes 1122","1070":"1070","Shropshire, England":"Shropshire, England","Torquay, Devon, England":"Torquay, Devon, England","Devon, England":"Devon, Inglismaa, United Kingdom"},"fi":{"Abt 1110–1141":"noin 1110–1141","1110–1141":"1110–1141","1111–1176":"1111–1176","1137–1203":"1137–1203","1070–1122":"1070–1122","1203":"1203","1137":"1137","Abt 1110":"noin 1110","1122":"1122","1111":"1111","1176":"1176","1110":"1110","about 1137":"noin 1137","1141":"1141","About 1122":"noin 1122","1070":"1070","Shropshire, England":"Shropshire, E