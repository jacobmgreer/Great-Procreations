380","1305":"1305","1315":"1315","1368":"1368","1379":"1379","1302":"1302","1301":"1301","1332":"1332","1343":"1343","1320":"1320","2 July 1361":"2 July 1361","1329":"1329","Grendon Warwickshire England":"Grendon, Warwickshire, England, United Kingdom","Fulford, Stafford, Staffordshire, England, United Kingdom":"Stafford, Staffordshire, England, United Kingdom","Grendon, Warwickshire, England":"Grendon, Warwickshire, England","England":"England, United Kingdom","Grendon, North Warwickshire, Warwickshire, England, United Kingdom":"Grendon, Warwickshire, England, United Kingdom","nameMeanings":[{"name":"Grendon","type":"LAST","attribution":"Dictionary of Family Names in Britain and Ireland © University of the West of England 2016","meanings":["English: locative name from Grendon (in Witheridge and in Tavistock, Devon), Grendon (Northants, Warwicks), Grendon Underwood (Bucks), Grendon Bishop, Grendon Warren (Herefs), or Grindon (Durham, Northumb, Staffs)."],"variants":[{"name":"Grundon","meanings":["English: variant of  <i>Grindon</i>,  see  Grendon  ."]},{"name":"Grindon","meanings":["English:  see  Grendon  ."]}]},{"name":"Margaret","type":"FIRST","attribution":"Dictionary of First Names © Patrick Hanks and Flavia Hodges 1990, 2003, 2006.","meanings":["An extremely common given name from the Middle Ages onwards, derived via Old French <i>Marguerite</i> and Latin <i>Margarita</i> from Greek <i>Margarītēs</i>, from <i>margaron</i> ‘pearl’, a word ultimately of Hebrew origin. The name was always understood to mean ‘pearl’ throughout the Middle Ages. The first  St Margaret  was martyred at Antioch in Pisidia during the persecution instigated by the  Emperor Diocletian  in the early 4th century. However, there is some doubt about her name, as the same saint is venerated in the Orthodox Church as   Marina .  There were several other saintly bearers of the name, including St Margaret of Scotland (  d. 1093 ), wife of  King Malcolm Canmore  and daughter of Edmund Ironside of England. It was also the name of the wife of  Henry VI  of England,  Margaret of Anjou  (  1430–82 ), and of  Margaret Tudor  (  1489–1541 ), sister of  Henry VIII , who married James IV of Scotland and ruled as regent there after his death.  See also  Margery  ,   Marjorie ."],"variants":[{"name":"Margareta","meanings":["From the Latin form of Greek <i>Margarītēs</i>.  See  <b>Margaret</b>   ."]},{"name":"Margaretta","meanings":["Formed from Margaret."]}]}],"lifeSummary":"When Margaret Grendon was born in 1320, in Grendon, Warwickshire, England, United Kingdom, her father, Sir Ralph de Grendon, was 50 and her mother, Joan Clinton, was 35. She married John Redyng. She died in 1368, in Stafford, Staffordshire, England, United Kingdom, at the age of 48."},"et":{"1320–1368":"1320–1368","1302–1343":"1302–1343","1305–1379":"1305–1379","1315–1361":"1315–1361","–Male":"Surnud","1305–1380":"1305–1380","–1368":"–1368","–1379":"–1379","1270–1332":"1270–1332","1285–1329":"1285–1329","1285":"1285","1361":"1361","20 January 1332":"20. jaanuar 1332","1270":"1270","1380":"1380","1305":"1305","1315":"1315","1368":"1368","1379":"1379","1302":"1302","1301":"1301","1332":"1332","1343":"1343","1320":"1320","2 July 1361":"2. juuli 1361","1329":"1329","Grendon Warwickshire England":"Grendon, Warwickshire, Inglismaa, United Kingdom","Fulford, Stafford, Staffordshire, England, United Kingdom":"Stafford, Staffordshire, Inglismaa, United Kingdom","Grendon, Warwickshire, England":"Grendon, Warwickshire, England","England":"Inglismaa, United Kingdom","Grendon, North Warwickshire, Warwickshire, England, United Kingdom":"Grendon, Warwickshire, Inglismaa, United Kingdom"},"fi":{"1320–1368":"1320–1368","1302–1343":"1302–1343","1305–1379":"1305–1379","1315–1361":"1315–1361","–Male":"Kuollut","1305–1380":"1305–1380","–1368":"–1368","–1379":"–1379","1270–1332":"1270–1332","1285–1329":"1285–1329","1285":"1285","1361":"1361","20 January 1332":"20. tammikuuta 1332","1270":"1270","1380":"1380","1305":"1