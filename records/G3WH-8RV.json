ire, England":"Lancashire, England","Stonyhurst, Lancashire, England":"Stonyhurst, Lancashire, England","Great Carleton, Lancashire, England":"Great Carleton, Lancashire, England"},"nl":{"about 1240–after 1317":"circa 1240–na 1317","1240–1317":"1240–1317","1246–1272":"1246–1272","–Male":"Overleden","1277–1342":"1277–1342","1215–1261":"1215–1261","1223–1261":"1223–1261","1240":"1240","1261":"1261","1272":"1272","1290":"1290","1315":"1315","1259":"1259","1215":"1215","after 1317":"na 1317","1246":"1246","1223":"1223","1277":"1277","1342":"1342","about 1277":"circa 1277","after 1317 ":"na 1317","about 1240":"circa 1240","1317":"1317","Sherburn, Durham, England":"Sherburn Village, Durham, England","Mitton, Yorkshire, England":"Mitton, Yorkshire, England","Lancashire, England":"Lancashire, England","Stonyhurst, Lancashire, England":"Stonyhurst, Lancashire, England","Great Carleton, Lancashire, England":"Great Carleton, Lancashire, England"},"en":{"about 1240–after 1317":"about 1240–after 1317","1240–1317":"1240–1317","1246–1272":"1246–1272","–Male":"Deceased","1277–1342":"1277–1342","1215–1261":"1215–1261","1223–1261":"1223–1261","1240":"1240","1261":"1261","1272":"1272","1290":"1290","1315":"1315","1259":"1259","1215":"1215","after 1317":"after 1317","1246":"1246","1223":"1223","1277":"1277","1342":"1342","about 1277":"about 1277","after 1317 ":"after 1317","about 1240":"about 1240","1317":"1317","Sherburn, Durham, England":"Sherburn Village, Durham, England","Mitton, Yorkshire, England":"Mitton, Yorkshire, England","Lancashire, England":"Lancashire, England","Stonyhurst, Lancashire, England":"Stonyhurst, Lancashire, England","Great Carleton, Lancashire, England":"Great Carleton, Lancashire, England","nameMeanings":[{"name":"Sherburne","type":"LAST","attribution":"Dictionary of American Family Names © Patrick Hanks 2003, 2006.","meanings":["English (Lancashire): habitational name from any of several places called with Old English <i>scīr</i> ‘bright, clear’ + <i>burna</i> ‘stream’, including Sherburn in Elmet (Yorkshire), Sherburn (East Yorkshire, Durham), Shirburn (Oxfordshire), Sherborne (Dorset, Gloucestershire), Sherborne Saint John, Monk Sherborne (Hampshire), Sherbourne (Warwickshire), Sherbourne in Albury (Surrey), and Sherborne in Litton (Somerset). This surname is now rare in Britain."],"variants":[{"name":"Sherburn","meanings":["English: variant of   Sherburne  ."]},{"name":"Sherbon","meanings":["English: variant of   Sherburne   with loss of the second <i>-r-</i> by dissimilation. This form of the surname is now rare in Britain."]}]},{"name":"John","type":"FIRST","attribution":"Dictionary of First Names © Patrick Hanks and Flavia Hodges 1990, 2003, 2006.","meanings":["Contracted form of Old French <i>Jo(h)anne</i>, from Latin <i>Io(h)anna</i> (  see  Joanna  ). In England this was the usual feminine form of   John   from the Middle English period onwards and was extremely popular, but in the 16th and 17th centuries it steadily lost ground to   Jane .  It was strongly revived in the first part of the 20th century, partly under the influence of  George Bernard Shaw's  play St Joan (  1923 ), based on the life of  Joan of Arc  (  1412–31 ). Claiming to be guided by the voices of the saints, she persuaded the French dauphin to defy the occupying English forces and have himself crowned, and she led the French army that raised the siege of Orleans in  1429 . The following year she was captured by the Burgundians and sold to the English, and a year later she was burned at the stake for witchcraft at the age of 18 or 19. Her story has captured the imagination of many writers, and she is variously portrayed as a national and political hero, a model of apolitical straightforwardness and honesty, and a religious heroine. She was canonized in  1920 . More recent influences have included the American film actress  Joan Crawford  (  1908–77 , born  Lucille le Sueur ), the British actress  Joan Collins  (  b. 1933 ), the American comedienne  Joan Rivers  (  b. 1933 ), and the West Indian pop singer  Joan Armatrading  (  b. 1950 )."],"variants":[]}],"historicEvents":[{"id":1705189,"age":19,"year":"1259","julianDay":2180901,"title":"100 Years of Conflict Between England and France Ends","description":"Treaty of Paris was signed on December 4, 1259, which ended 100 years of conflict between England and France.","url":"https://en.wikipedia.org/wiki/Treaty_of_Paris_(1259)","urlTitle":"Wikipedia - Treaty of Paris 1259","jurisdictionLevel":2},{"id":1705190,"age":50,"year":"1290","julianDay":2192224,"title":"Jews Expelled From England","description":"After years of anti-Semitic behavior, King Edward I expelled Jews from England in 1290.","jurisdictionLevel":2},{"id":1705191,"age":75,"year":"1315","toYear":"1317","julianDay":2201354,"title":"Famine Strikes Europe","description":"A famine caused by cold winters and wet summers across Europe caused millions to die due to starvation. Desperation from hunger caused high levels of crime, stampedes in bread lines in London, infanticide, and even cannibalism throughout Europe.","jurisdictionLevel":2}],"lifeSummary":"When John Sherburne was born about 1240, in Stonyhurst, Lancashire, England, his father, Robert Sherburne, was 26 and his mother, Matilda Catford, was 18. He had at least 1 son with Eva Carleton. He died after 1317, in Lancashire, England."},"et":{"about 1240–after 1317":"umbes 1240–pärast 1317","1240–1317":"1240–1317","1246–1272":"1246–1272","–Male":"Surnud","1277–1342":"1277–1342","1215–1261":"1215–1261","1223–1261":"1223–1261","1240":"1240","1261":"1261","1272":"1272","1290":"1290","1315":"1315","1259":"1259","1215":"1215","after 1317":"pärast 1317","1246":"1246","1223":"1223","1277":"1277","1342":"1342","about 1277":"umbes 1277","after 1317 ":"pärast 1317","about 1240":"umbes 1240","1317":"1317","Sherburn, Durham, England":"Sherburn Village, Durham, England","Mitton, Yorkshire, England":"Mitton, Yorkshire, England","Lancashire, England":"Lancash