1325":"1268–1325","1310–Male":"1310–Zesnulý","1310–1353":"1310–1353","1330–1385":"1330–1385","1325":"1325","before 1310":"před 1310","1268":"1268","1310":"1310","1353":"1353","1385":"1385","1330":"1330","1280":"1280","1290":"1290","Chillingham, Northumberland, England":"Chillingham, Northumberland, Anglie","England":"Anglie"},"da":{"1280–1310":"1280–1310","1268–1325":"1268–1325","1310–Male":"1310–Afdød","1310–1353":"1310–1353","1330–1385":"1330–1385","1325":"1325","before 1310":"før 1310","1268":"1268","1310":"1310","1353":"1353","1385":"1385","1330":"1330","1280":"1280","1290":"1290","Chillingham, Northumberland, England":"Chillingham, Northumberland, England","England":"England"},"nl":{"1280–1310":"1280–1310","1268–1325":"1268–1325","1310–Male":"1310–Overleden","1310–1353":"1310–1353","1330–1385":"1330–1385","1325":"1325","before 1310":"vóór 1310","1268":"1268","1310":"1310","1353":"1353","1385":"1385","1330":"1330","1280":"1280","1290":"1290","Chillingham, Northumberland, England":"Chillingham, Northumberland, England","England":"England"},"en":{"1280–1310":"1280–1310","1268–1325":"1268–1325","1310–Male":"1310–Deceased","1310–1353":"1310–1353","1330–1385":"1330–1385","1325":"1325","before 1310":"before 1310","1268":"1268","1310":"1310","1353":"1353","1385":"1385","1330":"1330","1280":"1280","1290":"1290","Chillingham, Northumberland, England":"Chillingham, Northumberland, England","England":"England","nameMeanings":[{"name":"Towley","type":"LAST","attribution":"Dictionary of American Family Names © Patrick Hanks 2003, 2006.","meanings":["English: habitational name from any of various places called Cowley. One in Gloucestershire is named with Old English <i>cū</i> ‘cow’ + <i>lēah</i> ‘woodland clearing’; two in Derbyshire have Old English <i>col</i> ‘(char)coal’ as the first element; and one near London is from Old English <i>cofa</i> ‘shelter, bay’ (see   Cove  ) or the personal name <i>Cofa</i>. The largest group, however, with examples in Buckinghamshire, Devon, Oxfordshire, and Staffordshire, were apparently named as ‘the wood or clearing of <i>Cufa</i>’; however, in view of the number of places called with this element, it is possible that it conceals a topographic term as well as a personal name.","Irish: shortened form of <b>Macaulay</b> (see   McCauley  ).","Manx: shortened form of Gaelic <i>Mac Amhlaoibh</i> ‘son of <i>Amhlaoibh</i>’ (a Gaelicized form of Old Norse <i>Óláfr</i>). For an alternative Manx form of the same patronymic see   Callow  ."],"variants":[{"name":"Coley","meanings":["English (Midlands): nickname for a swarthy person, from Middle English <i>coly</i> ‘coaly, coal-black’. The original short vowel is retained in the 16th century <i>colly</i> ‘dirtied with coal and soot’. Alternatively, a variant of   Cowley  .","Probably an Americanized form of Swiss German   Kohli   or   Kohler  ."]},{"name":"Cove","meanings":["English:","habitational name from a place called (the) Cove, examples of which are found in Hampshire, Wilts (a minor name in Leigh), Devon, and Suffolk, all from Old English <i>cofa</i>, which is recorded in literary sources with the sense ‘enclosed chamber’ but in placenames probably with extended senses such as ‘shelter, hut, building’, ‘hollow’ (in the case of the Devon name), and ‘creek, inlet’ (in the case of the Suffolk name).","nickname from Middle English <i>cof</i>, <i>cove</i> ‘eager, bold, courageous’ (Old English <i>cāf</i>)."]}]},{"name":"Margaret","type":"FIRST","attribution":"Dictionary of First Names © Patrick Hanks and Flavia Hodges 1990, 2003, 2006.","meanings":["An extremely common given name from the Middle Ages onwards, derived via Old French <i>Marguerite</i> and Latin <i>Margarita</i> from Greek <i>Margarītēs</i>, from <i>margaron</i> ‘pearl’, a word ultimately of Hebrew origin. The name was always understood to mean ‘pearl’ throughout the Middle Ages. The first  St Margaret  was martyred at Antioch in Pisidia during the persecution instigated by the  Emperor Diocletian  in the early 4th century. However, there is some doubt about her name, as the same saint is venerated in the Orthodox Church as   Marina .  There were several other saintly bearers of the name, including St Margaret of Scotland (  d. 1093 ), wife of  King Malcolm Canmore  and daughter of Edmund Ironside of England. It was also the name of the wife of  Henry VI  of England,  Margaret of Anjou  (  1430–82 ), and of  Margaret Tudor  (  1489–1541 ), sister of  Henry VIII , who married James IV of Scotland and ruled as regent there after his death.  See also  Margery  ,   Marjorie ."],"variants":[{"name":"Margareta","meanings":["From the Latin form of Greek <i>Margarītēs</i>.  See  <b>Margaret</b>   ."]},{"name":"Margaretta","meanings":["An extremely common given name from the Middle Ages onwards, derived via Old French <i>Marguerite</i> and Latin <i>Margarita</i> from Greek <i>Margarītēs</i>, from <i>margaron</i> ‘pearl’, a word ultimately of Hebrew origin. The name was always understood to mean ‘pearl’ throughout the Middle Ages. The first  St Margaret  was martyred at Antioch in Pisidia during the persecution instigated by the  Emperor Diocletian  in the early 4th century. However, there is some doubt about her name, as the same saint is venerated in the Orthodox Church as   Marina .  There were several other saintly bearers of the name, including St Margaret of Scotland (  d. 1093 ), wife of  King Malcolm Canmore  and daughter of Edmund Ironside of England. It was also the name of the wife of  Henry VI  of England,  Margaret of Anjou  (  1430–82 ), and of  Margaret Tudor  (  1489–1541 ), sister of  Henry VIII , who married James IV of Scotland and ruled as regent there after his death.  See also  Margery  ,   Marjorie ."]}]}],"historicEvents":[{"id":1705190,"age":10,"year":"1290","julianDay":2192224,"title":"Jews Expelled From England","description":"After years of anti-Semitic behavior, King Edward I expelled Jews from England in 1290.","jurisdictionLevel":0}],