ants":[{"name":"Wishart","meanings":["The same with the old name Guiscard, in Hebrew R. Wiscard; from Old German wtsa-hart, strong leader. It is found Latinised Guiscardus."]}]}],"lifeSummary":"Wischard Ledet was born in 1136, in Staffordshire, England, United Kingdom. He married Christian Longstone. They were the parents of at least 2 sons and 1 daughter. He died in 1208, in West Langton, Leicestershire, England, at the age of 72."},"et":{"1136–1208":"1136–1208","1140–Female":"1140–Surnud","1164–1222":"1164–1222","1166–Female":"1166–Surnud","Abt 1164":"umbes 1164","1136":"1136","1222":"1222","1166":"1166","1164":"1164","1140":"1140","about 1166":"umbes 1166","1208":"1208","Chipping Warden, Northamptonshire, England, United Kingdom":"Chipping Warden, Northamptonshire, Inglismaa, United Kingdom","Chipping Warden, Northamptonshire, England":"Chipping Warden, Northamptonshire, England","England":"England","West Langton, Leicestershire, England":"West Langton, Leicestershire, England","Staffordshire, England":"Staffordshire, Inglismaa, United Kingdom"},"fi":{"1136–1208":"1136–1208","1140–Female":"1140–Kuollut","1164–1222":"1164–1222","1166–Female":"1166–Kuollut","Abt 1164":"noin 1164","1136":"1136","1222":"1222","1166":"1166","1164":"1164","1140":"1140","about 1166":"noin 1166","1208":"1208","Chipping Warden, Northamptonshire, England, United Kingdom":"Chipping Warden, Northamptonshire, Englanti, Yhdistynyt kuningaskunta","Chipping Warden, Northamptonshire, England":"Chipping Warden, Northamptonshire, England","England":"England","West Langton, Leicestershire, England":"West Langton, Leicestershire, England","Staffordshire, England":"Staffordshire, Englanti, Yhdistynyt kuningaskunta"},"fr":{"1136–1208":"1136–1208","1140–Female":"1140–Décédée","1164–1222":"1164–1222","1166–Female":"1166–Décédée","Abt 1164":"environ 1164","1136":"1136","1222":"1222","1166":"1166","1164":"1164","1140":"1140","about 1166":"environ 1166","1208":"1208","Chipping Warden, Northamptonshire, Engl