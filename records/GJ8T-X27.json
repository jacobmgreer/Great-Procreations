jk","England":"England","Wigmore, Herefordshire, England":"Wigmore, Herefordshire, England","Wayland, Norfolk, England":"Wayland, Norfolk, Engeland, Verenigd Koninkrijk"},"en":{"1060–":"1060–Deceased","1050–1104":"1050–1104","1087–1148":"1087–1148","1090–Male":"1090–Deceased","1098–Male":"1098–Deceased","–Male":"Deceased","1060–Female":"1060–Deceased","1090":"1090","1106":"1106","1148":"1148","1104":"1104","1066":"1066","1087":"1087","1098":"1098","1086":"1086","1096":"1096","about 1098":"about 1098","1050":"1050","1060":"1060","Wigmore Castle, Herefordshire, England":"Wigmore Castle, Herefordshire, England, United Kingdom","England":"England","Wigmore, Herefordshire, England":"Wigmore, Herefordshire, England","Wayland, Norfolk, England":"Wayland, Norfolk, England, United Kingdom","nameMeanings":[{"name":"Mortimer","type":"LAST","attribution":"Dictionary of American Family Names © Patrick Hanks 2003, 2006.","meanings":["English and Scottish (of Norman origin): habitational name from Mortemer in Seine-Maritime, France, so called from Old French <i>mort(e)</i> ‘dead’ + <i>mer</i> ‘sea’, probably referring to a stagnant pond or drained swamp.","Irish (of Norman origin): the Norman surname in sense 1 above was taken to Ireland from England in the medieval period, where it has also been adopted by bearers of the Gaelic surnames <b>Mac Muircheartaigh</b> and <b>ÓMuircheartaigh</b>, commonly Anglicized as <b>McMurty</b> and <b>Mortagh</b>. Compare   McMurdo  ."],"variants":[{"name":"Mortimore","meanings":["English (Devon; of Norman origin): variant of   Mortimer  ."]},{"name":"McMurdo","meanings":["Scottish: Anglicized form of Gaelic <b>Mac Muircheartaigh</b> or <b>Mac Muircheartaich</b>, ‘son of Muircheartach’, a personal name meaning ‘sea-ruler’. In Scotland the name was often lenited to give   McCurdy  . Compare   Murdoch   and   Moriarty  . The name was also used to Anglicize <i>Mac Murchaidh</i> (see   McMorrow  )."]}]},{"name":"Mabel","type":"FIRST","attribution":"Dictionary of First Names © Patrick Hanks and Flavia Hodges 1990, 2003, 2006.","meanings":["Originally a nickname from the Old French vocabulary word <i>amabel</i>, <i>amable</i> ‘lovely’ (akin to modern English <i>amiable</i> ‘friendly, good-humoured’). The initial vowel began to be lost as early as the 12th century (the same woman is referred to as both <i>Mabilia</i> and <i>Amabilia</i> in a document of  1185 ), but a short vowel in the resulting first syllable was standard, giving a rhyme with <i>babble</i>, until the 19th century, when people began to pronounce the name to rhyme with <i>table</i>."],"variants":[]}],"historicEvents":[{"id":1705182,"age":6,"year":"1066","julianDay":2110409,"title":"Battle of Hastings","description":"Battle of Hastings was fought between the Norman-French army and the battle-wary English army on October 14, 1066. Duke William of Normandy believed he was the rightful king rather than Harold, who had been crowned king several months earlier. Harold was killed in battle and William was crowned king on Christmas Day 1066.","url":"https://www.english-heritage.org.uk/learn/1066-and-the-norman-conquest/what-happened-battle-hastings/","urlTitle":"English Heritage - Battle of Hastings","jurisdictionLevel":0},{"id":1705183,"age":26,"year":"1086","julianDay":2117714,"title":"Domesday Book","description":"Domesday Book is Britain's earliest extant public record with information containing land surveys and landholdings commissioned by William I. The book was completed in 1086.","url":"https://www.nationalarchives.gov.uk/domesday/","urlTitle":"National Archives - Domesday","jurisdictionLevel":0},{"id":1705184,"age":36,"year":"1096","julianDay":2121366,"title":"The Crusades","description":"A series of religious wars between Christians and Muslims, known as the Crusades, occurred between 1096 and 1291, and played a large role in European Christian dominance in the Middle East.","url":"https://www.history.com/topics/middle-ages/crusades","urlTitle":"History - The Crusades","jurisdictionLevel":0},{"id":1705185,"age":46,"year":"1106","julianDay":2125018,"title":"The Battle of Tichebray","description":"King Henry I defeated and captured his brother, Robert of Normandy, at the Battle of Tinchebray in 1106. Robert remained in captivity until his death in 1134.","jurisdictionLevel":0}],"lifeSummary":"Lady Mabel Mortimer was born in 1060, in England. She had at least 4 sons with Lord Ranulph de Mortimer."},"et":{"1060–":"1060–Surnud","1050–1104":"1050–1104","1087–1148":"1087–1148","1090–Male":"1090–Surnud","1098–Male":"1098–Surnud","–Male":"Surnud","1060–Female":"1060–Surnud","1090":"1090","1106":"1106","1148":"1148","1104":"1104","1066":"1066","1087":"1087","1098":"1098","1086":"1086","1096":"1096","about 1098":"umbes 1098","1050":"1050","1060":"1060","Wigmore Castle, Herefordshire, England":"Wigmore Castle, Herefordshire, Inglismaa, United Kingdom","England":"England","Wigmore, Herefordshire, England":"Wigmore, Herefordshire, England","Wayland, Norfolk, England":"Wayland, Norfolk, Inglismaa, United Kingdom"},"fi":{"1060–":"1060–Kuollut","1050–1104":"1050–1104","1087–1148":"1087–1148","1090–Male":"1090–Kuollut","1098–Male":"1098–Kuollut","–Male":"Kuollut","1060–Female":"1060–Kuollut","1090":"1090","1106":"1106","1148":"1148","1104":"1104","1066":"1066","1087":"1087","1098":"1098","1086":"1086","1096":"1096","about 1098":"noin 1098","1050":"1050","1060":"1060","Wigmore Castle, Herefordshire, England":"Wigmore Castle, Herefordshire, Englanti, Yhdistynyt kuningaskunta","England":"England","Wigmore, Herefordshire, England":"Wigmore, Herefordshire, England","Wayland, Norfolk, England":"Wayland, Norfolk, Englanti, Yhdistynyt kuningaskunta"},"fr":{"1060–":"1060–Décédée","1050–1104":"1050–1104","1087–1148":"1087–1148","1090–Male":"1090–Décédé","1098–Male":"1098–Décédé","–Male":"Décédé","1060–Female":"1060–Décédée","1090":"1090","1106":"1106","1148":"1148","1104":"1104","1066":"1066","1087":"1087","1098":"1098","1086":"1086"