ull 19. Er hat vor 2. November 1381 in Middlesex, England Maud Francis geheiratet. Sie hatten mindestens 1 Sohn. Er starb am 2. November 1381 im Alter von 59 Jahren in London, England und wurde in City of London, England, United Kingdom begraben."},"ht":{"about 1323–2 November 1381":"about 1323–2 November 1381","1323–1381":"1323–1381","1362–1424":"1362–1424","1382–1424":"1382–1424","1351–1420":"1351–1420","1352–1416":"1352–1416","1295–1325":"1295–1325","1305–1326":"1305–1326","2 November 1381":"2 November 1381","1352":"1352","18 July 1326":"18 July 1326","1351":"1351","1362":"1362","1295":"1295","1382":"1382","before 2 November 1381":"before 2 November 1381","1381":"1381","1305":"1305","1337":"1337","1326":"1326","1325":"1325","1424":"1424","1323":"1323","1453":"1453","1420":"1420","about 1323":"about 1323","1328":"1328","1416":"1416","Cockermouth, Cumberland, England":"Cockermouth, Cumberland, England","Middlesex, England":"Middlesex, England","Sussex, England":"Sussex, England","London, England":"London, England","Jesus' Chapel, Old St. Paul's, London, Middlesex,England":"City of London, Angletè, United Kingdom","Dorset, England":"Dorset, England"},"hu":{"about 1323–2 November 1381":"1323 körül–1381. november 2.","1323–1381":"1323–1381","1362–1424":"1362–1424","1382–1424":"1382–1424","1351–1420":"1351–1420","1352–1416":"1352–1416","1295–1325":"1295–1325","1305–1326":"1305–1326","2 November 1381":"1381. november 2.","1352":"1352","18 July 1326":"1326. július 18.","1351":"1351","1362":"1362","1295":"1295","1382":"1382","before 2 November 1381":"1381. november 2. előtt","1381":"1381","1305":"1305","1337":"1337","1326":"1326","1325":"1325","1424":"1424","1323":"1323","1453":"1453","1420":"1420","about 1323":"1323 körül","1328":"1328","1416":"1416","Cockermouth, Cumberland, England":"Cockermouth, Cumberland, England","Middlesex, England":"Middlesex, England","Sussex, England":"Sussex, England","London, England":"London, England","Jesus' Chapel, Old St. Paul's, London, 