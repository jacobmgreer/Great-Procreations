ingdom":"Staffordshire, Anglie, United Kingdom","Bromley, Staffordshire, England, United Kingdom":"Bromley, Staffordshire, Anglie, United Kingdom"},"da":{"–1214":"–1214","1086–1140":"1086–1140","1080–1130":"1080–1130","1130–1181":"1130–1181","1080":"1080","1214":"1214","1130":"1130","1086":"1086","1140":"1140","1181":"1181","Staffordshire, England, United Kingdom":"Staffordshire, England, United Kingdom","Bramshall, Staffordshire, England":"Bramshall, Staffordshire, England","Hyde, Hampshire, England":"Hyde, Hampshire, England, United Kingdom","Bramelle, Staffordshire, England, United Kingdom":"Staffordshire, England, United Kingdom","Bromley, Staffordshire, England, United Kingdom":"Bromley, Staffordshire, England, United Kingdom"},"nl":{"–1214":"–1214","1086–1140":"1086–1140","1080–1130":"1080–1130","1130–1181":"1130–1181","1080":"1080","1214":"1214","1130":"1130","1086":"1086","1140":"1140","1181":"1181","Staffordshire, England, United Kingdom":"Staffordshire, Engeland, Verenigd Koninkrijk","Bramshall, Staffordshire, England":"Bramshall, Staffordshire, England","Hyde, Hampshire, England":"Hyde, Hampshire, Engeland, Verenigd Koninkrijk","Bramelle, Staffordshire, England, United Kingdom":"Staffordshire, Engeland, Verenigd Koninkrijk","Bromley, Staffordshire, England, United Kingdom":"Bromley, Staffordshire, Engeland, Verenigd Koninkrijk"},"en":{"–1214":"–1214","1086–1140":"1086–1140","1080–1130":"1080–1130","1130–1181":"1130–1181","1080":"1080","1214":"1214","1130":"1130","1086":"1086","1140":"1140","1181":"1181","Staffordshire, England, United Kingdom":"Staffordshire, England, United Kingdom","Bramshall, Staffordshire, England":"Bramshall, Staffordshire, England","Hyde, Hampshire, England":"Hyde, Hampshire, England, United Kingdom","Bramelle, Staffordshire, England, United Kingdom":"Staffordshire, England, United Kingdom","Bromley, Staffordshire, England, United Kingdom":"Bromley, Staffordshire, England, United Kingdom","nameMeanings":[{"name":"de","type":"LAST","attribution":"Dictionary of American Family Names © Patrick Hanks 2003, 2006.","meanings":["Some characteristic forenames:  Indian Dilip, Anirban, Gopal, Alok, Anindya, Arunava, Asit, Asok, Dibyendu, Goutam, Indra, Indranil.","Indian: variant of   Dey  ."],"variants":[{"name":"Dey","meanings":["Some characteristic forenames:  Indian Ashit, Indu, Naina, Partha, Soumya, Ajit, Anjan, Anjana, Anup, Arjun, Arun, Ashim.","English, Scottish, and Welsh: variant of   Day  .","German: topographic name from a field name in North Rhine-Westphalia, denoting a sizeable piece of land, from Middle Low German <i>dē</i> ‘thigh’ (referring to the shape of the property)."]}]},{"name":"Clare","type":"LAST","attribution":"Dictionary of American Family Names © Patrick Hanks 2003, 2006.","meanings":["Irish (Clare, Wicklow, and Wexford): habitational name from Clare in Suffolk (an eastern county of England), the center of a major Norman baronial estate since the Norman Conquest. The English placename probably originated as a Celtic river name meaning ‘bright, gentle, or warm’. The surname is not from the Irish county name <i>Clare</i>, which is either from the surname or from a place called with Gaelic <i>clár</i> ‘plank bridge’. Another Norman surname in the southeast of Ireland was <i>de Clere</i>, from Clères in Seine-Maritime (France), named from the local river.","English and French: from the Middle English, Old French female personal name <i>Cla(i)re</i> (from Latin <i>Clara</i>, from <i>clarus</i> ‘clear, bright, famous’) which achieved some popularity, greater elsewhere in Europe than in England, through the fame of Saint Clare of Assisi (see   Chiara  ). The English surname seems to have been interchangeable with   Clear   1.","English: occupational name from an agent derivative of Middle English <i>cley</i> ‘clay’. The work of medieval clayers involved plastering a framework of interwoven twigs with mud to produce wattle-and-daub work."],"variants":[{"name":"Claire","meanings":["Irish: variant of   Clare  .","Variant of   Clair  , an altered form of German   Klare  .","French: variant of   Clair  ."]},{"name":"Chiara","meanings":["Some characteristic forenames:  Italian Marco, Amedeo, Angelo, Gino, Rocco.","Italian: from the female personal name <i>Chiara</i> or <i>Clara</i>, a name popularized in the medieval period by the cult of Saint Clare of Assisi (<i>c.</i> 1193–1253); she was an associate of Saint Francis of Assisi and founded the order of nuns known as the Poor Clares. See also   Chiaro  ."]},{"name":"Claar","meanings":["German: variant of <b>Klaar</b> (and, in North America, an altered form of this), a nickname from Middle High German, Middle Low German <i>klar</i> ‘pure, pretty, sensible’, or a habitational name from a minor place so named near Braunschweig.","Possibly also an Americanized form of Dutch <b>Klaar</b>: from a vernacular form of the female personal name <i>Clara</i> (see   Clare   2)."]},{"name":"Clarkin","meanings":["English (Lancashire and Cheshire): from a pet form of the personal name <i>Clare</i> (compare   Clare   and   Clear  ), which is both a masculine and a female personal name in Middle English.","Irish (Monaghan): variant of   Clerkin  ."]},{"name":"Clear","meanings":["English (southeastern England, of Norman origin): from <i>Clere</i>, the French popular form of the personal name   Clare   2, and possibly interchangeable with it or confused with it.","English (southeastern): probably a habitational name from clere, a component of several placenames in north Hampshire (Highclere, Burghclere, Kingsclere). This is probably from a Celtic stream name meaning ‘bright’ (cognate with Latin <i>clarus</i> ‘clear, bright’).","Americanized form (translation into English) of German   Klar   1."]}]},{"name":"Avis","type":"FIRST","attribution":"Dictionary of First Names © Patrick Hanks and Flavia Hodges 1990, 2003, 2006.","meanings":["From a Norman French form of the ancient Germanic name <i>Aveza</i>, derived from a short form of one or more compound names containing the first element <i>av</i> (as in   Ava ;  the meaning is uncertain). The correspondence in form to the Latin word <i>avis</i> ‘bird’ is coincidental."],"variants":[{"name":"Avice","meanings":["See Hawise."]}]}],"lifeSummary":"Avis de Clare had at least 1 son with Hervey fitz Baggott. She died in 1214, in Hyde, Hampshire, England, United Kingdom, and was buried in Hyde, Hampshire, England, United Kingdom."},"et":{"–1214":"–1214","1086–1140":"1086–1140","1080–1130":"1080–1130","1130–1181":"1130–1181","1080":"1080","1214":"1214","1130":"1130","1086":"1086","1140":"1140","1181":"1181","Staffordshire, England, United Kingdom":"Staffordshire, Inglismaa, United Kingdom","Bramshall, Staffordshire, England":"Bramshall, Staffordshire, England","Hyde, Hampshire, England":"Hyde, Hampshire, Inglismaa, United Kingdom","Bramelle, Staffordshire, England, United Kingdom":"Staffordshire, Inglismaa, United Kingdom","Bromley, Staffordshire, England, United Kingdom":"Bromley, Staffordshire, Inglismaa, United Kingdom"},"fi":{"–1214":"–1214","1086–1140":"1086–1140","1080–1130":"1080–1130","1130–1181":"1130–1181","1080":"1080","1214":"1214","1130":"1130","1086":"1086","1140":"1140","1181":"1181","Staffordshire, England, United Kingdom":"Staffordshire, Englanti, Yhdistynyt kuningaskunta","Bramshall, Staffordshire, England":"Bramshall, Staffordshire, England","Hyde, Hampshire, England":"Hyde, Hampshire, Englanti, Yhdistynyt kuningaskunta","Bramelle, Staffordshire, England, United Kingdom":"Staffordshire, Englanti, Yhdistynyt kuningaskunta","Bromley, Staffordshire, England, United Kingdom":"Bromley, Staffordshire, Englanti, Yhdistynyt kuningaskunta"},"fr":{"–1214":"–1214","1086–1140":"1086–1140","1080–1130":"1080–1130","1130–1181":"1130–1181","1080":"1080","1214":"1214","1130":"1130","1086":"1086","1140":"1140","1181":"1181","Staffordshire, England, United Kingdom":"Staffordshire, Angleterre, Royaume-Uni","Bramshall, Staffordshire, England"