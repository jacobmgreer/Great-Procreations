66":"1215–1266","1230–1295":"1230–1295","1245–1270":"1245–1270","1250–1298":"1250–1298","1194–1228":"1194–1228","1185–1250":"1185–1250","1230":"1230","1185":"1185","1295":"1295","1250":"1250","1194":"1194","abt. 1250":"omkring 1250","1270":"1270","1228":"1228","1215":"1215","abt 1228":"omkring 1228","1245":"1245","1266":"1266","1298":"1298","Fifeshire, Scotland":"Fife, Skotland, United Kingdom","Stafford, Staffordshire, England":"Stafford, Staffordshire, England","Scotland":"Skotland","Fife, Scotland":"Fife, Skotland","Methil, Fifeshire, Scotland":"Methil, Fife, Skotland"},"nl":{"1215–1266":"1215–1266","1230–1295":"1230–1295","1245–1270":"1245–1270","1250–1298":"1250–1298","1194–1228":"1194–1228","1185–1250":"1185–1250","1230":"1230","1185":"1185","1295":"1295","1250":"1250","1194":"1194","abt. 1250":"circa 1250","1270":"1270","1228":"1228","1215":"1215","abt 1228":"circa 1228","1245":"1245","1266":"1266","1298":"1298","Fifeshire, Scotland":"Fife, Schotland, Verenigd Koninkrijk","Stafford, Staffordshire, England":"Stafford, Staffordshire, England","Scotland":"Schotland","Fife, Scotland":"Fife, Schotland","Methil, Fifeshire, Scotland":"Methil, Fife, Schotland"},"en":{"1215–1266":"1215–1266","1230–1295":"1230–1295","1245–1270":"1245–1270","1250–1298":"1250–1298","1194–1228":"1194–1228","1185–1250":"1185–1250","1230":"1230","1185":"1185","1295":"1295","1250":"1250","1194":"1194","abt. 1250":"about 1250","1270":"1270","1228":"1228","1215":"1215","abt 1228":"about 1228","1245":"1245","1266":"1266","1298":"1298","Fifeshire, Scotland":"Fife, Scotland, United Kingdom","Stafford, Staffordshire, England":"Stafford, Staffordshire, England","Scotland":"Scotland","Fife, Scotland":"Fife, Scotland","Methil, Fifeshire, Scotland":"Methil, Fife, Scotland","nameMeanings":[{"name":"Coluim","type":"LAST","attribution":"Dictionary of Family Names in Britain and Ireland © University of the West of England 2016","meanings":["Irish: from  <b>Mac Coluim</b>,  see  McCallum  ."],"variants":[{"name":"McCallum","meanings":["Scottish and Irish: Anglicized form of Gaelic <b>Mac Caluim</b> ‘son of <i>Calum</i> or <i>Colum</i>’, a personal name derived from Latin <i>columba</i> ‘dove’. The surname often represents a short form of <i>Mac Gille Caluim</i> or <i>Mac Giolla Coluim</i> ‘son of the servant (i.e. devotee) of Saint <i>Columba</i>’ (<i>Colum Cille</i>). The personal name (Scottish <i>Calum</i>, Irish <i>Colum</i>, originally combined with <i>giolla</i> ‘servant’) has long been popular in Scotland and Ireland, due largely to the cult of Saint Columba, 521–597, who converted the Picts to Christianity and founded an influential monastery on the island of Iona. His name in Irish is <i>Colum Cille</i> ‘Dove of the Church’."]}]},{"name":"Máel","type":"FIRST","attribution":"Dictionary of First Names © Patrick Hanks and Flavia Hodges 1990, 2003, 2006.","meanings":["Originally a nickname from the Old French vocabulary word <i>amabel</i>, <i>amable</i> ‘lovely’ (akin to modern English <i>amiable</i> ‘friendly, good-humoured’). The initial vowel began to be lost as early as the 12th century (the same woman is referred to as both <i>Mabilia</i> and <i>Amabilia</i> in a document of  1185 ), but a short vowel in the resulting first syllable was standard, giving a rhyme with <i>babble</i>, until the 19th century, when people began to pronounce the name to rhyme with <i>table</i>."],"variants":[]}],"lifeSummary":"When Máel Coluim - Second Mormaer of Fife was born in 1215, in Fife, Scotland, his father, Duncan Macduff, was 22 and his mother, Alice Corbet, was 31. He had at least 2 sons with Elen ferch Llywelyn 'The Younger'. He died in 1266, in his hometown, at the age of 51, and was buried in Scotland."},"et":{"1215–1266":"1215–1266","1230–1295":"1230–1295","1245–1270":"1245–1270","1250–1298":"1250–1298","1194–1228":"1194–1228","1185–1250":"1185–1250","1230":"1230","1185":"1185","1295":"1295","1250":"1250","1194":"1194","abt. 1250":"umbes 1250","1270":"1270","1228":"