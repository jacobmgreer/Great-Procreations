nd":"Chichester, Sussex, Anglie, United Kingdom","Saint-Denis, Seine-Saint-Denis, Île-de-France, France":"Saint-Denis, Seine-Saint-Denis, Île-de-France, Francie"},"da":{"about 1125–about 1188":"omkring 1125–omkring 1188","–Female":"Afdød","1150–1213":"1150–1213","1153–Male":"1153–Afdød","1125–1188":"1125–1188","about 1150":"omkring 1150","1125":"1125","1213":"1213","1188":"1188","about 1125":"omkring 1125","1153":"1153","1150":"1150","about 1188":"omkring 1188","Lewes, Sussex, England, United Kingdom":"Lewes, Sussex, England, United Kingdom","Lewes, Chichester, Sussex, England":"Chichester, Sussex, England, United Kingdom","Saint-Denis, Seine-Saint-Denis, Île-de-France, France":"Saint-Denis, Seine-Saint-Denis, Île-de-France, Frankrig"},"nl":{"about 1125–about 1188":"circa 1125–circa 1188","–Female":"Overleden","1150–1213":"1150–1213","1153–Male":"1153–Overleden","1125–1188":"1125–1188","about 1150":"circa 1150","1125":"1125","1213":"1213","1188":"1188","about 1125":"circa 1125","1153":"1153","1150":"1150","about 1188":"circa 1188","Lewes, Sussex, England, United Kingdom":"Lewes, Sussex, Engeland, Verenigd Koninkrijk","Lewes, Chichester, Sussex, England":"Chichester, Sussex, Engeland, Verenigd Koninkrijk","Saint-Denis, Seine-Saint-Denis, Île-de-France, France":"Saint-Denis, Seine-Saint-Denis, Île-de-France, Frankrijk"},"en":{"about 1125–about 1188":"about 1125–about 1188","–Female":"Deceased","1150–1213":"1150–1213","1153–Male":"1153–Deceased","1125–1188":"1125–1188","about 1150":"about 1150","1125":"1125","1213":"1213","1188":"1188","about 1125":"about 1125","1153":"1153","1150":"1150","about 1188":"about 1188","Lewes, Sussex, England, United Kingdom":"Lewes, Sussex, England, United Kingdom","Lewes, Chichester, Sussex, England":"Chichester, Sussex, England, United Kingdom","Saint-Denis, Seine-Saint-Denis, Île-de-France, France":"Saint-Denis, Seine-Saint-Denis, Île-de-France, France","nameMeanings":[{"name":"Sidney","type":"LAST","attribution":"Dictionary of American Family Names © Patrick Hanks 2003, 2006.","meanings":["English (Durham):","habitational name from Sidney Farm in Alfold (Surrey), from Old English <i>sīd</i> ‘large, spacious, long’ (dative <i>sīdan</i>) + <i>ēg</i> ‘island’.","possibly also a habitational name from any of the places called Saint-Denis in Normandy, named from the dedication of their churches to Saint Dionysius (see   Dennis  )."],"variants":[{"name":"Dennis","meanings":["English: from the Middle English (Old French) personal name <i>Denis(e)</i>, <i>Dinis(e)</i>, vernacular forms of Latin <i>Dionysius</i>, Greek <i>Dionysios</i> ‘(follower) of <i>Dionysos</i>’, an eastern god introduced to the classical pantheon at a relatively late date and bearing a name of probably Semitic origin. The name was borne by various early Christian saints, including Saint Denis, the martyred 3rd-century bishop of Paris who became the patron saint of France. From the 12th century onward, the popularity of the name in England (and of its cognates, mainly   Denis  , in the continental Europe) seems to have been largely due to French influence. The feminine form <i>Dionysia</i> (in vernacular English likewise <i>Den(n)is</i>) is also found, and some examples of the surname may originate from it.","English: from Middle English <i>deneis</i>, a variant of <i>danais</i> ‘Danish’, with the vowel influenced by Middle English <i>denshe</i> (Old English <i>denisc</i>). Compare   Dence  .","Irish (mainly Dublin and Cork): of the same origin as 1 and 2 above, sometimes an alternative form to   Donohue   but more often to   McDonough  , since the personal name <i>Donnchadh</i> was Anglicized as <i>Donough</i> or <i>Denis</i>."]},{"name":"Sydney","meanings":["English and Scottish (Midlothian): variant of   Sidney  ."]}]},{"name":"William","type":"FIRST","attribution":"Dictionary of First Names © Patrick Hanks and Flavia Hodges 1990, 2003, 2006.","meanings":["Probably the most successful of all the Old French names of Germanic origin that were introduced to England by the Normans. It is derived from Germanic <i>wil</i> ‘will, desire’ + <i>helm</i> ‘helmet, protection’. The fact that it was borne by the Conqueror himself does not seem to have inhibited its favour with the ‘conquered’ population: in the first century after the Conquest it was the commonest male name of all, and not only among the Normans. In the later Middle Ages it was overtaken by   John  , but continued to run second to that name until the 20th century, when the picture became more fragmented."],"variants":[]}],"lifeSummary":"Sir William Sidney was born about 1125, in Saint-Denis, Seine-Saint-Denis, Île-de-France, France. He had at least 2 sons with Unknown. He died about 1188, in Lewes, Sussex, England, United Kingdom, at the age of 65."},"et":{"about 1125–about 1188":"umbes 1125–umbes 1188","–Female":"Surnud","1150–1213":"1150–1213","1153–Male":"1153–Surnud","1125–1188":"1125–1188","about 1150":"umbes 1150","1125":"1125","1213":"1213","1188":"1188","about 1125":"umbes 1125","1153":"1153","1150":"1150","about 1188":"umbes 1188","Lewes, Sussex, England, United Kingdom":"Lewes, Sussex, Inglismaa, United Kingdom","Lewes, Chichester, Sussex, England":"Chichester, Sussex, Inglismaa, United Kingdom","Saint-Denis, Seine-Saint-Denis, Île-de-France, France":"Saint-Denis, Seine-Saint-Denis, Île-de-France, Prantsusmaa"},"fi":{"about 1125–about 1188":"noin 1125–noin 1188","–Female":"Kuollut","1150–1213":"1150–1213","1153–Male":"1153–Kuollut","1125–1188":"1125–1188","about 1150":"noin 1150","1125":"1125","1213":"1213","1188":"1188","about 1125":"noin 1125","1153":"1153","1150":"1150","about 1188":"noin 1188","Lewes, Sussex, England, United Kingdom":"Lewes, Sussex, Englanti, Yhdistynyt kuningaskunta","Lewes, Chichester, Sussex, England":"Chichester, Sussex, Englanti, Yhdistynyt kuningaskunta","Saint-Denis, Seine-Saint-Denis, Île-de-France, France":"Saint-Denis, Seine-Saint-Denis, Île-de-France, Ranska"},"fr":{"about 1125–about 1188":"envir