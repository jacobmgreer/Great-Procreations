urt III33岁，母亲Avicie Nedonchel20岁。他于1196年与Isabeau de Brimeau结婚。他们至少是2个儿子和2个女儿的父母。他去世于1235年在他的家乡享年61岁。"},"hr":{"1174–1235":"1174.–1235.","1180–1230":"1180–1230.","1198–1264":"1198.–1264","1204–1265":"1204.–1265","1210–1251":"1210.–1251","1212–1250":"1212.–1250","1142–Male":"1142–preminuo","1154–1210":"1154–1210.","1198":"1198.","1154":"1154","1264":"1264","1230":"1230.","1142":"1142","1174":"1174.","1196":"1196.","1251":"1251","1250":"1250","1180":"1180","1204":"1204.","1235":"1235.","1212":"1212.","1210":"1210.","1265":"1265","Rollancourt, Pas-de-Calais, Hauts-de-France, France":"Rollancourt, Pas-de-Calais, Hauts-de-France, Francuska","Rollancourt, Pas-Calés, Heuts-d'Franche, Française":"Rollancourt, Pas-de-Calais, Nord-Pas-de-Calais, Francuska","France":"Francuska"},"cs":{"1174–1235":"1174–1235","1180–1230":"1180–1230","1198–1264":"1198–1264","1204–1265":"1204–1265","1210–1251":"1210–1251","1212–1250":"1212–1250","1142–Male":"1142–Zesnulý","1154–1210":"1154–1210","1198":"1198","1154":"1154","1264":"1264","1230":"1230","1142":"1142","1174":"1174","1196":"1196","1251":"1251","1250":"1250","1180":"1180","1204":"1204","1235":"1235","1212":"1212","1210":"1210","1265":"1265","Rollancourt, Pas-de-Calais, Hauts-de-France, France":"Rollancourt, Pas-de-Calais, Hauts-de-France, Francie","Rollancourt, Pas-Calés, Heuts-d'Franche, Française":"Rollancourt, Pas-de-Calais, Nord-Pas-de-Calais, Francie","France":"Francie"},"da":{"1174–1235":"1174–1235","1180–1230":"1180–1230","1198–1264":"1198–1264","1204–1265":"1204–1265","1210–1251":"1210–1251","1212–1250":"1212–1250","1142–Male":"1142–Afdød","1154–1210":"1154–1210","1198":"1198","1154":"1154","1264":"1264","1230":"1230","1142":"1142","1174":"1174","1196":"1196","1251":"1251","1250":"1250","1180":"1180","1204":"1204","1235":"1235","1212":"1212","1210":"1210","1265":"1265","Rollancourt, Pas-de-Calais, Hauts-de-France, France":"Rollancourt, Pas-de-Calais, Hauts-de-France, Frankrig","Rollancourt, Pas-Calés, Heuts-d'Franche, Française":