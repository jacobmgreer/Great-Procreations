Male":"1481–Overleden","1439–1487":"1439–1487","1460–1513":"1460–1513","1483–Male":"1483–Overleden","1486–1548":"1486–1548","1430–1497":"1430–1497","1425–1488":"1425–1488","1483":"1483","1460":"1460","1481":"1481","1480":"1480","1425":"1425","1513":"1513","1488":"1488","1487":"1487","1453":"1453","1486":"1486","1497":"1497","1430":"1430","1439":"1439","1548":"1548","Suffolk, England, United Kingdom":"Suffolk, Engeland, Verenigd Koninkrijk","Badley, Suffolk, England":"Badley, Suffolk, Engeland, Verenigd Koninkrijk","Of, Suffolk, , England":"Suffolk, Engeland, Verenigd Koninkrijk",", Suffolk, , England":"Suffolk, Engeland, Verenigd Koninkrijk"},"en":{"1453–1486":"1453–1486","1481–Male":"1481–Deceased","1439–1487":"1439–1487","1460–1513":"1460–1513","1483–Male":"1483–Deceased","1486–1548":"1486–1548","1430–1497":"1430–1497","1425–1488":"1425–1488","1483":"1483","1460":"1460","1481":"1481","1480":"1480","1425":"1425","1513":"1513","1488":"1488","1487":"1487","1453":"1453","1486":"1486","1497":"1497","1430":"1430","1439":"1439","1548":"1548","Suffolk, England, United Kingdom":"Suffolk, England, United Kingdom","Badley, Suffolk, England":"Badley, Suffolk, England, United Kingdom","Of, Suffolk, , England":"Suffolk, England, United Kingdom",", Suffolk, , England":"Suffolk, England, United Kingdom","nameMeanings":[{"name":"Gedding","type":"LAST","attribution":"Dictionary of American Family Names © Patrick Hanks 2003, 2006.","meanings":["German and Dutch: habitational name from any of several farms so named (in Lower Saxony or in the province of Drenthe), once belonging to a certain <i>Gerd</i> and his kin. The personal name <i>Gerd</i> is a shortened form of   Gerhardt  . Compare   Gardin  ."],"variants":[{"name":"Gardin","meanings":["Some characteristic forenames:  Spanish Jose, Homero, Ramonda, Ruben.  Italian Mario, Orlando.","Americanized form of German   Gerding  . It is concentrated in NC.","Italian (Veneto): from a pet form of <i>Gardo</i>, a short form of various personal names such as <i>Edgardo</i> and <i>Ildegardo</i>."]},{"name":"Gerhardt","meanings":["Some characteristic forenames:  German Kurt, Armin, Wilhelm, Bernhard, Dieter, Erwin, Gerda, Gerhardt, Heinrich, Heinz, Horst.","German: from a personal name composed of the ancient Germanic elements <i>gēr</i>, <i>gār</i> ‘spear’ + <i>hard</i> ‘hardy, brave, strong’. Compare   Garhart  ,   Gearhart  , and   Gearheart  ."]}]},{"name":"Constance","type":"FIRST","attribution":"Dictionary of First Names © Patrick Hanks and Flavia Hodges 1990, 2003, 2006.","meanings":["Medieval form of the Late Latin name <i>Constantia</i>, which is either a feminine derivative of <i>Constans</i> (  see  Constant  ) or an abstract noun meaning ‘constancy’. This was a popular name among the Normans, and was borne by, amongst others, the formidable Constance of Sicily (  1158–98 ), wife of the Emperor  Henry VI ."],"variants":[]}],"lifeSummary":"When Constance Gedding was born in 1453, in Suffolk, England, United Kingdom, her father, William Geddinge, was 24 and her mother, Margerie Watkins, was 28. She married Henry Poley in 1480, in Suffolk, England, United Kingdom. They were the parents of at least 2 sons and 1 daughter. She died in 1486, in her hometown, at the age of 33."},"et":{"1453–1486":"1453–1486","1481–Male":"1481–Surnud","1439–1487":"1439–1487","1460–1513":"1460–1513","1483–Male":"1483–Surnud","1486–1548":"1486–1548","1430–1497":"1430–1497","1425–1488":"1425–1488","1483":"1483","1460":"1460","1481":"1481","1480":"1480","1425":"1425","1513":"1513","1488":"1488","1487":"1487","1453":"1453","1486":"1486","1497":"1497","1430":"1430","1439":"1439","1548":"1548","Suffolk, England, United Kingdom":"Suffolk, Inglismaa, United Kingdom","Badley, Suffolk, England":"Badley, Suffolk, Inglismaa, United Kingdom","Of, Suffolk, , England":"Suffolk, Inglismaa, United Kingdom",", Suffolk, , England":"Suffolk, Inglismaa, United Kingdom"},"fi":{"1453–1486":"1453–1486","1481–Male":"1481–Kuollut","1439–1487":