ale":"1191–Afdød","1217–1297":"1217–1297","1188–Male":"1188–Afdød","1217":"1217","about 1217":"omkring 1217","1188":"1188","1297":"1297","about 1188":"omkring 1188","before 1217":"før 1217","1191":"1191","Norfolk, England":"Norfolk, England, United Kingdom","England":"England","England, United Kingdom":"England, United Kingdom"},"nl":{"about 1188–":"circa 1188–Overleden","1191–Female":"1191–Overleden","1217–1297":"1217–1297","1188–Male":"1188–Overleden","1217":"1217","about 1217":"circa 1217","1188":"1188","1297":"1297","about 1188":"circa 1188","before 1217":"vóór 1217","1191":"1191","Norfolk, England":"Norfolk, Engeland, Verenigd Koninkrijk","England":"England","England, United Kingdom":"Engeland, Verenigd Koninkrijk"},"en":{"about 1188–":"about 1188–Deceased","1191–Female":"1191–Deceased","1217–1297":"1217–1297","1188–Male":"1188–Deceased","1217":"1217","about 1217":"about 1217","1188":"1188","1297":"1297","about 1188":"about 1188","before 1217":"before 1217","1191":"1191","Norfolk, England":"Norfolk, England, United Kingdom","England":"England","England, United Kingdom":"England, United Kingdom","nameMeanings":[{"name":"Bellinger","type":"LAST","attribution":"Dictionary of American Family Names © Patrick Hanks 2003, 2006.","meanings":["English (of Norman origin): dissimilated form of   Berringer  . Compare   Benninger  .","German: habitational name for someone from a place called Belling or Bellingen (see   Belling  ). It is also found in France (Lorraine).","Americanized form of French <b>Bélanger</b> (see   Belanger  ) or of its variant   Bellanger  . Compare   Ballinger   2 and   Bellenger   1."],"variants":[{"name":"Berringer","meanings":["English (of Norman origin): from the Anglo-Norman French personal name <i>Berenger</i>, an Old French form of ancient Germanic <i>Beringar</i>, <i>Barengar</i>, composed of the elements <i>ber(n)</i> ‘bear’ + <i>gair</i> ‘spear’. The surname has several variants, including   Beringer  ,   Barringer  , and   Banger  , as well as the dissimilated forms   Bellanger  ,   Bellinger  ,   Ballanger  , and   Ballinger  , where /l/ has been substituted for /r/. The personal name <i>Berenger</i> was well known in England in the 12th and 13th centuries, having been borne by one of the paladins in the widely popular Charlemagne romances.","German: variant of   Beringer  .","Americanized form of German   Boehringer  ."]},{"name":"Ballenger","meanings":["English (of Norman origin; Gloucestershire): variant of   Bellinger   (see also   Ballinger  ). Compare   Ballanger   2 and   Bellenger   2.","French: variant of   Bellanger   1 and, in North America, (also) an altered form of this. This form of the surname is almost extinct in France. Compare   Ballanger   1 and   Bellenger   1."]}]},{"name":"Jacob","type":"FIRST","attribution":"Dictionary of First Names © Patrick Hanks and Flavia Hodges 1990, 2003, 2006.","meanings":["Biblical name, from Hebrew <i>Yaakov</i>. This was borne by perhaps the most important of all the patriarchs in the Book of Genesis. Jacob was the father of twelve sons, who gave their names to the twelve tribes of Israel. He was the son of Isaac and Rebecca and twin brother of Esau. According to the story in Genesis, he was the cunning younger twin, who persuaded his brother Esau to part with his right to his inheritance in exchange for a bowl of soup (‘a mess of pottage’). Later, he tricked his blind and dying father into blessing him in place of Esau. The derivation of the name has been much discussed. It is traditionally explained as being derived from Hebrew <i>akev</i> ‘heel’ and to have meant ‘heel grabber’, because when Jacob was born ‘his hand took hold of Esau's heel’ (Genesis 25:26). This is interpreted later in the Bible as ‘supplanter’ Esau himself remarks, ‘Is he not rightly named Jacob? for he has supplanted me these two times’ (Genesis 27:36). <i>Jacob</i> is especially common as a Jewish given name, although it also became very popular among the Puritans from the 16th century onwards, and has again been widely used since the 1990s.  Compare  James ."],"variants":[]}],"lifeSummary":"Jacob Bellinger was born about 1188, in England, United Kingdom. He married Margaret Bowman before 1217, in England. They were the parents of at least 1 daughter."},"et":{"about 1188–":"umbes 1188–Surnud","1191–Female":"1191–Surnud","1217–1297":"1217–1297","1188–Male":"1188–Surnud","1217":"1217","about 1217":"umbes 1217","1188":"1188","1297":"1297","about 1188":"umbes 1188","before 1217":"enne 1217","1191":"1191","Norfolk, England":"Norfolk, Inglismaa, United Kingdom","England":"England","England, United Kingdom":"Inglismaa, United Kingdom"},"fi":{"about 1188–":"noin 1188–Kuollut","1191–Female":"1191–Kuollut","1217–1297":"1217–1297","1188–Male":"1188–Kuollut","1217":"1217","about 1217":"noin 1217","1188":"1188","1297":"1297","about 1188":"noin 1188","before 1217":"ennen vuotta 1217","1191":"1191","Norfolk, England":"Norfolk, Englanti, Yhdistynyt kuningaskunta","England":"England","England, United Kingdom":"Englanti, Yhdistynyt kuningaskunta"},"fr":{"about 1188–":"environ 1188–Décédé","1191–Female":"1191–Décédée","1217–1297":"1217–1297","1188–Male":"1188–Décédé","1217":"1217","about 1217":"environ 1217","1188":"1188","1297":"1297","about 1188":"environ 1188","before 1217":"avant 1217","1191":"1191","Norfolk, England":"Norfolk, Angleterre, Royaume-Uni","England":"Angleterre","England, United Kingdom":"Angleterre, Royaume-Uni","lifeSummary":"Jacob Bellinger est né environ 1188, à Angleterre, Royaume-Uni. Il a épousé Margaret Bowman avant 1217, à Angleterre. Ils ont eu au moins 1 fille."},"de":{"about 1188–":"um 1188–Verstorben","1191–Female":"1191–Verstorben","1217–1297":"1217–1297","1188–Male":"1188–Verstorben","1217":"1217","about 1217":"um 1217","1188":"1188","1297":"1297","about 1188":"um 1188","before 1217":"vor 1217","1191":"1191","Norfolk, England":"Norfolk, England, United Kingdom","England":"England","England, United Kingdom":"England, United