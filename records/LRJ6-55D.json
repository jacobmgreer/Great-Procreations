일 영국 그루스스터실르 샌드후르스트에서 Joan Champernoun(와)과 결혼했다. 그들은 적어도 한 명의 아들을 두었다. 그는 1256년 11월 18일 이전 영국 잉글랜드에서 사망했으며 영국 잉글랜드 데폰 벌리에 묻혔다."},"lv":{"Abt 1210–Bef 18 November 1256":"ap 1210. gadu–pirms 1256. gada 18. novembra","1210–1256":"1210–1256","1224–1309":"1224–1309","1239–1294":"1239–1294","1180–1242":"1180–1242","1184–1242":"1184–1242","Bef 18 November 1256":"pirms 1256. gada 18. novembra","about 1193":"ap 1193. gadu","1242":"1242","1184":"1184","1294":"1294","17 July 1238":"1238. gada 17. jūlijs","1180":"1180","1239":"1239","about 1239":"ap 1239. gadu","1224":"1224","1256":"1256","Abt 1210":"ap 1210. gadu","Bef 1242":"pirms 1242. gada","1210":"1210","1 August 1242":"1242. gada 1. augusts","1309":"1309","England":"Anglija, Lielbritānija","Umberleigh, Devon, England":"Umberleigh, Devon, Anglija, Lielbritānija","Sandhurst, Gloucestershire, England":"Sandhurst, Gloucestershire, England","Gloucestershire, England":"Gloucestershire, England"},"mg":{"Abt 1210–Bef 18 November 1256":"tany ho any amin'ny 1210–talohan'ny 18 nôvambra 1256","1210–1256":"1210–1256","1224–1309":"1224–1309","1239–1294":"1239–1294","1180–1242":"1180–1242","1184–1242":"1184–1242","Bef 18 November 1256":"talohan'ny 18 nôvambra 1256","about 1193":"tany ho any amin'ny 1193","1242":"1242","1184":"1184","1294":"1294","17 July 1238":"17 jolay 1238","1180":"1180","1239":"1239","about 1239":"tany ho any amin'ny 1239","1224":"1224","1256":"1256","Abt 1210":"tany ho any amin'ny 1210","Bef 1242":"talohan'ny 1242","1210":"1210","1 August 1242":"1 aogôsitra 1242","1309":"1309","England":"Angletera, United Kingdom","Umberleigh, Devon, England":"Umberleigh, Devon, Angletera, United Kingdom","Sandhurst, Gloucestershire, England":"Sandhurst, Gloucestershire, England","Gloucestershire, England":"Gloucestershire, England"},"ms":{"Abt 1210–Bef 18 November 1256":"kira–kira 1210–sebelum 18 November 1256","1210–1256":"1210–1256","1224–1309":"1224–1309","1239–1294":"1239–1294","1180–1242":"1180–1242","1184–1242":"1184–1242","Be