247":"1247","1224":"1224","1256":"1256","1310":"1310","1188":"1188","about 1235":"omkring 1235","1209":"1209","about 1252":"omkring 1252","1207":"1207","Trigg Manor, Truro, Cornwall, England":"Truro, Cornwall, England, United Kingdom","Trevarren, Cornwall, England ":"Trenarren, Cornwall, England","Bideford, Devonshire, England":"Bideford, Devon, England","England":"England","Cornwall, England":"Cornwall, England","Kilkhampton, Cornwall, England":"Kilkhampton, Cornwall, England"},"nl":{"1209–1260":"1209–1260","1188–1240":"1188–1240","1236–1310":"1236–1310","1238–1260":"1238–1260","1250–1325":"1250–1325","1252–Male":"1252–Overleden","1180–1256":"1180–1256","1187–1247":"1187–1247","1187":"1187","1252":"1252","1240":"1240","1250":"1250","1260":"1260","1180":"1180","1238":"1238","1259":"1259","1215":"1215","1325":"1325","1236":"1236","1247":"1247","1224":"1224","1256":"1256","1310":"1310","1188":"1188","about 1235":"circa 1235","1209":"1209","about 1252":"circa 1252","1207":"1207","Trigg Manor, Truro, Cornwall, England":"Truro, Cornwall, Engeland, Verenigd Koninkrijk","Trevarren, Cornwall, England ":"Trenarren, Cornwall, England","Bideford, Devonshire, England":"Bideford, Devon, England","England":"England","Cornwall, England":"Cornwall, England","Kilkhampton, Cornwall, England":"Kilkhampton, Cornwall, England"},"en":{"1209–1260":"1209–1260","1188–1240":"1188–1240","1236–1310":"1236–1310","1238–1260":"1238–1260","1250–1325":"1250–1325","1252–Male":"1252–Deceased","1180–1256":"1180–1256","1187–1247":"1187–1247","1187":"1187","1252":"1252","1240":"1240","1250":"1250","1260":"1260","1180":"1180","1238":"1238","1259":"1259","1215":"1215","1325":"1325","1236":"1236","1247":"1247","1224":"1224","1256":"1256","1310":"1310","1188":"1188","about 1235":"about 1235","1209":"1209","about 1252":"about 1252","1207":"1207","Trigg Manor, Truro, Cornwall, England":"Truro, Cornwall, England, United Kingdom","Trevarren, Cornwall, England ":"Trenarren, Cornwall, England","Bideford, Devonshire, England":"Bideford, Devon, England","England":"England","Cornwall, England":"Cornwall, England","Kilkhampton, Cornwall, England":"Kilkhampton, Cornwall, England","nameMeanings":[{"name":"Jane","type":"FIRST","attribution":"Dictionary of First Names © Patrick Hanks and Flavia Hodges 1990, 2003, 2006.","meanings":["Originally a feminine form of   John  , from the Old French form <i>Je(h)anne</i>. Since the 17th century it has proved the most popular of the feminine forms of <i>John</i>, ahead of   Joan   and   Jean .  It now also commonly occurs as the second element in combinations such as <i>Sarah-Jane</i>. In Britain it is still one of the most frequent of all girls' names. It is not a royal name, but was borne by the tragic  Lady Jane Grey  (  1537–54 ), who was unwillingly proclaimed queen in  1553 , deposed nine days later, and executed the following year. Seventy years earlier, the name had come into prominence as that of  Jane Shore , mistress of  King Edward IV  and subsequently of  Thomas Grey , 1st Marquess of Dorset, Lady Jane's grandfather. Jane Shore's tribulations in  1483  at the hands of  Richard III , Edward's brother and successor, became the subject of popular ballads and plays, which may well have increased the currency of the name in the 16th century. A 19th-century influence was its use as the name of the central character in  Charlotte Brontë's  novel Jane Eyre (  1847 ). From  1932 to 1959  it was used as the name of a cheerful and scantily clad beauty whose adventures were chronicled in a strip cartoon in the Daily Mirror. It is also borne by the American film stars  Jane Russell  (  1921–2011 ) and  Jane Fonda  (  b. 1937 )."],"variants":[{"name":"Jayne","meanings":["Elaborated spelling of   Jane  , a form popularized no doubt by the American actress  Jayne Mansfield  (  Vera Jayne Palmer ,  1933–67 ) and British ice-dancer  Jayne Torvill  (  b. 1957 )."]},{"name":"Jaine","meanings":["Variant spelling of   Jane ."]},{"name":"Jain","meanings":["Originally a feminine form of   John  , from the Old French form <i>Je(h)anne</i>. Since the 17th century it has proved the most popular of the feminine forms of <i>John</i>, ahead of   Joan   and   Jean .  It now also commonly occurs as the second element in combinations such as <i>Sarah-Jane</i>. In Britain it is still one of the most frequent of all girls' names. It is not a royal name, but was borne by the tragic  Lady Jane Grey  (  1537–54 ), who was unwillingly proclaimed queen in  1553 , deposed nine days later, and executed the following year. Seventy years earlier, the name had come into prominence as that of  Jane Shore , mistress of  King Edward IV  and subsequently of  Thomas Grey , 1st Marquess of Dorset, Lady Jane's grandfather. Jane Shore's tribulations in  1483  at the hands of  Richard III , Edward's brother and successor, became the subject of popular ballads and plays, which may well have increased the currency of the name in the 16th century. A 19th-century influence was its use as the name of the central character in  Charlotte Brontë's  novel Jane Eyre (  1847 ). From  1932 to 1959  it was used as the name of a cheerful and scantily clad beauty whose adventures were chronicled in a strip cartoon in the Daily Mirror. It is also borne by the American film stars  Jane Russell  (  1921–2011 ) and  Jane Fonda  (  b. 1937 )."]}]}],"historicEvents":[{"id":1705187,"age":6,"year":"1215","julianDay":2164830,"title":"Magna Carta","description":"King John of England agreed to a charter of rights called the Magna Carta. The document was originally drafted by the Archbishop of Canterbury to establish peace between King John and a group of rebel barons. The Magna Carta was completed in 1215 and is now considered to be one of the greatest constitutional documents of all time.","url":"https://www.nationalarchives.gov.uk/education/medieval/magna-carta/","urlTitle":"National Archives - Magna Carta","jurisdictionLevel":2},{"id":1705188,"age":15,"year":"1224","julianDay":2168117,"title":"France Declares War on England","description":"France declared war on England as Louis VIII of France attacked Poitou and northern Gascony.","jurisdictionLevel":2},{"id":1705189,"age":50,"year":"1259","julianDay":2180901,"title":"100 Years of Conflict Between England and France Ends","description":"Treaty of Paris was signed on December 4, 1259, which ended 100 years of conflict between England and France.","url":"https://en.wikipedia.org/wiki/Treaty_of_Paris_(1259)","urlTitle":"Wikipedia - Treaty of Paris 1259","jurisdictionLevel":2}],"lifeSummary":"When Lady Jane Trewynt was born in 1209, in Trigg, Cornwall, England, United Kingdom, her father, William Trewynt II, was 29 and her mother, Lady William Trewynt, was 22. She married Sir Richard de Grenville V about 1235, in Cornwall, England. They were the parents of at least 4 sons. She died in 1260, in Bideford, Devon, England, at the age of 51."},"et":{"1209–1260":"1209–1260","1188–1240":"1188–1240","1236–1310":"1236–1310","1238–1260":"1238–1260","1250–1325":"1250–1325","1252–Male":"1252–Surnud","1180–1256":"1180–1256","1187–1247":"1187–1247","1187":"1187","1252":"1252","1240":"1240","1250":"1250","1260":"1260","1180":"1180","1238":"1238","1259":"1259","1215":"1215","1325":"1325","1236":"1236","1247":"1247","1224":"1224","1256":"1256","1310":"1310","1188":"1188","about 1235":"umbes 1235","1209":"1209","about 1252":"umbes 1252","1207":"1207","Trigg Manor, Truro, Cornwall, England":"Truro, Cornwall, Inglismaa, United Kingdom","Trevarren, Cornwall, England ":"Trenarren, Cornwall, England","Bideford, Devonshire, England":"Bideford, Devon, England","England":"England","Cornwall, England":"Cornwall, England","Kilkhampton, Cornwall, England":"Kilkhampton, Cornwall, England"},"fi":{"1209–1260":"1209–1260","1188–1240":"1188–1240","1236–1310":"1236–1310","1238–1260":"1238–1260","1250–1325":"1250–1325","1252–Male":"1252–Kuollut","1180–1256":"1180–1256","1187–1247":"1187–1247","1187":"1187","1252"