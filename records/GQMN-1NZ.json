nd":"Lancashire, Anglie, United Kingdom","Howgill Castle, Milburn, Westmorland, England, United Kingdom":"Milburn, Westmorland, Anglie, United Kingdom"},"da":{"1400–1437":"1400–1437","1413–Female":"1413–Afdød","1390–1440":"1390–1440","1420–1484":"1420–1484","1360–1433":"1360–1433","1365–1415":"1365–1415","1484":"1484","1440":"1440","1360":"1360","1380":"1380","1390":"1390","1415":"1415","1437":"1437","1413":"1413","1400":"1400","1433":"1433","Abt 1420":"omkring 1420","1420":"1420","1365":"1365","Westmorland, England, United Kingdom":"Westmorland, England, United Kingdom","Lancashire, England, United Kingdom":"Lancashire, England, United Kingdom","Rainhill, Lancashire, England":"Rainhill, Lancashire, England","Raynhill, Lancashire, England":"Lancashire, England, United Kingdom","Howgill Castle, Milburn, Westmorland, England, United Kingdom":"Milburn, Westmorland, England, United Kingdom"},"nl":{"1400–1437":"1400–1437","1413–Female":"1413–Overleden","1390–1440":"1390–1440","1420–1484":"1420–1484","1360–1433":"1360–1433","1365–1415":"1365–1415","1484":"1484","1440":"1440","1360":"1360","1380":"1380","1390":"1390","1415":"1415","1437":"1437","1413":"1413","1400":"1400","1433":"1433","Abt 1420":"circa 1420","1420":"1420","1365":"1365","Westmorland, England, United Kingdom":"Westmorland, Engeland, Verenigd Koninkrijk","Lancashire, England, United Kingdom":"Lancashire, Engeland, Verenigd Koninkrijk","Rainhill, Lancashire, England":"Rainhill, Lancashire, England","Raynhill, Lancashire, England":"Lancashire, Engeland, Verenigd Koninkrijk","Howgill Castle, Milburn, Westmorland, England, United Kingdom":"Milburn, Westmorland, Engeland, Verenigd Koninkrijk"},"en":{"1400–1437":"1400–1437","1413–Female":"1413–Deceased","1390–1440":"1390–1440","1420–1484":"1420–1484","1360–1433":"1360–1433","1365–1415":"1365–1415","1484":"1484","1440":"1440","1360":"1360","1380":"1380","1390":"1390","1415":"1415","1437":"1437","1413":"1413","1400":"1400","1433":"1433","Abt 1420":"about 1420","1420":"1420","1365":"1365","Westmorland, England, United Kingdom":"Westmorland, England, United Kingdom","Lancashire, England, United Kingdom":"Lancashire, England, United Kingdom","Rainhill, Lancashire, England":"Rainhill, Lancashire, England","Raynhill, Lancashire, England":"Lancashire, England, United Kingdom","Howgill Castle, Milburn, Westmorland, England, United Kingdom":"Milburn, Westmorland, England, United Kingdom","nameMeanings":[{"name":"Lancaster","type":"LAST","attribution":"Dictionary of American Family Names © Patrick Hanks 2003, 2006.","meanings":["English: habitational name from Lancaster in northwestern England, which is recorded as <i>Loncastre</i> in 1086. The place takes its name from the river Lune + Old English <i>ceaster</i> ‘city, Roman fortification’ (from Latin <i>castra</i> ‘legionary camp’). The river name is probably British, perhaps related to Gaelic <i>slán</i> ‘healthy’, ‘salubrious’."],"variants":[]},{"name":"Richard","type":"FIRST","attribution":"Dictionary of First Names © Patrick Hanks and Flavia Hodges 1990, 2003, 2006.","meanings":["One of the most enduringly successful of the Old French personal names introduced into Britain by the Normans. It is of Germanic (Frankish) origin, derived from <i>rīc</i> ‘power’ + <i>hard</i> ‘strong, hardy’. It has enjoyed continuous popularity in England from the Conquest to the present day, influenced by the fact that it was borne by three kings of England, in particular  Richard I  (  1157–99 ). He was king for only ten years (  1189–99 ), most of which he spent in warfare abroad, taking part in the Third Crusade and costing the people of England considerable sums in taxes. Nevertheless, he achieved the status of a folk hero, and was never in England long enough to disappoint popular faith in his goodness and justice. He was also Duke of Aquitaine and Normandy and Count of Anjou, fiefs which he held at a time of maximum English expansion in France. His exploits as a leader of the Third Crusade earned him the nickname ‘Coeur de Lion’ or ‘Lionheart’ and a permanent place in popular imagination, in which he was even more firmly enshrined by  Sir Walter Scott's  novel Ivanhoe (  1820 )."],"variants":[{"name":"Rikert","meanings":["One of the most enduringly successful of the Old French personal names introduced into Britain by the Normans. It is of Germanic (Frankish) origin, derived from <i>rīc</i> ‘power’ + <i>hard</i> ‘strong, hardy’. It has enjoyed continuous popularity in England from the Conquest to the present day, influenced by the fact that it was borne by three kings of England, in particular  Richard I  (  1157–99 ). He was king for only ten years (  1189–99 ), most of which he spent in warfare abroad, taking part in the Third Crusade and costing the people of England considerable sums in taxes. Nevertheless, he achieved the status of a folk hero, and was never in England long enough to disappoint popular faith in his goodness and justice. He was also Duke of Aquitaine and Normandy and Count of Anjou, fiefs which he held at a time of maximum English expansion in France. His exploits as a leader of the Third Crusade earned him the nickname ‘Coeur de Lion’ or ‘Lionheart’ and a permanent place in popular imagination, in which he was even more firmly enshrined by  Sir Walter Scott's  novel Ivanhoe (  1820 )."]},{"name":"Rickert","meanings":["One of the most enduringly successful of the Old French personal names introduced into Britain by the Normans. It is of Germanic (Frankish) origin, derived from <i>rīc</i> ‘power’ + <i>hard</i> ‘strong, hardy’. It has enjoyed continuous popularity in England from the Conquest to the present day, influenced by the fact that it was borne by three kings of England, in particular  Richard I  (  1157–99 ). He was king for only ten years (  1189–99 ), most of which he spent in warfare abroad, taking part in the Third Crusade and costing the people of England considerable sums in taxes. Nevertheless, he achieved the status of a folk hero, and was never in England long enough to disappoint popular faith in his goodness and justice. He was also Duke of Aquitaine and Normandy and Count of Anjou, fiefs which he held at a time of maximum English expansion in France. His exploits as a leader of the Third Crusade earned him the nickname ‘Coeur de Lion’ or ‘Lionheart’ and a permanent place in popular imagination, in which he was even more firmly enshrined by  Sir Walter Scott's  novel Ivanhoe (  1820 )."]}]}],"lifeSummary":"When Sir Richard Lancaster was born in 1400, in Lancashire, England, United Kingdom, his father, Sir John De Lancaster, was 41 and his mother, Katherine Crackenthorpe, was 35. He married Lady Margaret Bradshawe in 1420, in Lancashire, England, United Kingdom. They were the parents of at least 1 son. He died in 1437, in Westmorland, England, United Kingdom, at the age of 37."},"et":{"1400–1437":"1400–1437","1413–Female":"1413–Surnud","1390–1440":"1390–1440","1420–1484":"1420–1484","1360–1433":"1360–1433","1365–1415":"1365–1415","1484":"1484","1440":"1440","1360":"1360","1380":"1380","1390":"1390","1415":"1415","1437":"1437","1413":"1413","1400":"1400","1433":"1433","Abt 1420":"umbes 1420","1420":"1420","1365":"1365","Westmorland, England, United Kingdom":"Westmorland, Inglismaa, United Kingdom","Lancashire, England, United Kingdom":"Lancashire, Inglismaa, United Kingdom","Rainhill, Lancashire, England":"Rainhill, Lancashire, England","Raynhill, Lancashire, England":"Lancashire, Inglismaa, United Kingdom","Howgill Castle, Milburn, Westmorland, England, United Kingdom":"Milburn, Westmorland, Inglismaa, United Kingdom"},"fi":{"1400–1437":"1400–1437","1413–Female":"1413–Kuollut","1390–1440":"1390–1440","1420–1484":"1420–1484","1360–1433":"1360–1433","1365–1415":"1365–1415","1484":"1484","1440":"1440","1360":"1360","1380":"1380","1390":"1390","1415":"1415","1437":"1437","1413":"1413","1400":"1400","1433":"1433","Abt 1420":"noin 1420","1420":"1420","1365":"1365","Westmorland, Englan