nd":"英国英格兰戴文","Of, Wollegh, Devonshire, England":"英国英格兰戴文","lifeSummary":"当Mabel Hatch于大约1336年出生在英国英格兰戴文时，她的父亲Thomas Hatch-61岁，母亲Maud Leigh-64岁。她与Thomas Affeton在英国英格兰戴文结婚。他们至少是1个儿子的父母。"},"hr":{"about 1336–":"oko 1336.–preminula","1336–Female":"1336–preminula","1340–Female":"1340–preminula","1342–Female":"1342–preminula","1348–Female":"1348–preminula","1355–1404":"1355–1404","1336–1378":"1336–1378","1350–1410":"1350–1410","1399–Male":"1399–preminuo","1402–Female":"1402–preminula","1340":"1340","1350":"1350","1404":"1404","Abt 1350":"oko 1350.","1348":"1348","1402":"1402","1336":"1336","1378":"1378","1399":"1399","1410":"1410","1355":"1355","about 1336":"oko 1336.","1342":"1342","of, Affeton, Devon, England":"Devon, England","Of, Woolegh, Devonshire, England":"Devon, Engleska, United Kingdom","Of, Wollegh, Devonshire, England":"Devon, Engleska, United Kingdom"},"cs":{"about 1336–":"okolo 1336–Zesnulá","1336–Female":"1336–Zesnulá","1340–Female":"1340–Zesnulá","1342–Female":"1342–Zesnulá","1348–Female":"1348–Zesnulá","1355–1404":"1355–1404","1336–1378":"1336–1378","1350–1410":"1350–1410","1399–Male":"1399–Zesnulý","1402–Female":"1402–Zesnulá","1340":"1340","1350":"1350","1404":"1404","Abt 1350":"okolo 1350","1348":"1348","1402":"1402","1336":"1336","1378":"1378","1399":"1399","1410":"1410","1355":"1355","about 1336":"okolo 1336","1342":"1342","of, Affeton, Devon, England":"Devon, Anglie","Of, Woolegh, Devonshire, England":"Devon, Anglie, United Kingdom","Of, Wollegh, Devonshire, England":"Devon, Anglie, United Kingdom"},"da":{"about 1336–":"omkring 1336–Afdød","1336–Female":"1336–Afdød","1340–Female":"1340–Afdød","1342–Female":"1342–Afdød","1348–Female":"1348–Afdød","1355–1404":"1355–1404","1336–1378":"1336–1378","1350–1410":"1350–1410","1399–Male":"1399–Afdød","1402–Female":"1402–Afdød","1340":"1340","1350":"1350","1404":"1404","Abt 1350":"omkring 1350","1348":"1348","1402":"1402","1336":"1336","1378":"1378","1399":"1399","1410":"1410","1355":"1355","about 1336":"omkring 1336","1342":"1342","of, Affeton, Devon, England":"Devon, England","Of, Woolegh, Devonshire, England":"Devon, England, United Kingdom","Of, Wollegh, Devonshire, England":"Devon, England, United Kingdom"},"nl":{"about 1336–":"circa 1336–Overleden","1336–Female":"1336–Overleden","1340–Female":"1340–Overleden","1342–Female":"1342–Overleden","1348–Female":"1348–Overleden","1355–1404":"1355–1404","1336–1378":"1336–1378","1350–1410":"1350–1410","1399–Male":"1399–Overleden","1402–Female":"1402–Overleden","1340":"1340","1350":"1350","1404":"1404","Abt 1350":"circa 1350","1348":"1348","1402":"1402","1336":"1336","1378":"1378","1399":"1399","1410":"1410","1355":"1355","about 1336":"circa 1336","1342":"1342","of, Affeton, Devon, England":"Devon, England","Of, Woolegh, Devonshire, England":"Devon, Engeland, Verenigd Koninkrijk","Of, Wollegh, Devonshire, England":"Devon, Engeland, Verenigd Koninkrijk"},"en":{"about 1336–":"about 1336–Deceased","1336–Female":"1336–Deceased","1340–Female":"1340–Deceased","1342–Female":"1342–Deceased","1348–Female":"1348–Deceased","1355–1404":"1355–1404","1336–1378":"1336–1378","1350–1410":"1350–1410","1399–Male":"1399–Deceased","1402–Female":"1402–Deceased","1340":"1340","1350":"1350","1404":"1404","Abt 1350":"about 1350","1348":"1348","1402":"1402","1336":"1336","1378":"1378","1399":"1399","1410":"1410","1355":"1355","about 1336":"about 1336","1342":"1342","of, Affeton, Devon, England":"Devon, England","Of, Woolegh, Devonshire, England":"Devon, England, United Kingdom","Of, Wollegh, Devonshire, England":"Devon, England, United Kingdom","nameMeanings":[{"name":"Hatch","type":"LAST","attribution":"Dictionary of American Family Names © Patrick Hanks 2003, 2006.","meanings":["English: habitational name from Hatch (Bedfordshire, Devon, Hampshire, Somerset, Wiltshire), Hacche in South Molton (Devon), or else a topographic name from residence near a hatch, a gate leading to a forest or sometimes a sluice-gate, from Middle English <i>hacche</i> ‘gate’ (Old English <i>hæcce</i>, Kentish Old English <i>hec(c)</i>). This name has been in Ireland since the 17th century, associated with County Meath and the nearby part of Louth."],"variants":[{"name":"Hedge","meanings":["English: topographic name for someone who lived by a hedge or enclosure, from Middle English <i>hegge</i> ‘hedge, fence’. In the early Middle Ages, hedges were not merely dividers between fields, but had an important defensive function when planted around a settlement or enclosure.","English: probably also a variant of   Hatch  , with voicing of the final consonant.","Americanized form (translation into English) of German   Hecke  ."]},{"name":"Hatcher","meanings":["English (southern): topographic name for someone who lived by a gate, from Middle English <i>haccher(e)</i>, a derivative of <i>hacche</i> ‘gate’. This normally denoted a gate marking the entrance to a forest or other enclosed piece of land, sometimes a floodgate or sluice-gate. Compare   Hatch  ."]}]},{"name":"Mabel","type":"FIRST","attribution":"Dictionary of First Names © Patrick Hanks and Flavia Hodges 1990, 2003, 2006.","meanings":["Originally a nickname from the Old French vocabulary word <i>amabel</i>, <i>amable</i> ‘lovely’ (akin to modern English <i>amiable</i> ‘friendly, good-humoured’). The initial vowel began to be lost as early as the 12th century (the same woman is referred to as both <i>Mabilia</i> and <i>Amabilia</i> in a document of  1185 ), but a short vowel in the resulting first syllable was standard, giving a rhyme with <i>babble</i>, until the 19th century, when people began to pronounce the name to rhyme with <i>table</i>."],"variants":[]}],"lifeSummary":"When Mabel Hatch was born about 1336, in Devon, England, United Kingdom, her father, Thomas Hatch, was -61 and her mother, Maud Leigh, was -64. She married Thomas Affeton in Devon, England, United Kingdom. They were the parents of at least 1 son."},"et":{"about 1336–":"umbes 1336–Surnud","1336–Female":"1336–Surnud"