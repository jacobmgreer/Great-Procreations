d":"Jórvík, England, United Kingdom","Derbyshire, England":"Derbyshire, England, United Kingdom"},"nl":{"Abt 1112–1184":"circa 1112–1184","1112–1184":"1112–1184","1115–1226":"1115–1226","1152–1232":"1152–1232","1070–Male":"1070–Overleden","1072–Female":"1072–Overleden","Abt 1152":"circa 1152","1226":"1226","1115":"1115","Abt 1112":"circa 1112","1112":"1112","1232":"1232","1152":"1152","1184":"1184","1072":"1072","1070":"1070","Yorkshire, England":"Yorkshire, Engeland, Verenigd Koninkrijk","Derbyshire, England":"Derbyshire, Engeland, Verenigd Koninkrijk"},"en":{"Abt 1112–1184":"about 1112–1184","1112–1184":"1112–1184","1115–1226":"1115–1226","1152–1232":"1152–1232","1070–Male":"1070–Deceased","1072–Female":"1072–Deceased","Abt 1152":"about 1152","1226":"1226","1115":"1115","Abt 1112":"about 1112","1112":"1112","1232":"1232","1152":"1152","1184":"1184","1072":"1072","1070":"1070","Yorkshire, England":"Yorkshire, England, United Kingdom","Derbyshire, England":"Derbyshire, England, United Kingdom","nameMeanings":[{"name":"Foljambe","type":"LAST","attribution":"Dictionary of Family Names in Britain and Ireland © University of the West of England 2016","meanings":["Norman, English: nickname from Old French  <i>fol</i> ‘foolish, silly’ +  <i>jambe</i> ‘leg’, probably a nickname for a lame person, someone with a maimed or crooked leg;  compare  Belgian  . In Old French  <i>fol</i> could be used of something useless or of little value, e.g.  <i>farine folle</i> ‘mill dust’."],"variants":[{"name":"Fulljames","meanings":["English: variant of   Foljambe   with post-medieval excrescent  <i>-s</i>."]},{"name":"Belgian","meanings":["Norman, English, Scottish: nickname from Anglo-Norman French  <i>bele jambe</i> ‘fine leg’."]}]},{"name":"Geoffrey","type":"FIRST","attribution":"Dictionary of First Names © Patrick Hanks and Flavia Hodges 1990, 2003, 2006.","meanings":["Of Germanic (Frankish and Lombard) origin, introduced to Britain by the Normans. It was in regular use among the counts of Anjou, ancestors of the English royal house of Plantagenet, who were descended from Geoffrey Plantagenet, Count of Anjou (  1113–51 ). It was a particularly popular name in England and France in the later Middle Ages; notable bearers in England include the poet  Geoffrey Chaucer  (  <i>c.</i>1340–1400 ) and in Wales the chronicler  Geoffrey  of Monmouth (  d. 1155 ). The original form and meaning of the name is disputed. According to one theory, it is merely a variant of   Godfrey ;  others derive the first part from the Germanic word <i>gawia</i> ‘territory’, <i>walah</i> ‘stranger’, or <i>gisil</i> ‘pledge’. Medieval forms can be found to support all these theories, and it is possible that several names have fallen together, or that the name was subjected to reanalysis by folk etymology at an early date."],"variants":[]}],"lifeSummary":"When Geoffrey Foljambe Lord of Tideswell was born about 1112, in Derbyshire, England, United Kingdom, his father, Ralph Foleschamp Lord of Tideswell, was 44 and his mother, Gundred Ferrers, was 42. He had at least 1 son with Maud Musard. He died in 1184, in his hometown, at the age of 73."},"et":{"Abt 1112–1184":"umbes 1112–1184","1112–1184":"1112–1184","1115–1226":"1115–1226","1152–1232":"1152–1232","1070–Male":"1070–Surnud","1072–Female":"1072–Surnud","Abt 1152":"umbes 1152","1226":"1226","1115":"1115","Abt 1112":"umbes 1112","1112":"1112","1232":"1232","1152":"1152","1184":"1184","1072":"1072","1070":"1070","Yorkshire, England":"Yorkshire, Inglismaa, United Kingdom","Derbyshire, England":"Derbyshire, Inglismaa, United Kingdom"},"fi":{"Abt 1112–1184":"noin 1112–1184","1112–1184":"1112–1184","1115–1226":"1115–1226","1152–1232":"1152–1232","1070–Male":"1070–Kuollut","1072–Female":"1072–Kuollut","Abt 1152":"noin 1152","1226":"1226","1115":"1115","Abt 1112":"noin 1112","1112":"1112","1232":"1232","1152":"1152","1184":"1184","1072":"1072","1070":"1070","Yorkshire, England":"Yorkshire, Englanti, Yhdistynyt kuningaskunta","Derbys