22–1611":"1522–1611","–1578":"–1578","–1609":"–1609","1475–1502":"1475–1502","1480–1536":"1480–1536","1494":"1494","1580":"1580","1480":"1480","1536":"1536","1502":"1502","1578":"1578","1611":"1611","1522":"1522","1475":"1475","1563":"1563","about 1522":"omkring 1522","1609":"1609","1519":"1519","1518":"1518","1559":"1559","Dedham, Colchester district, Essex, England, United Kingdom":"Dedham, Essex, England, United Kingdom","England":"England","Dedham, Essex, England":"Dedham, Essex, England, United Kingdom"},"nl":{"1494–1559":"1494–1559","1502–1563":"1502–1563","1519–1580":"1519–1580","1522–1611":"1522–1611","–1578":"–1578","–1609":"–1609","1475–1502":"1475–1502","1480–1536":"1480–1536","1494":"1494","1580":"1580","1480":"1480","1536":"1536","1502":"1502","1578":"1578","1611":"1611","1522":"1522","1475":"1475","1563":"1563","about 1522":"circa 1522","1609":"1609","1519":"1519","1518":"1518","1559":"1559","Dedham, Colchester district, Essex, England, United Kingdom":"Dedham, Essex, Engeland, Verenigd Koninkrijk","England":"England","Dedham, Essex, England":"Dedham, Essex, Engeland, Verenigd Koninkrijk"},"en":{"1494–1559":"1494–1559","1502–1563":"1502–1563","1519–1580":"1519–1580","1522–1611":"1522–1611","–1578":"–1578","–1609":"–1609","1475–1502":"1475–1502","1480–1536":"1480–1536","1494":"1494","1580":"1580","1480":"1480","1536":"1536","1502":"1502","1578":"1578","1611":"1611","1522":"1522","1475":"1475","1563":"1563","about 1522":"about 1522","1609":"1609","1519":"1519","1518":"1518","1559":"1559","Dedham, Colchester district, Essex, England, United Kingdom":"Dedham, Essex, England, United Kingdom","England":"England","Dedham, Essex, England":"Dedham, Essex, England, United Kingdom","nameMeanings":[{"name":"Raven","type":"LAST","attribution":"Dictionary of American Family Names © Patrick Hanks 2003, 2006.","meanings":["English: from the Middle English personal name <i>Raven</i> (Old Norse <i>Hrafn</i>, Old English <i>Hræfn</i>, both meaning ‘raven’) or else a nickname from this word, probably denoting a dark-haired man.","English: occasionally perhaps also a topographic or habitational name referring to a house or inn distinguished by the sign of a raven (see 1 above). Surnames derived from house and inn signs are rare in English.","North German and Dutch: from Middle Low German <i>rave(n)</i> ‘raven’, a nickname or an old personal name. Compare 1 above."],"variants":[{"name":"Ravan","meanings":["English (Yorkshire): variant of   Raven  .","Americanized form of German   Raven  ."]},{"name":"Ravens","meanings":["English (London): variant of   Raven  , with genitival or post-medieval excrescent <i>-s</i>."]}]},{"name":"Richard","type":"FIRST","attribution":"Dictionary of First Names © Patrick Hanks and Flavia Hodges 1990, 2003, 2006.","meanings":["One of the most enduringly successful of the Old French personal names introduced into Britain by the Normans. It is of Germanic (Frankish) origin, derived from <i>rīc</i> ‘power’ + <i>hard</i> ‘strong, hardy’. It has enjoyed continuous popularity in England from the Conquest to the present day, influenced by the fact that it was borne by three kings of England, in particular  Richard I  (  1157–99 ). He was king for only ten years (  1189–99 ), most of which he spent in warfare abroad, taking part in the Third Crusade and costing the people of England considerable sums in taxes. Nevertheless, he achieved the status of a folk hero, and was never in England long enough to disappoint popular faith in his goodness and justice. He was also Duke of Aquitaine and Normandy and Count of Anjou, fiefs which he held at a time of maximum English expansion in France. His exploits as a leader of the Third Crusade earned him the nickname ‘Coeur de Lion’ or ‘Lionheart’ and a permanent place in popular imagination, in which he was even more firmly enshrined by  Sir Walter Scott's  novel Ivanhoe (  1820 )."],"variants":[{"name":"Rikert","meanings":["One of the most enduringly successful of the Old French personal names introduced into Britain by the Normans. It is of Germanic (Frankish) origin, derived from <i>rīc</i> ‘power’ + <i>hard</i> ‘strong, hardy’. It has enjoyed continuous popularity in England from the Conquest to the present day, influenced by the fact that it was borne by three kings of England, in particular  Richard I  (  1157–99 ). He was king for only ten years (  1189–99 ), most of which he spent in warfare abroad, taking part in the Third Crusade and costing the people of England considerable sums in taxes. Nevertheless, he achieved the status of a folk hero, and was never in England long enough to disappoint popular faith in his goodness and justice. He was also Duke of Aquitaine and Normandy and Count of Anjou, fiefs which he held at a time of maximum English expansion in France. His exploits as a leader of the Third Crusade earned him the nickname ‘Coeur de Lion’ or ‘Lionheart’ and a permanent place in popular imagination, in which he was even more firmly enshrined by  Sir Walter Scott's  novel Ivanhoe (  1820 )."]},{"name":"Rickert","meanings":["One of the most enduringly successful of the Old French personal names introduced into Britain by the Normans. It is of Germanic (Frankish) origin, derived from <i>rīc</i> ‘power’ + <i>hard</i> ‘strong, hardy’. It has enjoyed continuous popularity in England from the Conquest to the present day, influenced by the fact that it was borne by three kings of England, in particular  Richard I  (  1157–99 ). He was king for only ten years (  1189–99 ), most of which he spent in warfare abroad, taking part in the Third Crusade and costing the people of England considerable sums in taxes. Nevertheless, he achieved the status of a folk hero, and was never in England long enough to disappoint popular faith in his goodness and justice. He was also Duke of Aquitaine and Normandy and Count of Anjou, fiefs which he held at a time of maximum English expansion in France. His exploits as a leader of the Third Crusade earned him the nickname ‘Coeur de Lion’ or ‘Lionheart’ and a permanent place in popular imagination, in which he was even more firmly enshrined by  Sir Walter Scott's  novel Ivanhoe (  1820 )."]}]}],"lifeSummary":"When Richard Raven was born in 1494, in Dedham, Essex, England, United Kingdom, his father, William Ravens, was 19 and his mother, JoHanna E. Starlying, was 14. He married Alyse Carre Doggett in 1518, in Dedham, Essex, England. They were the parents of at least 4 sons. He died in 1559, in his hometown, at the age of 65."},"et":{"1494–1559":"1494–1559","1502–1563":"1502–1563","1519–1580":"1519–1580","1522–1611":"1522–1611","–1578":"–1578","–1609":"–1609","1475–1502":"1475–1502","1480–1536":"1480–1536","1494":"1494","1580":"1580","1480":"1480","1536":"1536","1502":"1502","1578":"1578","1611":"1611","1522":"1522","1475":"1475","1563":"1563","about 1522":"umbes 1522","1609":"1609","1519":"1519","1518":"1518","1559":"1559","Dedham, Colchester district, Essex, England, United Kingdom":"Dedham, Essex, Inglismaa, United Kingdom","England":"England","Dedham, Essex, England":"Dedham, Essex, Inglismaa, United Kingdom"},"fi":{"1494–1559":"1494–1559","1502–1563":"1502–1563","1519–1580":"1519–1580","1522–1611":"1522–1611","–1578":"–1578","–1609":"–1609","1475–1502":"1475–1502","1480–1536":"1480–1536","1494":"1494","1580":"1580","1480":"1480","1536":"1536","1502":"1502","1578":"1578","1611":"1611","1522":"1522","1475":"1475","1563":"1563","about 1522":"noin 1522","1609":"1609","1519":"1519","1518":"1518","1559":"1559","Dedham, Colchester district, Essex, England, United Kingdom":"Dedham, Essex, Englanti, Yhdistynyt kuningaskunta","England":"England","Dedham, Essex, England":"Dedham, Essex, Englanti, Yhdistynyt kuningaskunta"},"fr":{"1494–1559":"1494–1559","1502–1563":"1502–1563","1519–1580":"1519–1580","1522–1611":"1522–1611","–1578":"–1578","–1609":"–1609","1475–1502":"1475–1502","1480–1536":"1480–1536","1494":"1494","1580":"1580","1480":"1480","1536":"1536","1502":"15