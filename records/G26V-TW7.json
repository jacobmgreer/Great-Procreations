006.","meanings":["New Testament name, borne by one of Christ's twelve apostles, referred to as ‘Thomas, called Didymus’ (John 11:16; 20:24). <i>Didymos</i> is the Greek word for ‘twin’, and the name is the Greek form of an Aramaic byname meaning ‘twin’. The given name has always been popular throughout Christendom, in part because St Thomas's doubts have made him seem a very human character."],"variants":[]}],"lifeSummary":"Mrs. Thomas de Hopton was born about 1191. She had at least 2 sons with Thomas de Hopton."},"et":{"about 1191–":"umbes 1191–Surnud","1186–Male":"1186–Surnud","1215–Male":"1215–Surnud","1218–Male":"1218–Surnud","1191–Female":"1191–Surnud","1215":"1215","about 1191":"umbes 1191","1186":"1186","1218":"1218","1191":"1191"},"fi":{"about 1191–":"noin 1191–Kuollut","1186–Male":"1186–Kuollut","1215–Male":"1215–Kuollut","1218–Male":"1218–Kuollut","1191–Female":"1191–Kuollut","1215":"1215","about 1191":"noin 1191","1186":"1186","1218":"1218","1191":"1191"},"fr":{"about 1191–":"environ 1191–Décédée","1186–Male":"1186–Décédé","1215–Male":"1215–Décédé","1218–Male":"1218–Décédé","1191–Female":"1191–Décédée","1215":"1215","about 1191":"environ 1191","1186":"1186","1218":"1218","1191":"1191","lifeSummary":"Mrs. Thomas de Hopton est née environ 1191. Elle a eu au moins 2 fils avec Thomas de Hopton."},"de":{"about 1191–":"um 1191–Verstorben","1186–Male":"1186–Verstorben","1215–Male":"1215–Verstorben","1218–Male":"1218–Verstorben","1191–Female":"1191–Verstorben","1215":"1215","about 1191":"um 1191","1186":"1186","1218":"1218","1191":"1191","lifeSummary":"Mrs. Thomas de Hopton wurde um 1191 geboren. Sie hatte mit Thomas de Hopton mindestens 2 Söhne."},"ht":{"about 1191–":"about 1191–Desede","1186–Male":"1186–Desede","1215–Male":"1215–Desede","1218–Male":"1218–Desede","1191–Female":"1191–Desede","1215":"1215","about 1191":"about 1191","1186":"1186","1218":"1218","1191":"1191"},"hu":{"about 1191–":"1191 körül–elhunyt","1186–Male":"1186–elhunyt","1215–Male":"1215–elhu