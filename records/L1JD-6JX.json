219":"1187–1219","1200–1227":"1200–1227","1210–1249":"1210–1249","1215–1284":"1215–1284","1217–1227":"1217–1227","1180–1261":"1180–1261","about 1261":"about 1261","Aft 1227":"1227","about 1180":"about 1180","1187":"1187","Abt 1215":"1215","1284":"1284","1261":"1261","Abt 1217":"1217","12 July 1249":"12 July 1249","1180":"1180","1217":"1217","1227":"1227","1249":"1249","1215":"1215","1200":"1200","1210":"1210","about 1200":"about 1200","about 1210":"about 1210","1219":"1219","Durham, England":"Durham, England","England":"England","Redbourne, Lincolnshire, England":"Redbourne, Lincolnshire, England, United Kingdom","nameMeanings":[{"name":"Redbourne","type":"LAST","attribution":"Dictionary of Family Names in Britain and Ireland © University of the West of England 2016","meanings":["English: locative name from Rodbourne Cheney (Wilts), Rodbourne in Malmesbury (Wilts), or Rodbourn in Henbury (Gloucs). Some early forms are indistinguishable from those for   Radbourne  ."],"variants":[{"name":"Radbourne","meanings":["English: locative name from Radbourn (Warwicks), Radbourne (Derbys), Redbourn (Herts) or Redbourne (Lincs)."]}]},{"name":"Margaret","type":"FIRST","attribution":"Dictionary of First Names © Patrick Hanks and Flavia Hodges 1990, 2003, 2006.","meanings":["An extremely common given name from the Middle Ages onwards, derived via Old French <i>Marguerite</i> and Latin <i>Margarita</i> from Greek <i>Margarītēs</i>, from <i>margaron</i> ‘pearl’, a word ultimately of Hebrew origin. The name was always understood to mean ‘pearl’ throughout the Middle Ages. The first  St Margaret  was martyred at Antioch in Pisidia during the persecution instigated by the  Emperor Diocletian  in the early 4th century. However, there is some doubt about her name, as the same saint is venerated in the Orthodox Church as   Marina .  There were several other saintly bearers of the name, including St Margaret of Scotland (  d. 1093 ), wife of  King Malcolm Canmore  and daughter of Edmund Ironside of England. It was also the name of the wife of  Henry VI  of England,  Margaret of Anjou  (  1430–82 ), and of  Margaret Tudor  (  1489–1541 ), sister of  Henry VIII , who married James IV of Scotland and ruled as regent there after his death.  See also  Margery  ,   Marjorie ."],"variants":[{"name":"Margareta","meanings":["From the Latin form of Greek <i>Margarītēs</i>.  See  <b>Margaret</b>   ."]},{"name":"Margaretta","meanings":["Formed from Margaret."]}]},{"name":"de","type":"FIRST","attribution":"Dictionary of First Names © Patrick Hanks and Flavia Hodges 1990, 2003, 2006.","meanings":["‘Attainment’."],"variants":[]}],"lifeSummary":"Margaret de Redbourne was born about 1180, in Redbourne, Lincolnshire, England, United Kingdom. She married Alexander de Néville I. They were the parents of at least 2 sons and 2 daughters. She died about 1261, in her hometown, at the age of 83."},"et":{"about 1180–about 1261":"umbes 1180–umbes 1261","1187–1219":"1187–1219","1200–1227":"1200–1227","1210–1249":"1210–1249","1215–1284":"1215–1284","1217–1227":"1217–1227","1180–1261":"1180–1261","about 1261":"umbes 1261","Aft 1227":"1227","about 1180":"umbes 1180","1187":"1187","Abt 1215":"1215","1284":"1284","1261":"1261","Abt 1217":"1217","12 July 1249":"12. juuli 1249","1180":"1180","1217":"1217","1227":"1227","1249":"1249","1215":"1215","1200":"1200","1210":"1210","about 1200":"umbes 1200","about 1210":"umbes 1210","1219":"1219","Durham, England":"Durham, England","England":"England","Redbourne, Lincolnshire, England":"Redbourne, Lincolnshire, Inglismaa, United Kingdom"},"fi":{"about 1180–about 1261":"noin 1180–noin 1261","1187–1219":"1187–1219","1200–1227":"1200–1227","1210–1249":"1210–1249","1215–1284":"1215–1284","1217–1227":"1217–1227","1180–1261":"1180–1261","about 1261":"noin 1261","Aft 1227":"1227","about 1180":"noin 1180","1187":"1187","Abt 1215":"1215","1284":"1284","1261":"1261","Abt 1217":"1217","12 July 1249":"12. heinäkuuta 1249","1180":"1180","1217":"1217","122