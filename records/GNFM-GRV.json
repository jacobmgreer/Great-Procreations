1055":"1055","abt 1064":"circa 1064","1064":"1064","1063":"1063","1030":"1030","1062":"1062","1073":"1073","1072":"1072","ABT 1063":"circa 1063","1106":"1106","1025":"1025","about 1055":"circa 1055","ABT 1072":"circa 1072","of Clwyd,Wales":"Clwyd, Wales, Verenigd Koninkrijk","Hirdref, Llyn, Gwynedd, Wales":"Gwynedd, Wales, Verenigd Koninkrijk","South Wales, Wales":"South Wales, Wales","of Pengwern, Denbigh, Wales":"Denbighshire, Wales, Verenigd Koninkrijk","Penley, Flintshire, Wales":"Penley, Flintshire, Wales","Pengwern, Llangollen, Denbighshire, Wales, United Kingdom":"Pengwern, Llangollen, Denbighshire, Wales, Verenigd Koninkrijk"},"en":{"about 1030–":"about 1030–Deceased","1030–Female":"1030–Deceased","1025–1073":"1025–1073","1055–1106":"1055–1106","1062–Male":"1062–Deceased","1063–Female":"1063–Deceased","1064–Male":"1064–Deceased","1072–Female":"1072–Deceased","1000–Male":"1000–Deceased","about 1030":"about 1030","abt 1062":"about 1062","1000":"1000","1055":"1055","abt 1064":"about 1064","1064":"1064","1063":"1063","1030":"1030","1062":"1062","1073":"1073","1072":"1072","ABT 1063":"about 1063","1106":"1106","1025":"1025","about 1055":"about 1055","ABT 1072":"about 1072","of Clwyd,Wales":"Clwyd, Wales, United Kingdom","Hirdref, Llyn, Gwynedd, Wales":"Gwynedd, Wales, United Kingdom","South Wales, Wales":"South Wales, Wales","of Pengwern, Denbigh, Wales":"Denbighshire, Wales, United Kingdom","Penley, Flintshire, Wales":"Penley, Flintshire, Wales","Pengwern, Llangollen, Denbighshire, Wales, United Kingdom":"Pengwern, Llangollen, Denbighshire, Wales, United Kingdom","nameMeanings":[{"name":"Gruffydd","type":"LAST","meanings":["Welsh: The Welsh name; from creffydd, strong faith, or strong in faith. Gruffydd, a Welsh form of Gryffydd."],"variants":[]},{"name":"Hîr","type":"LAST","attribution":"Dictionary of American Family Names © Patrick Hanks 2003, 2006.","meanings":["German: variant of   Hirsch   1. Compare   Hirtz  ."],"variants":[{"name":"Hirzel","meanings":["Some characteristic forenames:  German Heinz.","South German and Swiss German: from a diminutive of   Hirz  . Compare   Hirtzel  ."]},{"name":"Hirsch","meanings":["Some characteristic forenames:  Jewish Emanuel, Meyer, Shimon, Moshe, Yosef, Beril, Chaim, Elihu, Eliyohu.  German Kurt, Otto, Erwin, Hans, Heinz, Helmut, Beate, Fritz, Gunther, Hedwig, Hilde, Ilse.","German: from Middle High German <i>hir(t)z</i> ‘deer, stag’; a metonymic occupational name for a keeper of deer, a nickname for someone thought to resemble a deer or stag, or a topographic or habitational name referring to a house distinguished by the sign of a stag. It is also found in some central European countries, for example in Czechia and Slovenia, often as a translation into German of corresponding Slavic surnames, e.g.   Jelen  . In some cases this is also a standardized form of the Gottscheerish (i.e. Gottschee German) surname   Hiris  .","Jewish (Ashkenazic): from the Yiddish male personal name <i>Hirsh</i> ‘deer’, which is common because of the association of the deer with the Hebrew personal name <i>Naphtali</i>, deriving from the blessing by Jacob of his sons (Genesis 49: 21), in which Naphtali is referred to as a ‘hind let loose’. Compare   Deer  ,   Jelen  ,   Jelinek  , and   Jelonek  ."]},{"name":"Hirtz","meanings":["German: variant of   Hirz   and, in North America, (also) an altered form of this."]}]},{"name":"Efa","type":"FIRST","attribution":"Dictionary of First Names © Patrick Hanks and Flavia Hodges 1990, 2003, 2006.","meanings":["Popular Latinate form of   Eve  , used also as an Anglicization of the Irish name Aoife ."],"variants":[]},{"name":"ferch","type":"LAST","attribution":"Dictionary of American Family Names © Patrick Hanks 2003, 2006.","meanings":["German: variant of   Ferg  . Compare   Verch  .","Probably also an Americanized form of German <b>Förtsch</b> (see   Foertsch  ).","Probably also an Americanized form of German <b>Förch</b> (see   Foerch  )."],"variants":[{"name":"Ferg","meanings":["1  ‘Sharp blade’.","2  ‘Wind’."]}]}],"lifeSummary":"Efa ferch Gruffydd Hîr was born about 1030, in South Wales, Wales as the daughter of Gruffydd Hir ap Gruffydd. She married Rhys Sais Ap Ednyfed. They were the parents of at least 3 sons and 2 daughters."},"et":{"about 1030–":"umbes 1030–Surnud","1030–Female":"1030–Surnud","1025–1073":"1025–1073","1055–1106":"1055–1106","1062–Male":"1062–Surnud","1063–Female":"1063–Surnud","1064–Male":"1064–Surnud","1072–Female":"1072–Surnud","1000–Male":"1000–Surnud","about 1030":"umbes 1030","abt 1062":"umbes 1062","1000":"1000","1055":"1055","abt 1064":"umbes 1064","1064":"1064","1063":"1063","1030":"1030","1062":"1062","1073":"1073","1072":"1072","ABT 1063":"umbes 1063","1106":"1106","1025":"1025","about 1055":"umbes 1055","ABT 1072":"umbes 1072","of Clwyd,Wales":"Clwyd, Wales, United Kingdom","Hirdref, Llyn, Gwynedd, Wales":"Gwynedd, Wales, United Kingdom","South Wales, Wales":"South Wales, Wales","of Pengwern, Denbigh, Wales":"Denbighshire, Wales, United Kingdom","Penley, Flintshire, Wales":"Penley, Flintshire, Wales","Pengwern, Llangollen, Denbighshire, Wales, United Kingdom":"Pengwern, Llangollen, Denbighshire, Wales, United Kingdom"},"fi":{"about 1030–":"noin 1030–Kuollut","1030–Female":"1030–Kuollut","1025–1073":"1025–1073","1055–1106":"1055–1106","1062–Male":"1062–Kuollut","1063–Female":"1063–Kuollut","1064–Male":"1064–Kuollut","1072–Female":"1072–Kuollut","1000–Male":"1000–Kuollut","about 1030":"noin 1030","abt 1062":"noin 1062","1000":"1000","1055":"1055","abt 1064":"noin 1064","1064":"1064","1063":"1063","1030":"1030","1062":"1062","1073":"1073","1072":"1072","ABT 1063":"noin 1063","1106":"1106","1025":"1025","about 1055":"noin 1055","ABT 1072":"noin 1072","of Clwyd,Wales":"Clwyd, Wales, Yhdistynyt kuningaskunta","Hirdref, Llyn, Gwynedd, Wales":"Gwynedd, Wales, Yhdistynyt kuningaskunta","South Wales, Wales":"South Wales, Wales","of Pengwern, Denbigh, Wales":"Denbighshire, Wales, Yhdistynyt kuningaskunta