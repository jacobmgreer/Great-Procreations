ngland":"England","Brandesburton, Yorkshire, England":"Brandesburton, Yorkshire, England","Dorset, England":"Dorset, England","Meriden, Warwickshire, England":"Meriden, Warwickshire, England, United Kingdom","nameMeanings":[{"name":"Maltravers","type":"LAST","attribution":"Dictionary of Family Names in Britain and Ireland © University of the West of England 2016","meanings":["Norman, English:  see  Matravers  ."],"variants":[{"name":"Matravers","meanings":["Norman, English: locative name from Mautravert in Chérencé-le-Héron (Manche)."]}]},{"name":"Anastasia","type":"FIRST","attribution":"Dictionary of First Names © Patrick Hanks and Flavia Hodges 1990, 2003, 2006.","meanings":["feminine form of the Greek male name <i>Anastasios</i> (a derivative of <i>anastasis</i> ‘resurrection’). It has always been popular in Eastern Europe, in honour of a 4th-century saint who was martyred at Sirmium in Dalmatia. It was also used occasionally in England in the Middle Ages and as late as the 17th century; more recently it has made a considerable comeback. One of the daughters of the last tsar of Russia bore this name. She was murdered by the Bolsheviks in  1918 , along with the rest of her family, but in  1920  a woman claiming to be the Romanov princess Anastasia came to public notice in Germany, and a film was later based on this story (  1956 )."],"variants":[{"name":"Anastasio","meanings":["From Greek <i>Anastasios</i>, a derivative of <i>anastasis</i> ‘resurrection’."]}]}],"historicEvents":[{"id":1705190,"age":26,"year":"1290","julianDay":2192224,"title":"Jews Expelled From England","description":"After years of anti-Semitic behavior, King Edward I expelled Jews from England in 1290.","jurisdictionLevel":2},{"id":1705191,"age":51,"year":"1315","toYear":"1317","julianDay":2201354,"title":"Famine Strikes Europe","description":"A famine caused by cold winters and wet summers across Europe caused millions to die due to starvation. Desperation from hunger caused high levels of crime, stampedes in bread lines in London, infanticide, and even cannibalism throughout Europe.","jurisdictionLevel":2},{"id":1705192,"age":64,"year":"1328","julianDay":2206102,"title":"First War of Scottish Independence","description":"The First War of Scottish Independence began after England invaded Scotland in 1296. The Treaty of Edinburgh was signed in 1328 which declared peace between the two kingdoms and brought the war to an end.","jurisdictionLevel":2}],"lifeSummary":"When Anastasia Maltravers was born in 1264, in Lytchett Matravers, Dorset, England, her father, Sir John Mautravers, was 26 and her mother, Joan of Woolcombe, was 25. She had at least 2 sons with Herbert de St Quintin V. She died in 1330, in Brandesburton, Yorkshire, England, at the age of 66."},"et":{"1264–1330":"1264–1330","1262–Female":"1262–Surnud","1266–1341":"1266–1341","1268–Male":"1268–Surnud","1292–1321":"1292–1321","1263–Male":"1263–Surnud","1286–1339":"1286–1339","1295–Male":"1295–Surnud","1238–1297":"1238–1297","1239–1297":"1239–1297","ABT    1295":"umbes 1295","1264":"1264","1286":"1286","1297":"1297","1330":"1330","1341":"1341","1263":"1263","1295":"1295","1262":"1262","1260":"1260","1292":"1292","1290":"1290","1239":"1239","1315":"1315","1238":"1238","1268":"1268","1321":"1321","1266":"1266","28 February 1297":"28. veebruar 1297","1328":"1328","1317":"1317","1339":"1339","Lytchett Matravers, Dorset, England":"Lytchett Matravers, Dorset, England","England":"England","Brandesburton, Yorkshire, England":"Brandesburton, Yorkshire, England","Dorset, England":"Dorset, England","Meriden, Warwickshire, England":"Meriden, Warwickshire, Inglismaa, United Kingdom"},"fi":{"1264–1330":"1264–1330","1262–Female":"1262–Kuollut","1266–1341":"1266–1341","1268–Male":"1268–Kuollut","1292–1321":"1292–1321","1263–Male":"1263–Kuollut","1286–1339":"1286–1339","1295–Male":"1295–Kuollut","1238–1297":"1238–1297","1239–1297":"1239–1297","ABT    1295":"noin 1295","1264":"1264","1286":"1286","1297":"1297","1330