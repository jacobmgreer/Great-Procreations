2–Female":"1122–Afdød","1130–Male":"1130–Afdød","1163–Male":"1163–Afdød","1080–1176":"1080–1176","1205–1312":"1205–1312","1232–Female":"1232–Afdød","1096–1152":"1096–1152","1165–Female":"1165–Afdød","1080":"1080","1165":"1165","1176":"1176","1121":"1121","1152":"1152","1163":"1163","1130":"1130","1096":"1096","1205":"1205","5 Nov 1176":"5. november 1176","Abt 1095":"omkring 1095","0995":"0995","1312":"1312","1057":"1057","1177":"1177","1232":"1232","1122":"1122","Nájera, La Rioja, España":"Nájera, La Rioja, Spanien","Spain":"Spanien"},"nl":{"–1177":"–1177","0995–1057":"0995–1057","1121–Male":"1121–Overleden","1122–Female":"1122–Overleden","1130–Male":"1130–Overleden","1163–Male":"1163–Overleden","1080–1176":"1080–1176","1205–1312":"1205–1312","1232–Female":"1232–Overleden","1096–1152":"1096–1152","1165–Female":"1165–Overleden","1080":"1080","1165":"1165","1176":"1176","1121":"1121","1152":"1152","1163":"1163","1130":"1130","1096":"1096","1205":"1205","5 Nov 1176":"5 november 1176","Abt 1095":"circa 1095","0995":"0995","1312":"1312","1057":"1057","1177":"1177","1232":"1232","1122":"1122","Nájera, La Rioja, España":"Nájera, La Rioja, Spanje","Spain":"Spanje"},"en":{"–1177":"–1177","0995–1057":"0995–1057","1121–Male":"1121–Deceased","1122–Female":"1122–Deceased","1130–Male":"1130–Deceased","1163–Male":"1163–Deceased","1080–1176":"1080–1176","1205–1312":"1205–1312","1232–Female":"1232–Deceased","1096–1152":"1096–1152","1165–Female":"1165–Deceased","1080":"1080","1165":"1165","1176":"1176","1121":"1121","1152":"1152","1163":"1163","1130":"1130","1096":"1096","1205":"1205","5 Nov 1176":"5 November 1176","Abt 1095":"about 1095","0995":"0995","1312":"1312","1057":"1057","1177":"1177","1232":"1232","1122":"1122","Nájera, La Rioja, España":"Nájera, La Rioja, Spain","Spain":"Spain","nameMeanings":[{"name":"Ponce","type":"LAST","attribution":"Dictionary of American Family Names © Patrick Hanks 2003, 2006.","meanings":["Some characteristic forenames:  Spanish Jose, Manuel, Juan, Luis, Jesus, Carlos, Francisco, Jorge, Miguel, Pedro, Raul, Roberto.","Spanish and French: from the medieval personal name <i>Ponce</i>, ultimately from <i>Pontius</i>, a Roman surname, perhaps an ethnic name for someone from <i>Pontus</i> (named from Greek <i>pontos</i> ‘ocean’) in Asia Minor, or an Italic cognate of Latin <i>Quintus</i> ‘fifth’ (i.e. ‘fifth-born’). The name was borne by two 3rd-century Christian saints, a Carthaginian deacon and a martyr of Nice, but was not widely popular in the Middle Ages because of the inhibiting influence of the even more famous Pontius Pilate. In some cases though, the surname may have been originally used for someone who had played the part of this character in a religious play."],"variants":[{"name":"Ponce de Leon","meanings":["Some characteristic forenames:  Spanish Jose, Luis, Cesar, Mercedes, Alberto, Francisco, Javier, Juan, Lazaro, Leticia, Manuel, Ramon.","Spanish (<b>Ponce de León</b>): compound of the surname   Ponce   + the habitational name <i>León</i> (see   Leon  ).","History: Juan Ponce De León, the Spanish explorer who discovered Florida, came from a noble Aragonese family. He is believed to have been on board for Columbus's second voyage to Hispaniola in 1493. After his death in Florida from a wound from an Indian arrow in 1521, Ponce De León's title and rights in Florida were passed on to his son."]},{"name":"Points","meanings":["English (of Norman origin):","from the Old French personal name <i>Ponz</i>, <i>Ponce</i>, from Latin <i>Pontius</i> (see   Ponce  ).","habitational name from any of several places called Ponts (such as those in Manche and in Seine-Maritime, Normandy), from Latin <i>pontes</i> ‘bridges’. This name has been established since the 13th century in Ireland, where it appears as <i>Pounce</i> and <i>Pounche</i>, and is Gaelicized as <b>Púinse</b>."]},{"name":"Pons","meanings":["Some characteristic forenames:  Spanish Jose, Juan, Pedro, Ramon, Guillermo, Roberto, Carlos, Francisco, Luis, Mario, Rafael, Apolonia.  French Adrien, Armand, Emile, Jacques, Marcel, Marcelle, Matilde.","Catalan, French (Occitan), and Dutch: from the medieval personal name <i>Pons</i> (see   Ponce  ).","German: patronymic from a short form of an ancient Germanic personal name, such as <i>Bonhard</i>, formed with the element <i>bon</i> ‘request, petition’ (compare Latin <i>bonus</i>)."]},{"name":"Ponzio","meanings":["Some characteristic forenames:  Italian Vito, Carlo, Carmine, Leonardo, Pasquale, Rocco, Salvatore, Silvio, Vincenzo.","Italian: from the personal name <i>Ponzio</i>, from Latin <i>Pontius</i> (see   Ponce  )."]},{"name":"Poncelet","meanings":["Some characteristic forenames:  French Alain, Benoit.  German Erwin, Fritz.","French (mainly northeastern) and Walloon:","topographic name from a diminutive of Old French <i>poncel</i> ‘little bridge’, or a habitational name from (Le) Poncelet, the name of several places in the northeastern part of France."]},{"name":"Poinsett","meanings":["Altered form of French <b>Poinset</b>: from a pet form of the personal name <i>Poinse</i>, from Latin <i>Pontius</i> (see   Ponce  ). Altered ending reflects the Canadian and American French practice of sounding the final <i>-t</i>. The surname <i>Poinset</i> is very rare in France.","History: The <i>poinsettia</i> takes its name from an American diplomat, Joel Poinsett (1779–1851), who was a keen amateur botanist and who brought the flower back from Mexico, where he was US ambassador. He was born in Charleston, SC, and was descended from a Huguenot, Pierre Poinset, who was born in Soubise in Charente-Maritime and settled in Charleston <i>c.</i> 1700. Pierre Poinset is listed in the (US) National Huguenot Society's register of qualified Huguenot ancestors and also in the similar registers of the Huguenot Society of America and of the Huguenot Society of South Carolina."]},{"name":"Point","meanings":["French: from the personal name <i>Point</i>, from Latin <i>Pontius</i> (see   Ponce  ).","English: variant of   Points   with loss of final <i>-s</i>. This surname is rare in Britain."]}]},{"name":"De","type":"LAST","attribution":"Dictionary of American Family Names © Patrick Hanks 2003, 2006.","meanings":["Some characteristic forenames:  Indian Dilip, Anirban, Gopal, Alok, Anindya, Arunava, Asit, Asok, Dibyendu, Goutam, Indra, Indranil.","Indian: variant of   Dey  ."],"variants":[{"name":"Dey","meanings":["Some characteristic forenames:  Indian Ashit, Indu, Naina, Partha, Soumya, Ajit, Anjan, Anjana, Anup, Arjun, Arun, Ashim.","English, Scottish, and Welsh: variant of   Day  .","German: topographic name from a field name in North Rhine-Westphalia, denoting a sizeable piece of land, from Middle Low German <i>dē</i> ‘thigh’ (referring to the shape of the property)."]}]},{"name":"Minerva","type":"LAST","attribution":"Dictionary of American Family Names © Patrick Hanks 2003, 2006.","meanings":["Some characteristic forenames:  Italian Vito, Domenic, Angelo, Giuseppe, Italia, Salvatore.","Italian: from the female personal name <i>Minerva</i>, from thename of the Roman goddess of wisdom, corresponding to Greek<i>Athena</i>."],"variants":[]},{"name":"Maria","type":"FIRST","attribution":"Dictionary of First Names © Patrick Hanks and Flavia Hodges 1990, 2003, 2006.","meanings":["Short form of   Maria  , of German origin but now also moderately popular in the English-speaking world."],"variants":[]}],"lifeSummary":"Maria Ponce De Minerva was born in Spain as the daughter of Ponce de Minerva and Condesa Estefania Ramirez de Cifuentes. She married Martin Diego de Villamayor about 1095, in Spain. They were the parents of at least 1 daughter. She died in 1177, in Nájera, La Rioja, Spain."},"et":{"–1177":"–1177","0995–1057":"0995–1057","1121–Male":"1121–Surnud","1122–Female":"1122–Surnud","1130–Male":"1130–Surnud","1163–Male":"1163–Surnud","1080–1176":"1080–1176","1205–1312":"1205–1312","1232–Female":"1232–Surnud","1096–1152":"1096–1152","1165–Female":"1165–Surnud"