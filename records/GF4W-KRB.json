155":"1155","before 1186":"før 1186","about 1176":"omkring 1176","about 1177":"omkring 1177","about 1175":"omkring 1175","Yorkshire, England":"Jórvík, England, United Kingdom","Holderness, Yorkshire, England":"Holderness, Jórvík, England"},"nl":{"Bef 1135–Bef 1186":"vóór 1135–vóór 1186","1135–1186":"1135–1186","–Female":"Overleden","1155–1186":"1155–1186","1175–Male":"1175–Overleden","1176–Male":"1176–Overleden","1177–Male":"1177–Overleden","1215–1237":"1215–1237","1220–Male":"1220–Overleden","–1173":"–1173","1120–Male":"1120–Overleden","1220":"1220","1176":"1176","1120":"1120","1175":"1175","1186":"1186","1173":"1173","Bef 1186":"vóór 1186","1237":"1237","1215":"1215","Bef 1135":"vóór 1135","1135":"1135","Bef 1155":"vóór 1155","1177":"1177","1155":"1155","before 1186":"vóór 1186","about 1176":"circa 1176","about 1177":"circa 1177","about 1175":"circa 1175","Yorkshire, England":"Yorkshire, Engeland, Verenigd Koninkrijk","Holderness, Yorkshire, England":"Holderness, Yorkshire, England"},"en":{"Bef 1135–Bef 1186":"before 1135–before 1186","1135–1186":"1135–1186","–Female":"Deceased","1155–1186":"1155–1186","1175–Male":"1175–Deceased","1176–Male":"1176–Deceased","1177–Male":"1177–Deceased","1215–1237":"1215–1237","1220–Male":"1220–Deceased","–1173":"–1173","1120–Male":"1120–Deceased","1220":"1220","1176":"1176","1120":"1120","1175":"1175","1186":"1186","1173":"1173","Bef 1186":"before 1186","1237":"1237","1215":"1215","Bef 1135":"before 1135","1135":"1135","Bef 1155":"before 1155","1177":"1177","1155":"1155","before 1186":"before 1186","about 1176":"about 1176","about 1177":"about 1177","about 1175":"about 1175","Yorkshire, England":"Yorkshire, England, United Kingdom","Holderness, Yorkshire, England":"Holderness, Yorkshire, England","nameMeanings":[{"name":"Sutton","type":"LAST","attribution":"Dictionary of American Family Names © Patrick Hanks 2003, 2006.","meanings":["English: habitational name from any of numerous places called Sutton, named with Old English <i>sūth</i> ‘south, southern’ + <i>tūn</i> ‘farmstead, estate’. The English surname is also common in Ireland (Wexford, Kildare), where it has been established since the 13th century and Gaelicized as <b>de Sutún</b>.","Jewish (from the former Ottoman Empire, including Syria): unexplained.","English: topographic name from Middle English <i>(bi) suthentune</i> ‘(at the place to the) south of the village’."],"variants":[{"name":"Setton","meanings":["Some characteristic forenames:  Jewish Avi, Ronit, Yossef.  French Andree, Henri, Jacques, Maryse.","Jewish (from the Ottoman Empire): altered form of   Sutton  .","English (Middlesex): variant of   Seaton  ."]}]},{"name":"Sayer","type":"LAST","attribution":"Dictionary of American Family Names © Patrick Hanks 2003, 2006.","meanings":["English: common occupational name from Middle English <i>sayer</i>, a phonetic variant of   Sawyer  , which in Wales and neighboring English counties may have been reinforced by the synonymous Welsh <i>saer</i> ‘carpenter’ and everywhere by a possible borrowing into Middle English of Old French <i>seieor</i>, <i>saieur</i> ‘sawyer’.","English: rare occupational name perhaps denoting an assayer of metals, or a servant who tasted his lord's food before serving, from Middle English <i>saiour</i> ‘assayer, tester’ (a shortened form of Old French <i>assaiour</i>, ultimately from Late Latin <i>exagium</i>, a derivative of <i>exagmināre</i> ‘to weigh’).","English: rare occupational name for a professional reciter or minstrel, from Middle English <i>seier(e)</i> ‘speaker’."],"variants":[{"name":"Sayre","meanings":["English (Middlesex and Surrey): variant of   Sayer  ."]},{"name":"Sears","meanings":["Irish (Kerry): Anglicized form of Gaelic <b>Mac Saoghair</b> ‘son of <i>Saoghar</i>’, a borrowing in Anglo-Norman Ireland of the Anglo-Norman French and Middle English personal name <i>Saher</i>, <i>Seier</i> (Old French <i>Seheri</i>), from ancient Germanic <i>Sigeheri</i>, <i>Sighari</i>, composed of the elements <i>sig</i>‘victory’ + <i>hari</i>, <i>heri</i> ‘army’. See   Sayer   5.","English: variant of   Sayers  .","Americanized form of French (or French Canadian)   Cyr   and French <b>Saint-Cyr</b> (see   St. Cyr  ), with the addition of excrescent <i>-s</i>, a common feature of Americanized surnames."]},{"name":"Sear","meanings":["‘peak, crest’, also ‘the best’. Common as an abbreviated form of compound names such as  Chandrasekhar  ‘moon-crested’, an epithet of the god Shiva."]},{"name":"Searson","meanings":["English: patronymic from the Middle English personal name <i>Saher</i>, <i>Seier</i> (see   Sayer   5) + <i>-son</i>.","English: variant of <b>Searston</b>, a habitational name from Syerston (Nottinghamshire). The placename probably derives from the Old English personal name <i>Sighere</i> (genitive <i>Sigheres</i>) + Old English <i>tūn</i> ‘farmstead, estate’.","Irish (Tipperary): variant of   Sears  ."]},{"name":"Sare","meanings":["version of the English name <b>Sally</b> ."]},{"name":"Saier","meanings":["South German: occupational name for a farmer, from an agent derivative of Middle High German <i>saien</i> ‘to sow’. Compare   Sayer   8."]},{"name":"Say","meanings":["From the vocabulary word (from Old Norse <i>ský</i> ‘cloud’). This was one of the names taken from the world of nature (  compare  Rainbow  ,   Leaf  ,   River  ) during the 1960s under the influence of the hippy and flower-power movements. It continues to enjoy a modest popularity."]},{"name":"Sayers","meanings":["English: variant of   Sayer  , with genitival or post-medieval excrescent <i>-s</i>. This name is also established in Ireland.","Irish: Anglicized form of Gaelic <b>Mac Saoghair</b>; see   Sears  ."]},{"name":"Sawyer","meanings":["English: occupational name for someone who earned his living by sawing wood, from Middle English <i>sauer(e)</i>, <i>sauw(i)er</i>, also <i>sagh(i)er</i>, <i>sag(i)er</i> ‘sawyer’, a derivative of Old English <i>sagu</i> ‘saw’.","Americanized form of some similar (like-sounding) Jewish surname, or translation into English of Jewish   Seger   or some other surname meaning ‘sawyer’, e.g. German   Sager   and Slovenian <b>Žagar</b> (see   Zagar  )."]},{"name":"Seekings","meanings":["English: from the unrecorded Middle English personal name <i>Saykin</i>, a pet form of Middle English and Anglo-Norman French <i>Saher</i>, <i>Seier</i> (see   Sayer   5). The final <i>-s</i> is post-medieval and excrescent."]}]}],"lifeSummary":"Sayer Sutton was born before 1135, in Holderness, Yorkshire, England, United Kingdom as the son of Syward Sutton. He had at least 7 sons and 1 daughter with Edith Grosse. He died before 1186."},"et":{"Bef 1135–Bef 1186":"enne 1135–enne 1186","1135–1186":"1135–1186","–Female":"Surnud","1155–1186":"1155–1186","1175–Male":"1175–Surnud","1176–Male":"1176–Surnud","1177–Male":"1177–Surnud","1215–1237":"1215–1237","1220–Male":"1220–Surnud","–1173":"–1173","1120–Male":"1120–Surnud","1220":"1220","1176":"1176","1120":"1120","1175":"1175","1186":"1186","1173":"1173","Bef 1186":"enne 1186","1237":"1237","1215":"1215","Bef 1135":"enne 1135","1135":"1135","Bef 1155":"enne 1155","1177":"1177","1155":"1155","before 1186":"enne 1186","about 1176":"umbes 1176","about 1177":"umbes 1177","about 1175":"umbes 1175","Yorkshire, England":"Yorkshire, Inglismaa, United Kingdom","Holderness, Yorkshire, England":"Holderness, Yorkshire, England"},"fi":{"Bef 1135–Bef 1186":"ennen vuotta 1135–ennen vuotta 1186","1135–1186":"1135–1186","–Female":"Kuollut","1155–1186":"1155–1186","1175–Male":"1175–Kuollut","1176–Male":"1176–Kuollut","1177–Male":"1177–Kuollut","1215–1237":"1215–1237","1220–Male":"1220–Kuollut","–1173":"–1173","1120–Male":"1120–Kuollut","1220":"1220","1176":"1176","1120":"1120","1175":"1175","1186":"1186","1173":"1173","Bef 1186":"ennen vuotta 1186","1237":"1237","1215":"1215","Bef 1135":"ennen vuotta 1135","1135":"1135","Bef 1155":"ennen vuotta 1155","1177":"1177","1155":"1155","before 1186":"ennen vuotta 1186","ab