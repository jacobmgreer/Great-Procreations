ais, France":"Cuinchy, Pas-de-Calais, Nord-Pas-de-Calais, Frankrijk","Winchester, Hampshire, England":"Winchester, Hampshire, Engeland, Verenigd Koninkrijk","Cuincy, Normandy, France":"Normandie, Frankrijk","Long Buckby, Northamptonshire, England":"Long Buckby, Northamptonshire, England","Winton, East Lothian, Scotland":"East Lothian, Schotland, Verenigd Koninkrijk"},"en":{"about 1050–about 1131":"about 1050–about 1131","1040–Male":"1040–Deceased","1066–1098":"1066–1098","1069–1120":"1069–1120","1050–1131":"1050–1131","about 1050":"about 1050","1069":"1069","1066":"1066","1098":"1098","1120":"1120","1131":"1131","1040":"1040","1050":"1050","about 1131":"about 1131","Cuinchy, Pas-de-Calais, Nord-Pas-de-Calais, France":"Cuinchy, Pas-de-Calais, Nord-Pas-de-Calais, France","Winchester, Hampshire, England":"Winchester, Hampshire, England, United Kingdom","Cuincy, Normandy, France":"Normandy, France","Long Buckby, Northamptonshire, England":"Long Buckby, Northamptonshire, England","Winton, East Lothian, Scotland":"East Lothian, Scotland, United Kingdom","nameMeanings":[{"name":"Matilda","type":"FIRST","attribution":"Dictionary of First Names © Patrick Hanks and Flavia Hodges 1990, 2003, 2006.","meanings":["Latinized form of a Germanic personal name derived from <i>maht</i>, <i>meht</i> ‘might’ + <i>hild</i> ‘battle’. This was the name of an early German queen (  895–968 ), wife of  Henry  the Fowler, who was noted for her piety and generosity. It was also the name of the wife of  William  the Conqueror and of the daughter of  Henry I  of England (  see  Maud  ). The name was introduced into England by the Normans, and this Latinized form is the one that normally occurs in medieval records, while the vernacular form <i>Maud</i> was the one in everyday use. <i>Matilda</i> was revived in England as a learned form in the 18th century."],"variants":[{"name":"Mathilda","meanings":["Latinized form of a Germanic personal name derived from <i>maht</i>, <i>meht</i> ‘might’ + <i>hild</i> ‘battle’. This was the name of an early German queen (  895–968 ), wife of  Henry  the Fowler, who was noted for her piety and generosity. It was also the name of the wife of  William  the Conqueror and of the daughter of  Henry I  of England (  see  Maud  ). The name was introduced into England by the Normans, and this Latinized form is the one that normally occurs in medieval records, while the vernacular form <i>Maud</i> was the one in everyday use. <i>Matilda</i> was revived in England as a learned form in the 18th century."]}]}],"lifeSummary":"Matilda was born about 1050, in Normandy, France. She married Robert de Quincy. They were the parents of at least 1 son and 1 daughter. She died about 1131, at the age of 83."},"et":{"about 1050–about 1131":"umbes 1050–umbes 1131","1040–Male":"1040–Surnud","1066–1098":"1066–1098","1069–1120":"1069–1120","1050–1131":"1050–1131","about 1050":"umbes 1050","1069":"1069","1066":"1066","1098":"1098","1120":"1120","1131":"1131","1040":"1040","1050":"1050","about 1131":"umbes 1131","Cuinchy, Pas-de-Calais, Nord-Pas-de-Calais, France":"Cuinchy, Pas-de-Calais, Nord-Pas-de-Calais, Prantsusmaa","Winchester, Hampshire, England":"Winchester, Hampshire, Inglismaa, United Kingdom","Cuincy, Normandy, France":"Normandie, Prantsusmaa","Long Buckby, Northamptonshire, England":"Long Buckby, Northamptonshire, England","Winton, East Lothian, Scotland":"East Lothian, Šotimaa, United Kingdom"},"fi":{"about 1050–about 1131":"noin 1050–noin 1131","1040–Male":"1040–Kuollut","1066–1098":"1066–1098","1069–1120":"1069–1120","1050–1131":"1050–1131","about 1050":"noin 1050","1069":"1069","1066":"1066","1098":"1098","1120":"1120","1131":"1131","1040":"1040","1050":"1050","about 1131":"noin 1131","Cuinchy, Pas-de-Calais, Nord-Pas-de-Calais, France":"Cuinchy, Pas-de-Calais, Nord-Pas-de-Calais, Ranska","Winchester, Hampshire, England":"Winchester, Hampshire, Englanti, Yhdistynyt kuningaskunta","Cuincy, Normandy, France":"Normandie, Ranska","Long Buckby