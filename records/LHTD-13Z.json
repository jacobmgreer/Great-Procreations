ire, England":"Grassington, Yorkshire, England","Craven, Yorkshire, England":"Craven, Yorkshire, England","Middleton, Yorkshire, England":"Middleton, Yorkshire, England","England":"Engeland, Verenigd Koninkrijk"},"en":{"about 1218–1300":"about 1218–1300","1217–1300":"1217–1300","–Male":"Deceased","1243–1340":"1243–1340","1245–Male":"1245–Deceased","1249–Female":"1249–Deceased","–1284":"–1284","1218–1300":"1218–1300","1242":"1242","1340":"1340","1284":"1284","1290":"1290","1217":"1217","1249":"1249","1259":"1259","1224":"1224","about 1218":"about 1218","1300":"1300","1245":"1245","1243":"1243","about 1249":"about 1249","after 1284":"after 1284","about 1245":"about 1245","1218":"1218","Grassington, Yorkshire, England":"Grassington, Yorkshire, England","Craven, Yorkshire, England":"Craven, Yorkshire, England","Middleton, Yorkshire, England":"Middleton, Yorkshire, England","England":"England, United Kingdom","nameMeanings":[{"name":"Agnes","type":"FIRST","attribution":"Dictionary of First Names © Patrick Hanks and Flavia Hodges 1990, 2003, 2006.","meanings":["Latinized version of the Greek name <i>Hagnē</i>, from the feminine form of the adjective <i>hagnos</i> ‘pure, holy’. This was the name of a young Roman virgin martyred in the persecutions instigated by the Roman emperor Diocletian in   ad  303 . She became a very popular saint in the Middle Ages. Her name was early associated with Latin <i>agnus</i> ‘lamb’, leading to the consistent dropping of the initial <i>H-</i> and to her representation in art accompanied by a lamb. The colloquial form <i>Annes</i> led to some confusion with <i>Ann(e)</i> in earlier centuries. Frequent in the medieval period, the name was revived in the 19th century, and has been especially popular in Scotland.  See also  Annis ."],"variants":[]},{"name":"of","type":"FIRST","attribution":"Dictionary of First Names © Patrick Hanks and Flavia Hodges 1990, 2003, 2006.","meanings":["Short form of   Oswald   or any of the various other names beginning with <i>Os-</i>."],"variants":[]},{"name":"Grassington","type":"LAST","attribution":"Dictionary of American Family Names © Patrick Hanks 2003, 2006.","meanings":["English: habitational name from a place so named in Derbyshire, which is probably named as ‘the settlement (Old English <i>tūn</i>) associated with a man named <i>Brandsige</i>’. <i>Brandsige</i>, composed of the elements <i>brand</i> ‘sword’ + <i>sige</i> ‘victory’, is not attested as an Old English personal name, but seems plausible."],"variants":[{"name":"Brasington","meanings":["English: variant of   Brassington  ."]},{"name":"Brazelton","meanings":["English: possibly a variant of   Brassington  ."]}]}],"historicEvents":[{"id":1705188,"age":6,"year":"1224","julianDay":2168117,"title":"France Declares War on England","description":"France declared war on England as Louis VIII of France attacked Poitou and northern Gascony.","jurisdictionLevel":2},{"id":1705189,"age":41,"year":"1259","julianDay":2180901,"title":"100 Years of Conflict Between England and France Ends","description":"Treaty of Paris was signed on December 4, 1259, which ended 100 years of conflict between England and France.","url":"https://en.wikipedia.org/wiki/Treaty_of_Paris_(1259)","urlTitle":"Wikipedia - Treaty of Paris 1259","jurisdictionLevel":2},{"id":1705190,"age":72,"year":"1290","julianDay":2192224,"title":"Jews Expelled From England","description":"After years of anti-Semitic behavior, King Edward I expelled Jews from England in 1290.","jurisdictionLevel":2}],"lifeSummary":"Agnes of Grassington was born about 1218, in Grassington, Yorkshire, England. She married Serlonis de Westwick in 1242, in Grassington, Yorkshire, England. They were the parents of at least 2 sons and 2 daughters. She died in 1300, in England, United Kingdom, at the age of 83."},"et":{"about 1218–1300":"umbes 1218–1300","1217–1300":"1217–1300","–Male":"Surnud","1243–1340":"1243–1340","1245–Male":"1245–Surnud","1249–Female":"1249–Surnud","–1284":"–1284","