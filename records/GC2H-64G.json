14":"1170–1214","1166–1187":"1166–1187","1187–1250":"1187–1250","1135–1220":"1135–1220","1140–1214":"1140–1214","about 1161":"circa 1161","about 1160":"circa 1160","1187":"1187","1220":"1220","1140":"1140","1250":"1250","1161":"1161","1170":"1170","1214":"1214","1225":"1225","1135":"1135","1166":"1166","about 1225":"circa 1225","about 1187":"circa 1187","about 1186":"circa 1186","Humbie, Haddingtonshire, Scotland":"Humbie, Haddingtonshire, Schotland","Humbie, East Lothian, Scotland":"Humbie, East Lothian, Schotland, Verenigd Koninkrijk","Scotland":"Schotland"},"en":{"about 1161–about 1225":"about 1161–about 1225","1161–1225":"1161–1225","1170–1214":"1170–1214","1166–1187":"1166–1187","1187–1250":"1187–1250","1135–1220":"1135–1220","1140–1214":"1140–1214","about 1161":"about 1161","about 1160":"about 1160","1187":"1187","1220":"1220","1140":"1140","1250":"1250","1161":"1161","1170":"1170","1214":"1214","1225":"1225","1135":"1135","1166":"1166","about 1225":"about 1225","about 1187":"about 1187","about 1186":"about 1186","Humbie, Haddingtonshire, Scotland":"Humbie, Haddingtonshire, Scotland","Humbie, East Lothian, Scotland":"Humbie, East Lothian, Scotland, United Kingdom","Scotland":"Scotland","nameMeanings":[{"name":"de","type":"LAST","attribution":"Dictionary of American Family Names © Patrick Hanks 2003, 2006.","meanings":["Some characteristic forenames:  Indian Dilip, Anirban, Gopal, Alok, Anindya, Arunava, Asit, Asok, Dibyendu, Goutam, Indra, Indranil.","Indian: variant of   Dey  ."],"variants":[{"name":"Dey","meanings":["Some characteristic forenames:  Indian Ashit, Indu, Naina, Partha, Soumya, Ajit, Anjan, Anjana, Anup, Arjun, Arun, Ashim.","English, Scottish, and Welsh: variant of   Day  .","German: topographic name from a field name in North Rhine-Westphalia, denoting a sizeable piece of land, from Middle Low German <i>dē</i> ‘thigh’ (referring to the shape of the property)."]}]},{"name":"Keith","type":"LAST","attribution":"Dictionary of American Family Names © Patrick Hanks 2003, 2006.","meanings":["Scottish: habitational name from the lands of Keith in East Lothian. The placename is derived from British Celtic <i>cait-</i> ‘wood’. In the 17th century numerous bearers of this name settled in Ulster.","German: nickname from Middle High German <i>kīt</i> ‘sprout, offspring’.","History: George Keith (<i>c.</i> 1638–1716), born at Peterhead, Aberdeenshire, Scotland, came to NJ in or before 1685. In 1689 he settled in Philadelphia, where he became headmaster of the school now called the William Penn Charter School. He came into sharp collision with the Quaker leaders in PA and formed a separatist party known as the Christian Quakers, popularly known as ‘Keithians’."],"variants":[{"name":"Kight","meanings":["Americanized form of German   Keith  .","English: perhaps a variant of   Kite  ."]},{"name":"Keath","meanings":["Scottish and English (mainly Cambridgeshire): variant of   Keith  ."]},{"name":"Kite","meanings":["English: nickname from Middle English <i>kete</i>, <i>kyte</i> ‘kite’ (the bird of prey), perhaps a nickname for a rapacious person.","Americanized form of German   Keith  .","English: habitational name from one or more of the minor places with names deriving from Old English <i>cȳte</i>, <i>cyte</i> ‘cottage, hut, shed’, such as Kite Farm in Swalecliffe (Kent)."]},{"name":"Keeth","meanings":["English and Scottish: variant of   Keith  ."]},{"name":"Keitt","meanings":["Possibly an altered form of German   Keith   2."]}]},{"name":"Philip","type":"FIRST","attribution":"Dictionary of First Names © Patrick Hanks and Flavia Hodges 1990, 2003, 2006.","meanings":["From the Greek name <i>Philippos</i>, meaning ‘lover of horses’, from <i>philein</i> ‘to love’ + <i>hippos</i> ‘horse’. This was popular in the classical period and since. It was the name of the father of  Alexander the Great . It was also the name of one of Christ's apostles, of a deacon ordained by the apostles after the death of Christ, and of several other early saints.  See also  Philippa ."],"variants":[]}],"lifeSummary":"When Philip de Keith was born about 1161, in Humbie, Haddingtonshire, Scotland, his father, Malcolm de Keith, was 27 and his mother, Lady Margaret de Humbie, was 22. He married Ida Lorens about 1186, in Scotland. They were the parents of at least 1 son. He died about 1225, in his hometown, at the age of 66."},"et":{"about 1161–about 1225":"umbes 1161–umbes 1225","1161–1225":"1161–1225","1170–1214":"1170–1214","1166–1187":"1166–1187","1187–1250":"1187–1250","1135–1220":"1135–1220","1140–1214":"1140–1214","about 1161":"umbes 1161","about 1160":"umbes 1160","1187":"1187","1220":"1220","1140":"1140","1250":"1250","1161":"1161","1170":"1170","1214":"1214","1225":"1225","1135":"1135","1166":"1166","about 1225":"umbes 1225","about 1187":"umbes 1187","about 1186":"umbes 1186","Humbie, Haddingtonshire, Scotland":"Humbie, Haddingtonshire, Scotland","Humbie, East Lothian, Scotland":"Humbie, East Lothian, Šotimaa, United Kingdom","Scotland":"Scotland"},"fi":{"about 1161–about 1225":"noin 1161–noin 1225","1161–1225":"1161–1225","1170–1214":"1170–1214","1166–1187":"1166–1187","1187–1250":"1187–1250","1135–1220":"1135–1220","1140–1214":"1140–1214","about 1161":"noin 1161","about 1160":"noin 1160","1187":"1187","1220":"1220","1140":"1140","1250":"1250","1161":"1161","1170":"1170","1214":"1214","1225":"1225","1135":"1135","1166":"1166","about 1225":"noin 1225","about 1187":"noin 1187","about 1186":"noin 1186","Humbie, Haddingtonshire, Scotland":"Humbie, Haddingtonshire, Scotland","Humbie, East Lothian, Scotland":"Humbie, East Lothian, Skotlanti, Yhdistynyt kuningaskunta","Scotland":"Scotland"},"fr":{"about 1161–about 1225":"environ 1161–environ 1225","1161–1225":"1161–1225","1170–1214":"1170–1214","1166–1187":"1166–1187","1187–1250":"1187–1250","1135–1220":"1135–1220","1140–1214":"1140–1214","about 1161":"environ 1161","about 1160":"environ 1160","1187":"1187","1220":"1220","1140":"1140","1250":"1250","1161":"1161"