ants":[]}],"lifeSummary":"When Agnes Ohnesorg was born about 1270, in Augsburg, Augsburg, Bavaria, Germany, her father, Richard Onsorg II, was 36 and her mother, Lutzy Portner von Wellenburg, was 26. She married Ulrich Von Suntheim about 1320, in Augsburg, Bavaria, Germany."},"et":{"um 1270–":"umbes 1270–Surnud","1270–Female":"1270–Surnud","1281–Female":"1281–Surnud","1264–1314":"1264–1314","1275–Male":"1275–Surnud","1297–Female":"1297–Surnud","1315–1390":"1315–1390","1235–Male":"1235–Surnud","1245–Female":"1245–Surnud","1297":"1297","1264":"1264","1275":"1275","1281":"1281","1270":"1270","1390":"1390","um 1270":"umbes 1270","1315":"1315","1314":"1314","1235":"1235","1245":"1245","Abt 1320":"umbes 1320","about 1315":"umbes 1315","Augsburg, Augsburg, Bayern, Deutschland":"Augsburg, Augsburg, Bayern, Saksamaa","Ulm, Baden-Württemberg, Germany":"Ulm, Baden-Württemberg, Saksamaa","Ulm, Stadtkreis, Baden-Württemberg, Germany":"Ulm, Oberamt Ulm, Württemberg, Saksamaa","Of,Augsburg,Schwaben,Bayern":"Landkreis Augsburg, Bayern, Saksamaa","Augsburg, Schwaben, Bayern, Germany":"Augsburg, Augsburg, Bayern, Saksamaa"},"fi":{"um 1270–":"noin 1270–Kuollut","1270–Female":"1270–Kuollut","1281–Female":"1281–Kuollut","1264–1314":"1264–1314","1275–Male":"1275–Kuollut","1297–Female":"1297–Kuollut","1315–1390":"1315–1390","1235–Male":"1235–Kuollut","1245–Female":"1245–Kuollut","1297":"1297","1264":"1264","1275":"1275","1281":"1281","1270":"1270","1390":"1390","um 1270":"noin 1270","1315":"1315","1314":"1314","1235":"1235","1245":"1245","Abt 1320":"noin 1320","about 1315":"noin 1315","Augsburg, Augsburg, Bayern, Deutschland":"Augsburg, Augsburg, Bayern, Saksa","Ulm, Baden-Württemberg, Germany":"Ulm, Baden-Württemberg, Saksa","Ulm, Stadtkreis, Baden-Württemberg, Germany":"Ulm, Oberamt Ulm, Württemberg, Saksa","Of,Augsburg,Schwaben,Bayern":"Landkreis Augsburg, Bayern, Saksa","Augsburg, Schwaben, Bayern, Germany":"Augsburg, Augsburg, Bayern, Saksa"},"fr":{"um 1270–":"environ 1270–Décédée","