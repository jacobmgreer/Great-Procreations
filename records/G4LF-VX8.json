ngdom":"Caerlaverock, Dumfriesshire, Schotland, Verenigd Koninkrijk","Caerlaverock, Dumfriesshire, Scotland":"Caerlaverock, Dumfriesshire, Schotland","Dumfriesshire, Scotland, United Kingdom":"Dumfriesshire, Schotland, Verenigd Koninkrijk"},"en":{"1382–14 FEB 1454":"1382–14 February 1454","–Female":"Deceased","1410–1478":"1410–1478","1408–Female":"1408–Deceased","1408–1486":"1408–1486","1415–1458":"1415–1458","1382–1454":"1382–1454","ABT 1408":"about 1408","1415":"1415","1458":"1458","1478":"1478","14 FEB 1454":"14 February 1454","1454":"1454","1410":"1410","1486":"1486","before 1408":"before 1408","1382":"1382","ABT 1415":"about 1415","1408":"1408","Calderwood, Lanarkshire, Scotland, United Kingdom":"Calderwood, Lanarkshire, Scotland, United Kingdom","Caerlaverock, Dumfriesshire, Scotland, United Kingdom":"Caerlaverock, Dumfriesshire, Scotland, United Kingdom","Caerlaverock, Dumfriesshire, Scotland":"Caerlaverock, Dumfriesshire, Scotland","Dumfriesshire, Scotland, United Kingdom":"Dumfriesshire, Scotland, United Kingdom","nameMeanings":[{"name":"Maxwelll","type":"LAST","attribution":"Dictionary of American Family Names © Patrick Hanks 2003, 2006.","meanings":["Scottish: habitational name from a place in Kelso, near Melrose in Roxburghshire, the name of a salmon pool on the Tweed near Kelso Bridge. The placename is first recorded in 1144 in the form <i>Mackeswell</i> ‘Mack's spring or stream’ (Old English <i>well(a)</i>).","Irish: adopted for <b>Ó Meisceall</b>, see   Miskell  . This surname is common in Ulster.","Jewish: arbitrary adoption of the Scottish name, or Americanized form of one or more similar (like-sounding) Jewish surnames."],"variants":[{"name":"Miskell","meanings":["Irish (Galway): Anglicized form of Gaelic <b>Ó Meisceall</b> ‘descendant of <i>Meiscill</i>’, a personal name of unexplained etymology. Sometimes Anglicized as   Maxwell  ."]}]},{"name":"Sir","type":"FIRST","attribution":"Dictionary of First Names © Patrick Hanks and Flavia Hodges 1990, 2003, 2006.","meanings":["From Old Norse, originally a byname meaning ‘bride, wife’; in mythology the name of Thor's golden-haired wife."],"variants":[]},{"name":"Herbert","type":"FIRST","attribution":"Dictionary of First Names © Patrick Hanks and Flavia Hodges 1990, 2003, 2006.","meanings":["From an Old French name of Germanic (Frankish) origin, introduced to Britain by the Normans. It is derived from <i>heri</i>, <i>hari</i> ‘army’ + <i>berht</i> ‘bright, famous’. An Old English form, <i>Herebeorht</i>, existed in England before the Conquest, but was superseded by the Norman form, which gave rise to an important surname. The family in question were earls of Pembroke in the 16th and 17th centuries; they included the poet  George Herbert . By the end of the Middle Ages <i>Herbert</i> was little used, although it remained a favourite with some families, notably the Saint Quintins of East Yorkshire. Its greater frequency in Britain from the 19th century onwards is due partly to the trend for the revival of medieval names of Germanic origin and partly to the trend for the transferred use of surnames."],"variants":[{"name":"Heribert","meanings":["From an Old French name of Germanic (Frankish) origin, introduced to Britain by the Normans. It is derived from <i>heri</i>, <i>hari</i> ‘army’ + <i>berht</i> ‘bright, famous’. An Old English form, <i>Herebeorht</i>, existed in England before the Conquest, but was superseded by the Norman form, which gave rise to an important surname. The family in question were earls of Pembroke in the 16th and 17th centuries; they included the poet  George Herbert . By the end of the Middle Ages <i>Herbert</i> was little used, although it remained a favourite with some families, notably the Saint Quintins of East Yorkshire. Its greater frequency in Britain from the 19th century onwards is due partly to the trend for the revival of medieval names of Germanic origin and partly to the trend for the transferred use of surnames."]}]},{"name":"III",