ll, Stafford, Eng":"Eccleshall, Staffordshire, Engeland, Verenigd Koninkrijk","Swinnerton, Stafford, England":"Swynnerton, Staffordshire, Engeland, Verenigd Koninkrijk"},"en":{"Abt 1230–":"about 1230–Deceased","1230–1276":"1230–1276","1250–1381":"1250–1381","1230–Female":"1230–Deceased","Abt 1230":"about 1230","Abt 1250":"about 1250","1276":"1276","1230":"1230","1250":"1250","1381":"1381",", Eccleshall, Stafford, Eng":"Eccleshall, Staffordshire, England, United Kingdom","Swinnerton, Stafford, England":"Swynnerton, Staffordshire, England, United Kingdom","nameMeanings":[{"name":"Waure","type":"LAST","attribution":"Dictionary of American Family Names © Patrick Hanks 2003, 2006.","meanings":["Hispanic: probably a shortened form of Basque   Jauregui  ."],"variants":[{"name":"Jauregui","meanings":["Some characteristic forenames:  Spanish Jose, Luis, Juan, Francisco, Alfredo, Jesus, Miguel, Salvador, Enrique, Manuel, Raul, Carlos.","Basque: Castilianized form of <b>Jauregi</b>, a habitational name from any of several places in the Basque Country called Jauregi, from Basque <i>jauregi</i> ‘palace, manor house’."]}]},{"name":"Joan","type":"FIRST","attribution":"Dictionary of First Names © Patrick Hanks and Flavia Hodges 1990, 2003, 2006.","meanings":["Contracted form of Old French <i>Jo(h)anne</i>, from Latin <i>Io(h)anna</i> (  see  Joanna  ). In England this was the usual feminine form of   John   from the Middle English period onwards and was extremely popular, but in the 16th and 17th centuries it steadily lost ground to   Jane .  It was strongly revived in the first part of the 20th century, partly under the influence of  George Bernard Shaw's  play St Joan (  1923 ), based on the life of  Joan of Arc  (  1412–31 ). Claiming to be guided by the voices of the saints, she persuaded the French dauphin to defy the occupying English forces and have himself crowned, and she led the French army that raised the siege of Orleans in  1429 . The following year she was captured by the Burgundians and sold to the English, and a year later she was burned at the stake for witchcraft at the age of 18 or 19. Her story has captured the imagination of many writers, and she is variously portrayed as a national and political hero, a model of apolitical straightforwardness and honesty, and a religious heroine. She was canonized in  1920 . More recent influences have included the American film actress  Joan Crawford  (  1908–77 , born  Lucille le Sueur ), the British actress  Joan Collins  (  b. 1933 ), the American comedienne  Joan Rivers  (  b. 1933 ), and the West Indian pop singer  Joan Armatrading  (  b. 1950 )."],"variants":[{"name":"John","meanings":["New Testament: ‘God is gracious’.  See  <b>John</b> ."]}]}],"lifeSummary":"Joan Waure was born about 1230, in Eccleshall, Staffordshire, England, United Kingdom. She married Stephen Swynnerton. They were the parents of at least 1 son."},"et":{"Abt 1230–":"umbes 1230–Surnud","1230–1276":"1230–1276","1250–1381":"1250–1381","1230–Female":"1230–Surnud","Abt 1230":"umbes 1230","Abt 1250":"umbes 1250","1276":"1276","1230":"1230","1250":"1250","1381":"1381",", Eccleshall, Stafford, Eng":"Eccleshall, Staffordshire, Inglismaa, United Kingdom","Swinnerton, Stafford, England":"Swynnerton, Staffordshire, Inglismaa, United Kingdom"},"fi":{"Abt 1230–":"noin 1230–Kuollut","1230–1276":"1230–1276","1250–1381":"1250–1381","1230–Female":"1230–Kuollut","Abt 1230":"noin 1230","Abt 1250":"noin 1250","1276":"1276","1230":"1230","1250":"1250","1381":"1381",", Eccleshall, Stafford, Eng":"Eccleshall, Staffordshire, Englanti, Yhdistynyt kuningaskunta","Swinnerton, Stafford, England":"Swynnerton, Staffordshire, Englanti, Yhdistynyt kuningaskunta"},"fr":{"Abt 1230–":"environ 1230–Décédée","1230–1276":"1230–1276","1250–1381":"1250–1381","1230–Female":"1230–Décédée","Abt 1230":"environ 1230","Abt 1250":"environ 1250","1276":"1276","1230":"1230","1250":"1250","1381":"1381",", Eccleshall, Stafford, Eng":"Eccleshall, Staffordshire,