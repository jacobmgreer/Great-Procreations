emale":"1195–Overleden","–Female":"Overleden","1230–Male":"1230–Overleden","–Male":"Overleden","1220–1241":"1220–1241","1165–1234":"1165–1234","1185–Female":"1185–Overleden","about 1192":"circa 1192","ABT 1230":"circa 1230","1234":"1234","1165":"1165","1220":"1220","1241":"1241","1230":"1230","1185":"1185","1195":"1195","1192":"1192","Radnorshire, Wales":"Radnorshire, Wales","{Cdfr ap Dnwl}":"Ascoli Piceno, Marche, Italië"},"en":{"about 1192–":"about 1192–Deceased","1192–Male":"1192–Deceased","1195–Female":"1195–Deceased","–Female":"Deceased","1230–Male":"1230–Deceased","–Male":"Deceased","1220–1241":"1220–1241","1165–1234":"1165–1234","1185–Female":"1185–Deceased","about 1192":"about 1192","ABT 1230":"about 1230","1234":"1234","1165":"1165","1220":"1220","1241":"1241","1230":"1230","1185":"1185","1195":"1195","1192":"1192","Radnorshire, Wales":"Radnorshire, Wales","{Cdfr ap Dnwl}":"Ascoli Piceno, Marche, Italy","nameMeanings":[{"name":"Rhys","type":"LAST","attribution":"Dictionary of Family Names in Britain and Ireland © University of the West of England 2016","meanings":["Welsh:  see  Rees  ."],"variants":[{"name":"Rees","meanings":["Welsh: variant of   Rice  .","German: habitational name from a place in the Rhineland called Rees.","German: from a short form of the personal name   Andreas  ."]}]},{"name":"Gryg","type":"LAST","attribution":"Dictionary of American Family Names © Patrick Hanks 2003, 2006.","meanings":["English: variant of   Gregg  ."],"variants":[{"name":"Gregg","meanings":["English (Yorkshire and Lancashire): from the Middle English personal name <i>Greg</i>, a pet form of   Gregory  ; compare   Grigg  ."]}]},{"name":"Philip","type":"FIRST","attribution":"Dictionary of First Names © Patrick Hanks and Flavia Hodges 1990, 2003, 2006.","meanings":["From the Greek name <i>Philippos</i>, meaning ‘lover of horses’, from <i>philein</i> ‘to love’ + <i>hippos</i> ‘horse’. This was popular in the classical period and since. It was the name of the father of  Alexander the Great . It was also the name of one of Christ's apostles, of a deacon ordained by the apostles after the death of Christ, and of several other early saints.  See also  Philippa ."],"variants":[]},{"name":"ap","type":"FIRST","attribution":"Dictionary of First Names © Patrick Hanks and Flavia Hodges 1990, 2003, 2006.","meanings":["Short form of any of the names beginning with this syllable."],"variants":[{"name":"Alexander","meanings":["From the Latin form of the Greek name <i>Alexandros</i>, from <i>alexein</i> ‘to defend’ + <i>anēr</i> ‘man, warrior’ (genitive <i>andros</i>). The name became extremely popular in the post-classical period, and was borne by several individuals in the New Testament and some early Christian saints. Its use as a common given name throughout Europe, however, derives largely from the fame of  Alexander the Great , King of Macedon (  356–323  bc  ), around whom a large body of popular legend grew up in late antiquity, much of which came to be embodied in the medieval ‘Alexander romances’."]},{"name":"Alan","meanings":["Of Celtic origin and uncertain derivation (possibly a diminutive of a word meaning ‘rock’). It was introduced into England by  Breton  followers of  William the Conqueror , most notably  Alan , Earl of Brittany, who was rewarded for his services with vast estates in the newly conquered kingdom. In Britain the variants  <b>Allan</b>  and  <b>Allen</b>  are considerably less frequent, and generally represent transferred uses of surname forms, whereas in America all three forms of the name are approximately equally common.  See also  Alun ."]},{"name":"Albert","meanings":["From an Old French name, <i>Albert</i>, of Germanic (Frankish) origin, derived from <i>adal</i> ‘noble’ + <i>berht</i> ‘bright, famous’. This was adopted by the Normans and introduced by them to England, displacing the Old English form <i>Æþelbeorht</i>. The name is popular in a variety of forms in Western Europe, and has been traditional in a number of European princely families. It was out of favour in England for centuries, however, and the revival of its popularity in the 19th century was largely in honour of  Queen Victoria's  consort,  Prince Albert of Saxe-Coburg-Gotha ."]}]}],"lifeSummary":"When Philip ap Rhys Gryg was born about 1192, in Radnorshire, Wales, his father, Prince Rhys Gryg, was 28 and his mother, Joan de Clare, was 8. He had at least 2 sons and 3 daughters with unknown."},"et":{"about 1192–":"umbes 1192–Surnud","1192–Male":"1192–Surnud","1195–Female":"1195–Surnud","–Female":"Surnud","1230–Male":"1230–Surnud","–Male":"Surnud","1220–1241":"1220–1241","1165–1234":"1165–1234","1185–Female":"1185–Surnud","about 1192":"umbes 1192","ABT 1230":"umbes 1230","1234":"1234","1165":"1165","1220":"1220","1241":"1241","1230":"1230","1185":"1185","1195":"1195","1192":"1192","Radnorshire, Wales":"Radnorshire, Wales","{Cdfr ap Dnwl}":"Ascoli Piceno, Marche, Itaalia"},"fi":{"about 1192–":"noin 1192–Kuollut","1192–Male":"1192–Kuollut","1195–Female":"1195–Kuollut","–Female":"Kuollut","1230–Male":"1230–Kuollut","–Male":"Kuollut","1220–1241":"1220–1241","1165–1234":"1165–1234","1185–Female":"1185–Kuollut","about 1192":"noin 1192","ABT 1230":"noin 1230","1234":"1234","1165":"1165","1220":"1220","1241":"1241","1230":"1230","1185":"1185","1195":"1195","1192":"1192","Radnorshire, Wales":"Radnorshire, Wales","{Cdfr ap Dnwl}":"Ascoli Piceno, Marche, Italia"},"fr":{"about 1192–":"environ 1192–Décédé","1192–Male":"1192–Décédé","1195–Female":"1195–Décédée","–Female":"Décédée","1230–Male":"1230–Décédé","–Male":"Décédé","1220–1241":"1220–1241","1165–1234":"1165–1234","1185–Female":"1185–Décédée","about 1192":"environ 1192","ABT 1230":"environ 1230","1234":"1234","1165":"1165","1220":"1220","1241":"1241","1230":"1230","1185":"1185","1195":"1195","1192":"1192","Radnorshire, Wales":"Radnorshire, Galles","{Cdfr ap Dnwl}":"Ascoli Piceno, Marche, Italie","lifeSummary":"Lorsque Philip ap Rhys Gryg est né environ 1192, à Radnor