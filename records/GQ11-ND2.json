0","1290":"1290","1315":"1315","1325":"1325.","1259":"1259","1236":"1236","1212":"1212","about 1248":"oko 1248.","1200":"1200","1232":"1232","about 1230":"oko 1230.","1317":"1317","Shunock, Cornwall, England":"Cornwall, England","Sesay, Yorkshire, England":"Yorkshire, England"},"cs":{"about 1230–1325":"okolo 1230–1325","1230–1325":"1230–1325","1236–Male":"1236–Zesnulý","1232–Female":"1232–Zesnulá","1250–Male":"1250–Zesnulý","1200–Male":"1200–Zesnulý","1212–Female":"1212–Zesnulá","about 1250":"okolo 1250","1230":"1230","1250":"1250","1290":"1290","1315":"1315","1325":"1325","1259":"1259","1236":"1236","1212":"1212","about 1248":"okolo 1248","1200":"1200","1232":"1232","about 1230":"okolo 1230","1317":"1317","Shunock, Cornwall, England":"Cornwall, Anglie","Sesay, Yorkshire, England":"Yorkshire, Anglie"},"da":{"about 1230–1325":"omkring 1230–1325","1230–1325":"1230–1325","1236–Male":"1236–Afdød","1232–Female":"1232–Afdød","1250–Male":"1250–Afdød","1200–Male":"1200–Afdød","1212–Female":"1212–Afdød","about 1250":"omkring 1250","1230":"1230","1250":"1250","1290":"1290","1315":"1315","1325":"1325","1259":"1259","1236":"1236","1212":"1212","about 1248":"omkring 1248","1200":"1200","1232":"1232","about 1230":"omkring 1230","1317":"1317","Shunock, Cornwall, England":"Cornwall, England","Sesay, Yorkshire, England":"Jórvík, England"},"nl":{"about 1230–1325":"circa 1230–1325","1230–1325":"1230–1325","1236–Male":"1236–Overleden","1232–Female":"1232–Overleden","1250–Male":"1250–Overleden","1200–Male":"1200–Overleden","1212–Female":"1212–Overleden","about 1250":"circa 1250","1230":"1230","1250":"1250","1290":"1290","1315":"1315","1325":"1325","1259":"1259","1236":"1236","1212":"1212","about 1248":"circa 1248","1200":"1200","1232":"1232","about 1230":"circa 1230","1317":"1317","Shunock, Cornwall, England":"Cornwall, England","Sesay, Yorkshire, England":"Yorkshire, England"},"en":{"about 1230–1325":"about 1230–1325","1230–1325":"1230–1325","1236–Male":"1236–Deceased","1232–Female":"1232–Deceased","1250–Male":"1250–Deceased","1200–Male":"1200–Deceased","1212–Female":"1212–Deceased","about 1250":"about 1250","1230":"1230","1250":"1250","1290":"1290","1315":"1315","1325":"1325","1259":"1259","1236":"1236","1212":"1212","about 1248":"about 1248","1200":"1200","1232":"1232","about 1230":"about 1230","1317":"1317","Shunock, Cornwall, England":"Cornwall, England","Sesay, Yorkshire, England":"Yorkshire, England","nameMeanings":[{"name":"Dawnay","type":"LAST","attribution":"Dictionary of Family Names in Britain and Ireland © University of the West of England 2016","meanings":["Norman, English: locative name from one of the many places in northern France named from an alder grove (Old French  <i>aulnai</i>,  <i>aulnoi</i>, latinized as  <i>alnetum</i>), such as Annay (Pas-de-Calais), Aulnay (Aube, Marne, Calvados), Aulnois (Aisne), and Aunay (Calvados, Eure-et-Loire, Seine-et-Oise). With fused preposition, Anglo-Norman French  <i>d'Aunai</i> became  <i>Dawnay</i>,  <i>Dawney</i> and (with loss of the final syllable)  <i>Dawn</i>.   Laney   is another form of this surname with fused definite article.  See also  Dando  , from Anglo-Norman French  <i>d'Aunou</i>, with which  <i>d'Aunai</i> may sometimes have been confused."],"variants":[{"name":"Dawney","meanings":["Norman, English:  See  Dawnay  ."]},{"name":"Laney","meanings":["Irish: probably a shortened and altered form of   McElhinney  .","English and Irish: habitational name introduced by the Normans originally deriving from any of the many places in northern France called L'Aunai (from Latin <i>alnetum</i> ‘alder grove’). It may also have developed to   Delaney  .","Variant of   Laine   2, a surname of French origin."]},{"name":"Dawn","meanings":["English (Derbyshire and Nottinghamshire): of Norman origin, probably a clipped form of <b>Dawnay</b> or <b>Dawney</b> (compare   Dana  ), habitational names from one of the many places in northern France named for an alder grove (Old French <i>aulnai</i>, <i>aulnoi</i>, Latinized as <i>alnetum</i>). With fused preposition <i>d(e)</i>, Anglo-Norman <i>d'Aunai</i> became <i>Dawnay</i>, <i>Dawney</i> and (with loss of the final syllable) <i>Dawn</i>.   Laney   is another form of this surname with fused definite article. See also   Dando  , from Anglo-Norman <i>d'Aunou</i>, with which <i>d'Aunai</i> may sometimes have been confused.","English: from Middle English <i>Dawen</i>, a variant of   Dawes   with the weak declension genitival suffix <i>-(e)n</i> (Old English <i>-an</i>) instead of the standard Middle English <i>-es</i>. The usage is mainly restricted to West Midlands dialects of Middle English.","Americanized form of German   Daun  ."]},{"name":"Doney","meanings":["English (Cornwall): of uncertain origin. There is a Richard <i>Donowe</i> recorded in 1451-64 as a tenant in Manuels, Saint Columb Minor, whose surname appears to be a pet form of an unidentified personal name with the Cornish hypocoristic suffix <i>-ow</i>. Formally this might have become <i>Doney</i> but <i>Donowe</i> itself seems not to have survived, unless it was altered to   Downey  . However, there is no evidence to suggest any connection of this west Cornwall surname with <i>Doney</i> in central and east Cornwall (Bodmin and Quethiock). Alternatively, perhaps it is a variant of the Devon name   Downey  , and with the main vowel shortened and lowered, but evidence for this is lacking.","Americanized form of French Canadian   Daunais   or   Donais  ."]},{"name":"Dando","meanings":["English (of Norman origin): habitational name for someone from Aunou-le-Faucon in Orne, Normandy, with fused preposition. Aunou was named for an alder grove, from Latin <i>alnus</i> ‘alder’ + the Gaulish suffix <i>-avum</i>. In medieval England <i>d'Aunou</i> developed an intrusive <i>-d-</i>, giving <i>Dando</i>. The surname was sometimes confused with <i>d'Aunay</i> or <i>d'Auney</i> (see   Delaney  )."]}]},{"name":"John","type":"FIRST","attribution":"Dictionary of First Names © Patrick Hanks and Flavia Hodges 1990, 2003, 2006.","meanings":["As a boy's name this represents a revival of Middle English <i>Jan</i>, a by‐form of   John  , or an adoption of the common European form with this spelling. As a girl's name it is a short form of names such as   Janet   and   Janice ."],"variants":[]}],"historicEvents":[{"id":1705189,"age":29,"year":"1259","julianDay":2180901,"title":"100 Years of Conflict Between England and France Ends","description":"Treaty of Paris was signed on December 4, 1259, which ended 100 years of conflict between England and France.","url":"https://en.wikipedia.org/wiki/Treaty_of_Paris_(1259)","urlTitle":"Wikipedia - Treaty of Paris 1259","jurisdictionLevel":1},{"id":1705190,"age":60,"year":"1290","julianDay":2192224,"title":"Jews Expelled From England","description":"After years of anti-Semitic behavior, King Edward I expelled Jews from England in 1290.","jurisdictionLevel":1},{"id":1705191,"age":85,"year":"1315","toYear":"1317","julianDay":2201354,"title":"Famine Strikes Europe","description":"A famine caused by cold winters and wet summers across Europe caused millions to die due to starvation. Desperation from hunger caused high levels of crime, stampedes in bread lines in London, infanticide, and even cannibalism throughout Europe.","jurisdictionLevel":1}],"lifeSummary":"When John Alneto Dawnay was born about 1230, in Cornwall, England, his father, Richard Dawnay, was 32 and his mother, Mrs. Richard Dawney, was 20. He married Jane Cave about 1248. They were the parents of at least 1 son. He died in 1325, in Yorkshire, England, at the age of 96."},"et":{"about 1230–1325":"umbes 1230–1325","1230–1325":"1230–1325","1236–Male":"1236–Surnud","1232–Female":"1232–Surnud","1250–Male":"1250–Surnud","1200–Male":"1200–Surnud","1212–Female":"1212–Surnud","about 1250":"umbes 1250","1230":"1230","1250":"1250","1290":"1290","1315":"1315","1325":"1325","1259":"1259","1236":"1236","1212":"1212","about 1248":"umbes 1248","12