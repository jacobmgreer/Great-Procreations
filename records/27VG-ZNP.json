0":"1350","1382":"1382","1425":"1425","1368":"1368","1411":"1411","1388":"1388","about 1368":"circa 1368","about 1388":"circa 1388","about 1374":"circa 1374","about 1350":"circa 1350","about 1372":"circa 1372","Worcestershire, England":"Worcestershire, England","Shropshire, England":"Shropshire, England"},"en":{"about 1350–1425":"about 1350–1425","–Male":"Deceased","1350–1388":"1350–1388","1368–1411":"1368–1411","1372–Male":"1372–Deceased","1374–Female":"1374–Deceased","1350–1425":"1350–1425","about 1370":"about 1370","before 1411":"before 1411","1374":"1374","1372":"1372","1350":"1350","1382":"1382","1425":"1425","1368":"1368","1411":"1411","1388":"1388","about 1368":"about 1368","about 1388":"about 1388","about 1374":"about 1374","about 1350":"about 1350","about 1372":"about 1372","Worcestershire, England":"Worcestershire, England","Shropshire, England":"Shropshire, England","nameMeanings":[{"name":"de","type":"LAST","attribution":"Dictionary of American Family Names © Patrick Hanks 2003, 2006.","meanings":["Some characteristic forenames:  Indian Dilip, Anirban, Gopal, Alok, Anindya, Arunava, Asit, Asok, Dibyendu, Goutam, Indra, Indranil.","Indian: variant of   Dey  ."],"variants":[{"name":"Dey","meanings":["Some characteristic forenames:  Indian Ashit, Indu, Naina, Partha, Soumya, Ajit, Anjan, Anjana, Anup, Arjun, Arun, Ashim.","English, Scottish, and Welsh: variant of   Day  .","German: topographic name from a field name in North Rhine-Westphalia, denoting a sizeable piece of land, from Middle Low German <i>dē</i> ‘thigh’ (referring to the shape of the property)."]}]},{"name":"Clifton","type":"LAST","attribution":"Dictionary of American Family Names © Patrick Hanks 2003, 2006.","meanings":["English: habitational name from any of the very numerous places called Clifton, from Old English <i>clif</i> ‘slope’ (see   Cliff  ) + <i>tūn</i> ‘enclosure, settlement’."],"variants":[{"name":"Cliff","meanings":["English: habitational name from any of numerous places called Cliff(e), Cle(e)ve, or Clive, from Old English <i>clif</i> ‘slope, bank, cliff’, or a topographic name from the same word. The Old English word was used not only in the sense of modern English <i>cliff</i> but also of much gentler slopes and frequently also of a riverbank or seashore."]}]},{"name":"Margaret","type":"FIRST","attribution":"Dictionary of First Names © Patrick Hanks and Flavia Hodges 1990, 2003, 2006.","meanings":["An extremely common given name from the Middle Ages onwards, derived via Old French <i>Marguerite</i> and Latin <i>Margarita</i> from Greek <i>Margarītēs</i>, from <i>margaron</i> ‘pearl’, a word ultimately of Hebrew origin. The name was always understood to mean ‘pearl’ throughout the Middle Ages. The first  St Margaret  was martyred at Antioch in Pisidia during the persecution instigated by the  Emperor Diocletian  in the early 4th century. However, there is some doubt about her name, as the same saint is venerated in the Orthodox Church as   Marina .  There were several other saintly bearers of the name, including St Margaret of Scotland (  d. 1093 ), wife of  King Malcolm Canmore  and daughter of Edmund Ironside of England. It was also the name of the wife of  Henry VI  of England,  Margaret of Anjou  (  1430–82 ), and of  Margaret Tudor  (  1489–1541 ), sister of  Henry VIII , who married James IV of Scotland and ruled as regent there after his death.  See also  Margery  ,   Marjorie ."],"variants":[{"name":"Margareta","meanings":["From the Latin form of Greek <i>Margarītēs</i>.  See  <b>Margaret</b>   ."]},{"name":"Margaretta","meanings":["An extremely common given name from the Middle Ages onwards, derived via Old French <i>Marguerite</i> and Latin <i>Margarita</i> from Greek <i>Margarītēs</i>, from <i>margaron</i> ‘pearl’, a word ultimately of Hebrew origin. The name was always understood to mean ‘pearl’ throughout the Middle Ages. The first  St Margaret  was martyred at Antioch in Pisidia during the persecution instigated by the  Emperor Diocletian  in the early 4th century. However, there is some doubt about her name, as the same saint is venerated in the Orthodox Church as   Marina .  There were several other saintly bearers of the name, including St Margaret of Scotland (  d. 1093 ), wife of  King Malcolm Canmore  and daughter of Edmund Ironside of England. It was also the name of the wife of  Henry VI  of England,  Margaret of Anjou  (  1430–82 ), and of  Margaret Tudor  (  1489–1541 ), sister of  Henry VIII , who married James IV of Scotland and ruled as regent there after his death.  See also  Margery  ,   Marjorie ."]}]}],"historicEvents":[{"id":1705195,"age":32,"year":"1382","julianDay":2225826,"title":"Wycliffe's Bible","description":"John Wycliffe, English theologian and professor at the University of Oxford, completed a translation of the Bible from the Latin Vulgate into Middle English. This translation is known as Wycliffe's Bible and was completed around 1382.","url":"https://en.wikipedia.org/wiki/Wycliffe%27s_Bible","urlTitle":"Wikipedia - Wycliffe's Bible","jurisdictionLevel":1}],"lifeSummary":"Margaret de Clifton was born about 1350, in Worcestershire, England. She married Sir William de Wysham about 1370, in Worcestershire, England. They were the parents of at least 2 sons and 2 daughters. She died in 1425, at the age of 76."},"et":{"about 1350–1425":"umbes 1350–1425","–Male":"Surnud","1350–1388":"1350–1388","1368–1411":"1368–1411","1372–Male":"1372–Surnud","1374–Female":"1374–Surnud","1350–1425":"1350–1425","about 1370":"umbes 1370","before 1411":"enne 1411","1374":"1374","1372":"1372","1350":"1350","1382":"1382","1425":"1425","1368":"1368","1411":"1411","1388":"1388","about 1368":"umbes 1368","about 1388":"umbes 1388","about 1374":"umbes 1374","about 1350":"umbes 1350","about 1372":"umbes 1372","Worcestershire, England":"Worcestershire, England","Shropshire, England":"Shropshire, England"},"fi":{"about 1350–1425":"noin 1350–1425","–Male":"Kuollut","1350–1388":"1350–1388","13