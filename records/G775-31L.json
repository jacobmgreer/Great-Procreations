0":"1010","1081":"1081","1029":"1029","1006":"1006","1014":"1014","0982":"0982","about 0976":"about 0976","1067":"1067","after 0989":"after 0989","0989":"0989","about 1020":"about 1020","0946":"0946","0976":"0976","1009":"1009","Baghdād, Iraq":"Baghdād, Iraq","Istanbul, Turkey":"İstanbul, Türkiye","Constantinople (now Istanbul), Istanbul Province, , Turkey, Byzantine Empire":"Byzantine Empire","Istambul, Niassa, Moçambique":"Istambul, Sanga, Niassa, Mozambique","Iraq":"Iraq","nameMeanings":[{"name":"Andronikus","type":"FIRST","meanings":["Greek: A conqueror of men"],"variants":[]},{"name":"Dukas","type":"FIRST","attribution":"Dictionary of First Names © Patrick Hanks and Flavia Hodges 1990, 2003, 2006.","meanings":["Greek.  See  <b>Luke</b> ."],"variants":[{"name":"Luke","meanings":["Middle English vernacular form of   Lucas  , Latin form of the post-classical Greek name <i>Loukas</i> ‘man from Lucania’. This owes its perennial popularity throughout Christian Europe to the fact that, from the 2nd century onwards, the third gospel in the New Testament has been ascribed to the Lucas or Luke mentioned at various places in Acts and in the Epistles. Little is known about him beyond the facts that he was a doctor, a Gentile, and a friend and convert of St Paul. The name was borne by the character  Luke Skywalker  in the film Star Wars (  1977 ), and rose sharply in popularity in the 1990s."]}]},{"name":"von","type":"FIRST","attribution":"Dictionary of First Names © Patrick Hanks and Flavia Hodges 1990, 2003, 2006.","meanings":["Short form of   Ronald .  It is sometimes used as a given name in its own right."],"variants":[{"name":"Ronald","meanings":["From the Old Norse personal name <i>Rögnvaldr</i> (composed of <i>regin</i> ‘advice, decision’ (also, ‘the gods’) + <i>valdr</i> ‘ruler’). This name was regularly used in the Middle Ages in northern England and Scotland, where Scandinavian influence was strong. It is now widespread throughout the English-speaking world."]}]}]