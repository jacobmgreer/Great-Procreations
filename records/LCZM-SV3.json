10–1166","1113–1180":"1113–1180","1115–Male":"1115–Overleden","1150–1190":"1150–1190","–1191":"–1191","1150–1208":"1150–1208","1069–1131":"1069–1131","1073–Female":"1073–Overleden","1190":"1190","1110":"1110","1131":"1131","1073":"1073","1150":"1150","1191":"1191","1180":"1180","about 1109":"circa 1109","1115":"1115","1069":"1069","1113":"1113","29 September 1131":"29 september 1131","1101":"1101","1166":"1166","1188":"1188","1177":"1177","after 1188":"na 1188","1208":"1208","1109":"1109","Berkeley Castle, Berkeley, Gloucester, England":"Berkeley, Gloucestershire, England","Coberley, Cheltenham, Gloucestershire, England":"Coberley, Gloucestershire, Engeland, Verenigd Koninkrijk","Coberley, Gloucestershire, England":"Coberley, Gloucestershire, England"},"en":{"about 1109–after 1188":"about 1109–after 1188","1101–1177":"1101–1177","1109–1188":"1109–1188","1110–1166":"1110–1166","1113–1180":"1113–1180","1115–Male":"1115–Deceased","1150–1190":"1150–1190","–1191":"–1191","1150–1208":"1150–1208","1069–1131":"1069–1131","1073–Female":"1073–Deceased","1190":"1190","1110":"1110","1131":"1131","1073":"1073","1150":"1150","1191":"1191","1180":"1180","about 1109":"about 1109","1115":"1115","1069":"1069","1113":"1113","29 September 1131":"29 September 1131","1101":"1101","1166":"1166","1188":"1188","1177":"1177","after 1188":"after 1188","1208":"1208","1109":"1109","Berkeley Castle, Berkeley, Gloucester, England":"Berkeley, Gloucestershire, England","Coberley, Cheltenham, Gloucestershire, England":"Coberley, Gloucestershire, England, United Kingdom","Coberley, Gloucestershire, England":"Coberley, Gloucestershire, England","nameMeanings":[{"name":"Berkeley","type":"LAST","attribution":"Dictionary of American Family Names © Patrick Hanks 2003, 2006.","meanings":["English: habitational name from one or more of the numerous places so named, such as Berkeley in Gloucestershire, named in Old English with <i>be(o)rc</i> ‘birch’ + <i>lēah</i> ‘woodland clearing’. Compare Scottish   Barclay  .","Jewish (American): adoption of the English surname (see 1 above) in place of   Berkowitz  ."],"variants":[{"name":"Barclay","meanings":["Scottish: habitational name of English origin, from any of several places so called, such as Berkley in Somerset or Berkeley in Gloucestershire, both named in Old English with <i>be(o)rc</i> ‘birch’ + <i>lēah</i> ‘woodland clearing’.","History: The surname was brought to Scotland from southwestern England in the 12th century; Walter de Berchelai or Berkelai was Chamberlain of Scotland in 1165. It was long assumed that they were from the family that held Berkeley Castle in Gloucestershire, but the historian G. W. S. Barrow (1973, <i>The Kingdom of the Scots</i>) adduced evidence that they are more probably from Berkley in Somerset."]},{"name":"Berkley","meanings":["English: variant of   Berkeley  . Compare Scottish   Barclay  .","Jewish (Ashkenazic): assimilated form of   Berkowitz  ."]}]},{"name":"William","type":"FIRST","attribution":"Dictionary of First Names © Patrick Hanks and Flavia Hodges 1990, 2003, 2006.","meanings":["Probably the most successful of all the Old French names of Germanic origin that were introduced to England by the Normans. It is derived from Germanic <i>wil</i> ‘will, desire’ + <i>helm</i> ‘helmet, protection’. The fact that it was borne by the Conqueror himself does not seem to have inhibited its favour with the ‘conquered’ population: in the first century after the Conquest it was the commonest male name of all, and not only among the Normans. In the later Middle Ages it was overtaken by   John  , but continued to run second to that name until the 20th century, when the picture became more fragmented."],"variants":[]},{"name":"de","type":"FIRST","attribution":"Dictionary of First Names © Patrick Hanks and Flavia Hodges 1990, 2003, 2006.","meanings":["‘Attainment’."],"variants":[]}],"lifeSummary":"When Great Chamberlain I William de Berkeley was born about 1109, in Coberley, Gloucestershire, Engla