英格兰肯特可藍別盧可","England, United Kingdom":"英国英格兰","lifeSummary":"Lord Roger Bigge是Sir Thomas John Bigge和Gese von Negendank的儿子，于1395年出生在英国英格兰肯特貝嫩登。他于大约1420年与Joan Kent of Plantagenent在英国英格兰肯特貝嫩登结婚。他们至少是3个儿子和1个女儿的父母。他去世于1474年6月在他的家乡享年79岁。"},"hr":{"1395–Jun 1474":"1395.–lipanj 1474.","1395–1474":"1395.–1474","1406–1443":"1406–1443","1400–1472":"1400–1472.","1420–1472":"1420.–1472.","1420–1488":"1420.–1488","1424–1474":"1424–1474","1378–1452":"1378–1452.","–Female":"preminula","Jun 1474":"lipanj 1474.","1 April 1424":"1. travnja 1424.","1395":"1395.","1472":"1472.","June 1472":"lipanj 1472.","1424":"1424","1378":"1378","1488":"1488","1400":"1400","1443":"1443","1420":"1420.","1452":"1452.","1474":"1474","before 1395":"prije 1395.","about 1420":"oko 1420.","1406":"1406","Marden, Kent, England":"Marden, Kent, England","Benenden, Kent, England":"Benenden, Kent, Engleska, United Kingdom","Cranbrook, Kent, England, United Kingdom":"Cranbrook, Kent, Engleska, United Kingdom","England, United Kingdom":"Engleska, United Kingdom"},"cs":{"1395–Jun 1474":"1395–červen 1474","1395–1474":"1395–1474","1406–1443":"1406–1443","1400–1472":"1400–1472","1420–1472":"1420–1472","1420–1488":"1420–1488","1424–1474":"1424–1474","1378–1452":"1378–1452","–Female":"Zesnulá","Jun 1474":"červen 1474","1 April 1424":"1. dubna 1424","1395":"1395","1472":"1472","June 1472":"červen 1472","1424":"1424","1378":"1378","1488":"1488","1400":"1400","1443":"1443","1420":"1420","1452":"1452","1474":"1474","before 1395":"před 1395","about 1420":"okolo 1420","1406":"1406","Marden, Kent, England":"Marden, Kent, Anglie","Benenden, Kent, England":"Benenden, Kent, Anglie, United Kingdom","Cranbrook, Kent, England, United Kingdom":"Cranbrook, Kent, Anglie, United Kingdom","England, United Kingdom":"Anglie, United Kingdom"},"da":{"1395–Jun 1474":"1395–juni 1474","1395–1474":"1395–1474","1406–1443":"1406–1443","1400–1472":"1400–1472","1420–1472":"1420–1472","1420–1488":"1420–1488","1424–1474":"1424–1474","1378–1452":"1378–14