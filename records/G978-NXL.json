:{"1365–1420":"1365–1420","1365–Male":"1365–Overleden","–Male":"Overleden","1432–1484":"1432–1484","1432":"1432","1365":"1365","1420":"1420","1484":"1484"},"en":{"1365–1420":"1365–1420","1365–Male":"1365–Deceased","–Male":"Deceased","1432–1484":"1432–1484","1432":"1432","1365":"1365","1420":"1420","1484":"1484","nameMeanings":[{"name":"Lindsay","type":"LAST","attribution":"Dictionary of American Family Names © Patrick Hanks 2003, 2006.","meanings":["Scottish: habitational name from Lindsey in Lincolnshire, England. This is first found in the form <i>Lindissi</i>, apparently a derivative of the British name of   Lincoln  . To this was later added the Old English element <i>ēg</i> ‘island’, since the place was virtually cut off by the surrounding fenland. The surname was taken to Scotland at an early date and is the name of an important and powerful Scottish family.","Irish: adopted as an equivalent ofvarious Gaelic names (see   Lindsey  )."],"variants":[{"name":"Linzy","meanings":["Altered form of Scottish, Irish, or English   Lindsay   or   Lindsey  . Compare   Lenzy  ."]},{"name":"Linzey","meanings":["English: variant of   Lindsay   or   Lindsey  ."]},{"name":"Lindsey","meanings":["Scottish: variant of   Lindsay  .","Irish: shortened and Anglicized form of various Gaelic surnames, as for example <b>Ó Loingsigh</b> (see   Lynch   1), <b>Mac Giolla Fhionntóg</b> (see   McClintock  ), and <b>Ó Fhloinn</b> (see   Flynn   and   Lynn  )."]},{"name":"Lincoln","meanings":["English: habitational name from the city of Lincoln, so named from an original British name <i>Lindo-</i> ‘lake’ + Latin <i>colonia</i> ‘settlement, colony’. The place was an important administrative center during the Roman occupation of Britain and in the Middle Ages it was a center for the manufacture of cloth, including the famous ‘Lincoln green’.","African American: adoption of the surname in 1 above, in honor of Abraham Lincoln, the 16th president of the US, who abolished slavery.","History: Abraham Lincoln (1809–65), 16th president of the US, was the son of an illiterate laborer, descended from Samuel Lincoln, who had emigrated from England to MA in 1637."]},{"name":"Linsey","meanings":["Scottish, Irish, or English: variant of   Lindsay   or   Lindsey  .","Americanized form of German   Linse   or Swiss German <b>Linsi</b>, see   Lins  ."]}]},{"name":"Mary","type":"FIRST","attribution":"Dictionary of First Names © Patrick Hanks and Flavia Hodges 1990, 2003, 2006.","meanings":["From Latin <i>Maria</i> via Old Welsh <i>Meir</i>.  See  <b>Mary</b> ."],"variants":[]}],"lifeSummary":"Mary Lindsay was born in 1365. She had at least 1 son with William Cochrane. She died in 1420, at the age of 55."},"et":{"1365–1420":"1365–1420","1365–Male":"1365–Surnud","–Male":"Surnud","1432–1484":"1432–1484","1432":"1432","1365":"1365","1420":"1420","1484":"1484"},"fi":{"1365–1420":"1365–1420","1365–Male":"1365–Kuollut","–Male":"Kuollut","1432–1484":"1432–1484","1432":"1432","1365":"1365","1420":"1420","1484":"1484"},"fr":{"1365–1420":"1365–1420","1365–Male":"1365–Décédé","–Male":"Décédé","1432–1484":"1432–1484","1432":"1432","1365":"1365","1420":"1420","1484":"1484","lifeSummary":"Mary Lindsay est née en 1365. Elle a eu au moins 1 fils avec William Cochrane. Elle est décédée en 1420, à l’âge de 55 ans."},"de":{"1365–1420":"1365–1420","1365–Male":"1365–Verstorben","–Male":"Verstorben","1432–1484":"1432–1484","1432":"1432","1365":"1365","1420":"1420","1484":"1484","lifeSummary":"Mary Lindsay wurde 1365 geboren. Sie hatte mit William Cochrane mindestens 1 Sohn. Sie starb 1420 im Alter von 55 Jahren."},"ht":{"1365–1420":"1365–1420","1365–Male":"1365–Desede","–Male":"Desede","1432–1484":"1432–1484","1432":"1432","1365":"1365","1420":"1420","1484":"1484"},"hu":{"1365–1420":"1365–1420","1365–Male":"1365–elhunyt","–Male":"elhunyt","1432–1484":"1432–1484","1432":"1432","1365":"1365","1420":"1420","1484":"1484"},"id":{"1365–1420":"1365–1420","1365–Male":"1365–Telah Meninggal","–Male":"Telah