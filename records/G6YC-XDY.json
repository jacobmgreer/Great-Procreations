Stockport, Cheshire, England","Adlington, Cheshire, England":"Adlington, Cheshire, England","Adlington, Cheshire East & Cheshire,  North West, England":"Adlington, Cheshire, England, United Kingdom","Macclesfield, Cheshire, England":"Macclesfield, Cheshire, England"},"nl":{"1305–1325":"1305–1325","1305–1345":"1305–1345","1308–1375":"1308–1375","1306–1370":"1306–1370","1320–Male":"1320–Overleden","1323–1379":"1323–1379","1325–1382":"1325–1382","1355–1399":"1355–1399","1275–1327":"1275–1327","1230–1326":"1230–1326","1275":"1275","1230":"1230","1382":"1382","1370":"1370","1305":"1305","1327":"1327","1315":"1315","1326":"1326","1325":"1325","1379":"1379","1323":"1323","1345":"1345","1399":"1399","1355":"1355","about 1325":"circa 1325","1320":"1320","1375":"1375","1308":"1308","after 1323":"na 1323","1317":"1317","1306":"1306","Stockport, Cheshire, England":"Stockport, Cheshire, England","Adlington, Cheshire, England":"Adlington, Cheshire, England","Adlington, Cheshire East & Cheshire,  North West, England":"Adlington, Cheshire, Engeland, Verenigd Koninkrijk","Macclesfield, Cheshire, England":"Macclesfield, Cheshire, England"},"en":{"1305–1325":"1305–1325","1305–1345":"1305–1345","1308–1375":"1308–1375","1306–1370":"1306–1370","1320–Male":"1320–Deceased","1323–1379":"1323–1379","1325–1382":"1325–1382","1355–1399":"1355–1399","1275–1327":"1275–1327","1230–1326":"1230–1326","1275":"1275","1230":"1230","1382":"1382","1370":"1370","1305":"1305","1327":"1327","1315":"1315","1326":"1326","1325":"1325","1379":"1379","1323":"1323","1345":"1345","1399":"1399","1355":"1355","about 1325":"about 1325","1320":"1320","1375":"1375","1308":"1308","after 1323":"after 1323","1317":"1317","1306":"1306","Stockport, Cheshire, England":"Stockport, Cheshire, England","Adlington, Cheshire, England":"Adlington, Cheshire, England","Adlington, Cheshire East & Cheshire,  North West, England":"Adlington, Cheshire, England, United Kingdom","Macclesfield, Cheshire, England":"Macclesfield, Cheshire, England","nameMeanings":[{"name":"de","type":"LAST","attribution":"Dictionary of American Family Names © Patrick Hanks 2003, 2006.","meanings":["Some characteristic forenames:  Indian Dilip, Anirban, Gopal, Alok, Anindya, Arunava, Asit, Asok, Dibyendu, Goutam, Indra, Indranil.","Indian: variant of   Dey  ."],"variants":[{"name":"Dey","meanings":["Some characteristic forenames:  Indian Ashit, Indu, Naina, Partha, Soumya, Ajit, Anjan, Anjana, Anup, Arjun, Arun, Ashim.","English, Scottish, and Welsh: variant of   Day  .","German: topographic name from a field name in North Rhine-Westphalia, denoting a sizeable piece of land, from Middle Low German <i>dē</i> ‘thigh’ (referring to the shape of the property)."]}]},{"name":"Honeford","type":"LAST","attribution":"Dictionary of Family Names in Britain and Ireland © University of the West of England 2016","meanings":["English, N Irish: locative name; the lack of early bearers before the 17th century suggests that it may be a euphemistic variant of   Hungerford  . The  <i>Honeyfield</i> examples are also late and those for  <i>Honyfold</i> only slightly earlier, but these names are clearly related to Honeyford."],"variants":[{"name":"Hunniford","meanings":["Irish: variant of   Honeyford  ."]},{"name":"Honeyfield","meanings":["English: perhaps a variant or, as  <i>Honyfold</i>, a precursor of   Honeyford  ."]},{"name":"Hungerford","meanings":["English: habitational name from Hungerford (Berkshire), from Old English <i>hungor</i> ‘hunger’, here probably denoting unproductive land, + <i>ford</i>. This surname has been established in Ireland since the 17th century."]}]},{"name":"Sybil","type":"FIRST","attribution":"Dictionary of First Names © Patrick Hanks and Flavia Hodges 1990, 2003, 2006.","meanings":["From the name (Greek <i>Sibylla</i> or <i>Sybilla</i>, with confusion over the vowels from an early period) of a class of ancient prophetesses inspired by Apollo. According to medieval theology, they were pagans denied the knowledge of Christ but blessed by God with some insight into things to come and accordingly admitted to heaven. It was thus regarded as a respectable name to be borne by Christians. This name was introduced to England by the Normans and enjoyed considerable popularity in the Middle Ages."],"variants":[{"name":"Sybilla","meanings":["From the name (Greek <i>Sibylla</i> or <i>Sybilla</i>, with confusion over the vowels from an early period) of a class of ancient prophetesses inspired by Apollo. According to medieval theology, they were pagans denied the knowledge of Christ but blessed by God with some insight into things to come and accordingly admitted to heaven. It was thus regarded as a respectable name to be borne by Christians. This name was introduced to England by the Normans and enjoyed considerable popularity in the Middle Ages."]},{"name":"Sibilla","meanings":["From the name (Greek <i>Sibylla</i> or <i>Sybilla</i>, with confusion over the vowels from an early period) of a class of ancient prophetesses inspired by Apollo. According to medieval theology, they were pagans denied the knowledge of Christ but blessed by God with some insight into things to come and accordingly admitted to heaven. It was thus regarded as a respectable name to be borne by Christians. This name was introduced to England by the Normans and enjoyed considerable popularity in the Middle Ages."]},{"name":"Sybille","meanings":["From Greek.  See  <b>Sybil</b> ."]},{"name":"Sibella","meanings":["From the name (Greek <i>Sibylla</i> or <i>Sybilla</i>, with confusion over the vowels from an early period) of a class of ancient prophetesses inspired by Apollo. According to medieval theology, they were pagans denied the knowledge of Christ but blessed by God with some insight into things to come and accordingly admitted to heaven. It was thus regarded as a respectable name to be borne by Christians. This name was introduced to England by the Normans and enjoyed considerable popularity in the Middle Ages."]}]}],"historicEvents":[{"id":1705191,"age":10,"year":"1315","toYear":"1317","julianDay":2201354,"title":"Famine Strikes Europe","description":"A famine caused by cold winters and wet summers across Europe caused millions to die due to starvation. Desperation from hunger caused high levels of crime, stampedes in bread lines in London, infanticide, and even cannibalism throughout Europe.","jurisdictionLevel":2}],"lifeSummary":"When Sybil de Honeford was born in 1305, in Stockport, Cheshire, England, her father, Henry De Honford III, was 31 and her mother, Margery Marjorie de Waleton, was 75. She married Robert Legh in 1320, in Adlington, Cheshire, England, United Kingdom. They were the parents of at least 3 sons and 1 daughter. She died in 1325, in Macclesfield, Cheshire, England, at the age of 20."},"et":{"1305–1325":"1305–1325","1305–1345":"1305–1345","1308–1375":"1308–1375","1306–1370":"1306–1370","1320–Male":"1320–Surnud","1323–1379":"1323–1379","1325–1382":"1325–1382","1355–1399":"1355–1399","1275–1327":"1275–1327","1230–1326":"1230–1326","1275":"1275","1230":"1230","1382":"1382","1370":"1370","1305":"1305","1327":"1327","1315":"1315","1326":"1326","1325":"1325","1379":"1379","1323":"1323","1345":"1345","1399":"1399","1355":"1355","about 1325":"umbes 1325","1320":"1320","1375":"1375","1308":"1308","after 1323":"pärast 1323","1317":"1317","1306":"1306","Stockport, Cheshire, England":"Stockport, Cheshire, England","Adlington, Cheshire, England":"Adlington, Cheshire, England","Adlington, Cheshire East & Cheshire,  North West, England":"Adlington, Cheshire, Inglismaa, United Kingdom","Macclesfield, Cheshire, England":"Macclesfield, Cheshire, England"},"fi":{"1305–1325":"1305–1325","1305–1345":"1305–1345","1308–1375":"1308–1375","1306–1370":"1306–1370","1320–Male":"1320–Kuollut","1323–1379":"1323–1379","1325–1382":"1325–1382","1355–1399":"1355–1399","1275–1327":"1275–1327","1230–1326":"1230–1326","1275":"1275","1230":"1230","1382":"1382","1370":"1370","1305":"1305",