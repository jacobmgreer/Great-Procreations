circa 1132","1104–1132":"1104–1132","1120–1176":"1120–1176","1075–1146":"1075–1146","–Female":"Overleden","1104":"1104","1146":"1146","Abt 1132":"circa 1132","before 1100":"vóór 1100","1176":"1176","1132":"1132","1120":"1120","Abt 1104":"circa 1104","1075":"1075","Thrapston, Northamptonshire, England":"Thrapston, Northamptonshire, Engeland, Verenigd Koninkrijk","England":"England","Drayton, Leicestershire, England":"Drayton, Leicestershire, Engeland, Verenigd Koninkrijk"},"en":{"Abt 1104–Abt 1132":"about 1104–about 1132","1104–1132":"1104–1132","1120–1176":"1120–1176","1075–1146":"1075–1146","–Female":"Deceased","1104":"1104","1146":"1146","Abt 1132":"about 1132","before 1100":"before 1100","1176":"1176","1132":"1132","1120":"1120","Abt 1104":"about 1104","1075":"1075","Thrapston, Northamptonshire, England":"Thrapston, Northamptonshire, England, United Kingdom","England":"England","Drayton, Leicestershire, England":"Drayton, Leicestershire, England, United Kingdom","nameMeanings":[{"name":"Furnell","type":"LAST","attribution":"Dictionary of American Family Names © Patrick Hanks 2003, 2006.","meanings":["English:","variant of   Furneaux  .","alternatively, perhaps a variant of   Farnell  . Compare   Funnell  ."],"variants":[{"name":"Furneaux","meanings":["English (of Norman origin): habitational name from either of two places in Normandy called Fourneaux ‘(the) furnaces’, one in Manche, the other in Calvados. Compare   Furnace   and   Furnell  ."]}]},{"name":"Robert","type":"FIRST","attribution":"Dictionary of First Names © Patrick Hanks and Flavia Hodges 1990, 2003, 2006.","meanings":["One of the many French names of Germanic origin that were introduced into Britain by the Normans; it has since remained in continuous use. It is derived from the nearly synonymous elements <i>hrōd</i> ‘fame’ + <i>berht</i> ‘bright, famous’, and had a native Old English predecessor of similar form (<i>Hreodbeorht</i>), which was supplanted by the Norman name. Two dukes of Normandy in the 11th century bore the name: the father of  William the Conqueror  (sometimes identified with the legendary Robert the Devil), and his eldest son. It was borne also by three kings of Scotland, notably  Robert the Bruce  (  1274–1329 ), who freed Scotland from English domination. The altered short form <i>Bob</i> is very common, but <i>Hob</i> and <i>Dob</i>, which were common in the Middle Ages and gave rise to surnames, are extinct.  See also  Rupert ."],"variants":[]}],"lifeSummary":"Robert Furnell was born about 1104, in Drayton, Leicestershire, England, United Kingdom as the son of Robert De Furnell and Mrs Robert De Furnell. He had at least 1 daughter. He died about 1132, in Thrapston, Northamptonshire, England, United Kingdom, at the age of 30."},"et":{"Abt 1104–Abt 1132":"umbes 1104–umbes 1132","1104–1132":"1104–1132","1120–1176":"1120–1176","1075–1146":"1075–1146","–Female":"Surnud","1104":"1104","1146":"1146","Abt 1132":"umbes 1132","before 1100":"enne 1100","1176":"1176","1132":"1132","1120":"1120","Abt 1104":"umbes 1104","1075":"1075","Thrapston, Northamptonshire, England":"Thrapston, Northamptonshire, Inglismaa, United Kingdom","England":"England","Drayton, Leicestershire, England":"Drayton, Leicestershire, Inglismaa, United Kingdom"},"fi":{"Abt 1104–Abt 1132":"noin 1104–noin 1132","1104–1132":"1104–1132","1120–1176":"1120–1176","1075–1146":"1075–1146","–Female":"Kuollut","1104":"1104","1146":"1146","Abt 1132":"noin 1132","before 1100":"ennen vuotta 1100","1176":"1176","1132":"1132","1120":"1120","Abt 1104":"noin 1104","1075":"1075","Thrapston, Northamptonshire, England":"Thrapston, Northamptonshire, Englanti, Yhdistynyt kuningaskunta","England":"England","Drayton, Leicestershire, England":"Drayton, Leicestershire, Englanti, Yhdistynyt kuningaskunta"},"fr":{"Abt 1104–Abt 1132":"environ 1104–environ 1132","1104–1132":"1104–1132","1120–1176":"1120–1176","1075–1146":"1075–1146","–Female":"Décédée","1104":"1104","1146":"1146","Abt 1132":"environ 1132","bef