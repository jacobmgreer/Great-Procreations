arshborough, Kent, England","Mashbury, Essex, England":"Mashbury, Essex, England, United Kingdom","Essex, Bedfordshire, England":"Essex, England","nameMeanings":[{"name":"Bedall","type":"LAST","attribution":"Dictionary of Family Names in Britain and Ireland © University of the West of England 2016","meanings":["English:  see  Bedale  ."],"variants":[{"name":"Bedale","meanings":["English: locative name from Bedale (NR Yorks)."]}]},{"name":"Isabell","type":"FIRST","attribution":"Dictionary of First Names © Patrick Hanks and Flavia Hodges 1990, 2003, 2006.","meanings":["Originally a Spanish version of   Elizabeth  , which was coined by deletion of the first syllable and alteration of the final consonant sound to one that can normally end a word in Spanish. The name was imported into France in the early Middle Ages, and thence into England. It was a royal name, and its enduring popularity may have been enhanced by the fact that it was borne by a queen of England—  Isabella  (  1296–1358 ), daughter of  Philip IV  of France—even though she led a turbulent life and eventually had her husband,  Edward II , murdered."],"variants":[{"name":"Isabelle","meanings":["form of   Isabel  , now in frequent use in the English-speaking world."]},{"name":"Isobella","meanings":["form of   Isabel  , which has been popular in England since the 18th century and has recently become the preferred form of the name."]},{"name":"Isobelle","meanings":["Originally a Spanish version of   Elizabeth  , which was coined by deletion of the first syllable and alteration of the final consonant sound to one that can normally end a word in Spanish. The name was imported into France in the early Middle Ages, and thence into England. It was a royal name, and its enduring popularity may have been enhanced by the fact that it was borne by a queen of England—  Isabella  (  1296–1358 ), daughter of  Philip IV  of France—even though she led a turbulent life and eventually had her husband,  Edward II , murdered."]},{"name":"Isobel","meanings":["Variant spelling of   Isabel ."]}]}],"lifeSummary":"Isabell Bedall was born in 1410, in Mashbury, Essex, England, United Kingdom as the daughter of Richard Bedell. She married William Everard about 1430. They were the parents of at least 2 sons. She died in 1499, in Marshborough, Kent, England, United Kingdom, at the age of 89."},"et":{"1410–1499":"1410–1499","1402–1431":"1402–1431","1432–1465":"1432–1465","1432–1522":"1432–1522","1380–1440":"1380–1440","1402":"1402","1522":"1522","1499":"1499","1410":"1410","1432":"1432","1465":"1465","1431":"1431","1440":"1440","about 1465":"umbes 1465","about 1430":"umbes 1430","after 1431":"pärast 1431","1380":"1380","Marshborough, Kent, England, United Kingdom":"Marshborough, Kent, Inglismaa, United Kingdom","Mashbury, Essex, England, United Kingdom":"Mashbury, Essex, Inglismaa, United Kingdom","Marshborough, Kent, England":"Marshborough, Kent, England","Mashbury, Essex, England":"Mashbury, Essex, Inglismaa, United Kingdom","Essex, Bedfordshire, England":"Essex, England"},"fi":{"1410–1499":"1410–1499","1402–1431":"1402–1431","1432–1465":"1432–1465","1432–1522":"1432–1522","1380–1440":"1380–1440","1402":"1402","1522":"1522","1499":"1499","1410":"1410","1432":"1432","1465":"1465","1431":"1431","1440":"1440","about 1465":"noin 1465","about 1430":"noin 1430","after 1431":"1431 jälkeen","1380":"1380","Marshborough, Kent, England, United Kingdom":"Marshborough, Kent, Englanti, Yhdistynyt kuningaskunta","Mashbury, Essex, England, United Kingdom":"Mashbury, Essex, Englanti, Yhdistynyt kuningaskunta","Marshborough, Kent, England":"Marshborough, Kent, England","Mashbury, Essex, England":"Mashbury, Essex, Englanti, Yhdistynyt kuningaskunta","Essex, Bedfordshire, England":"Essex, England"},"fr":{"1410–1499":"1410–1499","1402–1431":"1402–1431","1432–1465":"1432–1465","1432–1522":"1432–1522","1380–1440":"1380–1440","1402":"1402","1522":"1522","1499":"1499","1410":"1410","1432":"1432","1465":"1465","1431":"143