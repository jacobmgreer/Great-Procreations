agmented."],"variants":[]}],"lifeSummary":"William FitzBagot of Bagot of Bromley was born in 1130, in Staffordshire, England, United Kingdom as the son of Hervey fitz Baggott and Avis de Clare. He had at least 4 sons and 1 daughter with Ivetta Bramshall. He died in 1181, in his hometown, at the age of 51."},"et":{"1130–1181":"1130–1181","1135–1182":"1135–1182","1166–1221":"1166–1221","1171–1193":"1171–1193","1177–1208":"1177–1208","1182–Male":"1182–Surnud","–Male":"Surnud","1086–1140":"1086–1140","–1214":"–1214","1130":"1130","1086":"1086","1140":"1140","1193":"1193","1171":"1171","1182":"1182","1181":"1181","1214":"1214","1135":"1135","1166":"1166","1177":"1177","1221":"1221","1208":"1208","ABT 1171":"umbes 1171","Bagot's Bromley, Staffordshire, England, United Kingdom":"Bagot's Bromley, Staffordshire, Inglismaa, United Kingdom","Staffordshire, England, United Kingdom":"Staffordshire, Inglismaa, United Kingdom","Bagot's Bromley, Staffordshire, England":"Bagot's Bromley, Staffordshire, England","Bramelle, Staffordshire, England, United Kingdom":"Staffordshire, Inglismaa, United Kingdom","Hyde, Kinfare, Staffordshire, England":"Kinver, Staffordshire, Inglismaa, United Kingdom","Bromley, Staffordshire, England, United Kingdom":"Bromley, Staffordshire, Inglismaa, United Kingdom"},"fi":{"1130–1181":"1130–1181","1135–1182":"1135–1182","1166–1221":"1166–1221","1171–1193":"1171–1193","1177–1208":"1177–1208","1182–Male":"1182–Kuollut","–Male":"Kuollut","1086–1140":"1086–1140","–1214":"–1214","1130":"1130","1086":"1086","1140":"1140","1193":"1193","1171":"1171","1182":"1182","1181":"1181","1214":"1214","1135":"1135","1166":"1166","1177":"1177","1221":"1221","1208":"1208","ABT 1171":"noin 1171","Bagot's Bromley, Staffordshire, England, United Kingdom":"Bagot's Bromley, Staffordshire, Englanti, Yhdistynyt kuningaskunta","Staffordshire, England, United Kingdom":"Staffordshire, Englanti, Yhdistynyt kuningaskunta","Bagot's Bromley, Staffordshire, England":"Bagot's Bromley, Staffo