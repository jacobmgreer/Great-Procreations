d","1274":"1274","abt. 1276":"omkring 1276","1290":"1290","1348":"1348","1259":"1259","1323":"1323","1268":"1268","1234":"1234","1278":"1278","1256":"1256","1255":"1255","1288":"1288","ABT 1278":"omkring 1278","1254":"1254","1276":"1276","1229":"1229","Paston, Norfolk, England":"Paston, Norfolk, England","of Paston, Norfolk, England":"Paston, Norfolk, England, United Kingdom"},"nl":{"1255–1290":"1255–1290","1256–Male":"1256–Overleden","1256–Female":"1256–Overleden","1268–1323":"1268–1323","1276–Male":"1276–Overleden","1278–Male":"1278–Overleden","1290–1348":"1290–1348","1229–Male":"1229–Overleden","1234–Female":"1234–Overleden","1274":"1274","abt. 1276":"circa 1276","1290":"1290","1348":"1348","1259":"1259","1323":"1323","1268":"1268","1234":"1234","1278":"1278","1256":"1256","1255":"1255","1288":"1288","ABT 1278":"circa 1278","1254":"1254","1276":"1276","1229":"1229","Paston, Norfolk, England":"Paston, Norfolk, England","of Paston, Norfolk, England":"Paston, Norfolk, Engeland, Verenigd Koninkrijk"},"en":{"1255–1290":"1255–1290","1256–Male":"1256–Deceased","1256–Female":"1256–Deceased","1268–1323":"1268–1323","1276–Male":"1276–Deceased","1278–Male":"1278–Deceased","1290–1348":"1290–1348","1229–Male":"1229–Deceased","1234–Female":"1234–Deceased","1274":"1274","abt. 1276":"about 1276","1290":"1290","1348":"1348","1259":"1259","1323":"1323","1268":"1268","1234":"1234","1278":"1278","1256":"1256","1255":"1255","1288":"1288","ABT 1278":"about 1278","1254":"1254","1276":"1276","1229":"1229","Paston, Norfolk, England":"Paston, Norfolk, England","of Paston, Norfolk, England":"Paston, Norfolk, England, United Kingdom","nameMeanings":[{"name":"de","type":"LAST","attribution":"Dictionary of American Family Names © Patrick Hanks 2003, 2006.","meanings":["Some characteristic forenames:  Indian Dilip, Anirban, Gopal, Alok, Anindya, Arunava, Asit, Asok, Dibyendu, Goutam, Indra, Indranil.","Indian: variant of   Dey  ."],"variants":[{"name":"Dey","meanings":["Some characteristic forenames:  Indian Ashit, Indu, Naina, Partha, Soumya, Ajit, Anjan, Anjana, Anup, Arjun, Arun, Ashim.","English, Scottish, and Welsh: variant of   Day  .","German: topographic name from a field name in North Rhine-Westphalia, denoting a sizeable piece of land, from Middle Low German <i>dē</i> ‘thigh’ (referring to the shape of the property)."]}]},{"name":"Paston","type":"LAST","attribution":"Dictionary of American Family Names © Patrick Hanks 2003, 2006.","meanings":["English (Norfolk): habitational name, chiefly from Paston in Norfolk, probably derived from an Old English personal name <i>Pæcci</i> (genitive <i>Pæcces</i>) or Old English <i>pæsc(e)</i> (the source of northern English dialect <i>pash</i> ‘puddle’) + <i>tūn</i> ‘farmstead, estate’.","English (West Midlands): sometimes a variant of <b>Patstone</b>, a habitational name chiefly from the lost <i>Padston(e)</i> in Bromsgrove (Worcestershire), and occasionally from Padson in Inwardleigh (Devon). The Worcestershire placename derives from the Old English personal name <i>Padda</i> (genitive <i>Paddes</i>) + <i>tūn</i> ‘farmstead, estate’. The etymology of the Devon placename is uncertain due to a lack of medieval forms, though an early spelling suggests the final element is Old English <i>dūn</i> ‘hill’."],"variants":[]},{"name":"Walter","type":"FIRST","attribution":"Dictionary of First Names © Patrick Hanks and Flavia Hodges 1990, 2003, 2006.","meanings":["From an Old French personal name of Germanic (Frankish) origin, derived from <i>wald</i> ‘rule’ + <i>heri</i>, <i>hari</i> ‘army’. This was adopted by the Normans and introduced by them to England, superseding the native Old English form, <i>Wealdhere</i>. It was a very popular name in medieval England, normally pronounced ‘Water’."],"variants":[{"name":"Walther","meanings":["from <i>wald</i> ‘rule’ + <i>heri</i> ‘army’; name of the famous medieval minnesinger  Walther von der Vogelweide  (  <i>c.</i>1170– <i>c.</i>1230 )."]}]}],"historicEvents":[{"id":17051