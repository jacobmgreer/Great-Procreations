land":"Leicestershire, England, United Kingdom","Coleorton, Leicestershire, England":"Coleorton, Leicestershire, England, United Kingdom","Liversedge, Lancashire, England":"Lancashire, England, United Kingdom","England":"England","Cole Orton, Leicestershire, England":"Coleorton, Leicestershire, England, United Kingdom","Lancashire, England":"Lancashire, England, United Kingdom"},"nl":{"1450–1540":"1450–1540","1458–1476":"1458–1476","1476–1536":"1476–1536","1424–1460":"1424–1460","1424–1515":"1424–1515","1536":"1536","1458":"1458","1457":"1457","1424":"1424","1455":"1455","1476":"1476","1540":"1540","1450":"1450","1460":"1460","1515":"1515","Leicestershire, England":"Leicestershire, Engeland, Verenigd Koninkrijk","Coleorton, Leicestershire, England":"Coleorton, Leicestershire, Engeland, Verenigd Koninkrijk","Liversedge, Lancashire, England":"Lancashire, Engeland, Verenigd Koninkrijk","England":"England","Cole Orton, Leicestershire, England":"Coleorton, Leicestershire, Engeland, Verenigd Koninkrijk","Lancashire, England":"Lancashire, Engeland, Verenigd Koninkrijk"},"en":{"1450–1540":"1450–1540","1458–1476":"1458–1476","1476–1536":"1476–1536","1424–1460":"1424–1460","1424–1515":"1424–1515","1536":"1536","1458":"1458","1457":"1457","1424":"1424","1455":"1455","1476":"1476","1540":"1540","1450":"1450","1460":"1460","1515":"1515","Leicestershire, England":"Leicestershire, England, United Kingdom","Coleorton, Leicestershire, England":"Coleorton, Leicestershire, England, United Kingdom","Liversedge, Lancashire, England":"Lancashire, England, United Kingdom","England":"England","Cole Orton, Leicestershire, England":"Coleorton, Leicestershire, England, United Kingdom","Lancashire, England":"Lancashire, England, United Kingdom","nameMeanings":[{"name":"Fenton","type":"LAST","attribution":"Dictionary of American Family Names © Patrick Hanks 2003, 2006.","meanings":["English: habitational name from any of various places, in Yorkshire, Lincolnshire, Northumberland, Staffordshire, and Nottinghamshire, so called from Old English <i>fenn</i> ‘marsh, fen’ + <i>tūn</i> ‘enclosure, settlement’.","Irish: English surname adopted by bearers of Gaelic <i>Ó Fionnachta</i> or <b>Ó Fiachna</b> ‘descendant of <i>Fiachna</i>’, an old personal name Anglicized as <b>Feighney</b> and sometimes mistranslated as   Hunt   (see   Fee   1 and   Finnerty  ).","Scottish: habitational name from Fenton in East Lothian."],"variants":[{"name":"Hunt","meanings":["English (southwestern): occupational name for a hunter, from Middle English <i>hunte</i> ‘hunter, huntsman’ (Old English <i>hunta</i>). The term was used not only of the hunting on horseback of game such as stags and wild boars, which in the Middle Ages was a pursuit restricted to the ranks of the nobility, but also to much humbler forms of pursuit such as bird catching and poaching for food. The word seems also to have been used as an Old English personal name and to have survived into the Middle Ages as an occasional personal name. Compare   Huntington   and   Huntley  .","Irish: adopted for various Irish surnames containing or thought to contain the Gaelic element <i>fiadhach</i> ‘hunt’; for example <b>Ó Fiaich</b> (see   Fee  ) and <b>Ó Fiachna</b> (see   Fenton  ).","Possibly an Americanized form of German   Hundt  ."]},{"name":"Fantom","meanings":["English: nickname from Middle English <i>fantom</i>, <i>fainton</i> ‘apparition, ghost’. There has been some confusion with   Fenton  ."]},{"name":"Finton","meanings":["English and Irish: variant of   Fenton  ."]},{"name":"Fenty","meanings":["Scottish: variant of   Fenton  ."]}]},{"name":"Ralph","type":"FIRST","attribution":"Dictionary of First Names © Patrick Hanks and Flavia Hodges 1990, 2003, 2006.","meanings":["From a Norman French name, <i>Raulf</i>, a contracted form of the Germanic personal name <i>Radulf</i>, derived from <i>rād</i> ‘counsel’ + <i>wulf</i> ‘wolf’. The spelling with <i>-ph</i> is due to classical influence in the 18th century."],"variants":[{"name":"Ralf","meanings":["From a Norman French name, <i>Raulf</i>, a contracted form of the Germanic personal name <i>Radulf</i>, derived from <i>rād</i> ‘counsel’ + <i>wulf</i> ‘wolf’. The spelling with <i>-ph</i> is due to classical influence in the 18th century."]}]}],"historicEvents":[{"id":1705197,"age":5,"year":"1455","julianDay":2252488,"title":"Wars of the Roses","description":"Wars of the Roses was a series of English civil wars for control of the throne of England between the royal families House of Lancaster and the House of York. The name of the war was derived as the red rose was the symbol of the Lancastrians and the white rose was the symbol of the Yorks.","url":"https://www.history.com/topics/british-history/wars-of-the-roses","urlTitle":"History - Wars of the Roses","jurisdictionLevel":0}],"lifeSummary":"When Ralph Fenton was born in 1450, in Coleorton, Leicestershire, England, his father, Sir Thomas Fenton, was 26 and his mother, Lady Eleanor Neville, was 26. He had at least 1 son with Dorothy De Staunton. He died in 1540, in England, at the age of 90."},"et":{"1450–1540":"1450–1540","1458–1476":"1458–1476","1476–1536":"1476–1536","1424–1460":"1424–1460","1424–1515":"1424–1515","1536":"1536","1458":"1458","1457":"1457","1424":"1424","1455":"1455","1476":"1476","1540":"1540","1450":"1450","1460":"1460","1515":"1515","Leicestershire, England":"Leicestershire, Inglismaa, United Kingdom","Coleorton, Leicestershire, England":"Coleorton, Leicestershire, Inglismaa, United Kingdom","Liversedge, Lancashire, England":"Lancashire, Inglismaa, United Kingdom","England":"England","Cole Orton, Leicestershire, England":"Coleorton, Leicestershire, Inglismaa, United Kingdom","Lancashire, England":"Lancashire, Inglismaa, United Kingdom"},"fi":{"1450–1540":"1450–1540","1458–1476":"1458–1476","1476–1536":"1476–1536","1424–1460":"1424–1460","1424–1515":"1424–1515","1536":"1536","1458":"1458","1457":"1457","1424":"1424","1455":"1455","1476":"1476","1540":"1540","14