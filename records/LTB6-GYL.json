320":"1246–1320","1280–1323":"1280–1323","1250–Female":"1250–Overleden","1291–Female":"1291–Overleden","1276–1340":"1276–1340","1279–1357":"1279–1357","1310–Male":"1310–Overleden","1225–1264":"1225–1264","1235–Female":"1235–Overleden","1264":"1264","1340":"1340","1250":"1250","1280":"1280","1291":"1291","1225":"1225","1357":"1357","1246":"1246","1235":"1235","1279":"1279","1323":"1323","Abt 1320":"circa 1320","1310":"1310","1276":"1276","1320":"1320","about 1279":"circa 1279","about 1310":"circa 1310","Dumfriesshire, Scotland":"Dumfriesshire, Schotland","Closeburn, Dumfriesshire, Scotland":"Closeburn, Dumfriesshire, Schotland","Scotland":"Schotland, Verenigd Koninkrijk"},"en":{"1246–Abt 1320":"1246–about 1320","1246–1320":"1246–1320","1280–1323":"1280–1323","1250–Female":"1250–Deceased","1291–Female":"1291–Deceased","1276–1340":"1276–1340","1279–1357":"1279–1357","1310–Male":"1310–Deceased","1225–1264":"1225–1264","1235–Female":"1235–Deceased","1264":"1264","1340":"1340","1250":"1250","1280":"1280","1291":"1291","1225":"1225","1357":"1357","1246":"1246","1235":"1235","1279":"1279","1323":"1323","Abt 1320":"about 1320","1310":"1310","1276":"1276","1320":"1320","about 1279":"about 1279","about 1310":"about 1310","Dumfriesshire, Scotland":"Dumfriesshire, Scotland","Closeburn, Dumfriesshire, Scotland":"Closeburn, Dumfriesshire, Scotland","Scotland":"Scotland, United Kingdom","nameMeanings":[{"name":"Kirkpatrick","type":"LAST","attribution":"Dictionary of American Family Names © Patrick Hanks 2003, 2006.","meanings":["Scottish: habitational name from either of two places in Dumfriess called Kirkpatrick or any of various other places in Scotland, all so named from the dedication of their church to Saint Patrick. The Scottish word <i>kirk</i> sometimes replaced Gaelic <i>cill</i> ‘church’ in placenames; compare   Kilpatrick  ."],"variants":[{"name":"Kilpatrick","meanings":["Irish (Ulster): shortened Anglicized form of Gaelic <b>Mac Giolla Phádraig</b> ‘son of the servant of (Saint) Patrick’ (Irish <i>Pádraig</i>). See also   Fitzpatrick  .","Scottish: habitational name from any of various places called in Gaelic as <i>cill Padraig</i> ‘church of (Saint) Patrick’. See also   Kirkpatrick  ."]}]},{"name":"Sir","type":"FIRST","attribution":"Dictionary of First Names © Patrick Hanks and Flavia Hodges 1990, 2003, 2006.","meanings":["equivalent of <b>George</b> ."],"variants":[{"name":"George","meanings":["Via Old French and Latin, from Greek <i>Georgios</i> (a derivative of <i>geōrgos</i> ‘farmer’, from <i>gē</i> ‘earth’ + <i>ergein</i> ‘to work’). This was the name of several early saints, including the shadowy figure who is now the patron of England (as well as of Germany and Portugal). If the saint existed at all, he was perhaps martyred in Palestine in the persecutions of Christians instigated by the  Emperor Diocletian  at the beginning of the 4th century. The popular legend in which the hero slays a dragon is a medieval Italian invention. He was for a long time a more important saint in the Orthodox Church than in the West, and the name was not much used in England during the Middle Ages, even after  St George  came to be regarded as the patron of England in the 14th century. Its use increased from the 1400s, and by  1500  it was regularly among the most popular male names. This popularity was reinforced when  George I  came to the throne in  1714 , bringing this name with him from Germany. It has been one of the most popular English boys' names ever since."]}]},{"name":"Stephen","type":"FIRST","attribution":"Dictionary of First Names © Patrick Hanks and Flavia Hodges 1990, 2003, 2006.","meanings":["Usual English spelling of the name of the first Christian martyr (Acts 6–7), whose feast is accordingly celebrated next after Christ's own (  26 December ). His name is derived from the Greek word <i>stephanos</i> ‘garland, crown’."],"variants":[{"name":"Stephan","meanings":["Variant of   Stephen  , preserving the vowels of the Greek name."]},{"name":"Steven","meanings":["Variant of   Stephen  , reflecting the normal pronunciation of the name in the English-speaking world."]}]}],"lifeSummary":"When Sir Stephen Kirkpatrick Lord of Closeburn was born in 1246, in Closeburn, Dumfriesshire, Scotland, his father, Sir Adam Kirkpatrick, was 22 and his mother, Kirkpatrick, was 12. He had at least 3 sons with Lady Isabella de Torthorwald. He died about 1320, in Scotland, United Kingdom, at the age of 75."},"et":{"1246–Abt 1320":"1246–umbes 1320","1246–1320":"1246–1320","1280–1323":"1280–1323","1250–Female":"1250–Surnud","1291–Female":"1291–Surnud","1276–1340":"1276–1340","1279–1357":"1279–1357","1310–Male":"1310–Surnud","1225–1264":"1225–1264","1235–Female":"1235–Surnud","1264":"1264","1340":"1340","1250":"1250","1280":"1280","1291":"1291","1225":"1225","1357":"1357","1246":"1246","1235":"1235","1279":"1279","1323":"1323","Abt 1320":"umbes 1320","1310":"1310","1276":"1276","1320":"1320","about 1279":"umbes 1279","about 1310":"umbes 1310","Dumfriesshire, Scotland":"Dumfriesshire, Scotland","Closeburn, Dumfriesshire, Scotland":"Closeburn, Dumfriesshire, Scotland","Scotland":"Šotimaa, United Kingdom"},"fi":{"1246–Abt 1320":"1246–noin 1320","1246–1320":"1246–1320","1280–1323":"1280–1323","1250–Female":"1250–Kuollut","1291–Female":"1291–Kuollut","1276–1340":"1276–1340","1279–1357":"1279–1357","1310–Male":"1310–Kuollut","1225–1264":"1225–1264","1235–Female":"1235–Kuollut","1264":"1264","1340":"1340","1250":"1250","1280":"1280","1291":"1291","1225":"1225","1357":"1357","1246":"1246","1235":"1235","1279":"1279","1323":"1323","Abt 1320":"noin 1320","1310":"1310","1276":"1276","1320":"1320","about 1279":"noin 1279","about 1310":"noin 1310","Dumfriesshire, Scotland":"Dumfriesshire, Scotland","Closeburn, Dumfriesshire, Scotland":"Closeburn, Dumfriesshire, Scotland","Scotland":"Skotlanti, Yhdistynyt kuningaskunta"},"fr":{"1246–Abt 1320":"1246–environ 1320","1246–1320":"1246–1320","1280–1323":"1280–1323","1250–Female":"125