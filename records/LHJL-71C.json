228–1295":"1228–1295","1232–1297":"1232–1297","1264":"1264","1297":"1297","1274":"1274","1296":"1296","1295":"1295","1261":"1261","1270":"1270","1290":"1290","1228":"1228","1315":"1315","1359":"1359","1335":"1335","1368":"1368","1258":"1258","1268":"1268","1289":"1289","1300":"1300","1255":"1255","1254":"1254","1232":"1232","before 23 September 1295":"vóór 23 september 1295","1328":"1328","1317":"1317","1306":"1306","Pickhill, Yorkshire, England":"Pickhill, Yorkshire, Engeland, Verenigd Koninkrijk","Rolleston, Nottinghamshire, England":"Rolleston, Nottinghamshire, Engeland, Verenigd Koninkrijk"},"en":{"1264–1335":"1264–1335","1255–1296":"1255–1296","1258–Female":"1258–Deceased","1261–Female":"1261–Deceased","1268–1306":"1268–1306","1270–Male":"1270–Deceased","1274–1359":"1274–1359","1300–1368":"1300–1368","1228–1295":"1228–1295","1232–1297":"1232–1297","1264":"1264","1297":"1297","1274":"1274","1296":"1296","1295":"1295","1261":"1261","1270":"1270","1290":"1290","1228":"1228","1315":"1315","1359":"1359","1335":"1335","1368":"1368","1258":"1258","1268":"1268","1289":"1289","1300":"1300","1255":"1255","1254":"1254","1232":"1232","before 23 September 1295":"before 23 September 1295","1328":"1328","1317":"1317","1306":"1306","Pickhill, Yorkshire, England":"Pickhill, Yorkshire, England, United Kingdom","Rolleston, Nottinghamshire, England":"Rolleston, Nottinghamshire, England, United Kingdom","nameMeanings":[{"name":"DE","type":"LAST","attribution":"Dictionary of American Family Names © Patrick Hanks 2003, 2006.","meanings":["Some characteristic forenames:  Indian Dilip, Anirban, Gopal, Alok, Anindya, Arunava, Asit, Asok, Dibyendu, Goutam, Indra, Indranil.","Indian: variant of   Dey  ."],"variants":[{"name":"Dey","meanings":["Some characteristic forenames:  Indian Ashit, Indu, Naina, Partha, Soumya, Ajit, Anjan, Anjana, Anup, Arjun, Arun, Ashim.","English, Scottish, and Welsh: variant of   Day  .","German: topographic name from a field name in North Rhine-Westphalia, denoting a sizeable piece of land, from Middle Low German <i>dē</i> ‘thigh’ (referring to the shape of the property)."]}]},{"name":"NEVILLE","type":"LAST","attribution":"Dictionary of American Family Names © Patrick Hanks 2003, 2006.","meanings":["English and Irish (of Norman origin): habitational name from Neuville in Calvados or Néville in Seine-Maritime, both so called from Old French <i>neu(f)</i> ‘new’ (from Latin <i>novus</i>) + <i>ville</i> ‘settlement’. One family line, originally from Neuville (Calvados), became powerful during the Wars of the Roses through Richard <i>Neville</i> (1428–71), 16th Earl of Warwick, nicknamed \"The Kingmaker\".","Irish (Munster): assimilation of the Gaelic name <b>Ó Niadh</b> (see   Nee  ) and sometimes of <b>Ó Cnaimhín</b> (see   Nevin  ).","History: George Neville came to VA in or <i>c.</i> 1700 and settled on the headwaters of the Occoquan River, acquiring a large estate. His descendants, bearing the surnames Neville and Craig, were of considerable importance in Pittsburgh, PA, and Cincinnati, OH."],"variants":[{"name":"Nevells","meanings":["Irish: variant of   Neville  ."]},{"name":"Nevils","meanings":["English: variant of   Neville  ."]},{"name":"Novel","meanings":["English: variant of   Neville  .","Catalan: variant of   Novell  ."]},{"name":"Newell","meanings":["English (of Norman origin): variant of   Neville  .","English: variant of   Noel  .","English: variant of   Newhall  ."]},{"name":"Nevills","meanings":["English (of Norman origin): variant of   Neville  , with post-medieval excrescent <i>-s</i>. This surname is now rare in Britain."]},{"name":"Nevil","meanings":["English (of Norman origin): variant of   Neville  ."]},{"name":"Newill","meanings":["English and Irish (or Norman origin): variant of   Neville  ."]},{"name":"Nevill","meanings":["English and Irish: of Norman origin, a variant of   Neville  ."]},{"name":"Nevels","meanings":["English and Scottish (Wigtownshire): of Norman origin, a variant of   Neville  , with post-medieval excrescent <i>-s</i>. This surname is now rare in Britain.","Dutch and North German: unexplained."]},{"name":"Nee","meanings":["Some characteristic forenames:  Irish Dermot, John Patrick.","Irish (Galway): shortened Anglicized form of Gaelic <b>Ó Niadh</b> ‘descendant of <i>Nia</i>’ or <b>Mac Niadh</b> ‘son of <i>Nia</i>’. Compare   McNee  .   Needham   2 and   Neville   have also been adopted as Anglicized forms of this name.","North German: possibly a relationship name from Middle Low German <i>neve</i> ‘nephew, grand-child’."]}]},{"name":"Jollan","type":"LAST","attribution":"Dictionary of American Family Names © Patrick Hanks 2003, 2006.","meanings":["Germanized or Americanized form of Polish, Czech, and Sorbian   Polan  .","English: unexplained."],"variants":[{"name":"Polan","meanings":["Transferred use of the Irish surname, Gaelic <i>Ó Nualláin</i> ‘descendant of <i>Nuallán</i>’. The latter is an ancient Gaelic personal name, originally a byname representing a diminutive of <i>nuall</i> ‘chariot-fighter, champion’."]}]}],"historicEvents":[{"id":1705190,"age":26,"year":"1290","julianDay":2192224,"title":"Jews Expelled From England","description":"After years of anti-Semitic behavior, King Edward I expelled Jews from England in 1290.","jurisdictionLevel":2},{"id":1705191,"age":51,"year":"1315","toYear":"1317","julianDay":2201354,"title":"Famine Strikes Europe","description":"A famine caused by cold winters and wet summers across Europe caused millions to die due to starvation. Desperation from hunger caused high levels of crime, stampedes in bread lines in London, infanticide, and even cannibalism throughout Europe.","jurisdictionLevel":2},{"id":1705192,"age":64,"year":"1328","julianDay":2206102,"title":"First War of Scottish Independence","description":"The First War of Scottish Independence began after England invaded Scotland in 1296. The Treaty of Edinburgh was signed in 1328 which declared peace between the two kingdoms and brought the war t