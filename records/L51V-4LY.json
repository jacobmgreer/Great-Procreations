n":{"1333–":"1333–Deceased","1333–Female":"1333–Deceased","1329–Male":"1329–Deceased","1346–Male":"1346–Deceased","1313–Male":"1313–Deceased","1337":"1337","1313":"1313","1346":"1346","1333":"1333","1355":"1355","1453":"1453","ABT 1346":"about 1346","1382":"1382","1329":"1329","Hursley, Hampshire, England":"Hursley, Hampshire, England","Thinghill, Herefordshire, England":"Herefordshire, England, United Kingdom","Herefordshire, England":"Herefordshire, England, United Kingdom","nameMeanings":[{"name":"Hursley","type":"LAST","attribution":"Dictionary of American Family Names © Patrick Hanks 2003, 2006.","meanings":["English (Sussex and Devon): habitational name from Pursley Farm in Shenley, Hertfordshire.","Probably an altered form of German <b>Bürschle</b>, a diminutive of   Bursch  ."],"variants":[{"name":"Bursch","meanings":["German: nickname meaning ‘young man’, from Middle High German <i>burse</i>, originally denoting a student fraternity at a medieval university (from Late Latin <i>bursa</i> ‘purse’, i.e. a cash fund from which the students supported themselves), and later also other male societies, such as soldiers’ or craftsmen's guilds. Eventually the term <i>Bursch(e)</i> came to denote an individual member rather than the institution, and was pluralized as <i>Burschen</i>."]}]},{"name":"Sybil","type":"FIRST","attribution":"Dictionary of First Names © Patrick Hanks and Flavia Hodges 1990, 2003, 2006.","meanings":["From the name (Greek <i>Sibylla</i> or <i>Sybilla</i>, with confusion over the vowels from an early period) of a class of ancient prophetesses inspired by Apollo. According to medieval theology, they were pagans denied the knowledge of Christ but blessed by God with some insight into things to come and accordingly admitted to heaven. It was thus regarded as a respectable name to be borne by Christians. This name was introduced to England by the Normans and enjoyed considerable popularity in the Middle Ages."],"variants":[{"name":"Sybilla","meanings":["From the name (Greek <i>Sibylla</i> or <i>Sybilla</i>, with confusion over the vowels from an early period) of a class of ancient prophetesses inspired by Apollo. According to medieval theology, they were pagans denied the knowledge of Christ but blessed by God with some insight into things to come and accordingly admitted to heaven. It was thus regarded as a respectable name to be borne by Christians. This name was introduced to England by the Normans and enjoyed considerable popularity in the Middle Ages."]},{"name":"Sibilla","meanings":["From the name (Greek <i>Sibylla</i> or <i>Sybilla</i>, with confusion over the vowels from an early period) of a class of ancient prophetesses inspired by Apollo. According to medieval theology, they were pagans denied the knowledge of Christ but blessed by God with some insight into things to come and accordingly admitted to heaven. It was thus regarded as a respectable name to be borne by Christians. This name was introduced to England by the Normans and enjoyed considerable popularity in the Middle Ages."]},{"name":"Sybille","meanings":["From Greek.  See  <b>Sybil</b> ."]},{"name":"Sibella","meanings":["From the name (Greek <i>Sibylla</i> or <i>Sybilla</i>, with confusion over the vowels from an early period) of a class of ancient prophetesses inspired by Apollo. According to medieval theology, they were pagans denied the knowledge of Christ but blessed by God with some insight into things to come and accordingly admitted to heaven. It was thus regarded as a respectable name to be borne by Christians. This name was introduced to England by the Normans and enjoyed considerable popularity in the Middle Ages."]}]}],"historicEvents":[{"id":1705193,"age":4,"year":"1337","toYear":"1453","julianDay":2209390,"title":"The Hundred Years' War","description":"The Hundred Years' War between France and England was largely due to the question of legitimate succession to the French crown.","jurisdictionLevel":2},{"id":1705195,"age":49,"ye