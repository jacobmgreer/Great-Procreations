1135–1190","1155–1228":"1155–1228","1137–1174":"1137–1174","1228":"1228","1190":"1190","1137":"1137","1135":"1135","1155":"1155","about 1137":"omkring 1137","1174":"1174","about 1155":"omkring 1155","about 1174":"omkring 1174","Waltham, Essex, England":"Waltham, Essex, England","Lincoln, Lincolnshire, England":"Lincoln, Lincolnshire, England"},"nl":{"about 1137–about 1174":"circa 1137–circa 1174","1135–1190":"1135–1190","1155–1228":"1155–1228","1137–1174":"1137–1174","1228":"1228","1190":"1190","1137":"1137","1135":"1135","1155":"1155","about 1137":"circa 1137","1174":"1174","about 1155":"circa 1155","about 1174":"circa 1174","Waltham, Essex, England":"Waltham, Essex, England","Lincoln, Lincolnshire, England":"Lincoln, Lincolnshire, England"},"en":{"about 1137–about 1174":"about 1137–about 1174","1135–1190":"1135–1190","1155–1228":"1155–1228","1137–1174":"1137–1174","1228":"1228","1190":"1190","1137":"1137","1135":"1135","1155":"1155","about 1137":"about 1137","1174":"1174","about 1155":"about 1155","about 1174":"about 1174","Waltham, Essex, England":"Waltham, Essex, England","Lincoln, Lincolnshire, England":"Lincoln, Lincolnshire, England","nameMeanings":[{"name":"of","type":"LAST","attribution":"Dictionary of American Family Names © Patrick Hanks 2003, 2006.","meanings":["Some characteristic forenames:  Korean Kyong, Kyong Suk, Young, Chae, Chi Young, Hang, Kil, Rin, Sang Hun, Chang, Chong, Insoo, Kum, Sun Young, Yom, Young Hwan.  Cambodian Kiwan, Oeurn, Phoeun, Pich, Saroeuth, Seung, Sophath, Sophea, Yoeun, Phan, Son.  Indian Shanti, Harendra.","Indian (Uttar Pradesh): Brahmin name, from Sanskrit <i>om</i>, the Hindu sacred and mystic syllable uttered at the beginning of prayers.","Cambodian: written ឱម, corresponding to the exclamation of solemn affirmation, of Sanskrit origin (see 1 above), chanted by Buddhist monks."],"variants":[{"name":"Oum","meanings":["Some characteristic forenames:  Southeast Asian Heang, Hye, Kam, Kan, Kheng, Khin, Kun, Sang, Sok, Phong, Yom, Yoo, Youn, Cuong, Phal, Samnang, Tin.  Cambodian Sokha, Chheang, Choeun, Moeun, Roeun, Sambath, Samoeun, Savuth, Soeun, Sopheap.","Cambodian: written អ៊ុំ, from a Khmer word denoting an elder sibling of one's parent (i.e. ‘uncle’ or ‘aunt’). Compare   Om   3 and   Um   2."]}]},{"name":"Essex","type":"LAST","attribution":"Dictionary of American Family Names © Patrick Hanks 2003, 2006.","meanings":["English: habitational name from the county of Essex, whose name is from Old English <i>ēast</i> ‘east’ + <i>Seaxe</i> ‘Saxons’. In England, the surname is now particularly common in Birmingham."],"variants":[]},{"name":"Alice","type":"FIRST","attribution":"Dictionary of First Names © Patrick Hanks and Flavia Hodges 1990, 2003, 2006.","meanings":["Originally a variant of   Adelaide  , representing an Old French spelling of a reduced form of Germanic <i>Adalheidis</i>. <i>Alice</i> and <i>Adelaide</i> were already regarded as distinct names in English during the medieval period. <i>Alice</i> enjoyed a surge of popularity in the 19th century and periods of favour ever since. It was the name of the central character of  Lewis Carroll's  Alice's Adventures in Wonderland (  1865 ) and Through the Looking Glass (  1872 ), who was based on his child friend  Alice Liddell , daughter of the Dean of Christ Church, Oxford."],"variants":[{"name":"Alys","meanings":["Variant spelling of   Alice ."]},{"name":"Alis","meanings":["equivalent of <b>Alice</b> ."]}]}],"lifeSummary":"Alice of Essex was born about 1137, in Waltham, Essex, England. She had at least 1 daughter with John FitzRichard de Lacy. She died about 1174, in her hometown, at the age of 39."},"et":{"about 1137–about 1174":"umbes 1137–umbes 1174","1135–1190":"1135–1190","1155–1228":"1155–1228","1137–1174":"1137–1174","1228":"1228","1190":"1190","1137":"1137","1135":"1135","1155":"1155","about 1137":"umbes 1137","1174":"1174","about 1155":"umbes 1155","about 1174":"umbes 1174","Waltham, Essex, England":"Waltham, Essex, Eng