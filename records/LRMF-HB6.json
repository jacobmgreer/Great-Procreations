att."]}]}],"historicEvents":[{"id":1705184,"age":6,"year":"1096","julianDay":2121366,"title":"The Crusades","description":"A series of religious wars between Christians and Muslims, known as the Crusades, occurred between 1096 and 1291, and played a large role in European Christian dominance in the Middle East.","url":"https://www.history.com/topics/middle-ages/crusades","urlTitle":"History - The Crusades","jurisdictionLevel":2},{"id":1705185,"age":16,"year":"1106","julianDay":2125018,"title":"The Battle of Tichebray","description":"King Henry I defeated and captured his brother, Robert of Normandy, at the Battle of Tinchebray in 1106. Robert remained in captivity until his death in 1134.","jurisdictionLevel":2}],"lifeSummary":"Waleran FitzWilliam was born about 1090, in West Dean, Gloucestershire, England. He married Sophie de Lorraine about 1108. They were the parents of at least 1 son. In 1129, his occupation is listed as office: accounts for the new forest. He died about 1130, in West Dean, Wiltshire, England, at the age of 42."},"et":{"about 1090–about 1130":"umbes 1090–umbes 1130","1094–Female":"1094–Surnud","1110–1159":"1110–1159","1090–1130":"1090–1130","1106":"1106","1090":"1090","1159":"1159","about 1090":"umbes 1090","1110":"1110","1130":"1130","1096":"1096","about 1110":"umbes 1110","1129-1130":"1129 kuni 1130","1094":"1094","Abt 1108":"umbes 1108","about 1130":"umbes 1130","West Dean, Gloucestershire, England, United Kingdom":"West Dean, Gloucestershire, Inglismaa, United Kingdom","West Dean, Wiltshire, England":"West Dean, Wiltshire, England","West Dean, Gloucestershire, England":"West Dean, Gloucestershire, England"},"fi":{"about 1090–about 1130":"noin 1090–noin 1130","1094–Female":"1094–Kuollut","1110–1159":"1110–1159","1090–1130":"1090–1130","1106":"1106","1090":"1090","1159":"1159","about 1090":"noin 1090","1110":"1110","1130":"1130","1096":"1096","about 1110":"noin 1110","1129-1130":"vuodesta 1129 vuoteen 1130","1094":"1094","Abt 1108":"noin 1108"