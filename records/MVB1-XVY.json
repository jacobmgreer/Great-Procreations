ased","before 1440":"before 1440","ABT 1411":"about 1411","1440":"1440","1383":"1383","ABT 1407":"about 1407","1379":"1379","1411":"1411","1475":"1475","abt 1409":"about 1409","1409":"1409","1429":"1429","1407":"1407","1405":"1405","of Chetnoll, Dorset, Eng.":"Dorset, England, United Kingdom","of,Chetnoll,Dorset,England":"Dorset, England, United Kingdom","England":"England, United Kingdom","Dorset, England":"Dorset, England","nameMeanings":[{"name":"Lydiate","type":"LAST","attribution":"Dictionary of Family Names in Britain and Ireland © University of the West of England 2016","meanings":["1  English: locative name, chiefly from Lydiate (Lancs), sometimes perhaps from Lidgate (Suffolk).","2  English: locative name for someone who lived by a swing-gate for cattle, Middle English  <i>lidgate</i>,  <i>lidiate</i>, Old English  <i>hlidgeat</i>."],"variants":[{"name":"Lidgett","meanings":["English:  see  Lydiate  ."]},{"name":"Ludgate","meanings":["English: habitational name from Ludgate in London, so named from Old English <i>ludgeat</i> ‘back gate, postern’, or from Ludgate in Kent. Perhaps sometimes a variant of   Liggett  , ultimately from Old English <i>hlid-geat</i> ‘swing-gate’, which is also the probable source of the Kent placename."]},{"name":"Lidgate","meanings":["English:  see  Lydiate  ."]},{"name":"Liggatt","meanings":["English:  see  Lydiate  ."]},{"name":"Lyddiatt","meanings":["English:  see  Lydiate  ."]},{"name":"Liggat","meanings":["English, Scottish:  see  Lydiate  ."]},{"name":"Lydiatt","meanings":["English:  see  Lydiate  ."]},{"name":"Liggett","meanings":["English (now found mainly in northern Ireland): habitational name predominantly from Lydiate in Lancashire, or sometimes from Lidgate in Suffolk. The name derives from Middle English <i>lidyate</i> ‘gate in a fence between plowed land and meadow’ (Old English <i>hlid-geat</i> ‘swing-gate’)."]},{"name":"Liddiatt","meanings":["English:  see  Lydiate  ."]}]},{"name":"Alice","type":"FIRST","attribution":"Dictionary of First Names © Patrick Hanks and Flavia Hodges 1990, 2003, 2006.","meanings":["Originally a variant of   Adelaide  , representing an Old French spelling of a reduced form of Germanic <i>Adalheidis</i>. <i>Alice</i> and <i>Adelaide</i> were already regarded as distinct names in English during the medieval period. <i>Alice</i> enjoyed a surge of popularity in the 19th century and periods of favour ever since. It was the name of the central character of  Lewis Carroll's  Alice's Adventures in Wonderland (  1865 ) and Through the Looking Glass (  1872 ), who was based on his child friend  Alice Liddell , daughter of the Dean of Christ Church, Oxford."],"variants":[{"name":"Alys","meanings":["Variant spelling of   Alice ."]},{"name":"Alis","meanings":["equivalent of <b>Alice</b> ."]}]}],"lifeSummary":"Alice Lydiate was born in 1383, in Dorset, England, United Kingdom as the daughter of Samuel Lydiate. She had at least 2 sons and 2 daughters with Thomas Winterhay. She died before 1440, in England, United Kingdom."},"et":{"1383–before 1440":"1383–enne 1440","1383–1440":"1383–1440","1379–1429":"1379–1429","–Male":"Surnud","1405–1475":"1405–1475","1407–Male":"1407–Surnud","1409–Female":"1409–Surnud","1411–Female":"1411–Surnud","before 1440":"enne 1440","ABT 1411":"umbes 1411","1440":"1440","1383":"1383","ABT 1407":"umbes 1407","1379":"1379","1411":"1411","1475":"1475","abt 1409":"umbes 1409","1409":"1409","1429":"1429","1407":"1407","1405":"1405","of Chetnoll, Dorset, Eng.":"Dorset, Inglismaa, United Kingdom","of,Chetnoll,Dorset,England":"Dorset, Inglismaa, United Kingdom","England":"Inglismaa, United Kingdom","Dorset, England":"Dorset, England"},"fi":{"1383–before 1440":"1383–ennen vuotta 1440","1383–1440":"1383–1440","1379–1429":"1379–1429","–Male":"Kuollut","1405–1475":"1405–1475","1407–Male":"1407–Kuollut","1409–Female":"1409–Kuollut","1411–Female":"1411–Kuollut","before 1440":"ennen vuotta 1440","ABT 1411":"noin 1411","1440":"1440","1383":"1383","ABT 1