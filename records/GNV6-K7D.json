ord, Lancashire, England":"Rufford, Lancashire, Inglaterra, United Kingdom","England":"Inglaterra","Cornwall, England":"Cornwall, Inglaterra, United Kingdom","Ribbesford, Worcestershire, England":"Ribbesford, Worcestershire, Inglaterra","lifeSummary":"Quando Amy Haworth nasceu em 1485, em Binnerton, Cornwall, Inglaterra, seu pai, Christopher Haworth, tinha 17 anos e sua mãe, Lady Helen Hesketh, tinha 18 anos. Ela casou-se com William Beauchamp em 1520, em Cornwall, Inglaterra, United Kingdom. Eles tiveram pelo menos 2 filhas. Ela viveu em Drayton, Worcestershire, Inglaterra em 1523. Ela faleceu em 1526, em Ribbesford, Worcestershire, Inglaterra, com 41 anos."},"ro":{"1485–1526":"1485–1526","1480–1514":"1480–1514","1501–1523":"1501–1523","–Female":"Decedată","1485–1569":"1485–1569","1504–Female":"1504–Decedată","1526–1587":"1526–1587","1468–1496":"1468–1496","1467–Female":"1467–Decedată","1480":"1480","1569":"1569","1514":"1514","1523":"1523","1468":"1468","1501":"1501","1467":"1467","1587":"1587","1520":"1520","1485":"1485","1496":"1496","about 1495":"aproximativ 1495","1 Jan 1504":"1 ianuarie 1504","1526":"1526","1504":"1504","Binnerton, Cornwall, England":"Binnerton, Cornwall, England","Drayton, Worcestershire, England":"Drayton, Worcestershire, England","Rufford, Lancashire, England":"Rufford, Lancashire, Anglia, United Kingdom","England":"England","Cornwall, England":"Cornwall, Anglia, United Kingdom","Ribbesford, Worcestershire, England":"Ribbesford, Worcestershire, England"},"ru":{"1485–1526":"1485г.–1526г.","1480–1514":"1480г.–1514г.","1501–1523":"1501г.–1523г.","–Female":"Умершая","1485–1569":"1485г.–1569г.","1504–Female":"1504г.–Умершая","1526–1587":"1526г.–1587г.","1468–1496":"1468г.–1496г.","1467–Female":"1467г.–Умершая","1480":"1480 г.","1569":"1569 г.","1514":"1514 г.","1523":"1523 г.","1468":"1468 г.","1501":"1501 г.","1467":"1467 г.","1587":"1587 г.","1520":"1520 г.","1485":"1485 г.","1496":"1496 г.","about 1495":"около 1495 г.","1 Jan 1504":"1 января