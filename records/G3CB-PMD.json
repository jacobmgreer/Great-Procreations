mented."],"variants":[]}],"lifeSummary":"Sir William Annesly Knight was born in 1415, in Kent, England, United Kingdom. He had at least 1 daughter with Elizabeth Sutton. He died in Celbridge, County Kildare, Ireland."},"et":{"1415–":"1415–Surnud","1415–Female":"1415–Surnud","1435–1500":"1435–1500","1415–Male":"1415–Surnud","1415":"1415","1435":"1435","1500":"1500","Hertfordshire, England, United Kingdom":"Hertfordshire, Inglismaa, United Kingdom","Kent, England, United Kingdom":"Kent, Inglismaa, United Kingdom","Celbridge, County Kildare, Ireland":"Celbridge, County Kildare, Iirimaa"},"fi":{"1415–":"1415–Kuollut","1415–Female":"1415–Kuollut","1435–1500":"1435–1500","1415–Male":"1415–Kuollut","1415":"1415","1435":"1435","1500":"1500","Hertfordshire, England, United Kingdom":"Hertfordshire, Englanti, Yhdistynyt kuningaskunta","Kent, England, United Kingdom":"Kent, Englanti, Yhdistynyt kuningaskunta","Celbridge, County Kildare, Ireland":"Celbridge, County Kildare, Irlanti"},"fr":{"1415–":"1415–Décédé","1415–Female":"1415–Décédée","1435–1500":"1435–1500","1415–Male":"1415–Décédé","1415":"1415","1435":"1435","1500":"1500","Hertfordshire, England, United Kingdom":"Hertfordshire, Angleterre, Royaume-Uni","Kent, England, United Kingdom":"Kent, Angleterre, Royaume-Uni","Celbridge, County Kildare, Ireland":"Celbridge, County Kildare, Irlande","lifeSummary":"Sir William Annesly Knight est né en 1415, à Kent, Angleterre, Royaume-Uni. Il a eu au moins 1 fille avec Elizabeth Sutton. Il est décédé à Celbridge, County Kildare, Irlande."},"de":{"1415–":"1415–Verstorben","1415–Female":"1415–Verstorben","1435–1500":"1435–1500","1415–Male":"1415–Verstorben","1415":"1415","1435":"1435","1500":"1500","Hertfordshire, England, United Kingdom":"Hertfordshire, England, United Kingdom","Kent, England, United Kingdom":"Kent, England, United Kingdom","Celbridge, County Kildare, Ireland":"Celbridge, County Kildare, Irland","lifeSummary":"Sir William Annesly Knight wurde 1415 in Kent, England, Un