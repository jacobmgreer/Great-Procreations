0–1498","1465–1528":"1465–1528","1410–1454":"1410–1454","1415–1457":"1415–1457","1440":"1440","1450":"1450","abt 1465":"omkring 1465","1415":"1415","1457":"1457","1435":"1435","1455":"1455","1498":"1498","1454":"1454","1410":"1410","1465":"1465","about 1435":"omkring 1435","1452":"1452","about 1434":"omkring 1434","1506":"1506","1528":"1528","after 1454":"efter 1454","Petworth, Sussex, England":"Petworth, Sussex, England","Sussex, England":"Sussex, England"},"nl":{"about 1435–1506":"circa 1435–1506","1435–1506":"1435–1506","1450–1506":"1450–1506","1452–Male":"1452–Overleden","1440–1498":"1440–1498","1465–1528":"1465–1528","1410–1454":"1410–1454","1415–1457":"1415–1457","1440":"1440","1450":"1450","abt 1465":"circa 1465","1415":"1415","1457":"1457","1435":"1435","1455":"1455","1498":"1498","1454":"1454","1410":"1410","1465":"1465","about 1435":"circa 1435","1452":"1452","about 1434":"circa 1434","1506":"1506","1528":"1528","after 1454":"na 1454","Petworth, Sussex, England":"Petworth, Sussex, England","Sussex, England":"Sussex, England"},"en":{"about 1435–1506":"about 1435–1506","1435–1506":"1435–1506","1450–1506":"1450–1506","1452–Male":"1452–Deceased","1440–1498":"1440–1498","1465–1528":"1465–1528","1410–1454":"1410–1454","1415–1457":"1415–1457","1440":"1440","1450":"1450","abt 1465":"about 1465","1415":"1415","1457":"1457","1435":"1435","1455":"1455","1498":"1498","1454":"1454","1410":"1410","1465":"1465","about 1435":"about 1435","1452":"1452","about 1434":"about 1434","1506":"1506","1528":"1528","after 1454":"after 1454","Petworth, Sussex, England":"Petworth, Sussex, England","Sussex, England":"Sussex, England","nameMeanings":[{"name":"Bowyer","type":"LAST","attribution":"Dictionary of American Family Names © Patrick Hanks 2003, 2006.","meanings":["English: occupational name for a maker or seller of bows, or an archer, from Middle English <i>bowyere</i>, an agent derivative of Old English <i>boga</i> ‘bow’. Compare   Bowman  ."],"variants":[{"name":"Bowman","meanings":["English and Scottish: occupational name for an archer, hunter or soldier armed with a bow, from Middle English <i>bow(e)man</i>, <i>bouman</i> (from Old English <i>boga</i> ‘bow’ + <i>mann</i> ‘man’). This word was distinguished from   Bowyer  , which denoted a maker or seller of bows.","Americanized form of German   Baumann   or the Dutch cognate   Bouwman  ."]},{"name":"Bouyer","meanings":["Some characteristic forenames:  French Frederique, Monique, Napoleon.","English: variant of   Bowyer  .","French (southern): regional variant of   Bouvier  . Compare   Beyea  ."]},{"name":"Boyers","meanings":["English (Lincolnshire): variant of   Bowyer  , with post-medieval excrescent <i>-s</i>."]}]},{"name":"Richard","type":"FIRST","attribution":"Dictionary of First Names © Patrick Hanks and Flavia Hodges 1990, 2003, 2006.","meanings":["One of the most enduringly successful of the Old French personal names introduced into Britain by the Normans. It is of Germanic (Frankish) origin, derived from <i>rīc</i> ‘power’ + <i>hard</i> ‘strong, hardy’. It has enjoyed continuous popularity in England from the Conquest to the present day, influenced by the fact that it was borne by three kings of England, in particular  Richard I  (  1157–99 ). He was king for only ten years (  1189–99 ), most of which he spent in warfare abroad, taking part in the Third Crusade and costing the people of England considerable sums in taxes. Nevertheless, he achieved the status of a folk hero, and was never in England long enough to disappoint popular faith in his goodness and justice. He was also Duke of Aquitaine and Normandy and Count of Anjou, fiefs which he held at a time of maximum English expansion in France. His exploits as a leader of the Third Crusade earned him the nickname ‘Coeur de Lion’ or ‘Lionheart’ and a permanent place in popular imagination, in which he was even more firmly enshrined by  Sir Walter Scott's  novel Ivanhoe (  1820 )."],"variants":[{"name":"Rikert","meanings":["One of the most enduringly successful of the Old French personal names introduced into Britain by the Normans. It is of Germanic (Frankish) origin, derived from <i>rīc</i> ‘power’ + <i>hard</i> ‘strong, hardy’. It has enjoyed continuous popularity in England from the Conquest to the present day, influenced by the fact that it was borne by three kings of England, in particular  Richard I  (  1157–99 ). He was king for only ten years (  1189–99 ), most of which he spent in warfare abroad, taking part in the Third Crusade and costing the people of England considerable sums in taxes. Nevertheless, he achieved the status of a folk hero, and was never in England long enough to disappoint popular faith in his goodness and justice. He was also Duke of Aquitaine and Normandy and Count of Anjou, fiefs which he held at a time of maximum English expansion in France. His exploits as a leader of the Third Crusade earned him the nickname ‘Coeur de Lion’ or ‘Lionheart’ and a permanent place in popular imagination, in which he was even more firmly enshrined by  Sir Walter Scott's  novel Ivanhoe (  1820 )."]},{"name":"Rickert","meanings":["One of the most enduringly successful of the Old French personal names introduced into Britain by the Normans. It is of Germanic (Frankish) origin, derived from <i>rīc</i> ‘power’ + <i>hard</i> ‘strong, hardy’. It has enjoyed continuous popularity in England from the Conquest to the present day, influenced by the fact that it was borne by three kings of England, in particular  Richard I  (  1157–99 ). He was king for only ten years (  1189–99 ), most of which he spent in warfare abroad, taking part in the Third Crusade and costing the people of England considerable sums in taxes. Nevertheless, he achieved the status of a folk hero, and was never in England long enough to disappoint popular faith in his goodness and justice. He was also Duke of Aquitaine and Normandy and Count of Anjou, fiefs which he held at a time of maximum English expansion in France. His exploits as a leader of the Third Crusade earned him the nickname ‘Coeur de Lion’ or ‘Lionheart’ and a permanent place in popular imagination, in which he was even more firmly enshrined by  Sir Walter Scott's  novel Ivanhoe (  1820 )."]}]}],"historicEvents":[{"id":1705197,"age":20,"year":"1455","julianDay":2252488,"title":"Wars of the Roses","description":"Wars of the Roses was a series of English civil wars for control of the throne of England between the royal families House of Lancaster and the House of York. The name of the war was derived as the red rose was the symbol of the Lancastrians and the white rose was the symbol of the Yorks.","url":"https://www.history.com/topics/british-history/wars-of-the-roses","urlTitle":"History - Wars of the Roses","jurisdictionLevel":2}],"lifeSummary":"When Richard Bowyer of Petworth was born about 1435, in Sussex, England, his father, Thomas Bowyer, was 27 and his mother, Jennete Cotton, was 22. He had at least 1 son with Joan Gunter. He died in 1506, in Petworth, Sussex, England, at the age of 72."},"et":{"about 1435–1506":"umbes 1435–1506","1435–1506":"1435–1506","1450–1506":"1450–1506","1452–Male":"1452–Surnud","1440–1498":"1440–1498","1465–1528":"1465–1528","1410–1454":"1410–1454","1415–1457":"1415–1457","1440":"1440","1450":"1450","abt 1465":"umbes 1465","1415":"1415","1457":"1457","1435":"1435","1455":"1455","1498":"1498","1454":"1454","1410":"1410","1465":"1465","about 1435":"umbes 1435","1452":"1452","about 1434":"umbes 1434","1506":"1506","1528":"1528","after 1454":"pärast 1454","Petworth, Sussex, England":"Petworth, Sussex, England","Sussex, England":"Sussex, England"},"fi":{"about 1435–1506":"noin 1435–1506","1435–1506":"1435–1506","1450–1506":"1450–1506","1452–Male":"1452–Kuollut","1440–1498":"1440–1498","1465–1528":"1465–1528","1410–1454":"1410–1454","1415–1457":"1415–1457","1440":"1440","1450":"1450","abt 1465":"noin 1465","1415":"1415","1457":"1457","1435":"1435","1455":"1455","1498":"1498","1454":"1454