s":{"about 1220–":"okolo 1220–Zesnulá","1220–Male":"1220–Zesnulý","1240–Female":"1240–Zesnulá","1220–Female":"1220–Zesnulá","1220":"1220","1240":"1240","about 1220":"okolo 1220","about 1240":"okolo 1240","Scotland":"Scotland","Ayrshire, Scotland":"Ayrshire, Scotland"},"da":{"about 1220–":"omkring 1220–Afdød","1220–Male":"1220–Afdød","1240–Female":"1240–Afdød","1220–Female":"1220–Afdød","1220":"1220","1240":"1240","about 1220":"omkring 1220","about 1240":"omkring 1240","Scotland":"Skotland","Ayrshire, Scotland":"Ayrshire, Skotland"},"nl":{"about 1220–":"circa 1220–Overleden","1220–Male":"1220–Overleden","1240–Female":"1240–Overleden","1220–Female":"1220–Overleden","1220":"1220","1240":"1240","about 1220":"circa 1220","about 1240":"circa 1240","Scotland":"Schotland","Ayrshire, Scotland":"Ayrshire, Schotland"},"en":{"about 1220–":"about 1220–Deceased","1220–Male":"1220–Deceased","1240–Female":"1240–Deceased","1220–Female":"1220–Deceased","1220":"1220","1240":"1240","about 1220":"about 1220","about 1240":"about 1240","Scotland":"Scotland","Ayrshire, Scotland":"Ayrshire, Scotland","nameMeanings":[{"name":"of","type":"LAST","attribution":"Dictionary of American Family Names © Patrick Hanks 2003, 2006.","meanings":["Some characteristic forenames:  Chinese: Cheng, Jing, Kam Fung, Wai Shing, Wing, Yali, Yuk.","Chinese:","variant Romanization of the surnames 歐 and 區, see   Ou   1 and 2."],"variants":[{"name":"Ou","meanings":["Some characteristic forenames:  Chinese Wei, Ying, Ching, Heng, Hong, Jia, Kuang Yu, Li-Ching, Cho, Chong, Chung, Sa.  Southeast Asian Lichun, Ming, Quan, Roeun, Sokhom, Chau, Hai, Leang, Ly, Nhanh, Phan, Pho, Tha.","Chinese: Mandarin form of the surname 歐, meaning ‘to sing someone's praise’ in ancient Chinese: (i) from the placename Dong Ou (東甌), a fief (in present-day Wenzhou in Zhejiang province) which was granted to Yao in 192  BC . It is said that Yao was a descendant of Wujiang (reigned 355–333  BC ), king of the state of Yue (located mainly in present-day Zhejiang and Jiangxi provinces) during the Spring and Autumn period (770–476  BC ). (ii) from the placename Ou Yu (歐餘), the name of a fief (located in present-day Zhejiang province) that was granted to Ti, the second son of Wujiang (reigned 355–333  BC ), king of the state of Yue (located mainly in present-day Zhejiang and Jiangxi provinces) during the Spring and Autumn period (770–476  BC ).","Chinese: Mandarin form of the surname 區, originally denoting an ancient vessel for measurement in ancient Chinese: from the personal name of <i>Ou Zhizi</i> (歐治子), an expert sword-maker who lived during the Spring and Autumn period (770–476  BC ). Some of his descendants inherited <i>Ou</i> (歐) as their surname, simplifying the Chinese character 歐 to 區."]}]},{"name":"Riddell","type":"LAST","attribution":"Dictionary of American Family Names © Patrick Hanks 2003, 2006.","meanings":["Scottish and northern English: variant of   Riddle  . A family of the name <i>Riddell</i> has been established in Whitton in Roxburghshire since the mid 12th century, when Walter <i>de Riddel</i>, from Rydale (North Yorkshire), settled in Scotland after accompanying King David. Another unrelated family of this name have been established in Northumberland since at least the 14th century, with William <i>de Ridell</i> having been sheriff of the county in 1314."],"variants":[{"name":"Riddle","meanings":["English:","habitational name probably chiefly from Ryedale, a river valley in North Yorkshire. The placename derives from the river name <i>Rye</i> (of uncertain etymology) + Old Norse <i>dalr</i> ‘valley’. There are, however, other places called Rydale (in Westmorland for example) which could have given rise to hereditary surnames.","of Norman origin, from an Old French personal name <i>Ridel</i>, perhaps a pet form of ancient Germanic names such as <i>Ridbald</i> and <i>Ridhari(us)</i>."]},{"name":"Ridall","meanings":["Scottish and English (Yorkshire and Lincolnshire): variant of   Riddell  ."]},{"name":"Riddel","meanings":["Scottish and English: variant of   Riddell  ; see   Riddle  ."]},{"name":"Rydell","meanings":["Swedish: ornamental name composed of the placename element <i>ryd</i> ‘woodland clearing’ + the suffix <i>-ell</i>, a derivative of the Latin adjectival ending <i>-elius</i>.","English: variant of   Riddell  ; see   Riddle  . This surname is now rare in Britain."]}]}],"lifeSummary":"Lady Riddell of Glengarnock was born about 1220, in Scotland. She had at least 1 daughter with Sir Riddell of Glengarnock."},"et":{"about 1220–":"umbes 1220–Surnud","1220–Male":"1220–Surnud","1240–Female":"1240–Surnud","1220–Female":"1220–Surnud","1220":"1220","1240":"1240","about 1220":"umbes 1220","about 1240":"umbes 1240","Scotland":"Scotland","Ayrshire, Scotland":"Ayrshire, Scotland"},"fi":{"about 1220–":"noin 1220–Kuollut","1220–Male":"1220–Kuollut","1240–Female":"1240–Kuollut","1220–Female":"1220–Kuollut","1220":"1220","1240":"1240","about 1220":"noin 1220","about 1240":"noin 1240","Scotland":"Scotland","Ayrshire, Scotland":"Ayrshire, Scotland"},"fr":{"about 1220–":"environ 1220–Décédée","1220–Male":"1220–Décédé","1240–Female":"1240–Décédée","1220–Female":"1220–Décédée","1220":"1220","1240":"1240","about 1220":"environ 1220","about 1240":"environ 1240","Scotland":"Écosse","Ayrshire, Scotland":"Ayrshire, Écosse","lifeSummary":"Lady Riddell of Glengarnock est née environ 1220, à Écosse. Elle a eu au moins 1 fille avec Sir Riddell of Glengarnock."},"de":{"about 1220–":"um 1220–Verstorben","1220–Male":"1220–Verstorben","1240–Female":"1240–Verstorben","1220–Female":"1220–Verstorben","1220":"1220","1240":"1240","about 1220":"um 1220","about 1240":"um 1240","Scotland":"Scotland","Ayrshire, Scotland":"Ayrshire, Scotland","lifeSummary":"Lady Riddell of Glengarnock wurde um 1220 in Scotland geboren. Sie hatte mit Sir Riddell of Glengarnock mindestens 1 Tochter."},"ht":{"about 1220–":"about 1220–Desede","1220–Male":"1220–Desede","1240–Female":"1240–Desede","1220–Fe