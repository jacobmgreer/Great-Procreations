iants":[{"name":"Darsey","meanings":["Irish: variant of   Darcy   2.","Scottish: from Dairsie in Fife."]},{"name":"Darcey","meanings":["English (of Norman origin) and Irish (Tipperary): variant of   Darcy  ."]}]},{"name":"Thomas","type":"FIRST","attribution":"Dictionary of First Names © Patrick Hanks and Flavia Hodges 1990, 2003, 2006.","meanings":["New Testament name, borne by one of Christ's twelve apostles, referred to as ‘Thomas, called Didymus’ (John 11:16; 20:24). <i>Didymos</i> is the Greek word for ‘twin’, and the name is the Greek form of an Aramaic byname meaning ‘twin’. The given name has always been popular throughout Christendom, in part because St Thomas's doubts have made him seem a very human character."],"variants":[]}],"historicEvents":[{"id":1705195,"age":22,"year":"1382","julianDay":2225826,"title":"Wycliffe's Bible","description":"John Wycliffe, English theologian and professor at the University of Oxford, completed a translation of the Bible from the Latin Vulgate into Middle English. This translation is known as Wycliffe's Bible and was completed around 1382.","url":"https://en.wikipedia.org/wiki/Wycliffe%27s_Bible","urlTitle":"Wikipedia - Wycliffe's Bible","jurisdictionLevel":2}],"lifeSummary":"Sir Thomas d'Arcy II was born about 1360, in Maldon, Essex, England as the son of Thomas Darcy. He had at least 1 son with Alice Elizabeth Tyrell. He died in 1405, in his hometown, at the age of 46."},"et":{"Abt 1360–1405":"umbes 1360–1405","1360–1405":"1360–1405","1364–1441":"1364–1441","1391–1448":"1391–1448","1320–1359":"1320–1359","1448":"1448","1359":"1359","Abt 1360":"umbes 1360","1320":"1320","1441":"1441","1364":"1364","1382":"1382","1360":"1360","1391":"1391","1405":"1405","Maldon, Essex, England":"Maldon, Essex, England"},"fi":{"Abt 1360–1405":"noin 1360–1405","1360–1405":"1360–1405","1364–1441":"1364–1441","1391–1448":"1391–1448","1320–1359":"1320–1359","1448":"1448","1359":"1359","Abt 1360":"noin 1360","1320":"1320","1441":"1441","1364":"13