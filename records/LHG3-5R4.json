:"okolo 1512","1512":"1512","1567":"1567","about 1490":"okolo 1490","1510":"1510","1520":"1520","about 1510":"okolo 1510","before 1519":"před 1519","1519":"1519","1491":"1491","1490":"1490","Sockburn, Durham, England":"Sockburn, Durham, Anglie","of Sockbourne, Durham, Eng":"Durham, Anglie, United Kingdom","Durham, England":"Durham, Anglie","Dilston, Northumberland, England":"Dilston, Northumberland, Anglie"},"da":{"about 1490–before 1519":"omkring 1490–før 1519","1491–1520":"1491–1520","1510–1567":"1510–1567","1512–1547":"1512–1547","1490–1519":"1490–1519","1547":"1547","abt 1512":"omkring 1512","1512":"1512","1567":"1567","about 1490":"omkring 1490","1510":"1510","1520":"1520","about 1510":"omkring 1510","before 1519":"før 1519","1519":"1519","1491":"1491","1490":"1490","Sockburn, Durham, England":"Sockburn, Durham, England","of Sockbourne, Durham, Eng":"Durham, England, United Kingdom","Durham, England":"Durham, England","Dilston, Northumberland, England":"Dilston, Northumberland, England"},"nl":{"about 1490–before 1519":"circa 1490–vóór 1519","1491–1520":"1491–1520","1510–1567":"1510–1567","1512–1547":"1512–1547","1490–1519":"1490–1519","1547":"1547","abt 1512":"circa 1512","1512":"1512","1567":"1567","about 1490":"circa 1490","1510":"1510","1520":"1520","about 1510":"circa 1510","before 1519":"vóór 1519","1519":"1519","1491":"1491","1490":"1490","Sockburn, Durham, England":"Sockburn, Durham, England","of Sockbourne, Durham, Eng":"Durham, Engeland, Verenigd Koninkrijk","Durham, England":"Durham, England","Dilston, Northumberland, England":"Dilston, Northumberland, England"},"en":{"about 1490–before 1519":"about 1490–before 1519","1491–1520":"1491–1520","1510–1567":"1510–1567","1512–1547":"1512–1547","1490–1519":"1490–1519","1547":"1547","abt 1512":"about 1512","1512":"1512","1567":"1567","about 1490":"about 1490","1510":"1510","1520":"1520","about 1510":"about 1510","before 1519":"before 1519","1519":"1519","1491":"1491","1490":"1490","Sockburn, Durham, England":"Sockburn, Durham, England","of Sockbourne, Durham, Eng":"Durham, England, United Kingdom","Durham, England":"Durham, England","Dilston, Northumberland, England":"Dilston, Northumberland, England","nameMeanings":[{"name":"Radcliffe","type":"LAST","attribution":"Dictionary of American Family Names © Patrick Hanks 2003, 2006.","meanings":["English: variant of   Ratliff  ."],"variants":[{"name":"Ratliff","meanings":["English (Suffolk): habitational name from one or more of the places so named, such as Radcliffe (Lancashire), Radcliffe on Trent and Ratcliffe on Soar (both Nottinghamshire), Radclive (Buckinghamshire), Ratcliffe Culey and Ratcliffe on the Wreake (both Leicestershire), Ratclyffe in Clyst Hydon, Ratcliffes in Thorverton, and Ratcliffes in Broad Clyst (all Devon), Ratcliff in Stepney (Middlesex), and Rackley in Compton Bishop (Somerset). The placenames derive from Old English <i>rēad</i> ‘red’ + <i>clif</i> ‘cliff, bank, steep slope’ (see also   Rutley  ). A family of the name <i>Radcliffe</i> trace their descent from Sir Nicholas <i>de Radclyffe</i>. He is said to have been a knight who held the major of Radcliffe in Lancashire and served Roger de Poitou, Baron de Marsey in the 11th century."]}]},{"name":"Margaret","type":"FIRST","attribution":"Dictionary of First Names © Patrick Hanks and Flavia Hodges 1990, 2003, 2006.","meanings":["An extremely common given name from the Middle Ages onwards, derived via Old French <i>Marguerite</i> and Latin <i>Margarita</i> from Greek <i>Margarītēs</i>, from <i>margaron</i> ‘pearl’, a word ultimately of Hebrew origin. The name was always understood to mean ‘pearl’ throughout the Middle Ages. The first  St Margaret  was martyred at Antioch in Pisidia during the persecution instigated by the  Emperor Diocletian  in the early 4th century. However, there is some doubt about her name, as the same saint is venerated in the Orthodox Church as   Marina .  There were several other saintly bearers of the name, including St Margaret of Scotland (  d. 1093 ), wife of  King Malcolm Canmore  and daughter of Edmund Ironside of England. It was also the name of the wife of  Henry VI  of England,  Margaret of Anjou  (  1430–82 ), and of  Margaret Tudor  (  1489–1541 ), sister of  Henry VIII , who married James IV of Scotland and ruled as regent there after his death.  See also  Margery  ,   Marjorie ."],"variants":[{"name":"Margareta","meanings":["From the Latin form of Greek <i>Margarītēs</i>.  See  <b>Margaret</b>   ."]},{"name":"Margaretta","meanings":["Formed from Margaret."]}]}],"lifeSummary":"Margaret Radcliffe was born about 1490, in Dilston, Northumberland, England. She married Sir Thomas Conyers Knt. about 1510, in Dilston, Northumberland, England. They were the parents of at least 1 son and 1 daughter. She died before 1519, in Durham, England."},"et":{"about 1490–before 1519":"umbes 1490–enne 1519","1491–1520":"1491–1520","1510–1567":"1510–1567","1512–1547":"1512–1547","1490–1519":"1490–1519","1547":"1547","abt 1512":"umbes 1512","1512":"1512","1567":"1567","about 1490":"umbes 1490","1510":"1510","1520":"1520","about 1510":"umbes 1510","before 1519":"enne 1519","1519":"1519","1491":"1491","1490":"1490","Sockburn, Durham, England":"Sockburn, Durham, England","of Sockbourne, Durham, Eng":"Durham, Inglismaa, United Kingdom","Durham, England":"Durham, England","Dilston, Northumberland, England":"Dilston, Northumberland, England"},"fi":{"about 1490–before 1519":"noin 1490–ennen vuotta 1519","1491–1520":"1491–1520","1510–1567":"1510–1567","1512–1547":"1512–1547","1490–1519":"1490–1519","1547":"1547","abt 1512":"noin 1512","1512":"1512","1567":"1567","about 1490":"noin 1490","1510":"1510","1520":"1520","about 1510":"noin 1510","before 1519":"ennen vuotta 1519","1519":"1519","1491":"1491","1490":"1490","Sockburn, Durham, England":"Sockburn, Durham, England","of Sockbourne, Durham, Eng":"Durham, Englanti, Yhdistynyt kuningaskunta","Durham, England":"Durham, England","Dilston, Northumberland, Engla