fleet, Holderness, Yorkshire":"Marfleet, Yorkshire, England","England":"Engeland, Verenigd Koninkrijk","Marfleet, Holderness, Yorkshire, England":"Marfleet, Yorkshire, Engeland, Verenigd Koninkrijk"},"en":{"1230–1296":"1230–1296","1232–Male":"1232–Deceased","1233–1262":"1233–1262","1260–1310":"1260–1310","1198–1249":"1198–1249","1202–Female":"1202–Deceased","Aft. 1249":"after 1249","1198":"1198","1230":"1230","1296":"1296","1262":"1262","1260":"1260","ABT 1229":"about 1229","1290":"1290","1249":"1249","1259":"1259","1202":"1202","1310":"1310","1233":"1233","Abt. 1257":"about 1257","1232":"1232","Marfleet, Holderness, Yorkshire":"Marfleet, Yorkshire, England","England":"England, United Kingdom","Marfleet, Holderness, Yorkshire, England":"Marfleet, Yorkshire, England, United Kingdom","nameMeanings":[{"name":"de","type":"LAST","attribution":"Dictionary of American Family Names © Patrick Hanks 2003, 2006.","meanings":["Some characteristic forenames:  Indian Dilip, Anirban, Gopal, Alok, Anindya, Arunava, Asit, Asok, Dibyendu, Goutam, Indra, Indranil.","Indian: variant of   Dey  ."],"variants":[{"name":"Dey","meanings":["Some characteristic forenames:  Indian Ashit, Indu, Naina, Partha, Soumya, Ajit, Anjan, Anjana, Anup, Arjun, Arun, Ashim.","English, Scottish, and Welsh: variant of   Day  .","German: topographic name from a field name in North Rhine-Westphalia, denoting a sizeable piece of land, from Middle Low German <i>dē</i> ‘thigh’ (referring to the shape of the property)."]}]},{"name":"Thorpe","type":"LAST","attribution":"Dictionary of American Family Names © Patrick Hanks 2003, 2006.","meanings":["English (mainly Yorkshire and Lancashire): from Middle English <i>thorp(e)</i> ‘village, hamlet, farmstead’ (Old Norse, Old English <i>thorp</i> ‘secondary settlement’). The surname may be topographic, for someone who lived in such a settlement, or habitational, for someone from any of several places called Thorp(e), which are most frequent in Yorkshire, the Midlands, and East Anglia. Compare   Throop  ."],"variants":[{"name":"Trupp","meanings":["Some characteristic forenames:  German Hans, Hermann, Reinhold.","English (Herefordshire and Monmouthshire): variant of   Thorpe  , or from a place so named, such as Thrupp (Berkshire, Gloucestershire, Oxfordshire), Thrupe (Somerset), Throop (Dorset, Hampshire, Somerset), and Throope (Wiltshire).","Altered form of German   Trapp  ."]},{"name":"Throop","meanings":["English: from Middle English <i>throp</i> ‘village, hamlet, farmstead’ (Old Norse, Old English <i>throp</i> ‘secondary settlement’). The surname may be topographic, for someone who lived in such a settlement, or habitational, for someone from Throop in Hampshire, Throope in Wiltshire, Thrup in Oxfordshire, or any of the places called Thrupp in Berkshire, Gloucestershire, and Northamptonshire. Compare   Thorpe  ."]},{"name":"Tharpe","meanings":["English (Kent): variant of   Thorpe  . This form of the surname is rare in Britain and Ireland."]},{"name":"Thorp","meanings":["English (mainly Yorkshire and Lancashire): variant of   Thorpe  .","Scandinavian: variant of   Torp  ."]},{"name":"Troup","meanings":["Scottish (eastern): habitational name from a place in the parish of Gamrie, near Banff. The placename is unexplained, perhaps a Pictish cognate of Welsh <i>trwp</i> ‘vessel, dish, basin’.","Possibly also English, a metathesized form of   Thorpe  ."]},{"name":"Tharp","meanings":["English: variant of   Thorpe  ."]}]},{"name":"III","type":"LAST","attribution":"Dictionary of American Family Names © Patrick Hanks 2003, 2006.","meanings":["Some characteristic forenames:  Japanese Yuko, Aiko, Hideaki, Hiroki, Hiroyuki, Isamu, Kaoru, Katsumi, Keiichiro, Kenji, Masako, Masayuki.","Japanese: variously written, sometimes with characters used phonetically; the most probable meanings are 仁井 ‘benevolent well’, 新居 ‘new residence’, or 新井 ‘new well’. It is not common in Japan."],"variants":[]},{"name":"Stephen","type":"FIRST","attribution":"Dictionary of First Names © Patrick Hanks and Flavia Hodges 1990, 2003, 2006.","meanings":["Usual English spelling of the name of the first Christian martyr (Acts 6–7), whose feast is accordingly celebrated next after Christ's own (  26 December ). His name is derived from the Greek word <i>stephanos</i> ‘garland, crown’."],"variants":[{"name":"Stephan","meanings":["Variant of   Stephen  , preserving the vowels of the Greek name."]},{"name":"Steven","meanings":["Variant of   Stephen  , reflecting the normal pronunciation of the name in the English-speaking world."]}]}],"historicEvents":[{"id":1705189,"age":29,"year":"1259","julianDay":2180901,"title":"100 Years of Conflict Between England and France Ends","description":"Treaty of Paris was signed on December 4, 1259, which ended 100 years of conflict between England and France.","url":"https://en.wikipedia.org/wiki/Treaty_of_Paris_(1259)","urlTitle":"Wikipedia - Treaty of Paris 1259","jurisdictionLevel":2},{"id":1705190,"age":60,"year":"1290","julianDay":2192224,"title":"Jews Expelled From England","description":"After years of anti-Semitic behavior, King Edward I expelled Jews from England in 1290.","jurisdictionLevel":2}],"lifeSummary":"When Stephen de Thorpe III de Merflet was born in 1230, in Marfleet, Yorkshire, England, his father, Stephen de Thorpe II de Merflet, was 33 and his mother, Matilda, was 29. He married Agnes Saint Quintin about 1257, in England, United Kingdom. They were the parents of at least 1 son. He died in 1296, at the age of 66."},"et":{"1230–1296":"1230–1296","1232–Male":"1232–Surnud","1233–1262":"1233–1262","1260–1310":"1260–1310","1198–1249":"1198–1249","1202–Female":"1202–Surnud","Aft. 1249":"pärast 1249","1198":"1198","1230":"1230","1296":"1296","1262":"1262","1260":"1260","ABT 1229":"umbes 1229","1290":"1290","1249":"1249","1259":"1259","1202":"1202","1310":"1310","1233":"1233","Abt. 1257":"umbes 1257","1232":"1232","Marfleet, Holderness, Yorkshire":"Marfleet, Yorkshire, England","England":"In