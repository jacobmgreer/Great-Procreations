345–1387":"1345–1387","about 1418":"circa 1418","1345":"1345","1411":"1411","1387":"1387","1320":"1320","1364":"1364","1382":"1382","about 1364":"circa 1364","1380":"1380","1418":"1418","1390":"1390","Glassenbury, Kent, England":"Glassenbury, Kent, England","Glastonbury, Somerset, England":"Glastonbury, Somerset, England"},"en":{"about 1364–about 1418":"about 1364–about 1418","1364–1418":"1364–1418","1390–1411":"1390–1411","1320–1380":"1320–1380","1345–1387":"1345–1387","about 1418":"about 1418","1345":"1345","1411":"1411","1387":"1387","1320":"1320","1364":"1364","1382":"1382","about 1364":"about 1364","1380":"1380","1418":"1418","1390":"1390","Glassenbury, Kent, England":"Glassenbury, Kent, England","Glastonbury, Somerset, England":"Glastonbury, Somerset, England","nameMeanings":[{"name":"Tilley","type":"LAST","attribution":"Dictionary of American Family Names © Patrick Hanks 2003, 2006.","meanings":["English (of Norman origin): habitational name from Tilly-sur-Seulles (Calvados) or Tilly (Eure), France.","English: habitational name from Tyley in Wotton under Edge (Gloucestershire), Tiley in Minterne Magna (Dorset), or Tilley (Shropshire). The Gloucestershire and Dorset placenames derive from Old English <i>tigel</i> ‘tile’ + <i>lēah</i> ‘wood, woodland clearing’. The Shropshire placename derives from an uncertain first element + Old English <i>lēah</i>.","English: occupational name from Middle English <i>tilie</i> ‘one who tills the land, a husbandman’. Compare   Tiller  ."],"variants":[{"name":"Tillie","meanings":["English (northern England and southern Scotland): variant of   Tilley  . This form of the surname is rare in Britain and Ireland."]},{"name":"Tiller","meanings":["English (southern, especially Hampshire): occupational name from Middle English <i>tiliere</i>, <i>tilyer</i> ‘one who tills the soil, husbandman, farmer, farm laborer’. This is a derivative of Old English <i>tilian</i> ‘to till (the soil)’, Middle English <i>tilie</i>. There has been some confusion of this name with   Tyler  .","German: variant of <b>Tüller</b> (see   Tuller  )."]},{"name":"Tiley","meanings":["English (Gloucestershire, Somerset and Wiltshire): variant of   Tilley  ."]}]},{"name":"William","type":"FIRST","attribution":"Dictionary of First Names © Patrick Hanks and Flavia Hodges 1990, 2003, 2006.","meanings":["Probably the most successful of all the Old French names of Germanic origin that were introduced to England by the Normans. It is derived from Germanic <i>wil</i> ‘will, desire’ + <i>helm</i> ‘helmet, protection’. The fact that it was borne by the Conqueror himself does not seem to have inhibited its favour with the ‘conquered’ population: in the first century after the Conquest it was the commonest male name of all, and not only among the Normans. In the later Middle Ages it was overtaken by   John  , but continued to run second to that name until the 20th century, when the picture became more fragmented."],"variants":[]}],"historicEvents":[{"id":1705195,"age":18,"year":"1382","julianDay":2225826,"title":"Wycliffe's Bible","description":"John Wycliffe, English theologian and professor at the University of Oxford, completed a translation of the Bible from the Latin Vulgate into Middle English. This translation is known as Wycliffe's Bible and was completed around 1382.","url":"https://en.wikipedia.org/wiki/Wycliffe%27s_Bible","urlTitle":"Wikipedia - Wycliffe's Bible","jurisdictionLevel":2}],"lifeSummary":"When William Tilley was born about 1364, in Glassenbury, Kent, England, his father, William Tilley, was 45 and his mother, Elizabeth Danvers, was 20. He had at least 1 daughter. He died about 1418, in his hometown, at the age of 56."},"et":{"about 1364–about 1418":"umbes 1364–umbes 1418","1364–1418":"1364–1418","1390–1411":"1390–1411","1320–1380":"1320–1380","1345–1387":"1345–1387","about 1418":"umbes 1418","1345":"1345","1411":"1411","1387":"1387","1320":"1320","1364":"1364","1382":"1382","about 1364":"umbes 1364","1380":"1380",