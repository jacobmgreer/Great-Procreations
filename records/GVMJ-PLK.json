0":"omkring 1220–omkring 1270","1220–1270":"1220–1270","1240–1316":"1240–1316","1316":"1316","Abt 1240":"omkring 1240","Abt 1220":"omkring 1220","1220":"1220","1240":"1240","Abt 1270":"omkring 1270","1270":"1270","Angus, Scotland":"Angus, Skotland, United Kingdom","Scotland":"Skotland, United Kingdom","Airlie, Angus, Scotland":"Airlie, Angus, Skotland, United Kingdom"},"nl":{"Abt 1220–Abt 1270":"circa 1220–circa 1270","1220–1270":"1220–1270","1240–1316":"1240–1316","1316":"1316","Abt 1240":"circa 1240","Abt 1220":"circa 1220","1220":"1220","1240":"1240","Abt 1270":"circa 1270","1270":"1270","Angus, Scotland":"Angus, Schotland, Verenigd Koninkrijk","Scotland":"Schotland, Verenigd Koninkrijk","Airlie, Angus, Scotland":"Airlie, Angus, Schotland, Verenigd Koninkrijk"},"en":{"Abt 1220–Abt 1270":"about 1220–about 1270","1220–1270":"1220–1270","1240–1316":"1240–1316","1316":"1316","Abt 1240":"about 1240","Abt 1220":"about 1220","1220":"1220","1240":"1240","Abt 1270":"about 1270","1270":"1270","Angus, Scotland":"Angus, Scotland, United Kingdom","Scotland":"Scotland, United Kingdom","Airlie, Angus, Scotland":"Airlie, Angus, Scotland, United Kingdom","nameMeanings":[{"name":"Fenton","type":"LAST","attribution":"Dictionary of American Family Names © Patrick Hanks 2003, 2006.","meanings":["English: habitational name from any of various places, in Yorkshire, Lincolnshire, Northumberland, Staffordshire, and Nottinghamshire, so called from Old English <i>fenn</i> ‘marsh, fen’ + <i>tūn</i> ‘enclosure, settlement’.","Irish: English surname adopted by bearers of Gaelic <i>Ó Fionnachta</i> or <b>Ó Fiachna</b> ‘descendant of <i>Fiachna</i>’, an old personal name Anglicized as <b>Feighney</b> and sometimes mistranslated as   Hunt   (see   Fee   1 and   Finnerty  ).","Scottish: habitational name from Fenton in East Lothian."],"variants":[{"name":"Hunt","meanings":["English (southwestern): occupational name for a hunter, from Middle English <i>hunte</i> ‘hunter, huntsman’ (Old English <i>hunta</i>). The term was used not only of the hunting on horseback of game such as stags and wild boars, which in the Middle Ages was a pursuit restricted to the ranks of the nobility, but also to much humbler forms of pursuit such as bird catching and poaching for food. The word seems also to have been used as an Old English personal name and to have survived into the Middle Ages as an occasional personal name. Compare   Huntington   and   Huntley  .","Irish: adopted for various Irish surnames containing or thought to contain the Gaelic element <i>fiadhach</i> ‘hunt’; for example <b>Ó Fiaich</b> (see   Fee  ) and <b>Ó Fiachna</b> (see   Fenton  ).","Possibly an Americanized form of German   Hundt  ."]},{"name":"Fantom","meanings":["English: nickname from Middle English <i>fantom</i>, <i>fainton</i> ‘apparition, ghost’. There has been some confusion with   Fenton  ."]},{"name":"Finton","meanings":["English and Irish: variant of   Fenton  ."]},{"name":"Fenty","meanings":["Scottish: variant of   Fenton  ."]}]},{"name":"John","type":"FIRST","meanings":["Greek: the Lord gave graciously; whom Jehovah gave; whom Jehovah bestowed."],"variants":[]}],"lifeSummary":"John Fenton was born about 1220, in Scotland, United Kingdom. He had at least 1 son with Mary Kettins. He died about 1270, in Angus, Scotland, United Kingdom, at the age of 52."},"et":{"Abt 1220–Abt 1270":"umbes 1220–umbes 1270","1220–1270":"1220–1270","1240–1316":"1240–1316","1316":"1316","Abt 1240":"umbes 1240","Abt 1220":"umbes 1220","1220":"1220","1240":"1240","Abt 1270":"umbes 1270","1270":"1270","Angus, Scotland":"Angus, Šotimaa, United Kingdom","Scotland":"Šotimaa, United Kingdom","Airlie, Angus, Scotland":"Airlie, Angus, Šotimaa, United Kingdom"},"fi":{"Abt 1220–Abt 1270":"noin 1220–noin 1270","1220–1270":"1220–1270","1240–1316":"1240–1316","1316":"1316","Abt 1240":"noin 1240","Abt 1220":"noin 1220","1220":"1220","1240":"1240","Abt 1270":"noin 1270","1270":"1270","Angus, Scotland":"Angus, Skotlanti, Yhdist