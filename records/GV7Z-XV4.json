006.","meanings":["From the Old Welsh name  <b>Gwladus</b> , which is of uncertain derivation. It has been quite widely used outside Wales since the beginning of the 20th century, but is now out of fashion."],"variants":[]}],"lifeSummary":"Gladis Ap Rhys was born about 1204, in Wales. She married Philip ap Y Bach in 1198. They were the parents of at least 1 daughter."},"et":{"about 1204–":"umbes 1204–Surnud","1194–1234":"1194–1234","–Female":"Surnud","1204–Female":"1204–Surnud","1204":"1204","1234":"1234","about 1204":"umbes 1204","1194":"1194","Wales":"Wales"},"fi":{"about 1204–":"noin 1204–Kuollut","1194–1234":"1194–1234","–Female":"Kuollut","1204–Female":"1204–Kuollut","1204":"1204","1234":"1234","about 1204":"noin 1204","1194":"1194","Wales":"Wales"},"fr":{"about 1204–":"environ 1204–Décédée","1194–1234":"1194–1234","–Female":"Décédée","1204–Female":"1204–Décédée","1204":"1204","1234":"1234","about 1204":"environ 1204","1194":"1194","Wales":"Galles","lifeSummary":"Gladis Ap Rhys est née environ 1204, à Galles. Elle a épousé Philip ap Y Bach en 1198. Ils ont eu au moins 1 fille."},"de":{"about 1204–":"um 1204–Verstorben","1194–1234":"1194–1234","–Female":"Verstorben","1204–Female":"1204–Verstorben","1204":"1204","1234":"1234","about 1204":"um 1204","1194":"1194","Wales":"Wales","lifeSummary":"Gladis Ap Rhys wurde um 1204 in Wales geboren. Sie hat 1198 Philip ap Y Bach geheiratet. Sie hatten mindestens 1 Tochter."},"ht":{"about 1204–":"about 1204–Desede","1194–1234":"1194–1234","–Female":"Desede","1204–Female":"1204–Desede","1204":"1204","1234":"1234","about 1204":"about 1204","1194":"1194","Wales":"Wales"},"hu":{"about 1204–":"1204 körül–elhunyt","1194–1234":"1194–1234","–Female":"elhunyt","1204–Female":"1204–elhunyt","1204":"1204","1234":"1234","about 1204":"1204 körül","1194":"1194","Wales":"Wales"},"id":{"about 1204–":"sekitar 1204–Telah Meninggal","1194–1234":"1194–1234","–Female":"Telah Meninggal","1204–Female":"1204–Telah Meninggal","1204":"1204","1234":"12