44":"1344","1366":"1366","1443":"1443","1310":"1310","1420":"1420","1364":"1364","about 1363":"circa 1363","Tatham, Lancashire, England":"Tatham, Lancashire, England","Great Urswick, Lancashire, England":"Great Urswick, Lancashire, England","England":"England","Urswick, Lancashire, England":"Great Urswick, Lancashire, England","Lancashire, England":"Lancashire, England"},"en":{"1344–Bef 1372":"1344–before 1372","1344–1372":"1344–1372","1340–1401":"1340–1401","1364–1459":"1364–1459","1366–1420":"1366–1420","1370–1443":"1370–1443","1310–Male":"1310–Deceased","1340":"1340","1372":"1372","1370":"1370","1459":"1459","Bef 1372":"before 1372","1401":"1401","1344":"1344","1366":"1366","1443":"1443","1310":"1310","1420":"1420","1364":"1364","about 1363":"about 1363","Tatham, Lancashire, England":"Tatham, Lancashire, England","Great Urswick, Lancashire, England":"Great Urswick, Lancashire, England","England":"England","Urswick, Lancashire, England":"Great Urswick, Lancashire, England","Lancashire, England":"Lancashire, England","nameMeanings":[{"name":"Southworth","type":"LAST","attribution":"Dictionary of American Family Names © Patrick Hanks 2003, 2006.","meanings":["English (Lancashire): habitational name from Southworth in Winwick (Lancashire), from Old English <i>sūth</i> ‘south, southern’ + <i>worth</i> ‘enclosure’."],"variants":[{"name":"Suthard","meanings":["English: variant of   Southworth  . This form of the surname is now rare in Britain."]},{"name":"Sudderth","meanings":["Altered form of English   Southworth  ."]},{"name":"Southwood","meanings":["English:","habitational name from one or more of several places in southern England, especially in Devon, named with Middle English <i>bi southe wode</i> ‘(place) to the south of the wood’.","habitational name from one or more minor places called Southwood or Sowood, from Middle English <i>south(e)</i> + <i>wode</i> ‘south wood’. Sowood in Osset (Yorkshire) is the most likely source of the Yorkshire name. There may have been confusion with   Southworth  ."]},{"name":"Southward","meanings":["English (Lancashire and Cumberland):","variant of   Southworth  .","variant of   Southwood  ."]},{"name":"Suddith","meanings":["Altered form of English   Southworth  ."]},{"name":"Suddarth","meanings":["Altered form of English   Southworth  ."]},{"name":"Suddeth","meanings":["Altered form of English   Southworth  ."]},{"name":"Sudduth","meanings":["English: variant of   Southworth  . This form of the surname is now rare in Britain."]},{"name":"Suddreth","meanings":["Altered form of English   Southworth  ."]},{"name":"Suddath","meanings":["Altered form of English   Southworth  ."]}]},{"name":"Margaret","type":"FIRST","attribution":"Dictionary of First Names © Patrick Hanks and Flavia Hodges 1990, 2003, 2006.","meanings":["An extremely common given name from the Middle Ages onwards, derived via Old French <i>Marguerite</i> and Latin <i>Margarita</i> from Greek <i>Margarītēs</i>, from <i>margaron</i> ‘pearl’, a word ultimately of Hebrew origin. The name was always understood to mean ‘pearl’ throughout the Middle Ages. The first  St Margaret  was martyred at Antioch in Pisidia during the persecution instigated by the  Emperor Diocletian  in the early 4th century. However, there is some doubt about her name, as the same saint is venerated in the Orthodox Church as   Marina .  There were several other saintly bearers of the name, including St Margaret of Scotland (  d. 1093 ), wife of  King Malcolm Canmore  and daughter of Edmund Ironside of England. It was also the name of the wife of  Henry VI  of England,  Margaret of Anjou  (  1430–82 ), and of  Margaret Tudor  (  1489–1541 ), sister of  Henry VIII , who married James IV of Scotland and ruled as regent there after his death.  See also  Margery  ,   Marjorie ."],"variants":[{"name":"Margareta","meanings":["From the Latin form of Greek <i>Margarītēs</i>.  See  <b>Margaret</b>   ."]},{"name":"Margaretta","meanings":["Formed from Margaret."]}]}],"lifeS