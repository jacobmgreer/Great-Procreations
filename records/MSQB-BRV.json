/i> 1723."]}]}],"lifeSummary":"Mrs Holbroke married Willm. Holbroke on 8 December 1579, in Niton, Hampshire, England, United Kingdom."},"et":{"–":"Surnud","1274–1301":"1274–1301","–Male":"Surnud","1302–1318":"1302–1318","–Female":"Surnud","1302":"1302","08 Dec 1579":"8. detsember 1579","1301":"1301","1274":"1274","1318":"1318","of, Niton, Hampshire, England":"Niton, Hampshire, Inglismaa, United Kingdom","Stoke by Nayland, Suffolk, England":"Stoke by Nayland, Suffolk, England"},"fi":{"–":"Kuollut","1274–1301":"1274–1301","–Male":"Kuollut","1302–1318":"1302–1318","–Female":"Kuollut","1302":"1302","08 Dec 1579":"8. joulukuuta 1579","1301":"1301","1274":"1274","1318":"1318","of, Niton, Hampshire, England":"Niton, Hampshire, Englanti, Yhdistynyt kuningaskunta","Stoke by Nayland, Suffolk, England":"Stoke by Nayland, Suffolk, England"},"fr":{"–":"Décédée","1274–1301":"1274–1301","–Male":"Décédé","1302–1318":"1302–1318","–Female":"Décédée","1302":"1302","08 Dec 1579":"8 décembre 1579","1301":"1301","1274":"1274","1318":"1318","of, Niton, Hampshire, England":"Niton, Hampshire, Angleterre, Royaume-Uni","Stoke by Nayland, Suffolk, England":"Stoke by Nayland, Suffolk, Angleterre","lifeSummary":"Mrs Holbroke a épousé Willm. Holbroke le 8 décembre 1579, à Niton, Hampshire, Angleterre, Royaume-Uni."},"de":{"–":"Verstorben","1274–1301":"1274–1301","–Male":"Verstorben","1302–1318":"1302–1318","–Female":"Verstorben","1302":"1302","08 Dec 1579":"8. Dezember 1579","1301":"1301","1274":"1274","1318":"1318","of, Niton, Hampshire, England":"Niton, Hampshire, England, United Kingdom","Stoke by Nayland, Suffolk, England":"Stoke by Nayland, Suffolk, England","lifeSummary":"Mrs Holbroke hat am 8. Dezember 1579 in Niton, Hampshire, England, United Kingdom Willm. Holbroke geheiratet."},"ht":{"–":"Desede","1274–1301":"1274–1301","–Male":"Desede","1302–1318":"1302–1318","–Female":"Desede","1302":"1302","08 Dec 1579":"8 December 1579","1301":"1301","1274":"1274","1318":"1318","of, Niton, Hampshire