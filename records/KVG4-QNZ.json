t 1325–Deceased":"omkring 1325–Afdød","1295–Male":"1295–Afdød","1350–1425":"1350–1425","1325–Female":"1325–Afdød","1425":"1425","1325":"1325","Abt 1325":"omkring 1325","1350":"1350","1295":"1295","England, United Kingdom":"England, United Kingdom"},"nl":{"Abt 1325–Deceased":"circa 1325–Overleden","1295–Male":"1295–Overleden","1350–1425":"1350–1425","1325–Female":"1325–Overleden","1425":"1425","1325":"1325","Abt 1325":"circa 1325","1350":"1350","1295":"1295","England, United Kingdom":"Engeland, Verenigd Koninkrijk"},"en":{"Abt 1325–Deceased":"about 1325–Deceased","1295–Male":"1295–Deceased","1350–1425":"1350–1425","1325–Female":"1325–Deceased","1425":"1425","1325":"1325","Abt 1325":"about 1325","1350":"1350","1295":"1295","England, United Kingdom":"England, United Kingdom","nameMeanings":[{"name":"Joan","type":"FIRST","attribution":"Dictionary of First Names © Patrick Hanks and Flavia Hodges 1990, 2003, 2006.","meanings":["Contracted form of Old French <i>Jo(h)anne</i>, from Latin <i>Io(h)anna</i> (  see  Joanna  ). In England this was the usual feminine form of   John   from the Middle English period onwards and was extremely popular, but in the 16th and 17th centuries it steadily lost ground to   Jane .  It was strongly revived in the first part of the 20th century, partly under the influence of  George Bernard Shaw's  play St Joan (  1923 ), based on the life of  Joan of Arc  (  1412–31 ). Claiming to be guided by the voices of the saints, she persuaded the French dauphin to defy the occupying English forces and have himself crowned, and she led the French army that raised the siege of Orleans in  1429 . The following year she was captured by the Burgundians and sold to the English, and a year later she was burned at the stake for witchcraft at the age of 18 or 19. Her story has captured the imagination of many writers, and she is variously portrayed as a national and political hero, a model of apolitical straightforwardness and honesty, and a religious heroine. She was canonized in  1920 . More recent influences have included the American film actress  Joan Crawford  (  1908–77 , born  Lucille le Sueur ), the British actress  Joan Collins  (  b. 1933 ), the American comedienne  Joan Rivers  (  b. 1933 ), and the West Indian pop singer  Joan Armatrading  (  b. 1950 )."],"variants":[{"name":"John","meanings":["As a boy's name this represents a revival of Middle English <i>Jan</i>, a by‐form of   John  , or an adoption of the common European form with this spelling. As a girl's name it is a short form of names such as   Janet   and   Janice ."]}]}],"lifeSummary":"Joan was born about 1325, in England, United Kingdom. She had at least 1 son with Gilbert Shottisbroke."},"et":{"Abt 1325–Deceased":"umbes 1325–Surnud","1295–Male":"1295–Surnud","1350–1425":"1350–1425","1325–Female":"1325–Surnud","1425":"1425","1325":"1325","Abt 1325":"umbes 1325","1350":"1350","1295":"1295","England, United Kingdom":"Inglismaa, United Kingdom"},"fi":{"Abt 1325–Deceased":"noin 1325–Kuollut","1295–Male":"1295–Kuollut","1350–1425":"1350–1425","1325–Female":"1325–Kuollut","1425":"1425","1325":"1325","Abt 1325":"noin 1325","1350":"1350","1295":"1295","England, United Kingdom":"Englanti, Yhdistynyt kuningaskunta"},"fr":{"Abt 1325–Deceased":"environ 1325–Décédée","1295–Male":"1295–Décédé","1350–1425":"1350–1425","1325–Female":"1325–Décédée","1425":"1425","1325":"1325","Abt 1325":"environ 1325","1350":"1350","1295":"1295","England, United Kingdom":"Angleterre, Royaume-Uni","lifeSummary":"Joan est née environ 1325, à Angleterre, Royaume-Uni. Elle a eu au moins 1 fils avec Gilbert Shottisbroke."},"de":{"Abt 1325–Deceased":"um 1325–Verstorben","1295–Male":"1295–Verstorben","1350–1425":"1350–1425","1325–Female":"1325–Verstorben","1425":"1425","1325":"1325","Abt 1325":"um 1325","1350":"1350","1295":"1295","England, United Kingdom":"England, United Kingdom","lifeSummary":"Joan wurde um 1325 in England, United Kingdom geboren. Sie hatte mit Gilbert Shottisbroke min