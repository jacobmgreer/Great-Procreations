hire, England":"英国藍卡爾度波利","lifeSummary":"当Sir James de Standish II于1429年出生在英国英格兰藍卡爾时，他的父亲James De Standish I29岁，母亲Margaret Grace Hamerton24岁。他于1452年与Alice Poole在英国英格兰结婚。他们至少是3个儿子和1个女儿的父母。他去世于1471年在英国英格兰藍卡爾霍利享年42岁。"},"hr":{"1429–1471":"1429.–1471.","1434–Male":"1434–preminuo","1429–1518":"1429.–1518","1448–1495":"1448–1495","1460–1495":"1460.–1495","–Male":"preminuo","1400–1462":"1400–1462.","1405–1468":"1405–1468.","Prior to 1452":"1452.","1462":"1462.","1495":"1495","1460":"1460.","1471":"1471.","1448":"1448","1468":"1468.","Abt. 1448":"oko 1448.","1434":"1434","1400":"1400","1518":"1518","1429":"1429.","1405":"1405","Chorley, Lancashire, England":"Chorley, Lancashire, Engleska, United Kingdom","England":"Engleska, United Kingdom","Standish, Lancashire, England":"Standish, Lancashire, Engleska, United Kingdom","Duxbury Hall, Chorley, Lancashire, England":"Chorley, Lancashire, Engleska, United Kingdom","Duxbury, Lancashire, England":"Duxbury, Lancashire, England"},"cs":{"1429–1471":"1429–1471","1434–Male":"1434–Zesnulý","1429–1518":"1429–1518","1448–1495":"1448–1495","1460–1495":"1460–1495","–Male":"Zesnulý","1400–1462":"1400–1462","1405–1468":"1405–1468","Prior to 1452":"1452","1462":"1462","1495":"1495","1460":"1460","1471":"1471","1448":"1448","1468":"1468","Abt. 1448":"okolo 1448","1434":"1434","1400":"1400","1518":"1518","1429":"1429","1405":"1405","Chorley, Lancashire, England":"Chorley, Lancashire, Anglie, United Kingdom","England":"Anglie, United Kingdom","Standish, Lancashire, England":"Standish, Lancashire, Anglie, United Kingdom","Duxbury Hall, Chorley, Lancashire, England":"Chorley, Lancashire, Anglie, United Kingdom","Duxbury, Lancashire, England":"Duxbury, Lancashire, Anglie"},"da":{"1429–1471":"1429–1471","1434–Male":"1434–Afdød","1429–1518":"1429–1518","1448–1495":"1448–1495","1460–1495":"1460–1495","–Male":"Afdød","1400–1462":"1400–1462","1405–1468":"1405–1468","Prior to 1452":"1452","1462":"1462","1495":"1495","1460":"1460","1471":"1471","1448":"14