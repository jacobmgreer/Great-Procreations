dac um 1194 in Broughton, Oxfordshire, England geboren wurde, war ihr Vater Ralph de Murdac 49 und ihre Mutter Eva Grey 31. Sie hat 1220 in Wiltshire, England, United Kingdom Robert de Mauduit II geheiratet. Sie hatten mindestens 1 Sohn. Sie starb 1221 im Alter von 28 Jahren."},"ht":{"about 1194–1221":"about 1194–1221","1189–1246":"1189–1246","1194–1221":"1194–1221","1175–1245":"1175–1245","1221–1251":"1221–1251","1146–1198":"1146–1198","1165–1242":"1165–1242","about 1194":"about 1194","30 September 1198":"30 September 1198","1220":"1220","1242":"1242","1165":"1165","1198":"1198","1175":"1175","1251":"1251","1194":"1194","1215":"1215","1246":"1246","1146":"1146","1245":"1245","1189":"1189","1221":"1221","about 1188":"about 1188","Broughton, Oxfordshire, England":"Broughton, Oxfordshire, England","Black Bourton, Oxfordshire, England, United Kingdom":"Black Bourton, Oxfordshire, Angletè, United Kingdom","Great Somerford, Wiltshire, England":"Great Somerford, Wiltshire, England","Somerford, Wiltshire, England, Great Britain":"Wiltshire, Angletè, United Kingdom"},"hu":{"about 1194–1221":"1194 körül–1221","1189–1246":"1189–1246","1194–1221":"1194–1221","1175–1245":"1175–1245","1221–1251":"1221–1251","1146–1198":"1146–1198","1165–1242":"1165–1242","about 1194":"1194 körül","30 September 1198":"1198. szeptember 30.","1220":"1220","1242":"1242","1165":"1165","1198":"1198","1175":"1175","1251":"1251","1194":"1194","1215":"1215","1246":"1246","1146":"1146","1245":"1245","1189":"1189","1221":"1221","about 1188":"1188 körül","Broughton, Oxfordshire, England":"Broughton, Oxfordshire, England","Black Bourton, Oxfordshire, England, United Kingdom":"Black Bourton, Oxfordshire, Anglia, United Kingdom","Great Somerford, Wiltshire, England":"Great Somerford, Wiltshire, England","Somerford, Wiltshire, England, Great Britain":"Wiltshire, Anglia, United Kingdom"},"id":{"about 1194–1221":"sekitar 1194–1221","1189–1246":"1189–1246","1194–1221":"1194–1221","1175–1245":"1175–1245","1221–1251