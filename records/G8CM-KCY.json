lands":"Noord-Holland, Nederland","Antwerp, Antwerp, Belgium":"Antwerpen, Antwerpen, België","Amsterdam, North Holland, Netherlands":"Amsterdam, Noord-Holland, Nederland"},"en":{"Abt. 1530–Bef. 1567":"about 1530–before 1567","1521–1576":"1521–1576","1560–1620":"1560–1620","1564–1630":"1564–1630","1530–1567":"1530–1567","1560":"1560","abt 1560":"about 1560","5 November 1564":"5 November 1564","1567":"1567","1620":"1620","1576":"1576","1521":"1521","Bef. 1567":"before 1567","1630":"1630","1564":"1564","1530":"1530","Abt. 1530":"about 1530","21 Oct 1556":"21 October 1556","Noord-Holland, Netherlands":"North Holland, Netherlands","Antwerp, Antwerp, Belgium":"Antwerp, Antwerp, Belgium","Amsterdam, North Holland, Netherlands":"Amsterdam, North Holland, Netherlands","nameMeanings":[{"name":"Jans","type":"LAST","attribution":"Dictionary of American Family Names © Patrick Hanks 2003, 2006.","meanings":["Some characteristic forenames:  German Hans, Johannes, Klaus, Kurt, Matthias, Otto.","Dutch and North German: patronymic from the personal name   Jan  , a vernacular form of   Johannes  .","English: variant of   Janes  ."],"variants":[{"name":"Jan","meanings":["Some characteristic forenames:  Arabic/Muslim Mohammad, Mohammed, Ferdous, Momin, Sultan, Ahmad, Altaf, Ameen, Amin, Amina, Arif, Arshad.  French Pierre, Andre, Marcel, Pascale.","North German, Danish, Polish, Sorbian, and Croatian; Czech (also <b>Ján</b>); Slovak (<b>Ján</b>): from the personal name <i>Jan</i> (Slovak <i>Ján</i>), a shortened vernacular form of Latin <i>Johannes</i> (see   John  ). The Sorbian surname is found mainly in Germanized forms,   Jahn   and <b>Jähn</b>. See also   Yan  .","Slovenian: from the personal name <i>Jan</i>, a variant or a short form of <i>Janez</i>, an equivalent of   John  ."]}]},{"name":"Willim","type":"FIRST","attribution":"Dictionary of First Names © Patrick Hanks and Flavia Hodges 1990, 2003, 2006.","meanings":["Probably the most successful of all the Old French names of Germanic origin that were introduced to England by the Normans. It is derived from Germanic <i>wil</i> ‘will, desire’ + <i>helm</i> ‘helmet, protection’. The fact that it was borne by the Conqueror himself does not seem to have inhibited its favour with the ‘conquered’ population: in the first century after the Conquest it was the commonest male name of all, and not only among the Normans. In the later Middle Ages it was overtaken by   John  , but continued to run second to that name until the 20th century, when the picture became more fragmented."],"variants":[]}],"lifeSummary":"Willim Jans was born about 1530, in North Holland, Netherlands. He married Anna Thonis on 21 October 1556, in Antwerp, Antwerp, Belgium. They were the parents of at least 2 sons. He died before 1567, in his hometown."},"et":{"Abt. 1530–Bef. 1567":"umbes 1530–enne 1567","1521–1576":"1521–1576","1560–1620":"1560–1620","1564–1630":"1564–1630","1530–1567":"1530–1567","1560":"1560","abt 1560":"umbes 1560","5 November 1564":"5. november 1564","1567":"1567","1620":"1620","1576":"1576","1521":"1521","Bef. 1567":"enne 1567","1630":"1630","1564":"1564","1530":"1530","Abt. 1530":"umbes 1530","21 Oct 1556":"21. oktoober 1556","Noord-Holland, Netherlands":"Noord-Holland, Madalmaad","Antwerp, Antwerp, Belgium":"Antwerpen, Antwerpen, Belgia","Amsterdam, North Holland, Netherlands":"Amsterdam, Noord-Holland, Madalmaad"},"fi":{"Abt. 1530–Bef. 1567":"noin 1530–ennen vuotta 1567","1521–1576":"1521–1576","1560–1620":"1560–1620","1564–1630":"1564–1630","1530–1567":"1530–1567","1560":"1560","abt 1560":"noin 1560","5 November 1564":"5. marraskuuta 1564","1567":"1567","1620":"1620","1576":"1576","1521":"1521","Bef. 1567":"ennen vuotta 1567","1630":"1630","1564":"1564","1530":"1530","Abt. 1530":"noin 1530","21 Oct 1556":"21. lokakuuta 1556","Noord-Holland, Netherlands":"Noord-Holland, Alankomaat","Antwerp, Antwerp, Belgium":"Antwerpen, Antwerpen, Belgia","Amsterdam, North Holland, Netherlands":"Amsterdam, Noord-Holland