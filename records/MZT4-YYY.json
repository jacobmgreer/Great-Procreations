","1240":"1240","1170":"1170","1205":"1205","1125":"1125","1267":"1267","1168":"1168","1200":"1200","about 1205":"omkring 1205","1210":"1210","1320":"1320","about 1168":"omkring 1168","about 1240":"omkring 1240","Wales":"Wales","Dinmael, Llangwm, Denbighshire, Wales, United Kingdom":"Dinmael, Llangwm, Denbighshire, Wales, United Kingdom","Corwen, Merionethshire, Wales":"Corwen, Merionethshire, Wales","Anglesey, Wales":"Anglesey, Wales"},"nl":{"about 1168–":"circa 1168–Overleden","1168–Female":"1168–Overleden","1170–Male":"1170–Overleden","1205–Female":"1205–Overleden","1210–1267":"1210–1267","1240–1320":"1240–1320","1125–Male":"1125–Overleden","1130–1200":"1130–1200","1130":"1130","1240":"1240","1170":"1170","1205":"1205","1125":"1125","1267":"1267","1168":"1168","1200":"1200","about 1205":"circa 1205","1210":"1210","1320":"1320","about 1168":"circa 1168","about 1240":"circa 1240","Wales":"Wales","Dinmael, Llangwm, Denbighshire, Wales, United Kingdom":"Dinmael, Llangwm, Denbighshire, Wales, Verenigd Koninkrijk","Corwen, Merionethshire, Wales":"Corwen, Merionethshire, Wales","Anglesey, Wales":"Anglesey, Wales"},"en":{"about 1168–":"about 1168–Deceased","1168–Female":"1168–Deceased","1170–Male":"1170–Deceased","1205–Female":"1205–Deceased","1210–1267":"1210–1267","1240–1320":"1240–1320","1125–Male":"1125–Deceased","1130–1200":"1130–1200","1130":"1130","1240":"1240","1170":"1170","1205":"1205","1125":"1125","1267":"1267","1168":"1168","1200":"1200","about 1205":"about 1205","1210":"1210","1320":"1320","about 1168":"about 1168","about 1240":"about 1240","Wales":"Wales","Dinmael, Llangwm, Denbighshire, Wales, United Kingdom":"Dinmael, Llangwm, Denbighshire, Wales, United Kingdom","Corwen, Merionethshire, Wales":"Corwen, Merionethshire, Wales","Anglesey, Wales":"Anglesey, Wales","nameMeanings":[{"name":"FERCH","type":"LAST","attribution":"Dictionary of American Family Names © Patrick Hanks 2003, 2006.","meanings":["German: variant of   Ferg  . Compare   Verch  .","Probably also an Americanized form of German <b>Förtsch</b> (see   Foertsch  ).","Probably also an Americanized form of German <b>Förch</b> (see   Foerch  )."],"variants":[{"name":"Ferg","meanings":["German: occupational name for a ferryman, Middle High German <i>verje</i>, <i>verge</i>."]}]},{"name":"GWYN","type":"LAST","attribution":"Dictionary of American Family Names © Patrick Hanks 2003, 2006.","meanings":["Welsh (Glamorgan) and Irish: variant of   Gwin   or   Gwynne  ."],"variants":[{"name":"Gwin","meanings":["Welsh: from <i>gwyn</i> ‘fair, white’, also sometimes ‘white-headed; favorite’. This word was widely used as a personal name in the Middle Ages. It may also be a nickname for a person with fair hair or a noticeably pale complexion. See also   Winn  ."]}]},{"name":"Margaret","type":"FIRST","attribution":"Dictionary of First Names © Patrick Hanks and Flavia Hodges 1990, 2003, 2006.","meanings":["An extremely common given name from the Middle Ages onwards, derived via Old French <i>Marguerite</i> and Latin <i>Margarita</i> from Greek <i>Margarītēs</i>, from <i>margaron</i> ‘pearl’, a word ultimately of Hebrew origin. The name was always understood to mean ‘pearl’ throughout the Middle Ages. The first  St Margaret  was martyred at Antioch in Pisidia during the persecution instigated by the  Emperor Diocletian  in the early 4th century. However, there is some doubt about her name, as the same saint is venerated in the Orthodox Church as   Marina .  There were several other saintly bearers of the name, including St Margaret of Scotland (  d. 1093 ), wife of  King Malcolm Canmore  and daughter of Edmund Ironside of England. It was also the name of the wife of  Henry VI  of England,  Margaret of Anjou  (  1430–82 ), and of  Margaret Tudor  (  1489–1541 ), sister of  Henry VIII , who married James IV of Scotland and ruled as regent there after his death.  See also  Margery  ,   Marjorie ."],"variants":[{"name":"Margareta","meanings":["From the Latin form of Greek <i>Margarītēs</i>.  See  <b>Margaret</b>   ."]},{"name":"Margaretta","meanings":["An extremely common given name from the Middle Ages onwards, derived via Old French <i>Marguerite</i> and Latin <i>Margarita</i> from Greek <i>Margarītēs</i>, from <i>margaron</i> ‘pearl’, a word ultimately of Hebrew origin. The name was always understood to mean ‘pearl’ throughout the Middle Ages. The first  St Margaret  was martyred at Antioch in Pisidia during the persecution instigated by the  Emperor Diocletian  in the early 4th century. However, there is some doubt about her name, as the same saint is venerated in the Orthodox Church as   Marina .  There were several other saintly bearers of the name, including St Margaret of Scotland (  d. 1093 ), wife of  King Malcolm Canmore  and daughter of Edmund Ironside of England. It was also the name of the wife of  Henry VI  of England,  Margaret of Anjou  (  1430–82 ), and of  Margaret Tudor  (  1489–1541 ), sister of  Henry VIII , who married James IV of Scotland and ruled as regent there after his death.  See also  Margery  ,   Marjorie ."]}]}],"lifeSummary":"When Margaret FERCH GWYN was born about 1168, in Wales, her father, Gwyn Cywyn ap Gruffudd Lord of Guilsfield, was 45 and her mother, Mrs. Gwyn Ap Gruffydd, was 39. She had at least 1 son and 2 daughters with Bleddyn ap Owain Brogyntyn."},"et":{"about 1168–":"umbes 1168–Surnud","1168–Female":"1168–Surnud","1170–Male":"1170–Surnud","1205–Female":"1205–Surnud","1210–1267":"1210–1267","1240–1320":"1240–1320","1125–Male":"1125–Surnud","1130–1200":"1130–1200","1130":"1130","1240":"1240","1170":"1170","1205":"1205","1125":"1125","1267":"1267","1168":"1168","1200":"1200","about 1205":"umbes 1205","1210":"1210","1320":"1320","about 1168":"umbes 1168","about 1240":"umbes 1240","Wales":"Wales","Dinmael, Llangwm, Denbighshire, Wales, United Kingdom":"Dinmael, Llangwm, Denbighshire, Wales, United Kingdom","Corwen, Merionethshire, Wales":"Corwen, Merionethshire, Wales","Anglesey, Wales":"Anglesey,