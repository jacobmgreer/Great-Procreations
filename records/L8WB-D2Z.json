{"version":"1.2","person":{"datePublished":"2023-12-27","name":"Estrid of  Obotrites","nameForms":[{"lang":"und","fullText":"Estrid of  Obotrites","parts":[{"type":"http://gedcomx.org/Given","value":"Estrid"},{"type":"http://gedcomx.org/Surname","value":"of  Obotrites"}],"order":"EUROTYPIC"}],"alternateName":"Estred of the Obotrites","gender":"Female","lifespan":"0979–1035","fullLifespan":"about 0979–1035","memoryArtifacts":[{"memoryType":"STORY","url":"https://sg30p0.familysearch.org/service/records/storage/dascloud/patron/v2/TH-904-99542-1923-71/dist.txt?ctx=ArtCtxPublic","memoryUrl":"https://www.familysearch.org/photos/artifacts/108139519","headline":"BIO","description":"BIO:  Queen of Sweden.\n\n** from http://fmg.ac/Projects/MedLands/SWEDEN.htm#IngigerdOlafsddied1050 as of 4/26/2016\n\nESTRED of the Obotrites, daughter of ---.  Adam of Bremen names \"filiamque Sclavorum …","@type":"MediaObject"},{"memoryType":"PHOTO","url":"https://sg30p0.familysearch.org/service/records/storage/dascloud/patron/v2/TH-904-92180-11684-90/dist.png?ctx=ArtCtxPublic","memoryUrl":"https://www.familysearch.org/photos/artifacts/90874609","thumbnailUrl":"https://sg30p0.familysearch.org/service/records/storage/dascloud/patron/v2/TH-904-92180-11684-90/thumb200s.jpg?ctx=ArtCtxPublic","deepZoomUrl":"https://sg30p0.familysearch.org/service/records/storage/deepzoomcloud/dzpatron/v1/TH-904-92180-11684-90/scale?ctx=ArtCtxPublic","headline":"Main territory of the Obotritic tribes","@type":"ImageObject"}],"popularStory":{"memoryType":"STORY","url":"https://sg30p0.familysearch.org/service/records/storage/dascloud/patron/v2/TH-904-99542-1923-71/dist.txt?ctx=ArtCtxPublic","memoryUrl":"https://www.familysearch.org/photos/artifacts/108139519","headline":"BIO","description":"BIO:  Queen of Sweden.\n\n** from http://fmg.ac/Projects/MedLands/SWEDEN.htm#IngigerdOlafsddied1050 as of 4/26/2016\n\nESTRED of the Obotrites, daughter of ---.  Adam of Bremen names \"filiamque Sclavorum …","@type":"MediaObject"},