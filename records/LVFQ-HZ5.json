an, Aberdeenshire, Scotland":"Buchan, Aberdeenshire, Scotland"},"ms":{"1145–1179":"1145–1179","1165–1199":"1165–1199","1120–1180":"1120–1180","1179":"1179","1145":"1145","1199":"1199","1165":"1165","1120":"1120","1140":"1140","1180":"1180","Buchan, Aberdeenshire, Scotland":"Buchan, Aberdeenshire, Scotland"},"mn":{"1145–1179":"1145он–1179он","1165–1199":"1165он–1199он","1120–1180":"1120он–1180он","1179":"1179 он","1145":"1145 он","1199":"1199 он","1165":"1165 он","1120":"1120 он","1140":"1140 он","1180":"1180 он","Buchan, Aberdeenshire, Scotland":"Buchan, Coontie o Aiberdeen, Шотланд"},"no":{"1145–1179":"1145–1179","1165–1199":"1165–1199","1120–1180":"1120–1180","1179":"1179","1145":"1145","1199":"1199","1165":"1165","1120":"1120","1140":"1140","1180":"1180","Buchan, Aberdeenshire, Scotland":"Buchan, Aberdeenshire, Scotland"},"pl":{"1145–1179":"1145r.–1179r.","1165–1199":"1165r.–1199r.","1120–1180":"1120r.–1180r.","1179":"1179 r.","1145":"1145 r.","1199":"1199 r.","1165":"1165 r.","1120":"1120 r.","1140":"1140 r.","1180":"1180 r.","Buchan, Aberdeenshire, Scotland":"Buchan, Aberdeenshire, Scotland"},"pt":{"1145–1179":"1145–1179","1165–1199":"1165–1199","1120–1180":"1120–1180","1179":"1179","1145":"1145","1199":"1199","1165":"1165","1120":"1120","1140":"1140","1180":"1180","Buchan, Aberdeenshire, Scotland":"Buchan, Aberdeenshire, Scotland","lifeSummary":"Roger Buchan 3rd Earl  of Buchan nasceu em 1145, em Buchan, Aberdeenshire, Scotland filho de Colban Mormaer of Buchan. Ele teve pelo menos 1 filho. Ele faleceu em 1179, em sua cidade natal, com 34 anos, e foi sepultado em Buchan, Aberdeenshire, Scotland."},"ro":{"1145–1179":"1145–1179","1165–1199":"1165–1199","1120–1180":"1120–1180","1179":"1179","1145":"1145","1199":"1199","1165":"1165","1120":"1120","1140":"1140","1180":"1180","Buchan, Aberdeenshire, Scotland":"Buchan, Aberdeenshire, Scotland"},"ru":{"1145–1179":"1145г.–1179г.","1165–1199":"1165г.–1199г.","1120–1180":"1120г.–1180г.","1179":"1179 г.","1145":"1145 г.",