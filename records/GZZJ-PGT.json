ngland":"Sedgemoor, Somerset, England, United Kingdom","Sedgemoor, Somerset, England":"Sedgemoor, Somerset, England"},"nl":{"1350–1410":"1350–1410","1352–1410":"1352–1410","1375–1472":"1375–1472","1320–1380":"1320–1380","1323–1380":"1323–1380","1323":"1323","1410":"1410","1375":"1375","1320":"1320","1352":"1352","1472":"1472","1350":"1350","1382":"1382","1370":"1370","1380":"1380","Wooley, Sedgemoor, Somerset, England":"Sedgemoor, Somerset, Engeland, Verenigd Koninkrijk","Wooley, Cambridgeshire, England":"Cambridgeshire, England","Wooley, Sedgemoor, Somersetshire, England":"Sedgemoor, Somerset, Engeland, Verenigd Koninkrijk","Sedgemoor, Somerset, England":"Sedgemoor, Somerset, England"},"en":{"1350–1410":"1350–1410","1352–1410":"1352–1410","1375–1472":"1375–1472","1320–1380":"1320–1380","1323–1380":"1323–1380","1323":"1323","1410":"1410","1375":"1375","1320":"1320","1352":"1352","1472":"1472","1350":"1350","1382":"1382","1370":"1370","1380":"1380","Wooley, Sedgemoor, Somerset, England":"Sedgemoor, Somerset, England, United Kingdom","Wooley, Cambridgeshire, England":"Cambridgeshire, England","Wooley, Sedgemoor, Somersetshire, England":"Sedgemoor, Somerset, England, United Kingdom","Sedgemoor, Somerset, England":"Sedgemoor, Somerset, England","nameMeanings":[{"name":"Wheatley","type":"LAST","attribution":"Dictionary of American Family Names © Patrick Hanks 2003, 2006.","meanings":["English: habitational name from any of various places called Wheatley, for example in Essex, Lancashire, Nottinghamshire, Oxfordshire, and Yorkshire, or from Whatley in Somerset and Whateley in Warwickshire, all name of which are named with Old English <i>hwǣte</i> ‘wheat’ + <i>lēah</i> ‘(woodland) clearing’. Compare   Whatley  ."],"variants":[{"name":"Wheetley","meanings":["English (Lancashire): variant of   Wheatley  . This surname is now rare in Britain."]},{"name":"Watley","meanings":["English: variant of   Wheatley  ."]},{"name":"Wheatly","meanings":["English: variant of   Wheatley  ."]},{"name":"Wadley","meanings":["English: habitational name from numerous places. In southern England this can be derived from Wadley in Faringdon (Berkshire), or perhaps from Whatley (Somerset), Whateley in Kingsbury (Warwickshire), Wheatley (Oxfordshire), or Wheatley in Rayleigh (Essex), the latter of which often appears as <i>Watelegh</i> in the medieval records. The Berkshire placename derives from the Old English personal name <i>Wada</i> + Old English <i>lēah</i> ‘woodland clearing’. The other placenames derive from Old English <i>hwǣte</i> ‘wheat’ + <i>lēah</i>. Compare   Wheatley  . In some instances where the name originates from southeastern England, <i>Wadley</i> may alternatively be a post-medieval variant of   Wadlow  . In northern England, primarily Durham, this is a habitational name from Wadley in Witton le Wear (Durham). The placename derives from the Old English personal name <i>Wada</i>, <i>Wadda</i> + Old English <i>lēah</i>."]},{"name":"Whatley","meanings":["English (Wiltshire and Somerset): variant of   Wheatley  . A habitational name from any of various places called with Old English <i>hwǣte</i> ‘wheat’ + <i>lēah</i> ‘woodland clearing’, as for example Whatley in Somerset, Whately in Warwickshire, or any of the places mentioned under   Wheatley  ."]}]},{"name":"Thomas","type":"FIRST","attribution":"Dictionary of First Names © Patrick Hanks and Flavia Hodges 1990, 2003, 2006.","meanings":["New Testament name, borne by one of Christ's twelve apostles, referred to as ‘Thomas, called Didymus’ (John 11:16; 20:24). <i>Didymos</i> is the Greek word for ‘twin’, and the name is the Greek form of an Aramaic byname meaning ‘twin’. The given name has always been popular throughout Christendom, in part because St Thomas's doubts have made him seem a very human character."],"variants":[]}],"historicEvents":[{"id":1705195,"age":32,"year":"1382","julianDay":2225826,"title":"Wycliffe's Bible","description":"John Wycliffe, English theologian and professor at the University of Oxford, completed a translation of the Bible from the Latin Vulgate into Middle English. This translation is known as Wycliffe's Bible and was completed around 1382.","url":"https://en.wikipedia.org/wiki/Wycliffe%27s_Bible","urlTitle":"Wikipedia - Wycliffe's Bible","jurisdictionLevel":2}],"lifeSummary":"When Sir Thomas Wheatley was born in 1350, in Sedgemoor, Somerset, England, his father, John Wheatley, was 30 and his mother, Ann, was 27. He married Mary Woodruff in 1370, in Cambridgeshire, England. They were the parents of at least 1 son. He died in 1410, in Sedgemoor, Somerset, England, United Kingdom, at the age of 60."},"et":{"1350–1410":"1350–1410","1352–1410":"1352–1410","1375–1472":"1375–1472","1320–1380":"1320–1380","1323–1380":"1323–1380","1323":"1323","1410":"1410","1375":"1375","1320":"1320","1352":"1352","1472":"1472","1350":"1350","1382":"1382","1370":"1370","1380":"1380","Wooley, Sedgemoor, Somerset, England":"Sedgemoor, Somerset, Inglismaa, United Kingdom","Wooley, Cambridgeshire, England":"Cambridgeshire, England","Wooley, Sedgemoor, Somersetshire, England":"Sedgemoor, Somerset, Inglismaa, United Kingdom","Sedgemoor, Somerset, England":"Sedgemoor, Somerset, England"},"fi":{"1350–1410":"1350–1410","1352–1410":"1352–1410","1375–1472":"1375–1472","1320–1380":"1320–1380","1323–1380":"1323–1380","1323":"1323","1410":"1410","1375":"1375","1320":"1320","1352":"1352","1472":"1472","1350":"1350","1382":"1382","1370":"1370","1380":"1380","Wooley, Sedgemoor, Somerset, England":"Sedgemoor, Somerset, Englanti, Yhdistynyt kuningaskunta","Wooley, Cambridgeshire, England":"Cambridgeshire, England","Wooley, Sedgemoor, Somersetshire, England":"Sedgemoor, Somerset, Englanti, Yhdistynyt kuningaskunta","Sedgemoor, Somerset, England":"Sedgemoor, Somerset, England"},"fr":{"1350–1410":"1350–1410","1352–1410":"1352–1410","1375–1472":"1375–1472","1320–1380":"1320–1380","1323–1380":"1323–1380","1323":"1323","1410":"1410","1375":"1375","1320":"1320","1352":"13