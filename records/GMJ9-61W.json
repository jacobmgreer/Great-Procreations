35–1243":"1135–1243","1137–1220":"1137–1220","1139–Male":"1139–Deceased","1141–Female":"1141–Deceased","1086–1130":"1086–1130","1087–Female":"1087–Deceased","1220":"1220","1120":"1120","1087":"1087","1130":"1130","1086":"1086","1141":"1141","1139":"1139","1137":"1137","1225":"1225","1126":"1126","1135":"1135","about 1139":"about 1139","1199":"1199","1243":"1243","1177":"1177","about 1137":"about 1137","about 1135":"about 1135","about 1141":"about 1141","Laxton, Northamptonshire, England":"Laxton, Northamptonshire, England","Turvey, Bedfordshire, England":"Turvey, Bedfordshire, England","Pytchley, Kettering, Northamptonshire, England":"Pytchley, Northamptonshire, England","nameMeanings":[{"name":"Joice","type":"FIRST","attribution":"Dictionary of First Names © Patrick Hanks and Flavia Hodges 1990, 2003, 2006.","meanings":["Apparently from the Norman male name <i>Josce</i> (Middle English <i>Josse</i>), which in turn is from <i>Jodocus</i>, a Latinized form of a Breton name, <i>Iodoc</i>, meaning ‘lord’, borne by a 7th-century Breton saint. The name was in use in England among Breton followers of William the Conqueror. However, although this was fairly common as a male given name in the Middle Ages, it had virtually died out by the 14th century. There is evidence of its use as a girl's name from the 16th century onwards in parishes with strong Puritan links, which suggests that it may have been associated with the vocabulary word <i>joy</i>;  see  Joy .  It was strongly revived in the 19th century under the influence of popular fiction. It is borne by characters in Mrs  Henry Wood's  East Lynne (  1861 ) and  Edna Lyall's  In the Golden Days (  1885 ). Modern use may well have been influenced also by the common Irish surname derived from the medieval Norman male name.  See also  Joss ."],"variants":[]}],"lifeSummary":"When Joice d'Engaine was born in 1120, in Laxton, Northamptonshire, England, her father, Viel d'Engaine, was 34 and her mother, Alice de Lisours, was 33. She had at least 1 son and 3 daughters with William d'Alneto. She died in 1199, at the age of 79."},"et":{"1120–1199":"1120–1199","1126–Female":"1126–Surnud","1130–1177":"1130–1177","1130–1225":"1130–1225","1135–1243":"1135–1243","1137–1220":"1137–1220","1139–Male":"1139–Surnud","1141–Female":"1141–Surnud","1086–1130":"1086–1130","1087–Female":"1087–Surnud","1220":"1220","1120":"1120","1087":"1087","1130":"1130","1086":"1086","1141":"1141","1139":"1139","1137":"1137","1225":"1225","1126":"1126","1135":"1135","about 1139":"umbes 1139","1199":"1199","1243":"1243","1177":"1177","about 1137":"umbes 1137","about 1135":"umbes 1135","about 1141":"umbes 1141","Laxton, Northamptonshire, England":"Laxton, Northamptonshire, England","Turvey, Bedfordshire, England":"Turvey, Bedfordshire, England","Pytchley, Kettering, Northamptonshire, England":"Pytchley, Northamptonshire, England"},"fi":{"1120–1199":"1120–1199","1126–Female":"1126–Kuollut","1130–1177":"1130–1177","1130–1225":"1130–1225","1135–1243":"1135–1243","1137–1220":"1137–1220","1139–Male":"1139–Kuollut","1141–Female":"1141–Kuollut","1086–1130":"1086–1130","1087–Female":"1087–Kuollut","1220":"1220","1120":"1120","1087":"1087","1130":"1130","1086":"1086","1141":"1141","1139":"1139","1137":"1137","1225":"1225","1126":"1126","1135":"1135","about 1139":"noin 1139","1199":"1199","1243":"1243","1177":"1177","about 1137":"noin 1137","about 1135":"noin 1135","about 1141":"noin 1141","Laxton, Northamptonshire, England":"Laxton, Northamptonshire, England","Turvey, Bedfordshire, England":"Turvey, Bedfordshire, England","Pytchley, Kettering, Northamptonshire, England":"Pytchley, Northamptonshire, England"},"fr":{"1120–1199":"1120–1199","1126–Female":"1126–Décédée","1130–1177":"1130–1177","1130–1225":"1130–1225","1135–1243":"1135–1243","1137–1220":"1137–1220","1139–Male":"1139–Décédé","1141–Female":"1141–Décédée","1086–1130":"1086–1130","1087–Female":"1087–Décédée","1220":"1220","1120":"1120","1087":"1087","1130":"1130","1086":"108