male":"1617–Deceased","1582–1677":"1582–1677","1582–1624":"1582–1624","1671":"1671","1582":"1582","1 March 1617":"1 March 1617","1657":"1657","1624":"1624","1613":"1613","1677":"1677","1644":"1644","1621":"1621","1610":"1610","1598":"1598","1664":"1664","1618":"1618","1617":"1617","1606":"1606","January 1624":"January 1624","1604":"1604","1669":"1669","Warwick, Warwickshire, England":"Warwick, Warwickshire, England, United Kingdom","Kingston on the Hull, Yorkshire, England":"Yorkshire, England, United Kingdom","Hull, Yorkshire, England":"Hull, Yorkshire, England","nameMeanings":[{"name":"Whitby","type":"LAST","attribution":"Dictionary of American Family Names © Patrick Hanks 2003, 2006.","meanings":["English: habitational name from Whitby, a port in North Yorkshire, or from Whitby in Cheshire. The North Yorkshire placename probably derives from the Old Norse personal name <i>Hvíti</i> or Old Norse <i>hvítr</i> ‘white’ + <i>bý</i> ‘farmstead, village’. The Cheshire placename derives from Old English <i>hwīt</i> ‘white’ + <i>burg</i> ‘fortress’, later replaced by Old Norse <i>bý</i>."],"variants":[{"name":"Whidby","meanings":["English (Durham and East Anglia): variant of English   Whitby  ."]},{"name":"Whidbee","meanings":["English: variant of   Whitby  ."]}]},{"name":"William","type":"FIRST","attribution":"Dictionary of First Names © Patrick Hanks and Flavia Hodges 1990, 2003, 2006.","meanings":["Probably the most successful of all the Old French names of Germanic origin that were introduced to England by the Normans. It is derived from Germanic <i>wil</i> ‘will, desire’ + <i>helm</i> ‘helmet, protection’. The fact that it was borne by the Conqueror himself does not seem to have inhibited its favour with the ‘conquered’ population: in the first century after the Conquest it was the commonest male name of all, and not only among the Normans. In the later Middle Ages it was overtaken by   John  , but continued to run second to that name until the 20th century, when the picture became more fragmented."],"variants":[]}],"lifeSummary":"When William Whitby III was born in 1598, in Yorkshire, England, United Kingdom, his father, William Whitby, was 16 and his mother, Flower Pearson, was 16. He had at least 1 daughter with Ruth Katherine Gorsuch. He died in 1669, in Warwick, Warwickshire, England, United Kingdom, at the age of 71."},"et":{"1598–1669":"1598–1669","1604–1618":"1604–1618","1606–Male":"1606–Surnud","1610–1671":"1610–1671","1613–1664":"1613–1664","1621–Female":"1621–Surnud","1644–1657":"1644–1657","1617–Female":"1617–Surnud","1582–1677":"1582–1677","1582–1624":"1582–1624","1671":"1671","1582":"1582","1 March 1617":"1. märts 1617","1657":"1657","1624":"1624","1613":"1613","1677":"1677","1644":"1644","1621":"1621","1610":"1610","1598":"1598","1664":"1664","1618":"1618","1617":"1617","1606":"1606","January 1624":"jaanuar 1624","1604":"1604","1669":"1669","Warwick, Warwickshire, England":"Warwick, Warwickshire, Inglismaa, United Kingdom","Kingston on the Hull, Yorkshire, England":"Yorkshire, Inglismaa, United Kingdom","Hull, Yorkshire, England":"Hull, Yorkshire, England"},"fi":{"1598–1669":"1598–1669","1604–1618":"1604–1618","1606–Male":"1606–Kuollut","1610–1671":"1610–1671","1613–1664":"1613–1664","1621–Female":"1621–Kuollut","1644–1657":"1644–1657","1617–Female":"1617–Kuollut","1582–1677":"1582–1677","1582–1624":"1582–1624","1671":"1671","1582":"1582","1 March 1617":"1. maaliskuuta 1617","1657":"1657","1624":"1624","1613":"1613","1677":"1677","1644":"1644","1621":"1621","1610":"1610","1598":"1598","1664":"1664","1618":"1618","1617":"1617","1606":"1606","January 1624":"tammikuu 1624","1604":"1604","1669":"1669","Warwick, Warwickshire, England":"Warwick, Warwickshire, Englanti, Yhdistynyt kuningaskunta","Kingston on the Hull, Yorkshire, England":"Yorkshire, Englanti, Yhdistynyt kuningaskunta","Hull, Yorkshire, England":"Hull, Yorkshire, England"},"fr":{"1598–1669":"1598–1669","1604–1618":"1604–1618","1606–Male":"1606–Décédé","1