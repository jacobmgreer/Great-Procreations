124":"1124","1145":"1145","1176":"1176","1154":"1154","1230":"1230","about 1145":"omkring 1145","about 1143":"omkring 1143","about 1166":"omkring 1166","Rufford, Lancashire, England":"Rufford, Lancashire, England","England":"England","Hesketh Bank, Lancashire, England":"Hesketh Bank, Lancashire, England"},"nl":{"about 1145–":"circa 1145–Overleden","1145–Male":"1145–Overleden","1154–Female":"1154–Overleden","1176–1230":"1176–1230","–Male":"Overleden","1124–Male":"1124–Overleden","1125–Female":"1125–Overleden","1259":"1259","1215":"1215","1224":"1224","1125":"1125","1124":"1124","1145":"1145","1176":"1176","1154":"1154","1230":"1230","about 1145":"circa 1145","about 1143":"circa 1143","about 1166":"circa 1166","Rufford, Lancashire, England":"Rufford, Lancashire, England","England":"England","Hesketh Bank, Lancashire, England":"Hesketh Bank, Lancashire, England"},"en":{"about 1145–":"about 1145–Deceased","1145–Male":"1145–Deceased","1154–Female":"1154–Deceased","1176–1230":"1176–1230","–Male":"Deceased","1124–Male":"1124–Deceased","1125–Female":"1125–Deceased","1259":"1259","1215":"1215","1224":"1224","1125":"1125","1124":"1124","1145":"1145","1176":"1176","1154":"1154","1230":"1230","about 1145":"about 1145","about 1143":"about 1143","about 1166":"about 1166","Rufford, Lancashire, England":"Rufford, Lancashire, England","England":"England","Hesketh Bank, Lancashire, England":"Hesketh Bank, Lancashire, England","nameMeanings":[{"name":"Hesketh","type":"LAST","attribution":"Dictionary of American Family Names © Patrick Hanks 2003, 2006.","meanings":["English (Lancashire and Cheshire): habitational name from Hesketh (Lancashire), Hesketh Grange in Felixkirk (North Yorkshire), or Hesket in the Forest (Cumberland). The placenames derive from Old Norse <i>hestr</i> ‘horse, stallion’ + <i>skeith</i> ‘course, track, race course’. The ancient Scandinavians were fond of horse-racing and horse-fighting, and introduced both pastimes to England."],"variants":[{"name":"Heskett","meanings":["English (Cumberland and Lancashire): variant of   Hesketh  ."]}]},{"name":"William","type":"FIRST","attribution":"Dictionary of First Names © Patrick Hanks and Flavia Hodges 1990, 2003, 2006.","meanings":["Probably the most successful of all the Old French names of Germanic origin that were introduced to England by the Normans. It is derived from Germanic <i>wil</i> ‘will, desire’ + <i>helm</i> ‘helmet, protection’. The fact that it was borne by the Conqueror himself does not seem to have inhibited its favour with the ‘conquered’ population: in the first century after the Conquest it was the commonest male name of all, and not only among the Normans. In the later Middle Ages it was overtaken by   John  , but continued to run second to that name until the 20th century, when the picture became more fragmented."],"variants":[]}],"historicEvents":[{"id":1705187,"age":70,"year":"1215","julianDay":2164830,"title":"Magna Carta","description":"King John of England agreed to a charter of rights called the Magna Carta. The document was originally drafted by the Archbishop of Canterbury to establish peace between King John and a group of rebel barons. The Magna Carta was completed in 1215 and is now considered to be one of the greatest constitutional documents of all time.","url":"https://www.nationalarchives.gov.uk/education/medieval/magna-carta/","urlTitle":"National Archives - Magna Carta","jurisdictionLevel":2},{"id":1705188,"age":79,"year":"1224","julianDay":2168117,"title":"France Declares War on England","description":"France declared war on England as Louis VIII of France attacked Poitou and northern Gascony.","jurisdictionLevel":2},{"id":1705189,"age":114,"year":"1259","julianDay":2180901,"title":"100 Years of Conflict Between England and France Ends","description":"Treaty of Paris was signed on December 4, 1259, which ended 100 years of conflict between England and France.","url":"https://en.wikipedia.org/wiki/Treaty_of_Paris_(1259)","urlTitle":"Wikipedia - Treaty of Paris 1259","jurisdictionLevel":2}],"lifeSummary":"When William Hesketh was born about 1145, in Rufford, Lancashire, England, his father, Richard de Heskayth, was 22 and his mother, Annabel de Stafford, was 21. He married Annabel de Stafford about 1166, in England. They were the parents of at least 2 sons. He died in his hometown."},"et":{"about 1145–":"umbes 1145–Surnud","1145–Male":"1145–Surnud","1154–Female":"1154–Surnud","1176–1230":"1176–1230","–Male":"Surnud","1124–Male":"1124–Surnud","1125–Female":"1125–Surnud","1259":"1259","1215":"1215","1224":"1224","1125":"1125","1124":"1124","1145":"1145","1176":"1176","1154":"1154","1230":"1230","about 1145":"umbes 1145","about 1143":"umbes 1143","about 1166":"umbes 1166","Rufford, Lancashire, England":"Rufford, Lancashire, England","England":"England","Hesketh Bank, Lancashire, England":"Hesketh Bank, Lancashire, England"},"fi":{"about 1145–":"noin 1145–Kuollut","1145–Male":"1145–Kuollut","1154–Female":"1154–Kuollut","1176–1230":"1176–1230","–Male":"Kuollut","1124–Male":"1124–Kuollut","1125–Female":"1125–Kuollut","1259":"1259","1215":"1215","1224":"1224","1125":"1125","1124":"1124","1145":"1145","1176":"1176","1154":"1154","1230":"1230","about 1145":"noin 1145","about 1143":"noin 1143","about 1166":"noin 1166","Rufford, Lancashire, England":"Rufford, Lancashire, England","England":"England","Hesketh Bank, Lancashire, England":"Hesketh Bank, Lancashire, England"},"fr":{"about 1145–":"environ 1145–Décédé","1145–Male":"1145–Décédé","1154–Female":"1154–Décédée","1176–1230":"1176–1230","–Male":"Décédé","1124–Male":"1124–Décédé","1125–Female":"1125–Décédée","1259":"1259","1215":"1215","1224":"1224","1125":"1125","1124":"1124","1145":"1145","1176":"1176","1154":"1154","1230":"1230","about 1145":"environ 1145","about 1143":"environ 1143","about 1166":"environ 1166","Rufford, Lancashire, England":"Rufford, Lancashire, Angleterre","England":"Angleterre","Hesketh Bank, Lancashire, England":"Hesketh Bank, Lancashire, An