0–Male":"1330–Afdød","1359–1395":"1359–1395","1379–1416":"1379–1416","1382–1495":"1382–1495","1295–1348":"1295–1348","–Female":"Afdød","about March 1382":"omkring marts 1382","1363":"1363","1495":"1495","1330":"1330","1395":"1395","1383":"1383","1295":"1295","1382":"1382","1348":"1348","1359":"1359","about 1329":"omkring 1329","1379":"1379","1416":"1416","Colne, Lancashire, England":"Colne, Lancashire, England","Somerset, England":"Somerset, England","Radstock, Somerset, England":"Radstock, Somerset, England, United Kingdom","Wheathill, Somerset, England":"Wheathill, Somerset, England"},"nl":{"1363–1383":"1363–1383","1330–Male":"1330–Overleden","1359–1395":"1359–1395","1379–1416":"1379–1416","1382–1495":"1382–1495","1295–1348":"1295–1348","–Female":"Overleden","about March 1382":"circa maart 1382","1363":"1363","1495":"1495","1330":"1330","1395":"1395","1383":"1383","1295":"1295","1382":"1382","1348":"1348","1359":"1359","about 1329":"circa 1329","1379":"1379","1416":"1416","Colne, Lancashire, England":"Colne, Lancashire, England","Somerset, England":"Somerset, England","Radstock, Somerset, England":"Radstock, Somerset, Engeland, Verenigd Koninkrijk","Wheathill, Somerset, England":"Wheathill, Somerset, England"},"en":{"1363–1383":"1363–1383","1330–Male":"1330–Deceased","1359–1395":"1359–1395","1379–1416":"1379–1416","1382–1495":"1382–1495","1295–1348":"1295–1348","–Female":"Deceased","about March 1382":"about March 1382","1363":"1363","1495":"1495","1330":"1330","1395":"1395","1383":"1383","1295":"1295","1382":"1382","1348":"1348","1359":"1359","about 1329":"about 1329","1379":"1379","1416":"1416","Colne, Lancashire, England":"Colne, Lancashire, England","Somerset, England":"Somerset, England","Radstock, Somerset, England":"Radstock, Somerset, England, United Kingdom","Wheathill, Somerset, England":"Wheathill, Somerset, England","nameMeanings":[{"name":"Wellesley","type":"LAST","attribution":"Dictionary of American Family Names © Patrick Hanks 2003, 2006.","meanings":["English: habitational name from Wellesley Farm near Wells (Somerset). The placename probably derives from the genitive case of Old English <i>wella</i> ‘spring, stream’ + <i>lēah</i> ‘woodland clearing’. It was later interpreted as ‘woodland belonging to (the town of) Wells’."],"variants":[]},{"name":"Elizabeth","type":"FIRST","attribution":"Dictionary of First Names © Patrick Hanks and Flavia Hodges 1990, 2003, 2006.","meanings":["The usual spelling of   Elisabeth   in English. It is recorded in the medieval period, but was made popular by being borne by  Queen Elizabeth I  of England (  1533–1603 ). In the 20th century it again became extremely fashionable, partly because it was the name of  Elizabeth Bowes-Lyon  (  1900–2002 ), who in  1936  became Queen Elizabeth as the wife of King George VI, and after his death in  1952  achieved great public affection as Queen Mother for nearly half a century. Even more influentially, it is the name of her daughter  Queen Elizabeth II  (  b. 1926 )."],"variants":[{"name":"Elisabeth","meanings":["The spelling of   Elizabeth   used in the Authorized Version of the New Testament, and in most modern European languages. This was the name of the mother of John the Baptist (Luke 1:60). Etymologically, the name means ‘God is my oath’, and is therefore identical with <i>Elisheba</i>, the name of the wife of Aaron according to the genealogy at Exodus 6:23. The final element seems to have been altered by association with Hebrew <i>shabbāth</i> ‘Sabbath’."]}]}],"historicEvents":[{"id":1705195,"age":19,"year":"1382","julianDay":2225826,"title":"Wycliffe's Bible","description":"John Wycliffe, English theologian and professor at the University of Oxford, completed a translation of the Bible from the Latin Vulgate into Middle English. This translation is known as Wycliffe's Bible and was completed around 1382.","url":"https://en.wikipedia.org/wiki/Wycliffe%27s_Bible","urlTitle":"Wikipedia - Wycliffe's Bible","jurisdictionLevel":1}],"lifeSummary":"Elizabeth Wellesley was born in 1363, in Radstock, Somerset, England as the daughter of Phillip de Wellesley and Mrs Phillip de Wellesley. She married William Banastre II in 1383, in Radstock, Somerset, England, United Kingdom. They were the parents of at least 1 son and 1 daughter. She died in 1383, in Somerset, England, at the age of 20."},"et":{"1363–1383":"1363–1383","1330–Male":"1330–Surnud","1359–1395":"1359–1395","1379–1416":"1379–1416","1382–1495":"1382–1495","1295–1348":"1295–1348","–Female":"Surnud","about March 1382":"umbes märts 1382","1363":"1363","1495":"1495","1330":"1330","1395":"1395","1383":"1383","1295":"1295","1382":"1382","1348":"1348","1359":"1359","about 1329":"umbes 1329","1379":"1379","1416":"1416","Colne, Lancashire, England":"Colne, Lancashire, England","Somerset, England":"Somerset, England","Radstock, Somerset, England":"Radstock, Somerset, Inglismaa, United Kingdom","Wheathill, Somerset, England":"Wheathill, Somerset, England"},"fi":{"1363–1383":"1363–1383","1330–Male":"1330–Kuollut","1359–1395":"1359–1395","1379–1416":"1379–1416","1382–1495":"1382–1495","1295–1348":"1295–1348","–Female":"Kuollut","about March 1382":"noin maaliskuu 1382","1363":"1363","1495":"1495","1330":"1330","1395":"1395","1383":"1383","1295":"1295","1382":"1382","1348":"1348","1359":"1359","about 1329":"noin 1329","1379":"1379","1416":"1416","Colne, Lancashire, England":"Colne, Lancashire, England","Somerset, England":"Somerset, England","Radstock, Somerset, England":"Radstock, Somerset, Englanti, Yhdistynyt kuningaskunta","Wheathill, Somerset, England":"Wheathill, Somerset, England"},"fr":{"1363–1383":"1363–1383","1330–Male":"1330–Décédé","1359–1395":"1359–1395","1379–1416":"1379–1416","1382–1495":"1382–1495","1295–1348":"1295–1348","–Female":"Décédée","about March 1382":"environ mars 1382","1363":"1363","1495":"1495","1330":"1330","1395":"1395","1383":"1383","1295":"1295","1382":"1382","1348":"1348","1359":"1359","about 1329":"environ 1329","1379":"1379