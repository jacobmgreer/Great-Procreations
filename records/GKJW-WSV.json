dascloud/patron/v2/TH-7707-125103-456396-9/thumb200s.jpg?ctx=ArtCtxPublic","deepZoomUrl":"https://sg30p0.familysearch.org/service/records/storage/deepzoomcloud/dzpatron/v1/TH-7707-125103-456396-9/scale?ctx=ArtCtxPublic","@type":"ImageObject"},{"memoryType":"PHOTO","url":"https://sg30p0.familysearch.org/service/records/storage/dascloud/patron/v2/TH-7753-127803-5186-0/dist.jpg?ctx=ArtCtxPublic","memoryUrl":"https://www.familysearch.org/photos/artifacts/180864353","thumbnailUrl":"https://sg30p0.familysearch.org/service/records/storage/dascloud/patron/v2/TH-7753-127803-5186-0/thumb200s.jpg?ctx=ArtCtxPublic","deepZoomUrl":"https://sg30p0.familysearch.org/service/records/storage/deepzoomcloud/dzpatron/v1/TH-7753-127803-5186-0/scale?ctx=ArtCtxPublic","headline":"de la Haye coa","@type":"ImageObject"},{"memoryType":"PHOTO","url":"https://sg30p0.familysearch.org/service/records/storage/dascloud/patron/v2/TH-7707-125103-456733-28/dist.jpg?ctx=ArtCtxPublic","memoryUrl":"https://www.familysearch.org/photos/artifacts/172457472","thumbnailUrl":"https://sg30p0.familysearch.org/service/records/storage/dascloud/patron/v2/TH-7707-125103-456733-28/thumb200s.jpg?ctx=ArtCtxPublic","deepZoomUrl":"https://sg30p0.familysearch.org/service/records/storage/deepzoomcloud/dzpatron/v1/TH-7707-125103-456733-28/scale?ctx=ArtCtxPublic","@type":"ImageObject"},{"memoryType":"PHOTO","url":"https://sg30p0.familysearch.org/service/records/storage/dascloud/patron/v2/TH-7767-126407-4727-52/dist.jpg?ctx=ArtCtxPublic","memoryUrl":"https://www.familysearch.org/photos/artifacts/177077820","thumbnailUrl":"https://sg30p0.familysearch.org/service/records/storage/dascloud/patron/v2/TH-7767-126407-4727-52/thumb200s.jpg?ctx=ArtCtxPublic","deepZoomUrl":"https://sg30p0.familysearch.org/service/records/storage/deepzoomcloud/dzpatron/v1/TH-7767-126407-4727-52/scale?ctx=ArtCtxPublic","@type":"ImageObject"}],"birthPlace":{"address":"Scotland","geo":{"latitude":56.81674,"longitude":-4.18396,"@type":"GeoCoordinates"},"@type":"Place"},"deathPlace":{"address":"Scotland","geo":{"latitude":56.81674,"longitude":-4.18396,"@type":"GeoCoordinates"},"@type":"Place"},"userCertifiedLifeSummary":"Biography\nThomas was the son of Gilbert de Haye, of Locherworth of the Tweeddale branch of the Hays family and Margaret Fraser, daughter and co-heiress of Sir Simon Fraser of Oliver Castle. Thomas's father was executed by Edward I in 1306, therefore, Thomas's estimated date of birth likely occurred before or circa 1306.\n\nHe married firstly, Lora, widow of Richard de Bykretone, and daughter and heir of Sir William de Cuningesburgh and an unknown mother before 28 Aug 1306.\n\nTheir marriage produced the following issue:\n1.) William, heir\n\n2.) John. of Tullybody (possibly a grandson)\n\nHe married secondly, Christina Wardlaw about 1325.\n\nThey had issue:\n1.) Thomas\n\n2.) Dorothea, m. William Cuming 2nd son of the Earle of Buchan\n\n3.) Isabella, m. Roger Dalglee of Innerwick\n\n4.) Cecilia, m. Walter Lighton of Olishaven\n\n5.) Magdalen, m. Gilbert Mannemedille, of Storckmartin\n\n6.) Christiana, m. Alexander Ramesy of Dalhousie\n\nThomas likely died before 15 October 1335, as his son William succeeded him on this date.\n\nResearch Notes\nThomas Hay was the son of Gilbert de Hay of Locherworth and grandson to Sir William de Hay of Locherworth, members of the Tweeddale branch of the Hays family. He was not the son of Gilbert de Hay of Errol, as no evidence has been found to support this relationship and has been detached as Gilbert's son.\n\nThe Spectator, London: John Campbell, 1865, Vol 38,The Hays of Yester","sourceList":[{"title":"Thomas De La Haye","sourceType":"DEFAULT","sourceLink":"https://www.myheritage.com/research/record-1-1515510122-2-21764/thomas-de-la-haye-in-myheritage-family-trees","sourceUri":"Q4G2-V32"}],"events":[{"name":"Birth","sources":"0","year":"1306","date":"Bef 1306","place":"Scotland"},{"name":"Birth of Child","sources":"0","year":"1328","date":"about 1328","place":"Locherworth Castle Midlothian Scotland","age":"23","id":"GV5W-LTL"},{"name":"Death","sources":"0","year":"1335","date":"Bef 15 October 1335","place":"Scotland","age":"29"},{"name":"Marriage","sources":"0","year":"1285","date":"before 1285","type":"Parental"}],"parent":[{"name":"Sir Gilbert de la Hay 3rd of Locherwort","gender":"Male","lifespan":"1280–Male","birthDate":"+1280","@type":"Person","identifier":"GGJY-3SX","url":"https://ancestors.familysearch.org/en/GGJY-3SX/sir-gilbert-de-la-hay-3rd-of-locherwort-1280","published":true},{"name":"Margaret Fraser","gender":"Female","lifespan":"1291–Female","birthDate":"A+1291","portrait":{"url":"https://tree-portraits-pgp.familysearchcdn.org/ucccj/thumb64.jpg","@type":"ImageObject"},"@type":"Person","identifier":"G6WK-16H","url":"https://ancestors.familysearch.org/en/G6WK-16H/margaret-fraser-1291","published":true}],"parentMarriage":{"year":"1285","date":"before 1285"},"sibling":[{"name":"Baroness Rosalind de Haye","gender":"Female","lifespan":"1303–1373","birthDate":"+1303","deathDate":"+1373","age":70,"@type":"Person","identifier":"G9VB-T8V","url":"https://ancestors.familysearch.org/en/G9VB-T8V/baroness-rosalind-de-haye-1303-1373","published":true},{"name":"Thomas Hay 4th of Locherwort","gender":"Male","lifespan":"1306–1335","birthDate":"/+1306","deathDate":"/+1335-10-15","age":29,"portrait":{"url":"https://tree-portraits-pgp.familysearchcdn.org/o5xxl/thumb200s.jpg","@type":"ImageObject"},"@type":"Person","identifier":"GKJW-WSV","url":"https://ancestors.familysearch.org/en/GKJW-WSV/thomas-hay-4th-of-locherwort-1306-1335","published":true}],"spouse":[{"name":"Lora Coningesburgh","gender":"Female","lifespan":"1293–Female","birthDate":"/+1293-08-28","@type":"Person","identifier":"GKJW-3RZ","url":"https://ancestors.familysearch.org/en/GKJW-3RZ/lora-coningesburgh-1293","published":true},{"name":"Christina Wardlaw","gender":"Female","lifespan":"1313–1380","birthDate":"/+1313","deathDate":"+1380","age":68,"@type":"Person","identifie