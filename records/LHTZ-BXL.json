6年","1350–Male":"1350年–殁","1354–1430":"1354年–1430年","about 1390":"大约1390年","1374":"1374年","1350":"1350年","1390":"1390年","1404":"1404年","1479":"1479年","1412":"1412年","1456":"1456年","1400":"1400年","1388":"1388年","1354":"1354年","1430":"1430年","1375":"1375年","1419":"1419年","1449":"1449年","Otterton, Devonshire, England":"英国英格兰戴文奧特頓","Church Stretton, Shropshire, England":"英国英格兰史洛普爾邱奇 斯特頓","Leighton, Shropshire, England":"英国史洛普爾麗頓","lifeSummary":"当Margareta Drake于大约1390年出生在英国史洛普爾邱奇 斯特頓时，她的父亲John Drake42岁，母亲Christian Billett38岁。她于1400年与Thomas Leighton在英国英格兰史洛普爾邱奇 斯特頓结婚。他们至少是1个儿子的父母。她去世于1419年在英国戴文奧特頓享年30岁。"},"hr":{"about 1390–1419":"oko 1390.–1419.","1388–1419":"1388–1419.","1388–1449":"1388–1449","1390–1419":"1390–1419.","1375–Male":"1375–preminuo","1404–1479":"1404–1479","1412–1456":"1412.–1456","1350–Male":"1350–preminuo","1354–1430":"1354–1430","about 1390":"oko 1390.","1374":"1374.","1350":"1350","1390":"1390","1404":"1404","1479":"1479","1412":"1412.","1456":"1456","1400":"1400.","1388":"1388","1354":"1354","1430":"1430","1375":"1375","1419":"1419.","1449":"1449","Otterton, Devonshire, England":"Otterton, Devon, Engleska, United Kingdom","Church Stretton, Shropshire, England":"Church Stretton, Shropshire, Engleska, United Kingdom","Leighton, Shropshire, England":"Leighton, Shropshire, England"},"cs":{"about 1390–1419":"okolo 1390–1419","1388–1419":"1388–1419","1388–1449":"1388–1449","1390–1419":"1390–1419","1375–Male":"1375–Zesnulý","1404–1479":"1404–1479","1412–1456":"1412–1456","1350–Male":"1350–Zesnulý","1354–1430":"1354–1430","about 1390":"okolo 1390","1374":"1374","1350":"1350","1390":"1390","1404":"1404","1479":"1479","1412":"1412","1456":"1456","1400":"1400","1388":"1388","1354":"1354","1430":"1430","1375":"1375","1419":"1419","1449":"1449","Otterton, Devonshire, England":"Otterton, Devon, Anglie, United Kingdom","Church Stretton, Shropshire, England":"Church Stretton, Shropshire, Anglie, United Kingdom","Leighton, Shropshire, England":"Leighton, Shropshire, An