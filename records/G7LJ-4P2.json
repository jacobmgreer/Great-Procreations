65–Afdød","1088–1165":"1088–1165","1088–Male":"1088–Afdød","1030–1066":"1030–1066","1032–Female":"1032–Afdød","1066":"1066","1088":"1088","1165":"1165","1032":"1032","1065":"1065","1086":"1086","1030":"1030","1050":"1050","about 1088":"omkring 1088","Buckhurst by Withyham, Sussex, England":"Buckhurst by Withyham, Sussex, England","Sussex, England":"Sussex, England","Kent, England":"Kent, England"},"nl":{"1050–1088":"1050–1088","1050–Male":"1050–Overleden","1066–Male":"1066–Overleden","1065–Female":"1065–Overleden","1088–1165":"1088–1165","1088–Male":"1088–Overleden","1030–1066":"1030–1066","1032–Female":"1032–Overleden","1066":"1066","1088":"1088","1165":"1165","1032":"1032","1065":"1065","1086":"1086","1030":"1030","1050":"1050","about 1088":"circa 1088","Buckhurst by Withyham, Sussex, England":"Buckhurst by Withyham, Sussex, England","Sussex, England":"Sussex, England","Kent, England":"Kent, England"},"en":{"1050–1088":"1050–1088","1050–Male":"1050–Deceased","1066–Male":"1066–Deceased","1065–Female":"1065–Deceased","1088–1165":"1088–1165","1088–Male":"1088–Deceased","1030–1066":"1030–1066","1032–Female":"1032–Deceased","1066":"1066","1088":"1088","1165":"1165","1032":"1032","1065":"1065","1086":"1086","1030":"1030","1050":"1050","about 1088":"about 1088","Buckhurst by Withyham, Sussex, England":"Buckhurst by Withyham, Sussex, England","Sussex, England":"Sussex, England","Kent, England":"Kent, England","nameMeanings":[{"name":"De","type":"LAST","attribution":"Dictionary of American Family Names © Patrick Hanks 2003, 2006.","meanings":["Some characteristic forenames:  Indian Dilip, Anirban, Gopal, Alok, Anindya, Arunava, Asit, Asok, Dibyendu, Goutam, Indra, Indranil.","Indian: variant of   Dey  ."],"variants":[{"name":"Dey","meanings":["Some characteristic forenames:  Indian Ashit, Indu, Naina, Partha, Soumya, Ajit, Anjan, Anjana, Anup, Arjun, Arun, Ashim.","English, Scottish, and Welsh: variant of   Day  .","German: topographic name from a field name in North Rhine-Westphalia, denoting a sizeable piece of land, from Middle Low German <i>dē</i> ‘thigh’ (referring to the shape of the property)."]}]},{"name":"Denne","type":"LAST","attribution":"Dictionary of American Family Names © Patrick Hanks 2003, 2006.","meanings":["English (Kent): variant of   Denn  .","French (mainly northern) and Walloon: probably a variant of <b>Dhenne</b>, a patronymic, with fused preposition <i>d(e)</i> ‘of’, from <i>Henne</i>, a pet form of the personal names French <i>Henri</i>, Flemish <i>Hendrik</i> (see   Henry   1). Alternatively, perhaps a variant of <b>Daine</b>, the feminine form of   Dain  ."],"variants":[{"name":"Denn","meanings":["English (Kent): variant of   Denne  , a habitational name from one or more of the numerous places in Kent and Sussex with names derived from Middle English <i>den</i> ‘woodland swine-pasture’ (Old English <i>denn</i>), such as Denne Manor in Chilham, Denne Hill in Kingston, and Denne Court in Woodnesborough (Kent); Denne Park in Horsham, Denne in Warnham, and Dann's Farm in Willingdon (Sussex).","English: possibly from a pet form of   Denis  ."]}]},{"name":"Robert","type":"FIRST","attribution":"Dictionary of First Names © Patrick Hanks and Flavia Hodges 1990, 2003, 2006.","meanings":["One of the many French names of Germanic origin that were introduced into Britain by the Normans; it has since remained in continuous use. It is derived from the nearly synonymous elements <i>hrōd</i> ‘fame’ + <i>berht</i> ‘bright, famous’, and had a native Old English predecessor of similar form (<i>Hreodbeorht</i>), which was supplanted by the Norman name. Two dukes of Normandy in the 11th century bore the name: the father of  William the Conqueror  (sometimes identified with the legendary Robert the Devil), and his eldest son. It was borne also by three kings of Scotland, notably  Robert the Bruce  (  1274–1329 ), who freed Scotland from English domination. The altered short form <i>Bob</i> is very common, but <i>Hob</i> and <i>Dob</i>, which were common in the Middle Ages and gave rise to surnames, are extinct.  See also  Rupert ."],"variants":[]}],"historicEvents":[{"id":1705182,"age":16,"year":"1066","julianDay":2110409,"title":"Battle of Hastings","description":"Battle of Hastings was fought between the Norman-French army and the battle-wary English army on October 14, 1066. Duke William of Normandy believed he was the rightful king rather than Harold, who had been crowned king several months earlier. Harold was killed in battle and William was crowned king on Christmas Day 1066.","url":"https://www.english-heritage.org.uk/learn/1066-and-the-norman-conquest/what-happened-battle-hastings/","urlTitle":"English Heritage - Battle of Hastings","jurisdictionLevel":2},{"id":1705183,"age":36,"year":"1086","julianDay":2117714,"title":"Domesday Book","description":"Domesday Book is Britain's earliest extant public record with information containing land surveys and landholdings commissioned by William I. The book was completed in 1086.","url":"https://www.nationalarchives.gov.uk/domesday/","urlTitle":"National Archives - Domesday","jurisdictionLevel":2}],"lifeSummary":"When Robert De Denne III was born in 1050, in Buckhurst by Withyham, Sussex, England, his father, Robert de Denne jr, was 20 and his mother, Mrs Robert de Dene, was 18. He had at least 2 sons with Lady Beatrice Bassett. He died in 1088, in his hometown, at the age of 38, and was buried in Buckhurst by Withyham, Sussex, England."},"et":{"1050–1088":"1050–1088","1050–Male":"1050–Surnud","1066–Male":"1066–Surnud","1065–Female":"1065–Surnud","1088–1165":"1088–1165","1088–Male":"1088–Surnud","1030–1066":"1030–1066","1032–Female":"1032–Surnud","1066":"1066","1088":"1088","1165":"1165","1032":"1032","1065":"1065","1086":"1086","1030":"1030","1050":"1050","about 1088":"umbes 1088","Buckhurst by Withyham, Sussex, England":"Buckhurst by Withyham, Sussex, England","Sussex, England":"Sussex, England","Kent, England":"Kent, England"},"fi":{"105