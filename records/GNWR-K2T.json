08–1136":"1108–1136","1104–1175":"1104–1175","1105–1177":"1105–1177","1106–1173":"1106–1173","1106–1176":"1106–1176","1105–1182":"1105–1182","1135–1183":"1135–1183","1075–1136":"1075–1136","1085–1136":"1085–1136","1176":"1176","1175":"1175","1075":"1075","1085":"1085","1173":"1173","1183":"1183","1182":"1182","1106":"1106","1105":"1105","1104":"1104","1136":"1136","1135":"1135","1177":"1177","about 1136":"circa 1136","1108":"1108","Wales":"Wales","Cogan, Glamorgan, Wales":"Cogan, Glamorgan, Wales","England":"England","Pembroke, Pembrokeshire, Wales":"Pembroke, Pembrokeshire, Wales, Verenigd Koninkrijk","Carew, Pembrokeshire, Wales":"Carew, Pembrokeshire, Wales"},"en":{"1108–1136":"1108–1136","1104–1175":"1104–1175","1105–1177":"1105–1177","1106–1173":"1106–1173","1106–1176":"1106–1176","1105–1182":"1105–1182","1135–1183":"1135–1183","1075–1136":"1075–1136","1085–1136":"1085–1136","1176":"1176","1175":"1175","1075":"1075","1085":"1085","1173":"1173","1183":"1183","1182":"1182","1106":"1106","1105":"1105","1104":"1104","1136":"1136","1135":"1135","1177":"1177","about 1136":"about 1136","1108":"1108","Wales":"Wales","Cogan, Glamorgan, Wales":"Cogan, Glamorgan, Wales","England":"England","Pembroke, Pembrokeshire, Wales":"Pembroke, Pembrokeshire, Wales, United Kingdom","Carew, Pembrokeshire, Wales":"Carew, Pembrokeshire, Wales","nameMeanings":[{"name":"FitzGerald","type":"LAST","attribution":"Dictionary of American Family Names © Patrick Hanks 2003, 2006.","meanings":["Some characteristic forenames:  Irish Brendan, Eamon, Liam, Aidan, Bridgid, Caitlin, Donal, Fitz, Fitzgerald, Ciaran, Colum, Dermot.","Irish: from Anglo-Norman French <i>fi(t)z</i> ‘son’ (see   Fitz  ) + the personal name <i>Gerald</i> (see   Gerald  ), ‘son of <i>Gerald</i>’. This is a very common Anglo-Norman name in Ireland, where it has been Gaelicized as <b>Mac Gearailt</b>. Irish bearers of the name claim descent from <i>Gerald</i> Fitzwalter de Windsor, constable of Pembroke Castle in the early 12th century, whose grandson Raymond (or Redmond) ‘le Gros’ <i>FitzGerald</i> (died after 1185) led the invasion of Ireland on behalf of Strongbow in 1170. A branch of the family held the title Knight of Glin from at least 1299–2011."],"variants":[{"name":"Jarrell","meanings":["Irish: altered form of   Fitzgerald  .","English (Kent and Middlesex; of Norman origin): variant of <b>Jarrold</b>, itself a variant of   Gerald  ."]},{"name":"Fitz","meanings":["English: from Anglo-Norman French <i>fi(t)z</i> ‘son’ (from Latin <i>filius</i>), used originally to distinguish a son from a father bearing the same personal name and then conventionalized as a hereditary surname, or short for a surname of which <i>fiz</i> ‘son’ was the first element, for example   Fitzhenry   and   Fitzroy  .","Altered form of English   Fitch  .","German: from a vernacular pet form of the personal name <i>Vinzenz</i> (see   Vincent  ) or <i>Vitus</i> (see   Vito  , compare   Veit  ). Compare also   Fietz  ."]}]},{"name":"Gwladys","type":"FIRST","attribution":"Dictionary of First Names © Patrick Hanks and Flavia Hodges 1990, 2003, 2006.","meanings":["Old form of   Gladys  , of uncertain derivation."],"variants":[]}],"lifeSummary":"When Gwladys FitzGerald was born in 1108, in Carew, Pembrokeshire, Wales, her father, Gerald Fitz Walter Lord Constable of Windsor Castle, was 34 and her mother, Nesta ferch Rhys, was 24. She had at least 1 son with John de Cogan. She died in 1136, in England, at the age of 28."},"et":{"1108–1136":"1108–1136","1104–1175":"1104–1175","1105–1177":"1105–1177","1106–1173":"1106–1173","1106–1176":"1106–1176","1105–1182":"1105–1182","1135–1183":"1135–1183","1075–1136":"1075–1136","1085–1136":"1085–1136","1176":"1176","1175":"1175","1075":"1075","1085":"1085","1173":"1173","1183":"1183","1182":"1182","1106":"1106","1105":"1105","1104":"1104","1136":"1136","1135":"1135","1177":"1177","about 1136":"umbes 1136","1108":"1108","Wales":"Wales","Cogan, Glamorgan, Wales":"Cogan, Glamorgan, W