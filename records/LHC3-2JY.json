ales":"Ogmore, Glamorgan, Wales"},"nl":{"–":"Overleden","1160–Male":"1160–Overleden","–Female":"Overleden","–Male":"Overleden","1179–Female":"1179–Overleden","1203–Female":"1203–Overleden","1205–Male":"1205–Overleden","1210–Male":"1210–Overleden","–1215":"–1215","1129–1200":"1129–1200","–1203":"–1203","1129":"1129","1205":"1205","1215":"1215","1203":"1203","1179":"1179","1200":"1200","1210":"1210","1160":"1160","1093":"1093","Fordoun, Kincardineshire, Scotland":"Fordoun, Kincardineshire, Schotland","Wales":"Wales","England":"England","Ewenny, Glamorgan, Wales":"Ewenny, Glamorgan, Wales","Ogmore, Glamorgan, Wales":"Ogmore, Glamorgan, Wales"},"en":{"–":"Deceased","1160–Male":"1160–Deceased","–Female":"Deceased","–Male":"Deceased","1179–Female":"1179–Deceased","1203–Female":"1203–Deceased","1205–Male":"1205–Deceased","1210–Male":"1210–Deceased","–1215":"–1215","1129–1200":"1129–1200","–1203":"–1203","1129":"1129","1205":"1205","1215":"1215","1203":"1203","1179":"1179","1200":"1200","1210":"1210","1160":"1160","1093":"1093","Fordoun, Kincardineshire, Scotland":"Fordoun, Kincardineshire, Scotland","Wales":"Wales","England":"England","Ewenny, Glamorgan, Wales":"Ewenny, Glamorgan, Wales","Ogmore, Glamorgan, Wales":"Ogmore, Glamorgan, Wales","nameMeanings":[{"name":"de","type":"LAST","attribution":"Dictionary of American Family Names © Patrick Hanks 2003, 2006.","meanings":["Some characteristic forenames:  Indian Dilip, Anirban, Gopal, Alok, Anindya, Arunava, Asit, Asok, Dibyendu, Goutam, Indra, Indranil.","Indian: variant of   Dey  ."],"variants":[{"name":"Dey","meanings":["Some characteristic forenames:  Indian Ashit, Indu, Naina, Partha, Soumya, Ajit, Anjan, Anjana, Anup, Arjun, Arun, Ashim.","English, Scottish, and Welsh: variant of   Day  .","German: topographic name from a field name in North Rhine-Westphalia, denoting a sizeable piece of land, from Middle Low German <i>dē</i> ‘thigh’ (referring to the shape of the property)."]}]},{"name":"London","type":"LAST","attribution":"Dictionary of American Family Names © Patrick Hanks 2003, 2006.","meanings":["English and Jewish (Ashkenazic): habitational name for someone who came from London or a nickname for someone who had made a trip to London or had some other connection with the city. In some cases however, the Jewish name was purely artificial. The placename, recorded by the Roman historian Tacitus in the Latinized form <i>Londinium</i>, is obscure in origin and meaning, but may be derived from pre-Celtic (Old European) roots with a meaning something like ‘place at the navigable or unfordable river’."],"variants":[{"name":"Lonon","meanings":["English: probably a variant of   London  . This surname is very rare in Britain."]},{"name":"Lundon","meanings":["English: variant of   London  ."]}]},{"name":"William","type":"FIRST","attribution":"Dictionary of First Names © Patrick Hanks and Flavia Hodges 1990, 2003, 2006.","meanings":["Probably the most successful of all the Old French names of Germanic origin that were introduced to England by the Normans. It is derived from Germanic <i>wil</i> ‘will, desire’ + <i>helm</i> ‘helmet, protection’. The fact that it was borne by the Conqueror himself does not seem to have inhibited its favour with the ‘conquered’ population: in the first century after the Conquest it was the commonest male name of all, and not only among the Normans. In the later Middle Ages it was overtaken by   John  , but continued to run second to that name until the 20th century, when the picture became more fragmented."],"variants":[]}],"lifeSummary":"William de London was born in Wales as the son of William de London and Sibylla FitzWilliam. He had at least 3 sons and 1 daughter with Florence de London. He died in Ogmore, Glamorgan, Wales, and was buried in Ewenny, Glamorgan, Wales."},"et":{"–":"Surnud","1160–Male":"1160–Surnud","–Female":"Surnud","–Male":"Surnud","1179–Female":"1179–Surnud","1203–Female":"1203–Surnud","1205–Male":"1205–Surnud","1210–Male":"1210–Surnu