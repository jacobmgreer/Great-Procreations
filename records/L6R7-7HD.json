–1140","1124–Female":"1124–preminula","1129–1200":"1129–1200","1140–Male":"1140–preminuo","1067–1157":"1067–1157","1064–Female":"1064–preminula","about 1094":"oko 1094.","about 1140":"oko 1140.","1064":"1064","1096":"1096","1140":"1140","1094":"1094","1129":"1129","1106":"1106","1157":"1157","1124":"1124","1200":"1200","1089":"1089.","1067":"1067","Lyonshall, Herefordshire, England":"Lyonshall, Herefordshire, England","Cornwall, England":"Cornwall, England"},"cs":{"about 1094–about 1140":"okolo 1094–okolo 1140","1094–1140":"1094–1140","1124–Female":"1124–Zesnulá","1129–1200":"1129–1200","1140–Male":"1140–Zesnulý","1067–1157":"1067–1157","1064–Female":"1064–Zesnulá","about 1094":"okolo 1094","about 1140":"okolo 1140","1064":"1064","1096":"1096","1140":"1140","1094":"1094","1129":"1129","1106":"1106","1157":"1157","1124":"1124","1200":"1200","1089":"1089","1067":"1067","Lyonshall, Herefordshire, England":"Lyonshall, Herefordshire, Anglie","Cornwall, England":"Cornwall, Anglie"},"da":{"about 1094–about 1140":"omkring 1094–omkring 1140","1094–1140":"1094–1140","1124–Female":"1124–Afdød","1129–1200":"1129–1200","1140–Male":"1140–Afdød","1067–1157":"1067–1157","1064–Female":"1064–Afdød","about 1094":"omkring 1094","about 1140":"omkring 1140","1064":"1064","1096":"1096","1140":"1140","1094":"1094","1129":"1129","1106":"1106","1157":"1157","1124":"1124","1200":"1200","1089":"1089","1067":"1067","Lyonshall, Herefordshire, England":"Lyonshall, Herefordshire, England","Cornwall, England":"Cornwall, England"},"nl":{"about 1094–about 1140":"circa 1094–circa 1140","1094–1140":"1094–1140","1124–Female":"1124–Overleden","1129–1200":"1129–1200","1140–Male":"1140–Overleden","1067–1157":"1067–1157","1064–Female":"1064–Overleden","about 1094":"circa 1094","about 1140":"circa 1140","1064":"1064","1096":"1096","1140":"1140","1094":"1094","1129":"1129","1106":"1106","1157":"1157","1124":"1124","1200":"1200","1089":"1089","1067":"1067","Lyonshall, Herefordshire, England":"Lyonshall, Herefordshire, England","Cornwall, England":"Cornwall, England"},"en":{"about 1094–about 1140":"about 1094–about 1140","1094–1140":"1094–1140","1124–Female":"1124–Deceased","1129–1200":"1129–1200","1140–Male":"1140–Deceased","1067–1157":"1067–1157","1064–Female":"1064–Deceased","about 1094":"about 1094","about 1140":"about 1140","1064":"1064","1096":"1096","1140":"1140","1094":"1094","1129":"1129","1106":"1106","1157":"1157","1124":"1124","1200":"1200","1089":"1089","1067":"1067","Lyonshall, Herefordshire, England":"Lyonshall, Herefordshire, England","Cornwall, England":"Cornwall, England","nameMeanings":[{"name":"d'Evereux","type":"LAST","attribution":"Dictionary of American Family Names © Patrick Hanks 2003, 2006.","meanings":["Some characteristic forenames:  Irish Dermot, Sean.","English and Irish: of Norman origin, a habitational name for someone from Évreux in Eure, France, with the preposition <i>d(e)</i>. See also   Everest   for the name without the preposition.","History: This was the surname of the Earls of Essex from 1572 to 1641. Walter <i>Devereux</i>, 1st Earl of Essex, led an attempted colonization of Ulster, and his son, Robert, 2nd Earl of Essex, briefly held the position of lord lieutenant of Ireland in 1599."],"variants":[{"name":"Devereaux","meanings":["English and Irish: of Norman origin, a variant of   Devereux  ."]},{"name":"Everest","meanings":["English (southeastern): of Norman origin, a variant of   Devereux   without the fused preposition (Old French <i>de</i>). Compare   Evers  ."]},{"name":"Evers","meanings":["English: perhaps a variant of   Devereux   without the fused preposition (Old French <i>de</i>).","English: de-aspirated variant of <b>Heaver</b>, with post-medieval excrescent <i>-s</i>, a habitational name from Hever (Kent), named from Old English <i>hēah</i> ‘high’ + (Kentish) Old English <i>ēfre</i> ‘edge or brow of a hill’. Alternatively, the name may derive from some minor place in southeastern England named with Old English <i>ȳfre</i>, (Kentish) Old English <i>ēfre</i>, Middle English <i>evere</i> ‘edge or brow of a hill, tip of a promontory’, with the addition of a prosthetic <i>H-</i>.","North German and Dutch: genitivized patronymic from the personal name   Evert  , which lost its <i>t</i> in pronunciation and spelling subsequently; compare   Everts  . Compare also   Avers  ."]},{"name":"Deveraux","meanings":["Some characteristic forenames:  Irish Dermot.","English and Irish: of Norman origin, a variant of   Devereux  ."]},{"name":"Devery","meanings":["Some characteristic forenames:  Irish Kieran, Brendan, Clancy.","Irish (Offaly): of Norman origin, a variant of   Devereux  ."]},{"name":"Devary","meanings":["Probably Irish: variant of <b>Devery</b>, a variant of   Devereux   in counties Leix and Offaly."]},{"name":"Debrow","meanings":["Altered form of English or Irish   Devereux  ."]}]},{"name":"Reginald","type":"FIRST","attribution":"Dictionary of First Names © Patrick Hanks and Flavia Hodges 1990, 2003, 2006.","meanings":["Of Norman origin, derived from <i>Reginaldus</i>, a Latinized form of   Reynold   influenced by Latin <i>regina</i> ‘queen’. The full form is now regarded as very formal, and bearers generally shorten it to   Reg   in ordinary usage."],"variants":[]}],"historicEvents":[{"id":1705184,"age":2,"year":"1096","julianDay":2121366,"title":"The Crusades","description":"A series of religious wars between Christians and Muslims, known as the Crusades, occurred between 1096 and 1291, and played a large role in European Christian dominance in the Middle East.","url":"https://www.history.com/topics/middle-ages/crusades","urlTitle":"History - The Crusades","jurisdictionLevel":2},{"id":1705185,"age":12,"year":"1106","julianDay":2125018,"title":"The Battle of Tichebray","description":"King Henry I defeated and captured his brother, Robert of Normandy, at the Battle of Tinchebray in 1106. Robert remained in captivity until his death in 1134.","jurisdictionLevel":2}],"lifeSummary":"Wh