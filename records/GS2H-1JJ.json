1317":"1317","Worcestershire, England":"Worcestershire, England, United Kingdom","Worcester, Worcestershire, England":"Worcester, Worcestershire, England","Mountjoy, Worcestershire, England":"Worcestershire, England","Hatch Beauchamp, Somerset, England":"Hatch Beauchamp, Somerset, England, United Kingdom","England":"England",", Worcestershire, England":"Worcestershire, England, United Kingdom","nameMeanings":[{"name":"Mountjoy","type":"LAST","attribution":"Dictionary of American Family Names © Patrick Hanks 2003, 2006.","meanings":["English (Devon and Gloucestershire; of Norman origin): habitational name, ultimately from <i>Montjoie</i>, a crusaders’ name derived from that of the mountain in Palestine from which the first view of Jerusalem was obtained. The name was adopted for several places in western Europe (notably Montjoie-Saint-Martin in Manche), and this, or the original, could have given rise to the English surname."],"variants":[{"name":"Montjoy","meanings":["Altered form of English   Mountjoy  ."]}]},{"name":"Thomas","type":"FIRST","attribution":"Dictionary of First Names © Patrick Hanks and Flavia Hodges 1990, 2003, 2006.","meanings":["New Testament name, borne by one of Christ's twelve apostles, referred to as ‘Thomas, called Didymus’ (John 11:16; 20:24). <i>Didymos</i> is the Greek word for ‘twin’, and the name is the Greek form of an Aramaic byname meaning ‘twin’. The given name has always been popular throughout Christendom, in part because St Thomas's doubts have made him seem a very human character."],"variants":[]}],"historicEvents":[{"id":1705190,"age":9,"year":"1290","julianDay":2192224,"title":"Jews Expelled From England","description":"After years of anti-Semitic behavior, King Edward I expelled Jews from England in 1290.","jurisdictionLevel":2},{"id":1705191,"age":34,"year":"1315","toYear":"1317","julianDay":2201354,"title":"Famine Strikes Europe","description":"A famine caused by cold winters and wet summers across Europe caused millions to d