176–1220":"1176–1220","1113–Male":"1113–Deceased","1138":"1138","1157":"1157","1113":"1113","1133":"1133","1220":"1220","1176":"1176","about 1176":"about 1176","1194":"1194","about 1133":"about 1133","1180":"1180","Yorkshire, England":"Yorkshire, England","South Otterington, Yorkshire, England":"South Otterington, Yorkshire, England","nameMeanings":[{"name":"Monte","type":"LAST","attribution":"Dictionary of American Family Names © Patrick Hanks 2003, 2006.","meanings":["Some characteristic forenames:  Italian Carlo, Mario, Domenic, Salvatore, Aldo, Angelo, Antonio, Arturo, Carmelo, Gaspare, Carmela, Ciro, Gasper, Philomena.  Spanish Jose, Manuel, Carlos, Edgardo, Emilia.","Italian (southern), Spanish, and Portuguese: topographic name for someone who lived on or near a mountain, Italian, Spanish, Portuguese <i>monte</i> (from Latin <i>mons</i>, genitive <i>montis</i>).","Italian and Jewish (from Italy): habitational name from any of the places called with Monte or Monti. Compare   Del Monte  ."],"variants":[{"name":"Monti","meanings":["Some characteristic forenames:  Italian Angelo, Salvatore, Aniello, Pasquale, Aldo, Carmel, Elio, Enrico, Gaetano, Marco, Marino, Philomena.","Italian: variant of   Monte  , from the plural."]},{"name":"Montagna","meanings":["Some characteristic forenames:  Italian Angelo, Sal, Gaetano, Alessandro, Antonino, Attilio, Carlo, Carmelo, Cosmo, Dino, Enrico, Oreste.","Italian: topographic name for someone who lived on or near a mountain or mountains, Italian <i>montagna</i>, from Late Latin <i>montanea</i>, originally the neuter plural of an adjective derivative of <i>mons</i> (see   Monte   1), or a habitational name from one of the many places called with this word."]},{"name":"Montini","meanings":["Some characteristic forenames:  Italian Enio, Pietro, Arsenio, Concetta, Dante, Dino, Domenic, Eliseo, Lorenzo, Marco, Mauro, Quirino, Ricco, Tulio.","Italian (Milan):","patronymic or plural form of a diminutive of   Monte  ."]},{"name":"Montes","meanings":["Some characteristic forenames:  Spanish Jose, Juan, Jesus, Manuel, Jorge, Luis, Francisco, Miguel, Carlos, Alfredo, Ramon, Raul.  Portuguese Joaquim.","Spanish (also <b>Montés</b>); Portuguese (also <b>Montês</b>): topographic name for a mountain dweller, from the plural form of   Monte   ‘mountain’ or from the adjective Spanish <i>montés</i>, Portuguese <i>montês</i> ‘of the mountain’."]},{"name":"Montello","meanings":["Some characteristic forenames:  Italian Biagio, Carmela, Marco.","Italian: from a diminutive of   Monte  ."]},{"name":"Del Monte","meanings":["Some characteristic forenames:  Italian Gaspar, Angelo, Rocco, Giovanni, Pompeo, Antonio, Armelio, Berta, Camillo, Carmela, Deno, Elvio, Ezio, Gilda, Giulio.  Spanish Angel, Gonzalo, Guillermina, Jesus, Jose, Jose Manuel.","Italian, Spanish, and Jewish (from Italy): variant, with the preposition and definite article <i>del</i> ‘from the’, of   Monte  .","Jewish (Sephardic): adoption of the Spanish surname (see 1 above) at the moment of conversion to Roman Catholicism. After the return to Judaism (generations later), some descendants retained the name their families used as Catholics."]},{"name":"Montejo","meanings":["Some characteristic forenames:  Spanish Raul, Carlos, Eduardo, Abelardo, Alberto, Julio, Mario, Mauricio, Miguel, Miguel Angel, Alejandro, Alfonso.","Spanish:","topographic name from a diminutive of   Monte   1."]},{"name":"Montesi","meanings":["Italian:","habitational name for someone from a place called   Monte  , from an adjectival form of the placename.","from the plural of <b>Montese</b>, a habitational name from Montese in Modena province."]},{"name":"Montas","meanings":["Spanish and Catalan (<b>Montás</b>); French: derivative of Spanish <i>monte</i>, Catalan and Old French <i>mont</i> ‘mountain’ (see   Monte  ,   Mont  ). This surname is most common in the Dominican Republic and Haiti."]}]},{"name":"Beatrice","type":"FIRST","attribution":"Dictionary of First Names © Patrick Hanks and Flavia Hodges 1990, 2003, 2006.","meanings":["and French form of   Beatrix  , which was quite popular in England during the Middle Ages, and strongly revived in the 19th century. It is most famous as the name of Dante's beloved, and is borne by the elder (  b. 1988 ) of the Duke of York's daughters."],"variants":[]}],"lifeSummary":"Beatrice Monte was born about 1133, in Yorkshire, England as the daughter of Gilbert Monte. She married Robert Fossard Lord of Mulgrave in 1157, in South Otterington, Yorkshire, England. They were the parents of at least 1 daughter. She died in 1180, in her hometown, at the age of 48."},"et":{"about 1133–1180":"umbes 1133–1180","1133–1180":"1133–1180","1138–1194":"1138–1194","1176–1220":"1176–1220","1113–Male":"1113–Surnud","1138":"1138","1157":"1157","1113":"1113","1133":"1133","1220":"1220","1176":"1176","about 1176":"umbes 1176","1194":"1194","about 1133":"umbes 1133","1180":"1180","Yorkshire, England":"Yorkshire, England","South Otterington, Yorkshire, England":"South Otterington, Yorkshire, England"},"fi":{"about 1133–1180":"noin 1133–1180","1133–1180":"1133–1180","1138–1194":"1138–1194","1176–1220":"1176–1220","1113–Male":"1113–Kuollut","1138":"1138","1157":"1157","1113":"1113","1133":"1133","1220":"1220","1176":"1176","about 1176":"noin 1176","1194":"1194","about 1133":"noin 1133","1180":"1180","Yorkshire, England":"Yorkshire, England","South Otterington, Yorkshire, England":"South Otterington, Yorkshire, England"},"fr":{"about 1133–1180":"environ 1133–1180","1133–1180":"1133–1180","1138–1194":"1138–1194","1176–1220":"1176–1220","1113–Male":"1113–Décédé","1138":"1138","1157":"1157","1113":"1113","1133":"1133","1220":"1220","1176":"1176","about 1176":"environ 1176","1194":"1194","about 1133":"environ 1133","1180":"1180","Yorkshire, England":"Everwyck, Angleterre","South Otterington, Yorkshire, England":"South Otterington, Everwyck, Angleterre","lifeSummary":"Beatrice Monte est née environ 1133, à Everwyck, Angleterre, fille de Gilbert Monte. Elle a épousé Robert Fossard Lord of Mulgrave en 1157, à South Otterington, Everwyck, Angleterre. Ils ont eu au moins 1 fille. Elle est décédée en 1180, dans sa ville natale, à l’âge de 48 ans."},"de":{"about 1133–1180":"um 1133–1180","1133–1180":"1133–1180","1138–1194":"1138–1194","1176–1220":"1176–1220","1113–Male":"1113–Verstorben","1138":"1138","1157":"1157","1113":"1113","1133":"1133","1220":"1220","1176":"1176","about 1176":"um 1176","1194":"1194","about 1133":"um 1133","1180":"1180","Yorkshire, England":"Yorkshire, England","South Otterington, Yorkshire, England":"South Otterington, Yorkshire, England","lifeSummary":"Beatrice Monte wurde um 1133 in Yorkshire, England, als Tochter von Gilbert Monte geboren. Sie hat 1157 in South Otterington, Yorkshire, England Robert Fossard Lord of Mulgrave geheiratet. Sie hatten mindestens 1 Tochter. Sie starb 1180 im Alter von 48 Jahren in ihrem Geburtsort."},"ht":{"about 1133–1180":"about 1133–1180","1133–1180":"1133–1180","1138–1194":"1138–1194","1176–1220":"1176–1220","1113–Male":"1113–Desede","1138":"1138","1157":"1157","1113":"1113","1133":"1133","1220":"1220","1176":"1176","about 1176":"about 1176","1194":"1194","about 1133":"about 1133","1180":"1180","Yorkshire, England":"Yorkshire, England","South Otterington, Yorkshire, England":"South Otterington, Yorkshire, England"},"hu":{"about 1133–1180":"1133 körül–1180","1133–1180":"1133–1180","1138–1194":"1138–1194","1176–1220":"1176–1220","1113–Male":"1113–elhunyt","1138":"1138","1157":"1157","1113":"1113","1133":"1133","1220":"1220","1176":"1176","about 1176":"1176 körül","1194":"1194","about 1133":"1133 körül","1180":"1180","Yorkshire, England":"Yorkshire, England","South Otterington, Yorkshire, England":"South Otterington, Yorkshire, England"},"id":{"about 1133–1180":"sekitar 1133–1180","1133–1180":"1133–1180","1138–1194":"1138–1194","1176–1220":"1176–1220","1113–Male":"1113–Telah Meninggal","1138":"1138","1157":"1157","1113":"1113","1133":"1133","1