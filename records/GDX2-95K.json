066":"1066","1010":"1010","1020":"1020","1075":"1075","1086":"1086","1095":"1095","1007":"1007","1029":"1029","1027":"1027","1016":"1016","1005":"1005","1035":"1035","1013":"1013","1045":"1045","before 1075":"før 1075","about 1005":"omkring 1005","about 1045":"omkring 1045","Rayleigh, Essex, England, United Kingdom":"Rayleigh, Essex, England, United Kingdom","Ongar, Essex, England":"Ongar, Essex, England","England":"England","France":"Frankrig"},"nl":{"about 1005–before 1075":"circa 1005–vóór 1075","1010–1091":"1010–1091","1027–1086":"1027–1086","1045–1095":"1045–1095","1005–1075":"1005–1075","1091":"1091","1066":"1066","1010":"1010","1020":"1020","1075":"1075","1086":"1086","1095":"1095","1007":"1007","1029":"1029","1027":"1027","1016":"1016","1005":"1005","1035":"1035","1013":"1013","1045":"1045","before 1075":"vóór 1075","about 1005":"circa 1005","about 1045":"circa 1045","Rayleigh, Essex, England, United Kingdom":"Rayleigh, Essex, Engeland, Verenigd Koninkrijk","Ongar, Essex, England":"Ongar, Essex, England","England":"England","France":"Frankrijk"},"en":{"about 1005–before 1075":"about 1005–before 1075","1010–1091":"1010–1091","1027–1086":"1027–1086","1045–1095":"1045–1095","1005–1075":"1005–1075","1091":"1091","1066":"1066","1010":"1010","1020":"1020","1075":"1075","1086":"1086","1095":"1095","1007":"1007","1029":"1029","1027":"1027","1016":"1016","1005":"1005","1035":"1035","1013":"1013","1045":"1045","before 1075":"before 1075","about 1005":"about 1005","about 1045":"about 1045","Rayleigh, Essex, England, United Kingdom":"Rayleigh, Essex, England, United Kingdom","Ongar, Essex, England":"Ongar, Essex, England","England":"England","France":"France","nameMeanings":[{"name":"Roberd","type":"FIRST","attribution":"Dictionary of First Names © Patrick Hanks and Flavia Hodges 1990, 2003, 2006.","meanings":["One of the many French names of Germanic origin that were introduced into Britain by the Normans; it has since remained in continuous use. It is derived from the nearly synonymous elements <i>hrōd</i> ‘fame’ + <i>berht</i> ‘bright, famous’, and had a native Old English predecessor of similar form (<i>Hreodbeorht</i>), which was supplanted by the Norman name. Two dukes of Normandy in the 11th century bore the name: the father of  William the Conqueror  (sometimes identified with the legendary Robert the Devil), and his eldest son. It was borne also by three kings of Scotland, notably  Robert the Bruce  (  1274–1329 ), who freed Scotland from English domination. The altered short form <i>Bob</i> is very common, but <i>Hob</i> and <i>Dob</i>, which were common in the Middle Ages and gave rise to surnames, are extinct.  See also  Rupert ."],"variants":[]}],"historicEvents":[{"id":1705179,"age":8,"year":"1013","julianDay":2091051,"title":"Sweyn Forkbeard","description":"The Danes raided and captured England. Sweyn, King of Danes, was declared King of England on Christmas Day.","url":"https://en.wikipedia.org/wiki/Sweyn_Forkbeard","urlTitle":"Wikipedia - Sweyn Forkbeard","jurisdictionLevel":0},{"id":1705180,"age":11,"year":"1016","julianDay":2092146,"title":"Canut the Great","description":"As Aethelred, King of England died, his son, Edmund Ironside devised a truce with Danish King Canute. The truce divided the kingdom between the two but Edmund died shortly after and became King of England. Several years later, he also became king of Denmark.","url":"https://en.wikipedia.org/wiki/Cnut_the_Great","urlTitle":"Wikipedia - Cnut the Great","jurisdictionLevel":0},{"id":1705181,"age":30,"year":"1035","julianDay":2099086,"title":"England Divided","description":"King Canute died in 1035 and England was divided between his three sons. His son Sweyn received Norway, Harthacanute received Denmark, and Harold Harefoot received North England.","jurisdictionLevel":0},{"id":1705182,"age":61,"year":"1066","julianDay":2110409,"title":"Battle of Hastings","description":"Battle of Hastings was fought between the Norman-French army and the battle-wary English army on October 14, 1066. Duke William of Normandy believed he was the rightful king rather than Harold, who had been crowned king several months earlier. Harold was killed in battle and William was crowned king on Christmas Day 1066.","url":"https://www.english-heritage.org.uk/learn/1066-and-the-norman-conquest/what-happened-battle-hastings/","urlTitle":"English Heritage - Battle of Hastings","jurisdictionLevel":0}],"lifeSummary":"Roberd FitzWimarc was born about 1005, in France. He married Beatrice deVere in 1029, in Rayleigh, Essex, England, United Kingdom. They were the parents of at least 2 sons. His occupation is listed as sherrif of essex in Essex, England, United Kingdom. He died before 1075, in England."},"et":{"about 1005–before 1075":"umbes 1005–enne 1075","1010–1091":"1010–1091","1027–1086":"1027–1086","1045–1095":"1045–1095","1005–1075":"1005–1075","1091":"1091","1066":"1066","1010":"1010","1020":"1020","1075":"1075","1086":"1086","1095":"1095","1007":"1007","1029":"1029","1027":"1027","1016":"1016","1005":"1005","1035":"1035","1013":"1013","1045":"1045","before 1075":"enne 1075","about 1005":"umbes 1005","about 1045":"umbes 1045","Rayleigh, Essex, England, United Kingdom":"Rayleigh, Essex, Inglismaa, United Kingdom","Ongar, Essex, England":"Ongar, Essex, England","England":"England","France":"Prantsusmaa"},"fi":{"about 1005–before 1075":"noin 1005–ennen vuotta 1075","1010–1091":"1010–1091","1027–1086":"1027–1086","1045–1095":"1045–1095","1005–1075":"1005–1075","1091":"1091","1066":"1066","1010":"1010","1020":"1020","1075":"1075","1086":"1086","1095":"1095","1007":"1007","1029":"1029","1027":"1027","1016":"1016","1005":"1005","1035":"1035","1013":"1013","1045":"1045","before 1075":"ennen vuotta 1075","about 1005":"noin 1005","about 1045":"noin 1045","Rayleigh, Essex, England, United Kingdom":"Rayleigh, Essex, Englanti, Yhdistynyt kuningaskunta","Ongar, Essex, England":"Ongar, Essex, England","England":"England","France":"Ranska"},"fr":{"about