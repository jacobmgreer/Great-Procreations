d":"England","Lincolnshire, England":"Lincolnshire, England, United Kingdom","Boston, Lincolnshire, England":"Boston, Lincolnshire, England, United Kingdom","nameMeanings":[{"name":"Rochford","type":"LAST","attribution":"Dictionary of American Family Names © Patrick Hanks 2003, 2006.","meanings":["Some characteristic forenames:  Irish Brendan, Niall.","English: variant of   Ratchford  .","Irish: of Norman origin, probably brought to Ireland by the Normans after 1171, when Henry II acquired Dublin. However, it is not known if it was an English name (see   Ratchford  ), or a Norman equivalent of the French name   Rochefort  ."],"variants":[{"name":"Rockford","meanings":["Irish and English: variant of   Rochford   or   Ratchford  . This surname is now rare in Britain."]},{"name":"Rachford","meanings":["English:","variant of   Rochford  .","variant of<b>Rackford</b>, a habitational name from Rackenford in Devon,recorded in Domesday Book as <i>Racheneforda</i>, which Millsinterprets as ‘ford suitable for riding, by a stretch of river’."]},{"name":"Ratchford","meanings":["habitational name from Rochford (Worcestershire), from Old English <i>ræcc</i> ‘hunting dog’ (genitive <i>ræcces</i>) + <i>ford</i> ‘ford’.","habitational name from Rochford (Essex). Early forms of the name ending in <i>Ro-</i> suggest that the placename derives from Old English <i>hrōc</i> ‘rook’ or the Old English personal name <i>Hrōc(a)</i> + Old English <i>ford</i> ‘ford’, but the 13th century forms in <i>Ra-</i> and <i>Re-</i> suggest that the first element is Old English <i>ræcc</i> ‘hunting dog’.","English:"]},{"name":"Rotchford","meanings":["Some characteristic forenames:  Irish Caitlin.","Irish and English: variant of   Rochford  ."]}]},{"name":"John","type":"FIRST","attribution":"Dictionary of First Names © Patrick Hanks and Flavia Hodges 1990, 2003, 2006.","meanings":["As a boy's name this represents a revival of Middle English <i>Jan</i>, a by‐form of   John  , or an adoption of the common European form with this spelling. As a girl's name it is a short form of names such as   Janet   and   Janice ."],"variants":[]}],"historicEvents":[{"id":1705195,"age":32,"year":"1382","julianDay":2225826,"title":"Wycliffe's Bible","description":"John Wycliffe, English theologian and professor at the University of Oxford, completed a translation of the Bible from the Latin Vulgate into Middle English. This translation is known as Wycliffe's Bible and was completed around 1382.","url":"https://en.wikipedia.org/wiki/Wycliffe%27s_Bible","urlTitle":"Wikipedia - Wycliffe's Bible","jurisdictionLevel":2}],"lifeSummary":"When John Rochford was born about 1350, in Boston, Lincolnshire, England, his father, Saher de Rocheforde, was 32 and his mother, Joan Hillary, was 27. He had at least 2 daughters with Alice Hastings. He died on 13 December 1410, in Lincolnshire, England, United Kingdom, at the age of 61, and was buried in Barlings, Lincolnshire, England, United Kingdom."},"et":{"Abt 1350–13 December 1410":"umbes 1350–13. detsember 1410","1350–1410":"1350–1410","1352–1409":"1352–1409","1380–1443":"1380–1443","1390–1422":"1390–1422","1320–1350":"1320–1350","1325–1350":"1325–1350","13 December 1410":"13. detsember 1410","1352":"1352","1350":"1350","1382":"1382","1380":"1380","1390":"1390","Abt 1350":"umbes 1350","about 1409":"umbes 1409","1325":"1325","1422":"1422","1443":"1443","1410":"1410","1320":"1320","1409":"1409","Abt 1380":"umbes 1380","Abt 1390":"umbes 1390","about 1350":"umbes 1350","Barlings Abbey, Barlings, Lincolnshire, England":"Barlings, Lincolnshire, Inglismaa, United Kingdom","England":"England","Lincolnshire, England":"Lincolnshire, Inglismaa, United Kingdom","Boston, Lincolnshire, England":"Boston, Lincolnshire, Inglismaa, United Kingdom"},"fi":{"Abt 1350–13 December 1410":"noin 1350–13. joulukuuta 1410","1350–1410":"1350–1410","1352–1409":"1352–1409","1380–1443":"1380–1443","1390–1422":"1390–1422","1320–1350":"1320–1350","1325–1350":"1325–1350","13 December