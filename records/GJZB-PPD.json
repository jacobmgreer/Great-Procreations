d":"Edleston, Cheshire, England","Fouleshurst, Cheshire, England":"Cheshire, Engeland, Verenigd Koninkrijk"},"en":{"about 1230–about 1300":"about 1230–about 1300","1230–1300":"1230–1300","1231–Female":"1231–Deceased","1252–1299":"1252–1299","1198–Male":"1198–Deceased","1203–Female":"1203–Deceased","1198":"1198","1231":"1231","1252":"1252","1230":"1230","1290":"1290","1259":"1259","1203":"1203","1300":"1300","1299":"1299","about 1299":"about 1299","about 1300":"about 1300","about 1230":"about 1230","about 1252":"about 1252","Crewe, Cheshire, England":"Crewe, Cheshire, England, United Kingdom","Edleston, Cheshire, England":"Edleston, Cheshire, England","Fouleshurst, Cheshire, England":"Cheshire, England, United Kingdom","nameMeanings":[{"name":"Richard","type":"FIRST","attribution":"Dictionary of First Names © Patrick Hanks and Flavia Hodges 1990, 2003, 2006.","meanings":["One of the most enduringly successful of the Old French personal names introduced into Britain by the Normans. It is of Germanic (Frankish) origin, derived from <i>rīc</i> ‘power’ + <i>hard</i> ‘strong, hardy’. It has enjoyed continuous popularity in England from the Conquest to the present day, influenced by the fact that it was borne by three kings of England, in particular  Richard I  (  1157–99 ). He was king for only ten years (  1189–99 ), most of which he spent in warfare abroad, taking part in the Third Crusade and costing the people of England considerable sums in taxes. Nevertheless, he achieved the status of a folk hero, and was never in England long enough to disappoint popular faith in his goodness and justice. He was also Duke of Aquitaine and Normandy and Count of Anjou, fiefs which he held at a time of maximum English expansion in France. His exploits as a leader of the Third Crusade earned him the nickname ‘Coeur de Lion’ or ‘Lionheart’ and a permanent place in popular imagination, in which he was even more firmly enshrined by  Sir Walter Scott's  novel Ivanhoe (  1820 )."],"variants":[{"name":"Rikert","meanings":["One of the most enduringly successful of the Old French personal names introduced into Britain by the Normans. It is of Germanic (Frankish) origin, derived from <i>rīc</i> ‘power’ + <i>hard</i> ‘strong, hardy’. It has enjoyed continuous popularity in England from the Conquest to the present day, influenced by the fact that it was borne by three kings of England, in particular  Richard I  (  1157–99 ). He was king for only ten years (  1189–99 ), most of which he spent in warfare abroad, taking part in the Third Crusade and costing the people of England considerable sums in taxes. Nevertheless, he achieved the status of a folk hero, and was never in England long enough to disappoint popular faith in his goodness and justice. He was also Duke of Aquitaine and Normandy and Count of Anjou, fiefs which he held at a time of maximum English expansion in France. His exploits as a leader of the Third Crusade earned him the nickname ‘Coeur de Lion’ or ‘Lionheart’ and a permanent place in popular imagination, in which he was even more firmly enshrined by  Sir Walter Scott's  novel Ivanhoe (  1820 )."]},{"name":"Rickert","meanings":["One of the most enduringly successful of the Old French personal names introduced into Britain by the Normans. It is of Germanic (Frankish) origin, derived from <i>rīc</i> ‘power’ + <i>hard</i> ‘strong, hardy’. It has enjoyed continuous popularity in England from the Conquest to the present day, influenced by the fact that it was borne by three kings of England, in particular  Richard I  (  1157–99 ). He was king for only ten years (  1189–99 ), most of which he spent in warfare abroad, taking part in the Third Crusade and costing the people of England considerable sums in taxes. Nevertheless, he achieved the status of a folk hero, and was never in England long enough to disappoint popular faith in his goodness and justice. He was also Duke of Aquitaine and Normandy and Count of Anjou, fiefs which he held at a time of maximum English expansion in France. His exploits as a leader of the Third Crusade earned him the nickname ‘Coeur de Lion’ or ‘Lionheart’ and a permanent place in popular imagination, in which he was even more firmly enshrined by  Sir Walter Scott's  novel Ivanhoe (  1820 )."]}]}],"historicEvents":[{"id":1705189,"age":29,"year":"1259","julianDay":2180901,"title":"100 Years of Conflict Between England and France Ends","description":"Treaty of Paris was signed on December 4, 1259, which ended 100 years of conflict between England and France.","url":"https://en.wikipedia.org/wiki/Treaty_of_Paris_(1259)","urlTitle":"Wikipedia - Treaty of Paris 1259","jurisdictionLevel":2},{"id":1705190,"age":60,"year":"1290","julianDay":2192224,"title":"Jews Expelled From England","description":"After years of anti-Semitic behavior, King Edward I expelled Jews from England in 1290.","jurisdictionLevel":2}],"lifeSummary":"When Richard Fulleshurst was born about 1230, in Edleston, Cheshire, England, his father, William de Fulleshurst, was 33 and his mother, Mrs. William de Fulleshurst, was 28. He had at least 1 son with Mrs. Richard Fulleshurst. He died about 1300, in Cheshire, England, United Kingdom, at the age of 72."},"et":{"about 1230–about 1300":"umbes 1230–umbes 1300","1230–1300":"1230–1300","1231–Female":"1231–Surnud","1252–1299":"1252–1299","1198–Male":"1198–Surnud","1203–Female":"1203–Surnud","1198":"1198","1231":"1231","1252":"1252","1230":"1230","1290":"1290","1259":"1259","1203":"1203","1300":"1300","1299":"1299","about 1299":"umbes 1299","about 1300":"umbes 1300","about 1230":"umbes 1230","about 1252":"umbes 1252","Crewe, Cheshire, England":"Crewe, Cheshire, Inglismaa, United Kingdom","Edleston, Cheshire, England":"Edleston, Cheshire, England","Fouleshurst, Cheshire, England":"Cheshire, Inglismaa, United Kingdom"},"fi":{"about 1230–about 1300":"noin 1230–noin 1300","1230–1300":"1230–1300","1231–Female":"1231–Kuollut","1252–1299":"1252–1299","1198–Male":"1198–Kuollut","12