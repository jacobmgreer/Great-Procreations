ut 1420":"oko 1420.","1390":"1390","1428":"1428","1439":"1439","ABT 1429":"oko 1429.","Tedburn St Mary, Devon, England":"Tedburn St Mary, Devon, England","Of, Begery, Bedfordshire, England":"Bedfordshire, Engleska, United Kingdom"},"cs":{"about 1420–about 1439":"okolo 1420–okolo 1439","1420–1439":"1420–1439","1428–1483":"1428–1483","1445–1512":"1445–1512","1390–1477":"1390–1477","1400–Female":"1400–Zesnulá","about 1439":"okolo 1439","1512":"1512","1445":"1445","1400":"1400","1477":"1477","1420":"1420","1483":"1483","about 1420":"okolo 1420","1390":"1390","1428":"1428","1439":"1439","ABT 1429":"okolo 1429","Tedburn St Mary, Devon, England":"Tedburn St Mary, Devon, Anglie","Of, Begery, Bedfordshire, England":"Bedfordshire, Anglie, United Kingdom"},"da":{"about 1420–about 1439":"omkring 1420–omkring 1439","1420–1439":"1420–1439","1428–1483":"1428–1483","1445–1512":"1445–1512","1390–1477":"1390–1477","1400–Female":"1400–Afdød","about 1439":"omkring 1439","1512":"1512","1445":"1445","1400":"1400","1477":"1477","1420":"1420","1483":"1483","about 1420":"omkring 1420","1390":"1390","1428":"1428","1439":"1439","ABT 1429":"omkring 1429","Tedburn St Mary, Devon, England":"Tedburn St Mary, Devon, England","Of, Begery, Bedfordshire, England":"Bedfordshire, England, United Kingdom"},"nl":{"about 1420–about 1439":"circa 1420–circa 1439","1420–1439":"1420–1439","1428–1483":"1428–1483","1445–1512":"1445–1512","1390–1477":"1390–1477","1400–Female":"1400–Overleden","about 1439":"circa 1439","1512":"1512","1445":"1445","1400":"1400","1477":"1477","1420":"1420","1483":"1483","about 1420":"circa 1420","1390":"1390","1428":"1428","1439":"1439","ABT 1429":"circa 1429","Tedburn St Mary, Devon, England":"Tedburn St Mary, Devon, England","Of, Begery, Bedfordshire, England":"Bedfordshire, Engeland, Verenigd Koninkrijk"},"en":{"about 1420–about 1439":"about 1420–about 1439","1420–1439":"1420–1439","1428–1483":"1428–1483","1445–1512":"1445–1512","1390–1477":"1390–1477","1400–Female":"1400–Deceased","about 1439":"about 1439","1512":"1512","1445":"1445","1400":"1400","1477":"1477","1420":"1420","1483":"1483","about 1420":"about 1420","1390":"1390","1428":"1428","1439":"1439","ABT 1429":"about 1429","Tedburn St Mary, Devon, England":"Tedburn St Mary, Devon, England","Of, Begery, Bedfordshire, England":"Bedfordshire, England, United Kingdom","nameMeanings":[{"name":"Spencer","type":"LAST","attribution":"Dictionary of American Family Names © Patrick Hanks 2003, 2006.","meanings":["English (Lancashire and Yorkshire): occupational name for someone who dispensed provisions or money, from Middle English <i>spenser(e)</i>, <i>spencer(e)</i> ‘household steward, butler, almoner’ (Anglo-Norman French <i>espenser</i>, Old French <i>despensier</i>). Compare   Spence   and   Spender  . There is some dispute about the origins of the Spencer family, whose most famous member in recent times was the late Princess of Wales, born Lady Diana Spencer (1961–97). Some sources say that they are descended from William the Conqueror's steward, Robert Despencer. What is clear is that by the 15th century they had become prosperous from sheep farming in Northamptonshire. Robert Spencer (died 1627) was said to be the wealthiest man in England. Their titles have included Earls of Sunderland and Earls Spencer; and through the female line the 5th Earl of Sunderland also became Duke of Marlborough in 1733. This connection was the result of the marriage, in 1700, of the 3rd Duke of Sunderland to the daughter of John Churchill, 1st Duke of Marlborough. The youngest son of this union, John Spencer (1708–46), was the father of the 1st Earl Spencer (1734–83)."],"variants":[{"name":"Spence","meanings":["English and Scottish: nickname for a servant employed in the pantry of a great house or monastery, from Middle English <i>spense</i>, <i>spence</i> ‘pantry, larder, storeroom’ (Old French <i>despense</i>, from a Late Latin derivative of <i>dispendere</i>, past participle <i>dispensus</i> ‘to weigh out or dispense’). Compare   Spencer  ."]},{"name":"Spenser","meanings":["English: variant of   Spencer  ."]},{"name":"Spender","meanings":["English:","occupational name or status name from Middle English <i>spender(e)</i>, <i>spendour</i> ‘steward, treasurer’, a shortened form of Middle English, Old French <i>despendour</i>, denoting someone who managed money or supplies. Compare   Spencer  .","alternatively, perhaps a nickname from Middle English <i>spender(e)</i>, <i>spendour</i> ‘spender (of money), spendthrift’."]}]},{"name":"Joan","type":"FIRST","attribution":"Dictionary of First Names © Patrick Hanks and Flavia Hodges 1990, 2003, 2006.","meanings":["Contracted form of Old French <i>Jo(h)anne</i>, from Latin <i>Io(h)anna</i> (  see  Joanna  ). In England this was the usual feminine form of   John   from the Middle English period onwards and was extremely popular, but in the 16th and 17th centuries it steadily lost ground to   Jane .  It was strongly revived in the first part of the 20th century, partly under the influence of  George Bernard Shaw's  play St Joan (  1923 ), based on the life of  Joan of Arc  (  1412–31 ). Claiming to be guided by the voices of the saints, she persuaded the French dauphin to defy the occupying English forces and have himself crowned, and she led the French army that raised the siege of Orleans in  1429 . The following year she was captured by the Burgundians and sold to the English, and a year later she was burned at the stake for witchcraft at the age of 18 or 19. Her story has captured the imagination of many writers, and she is variously portrayed as a national and political hero, a model of apolitical straightforwardness and honesty, and a religious heroine. She was canonized in  1920 . More recent influences have included the American film actress  Joan Crawford  (  1908–77 , born  Lucille le Sueur ), the British actress  Joan Collins  (  b. 1933 ), the American comedienne  Joan Rivers  (  b. 1933 ), and the West Indian pop singer  Joan Armatrading  (  b. 1950 )."],"variants":[{"name":"John","meanings":["Greek: the Lord gave graciously; whom Jehovah gave; whom Jehovah bestowed."]}]}],"lifeSummary":"When Joan Spencer was born about 1420, in Tedburn St Mary, Devon, England, her father, John Spencer, was 31 and her mother, Mrs. John Spencer, was 22. She married Stephen Gifford. They were the parents of at least 1 daughter. She died about 1439, at the age of 21."},"et":{"about 1420–about 1439":"umbes 1420–umbes 1439","1420–1439":"1420–1439","1428–1483":"1428–1483","1445–1512":"1445–1512","1390–1477":"1390–1477","1400–Female":"1400–Surnud","about 1439":"umbes 1439","1512":"1512","1445":"1445","1400":"1400","1477":"1477","1420":"1420","1483":"1483","about 1420":"umbes 1420","1390":"1390","1428":"1428","1439":"1439","ABT 1429":"umbes 1429","Tedburn St Mary, Devon, England":"Tedburn St Mary, Devon, England","Of, Begery, Bedfordshire, England":"Bedfordshire, Inglismaa, United Kingdom"},"fi":{"about 1420–about 1439":"noin 1420–noin 1439","1420–1439":"1420–1439","1428–1483":"1428–1483","1445–1512":"1445–1512","1390–1477":"1390–1477","1400–Female":"1400–Kuollut","about 1439":"noin 1439","1512":"1512","1445":"1445","1400":"1400","1477":"1477","1420":"1420","1483":"1483","about 1420":"noin 1420","1390":"1390","1428":"1428","1439":"1439","ABT 1429":"noin 1429","Tedburn St Mary, Devon, England":"Tedburn St Mary, Devon, England","Of, Begery, Bedfordshire, England":"Bedfordshire, Englanti, Yhdistynyt kuningaskunta"},"fr":{"about 1420–about 1439":"environ 1420–environ 1439","1420–1439":"1420–1439","1428–1483":"1428–1483","1445–1512":"1445–1512","1390–1477":"1390–1477","1400–Female":"1400–Décédée","about 1439":"environ 1439","1512":"1512","1445":"1445","1400":"1400","1477":"1477","1420":"1420","1483":"1483","about 1420":"environ 1420","1390":"1390","1428":"1428","1439":"1439","ABT 1429":"environ 1429","Tedburn St Mary, Devon, England":"Tedburn St Mary, Devon, Angleterre","Of, Begery, Bedfordshire, England"