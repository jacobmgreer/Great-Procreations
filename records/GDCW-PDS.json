293":"1293","1280":"1280","1337":"1337","1315":"1315","1303":"1303","1358":"1358","1379":"1379","1333":"1333","1344":"1344","1453":"1453","1331":"1331","1386":"1386","about 1320":"circa 1320","1328":"1328","1317":"1317","Herefordshire, England, United Kingdom":"Herefordshire, Engeland, Verenigd Koninkrijk","Roydon, Norfolk, England":"Roydon, Norfolk, England","Norfolk, England":"Norfolk, Engeland, Verenigd Koninkrijk","Royden, Norfolk, England":"Roydon, Norfolk, Engeland, Verenigd Koninkrijk"},"en":{"1303–24 December 1358":"1303–24 December 1358","1303–1358":"1303–1358","1293–1360":"1293–1360","1331–1386":"1331–1386","1333–Male":"1333–Deceased","1344–1379":"1344–1379","1280–Male":"1280–Deceased","24 December 1358":"24 December 1358","1360":"1360","1293":"1293","1280":"1280","1337":"1337","1315":"1315","1303":"1303","1358":"1358","1379":"1379","1333":"1333","1344":"1344","1453":"1453","1331":"1331","1386":"1386","about 1320":"about 1320","1328":"1328","1317":"1317","Herefordshire, England, United Kingdom":"Herefordshire, England, United Kingdom","Roydon, Norfolk, England":"Roydon, Norfolk, England","Norfolk, England":"Norfolk, England, United Kingdom","Royden, Norfolk, England":"Roydon, Norfolk, England, United Kingdom","nameMeanings":[{"name":"DeTyes","type":"LAST","attribution":"Dictionary of American Family Names © Patrick Hanks 2003, 2006.","meanings":["French (northern): variant of <b>Destrées</b>, a habitational name, with fused preposition <i>d(e)</i> ‘from’, denoting someone from any of several places called Estrées. This form of the surname is most common in Puerto Rico."],"variants":[]},{"name":"Joan","type":"FIRST","attribution":"Dictionary of First Names © Patrick Hanks and Flavia Hodges 1990, 2003, 2006.","meanings":["Contracted form of Old French <i>Jo(h)anne</i>, from Latin <i>Io(h)anna</i> (  see  Joanna  ). In England this was the usual feminine form of   John   from the Middle English period onwards and was extremely popular, but in the 16th and 17th centuries it steadily lost ground to   Jane .  It was strongly revived in the first part of the 20th century, partly under the influence of  George Bernard Shaw's  play St Joan (  1923 ), based on the life of  Joan of Arc  (  1412–31 ). Claiming to be guided by the voices of the saints, she persuaded the French dauphin to defy the occupying English forces and have himself crowned, and she led the French army that raised the siege of Orleans in  1429 . The following year she was captured by the Burgundians and sold to the English, and a year later she was burned at the stake for witchcraft at the age of 18 or 19. Her story has captured the imagination of many writers, and she is variously portrayed as a national and political hero, a model of apolitical straightforwardness and honesty, and a religious heroine. She was canonized in  1920 . More recent influences have included the American film actress  Joan Crawford  (  1908–77 , born  Lucille le Sueur ), the British actress  Joan Collins  (  b. 1933 ), the American comedienne  Joan Rivers  (  b. 1933 ), and the West Indian pop singer  Joan Armatrading  (  b. 1950 )."],"variants":[{"name":"John","meanings":["As a boy's name this represents a revival of Middle English <i>Jan</i>, a by‐form of   John  , or an adoption of the common European form with this spelling. As a girl's name it is a short form of names such as   Janet   and   Janice ."]}]}],"historicEvents":[{"id":1705191,"age":12,"year":"1315","toYear":"1317","julianDay":2201354,"title":"Famine Strikes Europe","description":"A famine caused by cold winters and wet summers across Europe caused millions to die due to starvation. Desperation from hunger caused high levels of crime, stampedes in bread lines in London, infanticide, and even cannibalism throughout Europe.","jurisdictionLevel":1},{"id":1705192,"age":25,"year":"1328","julianDay":2206102,"title":"First War of Scottish Independence","description":"The First War of Scottish Independence began after Engla