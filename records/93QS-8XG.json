1420":"1420","1398":"1398","about 1414":"circa 1414","about 1425":"circa 1425","about 1420":"circa 1420","about 1396":"circa 1396","1418":"1418","Wales":"Wales","of Pen-rhys,Ystradyfodwg,Glamorganshire,Wales":"Glamorgan, Wales, Verenigd Koninkrijk"},"en":{"about 1396–":"about 1396–Deceased","1392–Male":"1392–Deceased","1394–Male":"1394–Deceased","1396–Male":"1396–Deceased","1398–Female":"1398–Deceased","1404–Female":"1404–Deceased","1413–Female":"1413–Deceased","1418–Female":"1418–Deceased","1400–Female":"1400–Deceased","1414–Male":"1414–Deceased","1420–Male":"1420–Deceased","1425–Male":"1425–Deceased","1366–Male":"1366–Deceased","1371–Female":"1371–Deceased","1396":"1396","1394":"1394","1371":"1371","1392":"1392","1404":"1404","1425":"1425","1414":"1414","1413":"1413","1400":"1400","1366":"1366","1420":"1420","1398":"1398","about 1414":"about 1414","about 1425":"about 1425","about 1420":"about 1420","about 1396":"about 1396","1418":"1418","Wales":"Wales","of Pen-rhys,Ystradyfodwg,Glamorganshire,Wales":"Glamorgan, Wales, United Kingdom","nameMeanings":[{"name":"Gruffudd","type":"LAST","attribution":"Dictionary of Family Names in Britain and Ireland © University of the West of England 2016","meanings":["Welsh: traditional spelling of   Griffith  ."],"variants":[{"name":"Griffith","meanings":["Welsh (Carmarthenshire and western England): from the Old Welsh personal name <i>Gruffudd</i>, Old Welsh <i>Grip(p)iud</i>, composed of the elements <i>grip</i>, of uncertain significance, + <i>iud</i> ‘chief, lord’."]}]},{"name":"Gwilym","type":"FIRST","attribution":"Dictionary of First Names © Patrick Hanks and Flavia Hodges 1990, 2003, 2006.","meanings":["equivalent of <b>William</b> , in use since the Middle Ages."],"variants":[{"name":"Gwilim","meanings":["equivalent of <b>William</b> , in use since the Middle Ages."]},{"name":"Gwillym","meanings":["equivalent of <b>William</b> , in use since the Middle Ages."]},{"name":"William","meanings":["Probably the most successful of all the Old French names of Germanic origin that were introduced to England by the Normans. It is derived from Germanic <i>wil</i> ‘will, desire’ + <i>helm</i> ‘helmet, protection’. The fact that it was borne by the Conqueror himself does not seem to have inhibited its favour with the ‘conquered’ population: in the first century after the Conquest it was the commonest male name of all, and not only among the Normans. In the later Middle Ages it was overtaken by   John  , but continued to run second to that name until the 20th century, when the picture became more fragmented."]}]},{"name":"ap","type":"FIRST","attribution":"Dictionary of First Names © Patrick Hanks and Flavia Hodges 1990, 2003, 2006.","meanings":["Short form of any of the names beginning with this syllable."],"variants":[{"name":"Alexander","meanings":["From the Latin form of the Greek name <i>Alexandros</i>, from <i>alexein</i> ‘to defend’ + <i>anēr</i> ‘man, warrior’ (genitive <i>andros</i>). The name became extremely popular in the post-classical period, and was borne by several individuals in the New Testament and some early Christian saints. Its use as a common given name throughout Europe, however, derives largely from the fame of  Alexander the Great , King of Macedon (  356–323  bc  ), around whom a large body of popular legend grew up in late antiquity, much of which came to be embodied in the medieval ‘Alexander romances’."]},{"name":"Alan","meanings":["Of Celtic origin and uncertain derivation (possibly a diminutive of a word meaning ‘rock’). It was introduced into England by  Breton  followers of  William the Conqueror , most notably  Alan , Earl of Brittany, who was rewarded for his services with vast estates in the newly conquered kingdom. In Britain the variants  <b>Allan</b>  and  <b>Allen</b>  are considerably less frequent, and generally represent transferred uses of surname forms, whereas in America all three forms of the name are approximately equally common.  See also  Alun ."]},{"name":"Albert","meanings":["From an Old French name, <i>Albert</i>, of Germanic (Frankish) origin, derived from <i>adal</i> ‘noble’ + <i>berht</i> ‘bright, famous’. This was adopted by the Normans and introduced by them to England, displacing the Old English form <i>Æþelbeorht</i>. The name is popular in a variety of forms in Western Europe, and has been traditional in a number of European princely families. It was out of favour in England for centuries, however, and the revival of its popularity in the 19th century was largely in honour of  Queen Victoria's  consort,  Prince Albert of Saxe-Coburg-Gotha ."]}]}],"lifeSummary":"When Gwilym ap Gruffudd was born about 1396, in Glamorgan, Wales, United Kingdom, his father, Gruffudd, was 32 and his mother, Gwenhwyfar ferch Ieuan, was 27. He had at least 3 sons with Mrs. Gwilym ap Gruffudd."},"et":{"about 1396–":"umbes 1396–Surnud","1392–Male":"1392–Surnud","1394–Male":"1394–Surnud","1396–Male":"1396–Surnud","1398–Female":"1398–Surnud","1404–Female":"1404–Surnud","1413–Female":"1413–Surnud","1418–Female":"1418–Surnud","1400–Female":"1400–Surnud","1414–Male":"1414–Surnud","1420–Male":"1420–Surnud","1425–Male":"1425–Surnud","1366–Male":"1366–Surnud","1371–Female":"1371–Surnud","1396":"1396","1394":"1394","1371":"1371","1392":"1392","1404":"1404","1425":"1425","1414":"1414","1413":"1413","1400":"1400","1366":"1366","1420":"1420","1398":"1398","about 1414":"umbes 1414","about 1425":"umbes 1425","about 1420":"umbes 1420","about 1396":"umbes 1396","1418":"1418","Wales":"Wales","of Pen-rhys,Ystradyfodwg,Glamorganshire,Wales":"Glamorgan, Wales, United Kingdom"},"fi":{"about 1396–":"noin 1396–Kuollut","1392–Male":"1392–Kuollut","1394–Male":"1394–Kuollut","1396–Male":"1396–Kuollut","1398–Female":"1398–Kuollut","1404–Female":"1404–Kuollut","1413–Female":"1413–Kuollut","1418–Female":"1418–Kuollut","1400–Female":"1400–Kuollut","1414–Male":"1414–Kuollut","1420–Male":"1420–Kuollut","1425–Male":"1425–Kuollut","1366–Male":"1366–Kuollut",