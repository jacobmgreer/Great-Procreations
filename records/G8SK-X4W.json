 von Walbeck于1070年出生在德国諾爾德海-維斯特法倫可萊斯 蓋爾德蓋爾德沃爾貝可。她于1087年与Goswin I. von Heinsberg-Valkenburg结婚。他们至少是2个儿子的父母。她去世于1152年在荷兰利包格瓦爾肯波格享年82岁。"},"hr":{"1070–1152":"1070.–1152.","1060–1128":"1060–1128","1088–1129":"1088.–1129","1102–1168":"1102.–1168","1 APR 1128":"1. travnja 1128.","1129":"1129","1128":"1128","ABT 1087":"1087.","1102":"1102.","1168":"1168","1088":"1088.","7. August 1129":"7. kolovoza 1129.","1152":"1152.","1060":"1060","1070":"1070.","Wassenberg, Kreis Heinsberg, Nordrhein-Westfalen, Duitsland":"Wassenberg, Kreis Heinsberg, Nordrhein-Westfalen, Njemačka","Heinsberg, Kreis Heinsberg, Nordrhein-Westfalen, Duitsland":"Heinsberg, Kreis Heinsberg, Nordrhein-Westfalen, Njemačka","Valkenburg, Limburg, Nederland":"Valkenburg, Limburg, Nizozemska","Walbeck, Geldern, Kreis Geldern, Nordrhein-Westfalen, Duitsland":"Walbeck, Geldern, Kreis Geldern, Nordrhein-Westfalen, Njemačka","Duras, Limburg, België":"Duras, Limburg, Belgija"},"cs":{"1070–1152":"1070–1152","1060–1128":"1060–1128","1088–1129":"1088–1129","1102–1168":"1102–1168","1 APR 1128":"1. dubna 1128","1129":"1129","1128":"1128","ABT 1087":"1087","1102":"1102","1168":"1168","1088":"1088","7. August 1129":"7. srpna 1129","1152":"1152","1060":"1060","1070":"1070","Wassenberg, Kreis Heinsberg, Nordrhein-Westfalen, Duitsland":"Wassenberg, Kreis Heinsberg, Nordrhein-Westfalen, Německo","Heinsberg, Kreis Heinsberg, Nordrhein-Westfalen, Duitsland":"Heinsberg, Kreis Heinsberg, Nordrhein-Westfalen, Německo","Valkenburg, Limburg, Nederland":"Valkenburg, Limburg, Nizozemsko","Walbeck, Geldern, Kreis Geldern, Nordrhein-Westfalen, Duitsland":"Walbeck, Geldern, Kreis Geldern, Nordrhein-Westfalen, Německo","Duras, Limburg, België":"Duras, Limburg, Belgie"},"da":{"1070–1152":"1070–1152","1060–1128":"1060–1128","1088–1129":"1088–1129","1102–1168":"1102–1168","1 APR 1128":"1. april 1128","1129":"1129","1128":"1128","ABT 1087":"1087","1102":"1102","1168":"1168","1088":"1088","7. August 1129":"7. august 1129","1152":"1152","1060":"10