2–1558":"1502–1558","1470–Male":"1470–Zesnulý","1569":"1569","1558":"1558","1502":"1502","1473":"1473","1571":"1571","1470":"1470","1490":"1490","1549":"1549","England":"Anglie"},"da":{"1470–":"1470–Afdød","1473–Female":"1473–Afdød","1502–1558":"1502–1558","1470–Male":"1470–Afdød","1569":"1569","1558":"1558","1502":"1502","1473":"1473","1571":"1571","1470":"1470","1490":"1490","1549":"1549","England":"England"},"nl":{"1470–":"1470–Overleden","1473–Female":"1473–Overleden","1502–1558":"1502–1558","1470–Male":"1470–Overleden","1569":"1569","1558":"1558","1502":"1502","1473":"1473","1571":"1571","1470":"1470","1490":"1490","1549":"1549","England":"England"},"en":{"1470–":"1470–Deceased","1473–Female":"1473–Deceased","1502–1558":"1502–1558","1470–Male":"1470–Deceased","1569":"1569","1558":"1558","1502":"1502","1473":"1473","1571":"1571","1470":"1470","1490":"1490","1549":"1549","England":"England","nameMeanings":[{"name":"Babcocke","type":"LAST","attribution":"Dictionary of American Family Names © Patrick Hanks 2003, 2006.","meanings":["English (Lancashire): although the first element of this name would suggest it is derived from the Middle English personal name <i>Babb</i> (see   Babb  ), apparently it is a post-medieval form of <b>Badcock</b>, from the Middle English personal name <i>Badecok</i>, a pet form of <i>Bade</i> (see   Bade  ) + the diminutive suffix <i>-cok</i>. There is no reason why a Middle English <i>Babbecok</i>, a pet form of <i>Babb</i> (itself a pet form of   Barbara  ), should not have existed, but evidence has yet to be found.","History: James Babcock settled in Portsmouth, RI, in 1642."],"variants":[{"name":"Babb","meanings":["English (Devon, Somerset, and Cornwall): from the Middle English personal name <i>Babb(e)</i>, usually no doubt a pet form of the female personal name <i>Barbara</i> (see   Barbara  ), but possibly in some cases a survival of the Old English personal name <i>Babba</i>, which is found in several placenames, including Babbacombe in Devon and Babington in Somerset.","English (Devon, Somerset, and Cornwall): from Middle English <i>babe</i> ‘infant, young child’, applied as a nickname.","Americanized form of German   Bobb   or of some other similar (like-sounding) surname."]}]},{"name":"William","type":"FIRST","attribution":"Dictionary of First Names © Patrick Hanks and Flavia Hodges 1990, 2003, 2006.","meanings":["Probably the most successful of all the Old French names of Germanic origin that were introduced to England by the Normans. It is derived from Germanic <i>wil</i> ‘will, desire’ + <i>helm</i> ‘helmet, protection’. The fact that it was borne by the Conqueror himself does not seem to have inhibited its favour with the ‘conquered’ population: in the first century after the Conquest it was the commonest male name of all, and not only among the Normans. In the later Middle Ages it was overtaken by   John  , but continued to run second to that name until the 20th century, when the picture became more fragmented."],"variants":[]}],"historicEvents":[{"id":1705201,"age":79,"year":"1549","julianDay":2286821,"title":"Book of Common Prayer","description":"Book of Common Prayer, a product of the English Reformation, was published in 1549 for assistance in the administration of the sacraments and other rites and ceremonies of the church according to the use of the Church of England. The book outlined morning, evening, and communion prayers and orders for baptism and marriage, thus making England a truly Protestant state.","url":"https://en.wikipedia.org/wiki/Book_of_Common_Prayer","urlTitle":"Wikipedia - Book of Common Prayer","jurisdictionLevel":0},{"id":1705202,"age":88,"year":"1558","julianDay":2290108,"title":"Act of Uniformity","description":"The Act of Uniformity was passed by the Parliament of England and required all people to go to church once a week. The consequence of not attending church was a fine of 12 pence, which was a considerable amount for a poor person.","jurisdictionLevel":0},{"id":1705205,"age":99,"year":"1569","julianDay":2294126,"title":"State Lottery","description":"A State Lottery was recorded in 1569. The tickets were sold at St. Paul's Cathedral in London.","jurisdictionLevel":0},{"id":1705206,"age":101,"year":"1571","julianDay":2294856,"title":"The Royal Exchange is Organized","description":"The Royal Exchange was organized in January 1571 by Sir Thomas Gresham. Gresham is known as the father of English banking.","jurisdictionLevel":0}],"lifeSummary":"William Babcocke was born in 1470, in England. He married Elizabeth in 1490, in England. They were the parents of at least 1 daughter."},"et":{"1470–":"1470–Surnud","1473–Female":"1473–Surnud","1502–1558":"1502–1558","1470–Male":"1470–Surnud","1569":"1569","1558":"1558","1502":"1502","1473":"1473","1571":"1571","1470":"1470","1490":"1490","1549":"1549","England":"England"},"fi":{"1470–":"1470–Kuollut","1473–Female":"1473–Kuollut","1502–1558":"1502–1558","1470–Male":"1470–Kuollut","1569":"1569","1558":"1558","1502":"1502","1473":"1473","1571":"1571","1470":"1470","1490":"1490","1549":"1549","England":"England"},"fr":{"1470–":"1470–Décédé","1473–Female":"1473–Décédée","1502–1558":"1502–1558","1470–Male":"1470–Décédé","1569":"1569","1558":"1558","1502":"1502","1473":"1473","1571":"1571","1470":"1470","1490":"1490","1549":"1549","England":"Angleterre","lifeSummary":"William Babcocke est né en 1470, à Angleterre. Il a épousé Elizabeth en 1490, à Angleterre. Ils ont eu au moins 1 fille."},"de":{"1470–":"1470–Verstorben","1473–Female":"1473–Verstorben","1502–1558":"1502–1558","1470–Male":"1470–Verstorben","1569":"1569","1558":"1558","1502":"1502","1473":"1473","1571":"1571","1470":"1470","1490":"1490","1549":"1549","England":"England","lifeSummary":"William Babcocke wurde 1470 in England geboren. Er hat 1490 in England Elizabeth geheiratet. Sie hatten mindestens 1 Tochter."},"ht":{"1470–":"1470–Desede","1473–Female":"1473–Desede","1502–1558":"1502–1558","1470–Male":"1470–Desede","1569