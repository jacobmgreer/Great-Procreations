s., Engl.":"Wanlip, Leicestershire, Engeland, Verenigd Koninkrijk","Wanlip, Leicestershire, England":"Wanlip, Leicestershire, Engeland, Verenigd Koninkrijk","England":"England"},"en":{"1203–":"1203–Deceased","1203–Female":"1203–Deceased","1200–1248":"1200–1248","1225–Male":"1225–Deceased","1245–Female":"1245–Deceased","1248–Female":"1248–Deceased","1251–Male":"1251–Deceased","1258–Female":"1258–Deceased","1180–Male":"1180–Deceased","1190–Female":"1190–Deceased","1190":"1190","Abt 1225":"about 1225","1251":"1251","abt 1245":"about 1245","1290":"1290","1180":"1180","1315":"1315","1248":"1248","1259":"1259","1215":"1215","1203":"1203","1258":"1258","1225":"1225","1224":"1224","1245":"1245","1200":"1200","1317":"1317","of Wanlip, Lcstrs., Engl.":"Wanlip, Leicestershire, England, United Kingdom","Wanlip, Leicestershire, England":"Wanlip, Leicestershire, England, United Kingdom","England":"England","nameMeanings":[{"name":"Anlep","type":"LAST","attribution":"Dictionary of Family Names in Britain and Ireland © University of the West of England 2016","meanings":["1  English: locative name from Anley, a Domesday manor in Settle (WR Yorks).","2  Huguenot: occasionally perhaps an anglicization of a French surname such as  <i>Agnelet</i>."],"variants":[]},{"name":"Maud","type":"FIRST","attribution":"Dictionary of First Names © Patrick Hanks and Flavia Hodges 1990, 2003, 2006.","meanings":["Medieval vernacular form of   Matilda .  This form was characteristically Low German (i.e. including medieval Dutch and Flemish). The wife of  William the Conqueror , who bore this name, was the daughter of  Baldwin , Count of Flanders. In Flemish and Dutch the letter <i>-t-</i> was generally lost when it occurred between vowels, giving forms such as <i>Ma(h)auld</i>. <i>Maud</i> or <i>Matilda</i> was also the name of the daughter (  1102–67 ) of  Henry I  of England; she was married early in life to the Holy Roman Emperor  Henry V , and later disputed the throne of England with her cousin  Stephen . In  1128  she married  Geoffrey , Count of Anjou. A medieval chronicler commented, ‘she was a good woman, but she had little bliss with him’. The name <i>Maud</i> became quite common in England in the 19th century, when its popularity was influenced in part by  Tennyson's  poem Maud, published in  1855 , but has not been much used since the early decades of the 20th century."],"variants":[]}],"historicEvents":[{"id":1705187,"age":12,"year":"1215","julianDay":2164830,"title":"Magna Carta","description":"King John of England agreed to a charter of rights called the Magna Carta. The document was originally drafted by the Archbishop of Canterbury to establish peace between King John and a group of rebel barons. The Magna Carta was completed in 1215 and is now considered to be one of the greatest constitutional documents of all time.","url":"https://www.nationalarchives.gov.uk/education/medieval/magna-carta/","urlTitle":"National Archives - Magna Carta","jurisdictionLevel":2},{"id":1705188,"age":21,"year":"1224","julianDay":2168117,"title":"France Declares War on England","description":"France declared war on England as Louis VIII of France attacked Poitou and northern Gascony.","jurisdictionLevel":2},{"id":1705189,"age":56,"year":"1259","julianDay":2180901,"title":"100 Years of Conflict Between England and France Ends","description":"Treaty of Paris was signed on December 4, 1259, which ended 100 years of conflict between England and France.","url":"https://en.wikipedia.org/wiki/Treaty_of_Paris_(1259)","urlTitle":"Wikipedia - Treaty of Paris 1259","jurisdictionLevel":2},{"id":1705190,"age":87,"year":"1290","julianDay":2192224,"title":"Jews Expelled From England","description":"After years of anti-Semitic behavior, King Edward I expelled Jews from England in 1290.","jurisdictionLevel":2},{"id":1705191,"age":112,"year":"1315","toYear":"1317","julianDay":2201354,"title":"Famine Strikes Europe","description":"A famine caused by cold winters and wet summers across E