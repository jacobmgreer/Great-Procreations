"about 1215–about 1260":"circa 1215–circa 1260","1215–1260":"1215–1260","1240–1336":"1240–1336","about 1260":"circa 1260","1336":"1336","1215":"1215","about 1215":"circa 1215","1240":"1240","1260":"1260","Lancashire, England":"Lancashire, Engeland, Verenigd Koninkrijk","Leeds, Yorkshire, England":"Leeds, Yorkshire, Engeland, Verenigd Koninkrijk"},"en":{"about 1215–about 1260":"about 1215–about 1260","1215–1260":"1215–1260","1240–1336":"1240–1336","about 1260":"about 1260","1336":"1336","1215":"1215","about 1215":"about 1215","1240":"1240","1260":"1260","Lancashire, England":"Lancashire, England, United Kingdom","Leeds, Yorkshire, England":"Leeds, Yorkshire, England, United Kingdom","nameMeanings":[{"name":"Yeoman","type":"LAST","attribution":"Dictionary of American Family Names © Patrick Hanks 2003, 2006.","meanings":["English and Scottish: status name, from Middle English <i>yoman</i>, <i>yeman</i>, used of an attendant of relatively high status in a noble household, ranking between a   Sergeant   and a   Groom  , or between a   Squire   and a   Page  . The word probably originated as a shortened form of Middle English <i>yonge man</i>. Later in the Middle English period it came to be used of a modest independent freeholder, and this latter sense may well lie behind some examples of the surname. In Scotland by the 16th century it had come to denote a landholder next in rank below a gentleman, specifically one who owned land worth at least forty shillings a year."],"variants":[{"name":"Sergeant","meanings":["English (Lancashire): variant of   Sargent  .","French: variant of   Sergent  ."]},{"name":"Yeaman","meanings":["Scottish (Angus) and English: variant of   Yeoman  ."]},{"name":"Youman","meanings":["English: variant of   Yeoman  . This form of the surname is now rare in Britain."]},{"name":"Yeomans","meanings":["English (Derbyshire and Staffordshire): variant of   Yeoman  , with post-medieval excrescent <i>-s</i>."]}]},{"name":"Sarah","type":"FIRST","attribution":"Dictionary of First Names © Patrick Hanks and Flavia Hodges 1990, 2003, 2006.","meanings":["Biblical name, borne by the wife of Abraham and mother of Isaac. According to the Book of Genesis, she was originally called <i>Sarai</i> (possibly meaning ‘contentious’ in Hebrew), but had her name changed by God to the more auspicious <i>Sarah</i> ‘princess’ in token of a greater blessing (Genesis 17:15, ‘And God said unto Abraham, As for Sarai thy wife, thou shalt not call her name Sarai, but Sarah shall her name be’). This has been one of the most enduringly popular girls' names."],"variants":[{"name":"Sara","meanings":["Variant of   Sarah .  This is the form used in the Greek of the New Testament (Hebrews 11:11)."]}]}],"lifeSummary":"Sarah Yeoman was born about 1215, in Leeds, Yorkshire, England, United Kingdom. She had at least 1 daughter with Thomas Laytham. She died about 1260, at the age of 47."},"et":{"about 1215–about 1260":"umbes 1215–umbes 1260","1215–1260":"1215–1260","1240–1336":"1240–1336","about 1260":"umbes 1260","1336":"1336","1215":"1215","about 1215":"umbes 1215","1240":"1240","1260":"1260","Lancashire, England":"Lancashire, Inglismaa, United Kingdom","Leeds, Yorkshire, England":"Leeds, Yorkshire, Inglismaa, United Kingdom"},"fi":{"about 1215–about 1260":"noin 1215–noin 1260","1215–1260":"1215–1260","1240–1336":"1240–1336","about 1260":"noin 1260","1336":"1336","1215":"1215","about 1215":"noin 1215","1240":"1240","1260":"1260","Lancashire, England":"Lancashire, Englanti, Yhdistynyt kuningaskunta","Leeds, Yorkshire, England":"Leeds, Yorkshire, Englanti, Yhdistynyt kuningaskunta"},"fr":{"about 1215–about 1260":"environ 1215–environ 1260","1215–1260":"1215–1260","1240–1336":"1240–1336","about 1260":"environ 1260","1336":"1336","1215":"1215","about 1215":"environ 1215","1240":"1240","1260":"1260","Lancashire, England":"Lancashire, Angleterre, Royaume-Uni","Leeds, Yorkshire, England":"Leeds, Everwyck, Angleterre, Royaume-Uni","lifeSummary":"Sarah Yeoman est