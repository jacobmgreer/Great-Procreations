r von 31 Jahren in seinem Geburtsort und wurde in Beckington with Standerwick, Somerset, England begraben."},"ht":{"1454–5 October 1485":"1454–5 October 1485","1454–1485":"1454–1485","–1533":"–1533","1450–1504":"1450–1504","1470–1491":"1470–1491","1470–1503":"1470–1503","–1517":"–1517","1430–1489":"1430–1489","1433–1478":"1433–1478","about 1470":"about 1470","7 February 1478":"7 February 1478","5 October 1485":"5 October 1485","1450":"1450","1470":"1470","1491":"1491","1503":"1503","1478":"1478","1489":"1489","1533":"1533","1455":"1455","1433":"1433","1454":"1454","1430":"1430","1485":"1485","1517":"1517","1504":"1504","Somerset, England":"Somerset, England","Beckington, Somerset, England":"Beckington with Standerwick, Somerset, England","Frome, Somerset, England":"Frome, Somerset, England","Devon, England":"Devon, England"},"hu":{"1454–5 October 1485":"1454–1485. október 5.","1454–1485":"1454–1485","–1533":"–1533","1450–1504":"1450–1504","1470–1491":"1470–1491","1470–1503":"1470–1503","–1517":"–1517","1430–1489":"1430–1489","1433–1478":"1433–1478","about 1470":"1470 körül","7 February 1478":"1478. február 7.","5 October 1485":"1485. október 5.","1450":"1450","1470":"1470","1491":"1491","1503":"1503","1478":"1478","1489":"1489","1533":"1533","1455":"1455","1433":"1433","1454":"1454","1430":"1430","1485":"1485","1517":"1517","1504":"1504","Somerset, England":"Somerset, England","Beckington, Somerset, England":"Beckington with Standerwick, Somerset, England","Frome, Somerset, England":"Frome, Somerset, England","Devon, England":"Devon, England"},"id":{"1454–5 October 1485":"1454–5 Oktober 1485","1454–1485":"1454–1485","–1533":"–1533","1450–1504":"1450–1504","1470–1491":"1470–1491","1470–1503":"1470–1503","–1517":"–1517","1430–1489":"1430–1489","1433–1478":"1433–1478","about 1470":"sekitar 1470","7 February 1478":"7 Februari 1478","5 October 1485":"5 Oktober 1485","1450":"1450","1470":"1470","1491":"1491","1503":"1503","1478":"1478","1489":"1489","1533":"1533","1455":"