":"okolo 1250–Zesnulý","1285–1360":"1285–1360","1286–1340":"1286–1340","1250–Male":"1250–Zesnulý","about 1250":"okolo 1250","14 March 1290":"14. března 1290","1286":"1286","1340":"1340","1285":"1285","1250":"1250","1360":"1360","Cumbernauld, Lanarkshire, Scotland":"Lanarkshire, Skotsko, United Kingdom"},"da":{"about 1250–":"omkring 1250–Afdød","1285–1360":"1285–1360","1286–1340":"1286–1340","1250–Male":"1250–Afdød","about 1250":"omkring 1250","14 March 1290":"14. marts 1290","1286":"1286","1340":"1340","1285":"1285","1250":"1250","1360":"1360","Cumbernauld, Lanarkshire, Scotland":"Lanarkshire, Skotland, United Kingdom"},"nl":{"about 1250–":"circa 1250–Overleden","1285–1360":"1285–1360","1286–1340":"1286–1340","1250–Male":"1250–Overleden","about 1250":"circa 1250","14 March 1290":"14 maart 1290","1286":"1286","1340":"1340","1285":"1285","1250":"1250","1360":"1360","Cumbernauld, Lanarkshire, Scotland":"Lanarkshire, Schotland, Verenigd Koninkrijk"},"en":{"about 1250–":"about 1250–Deceased","1285–1360":"1285–1360","1286–1340":"1286–1340","1250–Male":"1250–Deceased","about 1250":"about 1250","14 March 1290":"14 March 1290","1286":"1286","1340":"1340","1285":"1285","1250":"1250","1360":"1360","Cumbernauld, Lanarkshire, Scotland":"Lanarkshire, Scotland, United Kingdom","nameMeanings":[{"name":"Fleming","type":"LAST","attribution":"Dictionary of American Family Names © Patrick Hanks 2003, 2006.","meanings":["English: ethnic name for someone from Flanders, from Middle English <i>fleming</i>. The word reflects a Norman French form of Old French <i>flamanc</i> ‘Fleming’, from the stem <i>flam-</i> + the ancient Germanic suffix <i>-ing</i>. In the Middle Ages there was considerable commercial intercourse between England and the Netherlands, particularly in the wool trade, and many Flemish weavers and dyers settled in England. This surname is also common in south and east Scotland and in Ireland, where it is sometimes found in the Gaelicized form <b>Pléamonn</b>.","German: variant of   Flemming  , cognate with 1 above."],"variants":[{"name":"Flemings","meanings":["English: plural form of   Fleming  .","Americanized form of Flemish <b>Vleminckx</b>: patronymic from <b>Vleminck</b>, an ethnic name for someone from Flanders, Middle Dutch <i>vleminc</i>."]},{"name":"Flanders","meanings":["English: ethnic name from Middle English <i>Fla(u)ndres</i> ‘Flanders’, denoting someone from Flanders, a historical region covering parts of modern-day Belgium, France, and the Netherlands. Compare   Fleming  ."]},{"name":"Fleeman","meanings":["English: variant of   Fleming  ."]},{"name":"Flemming","meanings":["German: ethnic name for someone from Flanders, Middle High German <i>vlaeminc</i>. People from Flanders spread throughout Germany, as well as England, in the Middle Ages as clothmakers and dyers.","English: variant of   Fleming  ."]},{"name":"Flamenco","meanings":["Spanish: ethnic name from <i>flamenco</i> ‘Fleming, Flemish person’ (see   Fleming  )."]}]},{"name":"Robert","type":"FIRST","attribution":"Dictionary of First Names © Patrick Hanks and Flavia Hodges 1990, 2003, 2006.","meanings":["One of the many French names of Germanic origin that were introduced into Britain by the Normans; it has since remained in continuous use. It is derived from the nearly synonymous elements <i>hrōd</i> ‘fame’ + <i>berht</i> ‘bright, famous’, and had a native Old English predecessor of similar form (<i>Hreodbeorht</i>), which was supplanted by the Norman name. Two dukes of Normandy in the 11th century bore the name: the father of  William the Conqueror  (sometimes identified with the legendary Robert the Devil), and his eldest son. It was borne also by three kings of Scotland, notably  Robert the Bruce  (  1274–1329 ), who freed Scotland from English domination. The altered short form <i>Bob</i> is very common, but <i>Hob</i> and <i>Dob</i>, which were common in the Middle Ages and gave rise to surnames, are extinct.  See also  Rupert ."],"variants":[]}],"lifeSummary":"Robert Fleming was born about 1250, in Lanarkshire, Scotland, United Kingdom. He had at least 2 sons."},"et":{"about 1250–":"umbes 1250–Surnud","1285–1360":"1285–1360","1286–1340":"1286–1340","1250–Male":"1250–Surnud","about 1250":"umbes 1250","14 March 1290":"14. märts 1290","1286":"1286","1340":"1340","1285":"1285","1250":"1250","1360":"1360","Cumbernauld, Lanarkshire, Scotland":"Lanarkshire, Šotimaa, United Kingdom"},"fi":{"about 1250–":"noin 1250–Kuollut","1285–1360":"1285–1360","1286–1340":"1286–1340","1250–Male":"1250–Kuollut","about 1250":"noin 1250","14 March 1290":"14. maaliskuuta 1290","1286":"1286","1340":"1340","1285":"1285","1250":"1250","1360":"1360","Cumbernauld, Lanarkshire, Scotland":"Lanarkshire, Skotlanti, Yhdistynyt kuningaskunta"},"fr":{"about 1250–":"environ 1250–Décédé","1285–1360":"1285–1360","1286–1340":"1286–1340","1250–Male":"1250–Décédé","about 1250":"environ 1250","14 March 1290":"14 mars 1290","1286":"1286","1340":"1340","1285":"1285","1250":"1250","1360":"1360","Cumbernauld, Lanarkshire, Scotland":"Lanarkshire, Écosse, Royaume-Uni","lifeSummary":"Robert Fleming est né environ 1250, à Lanarkshire, Écosse, Royaume-Uni. Il a eu au moins 2 fils."},"de":{"about 1250–":"um 1250–Verstorben","1285–1360":"1285–1360","1286–1340":"1286–1340","1250–Male":"1250–Verstorben","about 1250":"um 1250","14 March 1290":"14. März 1290","1286":"1286","1340":"1340","1285":"1285","1250":"1250","1360":"1360","Cumbernauld, Lanarkshire, Scotland":"Lanarkshire, Schottland, United Kingdom","lifeSummary":"Robert Fleming wurde um 1250 in Lanarkshire, Schottland, United Kingdom geboren. Er hatte mindestens 2 Söhne."},"ht":{"about 1250–":"about 1250–Desede","1285–1360":"1285–1360","1286–1340":"1286–1340","1250–Male":"1250–Desede","about 1250":"about 1250","14 March 1290":"14 March 1290","1286":"1286","1340":"1340","1285":"1285","1250":"1250","1360":"1360","Cumbernauld, Lanarkshire, Scotland":"Lanarkshire, Ecosse, United Kingdom"},"hu":{"about 1250–":"1250 körül–elh