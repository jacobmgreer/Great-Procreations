200":"大約1200年","circa 1255":"大約1255年","1227":"1227年","1304":"1304年","1226":"1226年","1255":"1255年","1200":"1200年","1160":"1160年","circa 1224":"大約1224年","10 oktober 1226":"1226年10月10日","Berkel, Brabant, Nederland":"荷蘭努-布拉班特貝可爾","Brabant, Nederland":"荷蘭布拉班特","Netherlands":"荷蘭","lifeSummary":"Heer Willem Jan van Wijtvliet是Sijmon Willem Floris Teijlinc VAN WIJTFLIET和Aleid Jan Arnout VAN HEESBEEN的兒子，於大約1200年出生在荷蘭布拉班特。他於大約1224年與Dame Ada Ijsbrandsdr van Wijtvliet van der Made在荷蘭布拉班特結婚。他們至少是1個女兒的父母。他去世於大約1255年在他的家鄉享年57歲。"},"zh-hans":{"circa 1200–circa 1255":"大约1200年–大约1255年","1200–1255":"1200年–1255年","1200–Female":"1200年–殁","1226–1304":"1226年–1304年","1160–1227":"1160年–1227年","–Female":"殁","circa 1200":"大约1200年","circa 1255":"大约1255年","1227":"1227年","1304":"1304年","1226":"1226年","1255":"1255年","1200":"1200年","1160":"1160年","circa 1224":"大约1224年","10 oktober 1226":"1226年10月10日","Berkel, Brabant, Nederland":"荷兰努-布拉班特貝可爾","Brabant, Nederland":"荷兰布拉班特","Netherlands":"荷兰","lifeSummary":"Heer Willem Jan van Wijtvliet是Sijmon Willem Floris Teijlinc VAN WIJTFLIET和Aleid Jan Arnout VAN HEESBEEN的儿子，于大约1200年出生在荷兰布拉班特。他于大约1224年与Dame Ada Ijsbrandsdr van Wijtvliet van der Made在荷兰布拉班特结婚。他们至少是1个女儿的父母。他去世于大约1255年在他的家乡享年57岁。"},"hr":{"circa 1200–circa 1255":"oko 1200.–oko 1255.","1200–1255":"1200–1255","1200–Female":"1200–preminula","1226–1304":"1226–1304","1160–1227":"1160–1227.","–Female":"preminula","circa 1200":"oko 1200.","circa 1255":"oko 1255.","1227":"1227.","1304":"1304","1226":"1226","1255":"1255","1200":"1200","1160":"1160","circa 1224":"oko 1224.","10 oktober 1226":"10. listopada 1226.","Berkel, Brabant, Nederland":"Berkel, Noord-Brabant, Nizozemska","Brabant, Nederland":"Brabant, Nizozemska","Netherlands":"Nizozemska"},"cs":{"circa 1200–circa 1255":"okolo 1200–okolo 1255","1200–1255":"1200–1255","1200–Female":"1200–Zesnulá","1226–1304":"1226–1304","1160–1227":"1160–1227","–Female":"Zesnulá","circa 1200":"okolo 1200","circa 1255":"okolo 1255","1227":"1227","1304":"1304","1226":"1226",