iam John Chauntrell31岁，母亲Lucy Booth27岁。他于大约1475年与Elizabeth Mann在英国英格兰諾薩普頓史爾諾薩普頓结婚。他们至少是2个儿子和2个女儿的父母。他去世于1480年在他的家乡享年25岁，埋葬在英国英格兰諾薩普頓史爾可亞頓。"},"hr":{"1455–1480":"1455.–1480.","1459–1526":"1459–1526","1476–1546":"1476–1546","1478–1546":"1478–1546","1481–1541":"1481–1541","1424–1520":"1424–1520","1428–Female":"1428–preminula","abtg 1478":"1478.","1481":"1481","1480":"1480.","abt 1476":"oko 1476.","1459":"1459","1546":"1546","1424":"1424","1478":"1478","1455":"1455.","1520":"1520","1476":"1476","ABT 1475":"oko 1475.","1541":"1541","1428":"1428","1526":"1526","Creaton, Northamptonshire, England":"Creaton, Northamptonshire, Engleska, United Kingdom","of Litchborough, Northampton, Eng.":"Litchborough, Northamptonshire, Engleska, United Kingdom","Northampton, Northamptonshire, England":"Northampton, Northamptonshire, England"},"cs":{"1455–1480":"1455–1480","1459–1526":"1459–1526","1476–1546":"1476–1546","1478–1546":"1478–1546","1481–1541":"1481–1541","1424–1520":"1424–1520","1428–Female":"1428–Zesnulá","abtg 1478":"1478","1481":"1481","1480":"1480","abt 1476":"okolo 1476","1459":"1459","1546":"1546","1424":"1424","1478":"1478","1455":"1455","1520":"1520","1476":"1476","ABT 1475":"okolo 1475","1541":"1541","1428":"1428","1526":"1526","Creaton, Northamptonshire, England":"Creaton, Northamptonshire, Anglie, United Kingdom","of Litchborough, Northampton, Eng.":"Litchborough, Northamptonshire, Anglie, United Kingdom","Northampton, Northamptonshire, England":"Northampton, Northamptonshire, Anglie"},"da":{"1455–1480":"1455–1480","1459–1526":"1459–1526","1476–1546":"1476–1546","1478–1546":"1478–1546","1481–1541":"1481–1541","1424–1520":"1424–1520","1428–Female":"1428–Afdød","abtg 1478":"1478","1481":"1481","1480":"1480","abt 1476":"omkring 1476","1459":"1459","1546":"1546","1424":"1424","1478":"1478","1455":"1455","1520":"1520","1476":"1476","ABT 1475":"omkring 1475","1541":"1541","1428":"1428","1526":"1526","Creaton, Northamptonshire, England":"Creaton, Northamptonshire, England, U