15","1236":"1236","1224":"1224","1158":"1158","1135":"1135","1167":"1167","about 1158":"okolo 1158","about 1157":"okolo 1157","about 1164":"okolo 1164","Nottinghamshire, England":"Nottinghamshire, Anglie","England":"Anglie","Lancashire, England":"Lancashire, Anglie"},"da":{"1135–":"1135–Afdød","1131–1167":"1131–1167","1158–Male":"1158–Afdød","1162–Female":"1162–Afdød","1164–1236":"1164–1236","1135–Female":"1135–Afdød","about 1162":"omkring 1162","1164":"1164","1131":"1131","1162":"1162","1215":"1215","1236":"1236","1224":"1224","1158":"1158","1135":"1135","1167":"1167","about 1158":"omkring 1158","about 1157":"omkring 1157","about 1164":"omkring 1164","Nottinghamshire, England":"Nottinghamshire, England","England":"England","Lancashire, England":"Lancashire, England"},"nl":{"1135–":"1135–Overleden","1131–1167":"1131–1167","1158–Male":"1158–Overleden","1162–Female":"1162–Overleden","1164–1236":"1164–1236","1135–Female":"1135–Overleden","about 1162":"circa 1162","1164":"1164","1131":"1131","1162":"1162","1215":"1215","1236":"1236","1224":"1224","1158":"1158","1135":"1135","1167":"1167","about 1158":"circa 1158","about 1157":"circa 1157","about 1164":"circa 1164","Nottinghamshire, England":"Nottinghamshire, England","England":"England","Lancashire, England":"Lancashire, England"},"en":{"1135–":"1135–Deceased","1131–1167":"1131–1167","1158–Male":"1158–Deceased","1162–Female":"1162–Deceased","1164–1236":"1164–1236","1135–Female":"1135–Deceased","about 1162":"about 1162","1164":"1164","1131":"1131","1162":"1162","1215":"1215","1236":"1236","1224":"1224","1158":"1158","1135":"1135","1167":"1167","about 1158":"about 1158","about 1157":"about 1157","about 1164":"about 1164","Nottinghamshire, England":"Nottinghamshire, England","England":"England","Lancashire, England":"Lancashire, England","nameMeanings":[{"name":"Joan","type":"FIRST","attribution":"Dictionary of First Names © Patrick Hanks and Flavia Hodges 1990, 2003, 2006.","meanings":["Contracted form of Old French <i>Jo(h)anne</i>, from Latin <i>Io(h)anna</i> (  see  Joanna  ). In England this was the usual feminine form of   John   from the Middle English period onwards and was extremely popular, but in the 16th and 17th centuries it steadily lost ground to   Jane .  It was strongly revived in the first part of the 20th century, partly under the influence of  George Bernard Shaw's  play St Joan (  1923 ), based on the life of  Joan of Arc  (  1412–31 ). Claiming to be guided by the voices of the saints, she persuaded the French dauphin to defy the occupying English forces and have himself crowned, and she led the French army that raised the siege of Orleans in  1429 . The following year she was captured by the Burgundians and sold to the English, and a year later she was burned at the stake for witchcraft at the age of 18 or 19. Her story has captured the imagination of many writers, and she is variously portrayed as a national and political hero, a model of apolitical straightforwardness and honesty, and a religious heroine. She was canonized in  1920 . More recent influences have included the American film actress  Joan Crawford  (  1908–77 , born  Lucille le Sueur ), the British actress  Joan Collins  (  b. 1933 ), the American comedienne  Joan Rivers  (  b. 1933 ), and the West Indian pop singer  Joan Armatrading  (  b. 1950 )."],"variants":[{"name":"John","meanings":["Greek: the Lord gave graciously; whom Jehovah gave; whom Jehovah bestowed."]}]}],"historicEvents":[{"id":1705187,"age":80,"year":"1215","julianDay":2164830,"title":"Magna Carta","description":"King John of England agreed to a charter of rights called the Magna Carta. The document was originally drafted by the Archbishop of Canterbury to establish peace between King John and a group of rebel barons. The Magna Carta was completed in 1215 and is now considered to be one of the greatest constitutional documents of all time.","url":"https://www.nationalarchives.gov.uk/education/medieval/magna-carta/","urlTitle":"National Archives - Magna Carta","jurisdictionLevel":0},{"id":1705188,"age":89,"year":"1224","julianDay":2168117,"title":"France Declares War on England","description":"France declared war on England as Louis VIII of France attacked Poitou and northern Gascony.","jurisdictionLevel":0}],"lifeSummary":"Joan was born in 1135, in England. She married Alan fitz Jordan Sixth Steward of Dol about 1157, in Nottinghamshire, England. They were the parents of at least 1 son and 2 daughters."},"et":{"1135–":"1135–Surnud","1131–1167":"1131–1167","1158–Male":"1158–Surnud","1162–Female":"1162–Surnud","1164–1236":"1164–1236","1135–Female":"1135–Surnud","about 1162":"umbes 1162","1164":"1164","1131":"1131","1162":"1162","1215":"1215","1236":"1236","1224":"1224","1158":"1158","1135":"1135","1167":"1167","about 1158":"umbes 1158","about 1157":"umbes 1157","about 1164":"umbes 1164","Nottinghamshire, England":"Nottinghamshire, England","England":"England","Lancashire, England":"Lancashire, England"},"fi":{"1135–":"1135–Kuollut","1131–1167":"1131–1167","1158–Male":"1158–Kuollut","1162–Female":"1162–Kuollut","1164–1236":"1164–1236","1135–Female":"1135–Kuollut","about 1162":"noin 1162","1164":"1164","1131":"1131","1162":"1162","1215":"1215","1236":"1236","1224":"1224","1158":"1158","1135":"1135","1167":"1167","about 1158":"noin 1158","about 1157":"noin 1157","about 1164":"noin 1164","Nottinghamshire, England":"Nottinghamshire, England","England":"England","Lancashire, England":"Lancashire, England"},"fr":{"1135–":"1135–Décédée","1131–1167":"1131–1167","1158–Male":"1158–Décédé","1162–Female":"1162–Décédée","1164–1236":"1164–1236","1135–Female":"1135–Décédée","about 1162":"environ 1162","1164":"1164","1131":"1131","1162":"1162","1215":"1215","1236":"1236","1224":"1224","1158":"1158","1135":"1135","1167":"1167","about 1158":"environ 1158","about 1157":"environ 1157","about 1164":"environ 1164","Nottinghamshire, England":"Nottinghamshire, Angleterre","England":"Angleterre","Lancashire, England":"