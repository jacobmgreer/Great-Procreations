3–Deceased","1465–1514":"1465–1514","1420–1470":"1420–1470","1422–1475":"1422–1475","1514":"1514","1435":"1435","1455":"1455","1422":"1422","1465":"1465","1475":"1475","1420":"1420","1463":"1463","1440":"1440","1483":"1483","about 1475":"about 1475","1470":"1470","Yorkshire, England":"Yorkshire, England, United Kingdom","England":"England","Bossall, Yorkshire, England":"Bossall, Yorkshire, England","Barham, Kent, England":"Barham, Kent, England","London, England":"London, England","nameMeanings":[{"name":"Davall","type":"LAST","attribution":"Dictionary of Family Names in Britain and Ireland © University of the West of England 2016","meanings":["Norman, English:  See  Deaville  ."],"variants":[{"name":"Deaville","meanings":["English (Staffordshire):","(of Norman origin): habitational name from Déville in Seine-Maritime.","nickname from Middle English <i>devel</i> ‘devil’ (Old English <i>dēofol</i>). This may have been acquired as a pageant name or as a shortened form of a longer nickname such as that of Robert and William <i>Drepedevel</i> (‘kill the devil’), recorded in the 1301 Subsidy Rolls (Sutton Howgrave, in Kirklington, North Yorkshire)."]}]},{"name":"Alice","type":"FIRST","attribution":"Dictionary of First Names © Patrick Hanks and Flavia Hodges 1990, 2003, 2006.","meanings":["Originally a variant of   Adelaide  , representing an Old French spelling of a reduced form of Germanic <i>Adalheidis</i>. <i>Alice</i> and <i>Adelaide</i> were already regarded as distinct names in English during the medieval period. <i>Alice</i> enjoyed a surge of popularity in the 19th century and periods of favour ever since. It was the name of the central character of  Lewis Carroll's  Alice's Adventures in Wonderland (  1865 ) and Through the Looking Glass (  1872 ), who was based on his child friend  Alice Liddell , daughter of the Dean of Christ Church, Oxford."],"variants":[{"name":"Alys","meanings":["Variant spelling of   Alice ."]},{"name":"Alis","meanings":["equivalent of <b>Alice</b> ."]}]}],"historicEvents":[{"id":1705197,"age":15,"year":"1455","julianDay":2252488,"title":"Wars of the Roses","description":"Wars of the Roses was a series of English civil wars for control of the throne of England between the royal families House of Lancaster and the House of York. The name of the war was derived as the red rose was the symbol of the Lancastrians and the white rose was the symbol of the Yorks.","url":"https://www.history.com/topics/british-history/wars-of-the-roses","urlTitle":"History - Wars of the Roses","jurisdictionLevel":1}],"lifeSummary":"When Alice Davall was born in 1440, in London, England, her father, Sir Thomas Davall, was 20 and her mother, Joan Bruyn, was 19. She had at least 1 son and 1 daughter with Brian Redman. She died in 1483, in Bossall, Yorkshire, England, at the age of 43."},"et":{"1440–1483":"1440–1483","1435–Male":"1435–Surnud","1463–Female":"1463–Surnud","1465–1514":"1465–1514","1420–1470":"1420–1470","1422–1475":"1422–1475","1514":"1514","1435":"1435","1455":"1455","1422":"1422","1465":"1465","1475":"1475","1420":"1420","1463":"1463","1440":"1440","1483":"1483","about 1475":"umbes 1475","1470":"1470","Yorkshire, England":"Yorkshire, Inglismaa, United Kingdom","England":"England","Bossall, Yorkshire, England":"Bossall, Yorkshire, England","Barham, Kent, England":"Barham, Kent, England","London, England":"London, England"},"fi":{"1440–1483":"1440–1483","1435–Male":"1435–Kuollut","1463–Female":"1463–Kuollut","1465–1514":"1465–1514","1420–1470":"1420–1470","1422–1475":"1422–1475","1514":"1514","1435":"1435","1455":"1455","1422":"1422","1465":"1465","1475":"1475","1420":"1420","1463":"1463","1440":"1440","1483":"1483","about 1475":"noin 1475","1470":"1470","Yorkshire, England":"Yorkshire, Englanti, Yhdistynyt kuningaskunta","England":"England","Bossall, Yorkshire, England":"Bossall, Yorkshire, England","Barham, Kent, England":"Barham, Kent, England","London, England":"London, England"},"fr":{"1440–1483":"1440–1483",