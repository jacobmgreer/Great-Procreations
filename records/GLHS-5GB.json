0":"1460","1470":"1470","1480":"1480","1558":"1558","1446":"1446","1489":"1489","1500":"1500","1533":"1533","1478":"1478","1510":"1510","1420":"1420","1485":"1485","about 1478":"omkring 1478","1408":"1408","about 1485":"omkring 1485","Wolverton, Buckinghamshire, England":"Wolverton, Buckinghamshire, England","Wolverton,Buckinghamshire,England":"Wolverton, Buckinghamshire, England, United Kingdom","Buckinghamshire, England":"Buckinghamshire, England","Shropshire, England":"Shropshire, England","Wolverton Manor, Shropshire, England":"Shropshire, England, United Kingdom"},"nl":{"1460–1500":"1460–1500","1446–1489":"1446–1489","1473–Male":"1473–Overleden","1478–1558":"1478–1558","1480–1558":"1480–1558","1480–1571":"1480–1571","1485–Male":"1485–Overleden","1500–1533":"1500–1533","1408–1470":"1408–1470","1420–1510":"1420–1510","1473":"1473","1571":"1571","1460":"1460","1470":"1470","1480":"1480","1558":"1558","1446":"1446","1489":"1489","1500":"1500","1533":"1533","1478":"1478","1510":"1510","1420":"1420","1485":"1485","about 1478":"circa 1478","1408":"1408","about 1485":"circa 1485","Wolverton, Buckinghamshire, England":"Wolverton, Buckinghamshire, England","Wolverton,Buckinghamshire,England":"Wolverton, Buckinghamshire, Engeland, Verenigd Koninkrijk","Buckinghamshire, England":"Buckinghamshire, England","Shropshire, England":"Shropshire, England","Wolverton Manor, Shropshire, England":"Shropshire, Engeland, Verenigd Koninkrijk"},"en":{"1460–1500":"1460–1500","1446–1489":"1446–1489","1473–Male":"1473–Deceased","1478–1558":"1478–1558","1480–1558":"1480–1558","1480–1571":"1480–1571","1485–Male":"1485–Deceased","1500–1533":"1500–1533","1408–1470":"1408–1470","1420–1510":"1420–1510","1473":"1473","1571":"1571","1460":"1460","1470":"1470","1480":"1480","1558":"1558","1446":"1446","1489":"1489","1500":"1500","1533":"1533","1478":"1478","1510":"1510","1420":"1420","1485":"1485","about 1478":"about 1478","1408":"1408","about 1485":"about 1485","Wolverton, Buckinghamshire, England":"Wolverton, Buckinghamshire, England","Wolverton,Buckinghamshire,England":"Wolverton, Buckinghamshire, England, United Kingdom","Buckinghamshire, England":"Buckinghamshire, England","Shropshire, England":"Shropshire, England","Wolverton Manor, Shropshire, England":"Shropshire, England, United Kingdom","nameMeanings":[{"name":"Moore","type":"LAST","attribution":"Dictionary of American Family Names © Patrick Hanks 2003, 2006.","meanings":["English: from Middle English <i>more</i> ‘moor, marsh, fen’ (Old English <i>mōr</i>), hence a topographic name for someone who lived in such a place, or a habitational name from any of various places called with this word, as for example Moore in Cheshire or More in Shropshire.","English (of Norman origin): ethnic name from Old French <i>more</i> ‘Moor’, either someone from North Africa or, more often, a nickname for someone thought to resemble a Moor. Compare   Morrell   and   Moreau  .","English (of Norman origin): from the Middle English personal name <i>More</i> (Old French <i>More</i>, <i>Maur</i>, Latin <i>Maurus</i>), originally denoting either ‘Moor’ or someone with a swarthy complexion (compare   Morrell  ,   Morrin  ,   Morris  , and sense 2 above). There was a 6th-century Christian saint of this name."],"variants":[{"name":"Moor","meanings":["English, Irish, Scottish, and Welsh: variant of   Moore  .","German: variant of   Mohr  .","Dutch (also <b>De Moor</b>): nickname for a man of swarthy complexion, from Middle Dutch <i>moor</i> ‘Moor’ (from Latin <i>maurus</i>), or a topographic or habitational name referring to a house distinguished by the sign of a Moor. Compare   De Moor  ."]},{"name":"More","meanings":["French: nickname for a dark-skinned man, from a diminutive of Old French <i>more</i> ‘Moor’ (see   More  )."]},{"name":"Morrin","meanings":["Some characteristic forenames:  Irish Dermot.","English (of Norman origin): from the Old French personal name <i>Morin</i>, a diminutive of <i>More</i> (Old French <i>More</i>, <i>Maur</i>, Latin <i>Maurus</i>); see   Moore   2 and 3.","English: perhaps sometimes from the Middle English personal name <i>Morwin</i> (Old English <i>Mōrwine</i>, the first element of which is uncertain and the second <i>wine</i> ‘friend’)."]},{"name":"Mauro","meanings":["Some characteristic forenames:  Italian Salvatore, Angelo, Sal, Domenic, Giuseppe, Antonio, Carmine, Carmelo, Domenico, Gaetano, Nino, Pasquale.","Italian (mainly southern): from the personal name <i>Mauro</i>, derived from the Latin personal and ethnic name <i>Maurus</i>, borne by various early Christian saints and meaning ‘Moor, North African’. Compare   Moore   and   Moro  ."]},{"name":"Moresco","meanings":["Some characteristic forenames:  Italian Primo, Gino, Luciano, Riccardo.","Italian:","(<b>Morésco</b>): from a medieval personal name or a nickname for someone from North Africa or a swarthy or dark-haired man, from medieval Latin <i>Mauriscus</i> ‘Moor’ (see   Moore   2)."]},{"name":"Morey","meanings":["Irish (Limerick and Cork): variant of   Moore   4.","English (of Norman origin): from the Old French personal name <i>Mory</i>, a pet form of <i>Amauri</i> (see   Amery  ).","English: perhaps also a variant of   Moore   1–3."]},{"name":"Morrell","meanings":["English (northern): from the medieval personal name <i>Morel</i>, a diminutive of Middle English or Old French <i>More</i>. Compare   Moore  .","Americanized form of French   Morel  . Compare   Morell   3."]},{"name":"Moores","meanings":["English (Lancashire and Cheshire): variant of   Moore  , with post-medieval excrescent <i>-s</i>."]},{"name":"McMoore","meanings":["Irish: variant of   Moore   4, in which <i>Mac-</i> ‘son of’ has been prefixed in modern times to give the name (<b>Ó Mórdha</b> ‘descendant of Mórdha’) an unmistakably Gaelic identity."]},{"name":"Moro","meanings":["Some characteristic forenames:  Spanish Jose, Carlos, Mario, Alberto, Jorge, Lino, Luis, Luiz, Manuel, Ramiro, Adolfo, Aida.  Italian Angelo, Pino, Pio, Remo, Antonio, Ciro, Cosmo, Elio, Enrico, Geno, Giancarlo, Gino.","Spanish: nickname or ethnic name from <i>moro</i> ‘Moor’, from Latin <i>Maurus</i> ‘Moor, North African’.","Italian: nickname from <i>moro</i> ‘Moor’ (see   Moore   2, compare 1 above), also ‘black-haired man’."]}]},{"name":"Mary","type":"FIRST","attribution":"Dictionary of First Names © Patrick Hanks and Flavia Hodges 1990, 2003, 2006.","meanings":["From Hebrew.  See  <b>Maria</b>   and   <b>Mary</b> ."],"variants":[]}],"lifeSummary":"When Mary Moore was born in 1460, in Wolverton, Buckinghamshire, England, her father, Richard Moore, was 52 and her mother, Lady Mary Perkes Havens, was 40. She had at least 6 sons with Roland Jenkes. She died in 1500, in Buckinghamshire, England, at the age of 40."},"et":{"1460–1500":"1460–1500","1446–1489":"1446–1489","1473–Male":"1473–Surnud","1478–1558":"1478–1558","1480–1558":"1480–1558","1480–1571":"1480–1571","1485–Male":"1485–Surnud","1500–1533":"1500–1533","1408–1470":"1408–1470","1420–1510":"1420–1510","1473":"1473","1571":"1571","1460":"1460","1470":"1470","1480":"1480","1558":"1558","1446":"1446","1489":"1489","1500":"1500","1533":"1533","1478":"1478","1510":"1510","1420":"1420","1485":"1485","about 1478":"umbes 1478","1408":"1408","about 1485":"umbes 1485","Wolverton, Buckinghamshire, England":"Wolverton, Buckinghamshire, England","Wolverton,Buckinghamshire,England":"Wolverton, Buckinghamshire, Inglismaa, United Kingdom","Buckinghamshire, England":"Buckinghamshire, England","Shropshire, England":"Shropshire, England","Wolverton Manor, Shropshire, England":"Shropshire, Inglismaa, United Kingdom"},"fi":{"1460–1500":"1460–1500","1446–1489":"1446–1489","1473–Male":"1473–Kuollut","1478–1558":"1478–1558","1480–1558":"1480–1558","1480–1571":"1480–1571","1485–Male":"1485–Kuollut","1500–1533":"1500–1533","1408–1470":"1408–1470","1420–1510":"1420–1510","1473":"1473","1571":"1571","1460":"1460","1470":"1470","1480":"1480","1558":"1558","1446":"1446","1489":"1489","