omerset, Inglaterra, United Kingdom","England":"Inglaterra","lifeSummary":"Quando Sir William FitzAdams nasceu aproximadamente 1165, em Charlton Adam, Somerset, Inglaterra, United Kingdom, seu pai, Caradog ap Meurig of Penrhos, tinha 41 anos e sua mãe, Maude Matilda Fitz Walter, tinha 29 anos. Ele casou-se com Alice de Crèvecoeur em 1190, em Somerset, Inglaterra. Eles tiveram pelo menos 2 filhos. Ele faleceu aproximadamente 1206, em Hereford, Herefordshire, Inglaterra, United Kingdom, com 43 anos."},"ro":{"about 1165–about 1206":"aproximativ 1165–aproximativ 1206","1160–1250":"1160–1250","1165–1206":"1165–1206","1163–1247":"1163–1247","1190–Male":"1190–Decedat","1195–1252":"1195–1252","1125–1173":"1125–1173","1137–Female":"1137–Decedată","1190":"1190","1165":"1165","1252":"1252","1163":"1163","1173":"1173","1195":"1195","1250":"1250","1160":"1160","1206":"1206","1137":"1137","1247":"1247","about 1206":"aproximativ 1206","1125":"1125","about 1165":"aproximativ 1165","before 1160":"înainte de 1160","Somerset, England":"Somerset, England","Penrhos, Wales":"Penrhos, Montgomeryshire, Țara Galilor, United Kingdom","Hereford, Herefordshire, England, United Kingdom":"Hereford, Herefordshire, Anglia, United Kingdom","Charlton Adam, Somerset, England, United Kingdom":"Charlton Adam, Somerset, Anglia, United Kingdom","Europe":"Europe","Charleton Fitz Adam, Somerset, England":"Somerset, Anglia, United Kingdom","England":"England"},"ru":{"about 1165–about 1206":"около 1165 г.–около 1206 г.","1160–1250":"1160г.–1250г.","1165–1206":"1165г.–1206г.","1163–1247":"1163г.–1247г.","1190–Male":"1190г.–Умерший","1195–1252":"1195г.–1252г.","1125–1173":"1125г.–1173г.","1137–Female":"1137г.–Умершая","1190":"1190 г.","1165":"1165 г.","1252":"1252 г.","1163":"1163 г.","1173":"1173 г.","1195":"1195 г.","1250":"1250 г.","1160":"1160 г.","1206":"1206 г.","1137":"1137 г.","1247":"1247 г.","about 1206":"около 1206 г.","1125":"1125 г.","about 1165":"около 1165 г.","before 1160":"перед 1160 г.","Some