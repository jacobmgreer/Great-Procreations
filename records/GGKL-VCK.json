on VIIは42歳，母Anabilla de Rode de Astonは20歳であった。彼はFelice Hawardenとの間に少なくとも1人の娘をもうけた。彼は1356年に41歳で死去した。"},"ko":{"1315–1356":"1315년–1356년","1297–1367":"1297년–1367년","1383–1411":"1383년–1411년","1273–1345":"1273년–1345년","1295–1345":"1295년–1345년","1315":"1315년","1345":"1345년","1356":"1356년","1411":"1411년","1367":"1367년","1297":"1297년","1295":"1295년","1273":"1273년","1383":"1383년","lifeSummary":"Robert de Ashton I(이)가 1315년에 태어났을 때, 그의 아버지 Richard de Ashton VII(은)는 42세였고, 그의 어머니 Anabilla de Rode de Aston(은)는 20세였다. 그는 Felice Hawarden(와)과 적어도 한 명의 딸을 두었다. 그는 1356년 41세의 나이로 사망했다."},"lv":{"1315–1356":"1315.gads–1356.gads","1297–1367":"1297–1367","1383–1411":"1383–1411","1273–1345":"1273–1345.gads","1295–1345":"1295–1345.gads","1315":"1315. gads","1345":"1345. gads","1356":"1356. gads","1411":"1411","1367":"1367","1297":"1297","1295":"1295","1273":"1273","1383":"1383"},"mg":{"1315–1356":"1315–1356","1297–1367":"1297–1367","1383–1411":"1383–1411","1273–1345":"1273–1345","1295–1345":"1295–1345","1315":"1315","1345":"1345","1356":"1356","1411":"1411","1367":"1367","1297":"1297","1295":"1295","1273":"1273","1383":"1383"},"ms":{"1315–1356":"1315–1356","1297–1367":"1297–1367","1383–1411":"1383–1411","1273–1345":"1273–1345","1295–1345":"1295–1345","1315":"1315","1345":"1345","1356":"1356","1411":"1411","1367":"1367","1297":"1297","1295":"1295","1273":"1273","1383":"1383"},"mn":{"1315–1356":"1315он–1356он","1297–1367":"1297он–1367он","1383–1411":"1383он–1411он","1273–1345":"1273он–1345он","1295–1345":"1295он–1345он","1315":"1315 он","1345":"1345 он","1356":"1356 он","1411":"1411 он","1367":"1367 он","1297":"1297 он","1295":"1295 он","1273":"1273 он","1383":"1383 он"},"no":{"1315–1356":"1315–1356","1297–1367":"1297–1367","1383–1411":"1383–1411","1273–1345":"1273–1345","1295–1345":"1295–1345","1315":"1315","1345":"1345","1356":"1356","1411":"1411","1367":"1367","1297":"1297","1295":"1295","1273":"1273","1383":"1383"},"pl":{"1315–1356":"1315r.–1356r.","1297–1367":"1297r.–1367r.","1383–1411":