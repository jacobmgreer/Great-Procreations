rthamptonshire, England, United Kingdom":"Northamptonshire, Engleska, United Kingdom"},"cs":{"about 1108–":"okolo 1108–Zesnulý","1108–Male":"1108–Zesnulý","1117–1141":"1117–1141","1139–1164":"1139–1164","1141–Male":"1141–Zesnulý","1077–1107":"1077–1107","1086–Female":"1086–Zesnulá","1077":"1077","1164":"1164","1141":"1141","1086":"1086","Abt 1107":"okolo 1107","1107":"1107","1139":"1139","1117":"1117","1215":"1215","1224":"1224","about 1108":"okolo 1108","about 1138":"okolo 1138","1108":"1108","Winwick, Lancashire, England":"Winwick, Lancashire, Anglie","Northamptonshire, England":"Northamptonshire, Anglie","Winwick, Northamptonshire, England":"Winwick, Northamptonshire, Anglie","Northamptonshire, England, United Kingdom":"Northamptonshire, Anglie, United Kingdom"},"da":{"about 1108–":"omkring 1108–Afdød","1108–Male":"1108–Afdød","1117–1141":"1117–1141","1139–1164":"1139–1164","1141–Male":"1141–Afdød","1077–1107":"1077–1107","1086–Female":"1086–Afdød","1077":"1077","1164":"1164","1141":"1141","1086":"1086","Abt 1107":"omkring 1107","1107":"1107","1139":"1139","1117":"1117","1215":"1215","1224":"1224","about 1108":"omkring 1108","about 1138":"omkring 1138","1108":"1108","Winwick, Lancashire, England":"Winwick, Lancashire, England","Northamptonshire, England":"Northamptonshire, England","Winwick, Northamptonshire, England":"Winwick, Northamptonshire, England","Northamptonshire, England, United Kingdom":"Northamptonshire, England, United Kingdom"},"nl":{"about 1108–":"circa 1108–Overleden","1108–Male":"1108–Overleden","1117–1141":"1117–1141","1139–1164":"1139–1164","1141–Male":"1141–Overleden","1077–1107":"1077–1107","1086–Female":"1086–Overleden","1077":"1077","1164":"1164","1141":"1141","1086":"1086","Abt 1107":"circa 1107","1107":"1107","1139":"1139","1117":"1117","1215":"1215","1224":"1224","about 1108":"circa 1108","about 1138":"circa 1138","1108":"1108","Winwick, Lancashire, England":"Winwick, Lancashire, England","Northamptonshire, England":"Northamptonshire, England","Winwick, Northamptonshire, England":"Winwick, Northamptonshire, England","Northamptonshire, England, United Kingdom":"Northamptonshire, Engeland, Verenigd Koninkrijk"},"en":{"about 1108–":"about 1108–Deceased","1108–Male":"1108–Deceased","1117–1141":"1117–1141","1139–1164":"1139–1164","1141–Male":"1141–Deceased","1077–1107":"1077–1107","1086–Female":"1086–Deceased","1077":"1077","1164":"1164","1141":"1141","1086":"1086","Abt 1107":"about 1107","1107":"1107","1139":"1139","1117":"1117","1215":"1215","1224":"1224","about 1108":"about 1108","about 1138":"about 1138","1108":"1108","Winwick, Lancashire, England":"Winwick, Lancashire, England","Northamptonshire, England":"Northamptonshire, England","Winwick, Northamptonshire, England":"Winwick, Northamptonshire, England","Northamptonshire, England, United Kingdom":"Northamptonshire, England, United Kingdom","nameMeanings":[{"name":"Andrews","type":"LAST","attribution":"Dictionary of American Family Names © Patrick Hanks 2003, 2006.","meanings":["English: variant of   Andrew  , with genitival or post-medieval excrescent <i>-s</i>. This is the usual southern English patronymic form, also found in Wales; the Scottish and northern English form is   Anderson  . In North America, this surname has absorbed various cognates from other languages, e.g. Polish   Andrzejewski  , Slovenian <b>Andrejčič</b>, Serbian and Croatian <b>Andrić</b> (see   Andric  ), and Czech <b>Ondráček</b> (see   Ondracek  ).","Irish and Scottish: Anglicized form of Scottish Gaelic <b>Mac Aindreis</b> or Irish <b>Mac Aindriú</b>, see   McAndrew  .","History: This was a common name among the early settlers in New England. Robert Andrews emigrated in 1635 from Norwich, England, to Ipswich, MA. Even before 1635, one Thomas Andrews is recorded as being established in Hingham. A certain William Andrews was a member of John Davenport's company, which sailed from Boston in 1638 to found the New Haven colony."],"variants":[{"name":"Andrus","meanings":["English: variant of   Andrews  .","History: William Andrus came to Boston in 1635 and moved to New Haven in 1639, where he died in 1676."]},{"name":"Andrew","meanings":["English and Scottish: from the usual vernacular English form (recorded from the 13th century onward) of the New Testament Greek personal name   Andreas  . In North America, the English form of the surname has absorbed many cognates from other languages, e.g. Czech <b>Ondřej</b> (see   Ondrey  ) and Albanian   Ndreu  , and also their patronymics and other derivatives (see examples at   Andrews  ).","History: The surname Andrew was first brought to North America from England by Robert Andrew (died 1668), who settled in Boxford, MA."]},{"name":"Andros","meanings":["English: variant of   Andrews  . This surname is very rare in Britain.","American shortened form of Greek <b>Andronikos</b> (see   Andron   2) or of any other surname based on a personal name beginning with <i>Andr-</i> (from <i>andros</i>, genitive of <i>anēr</i> ‘man, male’), e.g. <b>Androutsos</b>, including their patronymics and other derivatives, such as <b>Andronikidis</b>.","History: William Andros came to VA in 1617 and died there <i>c.</i> 1655. Sir Edmund Andros (1637–1714) was the British colonial governor of several provinces in America between 1674 and 1698, most notably NY (1674–81)."]}]},{"name":"John","type":"FIRST","attribution":"Dictionary of First Names © Patrick Hanks and Flavia Hodges 1990, 2003, 2006.","meanings":["As a boy's name this represents a revival of Middle English <i>Jan</i>, a by‐form of   John  , or an adoption of the common European form with this spelling. As a girl's name it is a short form of names such as   Janet   and   Janice ."],"variants":[]}],"historicEvents":[{"id":1705187,"age":107,"year":"1215","julianDay":2164830,"title":"Magna Carta","description":"King John of England agreed to a charter of rights called the Magna Carta. The document was originally drafted by the Archbishop of Canterbury to establish peace between King John and a group of rebel barons. The Magna Carta was completed in 1215 and is now considered to be one of the greatest constitutional documents of all time.","url":"https://www.nationalarchives.gov.uk/education/medieval/magna-carta/","urlTitle":"National Archives - Magna Carta","jurisdictionLevel":2},{"id":1705188,"age":116,"year":"1224","julianDay":2168117,"title":"France Declares War on England","description":"France declared war on England as Louis VIII of France attacked Poitou and northern Gascony.","jurisdictionLevel":2}],"lifeSummary":"When Sir John Andrews was born about 1108, in Winwick, Northamptonshire, England, his father, Sir Robert Andrews II, was 33 and his mother, Lady Isabel Grecia Brewer, was 24. He married Lady Elizabeth Norton about 1138, in Northamptonshire, England. They were the parents of at least 2 sons. He died in his hometown."},"et":{"about 1108–":"umbes 1108–Surnud","1108–Male":"1108–Surnud","1117–1141":"1117–1141","1139–1164":"1139–1164","1141–Male":"1141–Surnud","1077–1107":"1077–1107","1086–Female":"1086–Surnud","1077":"1077","1164":"1164","1141":"1141","1086":"1086","Abt 1107":"umbes 1107","1107":"1107","1139":"1139","1117":"1117","1215":"1215","1224":"1224","about 1108":"umbes 1108","about 1138":"umbes 1138","1108":"1108","Winwick, Lancashire, England":"Winwick, Lancashire, England","Northamptonshire, England":"Northamptonshire, England","Winwick, Northamptonshire, England":"Winwick, Northamptonshire, England","Northamptonshire, England, United Kingdom":"Northamptonshire, Inglismaa, United Kingdom"},"fi":{"about 1108–":"noin 1108–Kuollut","1108–Male":"1108–Kuollut","1117–1141":"1117–1141","1139–1164":"1139–1164","1141–Male":"1141–Kuollut","1077–1107":"1077–1107","1086–Female":"1086–Kuollut","1077":"1077","1164":"1164","1141":"1141","1086":"1086","Abt 1107":"noin 1107","1107":"1107","1139":"1139","1117":"1117","1215":"1215","1224":"1224","about 1108":"noin 1108","about 1138":"noin 1138","1108":"1108","Winwic