ed","1066–1098":"1066–1098","1090–1158":"1090–1158","1092–Female":"1092–Deceased","1073–Female":"1073–Deceased","1090":"1090","1106":"1106","about 1073":"about 1073","1158":"1158","about 1092":"about 1092","1066":"1066","1098":"1098","1086":"1086","1096":"1096","1073":"1073","1092":"1092","Winchester, Hampshire, England":"Winchester, Hampshire, England","Europe":"Europe","Daventry, Northamptonshire, England":"Daventry, Northamptonshire, England","nameMeanings":[{"name":"Judith","type":"FIRST","attribution":"Dictionary of First Names © Patrick Hanks and Flavia Hodges 1990, 2003, 2006.","meanings":["Biblical name, meaning ‘Jewess’ or ‘woman from Judea’, borne by a Jewish heroine whose story is recorded in the Book of Judith in the Apocrypha. Judith is portrayed as a beautiful widow who delivers her people from the invading Assyrians by gaining the confidence of their commander, Holofernes, and cutting off his head while he is asleep; without their commander, the Assyrians are duly routed. This has been a perennially popular Jewish name. In the English-speaking world it was taken up in the 16th century, having been in occasional use among Gentiles before this: for example, it was borne by a niece of William the Conqueror. It enjoyed great popularity between the 1940s and the 1960s. Today's notable bearers include the American novelist  Judith Krantz  (  b. 1928 ) and the Scottish composer  Judith Weir  (  b. 1954 )."],"variants":[]}],"historicEvents":[{"id":1705183,"age":13,"year":"1086","julianDay":2117714,"title":"Domesday Book","description":"Domesday Book is Britain's earliest extant public record with information containing land surveys and landholdings commissioned by William I. The book was completed in 1086.","url":"https://www.nationalarchives.gov.uk/domesday/","urlTitle":"National Archives - Domesday","jurisdictionLevel":2},{"id":1705184,"age":23,"year":"1096","julianDay":2121366,"title":"The Crusades","description":"A series of religious wars between Christi