272","1260":"1260","1194":"1194","1072":"1072","1181":"1181","1216":"1216","1326":"1326","1215":"1215","1204":"1204","1259":"1259","1248":"1248","1137":"1137","1225":"1225","1224":"1224","Abt 1255":"circa 1255","1255":"1255","1287":"1287","1208":"1208","Cheshire, England":"Cheshire, England","Stanley, Staffordshire, England":"Stanley, Staffordshire, Engeland, Verenigd Koninkrijk","Hooton, Cheshire, England":"Hooton, Cheshire, England","Lancashire, England":"Lancashire, England"},"en":{"1215–1285":"1215–1285","1194–Male":"1194–Deceased","1208–1248":"1208–1248","1208–Male":"1208–Deceased","1225–1285":"1225–1285","1250–1326":"1250–1326","1255–Male":"1255–Deceased","1072–1137":"1072–1137","1181–1287":"1181–1287","1285":"1285","1250":"1250","1272":"1272","1260":"1260","1194":"1194","1072":"1072","1181":"1181","1216":"1216","1326":"1326","1215":"1215","1204":"1204","1259":"1259","1248":"1248","1137":"1137","1225":"1225","1224":"1224","Abt 1255":"about 1255","1255":"1255","1287":"1287","1208":"1208","Cheshire, England":"Cheshire, England","Stanley, Staffordshire, England":"Stanley, Staffordshire, England, United Kingdom","Hooton, Cheshire, England":"Hooton, Cheshire, England","Lancashire, England":"Lancashire, England","nameMeanings":[{"name":"Stanley","type":"LAST","attribution":"Dictionary of American Family Names © Patrick Hanks 2003, 2006.","meanings":["English: habitational name from any of various places called Stanley, including those in Yorkshire, Staffordshire, Derbyshire, Durham, Gloucestershire, and Wiltshire, named with Old English <i>stān</i> ‘stone, rock’ + <i>lēah</i> ‘woodland clearing’. This English name has been established in Ireland since the 13th century where it was Gaelicized as <b>de Stainléigh</b>.","English: possibly also a variant of <b>Stoneley</b>, a habitational name from Stoneley Green in Burland (Cheshire), Stoneleigh (Warwickshire), or Stonely in Kimbolton (Huntingdonshire), all named with Old English <i>stān</i> ‘stone, rock’ + <i>lēah</i> ‘woodland clearing’.","Americanized form of any of various like-sounding names in other languages, for example Polish   Stanislawski  , Greek   Anastasiou  , and Serbian <b>Stojadinov</b> (patronymic from the personal name <i>Stojadin</i>)."],"variants":[{"name":"Stanislawski","meanings":["Polish (<b>Stanisławski</b>): habitational name for someone from any of various places called Stanisław, Stanisławów, or Stanisławice, named with the personal name <i>Stanisław</i> (see   Stanislav  )."]},{"name":"Standley","meanings":["English: variant of   Stanley  ."]}]},{"name":"Walter","type":"FIRST","attribution":"Dictionary of First Names © Patrick Hanks and Flavia Hodges 1990, 2003, 2006.","meanings":["From an Old French personal name of Germanic (Frankish) origin, derived from <i>wald</i> ‘rule’ + <i>heri</i>, <i>hari</i> ‘army’. This was adopted by the Normans and introduced by them to England, superseding the native Old English form, <i>Wealdhere</i>. It was a very popular name in medieval England, normally pronounced ‘Water’."],"variants":[{"name":"Walther","meanings":["from <i>wald</i> ‘rule’ + <i>heri</i> ‘army’; name of the famous medieval minnesinger  Walther von der Vogelweide  (  <i>c.</i>1170– <i>c.</i>1230 )."]}]}],"historicEvents":[{"id":1705187,"age":0,"year":"1215","julianDay":2164830,"title":"Magna Carta","description":"King John of England agreed to a charter of rights called the Magna Carta. The document was originally drafted by the Archbishop of Canterbury to establish peace between King John and a group of rebel barons. The Magna Carta was completed in 1215 and is now considered to be one of the greatest constitutional documents of all time.","url":"https://www.nationalarchives.gov.uk/education/medieval/magna-carta/","urlTitle":"National Archives - Magna Carta","jurisdictionLevel":2},{"id":1705188,"age":9,"year":"1224","julianDay":2168117,"title":"France Declares War on England","description":"France declared war on England as Louis VIII of France attacked Poitou and northern Gascony.","jurisdictionLevel":2},{"id":1705189,"age":44,"year":"1259","julianDay":2180901,"title":"100 Years of Conflict Between England and France Ends","description":"Treaty of Paris was signed on December 4, 1259, which ended 100 years of conflict between England and France.","url":"https://en.wikipedia.org/wiki/Treaty_of_Paris_(1259)","urlTitle":"Wikipedia - Treaty of Paris 1259","jurisdictionLevel":2}],"lifeSummary":"When Sir Walter Stanley was born in 1215, his father, Sir William Walter de Stanley, was 143 and his mother, Clemence de Blore, was 34. He married Margery de Hooton in 1260, in Cheshire, England. They were the parents of at least 3 sons. In 1272, at the age of 57, his occupation is listed as juryman. He died in 1285, in Stanley, Staffordshire, England, United Kingdom, at the age of 70."},"et":{"1215–1285":"1215–1285","1194–Male":"1194–Surnud","1208–1248":"1208–1248","1208–Male":"1208–Surnud","1225–1285":"1225–1285","1250–1326":"1250–1326","1255–Male":"1255–Surnud","1072–1137":"1072–1137","1181–1287":"1181–1287","1285":"1285","1250":"1250","1272":"1272","1260":"1260","1194":"1194","1072":"1072","1181":"1181","1216":"1216","1326":"1326","1215":"1215","1204":"1204","1259":"1259","1248":"1248","1137":"1137","1225":"1225","1224":"1224","Abt 1255":"umbes 1255","1255":"1255","1287":"1287","1208":"1208","Cheshire, England":"Cheshire, England","Stanley, Staffordshire, England":"Stanley, Staffordshire, Inglismaa, United Kingdom","Hooton, Cheshire, England":"Hooton, Cheshire, England","Lancashire, England":"Lancashire, England"},"fi":{"1215–1285":"1215–1285","1194–Male":"1194–Kuollut","1208–1248":"1208–1248","1208–Male":"1208–Kuollut","1225–1285":"1225–1285","1250–1326":"1250–1326","1255–Male":"1255–Kuollut","1072–1137":"1072–1137","1181–1287":"1181–1287","1285":"1285","1250":"1250","1272":"1272","1260":"1260","1194":"1194","1072":"1072","1181":"1181","1216":"1216","1326":"1326","1215":"1215","1204":"1204","1259":"1259","1248":"1248"