IC","gender":"Male","lifespan":"–1041","deathDate":"+1041","@type":"Person","identifier":"GHGS-SVJ","url":"https://ancestors.familysearch.org/en/GHGS-SVJ/muirchertach-mac-gilla-patraic-1041","published":true}],"spouse":[{"name":"Mrs Donnchad MacGillapatrick","gender":"Female","lifespan":"1009–Female","birthDate":"A+1009","@type":"Person","identifier":"GLQN-BWD","url":"https://ancestors.familysearch.org/en/GLQN-BWD/mrs-donnchad-macgillapatrick-1009","published":true}],"children":[{"name":"Sadb MacGillapatrick","gender":"Female","lifespan":"1127–1162","birthDate":"+1127","deathDate":"+1162","age":35,"portrait":{"url":"https://tree-portraits-pgp.familysearchcdn.org/b582e/thumb64.jpg","@type":"ImageObject"},"otherParentId":"GLQN-BWD","@type":"Person","identifier":"LHT5-R49","url":"https://ancestors.familysearch.org/en/LHT5-R49/sadb-macgillapatrick-1127-1162","published":true}],"ageAtDeath":44,"@type":"Person","@context":"http://schema.org","identifier":"GHGS-D5X","memories":1,"photos":1,"stories":0,"sources":2,"nameSources":2,"genderSources":0,"url":"https://ancestors.familysearch.org/en/GHGS-D5X/donnchad-macgillapatrick%2C-king-of-osraige-and-leinster-0996-1039"},"localizedData":{"sq":{"before 0996–1039":"para vitit 0996–viti 1039","0990–1027":"vitit0990–vitit1027","0996–1039":"viti0996–viti1039","–1039":"–viti1039","–1041":"–vitit1041","1009–Female":"vitit1009–E Vdekur","1127–1162":"vitit1127–vitit1162","0947–0996":"vitit0947–viti0996","0935–1021":"vitit0935–vitit1021","before 0996":"para vitit 0996","before 1027":"para vitit 1027","1033":"viti 1033","1021":"vitit 1021","1162":"vitit 1162","1041":"vitit 1041","0996":"viti 0996","Abt 1021":"rreth vitit 1021","1039":"viti 1039","1127":"vitit 1127","1027":"vitit 1027","0990":"vitit 0990","0947":"vitit 0947","0935":"vitit 0935","1009":"vitit 1009","Ireland":"Irlanda","Kilkenny, County Kilkenny, Ireland":"Kilkenny, County Kilkenny, Irlanda"},"hy":{"before 0996–1039":"before 0996–1039","0990–1027":"0990–1027","0996–1039":"0