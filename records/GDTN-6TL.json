nings":["form of   Isabel  , now in frequent use in the English-speaking world."],"variants":[{"name":"Isabel","meanings":["Originally a Spanish version of   Elizabeth  , which was coined by deletion of the first syllable and alteration of the final consonant sound to one that can normally end a word in Spanish. The name was imported into France in the early Middle Ages, and thence into England. It was a royal name, and its enduring popularity may have been enhanced by the fact that it was borne by a queen of England—  Isabella  (  1296–1358 ), daughter of  Philip IV  of France—even though she led a turbulent life and eventually had her husband,  Edward II , murdered."]}]},{"name":"of","type":"FIRST","attribution":"Dictionary of First Names © Patrick Hanks and Flavia Hodges 1990, 2003, 2006.","meanings":["Short form of   Oswald   or any of the various other names beginning with <i>Os-</i>."],"variants":[]},{"name":"Tamworth","type":"LAST","attribution":"Dictionary of Family Names in Britain and Ireland © University of the West of England 2016","meanings":["English: locative name from Tamworth (Staffs)."],"variants":[]}],"historicEvents":[{"id":1705187,"age":50,"year":"1215","julianDay":2164830,"title":"Magna Carta","description":"King John of England agreed to a charter of rights called the Magna Carta. The document was originally drafted by the Archbishop of Canterbury to establish peace between King John and a group of rebel barons. The Magna Carta was completed in 1215 and is now considered to be one of the greatest constitutional documents of all time.","url":"https://www.nationalarchives.gov.uk/education/medieval/magna-carta/","urlTitle":"National Archives - Magna Carta","jurisdictionLevel":2},{"id":1705188,"age":59,"year":"1224","julianDay":2168117,"title":"France Declares War on England","description":"France declared war on England as Louis VIII of France attacked Poitou and northern Gascony.","jurisdictionLevel":2}],"lifeSummary":"Isabelle of Tamworth was born in 1165, in Drayton Bassett, Staffordshire, England. She married Ralph Bassett II in 1190, in Drayton Bassett, Staffordshire, England, United Kingdom. They were the parents of at least 1 son. She died in 1224, in Hanslope, Buckinghamshire, England, at the age of 59."},"et":{"1165–1224":"1165–1224","1155–1211":"1155–1211","1189–1261":"1189–1261","1190":"1190","1215":"1215","1224":"1224","1211":"1211","1189":"1189","1155":"1155","1165":"1165","about 1189":"umbes 1189","1261":"1261","Drayton Bassett Manor, Tamworth, Staffordshire, England":"Drayton Bassett, Staffordshire, England","Drayton Basset, Staffordshire, England":"Drayton Bassett, Staffordshire, Inglismaa, United Kingdom","Hanslope, Buckinghamshire, England.":"Hanslope, Buckinghamshire, England","Drayton Bassett, Staffordshire, England":"Drayton Bassett, Staffordshire, England"},"fi":{"1165–1224":"1165–1224","1155–1211":"1155–1211","1189–1261":"1189–1261","1190":"1190","1215":"1215","1224":"1224","1211":"1211","1189":"1189","1155":"1155","1165":"1165","about 1189":"noin 1189","1261":"1261","Drayton Bassett Manor, Tamworth, Staffordshire, England":"Drayton Bassett, Staffordshire, England","Drayton Basset, Staffordshire, England":"Drayton Bassett, Staffordshire, Englanti, Yhdistynyt kuningaskunta","Hanslope, Buckinghamshire, England.":"Hanslope, Buckinghamshire, England","Drayton Bassett, Staffordshire, England":"Drayton Bassett, Staffordshire, England"},"fr":{"1165–1224":"1165–1224","1155–1211":"1155–1211","1189–1261":"1189–1261","1190":"1190","1215":"1215","1224":"1224","1211":"1211","1189":"1189","1155":"1155","1165":"1165","about 1189":"environ 1189","1261":"1261","Drayton Bassett Manor, Tamworth, Staffordshire, England":"Drayton Bassett, Staffordshire, Angleterre","Drayton Basset, Staffordshire, England":"Drayton Bassett, Staffordshire, Angleterre, Royaume-Uni","Hanslope, Buckinghamshire, England.":"Hanslope, Buckinghamshire, Angleterre","Drayton Bassett, Staffordshire, England":"Drayton Bassett, Staffor