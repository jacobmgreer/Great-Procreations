60":"1200–1260","–1260":"–1260","1244–1303":"1244–1303","–1287":"–1287","–1303":"–1303","1223–1303":"1223–1303","1175–Male":"1175–Overleden","1175–Female":"1175–Overleden","about 1195":"circa 1195","about 14 May 1260":"circa 14 mei 1260","1303":"1303","Abt 1244":"circa 1244","1223":"1223","1200":"1200","1244":"1244","1287":"1287","1175":"1175","1260":"1260","about 1240":"circa 1240","Ulster, Ireland":"Ulster, Ierland","Limavady, Ireland":"Limavady, County Londonderry, Ierland","Limavady District, County Derry, Ireland":"Limavady District, County Londonderry, Ierland","Ireland":"Ierland","at Battle of Down, County Down, Ireland":"County Down, Ierland"},"en":{"1200–about 14 May 1260":"1200–about 14 May 1260","1200–1260":"1200–1260","–1260":"–1260","1244–1303":"1244–1303","–1287":"–1287","–1303":"–1303","1223–1303":"1223–1303","1175–Male":"1175–Deceased","1175–Female":"1175–Deceased","about 1195":"about 1195","about 14 May 1260":"about 14 May 1260","1303":"1303","Abt 1244":"about 1244","1223":"1223","1200":"1200","1244":"1244","1287":"1287","1175":"1175","1260":"1260","about 1240":"about 1240","Ulster, Ireland":"Ulster, Ireland","Limavady, Ireland":"Limavady, County Londonderry, Ireland","Limavady District, County Derry, Ireland":"Limavady District, County Londonderry, Ireland","Ireland":"Ireland","at Battle of Down, County Down, Ireland":"County Down, Ireland","nameMeanings":[{"name":"OCHAAN","type":"LAST","attribution":"Dictionary of American Family Names © Patrick Hanks 2003, 2006.","meanings":["Germanized form of French   Jean  ."],"variants":[{"name":"Jean","meanings":["Some characteristic forenames:  French Pierre, Francois, Marcel, Yves, Andre, Jacques, Georges, Michel, Philippe, Serge, Yvon, Cecile.","French, Walloon, West Indian (mainly Haiti), Mauritian, and English (of French Huguenot origin): from the male personal name <i>Jean</i>, French form of   John  . This is one of the most frequent surnames in Haiti (along with   Joseph   and   Pierre  ). It is also established elsewhere in the West Indies (e.g. in the Dominican Republic, Saint Lucia, Saint Martin, and Bahamas).","English: habitational name for someone from Genoa in Italy; compare   Janeway  ."]}]},{"name":"Magnus","type":"FIRST","attribution":"Dictionary of First Names © Patrick Hanks and Flavia Hodges 1990, 2003, 2006.","meanings":["Originally a Latin byname meaning ‘great’, this was first extracted from the name of <i>Charlemagne</i> (recorded in Latin chronicles as <i>Carolus Magnus</i> ‘Charles the Great’) and used as a given name by the Scandinavians. It was borne by seven medieval kings of Norway, including  Magnus I  (  1024–47 ), known as Magnus the Good, and  Magnus VI  (  1238–80 ), known as Magnus the Law Mender. There are several early Scandinavian saints called Magnus, including an earl of  Orkney  (  d. 1116 ), to whom Kirkwall cathedral is dedicated. The name was imported to Scotland and Ireland during the Middle Ages."],"variants":[{"name":"Mànas","meanings":["Gaelic equivalent of   Magnus ."]}]}],"lifeSummary":"When Prince Magnus Yellow-haired OCHAAN O'Cathain Prince of Limavadi was born in 1200, in Ulster, Ireland, his father, King Raudria O'Cathain - King of Formaeil, was 25 and his mother, Queen of Formaeil O'Cathain, was 25. He married Formaiel O'Caithan about 1240, in Ulster, Ireland. They were the parents of at least 2 sons and 1 daughter. He died about 14 May 1260, in County Down, Ireland, at the age of 60, and was buried in Limavady District, County Londonderry, Ireland."},"et":{"1200–about 14 May 1260":"1200–umbes 14. mai 1260","1200–1260":"1200–1260","–1260":"–1260","1244–1303":"1244–1303","–1287":"–1287","–1303":"–1303","1223–1303":"1223–1303","1175–Male":"1175–Surnud","1175–Female":"1175–Surnud","about 1195":"umbes 1195","about 14 May 1260":"umbes 14. mai 1260","1303":"1303","Abt 1244":"umbes 1244","1223":"1223","1200":"1200","1244":"1244","1287":"1287","1175":"1175","1260":"1260","about 1240":"umbes 1240","Ulster, Ireland":"Ulste