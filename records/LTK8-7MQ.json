ngland":"Pilkington, Lancashire, England","Preston, Lancashire, England":"Preston, Lancashire, England","Lancashire, England":"Lancashire, Engeland, Verenigd Koninkrijk","Samlesbury, Lancashire, England":"Samlesbury, Lancashire, England"},"en":{"1200–1278":"1200–1278","1220–1275":"1220–1275","1195–1268":"1195–1268","1217–1296":"1217–1296","1190–1231":"1190–1231","1190":"1190","before 1268":"before 1268","1231":"1231","1275":"1275","1220":"1220","1296":"1296","1195":"1195","Abt 1217":"about 1217","1217":"1217","1259":"1259","1215":"1215","1224":"1224","1268":"1268","1278":"1278","1200":"1200","about 1200":"about 1200","Liverpool, Lancashire, England":"Liverpool, Lancashire, England","Somme, Picardie, France":"Somme, Picardie, France","Pilkington, Lancashire, England":"Pilkington, Lancashire, England","Preston, Lancashire, England":"Preston, Lancashire, England","Lancashire, England":"Lancashire, England, United Kingdom","Samlesbury, Lancashire, England":"Samlesbury, Lancashire, England","nameMeanings":[{"name":"de","type":"LAST","attribution":"Dictionary of American Family Names © Patrick Hanks 2003, 2006.","meanings":["Some characteristic forenames:  Indian Dilip, Anirban, Gopal, Alok, Anindya, Arunava, Asit, Asok, Dibyendu, Goutam, Indra, Indranil.","Indian: variant of   Dey  ."],"variants":[{"name":"Dey","meanings":["Some characteristic forenames:  Indian Ashit, Indu, Naina, Partha, Soumya, Ajit, Anjan, Anjana, Anup, Arjun, Arun, Ashim.","English, Scottish, and Welsh: variant of   Day  .","German: topographic name from a field name in North Rhine-Westphalia, denoting a sizeable piece of land, from Middle Low German <i>dē</i> ‘thigh’ (referring to the shape of the property)."]}]},{"name":"Notton","type":"LAST","attribution":"Dictionary of Family Names in Britain and Ireland © University of the West of England 2016","meanings":["English: locative name from Notton in Lacock (Wilts) or Notton in Maiden Newton (Dorset), both of which are recorded as  <i>Natton</i> and  <i>Netton</i> in the 13th century. The place-names derive from Old English  <i>nēat</i> ‘cattle’ +  <i>tūn</i> ‘farmstead, settlement’. There has probably been some confusion with   Noton  ."],"variants":[{"name":"Natton","meanings":["English: variant of both   Notton   and   Noton  ."]},{"name":"Noton","meanings":["English: locative name from Notton (WR Yorks), which is recorded as  <i>Notone</i> in 1086 and  <i>Nocton</i> in 1230. The place-name derives from Old English  <i>hnoc</i> ‘wether sheep’ +  <i>tūn</i> ‘farmstead, settlement’. There has probably been some confusion with   Notton  , and perhaps also with   Knutton   and   Nocton  ."]}]},{"name":"Agnes","type":"FIRST","attribution":"Dictionary of First Names © Patrick Hanks and Flavia Hodges 1990, 2003, 2006.","meanings":["Latinized version of the Greek name <i>Hagnē</i>, from the feminine form of the adjective <i>hagnos</i> ‘pure, holy’. This was the name of a young Roman virgin martyred in the persecutions instigated by the Roman emperor Diocletian in   ad  303 . She became a very popular saint in the Middle Ages. Her name was early associated with Latin <i>agnus</i> ‘lamb’, leading to the consistent dropping of the initial <i>H-</i> and to her representation in art accompanied by a lamb. The colloquial form <i>Annes</i> led to some confusion with <i>Ann(e)</i> in earlier centuries. Frequent in the medieval period, the name was revived in the 19th century, and has been especially popular in Scotland.  See also  Annis ."],"variants":[]}],"historicEvents":[{"id":1705187,"age":15,"year":"1215","julianDay":2164830,"title":"Magna Carta","description":"King John of England agreed to a charter of rights called the Magna Carta. The document was originally drafted by the Archbishop of Canterbury to establish peace between King John and a group of rebel barons. The Magna Carta was completed in 1215 and is now considered to be one of the greatest constitutional documents of all time.","url":"https://www.nationalarchives.gov.uk/education/medieval/magna-carta/","urlTitle":"National Archives - Magna Carta","jurisdictionLevel":2},{"id":1705188,"age":24,"year":"1224","julianDay":2168117,"title":"France Declares War on England","description":"France declared war on England as Louis VIII of France attacked Poitou and northern Gascony.","jurisdictionLevel":2},{"id":1705189,"age":59,"year":"1259","julianDay":2180901,"title":"100 Years of Conflict Between England and France Ends","description":"Treaty of Paris was signed on December 4, 1259, which ended 100 years of conflict between England and France.","url":"https://en.wikipedia.org/wiki/Treaty_of_Paris_(1259)","urlTitle":"Wikipedia - Treaty of Paris 1259","jurisdictionLevel":2}],"lifeSummary":"Agnes de Notton was born in 1200, in Preston, Lancashire, England as the daughter of William De Notton II. She had at least 1 son with Geoffrey de Worsley. She died in 1278, in Somme, Picardie, France, at the age of 78, and was buried in Pilkington, Lancashire, England."},"et":{"1200–1278":"1200–1278","1220–1275":"1220–1275","1195–1268":"1195–1268","1217–1296":"1217–1296","1190–1231":"1190–1231","1190":"1190","before 1268":"enne 1268","1231":"1231","1275":"1275","1220":"1220","1296":"1296","1195":"1195","Abt 1217":"umbes 1217","1217":"1217","1259":"1259","1215":"1215","1224":"1224","1268":"1268","1278":"1278","1200":"1200","about 1200":"umbes 1200","Liverpool, Lancashire, England":"Liverpool, Lancashire, England","Somme, Picardie, France":"Somme, Picardie, Prantsusmaa","Pilkington, Lancashire, England":"Pilkington, Lancashire, England","Preston, Lancashire, England":"Preston, Lancashire, England","Lancashire, England":"Lancashire, Inglismaa, United Kingdom","Samlesbury, Lancashire, England":"Samlesbury, Lancashire, England"},"fi":{"1200–1278":"1200–1278","1220–1275":"1220–1275","1195–1268":"1195–1268","1217–1296":"1217–1296","1190–1231":"1190–1231","1190":"1190","before 1268":"ennen vuotta 1268","1231":"1231","1275":"1275","1220":"1220","1296"