lo 1210","1170":"1170","1229":"1229"},"da":{"Abt. 1210–":"omkring 1210–Afdød","1190–1232":"1190–1232","1210–Female":"1210–Afdød","–1246":"–1246","1233–1296":"1233–1296","1170–1229":"1170–1229","–1229":"–1229","1190":"1190","1246":"1246","1233":"1233","1210":"1210","1232":"1232","Abt. 1233":"omkring 1233","1296":"1296","Abt. 1210":"omkring 1210","1170":"1170","1229":"1229"},"nl":{"Abt. 1210–":"circa 1210–Overleden","1190–1232":"1190–1232","1210–Female":"1210–Overleden","–1246":"–1246","1233–1296":"1233–1296","1170–1229":"1170–1229","–1229":"–1229","1190":"1190","1246":"1246","1233":"1233","1210":"1210","1232":"1232","Abt. 1233":"circa 1233","1296":"1296","Abt. 1210":"circa 1210","1170":"1170","1229":"1229"},"en":{"Abt. 1210–":"about 1210–Deceased","1190–1232":"1190–1232","1210–Female":"1210–Deceased","–1246":"–1246","1233–1296":"1233–1296","1170–1229":"1170–1229","–1229":"–1229","1190":"1190","1246":"1246","1233":"1233","1210":"1210","1232":"1232","Abt. 1233":"about 1233","1296":"1296","Abt. 1210":"about 1210","1170":"1170","1229":"1229","nameMeanings":[{"name":"Bending","type":"LAST","attribution":"Dictionary of Family Names in Britain and Ireland © University of the West of England 2016","meanings":["English: probably a variant of   Bindon  .  Compare  Bendon  ."],"variants":[{"name":"Bindon","meanings":["English and Irish: habitational name from Bindon in Axmouth, Devon or Bindon in Wool, Dorset. A member of the family settled in Ireland, and the name <i>Bindon</i> became fairly common in County Clare."]},{"name":"Bendon","meanings":["English:","habitational name from one of four places: Benenden or the lost place called Begginden, both in Kent; Building End in Chrishall in Essex; or Bandons in Anstey in Hertfordshire. Benenden is named from the Old English personal name <i>Bionna</i> + <i>-ing-</i> denoting association with + <i>denn</i> ‘woodland pasture’.","(southwestern): variant of   Bindon  ."]}]},{"name":"Maud","type":"FIRST","attribution":"Dictionary of First Names © Patrick Hanks and Flavia Hodges 1990, 2003, 2006.","meanings":["Medieval vernacular form of   Matilda .  This form was characteristically Low German (i.e. including medieval Dutch and Flemish). The wife of  William the Conqueror , who bore this name, was the daughter of  Baldwin , Count of Flanders. In Flemish and Dutch the letter <i>-t-</i> was generally lost when it occurred between vowels, giving forms such as <i>Ma(h)auld</i>. <i>Maud</i> or <i>Matilda</i> was also the name of the daughter (  1102–67 ) of  Henry I  of England; she was married early in life to the Holy Roman Emperor  Henry V , and later disputed the throne of England with her cousin  Stephen . In  1128  she married  Geoffrey , Count of Anjou. A medieval chronicler commented, ‘she was a good woman, but she had little bliss with him’. The name <i>Maud</i> became quite common in England in the 19th century, when its popularity was influenced in part by  Tennyson's  poem Maud, published in  1855 , but has not been much used since the early decades of the 20th century."],"variants":[]}],"lifeSummary":"Maud Bending was born about 1210 as the daughter of Adam de Bendeng and Alice Gatton. She had at least 1 son with Geoffrey de Sturmy."},"et":{"Abt. 1210–":"umbes 1210–Surnud","1190–1232":"1190–1232","1210–Female":"1210–Surnud","–1246":"–1246","1233–1296":"1233–1296","1170–1229":"1170–1229","–1229":"–1229","1190":"1190","1246":"1246","1233":"1233","1210":"1210","1232":"1232","Abt. 1233":"umbes 1233","1296":"1296","Abt. 1210":"umbes 1210","1170":"1170","1229":"1229"},"fi":{"Abt. 1210–":"noin 1210–Kuollut","1190–1232":"1190–1232","1210–Female":"1210–Kuollut","–1246":"–1246","1233–1296":"1233–1296","1170–1229":"1170–1229","–1229":"–1229","1190":"1190","1246":"1246","1233":"1233","1210":"1210","1232":"1232","Abt. 1233":"noin 1233","1296":"1296","Abt. 1210":"noin 1210","1170":"1170","1229":"1229"},"fr":{"Abt. 1210–":"environ 1210–Décédée","1190–1232":"1190–1232","1210–Female":"1210–Décédée","–1246"