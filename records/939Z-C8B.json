320":"1320年","1364":"1364年","before 1340":"1340年之前","1418":"1418年","Arlington, Devon, England":"英国戴文阿爾林頓",", Devonshire, England":"英国英格兰戴文","Beaford, Devon, England":"英国戴文比阿福德","England":"英国","Devon, England, United Kingdom":"英国英格兰戴文","lifeSummary":"当William Hatch于1350年出生在英国英格兰戴文时，他的父亲Jeffery de Hatche30岁，母亲Elizabeth Hecche30岁。他于大约1380年与Jane Worlington在英国戴文比阿福德结婚。他们至少是3个儿子的父母。他去世于1420年享年70岁。"},"hr":{"1350–1420":"1350.–1420.","1364–1418":"1364–1418","1365–Male":"1365–preminuo","1352–Female":"1352–preminula","1330–Male":"1330–preminuo","1368–1404":"1368.–1404","1399–Male":"1399–preminuo","1320–Male":"1320–preminuo","1320–Female":"1320–preminula","about 1380":"oko 1380.","6 February 1404":"6. veljače 1404.","1330":"1330","1352":"1352","1350":"1350.","1404":"1404","1368":"1368.","Abt 1399":"oko 1399.","1399":"1399","1420":"1420.","1365":"1365","1320":"1320","1364":"1364","before 1340":"prije 1340.","1418":"1418","Arlington, Devon, England":"Arlington, Devon, England",", Devonshire, England":"Devon, Engleska, United Kingdom","Beaford, Devon, England":"Beaford, Devon, England","England":"England","Devon, England, United Kingdom":"Devon, Engleska, United Kingdom"},"cs":{"1350–1420":"1350–1420","1364–1418":"1364–1418","1365–Male":"1365–Zesnulý","1352–Female":"1352–Zesnulá","1330–Male":"1330–Zesnulý","1368–1404":"1368–1404","1399–Male":"1399–Zesnulý","1320–Male":"1320–Zesnulý","1320–Female":"1320–Zesnulá","about 1380":"okolo 1380","6 February 1404":"6. února 1404","1330":"1330","1352":"1352","1350":"1350","1404":"1404","1368":"1368","Abt 1399":"okolo 1399","1399":"1399","1420":"1420","1365":"1365","1320":"1320","1364":"1364","before 1340":"před 1340","1418":"1418","Arlington, Devon, England":"Arlington, Devon, Anglie",", Devonshire, England":"Devon, Anglie, United Kingdom","Beaford, Devon, England":"Beaford, Devon, Anglie","England":"Anglie","Devon, England, United Kingdom":"Devon, Anglie, United Kingdom"},"da":{"1350–1420":"1350–1420","1364–1418":"1364–1418","1365–Male":"13