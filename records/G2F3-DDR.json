ber 1200":"13 Nopember 1200","1093":"1093","1138":"1138","1136":"1136","1179":"1179","1212":"1212","1201":"1201","1135":"1135","1200":"1200","1155":"1155","about 7 December 1130":"sekitar 7 Desember 1130","1219":"1219","Lancaster, Lancashire, England":"Lancaster, Lancashire, England","Workington, Cumberland, England":"Workington, Cumberland, England","Scotland":"Scotland"},"it":{"about 7 December 1130–13 November 1200":"circa 7 dicembre 1130–13 novembre 1200","1130–1200":"1130–1200","1135–Male":"1135–Deceduto","1138–Male":"1138–Deceduto","1135–1201":"1135–1201","1136–Female":"1136–Deceduta","1155–1212":"1155–1212","1151–1219":"1151–1219","1093–1179":"1093–1179","1120–1163":"1120–1163","1120":"1120","1163":"1163","1130":"1130","1151":"1151","13 November 1200":"13 novembre 1200","1093":"1093","1138":"1138","1136":"1136","1179":"1179","1212":"1212","1201":"1201","1135":"1135","1200":"1200","1155":"1155","about 7 December 1130":"circa 7 dicembre 1130","1219":"1219","Lancaster, Lancashire, England":"Lancaster, Lancashire, England","Workington, Cumberland, England":"Workington, Cumberland, England","Scotland":"Scotland","lifeSummary":"Quando Sir Thomas Fitz Gospatric, Lord of Culwen, of Workington è nato il circa 7 dicembre 1130 nel Scotland, il suo padre, Gospatric de Workington of High Ireby, aveva 38 anni e il suo madre, Egeline d'Engaine, aveva 10 anni. Lui avuto almeno 1 figlia con Grace de Culwen. Morì il 13 novembre 1200, nel Workington, Cumberland, England, all'età di 69 anni."},"ja":{"about 7 December 1130–13 November 1200":"約1130年12月7日–1200年11月13日","1130–1200":"1130年–1200年","1135–Male":"1135年–死亡","1138–Male":"1138年–死亡","1135–1201":"1135年–1201年","1136–Female":"1136年–死亡","1155–1212":"1155年–1212年","1151–1219":"1151年–1219年","1093–1179":"1093年–1179年","1120–1163":"1120年–1163年","1120":"1120年","1163":"1163年","1130":"1130年","1151":"1151年","13 November 1200":"1200年11月13日","1093":"1093年","1138":"1138年","1136":"1136年","1179":"1179年","1212":"1212年","1201":"1201年","1135":"113