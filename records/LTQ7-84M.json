land":"Ballycullane, County Kildare, Irland","Trevidrian, Cornwall, England":"Cornwall, England","Trevidren, Cornwall, England":"Cornwall, England, United Kingdom","of Trevidren, Cornwall, England":"Cornwall, England, United Kingdom","County Kildare, Ireland":"County Kildare, Irland","Cornwall, England":"Cornwall, England","Treviddren Manor, Cornwall, England":"Cornwall, England, United Kingdom"},"nl":{"1204–1268":"1204–1268","1228–Male":"1228–Overleden","1230–1273":"1230–1273","1232–1325":"1232–1325","1247–Female":"1247–Overleden","1248–1344":"1248–1344","–Male":"Overleden","1182–Female":"1182–Overleden","1230":"1230","1273":"1273","ABT 1228":"circa 1228","1182":"1182","1228":"1228","1204":"1204","1248":"1248","1325":"1325","1247":"1247","1224":"1224","1268":"1268","1344":"1344","about 1248":"circa 1248","1232":"1232","Ballycullane, County Kildare, Ireland":"Ballycullane, County Kildare, Ierland","Trevidrian, Cornwall, England":"Cornwall, England","Trevidren, Cornwall, England":"Cornwall, Engeland, Verenigd Koninkrijk","of Trevidren, Cornwall, England":"Cornwall, Engeland, Verenigd Koninkrijk","County Kildare, Ireland":"County Kildare, Ierland","Cornwall, England":"Cornwall, England","Treviddren Manor, Cornwall, England":"Cornwall, Engeland, Verenigd Koninkrijk"},"en":{"1204–1268":"1204–1268","1228–Male":"1228–Deceased","1230–1273":"1230–1273","1232–1325":"1232–1325","1247–Female":"1247–Deceased","1248–1344":"1248–1344","–Male":"Deceased","1182–Female":"1182–Deceased","1230":"1230","1273":"1273","ABT 1228":"about 1228","1182":"1182","1228":"1228","1204":"1204","1248":"1248","1325":"1325","1247":"1247","1224":"1224","1268":"1268","1344":"1344","about 1248":"about 1248","1232":"1232","Ballycullane, County Kildare, Ireland":"Ballycullane, County Kildare, Ireland","Trevidrian, Cornwall, England":"Cornwall, England","Trevidren, Cornwall, England":"Cornwall, England, United Kingdom","of Trevidren, Cornwall, England":"Cornwall, England, United Kingdom","County Kildare, Ireland":"County Kildare, Ireland","Cornwall, England":"Cornwall, England","Treviddren Manor, Cornwall, England":"Cornwall, England, United Kingdom","nameMeanings":[{"name":"FitzGerald","type":"LAST","attribution":"Dictionary of American Family Names © Patrick Hanks 2003, 2006.","meanings":["Some characteristic forenames:  Irish Brendan, Eamon, Liam, Aidan, Bridgid, Caitlin, Donal, Fitz, Fitzgerald, Ciaran, Colum, Dermot.","Irish: from Anglo-Norman French <i>fi(t)z</i> ‘son’ (see   Fitz  ) + the personal name <i>Gerald</i> (see   Gerald  ), ‘son of <i>Gerald</i>’. This is a very common Anglo-Norman name in Ireland, where it has been Gaelicized as <b>Mac Gearailt</b>. Irish bearers of the name claim descent from <i>Gerald</i> Fitzwalter de Windsor, constable of Pembroke Castle in the early 12th century, whose grandson Raymond (or Redmond) ‘le Gros’ <i>FitzGerald</i> (died after 1185) led the invasion of Ireland on behalf of Strongbow in 1170. A branch of the family held the title Knight of Glin from at least 1299–2011."],"variants":[{"name":"Jarrell","meanings":["Irish: altered form of   Fitzgerald  .","English (Kent and Middlesex; of Norman origin): variant of <b>Jarrold</b>, itself a variant of   Gerald  ."]},{"name":"Fitz","meanings":["English: from Anglo-Norman French <i>fi(t)z</i> ‘son’ (from Latin <i>filius</i>), used originally to distinguish a son from a father bearing the same personal name and then conventionalized as a hereditary surname, or short for a surname of which <i>fiz</i> ‘son’ was the first element, for example   Fitzhenry   and   Fitzroy  .","Altered form of English   Fitch  .","German: from a vernacular pet form of the personal name <i>Vinzenz</i> (see   Vincent  ) or <i>Vitus</i> (see   Vito  , compare   Veit  ). Compare also   Fietz  ."]}]},{"name":"Margaret","type":"FIRST","attribution":"Dictionary of First Names © Patrick Hanks and Flavia Hodges 1990, 2003, 2006.","meanings":["An extremely common given name from the Middle Ages onwards, derived via Old French <i>Marguerite</i> and Latin <i>Margarita</i> from Greek <i>Margarītēs</i>, from <i>margaron</i> ‘pearl’, a word ultimately of Hebrew origin. The name was always understood to mean ‘pearl’ throughout the Middle Ages. The first  St Margaret  was martyred at Antioch in Pisidia during the persecution instigated by the  Emperor Diocletian  in the early 4th century. However, there is some doubt about her name, as the same saint is venerated in the Orthodox Church as   Marina .  There were several other saintly bearers of the name, including St Margaret of Scotland (  d. 1093 ), wife of  King Malcolm Canmore  and daughter of Edmund Ironside of England. It was also the name of the wife of  Henry VI  of England,  Margaret of Anjou  (  1430–82 ), and of  Margaret Tudor  (  1489–1541 ), sister of  Henry VIII , who married James IV of Scotland and ruled as regent there after his death.  See also  Margery  ,   Marjorie ."],"variants":[{"name":"Margareta","meanings":["From the Latin form of Greek <i>Margarītēs</i>.  See  <b>Margaret</b>   ."]},{"name":"Margaretta","meanings":["An extremely common given name from the Middle Ages onwards, derived via Old French <i>Marguerite</i> and Latin <i>Margarita</i> from Greek <i>Margarītēs</i>, from <i>margaron</i> ‘pearl’, a word ultimately of Hebrew origin. The name was always understood to mean ‘pearl’ throughout the Middle Ages. The first  St Margaret  was martyred at Antioch in Pisidia during the persecution instigated by the  Emperor Diocletian  in the early 4th century. However, there is some doubt about her name, as the same saint is venerated in the Orthodox Church as   Marina .  There were several other saintly bearers of the name, including St Margaret of Scotland (  d. 1093 ), wife of  King Malcolm Canmore  and daughter of Edmund Ironside of England. It was also the name of the wife of  Henry VI  of England,  Margaret of Anjou  (  1430–82 ), and of  Margaret Tudor  (  1489–1541 ), sister of  Henry VIII , who married James IV of Scotland and ruled as regent there after his death.  See also  Margery  ,   Marjorie ."]}]}],"lifeSummary":"Margaret FitzGerald of Kildare was born in 1204, in County Kildare, Ireland as the daughter of Christopher Fitzgerald, Count and Unnamed. She had at least 2 sons and 3 daughters with Sir Vyell Vyvyan. She died in 1268, in Cornwall, England, United Kingdom, at the age of 64."},"et":{"1204–1268":"1204–1268","1228–Male":"1228–Surnud","1230–1273":"1230–1273","1232–1325":"1232–1325","1247–Female":"1247–Surnud","1248–1344":"1248–1344","–Male":"Surnud","1182–Female":"1182–Surnud","1230":"1230","1273":"1273","ABT 1228":"umbes 1228","1182":"1182","1228":"1228","1204":"1204","1248":"1248","1325":"1325","1247":"1247","1224":"1224","1268":"1268","1344":"1344","about 1248":"umbes 1248","1232":"1232","Ballycullane, County Kildare, Ireland":"Ballycullane, County Kildare, Iirimaa","Trevidrian, Cornwall, England":"Cornwall, England","Trevidren, Cornwall, England":"Cornwall, Inglismaa, United Kingdom","of Trevidren, Cornwall, England":"Cornwall, Inglismaa, United Kingdom","County Kildare, Ireland":"County Kildare, Iirimaa","Cornwall, England":"Cornwall, England","Treviddren Manor, Cornwall, England":"Cornwall, Inglismaa, United Kingdom"},"fi":{"1204–1268":"1204–1268","1228–Male":"1228–Kuollut","1230–1273":"1230–1273","1232–1325":"1232–1325","1247–Female":"1247–Kuollut","1248–1344":"1248–1344","–Male":"Kuollut","1182–Female":"1182–Kuollut","1230":"1230","1273":"1273","ABT 1228":"noin 1228","1182":"1182","1228":"1228","1204":"1204","1248":"1248","1325":"1325","1247":"1247","1224":"1224","1268":"1268","1344":"1344","about 1248":"noin 1248","1232":"1232","Ballycullane, County Kildare, Ireland":"Ballycullane, County Kildare, Irlanti","Trevidrian, Cornwall, England":"Cornwall, England","Trevidren, Cornwall, England":"Cornwall, Englanti, Yhdistynyt kuningaskunta","of Trevidren, Cornwall, England":"Cornwall, Englanti, Yhdistynyt kuningaskunta","County Kildare, Ireland"