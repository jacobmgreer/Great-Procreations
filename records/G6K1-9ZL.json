om":"Staffordshire, Engeland, Verenigd Koninkrijk"},"en":{"about 1140–":"about 1140–Deceased","1215–Female":"1215–Deceased","1140–Male":"1140–Deceased","about 1140":"about 1140","1215":"1215","1140":"1140","Staffordshire, England, United Kingdom":"Staffordshire, England, United Kingdom","nameMeanings":[{"name":"Bray","type":"LAST","attribution":"Dictionary of American Family Names © Patrick Hanks 2003, 2006.","meanings":["English: habitational name from any of the places in Berkshire and Devon. The former is probably named with Old French <i>bray</i> ‘marsh’, the latter from the Cornish element <i>bre</i> ‘hill’.","English: perhaps a topographic name from northern Middle English <i>bra</i> ‘steep (river) bank’ or ‘brow of a hill’, denoting someone who lived at such a place.","English (of Norman origin): habitational name from any of several places in Normandy or Picardy called Bray (Eure, Calvados, Aisne, Somme); see 6."],"variants":[{"name":"Dubray","meanings":["Some characteristic forenames:  French Napoleon.","French: habitational name, with fused preposition and definite article <i>du</i> ‘from the’, for someone from any of various minor places called Bray (see   Bray  ).","Altered form of French   Dubreuil  . This surname is common among Native Americans, namely the Cheyenne River Sioux in SD."]},{"name":"Braye","meanings":["English (Sussex): from the Middle English female personal name <i>Braye</i>. Its origin is unknown but it might derive from Breton <i>bregh</i> ‘fine, brave’."]},{"name":"Brais","meanings":["Some characteristic forenames:  French Marcel, Aldea, Andre, Cecile, Fernande, Stephane.","French: altered form of   Bray  ."]}]},{"name":"William","type":"FIRST","attribution":"Dictionary of First Names © Patrick Hanks and Flavia Hodges 1990, 2003, 2006.","meanings":["Probably the most successful of all the Old French names of Germanic origin that were introduced to England by the Normans. It is derived from Germanic <i>wil</i> ‘will, desire’ + <i>helm</i> ‘helmet, protection’. The fact that it was borne by the Conqueror himself does not seem to have inhibited its favour with the ‘conquered’ population: in the first century after the Conquest it was the commonest male name of all, and not only among the Normans. In the later Middle Ages it was overtaken by   John  , but continued to run second to that name until the 20th century, when the picture became more fragmented."],"variants":[]},{"name":"of","type":"FIRST","attribution":"Dictionary of First Names © Patrick Hanks and Flavia Hodges 1990, 2003, 2006.","meanings":["Short form of   Oswald   or any of the various other names beginning with <i>Os-</i>."],"variants":[]}],"lifeSummary":"William of Bray was born about 1140, in Staffordshire, England, United Kingdom. He had at least 1 daughter."},"et":{"about 1140–":"umbes 1140–Surnud","1215–Female":"1215–Surnud","1140–Male":"1140–Surnud","about 1140":"umbes 1140","1215":"1215","1140":"1140","Staffordshire, England, United Kingdom":"Staffordshire, Inglismaa, United Kingdom"},"fi":{"about 1140–":"noin 1140–Kuollut","1215–Female":"1215–Kuollut","1140–Male":"1140–Kuollut","about 1140":"noin 1140","1215":"1215","1140":"1140","Staffordshire, England, United Kingdom":"Staffordshire, Englanti, Yhdistynyt kuningaskunta"},"fr":{"about 1140–":"environ 1140–Décédé","1215–Female":"1215–Décédée","1140–Male":"1140–Décédé","about 1140":"environ 1140","1215":"1215","1140":"1140","Staffordshire, England, United Kingdom":"Staffordshire, Angleterre, Royaume-Uni","lifeSummary":"William of Bray est né environ 1140, à Staffordshire, Angleterre, Royaume-Uni. Il a eu au moins 1 fille."},"de":{"about 1140–":"um 1140–Verstorben","1215–Female":"1215–Verstorben","1140–Male":"1140–Verstorben","about 1140":"um 1140","1215":"1215","1140":"1140","Staffordshire, England, United Kingdom":"Staffordshire, England, United Kingdom","lifeSummary":"William of Bray wurde um 1140 in Staffordshire, England, United Kingdom geboren. Er hatte mindestens 1 Tocht