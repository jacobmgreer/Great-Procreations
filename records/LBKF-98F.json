m":"Jórvík, England, United Kingdom","Radbourne, Derbyshire, England":"Radbourne, Derbyshire, England, United Kingdom","Radbourne, Derbyshire, England, United Kingdom":"Radbourne, Derbyshire, England, United Kingdom"},"nl":{"Abt 1218–after 1248":"circa 1218–na 1248","1218–1248":"1218–1248","1220–Male":"1220–Overleden","1227–1253":"1227–1253","1163–Male":"1163–Overleden","1248–1280":"1248–1280","1199–1238":"1199–1238","1203–Female":"1203–Overleden","1253":"1253","1220":"1220","Abt 1248":"circa 1248","1163":"1163","Abt 1218":"circa 1218","1280":"1280","1238":"1238","after 1248":"na 1248","1227":"1227","1248":"1248","1203":"1203","1199":"1199","about 1225":"circa 1225","1218":"1218","Derbyshire, England":"Derbyshire, Engeland, Verenigd Koninkrijk","Yorkshire, England, United Kingdom":"Yorkshire, Engeland, Verenigd Koninkrijk","Radbourne, Derbyshire, England":"Radbourne, Derbyshire, Engeland, Verenigd Koninkrijk","Radbourne, Derbyshire, England, United Kingdom":"Radbourne, Derbyshire, Engeland, Verenigd Koninkrijk"},"en":{"Abt 1218–after 1248":"about 1218–after 1248","1218–1248":"1218–1248","1220–Male":"1220–Deceased","1227–1253":"1227–1253","1163–Male":"1163–Deceased","1248–1280":"1248–1280","1199–1238":"1199–1238","1203–Female":"1203–Deceased","1253":"1253","1220":"1220","Abt 1248":"about 1248","1163":"1163","Abt 1218":"about 1218","1280":"1280","1238":"1238","after 1248":"after 1248","1227":"1227","1248":"1248","1203":"1203","1199":"1199","about 1225":"about 1225","1218":"1218","Derbyshire, England":"Derbyshire, England, United Kingdom","Yorkshire, England, United Kingdom":"Yorkshire, England, United Kingdom","Radbourne, Derbyshire, England":"Radbourne, Derbyshire, England, United Kingdom","Radbourne, Derbyshire, England, United Kingdom":"Radbourne, Derbyshire, England, United Kingdom","nameMeanings":[{"name":"Margaret","type":"FIRST","attribution":"Dictionary of First Names © Patrick Hanks and Flavia Hodges 1990, 2003, 2006.","meanings":["An extremely common given name from the Middle Ages onwards, derived via Old French <i>Marguerite</i> and Latin <i>Margarita</i> from Greek <i>Margarītēs</i>, from <i>margaron</i> ‘pearl’, a word ultimately of Hebrew origin. The name was always understood to mean ‘pearl’ throughout the Middle Ages. The first  St Margaret  was martyred at Antioch in Pisidia during the persecution instigated by the  Emperor Diocletian  in the early 4th century. However, there is some doubt about her name, as the same saint is venerated in the Orthodox Church as   Marina .  There were several other saintly bearers of the name, including St Margaret of Scotland (  d. 1093 ), wife of  King Malcolm Canmore  and daughter of Edmund Ironside of England. It was also the name of the wife of  Henry VI  of England,  Margaret of Anjou  (  1430–82 ), and of  Margaret Tudor  (  1489–1541 ), sister of  Henry VIII , who married James IV of Scotland and ruled as regent there after his death.  See also  Margery  ,   Marjorie ."],"variants":[{"name":"Margareta","meanings":["From the Latin form of Greek <i>Margarītēs</i>.  See  <b>Margaret</b>   ."]},{"name":"Margaretta","meanings":["An extremely common given name from the Middle Ages onwards, derived via Old French <i>Marguerite</i> and Latin <i>Margarita</i> from Greek <i>Margarītēs</i>, from <i>margaron</i> ‘pearl’, a word ultimately of Hebrew origin. The name was always understood to mean ‘pearl’ throughout the Middle Ages. The first  St Margaret  was martyred at Antioch in Pisidia during the persecution instigated by the  Emperor Diocletian  in the early 4th century. However, there is some doubt about her name, as the same saint is venerated in the Orthodox Church as   Marina .  There were several other saintly bearers of the name, including St Margaret of Scotland (  d. 1093 ), wife of  King Malcolm Canmore  and daughter of Edmund Ironside of England. It was also the name of the wife of  Henry VI  of England,  Margaret of Anjou  (  1430–82 ), and of  Margaret Tudor  (  1489–1541 ), sister of  Henry VIII , who married James IV of Scotland and ruled as regent there after his death.  See also  Margery  ,   Marjorie ."]}]}],"lifeSummary":"When Margaret FitzWalchelin was born about 1218, in Derbyshire, England, United Kingdom, her father, Robert FitzRobert, was 20 and her mother, Margaret de Grendon, was 17. She had at least 1 son with Sir John de Chandos. She died after 1248, in Radbourne, Derbyshire, England, United Kingdom."},"et":{"Abt 1218–after 1248":"umbes 1218–pärast 1248","1218–1248":"1218–1248","1220–Male":"1220–Surnud","1227–1253":"1227–1253","1163–Male":"1163–Surnud","1248–1280":"1248–1280","1199–1238":"1199–1238","1203–Female":"1203–Surnud","1253":"1253","1220":"1220","Abt 1248":"umbes 1248","1163":"1163","Abt 1218":"umbes 1218","1280":"1280","1238":"1238","after 1248":"pärast 1248","1227":"1227","1248":"1248","1203":"1203","1199":"1199","about 1225":"about 1225","1218":"1218","Derbyshire, England":"Derbyshire, Inglismaa, United Kingdom","Yorkshire, England, United Kingdom":"Yorkshire, Inglismaa, United Kingdom","Radbourne, Derbyshire, England":"Radbourne, Derbyshire, Inglismaa, United Kingdom","Radbourne, Derbyshire, England, United Kingdom":"Radbourne, Derbyshire, Inglismaa, United Kingdom"},"fi":{"Abt 1218–after 1248":"noin 1218–1248 jälkeen","1218–1248":"1218–1248","1220–Male":"1220–Kuollut","1227–1253":"1227–1253","1163–Male":"1163–Kuollut","1248–1280":"1248–1280","1199–1238":"1199–1238","1203–Female":"1203–Kuollut","1253":"1253","1220":"1220","Abt 1248":"noin 1248","1163":"1163","Abt 1218":"noin 1218","1280":"1280","1238":"1238","after 1248":"1248 jälkeen","1227":"1227","1248":"1248","1203":"1203","1199":"1199","about 1225":"noin 1225","1218":"1218","Derbyshire, England":"Derbyshire, Englanti, Yhdistynyt kuningaskunta","Yorkshire, England, United Kingdom":"Yorkshire, Englanti, Yhdistynyt kuningaskunta","Radbourne, Derbyshire, England":"Radbourne, Derbyshire, Englanti, Yhdistynyt kuningaskunta","Radbourne, Derbyshire, Engl