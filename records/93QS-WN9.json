emale":"1286–Afdød","1325":"1325","1335":"1335","about 1325":"omkring 1325","1353":"1353","1331":"1331","ABT    1360":"omkring 1360","1286":"1286","1361":"1361","1360":"1360","about 1353":"omkring 1353","Wales":"Wales","Breconshire, Wales":"Breconshire, Wales","Llwyn-y-gwch, Buellt ctf, Breconshire, Wales":"Breconshire, Wales, United Kingdom","of Abercrai,Traean-glas,Breconshire,Wales":"Breconshire, Wales, United Kingdom"},"nl":{"about 1325–":"circa 1325–Overleden","1325–Male":"1325–Overleden","1335–1361":"1335–1361","1331–Female":"1331–Overleden","1353–Male":"1353–Overleden","1360–Male":"1360–Overleden","1286–Male":"1286–Overleden","1286–Female":"1286–Overleden","1325":"1325","1335":"1335","about 1325":"circa 1325","1353":"1353","1331":"1331","ABT    1360":"circa 1360","1286":"1286","1361":"1361","1360":"1360","about 1353":"circa 1353","Wales":"Wales","Breconshire, Wales":"Breconshire, Wales","Llwyn-y-gwch, Buellt ctf, Breconshire, Wales":"Breconshire, Wales, Verenigd Koninkrijk","of Abercrai,Traean-glas,Breconshire,Wales":"Breconshire, Wales, Verenigd Koninkrijk"},"en":{"about 1325–":"about 1325–Deceased","1325–Male":"1325–Deceased","1335–1361":"1335–1361","1331–Female":"1331–Deceased","1353–Male":"1353–Deceased","1360–Male":"1360–Deceased","1286–Male":"1286–Deceased","1286–Female":"1286–Deceased","1325":"1325","1335":"1335","about 1325":"about 1325","1353":"1353","1331":"1331","ABT    1360":"about 1360","1286":"1286","1361":"1361","1360":"1360","about 1353":"about 1353","Wales":"Wales","Breconshire, Wales":"Breconshire, Wales","Llwyn-y-gwch, Buellt ctf, Breconshire, Wales":"Breconshire, Wales, United Kingdom","of Abercrai,Traean-glas,Breconshire,Wales":"Breconshire, Wales, United Kingdom","nameMeanings":[{"name":"Hywel","type":"LAST","meanings":["A Welsh name. Some write the name Hoel, which they render 'lordly;' if so, it may come from huail, a vice-regent, regent. Arthur derives the surname Howell from Corn. -Brit, houl, the sun; and he adds, high, exalted.' But Hywel is rather from hywel, conspicuous."],"variants":[]},{"name":"Dafydd","type":"FIRST","attribution":"Dictionary of First Names © Patrick Hanks and Flavia Hodges 1990, 2003, 2006.","meanings":["equivalent of <b>David</b> . In widespread use during the Middle Ages, it was later largely replaced by the English form, but since the late 19th century it has come into its own again."],"variants":[]},{"name":"ap","type":"FIRST","attribution":"Dictionary of First Names © Patrick Hanks and Flavia Hodges 1990, 2003, 2006.","meanings":["Short form of any of the names beginning with this syllable."],"variants":[{"name":"Alexander","meanings":["From the Latin form of the Greek name <i>Alexandros</i>, from <i>alexein</i> ‘to defend’ + <i>anēr</i> ‘man, warrior’ (genitive <i>andros</i>). The name became extremely popular in the post-classical period, and was borne by several individuals in the New Testament and some early Christian saints. Its use as a common given name throughout Europe, however, derives largely from the fame of  Alexander the Great , King of Macedon (  356–323  bc  ), around whom a large body of popular legend grew up in late antiquity, much of which came to be embodied in the medieval ‘Alexander romances’."]},{"name":"Alan","meanings":["Of Celtic origin and uncertain derivation (possibly a diminutive of a word meaning ‘rock’). It was introduced into England by  Breton  followers of  William the Conqueror , most notably  Alan , Earl of Brittany, who was rewarded for his services with vast estates in the newly conquered kingdom. In Britain the variants  <b>Allan</b>  and  <b>Allen</b>  are considerably less frequent, and generally represent transferred uses of surname forms, whereas in America all three forms of the name are approximately equally common.  See also  Alun ."]},{"name":"Albert","meanings":["From an Old French name, <i>Albert</i>, of Germanic (Frankish) origin, derived from <i>adal</i> ‘noble’ + <i>berht</i> ‘bright, famous’. This was adopted by the Normans and introduced by them to England, displacing the Old English form <i>Æþelbeorht</i>. The name is popular in a variety of forms in Western Europe, and has been traditional in a number of European princely families. It was out of favour in England for centuries, however, and the revival of its popularity in the 19th century was largely in honour of  Queen Victoria's  consort,  Prince Albert of Saxe-Coburg-Gotha ."]}]}],"lifeSummary":"When Dafydd ap Hywel was born about 1325, in Breconshire, Wales, his father, Hywel Grach Llewelyn, was 40 and his mother, Hywel verch Gwilym, was 40. He had at least 2 sons with Mrs. Dafydd ap Owain."},"et":{"about 1325–":"umbes 1325–Surnud","1325–Male":"1325–Surnud","1335–1361":"1335–1361","1331–Female":"1331–Surnud","1353–Male":"1353–Surnud","1360–Male":"1360–Surnud","1286–Male":"1286–Surnud","1286–Female":"1286–Surnud","1325":"1325","1335":"1335","about 1325":"umbes 1325","1353":"1353","1331":"1331","ABT    1360":"umbes 1360","1286":"1286","1361":"1361","1360":"1360","about 1353":"umbes 1353","Wales":"Wales","Breconshire, Wales":"Breconshire, Wales","Llwyn-y-gwch, Buellt ctf, Breconshire, Wales":"Breconshire, Wales, United Kingdom","of Abercrai,Traean-glas,Breconshire,Wales":"Breconshire, Wales, United Kingdom"},"fi":{"about 1325–":"noin 1325–Kuollut","1325–Male":"1325–Kuollut","1335–1361":"1335–1361","1331–Female":"1331–Kuollut","1353–Male":"1353–Kuollut","1360–Male":"1360–Kuollut","1286–Male":"1286–Kuollut","1286–Female":"1286–Kuollut","1325":"1325","1335":"1335","about 1325":"noin 1325","1353":"1353","1331":"1331","ABT    1360":"noin 1360","1286":"1286","1361":"1361","1360":"1360","about 1353":"noin 1353","Wales":"Wales","Breconshire, Wales":"Breconshire, Wales","Llwyn-y-gwch, Buellt ctf, Breconshire, Wales":"Breconshire, Wales, Yhdistynyt kuningaskunta","of Abercrai,Traean-glas,Breconshire,Wales":"Breconshire, Wales, Yhdistynyt kuningaskunta"},"fr":{"about 1325–":"environ 1325–Décédé","1325–Male":"1325–Décédé","1335–1