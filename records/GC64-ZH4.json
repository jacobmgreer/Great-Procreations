efore 1365":"before 1365","1352":"1352","1374":"1374","1372":"1372","1382":"1382","1370":"1370","1402":"1402","1435":"1435","1478":"1478","1422":"1422","1345":"1345","1367":"1367","1410":"1410","1365":"1365","1507":"1507","1406":"1406","1417":"1417","1427":"1427","Delves, Staffordshire, England":"Delves, Staffordshire, England","Great Budworth, Cheshire, England":"Great Budworth, Cheshire, England","Nocton, Lincolnshire, England":"Nocton, Lincolnshire, England","Winnington, Cheshire, England":"Winnington, Cheshire, England","Winnington Hall, Northwich, Cheshire, England, United Kingdom":"Northwich, Cheshire, England, United Kingdom","nameMeanings":[{"name":"Winnington,","type":"LAST","attribution":"Dictionary of Family Names in Britain and Ireland © University of the West of England 2016","meanings":["English: (i) locative name from Winnington (Cheshire, Staffs). (ii)  see  Wennington  ."],"variants":[{"name":"Wennington","meanings":["English: (i) locative name from Wennington (Hunts, Essex). (ii)  see  Winnington  ."]}]},{"name":"Robert","type":"FIRST","attribution":"Dictionary of First Names © Patrick Hanks and Flavia Hodges 1990, 2003, 2006.","meanings":["One of the many French names of Germanic origin that were introduced into Britain by the Normans; it has since remained in continuous use. It is derived from the nearly synonymous elements <i>hrōd</i> ‘fame’ + <i>berht</i> ‘bright, famous’, and had a native Old English predecessor of similar form (<i>Hreodbeorht</i>), which was supplanted by the Norman name. Two dukes of Normandy in the 11th century bore the name: the father of  William the Conqueror  (sometimes identified with the legendary Robert the Devil), and his eldest son. It was borne also by three kings of Scotland, notably  Robert the Bruce  (  1274–1329 ), who freed Scotland from English domination. The altered short form <i>Bob</i> is very common, but <i>Hob</i> and <i>Dob</i>, which were common in the Middle Ages and gave rise to surnames, are extinct.  See also  Rupert ."],"variants":[]}],"historicEvents":[{"id":1705195,"age":12,"year":"1382","julianDay":2225826,"title":"Wycliffe's Bible","description":"John Wycliffe, English theologian and professor at the University of Oxford, completed a translation of the Bible from the Latin Vulgate into Middle English. This translation is known as Wycliffe's Bible and was completed around 1382.","url":"https://en.wikipedia.org/wiki/Wycliffe%27s_Bible","urlTitle":"Wikipedia - Wycliffe's Bible","jurisdictionLevel":2}],"lifeSummary":"When Sir Robert Winnington, Lord was born in 1370, in Delves, Staffordshire, England, his father, Richard De Wynnington, was 25 and his mother, Emma de Mainwaring, was 19. He married Katherine de Venables in 1427, in Great Budworth, Cheshire, England. They were the parents of at least 1 daughter. He died in 1427, in Winnington, Cheshire, England, at the age of 57."},"et":{"1370–1427":"1370–1427","1365–1435":"1365–1435","1367–1417":"1367–1417","1372–Female":"1372–Surnud","1374–Female":"1374–Surnud","1410–1507":"1410–1507","1406–1507":"1406–1507","1427–1478":"1427–1478","1345–1422":"1345–1422","1352–1402":"1352–1402","before 1365":"enne 1365","1352":"1352","1374":"1374","1372":"1372","1382":"1382","1370":"1370","1402":"1402","1435":"1435","1478":"1478","1422":"1422","1345":"1345","1367":"1367","1410":"1410","1365":"1365","1507":"1507","1406":"1406","1417":"1417","1427":"1427","Delves, Staffordshire, England":"Delves, Staffordshire, England","Great Budworth, Cheshire, England":"Great Budworth, Cheshire, England","Nocton, Lincolnshire, England":"Nocton, Lincolnshire, England","Winnington, Cheshire, England":"Winnington, Cheshire, England","Winnington Hall, Northwich, Cheshire, England, United Kingdom":"Northwich, Cheshire, Inglismaa, United Kingdom"},"fi":{"1370–1427":"1370–1427","1365–1435":"1365–1435","1367–1417":"1367–1417","1372–Female":"1372–Kuollut","1374–Female":"1374–Kuollut","1410–1507":"1410–1507","1406–1507":"1406–1507","1427–1478":"142