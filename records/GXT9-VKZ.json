04","1129–1199":"1129–1199","1145–Female":"1145–Deceased","1190":"1190","1186":"1186","1164":"1164","1162":"1162","1160":"1160","1129":"1129","1204":"1204","1159":"1159","ABT 1188":"about 1188","1145":"1145","1199":"1199","1188":"1188","1254":"1254","ABT 1190":"about 1190","about 1199":"about 1199","about 1186":"about 1186","1207":"1207","Saint Lawrence Churchyard, Gnosall, Staffordshire, England":"Gnosall, Staffordshire, England, United Kingdom","Knightley, Staffordshire, England":"Knightley, Staffordshire, England","Knightley, Stafford, England, Great Britain":"Knightley, Staffordshire, England, United Kingdom","Knightley, Stafford, England":"Knightley, Staffordshire, England, United Kingdom","nameMeanings":[{"name":"Jorden","type":"FIRST","attribution":"Dictionary of First Names © Patrick Hanks and Flavia Hodges 1990, 2003, 2006.","meanings":["Originally a name given to a child of either sex baptized in holy water that was, purportedly at least, brought from the River Jordan, whose Hebrew name, <i>ha-yarden</i>, means ‘flowing down’. It was in this river that Christ was baptized by John the Baptist, and medieval pilgrims to the Holy Land usually tried to bring back a flask of its water with them. The modern given name is either a revival of this, or else a transferred use of the surname that was derived from the medieval given name. It is more popular as a boy's name in Britain and as a girl's name in the United States."],"variants":[{"name":"Jordin","meanings":["Originally a name given to a child of either sex baptized in holy water that was, purportedly at least, brought from the River Jordan, whose Hebrew name, <i>ha-yarden</i>, means ‘flowing down’. It was in this river that Christ was baptized by John the Baptist, and medieval pilgrims to the Holy Land usually tried to bring back a flask of its water with them. The modern given name is either a revival of this, or else a transferred use of the surname that was derived from the medieval given name. It is more popular as a boy's name in Britain and as a girl's name in the United States."]},{"name":"Jordyn","meanings":["Originally a name given to a child of either sex baptized in holy water that was, purportedly at least, brought from the River Jordan, whose Hebrew name, <i>ha-yarden</i>, means ‘flowing down’. It was in this river that Christ was baptized by John the Baptist, and medieval pilgrims to the Holy Land usually tried to bring back a flask of its water with them. The modern given name is either a revival of this, or else a transferred use of the surname that was derived from the medieval given name. It is more popular as a boy's name in Britain and as a girl's name in the United States."]},{"name":"Jordon","meanings":["Originally a name given to a child of either sex baptized in holy water that was, purportedly at least, brought from the River Jordan, whose Hebrew name, <i>ha-yarden</i>, means ‘flowing down’. It was in this river that Christ was baptized by John the Baptist, and medieval pilgrims to the Holy Land usually tried to bring back a flask of its water with them. The modern given name is either a revival of this, or else a transferred use of the surname that was derived from the medieval given name. It is more popular as a boy's name in Britain and as a girl's name in the United States."]}]},{"name":"De","type":"FIRST","attribution":"Dictionary of First Names © Patrick Hanks and Flavia Hodges 1990, 2003, 2006.","meanings":["Variant of   Dev ."],"variants":[{"name":"Deborah","meanings":["Biblical name (meaning ‘bee’ in Hebrew), borne by the nurse of Rebecca (Genesis 35:8) and by a woman judge and prophet (Judges 4–5) who led the Israelites to victory over the Canaanites. It has always been popular as a Jewish name. It was in use among Christians by the mid 16th century and was taken up by the Puritans in the 17th century, in part because the bee was a symbol of industriousness. Since then it has enjoyed enormous popularity, peaking in the 1960s. Among other famous bearers is the actress  Deborah Kerr  (  1921–2007 )."]}]}],"lifeSummary":"When Jorden De Chitteleia DeKnightley was born in 1160, in Knightley, Staffordshire, England, his father, Sir Robert I de Knightley Kt, was 31 and his mother, Saira de Chitteleia, was 15. He had at least 3 sons with Beatrice De Knightley. He died in 1207, in his hometown, at the age of 47, and was buried in Gnosall, Staffordshire, England, United Kingdom."},"et":{"1160–1207":"1160–1207","1159–Male":"1159–Surnud","1162–Male":"1162–Surnud","1164–Female":"1164–Surnud","1160–Female":"1160–Surnud","1186–1254":"1186–1254","1188–Male":"1188–Surnud","1190–1204":"1190–1204","1129–1199":"1129–1199","1145–Female":"1145–Surnud","1190":"1190","1186":"1186","1164":"1164","1162":"1162","1160":"1160","1129":"1129","1204":"1204","1159":"1159","ABT 1188":"umbes 1188","1145":"1145","1199":"1199","1188":"1188","1254":"1254","ABT 1190":"umbes 1190","about 1199":"umbes 1199","about 1186":"umbes 1186","1207":"1207","Saint Lawrence Churchyard, Gnosall, Staffordshire, England":"Gnosall, Staffordshire, Inglismaa, United Kingdom","Knightley, Staffordshire, England":"Knightley, Staffordshire, England","Knightley, Stafford, England, Great Britain":"Knightley, Staffordshire, Inglismaa, United Kingdom","Knightley, Stafford, England":"Knightley, Staffordshire, Inglismaa, United Kingdom"},"fi":{"1160–1207":"1160–1207","1159–Male":"1159–Kuollut","1162–Male":"1162–Kuollut","1164–Female":"1164–Kuollut","1160–Female":"1160–Kuollut","1186–1254":"1186–1254","1188–Male":"1188–Kuollut","1190–1204":"1190–1204","1129–1199":"1129–1199","1145–Female":"1145–Kuollut","1190":"1190","1186":"1186","1164":"1164","1162":"1162","1160":"1160","1129":"1129","1204":"1204","1159":"1159","ABT 1188":"noin 1188","1145":"1145","1199":"1199","1188":"1188","1254":"1254","ABT 1190":"noin 1190","about 1199":"noin 1199","about 1186":"noin 1186","1207":"1207","Saint Lawrence Churchyard, Gnosall, Staffordshire, England":"Gnosall, Staffordshire, Eng