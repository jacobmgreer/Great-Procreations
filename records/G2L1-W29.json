202","1138–1190":"1138–1190","1190":"1190","1185":"1185","1140":"1140","1206":"1206","1215":"1215","1138":"1138","1202":"1202","about 1206":"okolo 1206","1224":"1224","1189":"1189","1244":"1244","1254":"1254","1155":"1155","about 1155":"okolo 1155","Abt. 1185":"okolo 1185","Thornton le Moors, Cheshire, England":"Thornton le Moors, Cheshire, Anglie, United Kingdom","Malpas, Cheshire, England":"Malpas, Cheshire, Anglie","England":"Anglie","Thornton Mayow, Cheshire, England":"Thornton Mayow, Cheshire, Anglie"},"da":{"about 1155–1254":"omkring 1155–1254","1155–1254":"1155–1254","1155–Female":"1155–Afdød","1185–Female":"1185–Afdød","1189–1244":"1189–1244","1206–1244":"1206–1244","1140–1202":"1140–1202","1138–1190":"1138–1190","1190":"1190","1185":"1185","1140":"1140","1206":"1206","1215":"1215","1138":"1138","1202":"1202","about 1206":"omkring 1206","1224":"1224","1189":"1189","1244":"1244","1254":"1254","1155":"1155","about 1155":"omkring 1155","Abt. 1185":"omkring 1185","Thornton le Moors, Cheshire, England":"Thornton le Moors, Cheshire, England, United Kingdom","Malpas, Cheshire, England":"Malpas, Cheshire, England","England":"England","Thornton Mayow, Cheshire, England":"Thornton Mayow, Cheshire, England"},"nl":{"about 1155–1254":"circa 1155–1254","1155–1254":"1155–1254","1155–Female":"1155–Overleden","1185–Female":"1185–Overleden","1189–1244":"1189–1244","1206–1244":"1206–1244","1140–1202":"1140–1202","1138–1190":"1138–1190","1190":"1190","1185":"1185","1140":"1140","1206":"1206","1215":"1215","1138":"1138","1202":"1202","about 1206":"circa 1206","1224":"1224","1189":"1189","1244":"1244","1254":"1254","1155":"1155","about 1155":"circa 1155","Abt. 1185":"circa 1185","Thornton le Moors, Cheshire, England":"Thornton le Moors, Cheshire, Engeland, Verenigd Koninkrijk","Malpas, Cheshire, England":"Malpas, Cheshire, England","England":"England","Thornton Mayow, Cheshire, England":"Thornton Mayow, Cheshire, England"},"en":{"about 1155–1254":"about 1155–1254","1155–1254":"1155–1254","1155–Female":"1155–Deceased","1185–Female":"1185–Deceased","1189–1244":"1189–1244","1206–1244":"1206–1244","1140–1202":"1140–1202","1138–1190":"1138–1190","1190":"1190","1185":"1185","1140":"1140","1206":"1206","1215":"1215","1138":"1138","1202":"1202","about 1206":"about 1206","1224":"1224","1189":"1189","1244":"1244","1254":"1254","1155":"1155","about 1155":"about 1155","Abt. 1185":"about 1185","Thornton le Moors, Cheshire, England":"Thornton le Moors, Cheshire, England, United Kingdom","Malpas, Cheshire, England":"Malpas, Cheshire, England","England":"England","Thornton Mayow, Cheshire, England":"Thornton Mayow, Cheshire, England","nameMeanings":[{"name":"Thornton","type":"LAST","attribution":"Dictionary of American Family Names © Patrick Hanks 2003, 2006.","meanings":["English and Scottish: habitational name from any of numerous places throughout England and Scotland so called, from Old English <i>thorn</i> ‘thorn tree’ + <i>tūn</i> ‘farmstead, estate’. The placename is most frequent in northern England, especially Yorkshire, where there are at least 16 possible sources for the surname.","Irish: Anglicized (translated) form of Gaelic <b>Mac Sceacháin</b> ‘son of <i>Sceachán</i>’ (see   Skehan  ).","Irish: shortened Anglicized form of Gaelic <b>Ó Draighneáin</b> ‘descendant of <i>Draighneán</i>’ (see   Drennan  )."],"variants":[{"name":"Thornber","meanings":["English: habitational name from any of the five minor places in Yorkshire called Thornber, particularly Thornber in Halton West. The placenames derive from Old English <i>thorn</i> ‘thorn’ + <i>beorg</i> ‘hill, mound’.","Irish: adopted for various Irish names containing an element meaning ‘thorn’; compare   Thornton  ."]},{"name":"Thorton","meanings":["(1997: 465;2007: 2025; 2010: NA)","English: probably a shortened form of   Thornton  , or a habitational name from Thorton in Marnhull, Dorset, which has the same origin."]},{"name":"Skehan","meanings":["Irish: shortened Anglicized form of Gaelic <b>Mac Sceacháin</b> or <b>Ó Sceacháin</b> ‘son (or descendant) of <i>Sceachán</i>’, a personal name probably based on a diminutive of <i>sceach</i> ‘briar, thorn bush’. The Gaelic name has sometimes been ‘translated’ as   Thornton  ."]}]},{"name":"Peter","type":"FIRST","attribution":"Dictionary of First Names © Patrick Hanks and Flavia Hodges 1990, 2003, 2006.","meanings":["form of the name of the best-known of all Christ's apostles, traditionally regarded as the founder of the Christian Church. The name derives, via Latin, from Greek <i>petros</i> ‘stone, rock’. This is used as a translation of the Aramaic byname <i>Cephas</i>, given to the apostle  Simon  son of Jona, to distinguish him from another of the same name (  Simon Zelotes ). ‘When Jesus beheld him, he said, Thou art Simon the son of Jona: thou shalt be called Cephas, which is by interpretation, A stone’ (John 1:42). According to Matthew 16:17–18, Christ says more explicitly, ‘Blessed art thou, Simon Bar-jona … thou art Peter, and upon this rock I will build my church’. The name has been in continuous use since the Middle Ages."],"variants":[]}],"historicEvents":[{"id":1705187,"age":60,"year":"1215","julianDay":2164830,"title":"Magna Carta","description":"King John of England agreed to a charter of rights called the Magna Carta. The document was originally drafted by the Archbishop of Canterbury to establish peace between King John and a group of rebel barons. The Magna Carta was completed in 1215 and is now considered to be one of the greatest constitutional documents of all time.","url":"https://www.nationalarchives.gov.uk/education/medieval/magna-carta/","urlTitle":"National Archives - Magna Carta","jurisdictionLevel":2},{"id":1705188,"age":69,"year":"1224","julianDay":2168117,"title":"France Declares War on England","description":"France declared war on England as Louis VIII of France attacked Poitou and northern Gascony.","jurisdictionLevel":2}],"lifeSummary":"When Peter Thornton was born about 1155, 