d Kingdom"},"da":{"1382–8 March 1482":"1382–8. marts 1482","1385–1443":"1385–1443","1407–1486":"1407–1486","1408–1473":"1408–1473","1382–1482":"1382–1482","c.1443":"omkring 1443","1473":"1473","1385":"1385","1482":"1482","1382":"1382","1455":"1455","1443":"1443","21 November 1473":"21. november 1473","1486":"1486","8 March 1482":"8. marts 1482","1408":"1408","1407":"1407","1405":"1405","Landwade, Cambridgeshire, England":"Landwade, Cambridgeshire, England, United Kingdom","London, Middlesex, England":"London, Middlesex, England","Northamptonshire, England":"Northamptonshire, England","Rothwell, Yorkshire, England":"Rothwell, Jórvík, England, United Kingdom","London, England, United Kingdom":"London, England, United Kingdom"},"nl":{"1382–8 March 1482":"1382–8 maart 1482","1385–1443":"1385–1443","1407–1486":"1407–1486","1408–1473":"1408–1473","1382–1482":"1382–1482","c.1443":"circa 1443","1473":"1473","1385":"1385","1482":"1482","1382":"1382","1455":"1455","1443":"1443","21 November 1473":"21 november 1473","1486":"1486","8 March 1482":"8 maart 1482","1408":"1408","1407":"1407","1405":"1405","Landwade, Cambridgeshire, England":"Landwade, Cambridgeshire, Engeland, Verenigd Koninkrijk","London, Middlesex, England":"London, Middlesex, England","Northamptonshire, England":"Northamptonshire, England","Rothwell, Yorkshire, England":"Rothwell, Yorkshire, Engeland, Verenigd Koninkrijk","London, England, United Kingdom":"London, Engeland, Verenigd Koninkrijk"},"en":{"1382–8 March 1482":"1382–8 March 1482","1385–1443":"1385–1443","1407–1486":"1407–1486","1408–1473":"1408–1473","1382–1482":"1382–1482","c.1443":"about 1443","1473":"1473","1385":"1385","1482":"1482","1382":"1382","1455":"1455","1443":"1443","21 November 1473":"21 November 1473","1486":"1486","8 March 1482":"8 March 1482","1408":"1408","1407":"1407","1405":"1405","Landwade, Cambridgeshire, England":"Landwade, Cambridgeshire, England, United Kingdom","London, Middlesex, England":"London, Middlesex, England","Northamptonshire, England":"Northamptonshire, England","Rothwell, Yorkshire, England":"Rothwell, Yorkshire, England, United Kingdom","London, England, United Kingdom":"London, England, United Kingdom","nameMeanings":[{"name":"Abbott","type":"LAST","attribution":"Dictionary of American Family Names © Patrick Hanks 2003, 2006.","meanings":["English: nickname from Middle English <i>abbod</i>, <i>abbot(t)</i>, <i>abbat</i> ‘abbot’ (Old English <i>abbod</i>) or Old French <i>abet</i> ‘priest’. Both the Old English and the Old French term are derived from Late Latin <i>abbas</i> (genitive <i>abbatis</i>) ‘priest’, from Greek <i>abbas</i>, from Aramaic <i>aba</i> ‘father’. The nickname was presumably a joking reference to a person's behaviour. In the US, the English name is also sometimes a translation of a cognate or equivalent European name, e.g. Italian   Abate  , Spanish   Abad  , or German   Abt  .","History: George Abbot from Yorkshire, England, settled in Andover, MA, in 1640; he had numerous prominent descendants. George Abbott (probably not the same man) died in Rowley, MA, in 1647. Another early migrant was James Abbott, who came from Somerset, England, to Long Island, NY, in the 17th century."],"variants":[{"name":"Abate","meanings":["Some characteristic forenames:  Italian Salvatore, Antonio, Carmelo, Carmine, Gaetano, Vito, Angelo, Canio, Rocco, Sal, Aldo, Carlo.","Italian: from <i>abate</i> ‘priest’ (from Late Latin <i>abbas</i> ‘priest’, genitive <i>abbatis</i>). It could be a nickname, perhaps given to someone who behaved in a priest-like manner, an occupational name for the servant of a priest, or it may denote an (illegitimate) son of a priest. Compare   Labate  ."]},{"name":"Abbot","meanings":["English and Scottish: variant of   Abbott  . The spelling with one <i>-t</i> is more typically Scottish than English, and in Gaelic-speaking areas of Scotland, this is sometimes an Anglicized form of   McNabb  ."]},{"name":"Abbitt","meanings":["English: variant of   Abbott  ."]},{"name":"Abbett","meanings":["English: variant of   Abbott  ."]},{"name":"Abbotts","meanings":["English:","topographic or occupational name from Middle English <i>(atte) abbotes</i> ‘(at the, of the) abbot's (house or quarters)’, a name for someone who lived or worked at such a place, presumably a servant.","variant of   Abbott  , with post-medieval excrescent <i>-s</i>."]}]},{"name":"John","type":"FIRST","attribution":"Dictionary of First Names © Patrick Hanks and Flavia Hodges 1990, 2003, 2006.","meanings":["As a boy's name this represents a revival of Middle English <i>Jan</i>, a by‐form of   John  , or an adoption of the common European form with this spelling. As a girl's name it is a short form of names such as   Janet   and   Janice ."],"variants":[]},{"name":"Symond","type":"LAST","attribution":"Dictionary of Family Names in Britain and Ireland © University of the West of England 2016","meanings":["English:  see  Simon  ."],"variants":[{"name":"Simon","meanings":["Usual English form of   Simeon  , borne in the New Testament by various characters: two apostles, a brother of Jesus, a Pharisee, a leper, a tanner, a sorcerer (who offered money for the gifts of the Holy Ghost, giving rise to the term <i>simony</i>), and the man who carried Jesus's cross to the Crucifixion."]}]}],"historicEvents":[{"id":1705195,"age":0,"year":"1382","julianDay":2225826,"title":"Wycliffe's Bible","description":"John Wycliffe, English theologian and professor at the University of Oxford, completed a translation of the Bible from the Latin Vulgate into Middle English. This translation is known as Wycliffe's Bible and was completed around 1382.","url":"https://en.wikipedia.org/wiki/Wycliffe%27s_Bible","urlTitle":"Wikipedia - Wycliffe's Bible","jurisdictionLevel":1},{"id":1705197,"age":73,"year":"1455","julianDay":2252488,"title":"Wars of the Roses","description":"Wars of the Roses was a series of English civil wars for control of the throne of England between the royal families House of Lancaster and the House of York. The name of the war was derived as the red rose was the symbol of the Lancastrians and the white rose was the symbol of the Yorks.","url":"https://www.history.com/topics/british-history/wars-of-the-roses","urlTitle":"History - Wars of the Roses","jurisdictionLevel":1}],"lifeSummary":"Sir John Symond Abbott III was born in 1382, in Northamptonshire, England. He married Mrs Agnes Abbott in 1405. They were the parents of at least 2 daughters. He died in London, Middlesex, England, and was buried in London, Middlesex, England."},"et":{"1382–8 March 1482":"1382–8. märts 1482","1385–1443":"1385–1443","1407–1486":"1407–1486","1408–1473":"1408–1473","1382–1482":"1382–1482","c.1443":"umbes 1443","1473":"1473","1385":"1385","1482":"1482","1382":"1382","1455":"1455","1443":"1443","21 November 1473":"21. november 1473","1486":"1486","8 March 1482":"8. märts 1482","1408":"1408","1407":"1407","1405":"1405","Landwade, Cambridgeshire, England":"Landwade, Cambridgeshire, Inglismaa, United Kingdom","London, Middlesex, England":"London, Middlesex, England","Northamptonshire, England":"Northamptonshire, England","Rothwell, Yorkshire, England":"Rothwell, Yorkshire, Inglismaa, United Kingdom","London, England, United Kingdom":"London, Inglismaa, United Kingdom"},"fi":{"1382–8 March 1482":"1382–8. maaliskuuta 1482","1385–1443":"1385–1443","1407–1486":"1407–1486","1408–1473":"1408–1473","1382–1482":"1382–1482","c.1443":"noin 1443","1473":"1473","1385":"1385","1482":"1482","1382":"1382","1455":"1455","1443":"1443","21 November 1473":"21. marraskuuta 1473","1486":"1486","8 March 1482":"8. maaliskuuta 1482","1408":"1408","1407":"1407","1405":"1405","Landwade, Cambridgeshire, England":"Landwade, Cambridgeshire, Englanti, Yhdistynyt kuningaskunta","London, Middlesex, England":"London, Middlesex, England","Northamptonshire, England":"Northamptonshire, England","Rothwell, Yorkshire, England":"Rothwell, Yorkshire, Englanti, Yhdistynyt kuningaskunta","Lo