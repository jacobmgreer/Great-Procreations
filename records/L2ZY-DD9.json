nce the Middle Ages."],"variants":[]}],"historicEvents":[{"id":1353273,"age":109,"year":"1350","julianDay":2214138,"description":"Plague ravishes Denmark and Sweden.","jurisdictionLevel":0}],"lifeSummary":"Peder Skram was born about 1241. He had at least 1 son with Ukendt. He died in Denmark."},"et":{"about 1241–":"umbes 1241–Surnud","1205–Female":"1205–Surnud","1255–1303":"1255–1303","1241–Male":"1241–Surnud","1205":"1205","1303":"1303","1255":"1255","1241":"1241","about 1255":"umbes 1255","1350":"1350","about 1241":"umbes 1241","Denmark":"Taani"},"fi":{"about 1241–":"noin 1241–Kuollut","1205–Female":"1205–Kuollut","1255–1303":"1255–1303","1241–Male":"1241–Kuollut","1205":"1205","1303":"1303","1255":"1255","1241":"1241","about 1255":"noin 1255","1350":"1350","about 1241":"noin 1241","Denmark":"Tanska"},"fr":{"about 1241–":"environ 1241–Décédé","1205–Female":"1205–Décédée","1255–1303":"1255–1303","1241–Male":"1241–Décédé","1205":"1205","1303":"1303","1255":"1255","1241":"1241","about 1255":"environ 1255","1350":"1350","about 1241":"environ 1241","Denmark":"Danemark","lifeSummary":"Peder Skram est né environ 1241. Il a eu au moins 1 fils avec Ukendt. Il est décédé à Danemark."},"de":{"about 1241–":"um 1241–Verstorben","1205–Female":"1205–Verstorben","1255–1303":"1255–1303","1241–Male":"1241–Verstorben","1205":"1205","1303":"1303","1255":"1255","1241":"1241","about 1255":"um 1255","1350":"1350","about 1241":"um 1241","Denmark":"Dänemark","lifeSummary":"Peder Skram wurde um 1241 geboren. Er hatte mit Ukendt mindestens 1 Sohn. Er starb in Dänemark."},"ht":{"about 1241–":"about 1241–Desede","1205–Female":"1205–Desede","1255–1303":"1255–1303","1241–Male":"1241–Desede","1205":"1205","1303":"1303","1255":"1255","1241":"1241","about 1255":"about 1255","1350":"1350","about 1241":"about 1241","Denmark":"Danemark"},"hu":{"about 1241–":"1241 körül–elhunyt","1205–Female":"1205–elhunyt","1255–1303":"1255–1303","1241–Male":"1241–elhunyt","1205":"1205","1303":"1303","1255":"1255","1