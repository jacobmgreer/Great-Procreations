,"1241–1299":"1241–1299","–1280":"–1280","1180–1224":"1180–1224","1182–1218":"1182–1218","Abt 1238":"circa 1238","1241":"1241","1240":"1240","1250":"1250","1272":"1272","1182":"1182","1280":"1280","1180":"1180","1215":"1215","after 1218":"na 1218","1224":"1224","1212":"1212","1299":"1299","1199":"1199","1221":"1221","1240  eldest son":"1240","1218":"1218","Gonalston, Nottinghamshire, England":"Gonalston, Nottinghamshire, Engeland, Verenigd Koninkrijk","Gunnolston, Nottinghamshire,England":"Nottinghamshire, Engeland, Verenigd Koninkrijk","Wingfield, Derbyshire, England":"South Wingfield, Derbyshire, Engeland, Verenigd Koninkrijk","South Wingfield, Derbyshire, England":"South Wingfield, Derbyshire, England"},"en":{"1199–1241":"1199–1241","1212–1272":"1212–1272","–Female":"Deceased","1221–1250":"1221–1250","1240–1272":"1240–1272","1241–1299":"1241–1299","–1280":"–1280","1180–1224":"1180–1224","1182–1218":"1182–1218","Abt 1238":"about 1238","1241":"1241","1240":"1240","1250":"1250","1272":"1272","1182":"1182","1280":"1280","1180":"1180","1215":"1215","after 1218":"after 1218","1224":"1224","1212":"1212","1299":"1299","1199":"1199","1221":"1221","1240  eldest son":"1240","1218":"1218","Gonalston, Nottinghamshire, England":"Gonalston, Nottinghamshire, England, United Kingdom","Gunnolston, Nottinghamshire,England":"Nottinghamshire, England, United Kingdom","Wingfield, Derbyshire, England":"South Wingfield, Derbyshire, England, United Kingdom","South Wingfield, Derbyshire, England":"South Wingfield, Derbyshire, England","nameMeanings":[{"name":"Heriz,","type":"LAST","attribution":"Dictionary of American Family Names © Patrick Hanks 2003, 2006.","meanings":["French and Walloon: from a pet form of an ancient Germanic personal name with the element <i>heri</i> ‘army’."],"variants":[]},{"name":"John","type":"FIRST","attribution":"Dictionary of First Names © Patrick Hanks and Flavia Hodges 1990, 2003, 2006.","meanings":["Contracted form of Old French <i>Jo(h)anne</i>, from Latin <i>Io(h)anna</i> (  see  Joanna  ). In England this was the usual feminine form of   John   from the Middle English period onwards and was extremely popular, but in the 16th and 17th centuries it steadily lost ground to   Jane .  It was strongly revived in the first part of the 20th century, partly under the influence of  George Bernard Shaw's  play St Joan (  1923 ), based on the life of  Joan of Arc  (  1412–31 ). Claiming to be guided by the voices of the saints, she persuaded the French dauphin to defy the occupying English forces and have himself crowned, and she led the French army that raised the siege of Orleans in  1429 . The following year she was captured by the Burgundians and sold to the English, and a year later she was burned at the stake for witchcraft at the age of 18 or 19. Her story has captured the imagination of many writers, and she is variously portrayed as a national and political hero, a model of apolitical straightforwardness and honesty, and a religious heroine. She was canonized in  1920 . More recent influences have included the American film actress  Joan Crawford  (  1908–77 , born  Lucille le Sueur ), the British actress  Joan Collins  (  b. 1933 ), the American comedienne  Joan Rivers  (  b. 1933 ), and the West Indian pop singer  Joan Armatrading  (  b. 1950 )."],"variants":[]}],"historicEvents":[{"id":1705187,"age":16,"year":"1215","julianDay":2164830,"title":"Magna Carta","description":"King John of England agreed to a charter of rights called the Magna Carta. The document was originally drafted by the Archbishop of Canterbury to establish peace between King John and a group of rebel barons. The Magna Carta was completed in 1215 and is now considered to be one of the greatest constitutional documents of all time.","url":"https://www.nationalarchives.gov.uk/education/medieval/magna-carta/","urlTitle":"National Archives - Magna Carta","jurisdictionLevel":2},{"id":1705188,"age":25,"year":"1224","julianDay":2168117,"title":"France Declares War on England","description":"France declared war on England as Louis VIII of France attacked Poitou and northern Gascony.","jurisdictionLevel":2}],"lifeSummary":"When Sir John I Heriz, Knight was born in 1199, in Gonalston, Nottinghamshire, England, his father, Ivo de Heriz II, was 19 and his mother, Hawise de Briwere, was 17. He married Sarah de Wingfield about 1238, in Gonalston, Nottinghamshire, England, United Kingdom. They were the parents of at least 3 sons. He died in 1241, in South Wingfield, Derbyshire, England, at the age of 42."},"et":{"1199–1241":"1199–1241","1212–1272":"1212–1272","–Female":"Surnud","1221–1250":"1221–1250","1240–1272":"1240–1272","1241–1299":"1241–1299","–1280":"–1280","1180–1224":"1180–1224","1182–1218":"1182–1218","Abt 1238":"umbes 1238","1241":"1241","1240":"1240","1250":"1250","1272":"1272","1182":"1182","1280":"1280","1180":"1180","1215":"1215","after 1218":"pärast 1218","1224":"1224","1212":"1212","1299":"1299","1199":"1199","1221":"1221","1240  eldest son":"1240","1218":"1218","Gonalston, Nottinghamshire, England":"Gonalston, Nottinghamshire, Inglismaa, United Kingdom","Gunnolston, Nottinghamshire,England":"Nottinghamshire, Inglismaa, United Kingdom","Wingfield, Derbyshire, England":"South Wingfield, Derbyshire, Inglismaa, United Kingdom","South Wingfield, Derbyshire, England":"South Wingfield, Derbyshire, England"},"fi":{"1199–1241":"1199–1241","1212–1272":"1212–1272","–Female":"Kuollut","1221–1250":"1221–1250","1240–1272":"1240–1272","1241–1299":"1241–1299","–1280":"–1280","1180–1224":"1180–1224","1182–1218":"1182–1218","Abt 1238":"noin 1238","1241":"1241","1240":"1240","1250":"1250","1272":"1272","1182":"1182","1280":"1280","1180":"1180","1215":"1215","after 1218":"1218 jälkeen","1224":"1224","1212":"1212","1299":"1299","1199":"1199","1221":"1221","1240  eldest son":"1240","1218":"1218","Gonalston, Nottinghamshire, England":"Gonalston, Nottinghamshire, Englanti, Yhdistynyt kuningaskunta","Gunnolston, Nottinghamshire,E