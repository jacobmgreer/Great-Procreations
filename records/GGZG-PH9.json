nially popular boys' names."],"variants":[]}],"lifeSummary":"James Tattenhall was born in 1275. He had at least 1 daughter with Joan De Mortimer."},"et":{"1275–":"1275–Surnud","1282–1327":"1282–1327","1302–1327":"1302–1327","1275–Male":"1275–Surnud","1327":"1327","1302":"1302","1275":"1275","1282":"1282","Derby, Derbyshire, England":"Derby, Derbyshire, England"},"fi":{"1275–":"1275–Kuollut","1282–1327":"1282–1327","1302–1327":"1302–1327","1275–Male":"1275–Kuollut","1327":"1327","1302":"1302","1275":"1275","1282":"1282","Derby, Derbyshire, England":"Derby, Derbyshire, England"},"fr":{"1275–":"1275–Décédé","1282–1327":"1282–1327","1302–1327":"1302–1327","1275–Male":"1275–Décédé","1327":"1327","1302":"1302","1275":"1275","1282":"1282","Derby, Derbyshire, England":"Derby, Derbyshire, Angleterre","lifeSummary":"James Tattenhall est né en 1275. Il a eu au moins 1 fille avec Joan De Mortimer."},"de":{"1275–":"1275–Verstorben","1282–1327":"1282–1327","1302–1327":"1302–1327","1275–Male":"1275–Verstorben","1327":"1327","1302":"1302","1275":"1275","1282":"1282","Derby, Derbyshire, England":"Derby, Derbyshire, England","lifeSummary":"James Tattenhall wurde 1275 geboren. Er hatte mit Joan De Mortimer mindestens 1 Tochter."},"ht":{"1275–":"1275–Desede","1282–1327":"1282–1327","1302–1327":"1302–1327","1275–Male":"1275–Desede","1327":"1327","1302":"1302","1275":"1275","1282":"1282","Derby, Derbyshire, England":"Derby, Derbyshire, England"},"hu":{"1275–":"1275–elhunyt","1282–1327":"1282–1327","1302–1327":"1302–1327","1275–Male":"1275–elhunyt","1327":"1327","1302":"1302","1275":"1275","1282":"1282","Derby, Derbyshire, England":"Derby, Derbyshire, England"},"id":{"1275–":"1275–Telah Meninggal","1282–1327":"1282–1327","1302–1327":"1302–1327","1275–Male":"1275–Telah Meninggal","1327":"1327","1302":"1302","1275":"1275","1282":"1282","Derby, Derbyshire, England":"Derby, Derbyshire, England"},"it":{"1275–":"1275–Deceduto","1282–1327":"1282–1327","1302–1327":"1302–1327","1275–Male":"1275–De