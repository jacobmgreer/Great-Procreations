lk, England","England":"England","Essex, England":"Essex, England","Wymondley, Hertsfordshire, England":"Little Wymondley, Hertfordshire, Engeland, Verenigd Koninkrijk"},"en":{"1350–22 January 1419":"1350–22 January 1419","1332–1375":"1332–1375","1343–Female":"1343–Deceased","1350–1414":"1350–1414","1350–1419":"1350–1419","1350–1383":"1350–1383","1363–1410":"1363–1410","1370–1419":"1370–1419","1318–1382":"1318–1382","1313–1383":"1313–1383","21 Mar 1410":"21 March 1410","1 September 1383":"1 September 1383","1363":"1363","1350":"1350","1383":"1383","1382":"1382","1370":"1370","26 November 1382":"26 November 1382","after 8 July 1325":"after 8 July 1325","22 January 1419":"22 January 1419","1414":"1414","1313":"1313","1410":"1410","1343":"1343","1332":"1332","1375":"1375","1419":"1419","1318":"1318","Halesworth, Suffolk, England":"Halesworth, Suffolk, England","England":"England","Essex, England":"Essex, England","Wymondley, Hertsfordshire, England":"Little Wymondley, Hertfordshire, England, United Kingdom","nameMeanings":[{"name":"William","type":"FIRST","attribution":"Dictionary of First Names © Patrick Hanks and Flavia Hodges 1990, 2003, 2006.","meanings":["Probably the most successful of all the Old French names of Germanic origin that were introduced to England by the Normans. It is derived from Germanic <i>wil</i> ‘will, desire’ + <i>helm</i> ‘helmet, protection’. The fact that it was borne by the Conqueror himself does not seem to have inhibited its favour with the ‘conquered’ population: in the first century after the Conquest it was the commonest male name of all, and not only among the Normans. In the later Middle Ages it was overtaken by   John  , but continued to run second to that name until the 20th century, when the picture became more fragmented."],"variants":[]}],"historicEvents":[{"id":1705195,"age":32,"year":"1382","julianDay":2225826,"title":"Wycliffe's Bible","description":"John Wycliffe, English theologian and professor at the University of Oxford, completed a translation of the Bible from the Latin Vulgate into Middle English. This translation is known as Wycliffe's Bible and was completed around 1382.","url":"https://en.wikipedia.org/wiki/Wycliffe%27s_Bible","urlTitle":"Wikipedia - Wycliffe's Bible","jurisdictionLevel":2}],"lifeSummary":"When William Argentine was born in 1350, in Halesworth, Suffolk, England, his father, John de Argentine, was 32 and his mother, Margaret Darcy, was 38. He married Isabel Kerdeston. They were the parents of at least 1 son. He died on 22 January 1419, in his hometown, at the age of 69, and was buried in Halesworth, Suffolk, England."},"et":{"1350–22 January 1419":"1350–22. jaanuar 1419","1332–1375":"1332–1375","1343–Female":"1343–Surnud","1350–1414":"1350–1414","1350–1419":"1350–1419","1350–1383":"1350–1383","1363–1410":"1363–1410","1370–1419":"1370–1419","1318–1382":"1318–1382","1313–1383":"1313–1383","21 Mar 1410":"21. märts 1410","1 September 1383":"1. september 1383","1363":"1363","1350":"1350","1383":"1383","1382":"1382","1370":"1370","26 November 1382":"26. november 1382","after 8 July 1325":"pärast 8. juulit 1325","22 January 1419":"22. jaanuar 1419","1414":"1414","1313":"1313","1410":"1410","1343":"1343","1332":"1332","1375":"1375","1419":"1419","1318":"1318","Halesworth, Suffolk, England":"Halesworth, Suffolk, England","England":"England","Essex, England":"Essex, England","Wymondley, Hertsfordshire, England":"Little Wymondley, Hertfordshire, Inglismaa, United Kingdom"},"fi":{"1350–22 January 1419":"1350–22. tammikuuta 1419","1332–1375":"1332–1375","1343–Female":"1343–Kuollut","1350–1414":"1350–1414","1350–1419":"1350–1419","1350–1383":"1350–1383","1363–1410":"1363–1410","1370–1419":"1370–1419","1318–1382":"1318–1382","1313–1383":"1313–1383","21 Mar 1410":"21. maaliskuuta 1410","1 September 1383":"1. syyskuuta 1383","1363":"1363","1350":"1350","1383":"1383","1382":"1382","1370":"1370","26 November 1382":"26. marraskuuta 1382","after 8 July 1325":"8. heinäkuuta 1325 j