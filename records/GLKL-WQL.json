ale":"1365–Deceased","1368–1425":"1368–1425","1350–Female":"1350–Deceased","1425":"1425","1368":"1368","1365":"1365","1385":"1385","1350":"1350","about 1365":"about 1365","Abt 1367":"about 1367","Dunbartonshire, Scotland":"Dunbartonshire, Scotland","Cromarty, Ross, Scotland":"Cromarty, Cromartyshire, Scotland","Scotland, , , United Kingdom":"Scotland, United Kingdom","Cumbernauld, Dunbartonshire, Scotland":"Cumbernauld, Dunbartonshire, Scotland","Cumbernauld, , Dunbartonshire, Scotland":"Cumbernauld, Dunbartonshire, Scotland, United Kingdom","nameMeanings":[{"name":"Fleming","type":"LAST","attribution":"Dictionary of American Family Names © Patrick Hanks 2003, 2006.","meanings":["English: ethnic name for someone from Flanders, from Middle English <i>fleming</i>. The word reflects a Norman French form of Old French <i>flamanc</i> ‘Fleming’, from the stem <i>flam-</i> + the ancient Germanic suffix <i>-ing</i>. In the Middle Ages there was considerable commercial intercourse between England and the Netherlands, particularly in the wool trade, and many Flemish weavers and dyers settled in England. This surname is also common in south and east Scotland and in Ireland, where it is sometimes found in the Gaelicized form <b>Pléamonn</b>.","German: variant of   Flemming  , cognate with 1 above."],"variants":[{"name":"Flemings","meanings":["English: plural form of   Fleming  .","Americanized form of Flemish <b>Vleminckx</b>: patronymic from <b>Vleminck</b>, an ethnic name for someone from Flanders, Middle Dutch <i>vleminc</i>."]},{"name":"Flanders","meanings":["English: ethnic name from Middle English <i>Fla(u)ndres</i> ‘Flanders’, denoting someone from Flanders, a historical region covering parts of modern-day Belgium, France, and the Netherlands. Compare   Fleming  ."]},{"name":"Fleeman","meanings":["English: variant of   Fleming  ."]},{"name":"Flemming","meanings":["German: ethnic name for someone from Flanders, Middle High German <i>vlaeminc</i>. People from Flanders spread throughout Germany, as well as England, in the Middle Ages as clothmakers and dyers.","English: variant of   Fleming  ."]},{"name":"Flamenco","meanings":["Spanish: ethnic name from <i>flamenco</i> ‘Fleming, Flemish person’ (see   Fleming  )."]}]},{"name":"Brigida","type":"FIRST","attribution":"Dictionary of First Names © Patrick Hanks and Flavia Hodges 1990, 2003, 2006.","meanings":["From Irish  Brighid  (  and <b>Bridget</b> ) or from its Swedish derivative <b>Birgit</b> ."],"variants":[]}],"lifeSummary":"Lady Brigida Fleming was born in 1350, in Cumbernauld, Dunbartonshire, Scotland. She married Adam Urquhart de Urchard 2nd of Cromarty, Sheriff of Cromarty about 1367, in Cumbernauld, Dunbartonshire, Scotland, United Kingdom. They were the parents of at least 1 son and 1 daughter. She died in Scotland, United Kingdom."},"et":{"1350–":"1350–Surnud","1350–1385":"1350–1385","1365–Female":"1365–Surnud","1368–1425":"1368–1425","1350–Female":"1350–Surnud","1425":"1425","1368":"1368","1365":"1365","1385":"1385","1350":"1350","about 1365":"umbes 1365","Abt 1367":"umbes 1367","Dunbartonshire, Scotland":"Dunbartonshire, Scotland","Cromarty, Ross, Scotland":"Cromarty, Cromartyshire, Scotland","Scotland, , , United Kingdom":"Šotimaa, United Kingdom","Cumbernauld, Dunbartonshire, Scotland":"Cumbernauld, Dunbartonshire, Scotland","Cumbernauld, , Dunbartonshire, Scotland":"Cumbernauld, Dunbartonshire, Šotimaa, United Kingdom"},"fi":{"1350–":"1350–Kuollut","1350–1385":"1350–1385","1365–Female":"1365–Kuollut","1368–1425":"1368–1425","1350–Female":"1350–Kuollut","1425":"1425","1368":"1368","1365":"1365","1385":"1385","1350":"1350","about 1365":"noin 1365","Abt 1367":"noin 1367","Dunbartonshire, Scotland":"Dunbartonshire, Scotland","Cromarty, Ross, Scotland":"Cromarty, Cromartyshire, Scotland","Scotland, , , United Kingdom":"Skotlanti, Yhdistynyt kuningaskunta","Cumbernauld, Dunbartonshire, Scotland":"Cumbernauld, Dunbartonshire, Scotland","Cumbernauld, , Dunbartonshire, Scotland"