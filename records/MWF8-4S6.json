,"1030":"1030","1073":"1073","1170":"1170","1060":"1060","1070":"1070","1106":"1106","14 October 1066":"14. oktober 1066","1035":"1035","0990":"0990","1023":"1023","about 1023":"omkring 1023","Yorkshire, England":"Jórvík, England","Hooton Pagnell, Yorkshire, England":"Hooton Pagnell, Jórvík, England","York, Yorkshire, England":"York, Jórvík, England","Hastings, Sussex, England":"Hastings, Sussex, England","Sourdeval, Manche, Normandy, France":"Sourdeval, Manche, Normandie, Frankrig","Wales":"Wales","France":"Frankrig"},"nl":{"about 1023–1090":"circa 1023–1090","1023–1090":"1023–1090","1030–Female":"1030–Overleden","1060–Male":"1060–Overleden","1070–1106":"1070–1106","1070–1170":"1070–1170","1073–1097":"1073–1097","0990–Male":"0990–Overleden","–Female":"Overleden","about 1060":"circa 1060","1090":"1090","before 1023":"vóór 1023","1066":"1066","1086":"1086","1097":"1097","1030":"1030","1073":"1073","1170":"1170","1060":"1060","1070":"1070","1106":"1106","14 October 1066":"14 oktober 1066","1035":"1035","0990":"0990","1023":"1023","about 1023":"circa 1023","Yorkshire, England":"Yorkshire, England","Hooton Pagnell, Yorkshire, England":"Hooton Pagnell, Yorkshire, England","York, Yorkshire, England":"York, Yorkshire, England","Hastings, Sussex, England":"Hastings, Sussex, England","Sourdeval, Manche, Normandy, France":"Sourdeval, Manche, Normandie, Frankrijk","Wales":"Wales","France":"Frankrijk"},"en":{"about 1023–1090":"about 1023–1090","1023–1090":"1023–1090","1030–Female":"1030–Deceased","1060–Male":"1060–Deceased","1070–1106":"1070–1106","1070–1170":"1070–1170","1073–1097":"1073–1097","0990–Male":"0990–Deceased","–Female":"Deceased","about 1060":"about 1060","1090":"1090","before 1023":"before 1023","1066":"1066","1086":"1086","1097":"1097","1030":"1030","1073":"1073","1170":"1170","1060":"1060","1070":"1070","1106":"1106","14 October 1066":"14 October 1066","1035":"1035","0990":"0990","1023":"1023","about 1023":"about 1023","Yorkshire, England":"Yorkshire, England","Hooton Pagnell, Yorkshire, England":"Hooton Pagnell, Yorkshire, England","York, Yorkshire, England":"York, Yorkshire, England","Hastings, Sussex, England":"Hastings, Sussex, England","Sourdeval, Manche, Normandy, France":"Sourdeval, Manche, Normandy, France","Wales":"Wales","France":"France","nameMeanings":[{"name":"Richard","type":"FIRST","attribution":"Dictionary of First Names © Patrick Hanks and Flavia Hodges 1990, 2003, 2006.","meanings":["One of the most enduringly successful of the Old French personal names introduced into Britain by the Normans. It is of Germanic (Frankish) origin, derived from <i>rīc</i> ‘power’ + <i>hard</i> ‘strong, hardy’. It has enjoyed continuous popularity in England from the Conquest to the present day, influenced by the fact that it was borne by three kings of England, in particular  Richard I  (  1157–99 ). He was king for only ten years (  1189–99 ), most of which he spent in warfare abroad, taking part in the Third Crusade and costing the people of England considerable sums in taxes. Nevertheless, he achieved the status of a folk hero, and was never in England long enough to disappoint popular faith in his goodness and justice. He was also Duke of Aquitaine and Normandy and Count of Anjou, fiefs which he held at a time of maximum English expansion in France. His exploits as a leader of the Third Crusade earned him the nickname ‘Coeur de Lion’ or ‘Lionheart’ and a permanent place in popular imagination, in which he was even more firmly enshrined by  Sir Walter Scott's  novel Ivanhoe (  1820 )."],"variants":[{"name":"Rikert","meanings":["One of the most enduringly successful of the Old French personal names introduced into Britain by the Normans. It is of Germanic (Frankish) origin, derived from <i>rīc</i> ‘power’ + <i>hard</i> ‘strong, hardy’. It has enjoyed continuous popularity in England from the Conquest to the present day, influenced by the fact that it was borne by three kings of England, in particular  Richard I  (  1157–99 ). He was king for only ten years (  1189–99 ), most of which he spent in warfare abroad, taking part in the Third Crusade and costing the people of England considerable sums in taxes. Nevertheless, he achieved the status of a folk hero, and was never in England long enough to disappoint popular faith in his goodness and justice. He was also Duke of Aquitaine and Normandy and Count of Anjou, fiefs which he held at a time of maximum English expansion in France. His exploits as a leader of the Third Crusade earned him the nickname ‘Coeur de Lion’ or ‘Lionheart’ and a permanent place in popular imagination, in which he was even more firmly enshrined by  Sir Walter Scott's  novel Ivanhoe (  1820 )."]},{"name":"Rickert","meanings":["One of the most enduringly successful of the Old French personal names introduced into Britain by the Normans. It is of Germanic (Frankish) origin, derived from <i>rīc</i> ‘power’ + <i>hard</i> ‘strong, hardy’. It has enjoyed continuous popularity in England from the Conquest to the present day, influenced by the fact that it was borne by three kings of England, in particular  Richard I  (  1157–99 ). He was king for only ten years (  1189–99 ), most of which he spent in warfare abroad, taking part in the Third Crusade and costing the people of England considerable sums in taxes. Nevertheless, he achieved the status of a folk hero, and was never in England long enough to disappoint popular faith in his goodness and justice. He was also Duke of Aquitaine and Normandy and Count of Anjou, fiefs which he held at a time of maximum English expansion in France. His exploits as a leader of the Third Crusade earned him the nickname ‘Coeur de Lion’ or ‘Lionheart’ and a permanent place in popular imagination, in which he was even more firmly enshrined by  Sir Walter Scott's  novel Ivanhoe (  1820 )."]}]}],"historicEvents":[{"id":1705181,"age":12,"year":"1035","julianDay":2099086,"title":"England Divided","description":"King Canute died in 1035 and England was divided between his three sons. His son Sweyn received Norway, Harthacanute received Denmark, and Harold Harefoot received North England.","jurisdictionLevel":2},{"id":1705182,"age":43,"year":"1066","julianDay":2110409,"title":"Battle of Hastings","description":"Battle of Hastings was fought between the Norman-French army and the battle-wary English army on October 14, 1066. Duke William of Normandy believed he was the rightful king rather than Harold, who had been crowned king several months earlier. Harold was killed in battle and William was crowned king on Christmas Day 1066.","url":"https://www.english-heritage.org.uk/learn/1066-and-the-norman-conquest/what-happened-battle-hastings/","urlTitle":"English Heritage - Battle of Hastings","jurisdictionLevel":2},{"id":1705183,"age":63,"year":"1086","julianDay":2117714,"title":"Domesday Book","description":"Domesday Book is Britain's earliest extant public record with information containing land surveys and landholdings commissioned by William I. The book was completed in 1086.","url":"https://www.nationalarchives.gov.uk/domesday/","urlTitle":"National Archives - Domesday","jurisdictionLevel":2}],"lifeSummary":"Richard Surdeval was born about 1023, in Sourdeval, Manche, Normandy, France as the son of Baron le Moigne and Mrs. Baron le Moigne. He had at least 2 sons and 2 daughters with Mrs Richard de Surdeval. He registered for military service in 1066. He died in 1090, in Hooton Pagnell, Yorkshire, England, at the age of 68."},"et":{"about 1023–1090":"umbes 1023–1090","1023–1090":"1023–1090","1030–Female":"1030–Surnud","1060–Male":"1060–Surnud","1070–1106":"1070–1106","1070–1170":"1070–1170","1073–1097":"1073–1097","0990–Male":"0990–Surnud","–Female":"Surnud","about 1060":"umbes 1060","1090":"1090","before 1023":"enne 1023","1066":"1066","1086":"1086","1097":"1097","1030":"1030","1073":"1073","1170":"1170","1060":"1060","1070":"1070","1106":"1106","14 October 1066":"14. oktoober 1066","1035":"1035","0990":"099