352","1230":"1230","about 1278":"about 1278","1260":"1260","1280":"1280",",Herefordshire,England.":"Herefordshire, England, United Kingdom","Abbey Dore, Herefordshire, England":"Abbey Dore, Herefordshire, England","Ewyas Harold, Herefordshire, England, United Kingdom":"Ewyas Harold, Herefordshire, England, United Kingdom","nameMeanings":[{"name":"Whelan","type":"LAST","attribution":"Dictionary of American Family Names © Patrick Hanks 2003, 2006.","meanings":["Some characteristic forenames:  Irish Brendan, Dermot, Declan, James Patrick, Niall, Cahal, Ronan, Sean Patrick.","Irish (southern counties): shortened and altered Anglicized form of Gaelic <b>Ó Faoláin</b> ‘descendant of <i>Faolán</i>’, a personal name based on a diminutive of <i>faol</i> ‘wolf’. This name is also Anglicized as   Phelan   and   Folan   or ‘translated’ as   Woulfe  . The Irish name also occurs in a form without initial <i>f</i>, namely <b>Ó hAoláin</b> and <b>Ó hAoileáin</b>, Anglicized as   Heelan  , and, with excrescent final <i>-d</i> as   Hyland   and   Holland   6."],"variants":[{"name":"Phelan","meanings":["Some characteristic forenames:  Irish Kieran, Aine, Declan, Finbarr.","Irish:","Anglicized form of <b>Ó Faoláin</b> ‘descendant of <i>Faolán</i>’, see   Whelan  ."]},{"name":"Whalen","meanings":["Irish: variant of   Whelan  ."]},{"name":"Whaling","meanings":["Irish: variant of   Whelan  ."]},{"name":"Wheelan","meanings":["Irish (Tipperary): variant of   Whelan  ."]},{"name":"Whalin","meanings":["Irish: variant of   Whelan  .","In some cases possibly also an Americanized form of Swedish   Wahlin   or   Wallin   (see   Vallin  )."]}]},{"name":"Clara","type":"FIRST","attribution":"Dictionary of First Names © Patrick Hanks and Flavia Hodges 1990, 2003, 2006.","meanings":["Post-classical Latin name, from the feminine form of the adjective <i>clarus</i> ‘bright, famous’. In the modern English-speaking world it represents a re-Latinization of the regular English form   Clare .  It was made famous in the early 20th century by the singer  Dame Clara Butt  (  1873–1936 ) and the silent film actress  Clara Bow  (  1905–65 ), known as ‘the It girl’ (because, whatever ‘it’ was, she had it)."],"variants":[]},{"name":"de","type":"FIRST","attribution":"Dictionary of First Names © Patrick Hanks and Flavia Hodges 1990, 2003, 2006.","meanings":["‘Attainment’."],"variants":[]}],"lifeSummary":"When Clara de Whelan was born about 1260, in Herefordshire, England, United Kingdom, her father, Ivan de Whelan, was 31 and her mother, Clarice de Ewyas, was 27. She had at least 2 sons with Thomas Scudamore Lord Kentchurch."},"et":{"about 1260–":"umbes 1260–Surnud","1260–Female":"1260–Surnud","1254–Male":"1254–Surnud","1278–Male":"1278–Surnud","1280–1352":"1280–1352","1230–Male":"1230–Surnud","1234–Female":"1234–Surnud","about 1260":"umbes 1260","1234":"1234","1278":"1278","1254":"1254","1352":"1352","1230":"1230","about 1278":"umbes 1278","1260":"1260","1280":"1280",",Herefordshire,England.":"Herefordshire, Inglismaa, United Kingdom","Abbey Dore, Herefordshire, England":"Abbey Dore, Herefordshire, England","Ewyas Harold, Herefordshire, England, United Kingdom":"Ewyas Harold, Herefordshire, Inglismaa, United Kingdom"},"fi":{"about 1260–":"noin 1260–Kuollut","1260–Female":"1260–Kuollut","1254–Male":"1254–Kuollut","1278–Male":"1278–Kuollut","1280–1352":"1280–1352","1230–Male":"1230–Kuollut","1234–Female":"1234–Kuollut","about 1260":"noin 1260","1234":"1234","1278":"1278","1254":"1254","1352":"1352","1230":"1230","about 1278":"noin 1278","1260":"1260","1280":"1280",",Herefordshire,England.":"Herefordshire, Englanti, Yhdistynyt kuningaskunta","Abbey Dore, Herefordshire, England":"Abbey Dore, Herefordshire, England","Ewyas Harold, Herefordshire, England, United Kingdom":"Ewyas Harold, Herefordshire, Englanti, Yhdistynyt kuningaskunta"},"fr":{"about 1260–":"environ 1260–Décédée","1260–Female":"1260–Décédée","1254–Male":"1254–Décédé","1278–Male":"1278–Décédé","1280–1352":"1280–1352",