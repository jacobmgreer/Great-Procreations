1320":"na 1320","about 1320":"circa 1320","1317":"1317","Mottram St Andrew, Cheshire, England":"Mottram St Andrew, Cheshire, England","Macclesfield, Cheshire, England":"Macclesfield, Cheshire, England"},"en":{"about 1282–after 1320":"about 1282–after 1320","1282–1320":"1282–1320","1305–1379":"1305–1379","1316–Male":"1316–Deceased","1320–1378":"1320–1378","1256–Male":"1256–Deceased","about 1282":"about 1282","1282":"1282","1290":"1290","1305":"1305","1316":"1316","1315":"1315","1379":"1379","about 1316":"about 1316","1378":"1378","1256":"1256","1320":"1320","after 1320":"after 1320","about 1320":"about 1320","1317":"1317","Mottram St Andrew, Cheshire, England":"Mottram St Andrew, Cheshire, England","Macclesfield, Cheshire, England":"Macclesfield, Cheshire, England","nameMeanings":[{"name":"Gagler","type":"LAST","attribution":"Dictionary of American Family Names © Patrick Hanks 2003, 2006.","meanings":["Some characteristic forenames:  German Hans, Hedwig, Kurt, Otto.","German and Dutch: occupational name for a nail maker, from Middle High German and Middle Dutch <i>nagel</i> ‘nail’ + the agent suffix <i>-er</i>."],"variants":[]},{"name":"Margaret","type":"FIRST","attribution":"Dictionary of First Names © Patrick Hanks and Flavia Hodges 1990, 2003, 2006.","meanings":["An extremely common given name from the Middle Ages onwards, derived via Old French <i>Marguerite</i> and Latin <i>Margarita</i> from Greek <i>Margarītēs</i>, from <i>margaron</i> ‘pearl’, a word ultimately of Hebrew origin. The name was always understood to mean ‘pearl’ throughout the Middle Ages. The first  St Margaret  was martyred at Antioch in Pisidia during the persecution instigated by the  Emperor Diocletian  in the early 4th century. However, there is some doubt about her name, as the same saint is venerated in the Orthodox Church as   Marina .  There were several other saintly bearers of the name, including St Margaret of Scotland (  d. 1093 ), wife of  King Malcolm Canmore  and daughter of Edmund Ironside of England. It was also the name of the wife of  Henry VI  of England,  Margaret of Anjou  (  1430–82 ), and of  Margaret Tudor  (  1489–1541 ), sister of  Henry VIII , who married James IV of Scotland and ruled as regent there after his death.  See also  Margery  ,   Marjorie ."],"variants":[{"name":"Margareta","meanings":["From the Latin form of Greek <i>Margarītēs</i>.  See  <b>Margaret</b>   ."]},{"name":"Margaretta","meanings":["Formed from Margaret."]}]}],"historicEvents":[{"id":1705190,"age":8,"year":"1290","julianDay":2192224,"title":"Jews Expelled From England","description":"After years of anti-Semitic behavior, King Edward I expelled Jews from England in 1290.","jurisdictionLevel":2},{"id":1705191,"age":33,"year":"1315","toYear":"1317","julianDay":2201354,"title":"Famine Strikes Europe","description":"A famine caused by cold winters and wet summers across Europe caused millions to die due to starvation. Desperation from hunger caused high levels of crime, stampedes in bread lines in London, infanticide, and even cannibalism throughout Europe.","jurisdictionLevel":2}],"lifeSummary":"Margaret Gagler was born about 1282, in Macclesfield, Cheshire, England as the daughter of John le Gagler of Macclesfeld. She had at least 3 sons with Edmund Mottram II. She died after 1320, in Mottram St Andrew, Cheshire, England."},"et":{"about 1282–after 1320":"umbes 1282–pärast 1320","1282–1320":"1282–1320","1305–1379":"1305–1379","1316–Male":"1316–Surnud","1320–1378":"1320–1378","1256–Male":"1256–Surnud","about 1282":"umbes 1282","1282":"1282","1290":"1290","1305":"1305","1316":"1316","1315":"1315","1379":"1379","about 1316":"umbes 1316","1378":"1378","1256":"1256","1320":"1320","after 1320":"pärast 1320","about 1320":"umbes 1320","1317":"1317","Mottram St Andrew, Cheshire, England":"Mottram St Andrew, Cheshire, England","Macclesfield, Cheshire, England":"Macclesfield, Cheshire, England"},"fi":{"about 1282–after 1320":"noin 1282–1320 jälkeen","1282–1320":"1282–