en","1303":"1303","1325":"1325","1369":"1369","1335":"1335","1299":"1299","1373":"1373","before 1285":"vóór 1285","1395":"1395","1291":"1291","1280":"1280","1306":"1306","Cromartyshire, Scotland":"Cromartyshire, Schotland","Erroll, Perthshire, Scotland":"Errol, Perthshire, Schotland, Verenigd Koninkrijk","Scotland":"Schotland","Gowrie Castle, Gowrie, Perthshire, Scotland":"Caithness, Schotland, Verenigd Koninkrijk"},"en":{"1303–1373":"1303–1373","1306–1335":"1306–1335","1299–1369":"1299–1369","1325–1395":"1325–1395","1280–Male":"1280–Deceased","1291–Female":"1291–Deceased","1303":"1303","1325":"1325","1369":"1369","1335":"1335","1299":"1299","1373":"1373","before 1285":"before 1285","1395":"1395","1291":"1291","1280":"1280","1306":"1306","Cromartyshire, Scotland":"Cromartyshire, Scotland","Erroll, Perthshire, Scotland":"Errol, Perthshire, Scotland, United Kingdom","Scotland":"Scotland","Gowrie Castle, Gowrie, Perthshire, Scotland":"Caithness, Scotland, United Kingdom","nameMeanings":[{"name":"Haye","type":"LAST","attribution":"Dictionary of American Family Names © Patrick Hanks 2003, 2006.","meanings":["Some characteristic forenames:  German Hans, Helmut, Willi.","North German, East Frisian, and Dutch: from a personal name, Frisian <i>Hajo</i>, ancient Germanic <i>Haio</i>; or from a short form of the female name <i>Hadewig</i>, composed of the elements <i>hadu</i> ‘battle, strife’ + <i>wīg</i> ‘war’.","German: variant of   Hey   4, 5."],"variants":[{"name":"Deshayes","meanings":["French: topographic name for someone who lived by an enclosure, from the plural of Old French <i>haye</i> ‘hedge’ (see   Haye   and   Hayes  ), with fused preposition and definite article <i>des</i> ‘from the’; or a habitational name denoting someone from Les Hayes, the name of several places in various parts of France. Compare   Deshaies  ."]},{"name":"Hayenga","meanings":["East Frisian: patronymic from the personal name <i>Hajo</i> (see   Haye   1). It is formed with the suffix <i>-enga</i>, a variant of <i>-inga</i> (from the patronymic suffix <i>-ing</i> and genitive plural ending <i>-a</i>)."]},{"name":"Hey","meanings":["English (Yorkshire and Lancashire): variant of   Hay  .","Dutch: variant, mostly Americanized (or archaic) and Flemish, of <b>Heij</b>, a topographic name for someone who lived on a heath, Dutch <i>hei</i>, <i>heide</i>.","German: metonymic occupational name for a grower or mower of grass, from Middle High German <i>höu</i> ‘grass, hay’."]},{"name":"Hayen","meanings":["Some characteristic forenames:  French Alphonse.  German Heinz, Wilhelm.","Flemish, East Frisian, and North German: patronymic from   Haye   1."]}]},{"name":"Rosalind","type":"FIRST","attribution":"Dictionary of First Names © Patrick Hanks and Flavia Hodges 1990, 2003, 2006.","meanings":["From an Old French personal name of Germanic (Frankish) origin, from <i>hros</i> ‘horse’ + <i>lind</i> ‘weak, tender, soft’. It was adopted by the Normans and introduced by them to Britain. In the Middle Ages it was reanalysed by folk etymology as if from Latin <i>rosa linda</i> ‘lovely rose’. Its popularity as a given name owes much to its use by  Edmund Spenser  for the character of a shepherdess in his pastoral poetry, and by  Shakespeare  as the name of the heroine in As You Like It (  1599 )."],"variants":[]},{"name":"de","type":"FIRST","attribution":"Dictionary of First Names © Patrick Hanks and Flavia Hodges 1990, 2003, 2006.","meanings":["Variant of   Dev ."],"variants":[{"name":"Deborah","meanings":["Biblical name (meaning ‘bee’ in Hebrew), borne by the nurse of Rebecca (Genesis 35:8) and by a woman judge and prophet (Judges 4–5) who led the Israelites to victory over the Canaanites. It has always been popular as a Jewish name. It was in use among Christians by the mid 16th century and was taken up by the Puritans in the 17th century, in part because the bee was a symbol of industriousness. Since then it has enjoyed enormous popularity, peaking in the 1960s. Among other famous bearers is the actress  Deborah Kerr  (  1921–2007 )."]}]}],"lifeSummary":"When Baroness Rosalind de Haye was born in 1303, in Errol, Perthshire, Scotland, United Kingdom, her father, Sir Gilbert de la Hay 3rd of Locherwort, was 23 and her mother, Margaret Fraser, was 13. She had at least 1 son with Francis Urquhart. She died in 1373, in Caithness, Scotland, United Kingdom, at the age of 70."},"et":{"1303–1373":"1303–1373","1306–1335":"1306–1335","1299–1369":"1299–1369","1325–1395":"1325–1395","1280–Male":"1280–Surnud","1291–Female":"1291–Surnud","1303":"1303","1325":"1325","1369":"1369","1335":"1335","1299":"1299","1373":"1373","before 1285":"enne 1285","1395":"1395","1291":"1291","1280":"1280","1306":"1306","Cromartyshire, Scotland":"Cromartyshire, Scotland","Erroll, Perthshire, Scotland":"Errol, Perthshire, Šotimaa, United Kingdom","Scotland":"Scotland","Gowrie Castle, Gowrie, Perthshire, Scotland":"Caithness, Šotimaa, United Kingdom"},"fi":{"1303–1373":"1303–1373","1306–1335":"1306–1335","1299–1369":"1299–1369","1325–1395":"1325–1395","1280–Male":"1280–Kuollut","1291–Female":"1291–Kuollut","1303":"1303","1325":"1325","1369":"1369","1335":"1335","1299":"1299","1373":"1373","before 1285":"ennen vuotta 1285","1395":"1395","1291":"1291","1280":"1280","1306":"1306","Cromartyshire, Scotland":"Cromartyshire, Scotland","Erroll, Perthshire, Scotland":"Errol, Perthshire, Skotlanti, Yhdistynyt kuningaskunta","Scotland":"Scotland","Gowrie Castle, Gowrie, Perthshire, Scotland":"Caithness, Skotlanti, Yhdistynyt kuningaskunta"},"fr":{"1303–1373":"1303–1373","1306–1335":"1306–1335","1299–1369":"1299–1369","1325–1395":"1325–1395","1280–Male":"1280–Décédé","1291–Female":"1291–Décédée","1303":"1303","1325":"1325","1369":"1369","1335":"1335","1299":"1299","1373":"1373","before 1285":"avant 1285","1395":"1395","1291":"1291","1280":"1280","1306":"1306","Cromartyshire, Scotland":"Cromartyshire, Écosse","Erroll, Perthshire, Scotland":"Errol, Perthshire, Écosse, Royaume-Uni","Sco