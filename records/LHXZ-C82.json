ert ."],"variants":[]}],"historicEvents":[{"id":1705188,"age":4,"year":"1224","julianDay":2168117,"title":"France Declares War on England","description":"France declared war on England as Louis VIII of France attacked Poitou and northern Gascony.","jurisdictionLevel":2},{"id":1705189,"age":39,"year":"1259","julianDay":2180901,"title":"100 Years of Conflict Between England and France Ends","description":"Treaty of Paris was signed on December 4, 1259, which ended 100 years of conflict between England and France.","url":"https://en.wikipedia.org/wiki/Treaty_of_Paris_(1259)","urlTitle":"Wikipedia - Treaty of Paris 1259","jurisdictionLevel":2},{"id":1705190,"age":70,"year":"1290","julianDay":2192224,"title":"Jews Expelled From England","description":"After years of anti-Semitic behavior, King Edward I expelled Jews from England in 1290.","jurisdictionLevel":2}],"lifeSummary":"Robert de Chaumbleng was born in 1220, in Pulford, Cheshire, England. He had at least 1 daughter."},"et":{"1220–":"1220–Surnud","1247–1300":"1247–1300","1220–Male":"1220–Surnud","1259":"1259","1247":"1247","1224":"1224","1300":"1300","1220":"1220","1290":"1290","Pulford, Cheshire, England":"Pulford, Cheshire, England"},"fi":{"1220–":"1220–Kuollut","1247–1300":"1247–1300","1220–Male":"1220–Kuollut","1259":"1259","1247":"1247","1224":"1224","1300":"1300","1220":"1220","1290":"1290","Pulford, Cheshire, England":"Pulford, Cheshire, England"},"fr":{"1220–":"1220–Décédé","1247–1300":"1247–1300","1220–Male":"1220–Décédé","1259":"1259","1247":"1247","1224":"1224","1300":"1300","1220":"1220","1290":"1290","Pulford, Cheshire, England":"Pulford, Cheshire, Angleterre","lifeSummary":"Robert de Chaumbleng est né en 1220, à Pulford, Cheshire, Angleterre. Il a eu au moins 1 fille."},"de":{"1220–":"1220–Verstorben","1247–1300":"1247–1300","1220–Male":"1220–Verstorben","1259":"1259","1247":"1247","1224":"1224","1300":"1300","1220":"1220","1290":"1290","Pulford, Cheshire, England":"Pulford, Cheshire, England","lifeSu