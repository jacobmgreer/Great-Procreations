names:  Spanish Jose, Francisco, Jesus, Pablo, Juan, Agustin, Carlos, Ernesto, Manuel, Roberto, Ruben, Santiago.","Spanish (<b>Aguillón</b>) and French (Occitan):","habitational name from any of several places called Aguillón in Spain (Asturias or Galicia), or Aguillon in Var, France."],"variants":[]},{"name":"II","type":"FIRST","attribution":"Dictionary of First Names © Patrick Hanks and Flavia Hodges 1990, 2003, 2006.","meanings":["‘Loving’."],"variants":[]}],"lifeSummary":"Enguerrand II de Trie Aiguillon was born about 1136, in Chaumont, Oise, Picardie, France. He had at least 2 sons and 2 daughters with Edine De Moucy Le Chastel. He died about 1170, at the age of 36."},"et":{"about 1136–environ 1170":"umbes 1136–umbes 1170","1135–Female":"1135–Surnud","1170–Female":"1170–Surnud","1170–Male":"1170–Surnud","1750–1237":"1750–1237","1136–1170":"1136–1170","1237":"1237","1136":"1136","1135":"1135","1750":"1750","about 1136":"umbes 1136","environ 1170":"umbes 1170","ABT 1170":"umbes 1170","1170":"1170","Chaumont, Oise, Picardie, France":"Chaumont, Oise, Picardie, Prantsusmaa"},"fi":{"about 1136–environ 1170":"noin 1136–noin 1170","1135–Female":"1135–Kuollut","1170–Female":"1170–Kuollut","1170–Male":"1170–Kuollut","1750–1237":"1750–1237","1136–1170":"1136–1170","1237":"1237","1136":"1136","1135":"1135","1750":"1750","about 1136":"noin 1136","environ 1170":"noin 1170","ABT 1170":"noin 1170","1170":"1170","Chaumont, Oise, Picardie, France":"Chaumont, Oise, Picardie, Ranska"},"fr":{"about 1136–environ 1170":"environ 1136–environ 1170","1135–Female":"1135–Décédée","1170–Female":"1170–Décédée","1170–Male":"1170–Décédé","1750–1237":"1750–1237","1136–1170":"1136–1170","1237":"1237","1136":"1136","1135":"1135","1750":"1750","about 1136":"environ 1136","environ 1170":"environ 1170","ABT 1170":"environ 1170","1170":"1170","Chaumont, Oise, Picardie, France":"Chaumont, Oise, Picardie, France","lifeSummary":"Enguerrand II de Trie Aiguillon est né environ 1136, à Chaumont, Oise, Pic