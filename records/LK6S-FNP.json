普雷斯頓","Durham, England":"英国達勒姆","Owlton, Durham, England":"英国英格兰達勒姆希爾頓","lifeSummary":"Nicholas Lambert Lord of Skipton是Henry Lambert和Isabel Lambert的儿子，出生在英国英格兰達勒姆希爾頓。他于大约1362年与Isabella Lambert of Owlton在英国達勒姆结婚。他们至少是5个儿子的父母。他去世在他的家乡。"},"hr":{"–":"preminuo","1337–1386":"1337–1386","1342–1411":"1342–1411","1875–Female":"1875–preminula","–Male":"preminuo","1324–1355":"1324–1355","1340–Male":"1340.–preminuo","1353–1430":"1353–1430","1364–1418":"1364–1418","1370–1399":"1370.–1399","1408–1477":"1408.–1477","1307–1360":"1307–1360","1340":"1340.","1360":"1360","1370":"1370.","abt 1364":"oko 1364.","1337":"1337","1875":"1875","1324":"1324","1477":"1477","1411":"1411","1399":"1399","1355":"1355","Abt 1353":"oko 1353.","1364":"1364","1430":"1430","1353":"1353","1342":"1342","1386":"1386","1408":"1408.","1418":"1418","1307":"1307","about 1362":"oko 1362.","Long Preston, Yorkshire, England":"Long Preston, Yorkshire, England","Durham, England":"Durham, England","Owlton, Durham, England":"Hilton, Durham, Engleska, United Kingdom"},"cs":{"–":"Zesnulý","1337–1386":"1337–1386","1342–1411":"1342–1411","1875–Female":"1875–Zesnulá","–Male":"Zesnulý","1324–1355":"1324–1355","1340–Male":"1340–Zesnulý","1353–1430":"1353–1430","1364–1418":"1364–1418","1370–1399":"1370–1399","1408–1477":"1408–1477","1307–1360":"1307–1360","1340":"1340","1360":"1360","1370":"1370","abt 1364":"okolo 1364","1337":"1337","1875":"1875","1324":"1324","1477":"1477","1411":"1411","1399":"1399","1355":"1355","Abt 1353":"okolo 1353","1364":"1364","1430":"1430","1353":"1353","1342":"1342","1386":"1386","1408":"1408","1418":"1418","1307":"1307","about 1362":"okolo 1362","Long Preston, Yorkshire, England":"Long Preston, Yorkshire, Anglie","Durham, England":"Durham, Anglie","Owlton, Durham, England":"Hilton, Durham, Anglie, United Kingdom"},"da":{"–":"Afdød","1337–1386":"1337–1386","1342–1411":"1342–1411","1875–Female":"1875–Afdød","–Male":"Afdød","1324–1355":"1324–1355","1340–Male":"1340–Afdød","1353–1430":"1353–1430","