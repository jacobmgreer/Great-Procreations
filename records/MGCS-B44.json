"1382":"1382","1392":"1392","1370":"1370","1369":"1369","1456":"1456","1368":"1368","1455":"1455","1421":"1421","1366":"1366","1398":"1398","1331":"1331","Leicester, Leicestershire, England, United Kingdom":"Leicester, Leicestershire, England, United Kingdom","Leicester, Leicestershire, England":"Leicester, Leicestershire, England"},"nl":{"about 1370–":"circa 1370–Overleden","1366–Male":"1366–Overleden","1368–Male":"1368–Overleden","1369–1456":"1369–1456","1370–Male":"1370–Overleden","–1455":"–1455","–Female":"Overleden","1372–Female":"1372–Overleden","1392–Female":"1392–Overleden","1331–1398":"1331–1398","–1421":"–1421","about 1370":"circa 1370","1372":"1372","1382":"1382","1392":"1392","1370":"1370","1369":"1369","1456":"1456","1368":"1368","1455":"1455","1421":"1421","1366":"1366","1398":"1398","1331":"1331","Leicester, Leicestershire, England, United Kingdom":"Leicester, Leicestershire, Engeland, Verenigd Koninkrijk","Leicester, Leicestershire, England":"Leicester, Leicestershire, England"},"en":{"about 1370–":"about 1370–Deceased","1366–Male":"1366–Deceased","1368–Male":"1368–Deceased","1369–1456":"1369–1456","1370–Male":"1370–Deceased","–1455":"–1455","–Female":"Deceased","1372–Female":"1372–Deceased","1392–Female":"1392–Deceased","1331–1398":"1331–1398","–1421":"–1421","about 1370":"about 1370","1372":"1372","1382":"1382","1392":"1392","1370":"1370","1369":"1369","1456":"1456","1368":"1368","1455":"1455","1421":"1421","1366":"1366","1398":"1398","1331":"1331","Leicester, Leicestershire, England, United Kingdom":"Leicester, Leicestershire, England, United Kingdom","Leicester, Leicestershire, England":"Leicester, Leicestershire, England","nameMeanings":[{"name":"Walsh","type":"LAST","attribution":"Dictionary of American Family Names © Patrick Hanks 2003, 2006.","meanings":["Some characteristic forenames:  Irish Brendan, Aileen, Dermot, John Patrick, Kieran, Declan, Eamonn, Colm, Donal, Seamus, Siobhan, Brennan.","English and Irish: ethnic name from Middle English <i>walshe</i> (Old English <i>wælisc</i>) ‘foreign, Welsh’. This form of the name was generally more common than   Welsh  , especially in Ireland, where it originally denoted a Welsh-speaking immigrant, in particular any of the Welshmen who arrived in the wake of Strongbow's Anglo-Norman invasion of 1170. In Ireland it is sometimes also a translation of <b>Breathnach</b> ‘Briton’.","English: in Yorkshire and Lancashire the name is sometimes a shortened form of   Walshaw  ."],"variants":[{"name":"Walshe","meanings":["Some characteristic forenames:  Irish Brendan, Eoin, Murph.","English and Irish: variant of   Walsh  ."]},{"name":"McBratney","meanings":["Scottish: Anglicized form of Gaelic <b>Mac Breatnaigh</b> ‘son of the Briton’ (referring to the Welsh of Strathclyde). Compare   Walsh   and   Galbraith  ."]},{"name":"Welsh","meanings":["Scottish, English, and Irish: ethnic name from Middle English <i>welshe</i> (Old English <i>wēalisc</i>, <i>wēlisc</i>) ‘foreign, Welsh’, for someone from Wales or a speaker of the Welsh language. Compare   Walsh   and   Wallace  .","Americanized form of German   Welsch  .","Americanized form of Ukrainian and Jewish (from Ukraine)   Voloshin   or its Polish variant <b>Wołoszyn</b> (see   Woloszyn  )."]}]},{"name":"Thomas","type":"FIRST","attribution":"Dictionary of First Names © Patrick Hanks and Flavia Hodges 1990, 2003, 2006.","meanings":["New Testament name, borne by one of Christ's twelve apostles, referred to as ‘Thomas, called Didymus’ (John 11:16; 20:24). <i>Didymos</i> is the Greek word for ‘twin’, and the name is the Greek form of an Aramaic byname meaning ‘twin’. The given name has always been popular throughout Christendom, in part because St Thomas's doubts have made him seem a very human character."],"variants":[]}],"historicEvents":[{"id":1705195,"age":12,"year":"1382","julianDay":2225826,"title":"Wycliffe's Bible","description":"John Wycliffe, English theologian and professor at the University of Oxford, completed a translation of the Bible from the Latin Vulgate into Middle English. This translation is known as Wycliffe's Bible and was completed around 1382.","url":"https://en.wikipedia.org/wiki/Wycliffe%27s_Bible","urlTitle":"Wikipedia - Wycliffe's Bible","jurisdictionLevel":2},{"id":1705197,"age":85,"year":"1455","julianDay":2252488,"title":"Wars of the Roses","description":"Wars of the Roses was a series of English civil wars for control of the throne of England between the royal families House of Lancaster and the House of York. The name of the war was derived as the red rose was the symbol of the Lancastrians and the white rose was the symbol of the Yorks.","url":"https://www.history.com/topics/british-history/wars-of-the-roses","urlTitle":"History - Wars of the Roses","jurisdictionLevel":2}],"lifeSummary":"Thomas Walsh was born about 1370, in Leicester, Leicestershire, England as the son of Thomas Walsh and Katherine. He had at least 1 daughter with Margery."},"et":{"about 1370–":"umbes 1370–Surnud","1366–Male":"1366–Surnud","1368–Male":"1368–Surnud","1369–1456":"1369–1456","1370–Male":"1370–Surnud","–1455":"–1455","–Female":"Surnud","1372–Female":"1372–Surnud","1392–Female":"1392–Surnud","1331–1398":"1331–1398","–1421":"–1421","about 1370":"umbes 1370","1372":"1372","1382":"1382","1392":"1392","1370":"1370","1369":"1369","1456":"1456","1368":"1368","1455":"1455","1421":"1421","1366":"1366","1398":"1398","1331":"1331","Leicester, Leicestershire, England, United Kingdom":"Leicester, Leicestershire, Inglismaa, United Kingdom","Leicester, Leicestershire, England":"Leicester, Leicestershire, England"},"fi":{"about 1370–":"noin 1370–Kuollut","1366–Male":"1366–Kuollut","1368–Male":"1368–Kuollut","1369–1456":"1369–1456","1370–Male":"1370–Kuollut","–1455":"–1455","–Female":"Kuollut","1372–Female":"1372–Kuollut","1392–Female":"1392–Kuollut","1331–1398":"1331–1398","–1421":"–1421","about 1370":"noin 1370","1372":"1372","1382":"1382","1392":"1392","1370":"1370","1369":"1369","1456