ne Maga Dorset England":"Dorset, Anglie, United Kingdom","Winterbourne, -Clenstone, Dorestshire, England":"Winterbourne Herringstone, Dorset, Anglie"},"da":{"about 1274–5 February 1313":"omkring 1274–før 5. februar 1313","1274–1313":"1274–1313","1276–1311":"1276–1311","1304–1318":"1304–1318","1311–1345":"1311–1345","1250–1320":"1250–1320","1250–Female":"1250–Afdød","25 Mar 1304":"25. marts 1304","1274":"1274","1250":"1250","1290":"1290","1304":"1304","1303":"1303","5 February 1313":"før 5. februar 1313","1313":"1313","1345":"1345","1311":"1311","1266":"1266","1320":"1320","1276":"1276","about 1311":"omkring 1311","after 1311":"efter 1311","1318":"1318","about 1274":"omkring 1274","Winterbourne Clenstone, Dorset, England":"Winterbourne Clenstone, Dorset, England","Hartley, Devon, England":"Hartley, Devon, England","Hartley Minterene Maga Dorset England":"Dorset, England, United Kingdom","Winterbourne, -Clenstone, Dorestshire, England":"Winterbourne Herringstone, Dorset, England"},"nl":{"about 1274–5 February 1313":"circa 1274–vóór 5 februari 1313","1274–1313":"1274–1313","1276–1311":"1276–1311","1304–1318":"1304–1318","1311–1345":"1311–1345","1250–1320":"1250–1320","1250–Female":"1250–Overleden","25 Mar 1304":"25 maart 1304","1274":"1274","1250":"1250","1290":"1290","1304":"1304","1303":"1303","5 February 1313":"vóór 5 februari 1313","1313":"1313","1345":"1345","1311":"1311","1266":"1266","1320":"1320","1276":"1276","about 1311":"circa 1311","after 1311":"na 1311","1318":"1318","about 1274":"circa 1274","Winterbourne Clenstone, Dorset, England":"Winterbourne Clenstone, Dorset, England","Hartley, Devon, England":"Hartley, Devon, England","Hartley Minterene Maga Dorset England":"Dorset, Engeland, Verenigd Koninkrijk","Winterbourne, -Clenstone, Dorestshire, England":"Winterbourne Herringstone, Dorset, England"},"en":{"about 1274–5 February 1313":"about 1274–before 5 February 1313","1274–1313":"1274–1313","1276–1311":"1276–1311","1304–1318":"1304–1318","1311–1345":"1311–1345","1250–1320":"1250–1320","1250–Female":"1250–Deceased","25 Mar 1304":"25 March 1304","1274":"1274","1250":"1250","1290":"1290","1304":"1304","1303":"1303","5 February 1313":"before 5 February 1313","1313":"1313","1345":"1345","1311":"1311","1266":"1266","1320":"1320","1276":"1276","about 1311":"about 1311","after 1311":"after 1311","1318":"1318","about 1274":"about 1274","Winterbourne Clenstone, Dorset, England":"Winterbourne Clenstone, Dorset, England","Hartley, Devon, England":"Hartley, Devon, England","Hartley Minterene Maga Dorset England":"Dorset, England, United Kingdom","Winterbourne, -Clenstone, Dorestshire, England":"Winterbourne Herringstone, Dorset, England","nameMeanings":[{"name":"de","type":"LAST","attribution":"Dictionary of American Family Names © Patrick Hanks 2003, 2006.","meanings":["Some characteristic forenames:  Indian Dilip, Anirban, Gopal, Alok, Anindya, Arunava, Asit, Asok, Dibyendu, Goutam, Indra, Indranil.","Indian: variant of   Dey  ."],"variants":[{"name":"Dey","meanings":["Some characteristic forenames:  Indian Ashit, Indu, Naina, Partha, Soumya, Ajit, Anjan, Anjana, Anup, Arjun, Arun, Ashim.","English, Scottish, and Welsh: variant of   Day  .","German: topographic name from a field name in North Rhine-Westphalia, denoting a sizeable piece of land, from Middle Low German <i>dē</i> ‘thigh’ (referring to the shape of the property)."]}]},{"name":"la","type":"LAST","attribution":"Dictionary of American Family Names © Patrick Hanks 2003, 2006.","meanings":["Some characteristic forenames:  Vietnamese Hung, Cuong, Anh, Thanh, Ha, Hoang, Tuan, Chau, Hao, Hien, Hoa, Hue, Nam, Phong, Sinh, Tuong, Min, Tam, Tanh, Thai, Tham, Tinh, Yeong.  Chinese Hong, Hang, Sang, Tong, Chan, Chi, Hwa Ja, Hyung, Kam, Ki Bong, Kin, Man.","Vietnamese: from the Chinese surname 羅, see   Luo   1.","Vietnamese (<b>Lã</b>): from the Chinese surname 呂, see   Lu   6 and 3 below."],"variants":[{"name":"Luo","meanings":["Some characteristic forenames:  Chinese Wei, Jian, Yi, Ping, Yong, Zhen, Feng, Hong, Ming, Jin, Bin, Chen, Hai, Lan, Min, Huan, Hung, Shen, Tian.","Chinese:","Mandarin form of the surname 羅, meaning ‘net for catching birds’ or ‘to collect’ in Chinese: (i) from Luo (羅), the name of an ancient state (located in present-day Hubei province). After it was annexed by the state of Chu during the early Spring and Autumn period (770–476  BC ), people from the state migrated southwards and adopted Luo (羅) as their surname. (ii) from the Po Duo Luo (破多羅) and Chi Luo (叱羅) families from the Xianbei ethnic group in northern China, who changed their original surnames to 羅 during the Northern Wei dynasty (386–534  AD ). (iii) from the personal name Hu Se Luo (斛瑟羅), leader of an ancient Turkic tribe who are believed to have migrated to China during the Tang dynasty (618–907  AD ). His descendants inherited his name Hu Se Luo (斛瑟羅) as their surname and shortened it to 羅 during the Northern Wei dynasty (386–534  AD ). (iv) from the name of one of the seven families from the Bandun Man, an ethnic group residing in ancient southwestern China (located mainly in present-day Sichuan province)."]}]},{"name":"Lynde","type":"LAST","attribution":"Dictionary of American Family Names © Patrick Hanks 2003, 2006.","meanings":["English: variant of   Lind   1."],"variants":[{"name":"Lind","meanings":["Scandinavian, English, and Dutch: topographic name for someone who lived by a lime tree, Scandinavian and Middle English <i>lind</i>. As a Swedish name, it is often of ornamental origin.","North German and Danish: habitational name from any of various places called with <i>Lind</i> ‘lime tree’.","South German, and Jewish (Ashkenazic): nickname for a gentle, mild, tolerant man, from Middle High German <i>lint</i>, <i>linde</i>, Yiddish <i>lind</i> ‘gentle, mild’."]}]},{"name":"William","type":"FIRST","attribution":"Dictionary of First Names © Patrick Hanks and Flavia Hodges 1990, 2003, 2006.","meanings":["Probably the most successful of all the Old French names of Germanic origin that were introduced to England by the Normans. It is derived from Germanic <i>wil</i> ‘will, desire’ + <i>helm</i> ‘helmet, protection’. The fact that it was borne by the Conqueror himself does not seem to have inhibited its favour with the ‘conquered’ population: in the first century after the Conquest it was the commonest male name of all, and not only among the Normans. In the later Middle Ages it was overtaken by   John  , but continued to run second to that name until the 20th century, when the picture became more fragmented."],"variants":[]},{"name":"Alexander","type":"FIRST","attribution":"Dictionary of First Names © Patrick Hanks and Flavia Hodges 1990, 2003, 2006.","meanings":["From the Latin form of the Greek name <i>Alexandros</i>, from <i>alexein</i> ‘to defend’ + <i>anēr</i> ‘man, warrior’ (genitive <i>andros</i>). The name became extremely popular in the post-classical period, and was borne by several individuals in the New Testament and some early Christian saints. Its use as a common given name throughout Europe, however, derives largely from the fame of  Alexander the Great , King of Macedon (  356–323  bc  ), around whom a large body of popular legend grew up in late antiquity, much of which came to be embodied in the medieval ‘Alexander romances’."],"variants":[]}],"historicEvents":[{"id":1705190,"age":16,"year":"1290","julianDay":2192224,"title":"Jews Expelled From England","description":"After years of anti-Semitic behavior, King Edward I expelled Jews from England in 1290.","jurisdictionLevel":2}],"lifeSummary":"When William Alexander de la Lynde Sir was born about 1274, in Winterbourne Clenstone, Dorset, England, his father, Geoffrey de la Lynde, was 25 and his mother, Alice de La Lynde, was 25. He married Edith de la Hartley in 1303. They were the parents of at least 2 sons. He died before 5 February 1313, in Dorset, England, United Kingdom."},"et":{"about 1274–5 February 1313":"umbes 1274–enne 5. veebruari 1313