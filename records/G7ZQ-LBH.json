:{"1420–":"1420–Afdød","1420–Male":"1420–Afdød","1430–Female":"1430–Afdød","–Female":"Afdød","1446–Female":"1446–Afdød","1448–Female":"1448–Afdød","1450–1501":"1450–1501","1452–Male":"1452–Afdød","1400–Male":"1400–Afdød","1407–Female":"1407–Afdød","1448":"1448","1446":"1446","1501":"1501","1400":"1400","1420":"1420","1452":"1452","1430":"1430","1450":"1450","1407":"1407","about 1450":"omkring 1450","Of,, Hertfordshire, England":"Hertfordshire, England, United Kingdom","Olveston, Gloucestershire, England":"Olveston, Gloucestershire, England","England, United Kingdom":"England, United Kingdom"},"nl":{"1420–":"1420–Overleden","1420–Male":"1420–Overleden","1430–Female":"1430–Overleden","–Female":"Overleden","1446–Female":"1446–Overleden","1448–Female":"1448–Overleden","1450–1501":"1450–1501","1452–Male":"1452–Overleden","1400–Male":"1400–Overleden","1407–Female":"1407–Overleden","1448":"1448","1446":"1446","1501":"1501","1400":"1400","1420":"1420","1452":"1452","1430":"1430","1450":"1450","1407":"1407","about 1450":"circa 1450","Of,, Hertfordshire, England":"Hertfordshire, Engeland, Verenigd Koninkrijk","Olveston, Gloucestershire, England":"Olveston, Gloucestershire, England","England, United Kingdom":"Engeland, Verenigd Koninkrijk"},"en":{"1420–":"1420–Deceased","1420–Male":"1420–Deceased","1430–Female":"1430–Deceased","–Female":"Deceased","1446–Female":"1446–Deceased","1448–Female":"1448–Deceased","1450–1501":"1450–1501","1452–Male":"1452–Deceased","1400–Male":"1400–Deceased","1407–Female":"1407–Deceased","1448":"1448","1446":"1446","1501":"1501","1400":"1400","1420":"1420","1452":"1452","1430":"1430","1450":"1450","1407":"1407","about 1450":"about 1450","Of,, Hertfordshire, England":"Hertfordshire, England, United Kingdom","Olveston, Gloucestershire, England":"Olveston, Gloucestershire, England","England, United Kingdom":"England, United Kingdom","nameMeanings":[{"name":"Walsh","type":"LAST","attribution":"Dictionary of American Family Names © Patrick Hanks 2003, 2006.","meanings":["Some characteristic forenames:  Irish Brendan, Aileen, Dermot, John Patrick, Kieran, Declan, Eamonn, Colm, Donal, Seamus, Siobhan, Brennan.","English and Irish: ethnic name from Middle English <i>walshe</i> (Old English <i>wælisc</i>) ‘foreign, Welsh’. This form of the name was generally more common than   Welsh  , especially in Ireland, where it originally denoted a Welsh-speaking immigrant, in particular any of the Welshmen who arrived in the wake of Strongbow's Anglo-Norman invasion of 1170. In Ireland it is sometimes also a translation of <b>Breathnach</b> ‘Briton’.","English: in Yorkshire and Lancashire the name is sometimes a shortened form of   Walshaw  ."],"variants":[{"name":"Walshe","meanings":["Some characteristic forenames:  Irish Brendan, Eoin, Murph.","English and Irish: variant of   Walsh  ."]},{"name":"McBratney","meanings":["Scottish: Anglicized form of Gaelic <b>Mac Breatnaigh</b> ‘son of the Briton’ (referring to the Welsh of Strathclyde). Compare   Walsh   and   Galbraith  ."]},{"name":"Welsh","meanings":["Scottish, English, and Irish: ethnic name from Middle English <i>welshe</i> (Old English <i>wēalisc</i>, <i>wēlisc</i>) ‘foreign, Welsh’, for someone from Wales or a speaker of the Welsh language. Compare   Walsh   and   Wallace  .","Americanized form of German   Welsch  .","Americanized form of Ukrainian and Jewish (from Ukraine)   Voloshin   or its Polish variant <b>Wołoszyn</b> (see   Woloszyn  )."]}]},{"name":"John","type":"FIRST","attribution":"Dictionary of First Names © Patrick Hanks and Flavia Hodges 1990, 2003, 2006.","meanings":["As a boy's name this represents a revival of Middle English <i>Jan</i>, a by‐form of   John  , or an adoption of the common European form with this spelling. As a girl's name it is a short form of names such as   Janet   and   Janice ."],"variants":[]},{"name":"Alexander","type":"FIRST","attribution":"Dictionary of First Names © Patrick Hanks and Flavia Hodges 1990, 2003, 2006.","meanings":["From the Latin form of the Greek name <i>Alexandros</i>, from <i>alexein</i> ‘to defend’ + <i>anēr</i> ‘man, warrior’ (genitive <i>andros</i>). The name became extremely popular in the post-classical period, and was borne by several individuals in the New Testament and some early Christian saints. Its use as a common given name throughout Europe, however, derives largely from the fame of  Alexander the Great , King of Macedon (  356–323  bc  ), around whom a large body of popular legend grew up in late antiquity, much of which came to be embodied in the medieval ‘Alexander romances’."],"variants":[]}],"lifeSummary":"When Sir John Alexander Walsh Sr. was born in 1420, in England, United Kingdom, his father, Adam Simon Welsch, was 20 and his mother, Julianna De'Pontlarch, was 14. He had at least 2 sons and 2 daughters with Lady Margaret Alice De'Seymour."},"et":{"1420–":"1420–Surnud","1420–Male":"1420–Surnud","1430–Female":"1430–Surnud","–Female":"Surnud","1446–Female":"1446–Surnud","1448–Female":"1448–Surnud","1450–1501":"1450–1501","1452–Male":"1452–Surnud","1400–Male":"1400–Surnud","1407–Female":"1407–Surnud","1448":"1448","1446":"1446","1501":"1501","1400":"1400","1420":"1420","1452":"1452","1430":"1430","1450":"1450","1407":"1407","about 1450":"umbes 1450","Of,, Hertfordshire, England":"Hertfordshire, Inglismaa, United Kingdom","Olveston, Gloucestershire, England":"Olveston, Gloucestershire, England","England, United Kingdom":"Inglismaa, United Kingdom"},"fi":{"1420–":"1420–Kuollut","1420–Male":"1420–Kuollut","1430–Female":"1430–Kuollut","–Female":"Kuollut","1446–Female":"1446–Kuollut","1448–Female":"1448–Kuollut","1450–1501":"1450–1501","1452–Male":"1452–Kuollut","1400–Male":"1400–Kuollut","1407–Female":"1407–Kuollut","1448":"1448","1446":"1446","1501":"1501","1400":"1400","1420":"1420","1452":"1452","1430":"1430","1450":"1450","1407":"1407","about 1450":"noin 1450","Of,, Hertfordshire, England":"Hertfordshire, Englanti, Yhdistynyt kuningaskunta","Olveston, Glou