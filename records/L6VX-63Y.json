76":"1322–1376","October 1354":"oktober 1354","1352":"1352","1384":"1384","1373":"1373","1340":"1340","1295":"1295","1360":"1360","1424":"1424","1413":"1413","1368":"1368","1322":"1322","1376":"1376","1342":"1342","about 1363":"omkring 1363","1406":"1406","4 April 1373":"4. april 1373","Montrose, Forfarshire, Scotland":"Montrose, Angus, Skotland, United Kingdom","SCOTLAND":"Skotland, United Kingdom","Kincardine, Perthshire, Scotland, United Kingdom":"Kincardine, Perthshire, Skotland, United Kingdom","Blackford, Perthshire, Scotland":"Blackford, Perthshire, Skotland, United Kingdom","Kincardineshire Scotland":"Kincardineshire, Skotland, United Kingdom"},"nl":{"1352–1384":"1352–1384","1342–1406":"1342–1406","1360–Female":"1360–Overleden","1360–Male":"1360–Overleden","1340–1413":"1340–1413","1368–1424":"1368–1424","1295–1373":"1295–1373","1322–1376":"1322–1376","October 1354":"oktober 1354","1352":"1352","1384":"1384","1373":"1373","1340":"1340","1295":"1295","1360":"1360","1424":"1424","1413":"1413","1368":"1368","1322":"1322","1376":"1376","1342":"1342","about 1363":"circa 1363","1406":"1406","4 April 1373":"4 april 1373","Montrose, Forfarshire, Scotland":"Montrose, Angus, Schotland, Verenigd Koninkrijk","SCOTLAND":"Schotland, Verenigd Koninkrijk","Kincardine, Perthshire, Scotland, United Kingdom":"Kincardine, Perthshire, Schotland, Verenigd Koninkrijk","Blackford, Perthshire, Scotland":"Blackford, Perthshire, Schotland, Verenigd Koninkrijk","Kincardineshire Scotland":"Kincardineshire, Schotland, Verenigd Koninkrijk"},"en":{"1352–1384":"1352–1384","1342–1406":"1342–1406","1360–Female":"1360–Deceased","1360–Male":"1360–Deceased","1340–1413":"1340–1413","1368–1424":"1368–1424","1295–1373":"1295–1373","1322–1376":"1322–1376","October 1354":"October 1354","1352":"1352","1384":"1384","1373":"1373","1340":"1340","1295":"1295","1360":"1360","1424":"1424","1413":"1413","1368":"1368","1322":"1322","1376":"1376","1342":"1342","about 1363":"about 1363","1406":"1406","4 April 1373":"4 April 1373","Montrose, Forfarshire, Scotland":"Montrose, Angus, Scotland, United Kingdom","SCOTLAND":"Scotland, United Kingdom","Kincardine, Perthshire, Scotland, United Kingdom":"Kincardine, Perthshire, Scotland, United Kingdom","Blackford, Perthshire, Scotland":"Blackford, Perthshire, Scotland, United Kingdom","Kincardineshire Scotland":"Kincardineshire, Scotland, United Kingdom","nameMeanings":[{"name":"Blackford","type":"LAST","attribution":"Dictionary of American Family Names © Patrick Hanks 2003, 2006.","meanings":["English: habitational name from any of various places called Blackford, for example in Blackford (Somerset), Blackford Farm (Sussex), Blackford Farm in Castle Eaton (Wiltshire), and Blackford House in Tanworth in Arden (Warwickshire), from Old English <i>blæc</i> ‘black, dark’ + <i>ford</i> ‘ford’."],"variants":[]},{"name":"Matilda","type":"FIRST","attribution":"Dictionary of First Names © Patrick Hanks and Flavia Hodges 1990, 2003, 2006.","meanings":["Latinized form of a Germanic personal name derived from <i>maht</i>, <i>meht</i> ‘might’ + <i>hild</i> ‘battle’. This was the name of an early German queen (  895–968 ), wife of  Henry  the Fowler, who was noted for her piety and generosity. It was also the name of the wife of  William  the Conqueror and of the daughter of  Henry I  of England (  see  Maud  ). The name was introduced into England by the Normans, and this Latinized form is the one that normally occurs in medieval records, while the vernacular form <i>Maud</i> was the one in everyday use. <i>Matilda</i> was revived in England as a learned form in the 18th century."],"variants":[{"name":"Mathilda","meanings":["Latinized form of a Germanic personal name derived from <i>maht</i>, <i>meht</i> ‘might’ + <i>hild</i> ‘battle’. This was the name of an early German queen (  895–968 ), wife of  Henry  the Fowler, who was noted for her piety and generosity. It was also the name of the wife of  William  the Conqueror and of the daughter of  Henry I  of England (  see  Maud  ). The name was introduced into England by the Normans, and this Latinized form is the one that normally occurs in medieval records, while the vernacular form <i>Maud</i> was the one in everyday use. <i>Matilda</i> was revived in England as a learned form in the 18th century."]}]},{"name":"Maud","type":"FIRST","attribution":"Dictionary of First Names © Patrick Hanks and Flavia Hodges 1990, 2003, 2006.","meanings":["Medieval vernacular form of   Matilda .  This form was characteristically Low German (i.e. including medieval Dutch and Flemish). The wife of  William the Conqueror , who bore this name, was the daughter of  Baldwin , Count of Flanders. In Flemish and Dutch the letter <i>-t-</i> was generally lost when it occurred between vowels, giving forms such as <i>Ma(h)auld</i>. <i>Maud</i> or <i>Matilda</i> was also the name of the daughter (  1102–67 ) of  Henry I  of England; she was married early in life to the Holy Roman Emperor  Henry V , and later disputed the throne of England with her cousin  Stephen . In  1128  she married  Geoffrey , Count of Anjou. A medieval chronicler commented, ‘she was a good woman, but she had little bliss with him’. The name <i>Maud</i> became quite common in England in the 19th century, when its popularity was influenced in part by  Tennyson's  poem Maud, published in  1855 , but has not been much used since the early decades of the 20th century."],"variants":[]}],"lifeSummary":"When Matilda Maud Blackford was born in 1352, in Kincardineshire, Scotland, United Kingdom, her father, David Graham Lord of Kincardine and Dunaff, was 57 and her mother, Helen of Strathearn, was 30. She married Sir Patrick Graham of Dundaff and Kincardine - Earl of Strathearn about 1363. She died in 1384, in Kincardine, Perthshire, Scotland, United Kingdom, at the age of 32."},"et":{"1352–1384":"1352–1384","1342–1406":"1342–1406","1360–Female":"1360–Surnud","1360–Male":"1360–Surnud","1340–1413":"1340–1413","1368–1424":"1