land":"Wing, Buckinghamshire, England","Essex, England":"Essex, England, United Kingdom","England, United Kingdom":"England","St Mary, Paddington Green, Middlesex, England":"St Mary's, Ealing, Middlesex, England, United Kingdom","nameMeanings":[{"name":"Buckingham","type":"LAST","attribution":"Dictionary of American Family Names © Patrick Hanks 2003, 2006.","meanings":["English: habitational name from the former county seat of the county of Buckinghamshire, Old English <i>Buccingahamm</i> ‘water meadow (Old English <i>hamm</i>) of the people of (<i>-inga-</i>) <i>Bucc(a)</i>’."],"variants":[]},{"name":"John","type":"FIRST","attribution":"Dictionary of First Names © Patrick Hanks and Flavia Hodges 1990, 2003, 2006.","meanings":["form of   John  , also used quite frequently in the English-speaking world. In Northern Ireland it is sometimes found as a variant of   Ewan ."],"variants":[]},{"name":"Stafford","type":"FIRST","attribution":"Dictionary of First Names © Patrick Hanks and Flavia Hodges 1990, 2003, 2006.","meanings":["Transferred use of the surname, in origin a local name from any of various places so called from Old English <i>stæð</i> ‘landing place’ + <i>ford</i> ‘ford’, most notably the county town of Staffordshire. This was the surname of the family that held the dukedom of Buckingham in the 15th and 16th centuries."],"variants":[]},{"name":"of","type":"FIRST","attribution":"Dictionary of First Names © Patrick Hanks and Flavia Hodges 1990, 2003, 2006.","meanings":["Short form of   Oswald   or any of the various other names beginning with <i>Os-</i>."],"variants":[]}],"lifeSummary":"When John Stafford of Buckingham was born in 1445, in Buckinghamshire, England, United Kingdom, his father, Edward Stafford, was 17 and his mother, Mrs Edward De Stafford III, was 16. He had at least 1 daughter with Lady Advice of Upton Countess of Buckingham. He died in 1505, in Essex, England, United Kingdom, at the age of 60, and was buried in St Mary's, Ealing, Middlesex, England, United Kingdom."},"et":{"1445–1505":"1445–1505","1460–1558":"1460–1558","1445–1525":"1445–1525","1470–1540":"1470–1540","1428–1484":"1428–1484","1429–Female":"1429–Surnud","1525":"1525","1558":"1558","1445":"1445","1540":"1540","1484":"1484","1 January 1470":"1. jaanuar 1470","1460":"1460","24 Jun":"juuni 0024","1470":"1470","1429":"1429","1505":"1505","1428":"1428","Buckinghamshire, England":"Buckinghamshire, Inglismaa, United Kingdom","Wing, Buckinghamshire, England":"Wing, Buckinghamshire, England","Essex, England":"Essex, Inglismaa, United Kingdom","England, United Kingdom":"England","St Mary, Paddington Green, Middlesex, England":"St Mary's, Ealing, Middlesex, Inglismaa, United Kingdom"},"fi":{"1445–1505":"1445–1505","1460–1558":"1460–1558","1445–1525":"1445–1525","1470–1540":"1470–1540","1428–1484":"1428–1484","1429–Female":"1429–Kuollut","1525":"1525","1558":"1558","1445":"1445","1540":"1540","1484":"1484","1 January 1470":"1. tammikuuta 1470","1460":"1460","24 Jun":"kesäkuu 0024","1470":"1470","1429":"1429","1505":"1505","1428":"1428","Buckinghamshire, England":"Buckinghamshire, Englanti, Yhdistynyt kuningaskunta","Wing, Buckinghamshire, England":"Wing, Buckinghamshire, England","Essex, England":"Essex, Englanti, Yhdistynyt kuningaskunta","England, United Kingdom":"England","St Mary, Paddington Green, Middlesex, England":"St Mary's, Ealing, Middlesex, Englanti, Yhdistynyt kuningaskunta"},"fr":{"1445–1505":"1445–1505","1460–1558":"1460–1558","1445–1525":"1445–1525","1470–1540":"1470–1540","1428–1484":"1428–1484","1429–Female":"1429–Décédée","1525":"1525","1558":"1558","1445":"1445","1540":"1540","1484":"1484","1 January 1470":"1 janvier 1470","1460":"1460","24 Jun":"juin 0024","1470":"1470","1429":"1429","1505":"1505","1428":"1428","Buckinghamshire, England":"Buckinghamshire, Angleterre, Royaume-Uni","Wing, Buckinghamshire, England":"Wing, Buckinghamshire, Angleterre","Essex, England":"Essex, Angleterre, Royaume-Uni","England, United Kingdom":"Angleter