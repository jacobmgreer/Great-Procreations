ngland":"Lincolnshire, England","Edlington, Lincolnshire, England":"Edlington, Lincolnshire, England"},"nl":{"1428–1470":"1428–1470","1425–1476":"1425–1476","1451–1522":"1451–1522","1470–1530":"1470–1530","1400–1428":"1400–1428","1406–1428":"1406–1428","about 1470":"circa 1470","1451":"1451","1450":"1450","1470":"1470","1425":"1425","about 1428":"circa 1428","1522":"1522","1455":"1455","1400":"1400","1476":"1476","about 1424":"circa 1424","1530":"1530","1428":"1428","1406":"1406","Billesby, England":"Engeland, Verenigd Koninkrijk","Lincolnshire, England":"Lincolnshire, England","Edlington, Lincolnshire, England":"Edlington, Lincolnshire, England"},"en":{"1428–1470":"1428–1470","1425–1476":"1425–1476","1451–1522":"1451–1522","1470–1530":"1470–1530","1400–1428":"1400–1428","1406–1428":"1406–1428","about 1470":"about 1470","1451":"1451","1450":"1450","1470":"1470","1425":"1425","about 1428":"about 1428","1522":"1522","1455":"1455","1400":"1400","1476":"1476","about 1424":"about 1424","1530":"1530","1428":"1428","1406":"1406","Billesby, England":"England, United Kingdom","Lincolnshire, England":"Lincolnshire, England","Edlington, Lincolnshire, England":"Edlington, Lincolnshire, England","nameMeanings":[{"name":"Bilesby","type":"LAST","attribution":"Dictionary of Family Names in Britain and Ireland © University of the West of England 2016","meanings":["English: locative name from Bilsby (Lincs)."],"variants":[{"name":"Bilby","meanings":["English:","variant of   Bielby  .","shortened form of <b>Bilsby</b>, a habitational name from Bilsby in Lincolnshire, so named with the Old Norse personal name <i>Billi</i> + <i>bȳ</i> ‘farmstead, settlement’. However, it is equally possible that <i>Bilsby</i> is an altered form of <i>Bilby</i>, with an intrusive <i>-s-</i>."]}]},{"name":"Margaret","type":"FIRST","attribution":"Dictionary of First Names © Patrick Hanks and Flavia Hodges 1990, 2003, 2006.","meanings":["An extremely common given name from the Middle Ages onwards, derived via Old French <i>Marguerite</i> and Latin <i>Margarita</i> from Greek <i>Margarītēs</i>, from <i>margaron</i> ‘pearl’, a word ultimately of Hebrew origin. The name was always understood to mean ‘pearl’ throughout the Middle Ages. The first  St Margaret  was martyred at Antioch in Pisidia during the persecution instigated by the  Emperor Diocletian  in the early 4th century. However, there is some doubt about her name, as the same saint is venerated in the Orthodox Church as   Marina .  There were several other saintly bearers of the name, including St Margaret of Scotland (  d. 1093 ), wife of  King Malcolm Canmore  and daughter of Edmund Ironside of England. It was also the name of the wife of  Henry VI  of England,  Margaret of Anjou  (  1430–82 ), and of  Margaret Tudor  (  1489–1541 ), sister of  Henry VIII , who married James IV of Scotland and ruled as regent there after his death.  See also  Margery  ,   Marjorie ."],"variants":[{"name":"Margareta","meanings":["From the Latin form of Greek <i>Margarītēs</i>.  See  <b>Margaret</b>   ."]},{"name":"Margaretta","meanings":["An extremely common given name from the Middle Ages onwards, derived via Old French <i>Marguerite</i> and Latin <i>Margarita</i> from Greek <i>Margarītēs</i>, from <i>margaron</i> ‘pearl’, a word ultimately of Hebrew origin. The name was always understood to mean ‘pearl’ throughout the Middle Ages. The first  St Margaret  was martyred at Antioch in Pisidia during the persecution instigated by the  Emperor Diocletian  in the early 4th century. However, there is some doubt about her name, as the same saint is venerated in the Orthodox Church as   Marina .  There were several other saintly bearers of the name, including St Margaret of Scotland (  d. 1093 ), wife of  King Malcolm Canmore  and daughter of Edmund Ironside of England. It was also the name of the wife of  Henry VI  of England,  Margaret of Anjou  (  1430–82 ), and of  Margaret Tudor  (  1489–1541 ), sister of  Henry VIII , who married James IV of Scotland and ruled as regent there after his death.  See also  Margery  ,   Marjorie ."]}]}],"historicEvents":[{"id":1705197,"age":27,"year":"1455","julianDay":2252488,"title":"Wars of the Roses","description":"Wars of the Roses was a series of English civil wars for control of the throne of England between the royal families House of Lancaster and the House of York. The name of the war was derived as the red rose was the symbol of the Lancastrians and the white rose was the symbol of the Yorks.","url":"https://www.history.com/topics/british-history/wars-of-the-roses","urlTitle":"History - Wars of the Roses","jurisdictionLevel":2}],"lifeSummary":"When Margaret Bilesby was born in 1428, in Lincolnshire, England, her father, Sir William Bilesby, was 28 and her mother, Elizabeth Swynford, was 23. She married Thomas Robert Thimbleby in 1450, in Lincolnshire, England. They were the parents of at least 1 son and 1 daughter. She died in 1470, in Edlington, Lincolnshire, England, at the age of 42."},"et":{"1428–1470":"1428–1470","1425–1476":"1425–1476","1451–1522":"1451–1522","1470–1530":"1470–1530","1400–1428":"1400–1428","1406–1428":"1406–1428","about 1470":"umbes 1470","1451":"1451","1450":"1450","1470":"1470","1425":"1425","about 1428":"umbes 1428","1522":"1522","1455":"1455","1400":"1400","1476":"1476","about 1424":"umbes 1424","1530":"1530","1428":"1428","1406":"1406","Billesby, England":"Inglismaa, United Kingdom","Lincolnshire, England":"Lincolnshire, England","Edlington, Lincolnshire, England":"Edlington, Lincolnshire, England"},"fi":{"1428–1470":"1428–1470","1425–1476":"1425–1476","1451–1522":"1451–1522","1470–1530":"1470–1530","1400–1428":"1400–1428","1406–1428":"1406–1428","about 1470":"noin 1470","1451":"1451","1450":"1450","1470":"1470","1425":"1425","about 1428":"noin 1428","1522":"1522","1455":"1455","1400":"1400","1476":"1476","about 1424":"noin 1424","1530":"1530","1428":"1428","1406":"1406","Billesby, England":"Englanti, Yhdistynyt kuningasku