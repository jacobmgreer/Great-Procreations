ingdom"},"nl":{"1412–1442":"1412–1442","1410–1446":"1410–1446","1439–1488":"1439–1488","1381–1430":"1381–1430","1385–1420":"1385–1420","24 June 1430":"24 juni 1430","1385":"1385","1381":"1381","1446":"1446","1412":"1412","1488":"1488","1410":"1410","1442":"1442","1420":"1420","1430":"1430","1409":"1409","8 August 1420":"8 augustus 1420","1439":"1439","1438":"1438","Eardisley, Herefordshire, England":"Eardisley, Herefordshire, England","Burghill, Herefordshire, England":"Burghill, Herefordshire, England","Somme, Picardie, France":"Somme, Picardie, Frankrijk","England":"England","Icomb, Gloucestershire, England":"Icomb, Gloucestershire, Engeland, Verenigd Koninkrijk"},"en":{"1412–1442":"1412–1442","1410–1446":"1410–1446","1439–1488":"1439–1488","1381–1430":"1381–1430","1385–1420":"1385–1420","24 June 1430":"24 June 1430","1385":"1385","1381":"1381","1446":"1446","1412":"1412","1488":"1488","1410":"1410","1442":"1442","1420":"1420","1430":"1430","1409":"1409","8 August 1420":"8 August 1420","1439":"1439","1438":"1438","Eardisley, Herefordshire, England":"Eardisley, Herefordshire, England","Burghill, Herefordshire, England":"Burghill, Herefordshire, England","Somme, Picardie, France":"Somme, Picardie, France","England":"England","Icomb, Gloucestershire, England":"Icomb, Gloucestershire, England, United Kingdom","nameMeanings":[{"name":"Blackett","type":"LAST","attribution":"Dictionary of American Family Names © Patrick Hanks 2003, 2006.","meanings":["English:","nickname for a person with dark or fair hair, from Middle English <i>blak</i> ‘black’ (Old English <i>blæc</i>) or ‘fair’ (Old English <i>blāc</i>) + <i>hed</i>, <i>heved</i> ‘head’. See also   Black  .","nickname from Middle English <i>blak</i> ‘black’ + <i>hod</i> ‘hood’."],"variants":[{"name":"Black","meanings":["English and Scottish: chiefly from Middle English <i>blak(e)</i> ‘black’ (Old English <i>blæc</i>, <i>blaca</i>), a nickname given from the earliest times to a swarthy or dark-haired man. However, Middle English <i>blac</i> also meant ‘pale, wan’, a reflex of Old English <i>blāc</i> ‘pale, white’ with a shortened vowel. Compare   Blatch   and   Blick  . With rare exceptions it is impossible to disambiguate these antithetical senses in Middle English surnames. The same difficulty arises with   Blake   and   Block  .","Scottish: in Gaelic-speaking areas this name was adopted as a translation of the epithet <i>dubh</i> ‘dark, black-(haired)’, or of various other names based on Gaelic <i>dubh</i> ‘black’, see   Duff  .","Americanized form (translation into English) of various European surnames directly or indirectly derived from the adjective meaning ‘black, dark’, for example German and Jewish   Schwarz   and Slavic surnames beginning with <i>Čern-</i>, <i>Chern-</i> (see   Chern   and   Cherne  ), <i>Chorn-</i>, <i>Crn-</i> or <i>Czern-</i>."]}]},{"name":"Anne","type":"FIRST","attribution":"Dictionary of First Names © Patrick Hanks and Flavia Hodges 1990, 2003, 2006.","meanings":["Pet form of   Ann   or   Anne ."],"variants":[{"name":"Anni","meanings":["Pet form of   Ann   or   Anne ."]}]}],"lifeSummary":"When Anne Blackett was born in 1412, in Icomb, Gloucestershire, England, United Kingdom, her father, John Blackett, was 31 and her mother, Margaret Beaupyne, was 28. She married Sir Ralph Baskerville in 1438, in Eardisley, Herefordshire, England. They were the parents of at least 1 daughter. She died in 1442, in Somme, Picardie, France, at the age of 30."},"et":{"1412–1442":"1412–1442","1410–1446":"1410–1446","1439–1488":"1439–1488","1381–1430":"1381–1430","1385–1420":"1385–1420","24 June 1430":"24. juuni 1430","1385":"1385","1381":"1381","1446":"1446","1412":"1412","1488":"1488","1410":"1410","1442":"1442","1420":"1420","1430":"1430","1409":"1409","8 August 1420":"8. august 1420","1439":"1439","1438":"1438","Eardisley, Herefordshire, England":"Eardisley, Herefordshire, England","Burghill, Herefordshire, England":"Burghill, Herefordshire, England","Somme, Picardi