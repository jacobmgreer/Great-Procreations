croft, Cheshire, England, United Kingdom":"Ravenscroft, Cheshire, England, United Kingdom","Kempston Parish, Bedfordshire, England":"Bedfordshire, England, United Kingdom","Kempston, Bedfordshire, England":"Kempston, Bedfordshire, England"},"nl":{"1426–1496":"1426–1496","1435–1485":"1435–1485","1462–1525":"1462–1525","1465–1496":"1465–1496","1405–Male":"1405–Overleden","1411–Female":"1411–Overleden","1426":"1426","1525":"1525","1425":"1425","1435":"1435","1411":"1411","1465":"1465","1485":"1485","1496":"1496","1462":"1462","1405":"1405","Ravenscrofte, Cheshire, England":"Cheshire, Engeland, Verenigd Koninkrijk","Ravenscroft, Cheshire, England, United Kingdom":"Ravenscroft, Cheshire, Engeland, Verenigd Koninkrijk","Kempston Parish, Bedfordshire, England":"Bedfordshire, Engeland, Verenigd Koninkrijk","Kempston, Bedfordshire, England":"Kempston, Bedfordshire, England"},"en":{"1426–1496":"1426–1496","1435–1485":"1435–1485","1462–1525":"1462–1525","1465–1496":"1465–1496","1405–Male":"1405–Deceased","1411–Female":"1411–Deceased","1426":"1426","1525":"1525","1425":"1425","1435":"1435","1411":"1411","1465":"1465","1485":"1485","1496":"1496","1462":"1462","1405":"1405","Ravenscrofte, Cheshire, England":"Cheshire, England, United Kingdom","Ravenscroft, Cheshire, England, United Kingdom":"Ravenscroft, Cheshire, England, United Kingdom","Kempston Parish, Bedfordshire, England":"Bedfordshire, England, United Kingdom","Kempston, Bedfordshire, England":"Kempston, Bedfordshire, England","nameMeanings":[{"name":"Croxton","type":"LAST","attribution":"Dictionary of American Family Names © Patrick Hanks 2003, 2006.","meanings":["English: habitational name from any of the places in Cambridgeshire, Cheshire, Lincolnshire, Leicestershire, Norfolk, and Staffordshire named Croxton, from the Old Norse personal name <i>Krókr</i> (see   Crook   3) or an Old English word <i>crōc</i> ‘nook’ + Old English <i>tūn</i> ‘farmstead, settlement’."],"variants":[{"name":"Crowston","meanings":["English: habitational name from South Croxton or Croxton Kerrial (Leicestershire), traditionally pronounced /'krousən/; or possibly from a village so named in Lincolnshire. Compare   Croxton  ."]},{"name":"Crook","meanings":["English:","topographic name from Old Norse <i>krókr</i> ‘nook or bend’ denoting someone who lived by a bend in a river or road. In some instances the surname may have arisen as a habitational name from any of the places called Crook in Cumberland and Durham, or Crooke in Lancashire, all of which are derived from this word.","topographic name for someone who lived ‘(at the) barrow or mound’ from Brittonic <i>crüg</i>. In some instances this may have arisen as a habitational name from either Crook in Combe Raleigh or perhaps Crooke in North Tawton (both Devon), which are derived from this word."]},{"name":"Croston","meanings":["English (Lancashire): habitational name from a place in Lancashire named Croston, from Old Norse <i>kross</i> ‘cross’ or Old English <i>cros</i> + Old English <i>tūn</i> ‘farmstead, settlement’.","English: occasionally, a variant of   Croxton   or   Croson  ."]}]},{"name":"William","type":"FIRST","attribution":"Dictionary of First Names © Patrick Hanks and Flavia Hodges 1990, 2003, 2006.","meanings":["Probably the most successful of all the Old French names of Germanic origin that were introduced to England by the Normans. It is derived from Germanic <i>wil</i> ‘will, desire’ + <i>helm</i> ‘helmet, protection’. The fact that it was borne by the Conqueror himself does not seem to have inhibited its favour with the ‘conquered’ population: in the first century after the Conquest it was the commonest male name of all, and not only among the Normans. In the later Middle Ages it was overtaken by   John  , but continued to run second to that name until the 20th century, when the picture became more fragmented."],"variants":[]}],"lifeSummary":"When William Croxton was born in 1426, in Cheshire, England, United Kingdom, his father, Roger Croxton, was 21 and his mother, Margery Ravenscroft, was 15. He had at least 1 son and 1 daughter with Alice DeMulton. He died in 1496, in his hometown, at the age of 70."},"et":{"1426–1496":"1426–1496","1435–1485":"1435–1485","1462–1525":"1462–1525","1465–1496":"1465–1496","1405–Male":"1405–Surnud","1411–Female":"1411–Surnud","1426":"1426","1525":"1525","1425":"1425","1435":"1435","1411":"1411","1465":"1465","1485":"1485","1496":"1496","1462":"1462","1405":"1405","Ravenscrofte, Cheshire, England":"Cheshire, Inglismaa, United Kingdom","Ravenscroft, Cheshire, England, United Kingdom":"Ravenscroft, Cheshire, Inglismaa, United Kingdom","Kempston Parish, Bedfordshire, England":"Bedfordshire, Inglismaa, United Kingdom","Kempston, Bedfordshire, England":"Kempston, Bedfordshire, England"},"fi":{"1426–1496":"1426–1496","1435–1485":"1435–1485","1462–1525":"1462–1525","1465–1496":"1465–1496","1405–Male":"1405–Kuollut","1411–Female":"1411–Kuollut","1426":"1426","1525":"1525","1425":"1425","1435":"1435","1411":"1411","1465":"1465","1485":"1485","1496":"1496","1462":"1462","1405":"1405","Ravenscrofte, Cheshire, England":"Cheshire, Englanti, Yhdistynyt kuningaskunta","Ravenscroft, Cheshire, England, United Kingdom":"Ravenscroft, Cheshire, Englanti, Yhdistynyt kuningaskunta","Kempston Parish, Bedfordshire, England":"Bedfordshire, Englanti, Yhdistynyt kuningaskunta","Kempston, Bedfordshire, England":"Kempston, Bedfordshire, England"},"fr":{"1426–1496":"1426–1496","1435–1485":"1435–1485","1462–1525":"1462–1525","1465–1496":"1465–1496","1405–Male":"1405–Décédé","1411–Female":"1411–Décédée","1426":"1426","1525":"1525","1425":"1425","1435":"1435","1411":"1411","1465":"1465","1485":"1485","1496":"1496","1462":"1462","1405":"1405","Ravenscrofte, Cheshire, England":"Cheshire, Angleterre, Royaume-Uni","Ravenscroft, Cheshire, England, United Kingdom":"Ravenscroft, Cheshire, Angleterre, Royaume-Uni","Kempston Parish, Bedfordshire, England":"Bedfordshire, Angleterre, Royaume-Uni","Kempston, Bedf