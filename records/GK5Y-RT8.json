d against William de Sibthorp, Esquire, two Mess. one Toft, twenty-six Acres of Land, and two of Meadow, in Aslacton. Their son John Cranmer inherited the estate.","events":[{"name":"Birth","sources":"0","year":"1400","date":"Abt 1400","place":"Sutterton, Lincolnshire, England"},{"name":"Birth of Child","sources":"0","year":"1425","date":"about 1425","place":"Aslacton, Watton Parish, England","age":"25","id":"GK5B-QVM"},{"name":"Death","sources":"0"},{"name":"Marriage","sources":"0","year":"1407","date":"1407","place":"Sutterton, , Lincolnshire, England","type":"Parental"}],"parent":[{"name":"Thomas de Cranmer","gender":"Male","lifespan":"1378–1450","birthDate":"+1378","deathDate":"+1450-11","age":72,"@type":"Person","identifier":"LDP1-MLW","url":"https://ancestors.familysearch.org/en/LDP1-MLW/thomas-de-cranmer-1378-1450","published":true},{"name":"Mrs Alice Cranmer","gender":"Female","lifespan":"1386–1461","birthDate":"+1386","deathDate":"+1461","age":75,"@type":"Person","identifier":"LDP1-MGK","url":"https://ancestors.familysearch.org/en/LDP1-MGK/mrs-alice-cranmer-1386-1461","published":true}],"parentMarriage":{"year":"1407","date":"1407","place":"Sutterton, , Lincolnshire, England"},"sibling":[{"name":"Edmund Cranmer of Sutterton","gender":"Male","lifespan":"1400–Male","birthDate":"A+1400","@type":"Person","identifier":"GK5Y-RT8","url":"https://ancestors.familysearch.org/en/GK5Y-RT8/edmund-cranmer-of-sutterton-1400","published":true}],"spouse":[{"name":"Isabella Aslacton","gender":"Female","lifespan":"1405–Female","birthDate":"+1405/","@type":"Person","identifier":"GK5Y-55Q","url":"https://ancestors.familysearch.org/en/GK5Y-55Q/isabella-aslacton-1405","published":true}],"children":[{"name":"John Cranmer","gender":"Male","lifespan":"1425–Male","birthDate":"A+1425","otherParentId":"GK5Y-55Q","@type":"Person","identifier":"GK5B-QVM","url":"https://ancestors.familysearch.org/en/GK5B-QVM/john-cranmer-1425","published":true}],"@type":"Person","@context":"http://schema.