nited Kingdom":"Preston, Lancashire, Engeland, Verenigd Koninkrijk","Preston, Lancashire, England":"Preston, Lancashire, Engeland, Verenigd Koninkrijk","More Hall, Preston, Lancashire, England":"Preston, Lancashire, England","Lancashire, England":"Lancashire, Engeland, Verenigd Koninkrijk"},"en":{"1413–1472":"1413–1472","–Male":"Deceased","1415–Female":"1415–Deceased","1463–1531":"1463–1531","1451–Male":"1451–Deceased","1379–1450":"1379–1450","1388–Female":"1388–Deceased","1415":"1415","1413":"1413","1379":"1379","1388":"1388","1531":"1531","Abt 1451":"about 1451","1463":"1463","1451":"1451","1450":"1450","1472":"1472","about 1440":"about 1440","Preston, Lancashire, England, United Kingdom":"Preston, Lancashire, England, United Kingdom","Preston, Lancashire, England":"Preston, Lancashire, England, United Kingdom","More Hall, Preston, Lancashire, England":"Preston, Lancashire, England","Lancashire, England":"Lancashire, England, United Kingdom","nameMeanings":[{"name":"Wall","type":"LAST","attribution":"Dictionary of American Family Names © Patrick Hanks 2003, 2006.","meanings":["English: topographic name for someone who lived by a stone-built wall, e.g. one used to fortify a town or to keep back the encroachment of the sea (Middle English <i>wall</i> ‘wall’, Old English <i>wall</i>, <i>weall</i>, from Latin <i>vallum</i> ‘rampart, palisade’), or a habitational name from a place so named, such as Wall (Staffordshire).","English (West Midlands): topographic name for someone who lived by a spring or stream, northern Middle English <i>wall(e)</i> (Old English (Mercian) <i>wæll(a)</i>; compare   Well  ).","Irish (of Norman origin): Anglicized form of <i>de Valle</i> (Gaelicized form <i>de Bhál</i>), the name of a Norman family established in Munster and Connacht."],"variants":[{"name":"Wallander","meanings":["Swedish: variant of   Wall  , with the addition of the suffix <i>-ander</i>, derived from Greek <i>anēr</i> (genitive <i>andros</i>) ‘man’."]},{"name":"Wallenberg","meanings":["Swedish: ornamental name composed of the elements   Wall   + the plural suffix <i>- en</i> (originally German) + <i>berg</i> ‘mountain, hill’.","History: While working as a businessman in Budapest in 1944, Raoul Wallenberg (1912–?47) was entrusted by the Swedish government with the protection of Hungarian Jews from the Nazis. Wallenberg helped about 95,000 Jews to escape death by issuing them Swedish passports. When Soviet forces took control of Budapest in 1945, he was arrested, taken to Moscow, and imprisoned. The Soviet authorities stated that he died in prison in 1947."]},{"name":"Well","meanings":["English (London): topographic name for someone who lived near a spring or stream, from Middle English <i>well(e)</i> ‘spring, stream, well’ (Old English <i>well(a)</i>).","German: from a short form of the personal names <i>Wallo</i>, <i>Walilo</i>.","German: nickname from Middle High German <i>wël</i> ‘round’."]},{"name":"Walle","meanings":["Some characteristic forenames:  Spanish Alberto, Arnulfo, Efrain, Emilia, Evodio, Frederico, Jaime, Javier, Jesus, Jose, Juan, Justo.","English and German: variant of   Wall  . This surname is also found in Mexico.","Norwegian: variant of   Valle  ."]},{"name":"Wallen","meanings":["Swedish (mainly <b>Wallén</b>): topographic or ornamental name composed of a variant of the element <i>vall</i> ‘grassy bank, pasture’ (see   Wall  ) or the root of Latin <i>vallis</i> ‘valley’ (representing Swedish <i>dal</i>) + the adjectival suffix <i>-én/-en</i>, a derivative of Latin <i>-enius</i> ‘relating to’. Compare   Wallin   and   Walen  ."]},{"name":"Walls","meanings":["English and Scottish: variant of   Wall  , with post-medieval excrescent <i>-s</i>.","Irish (Derry): in Ireland this name is also sometimes a variant of   Walsh  ."]}]},{"name":"Evan","type":"FIRST","attribution":"Dictionary of First Names © Patrick Hanks and Flavia Hodges 1990, 2003, 2006.","meanings":["As a Welsh name this represents an Anglicized form of  <b>