D":"Englefield, Berkshire, Engeland, Verenigd Koninkrijk","Englefield, Berkshire, England":"Englefield, Berkshire, England","Lichtenberg, Bas-Rhin, Alsace, France":"Lichtenberg, Bas-Rhin, Alsace, Frankrijk"},"en":{"circa 1110–1190":"about 1110–1190","1106–Male":"1106–Deceased","1110–1190":"1110–1190","1135–1184":"1135–1184","1110–1154":"1110–1154","1154–1226":"1154–1226","1154–Male":"1154–Deceased","1080–1120":"1080–1120","1084–Female":"1084–Deceased","1190":"1190","1080":"1080","1154":"1154","1110":"1110","1120":"1120","1184":"1184","1084":"1084","between 1128 and 1154":"from 1128 to 1154","1106":"1106","circa 1110":"about 1110","1127":"1127","1226":"1226","ABT 1154":"about 1154","1103":"1103","1135":"1135","about 1154":"about 1154","ENGLEFIELD, BERKSHIRE, ENGLAND":"Englefield, Berkshire, England, United Kingdom","Englefield, Berkshire, England":"Englefield, Berkshire, England","Lichtenberg, Bas-Rhin, Alsace, France":"Lichtenberg, Bas-Rhin, Alsace, France","nameMeanings":[{"name":"de","type":"LAST","attribution":"Dictionary of American Family Names © Patrick Hanks 2003, 2006.","meanings":["Some characteristic forenames:  Indian Dilip, Anirban, Gopal, Alok, Anindya, Arunava, Asit, Asok, Dibyendu, Goutam, Indra, Indranil.","Indian: variant of   Dey  ."],"variants":[{"name":"Dey","meanings":["Some characteristic forenames:  Indian Ashit, Indu, Naina, Partha, Soumya, Ajit, Anjan, Anjana, Anup, Arjun, Arun, Ashim.","English, Scottish, and Welsh: variant of   Day  .","German: topographic name from a field name in North Rhine-Westphalia, denoting a sizeable piece of land, from Middle Low German <i>dē</i> ‘thigh’ (referring to the shape of the property)."]}]},{"name":"Englefield","type":"LAST","attribution":"Dictionary of Family Names in Britain and Ireland © University of the West of England 2016","meanings":["English: locative name from either of two places called Englefield (in Berks and Surrey).  Compare  Inglefield  ."],"variants":[{"name":"Ingarfield","meanings":["English: locative name,  see  Englefield  ."]},{"name":"Inglefield","meanings":["English: locative name from Englefield (Surrey), recorded as  <i>Ingelfeld</i> in 1282, or Englefield (Berks)."]}]},{"name":"William","type":"FIRST","attribution":"Dictionary of First Names © Patrick Hanks and Flavia Hodges 1990, 2003, 2006.","meanings":["Probably the most successful of all the Old French names of Germanic origin that were introduced to England by the Normans. It is derived from Germanic <i>wil</i> ‘will, desire’ + <i>helm</i> ‘helmet, protection’. The fact that it was borne by the Conqueror himself does not seem to have inhibited its favour with the ‘conquered’ population: in the first century after the Conquest it was the commonest male name of all, and not only among the Normans. In the later Middle Ages it was overtaken by   John  , but continued to run second to that name until the 20th century, when the picture became more fragmented."],"variants":[]}],"lifeSummary":"When Sir William de Englefield was born about 1110, in Englefield, Berkshire, England, his father, Sir Elias de Englefield, was 31 and his mother, Hely, was 27. He married Maud de la Mare in 1127, in Englefield, Berkshire, England. He died in 1190, in his hometown, at the age of 81."},"et":{"circa 1110–1190":"umbes 1110–1190","1106–Male":"1106–Surnud","1110–1190":"1110–1190","1135–1184":"1135–1184","1110–1154":"1110–1154","1154–1226":"1154–1226","1154–Male":"1154–Surnud","1080–1120":"1080–1120","1084–Female":"1084–Surnud","1190":"1190","1080":"1080","1154":"1154","1110":"1110","1120":"1120","1184":"1184","1084":"1084","between 1128 and 1154":"1128 kuni 1154","1106":"1106","circa 1110":"umbes 1110","1127":"1127","1226":"1226","ABT 1154":"umbes 1154","1103":"1103","1135":"1135","about 1154":"umbes 1154","ENGLEFIELD, BERKSHIRE, ENGLAND":"Englefield, Berkshire, Inglismaa, United Kingdom","Englefield, Berkshire, England":"Englefield, Berkshire, England","Lichtenberg, Bas-Rhin, Alsace, France":"Lichtenberg, B