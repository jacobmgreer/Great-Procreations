n, Middlesex, England":"London, Middlesex, England","London, , Middlesex, England":"London, Middlesex, England","England":"England, United Kingdom","Barnstaple, Devon, England":"Barnstaple, Devon, England","Torthorwald, Dumfriesshire, Scotland":"Torthorwald, Dumfriesshire, Skotland","Donegal, County Donegal, Ireland":"Donegal, County Donegal, Irland"},"nl":{"1338–1365":"1338–1365","1336–Male":"1336–Overleden","1340–1365":"1340–1365","1360–Male":"1360–Overleden","1362–1410":"1362–1410","1363–Female":"1363–Overleden","1364–Female":"1364–Overleden","1318–1338":"1318–1338","1338":"1338","1336":"1336","1410":"1410","1365":"1365","1364":"1364","1363":"1363","1362":"1362","1340":"1340","1360":"1360","1318":"1318","London, Middlesex, England":"London, Middlesex, England","London, , Middlesex, England":"London, Middlesex, England","England":"Engeland, Verenigd Koninkrijk","Barnstaple, Devon, England":"Barnstaple, Devon, England","Torthorwald, Dumfriesshire, Scotland":"Torthorwald, Dumfriesshire, Schotland","Donegal, County Donegal, Ireland":"Donegal, County Donegal, Ierland"},"en":{"1338–1365":"1338–1365","1336–Male":"1336–Deceased","1340–1365":"1340–1365","1360–Male":"1360–Deceased","1362–1410":"1362–1410","1363–Female":"1363–Deceased","1364–Female":"1364–Deceased","1318–1338":"1318–1338","1338":"1338","1336":"1336","1410":"1410","1365":"1365","1364":"1364","1363":"1363","1362":"1362","1340":"1340","1360":"1360","1318":"1318","London, Middlesex, England":"London, Middlesex, England","London, , Middlesex, England":"London, Middlesex, England","England":"England, United Kingdom","Barnstaple, Devon, England":"Barnstaple, Devon, England","Torthorwald, Dumfriesshire, Scotland":"Torthorwald, Dumfriesshire, Scotland","Donegal, County Donegal, Ireland":"Donegal, County Donegal, Ireland","nameMeanings":[{"name":"Collins","type":"LAST","attribution":"Dictionary of American Family Names © Patrick Hanks 2003, 2006.","meanings":["English: variant of   Colin  , with genitival or post-medieval excrescent <i>-s</i>.","Irish and Manx: shortened Anglicized from <b>Ó Coileáin</b>, compare   Cullen  , or in Man or west Ulster shortened from <b>Mac Coileáin</b>, compare   McQuillan   and   McCallion  . The genitival <i>-s</i> is a local addition to   Collin   and variants after the surname was Anglicized.","Americanized form of French   Colin   or   Collin   and also   Collette  ."],"variants":[{"name":"Colin","meanings":["Some characteristic forenames:  Spanish Jose, Juan, Alfredo, Francisco, Jesus, Ricardo, Alberto, Angel, Arturo, Eduardo, Esteban, Faustino.  French Alexandre, Andre, Armand, Georges, Henri, Jean Claude, Jean-Michel, Laurette, Lucien, Marcel, Patrice, Pierre.","French, Walloon, and Breton: from a French shortened pet form of the personal name   Nicolas   (see   Nicholas  ). This surname is also found in the Flemish part of Belgium.","English: from the personal name <i>Colin</i>, a diminutive of <i>Col</i>, itself a pet form of   Nicholas  ."]},{"name":"Kolenc","meanings":["Slovenian:","topographic name derived from <i>koleno</i> ‘knee’.","nickname from the dialect plant name <i>kolenc</i> ‘yellow bedstraw (Galium verum)’ or ‘common nipplewort (Lapsana communis)’. Compare   Collins   3."]},{"name":"Callins","meanings":["Irish: variant of   Collins  ."]},{"name":"Collings","meanings":["English: variant of   Collins   or   Colling  , with post-medieval excrescent <i>-s</i>."]}]},{"name":"Andrew","type":"FIRST","attribution":"Dictionary of First Names © Patrick Hanks and Flavia Hodges 1990, 2003, 2006.","meanings":["form of the Greek name <i>Andreas</i>, a short form of any of various compound names derived from <i>andr-</i> ‘man, warrior’. In the New Testament this is the name of the first disciple to be called by Jesus. After the Resurrection,  St Andrew  preached in Asia Minor and Greece. He is traditionally believed to have been crucified at Patras in Achaia. He was one of the most popular saints of the Middle Ages and was adopted as the patron of Scotland, Russia, and Greece. It has long been among the most popular boys' names in the English-speaking world, especially in Scotland. Its popularity in England was further enhanced by its use as a British royal name for  Prince Andrew  (  b. 1960 ), the Duke of York."],"variants":[]}],"lifeSummary":"When Andrew Collins was born in 1338, in Torthorwald, Dumfriesshire, Scotland, his father, Ánrothán Cuilliaéan, was 20 and his mother, Ann Cousins, was 20. He married Mary in 1360, in London, Middlesex, England. They were the parents of at least 2 sons and 2 daughters. He died in 1365, in London, Middlesex, England, at the age of 27."},"et":{"1338–1365":"1338–1365","1336–Male":"1336–Surnud","1340–1365":"1340–1365","1360–Male":"1360–Surnud","1362–1410":"1362–1410","1363–Female":"1363–Surnud","1364–Female":"1364–Surnud","1318–1338":"1318–1338","1338":"1338","1336":"1336","1410":"1410","1365":"1365","1364":"1364","1363":"1363","1362":"1362","1340":"1340","1360":"1360","1318":"1318","London, Middlesex, England":"London, Middlesex, England","London, , Middlesex, England":"London, Middlesex, England","England":"Inglismaa, United Kingdom","Barnstaple, Devon, England":"Barnstaple, Devon, England","Torthorwald, Dumfriesshire, Scotland":"Torthorwald, Dumfriesshire, Scotland","Donegal, County Donegal, Ireland":"Donegal, County Donegal, Iirimaa"},"fi":{"1338–1365":"1338–1365","1336–Male":"1336–Kuollut","1340–1365":"1340–1365","1360–Male":"1360–Kuollut","1362–1410":"1362–1410","1363–Female":"1363–Kuollut","1364–Female":"1364–Kuollut","1318–1338":"1318–1338","1338":"1338","1336":"1336","1410":"1410","1365":"1365","1364":"1364","1363":"1363","1362":"1362","1340":"1340","1360":"1360","1318":"1318","London, Middlesex, England":"London, Middlesex, England","London, , Middlesex, England":"London, Middlesex, England","England":"Englanti, Yhdistynyt kuningaskunta","Barnstaple, Devon, England":"Barnstaple, Devon, England","Torthorwald, Dumfriesshire, Scotland":"Torthorwald, Dumf