1521","1550":"1550","1493":"1493","1490":"1490","1525":"1525","1469":"1469","1600":"1600","1521":"1521","1498":"1498","1497":"1497","1619":"1619","1518":"1518","1529":"1529","1527":"1527","1549":"1549","1515":"1515","England":"England","London, England":"London, England","Bishop's Lynn, Norfolk, England":"King's Lynn, Norfolk, England, United Kingdom","Devon, England":"Devon, England"},"nl":{"1490–1550":"1490–1550","1497–Female":"1497–Overleden","1498–Female":"1498–Overleden","1493–Female":"1493–Overleden","1521–1600":"1521–1600","1521–1619":"1521–1619","1525–Male":"1525–Overleden","1527–Male":"1527–Overleden","1529–Female":"1529–Overleden","1469–1518":"1469–1518","–1521":"–1521","1550":"1550","1493":"1493","1490":"1490","1525":"1525","1469":"1469","1600":"1600","1521":"1521","1498":"1498","1497":"1497","1619":"1619","1518":"1518","1529":"1529","1527":"1527","1549":"1549","1515":"1515","England":"England","London, England":"London, England","Bishop's Lynn, Norfolk, England":"King's Lynn, Norfolk, Engeland, Verenigd Koninkrijk","Devon, England":"Devon, England"},"en":{"1490–1550":"1490–1550","1497–Female":"1497–Deceased","1498–Female":"1498–Deceased","1493–Female":"1493–Deceased","1521–1600":"1521–1600","1521–1619":"1521–1619","1525–Male":"1525–Deceased","1527–Male":"1527–Deceased","1529–Female":"1529–Deceased","1469–1518":"1469–1518","–1521":"–1521","1550":"1550","1493":"1493","1490":"1490","1525":"1525","1469":"1469","1600":"1600","1521":"1521","1498":"1498","1497":"1497","1619":"1619","1518":"1518","1529":"1529","1527":"1527","1549":"1549","1515":"1515","England":"England","London, England":"London, England","Bishop's Lynn, Norfolk, England":"King's Lynn, Norfolk, England, United Kingdom","Devon, England":"Devon, England","nameMeanings":[{"name":"Kinne","type":"LAST","attribution":"Dictionary of American Family Names © Patrick Hanks 2003, 2006.","meanings":["German: from the female personal name <i>Kinne</i>, a Silesian pet form of Middle High German <i>Kunigunde</i>, composed of the Old High German elements <i>kuoni</i> ‘brave’ + <i>gund</i> ‘battle’.","Flemish: variant of   Kin   2 and 3."],"variants":[{"name":"Kin","meanings":["Some characteristic forenames:  Korean Sang, Young, Chong, Chun, Hak, Kwang, Song, Tae Wan, Yong, Yung, Aeja, Chin, Chul, Dong Joo, Dongil, Doo, Eng, Hee Chul, Hyeok, Hyung Joon, In-Young, Jong Woo, Min, Moon.","Polish: unexplained.","Dutch and Flemish: nickname for someone with a pointed or jutting chin, from Middle Dutch <i>kinne</i> ‘chin’."]}]},{"name":"Keeny","type":"LAST","attribution":"Dictionary of American Family Names © Patrick Hanks 2003, 2006.","meanings":["Irish: variant of   Keaney  . This surname is rare in Britain."],"variants":[{"name":"Keaney","meanings":["Some characteristic forenames:  Irish Brendan, Kieran.","Irish: Anglicized form of Gaelic <b>Ó Cianaigh</b>, from a personal name based on <i>cianach</i>, a derivative of <i>cian</i> ‘distant, long’, or <b>Ó Caoinnigh</b>, a variant of <b>Ó Coinnigh</b>, see   Kenny  ."]}]},{"name":"Kinney","type":"LAST","attribution":"Dictionary of American Family Names © Patrick Hanks 2003, 2006.","meanings":["Scottish and Irish: from a shortened form of   McKinney  ."],"variants":[{"name":"McKinney","meanings":["Scottish and Irish: Anglicized form of Gaelic <b>Mac Cionaodha</b> or <b>Mac Cionaoith</b> ‘son of <i>ç</i>’, an early Gaelic personal name popular from the ninth century and possibly derived from Pictish.","Irish (northern): Anglicized form of Gaelic <b>Mac Coinnigh</b> ‘son of <i>Coinneach</i>’, an Old Irish personal name, borne by a Christian saint and Anglicized in Ireland as <i>Canice</i>, which was treated in Scotland as equivalent to   Kenneth  . This surname was usually Anglicized in Scotland as   McKenzie  , but is otherwise hard to distinguish from sense 1 above."]},{"name":"Kinnee","meanings":["Scottish: variant of   Kinney  ."]}]},{"name":"Richard","type":"FIRST","attribution":"Dictionary of First Names © Patrick Hanks and Flavia Hodges 1990, 2003, 2006.","meanings":["One of the most enduringly successful of the Old French personal names introduced into Britain by the Normans. It is of Germanic (Frankish) origin, derived from <i>rīc</i> ‘power’ + <i>hard</i> ‘strong, hardy’. It has enjoyed continuous popularity in England from the Conquest to the present day, influenced by the fact that it was borne by three kings of England, in particular  Richard I  (  1157–99 ). He was king for only ten years (  1189–99 ), most of which he spent in warfare abroad, taking part in the Third Crusade and costing the people of England considerable sums in taxes. Nevertheless, he achieved the status of a folk hero, and was never in England long enough to disappoint popular faith in his goodness and justice. He was also Duke of Aquitaine and Normandy and Count of Anjou, fiefs which he held at a time of maximum English expansion in France. His exploits as a leader of the Third Crusade earned him the nickname ‘Coeur de Lion’ or ‘Lionheart’ and a permanent place in popular imagination, in which he was even more firmly enshrined by  Sir Walter Scott's  novel Ivanhoe (  1820 )."],"variants":[{"name":"Rikert","meanings":["One of the most enduringly successful of the Old French personal names introduced into Britain by the Normans. It is of Germanic (Frankish) origin, derived from <i>rīc</i> ‘power’ + <i>hard</i> ‘strong, hardy’. It has enjoyed continuous popularity in England from the Conquest to the present day, influenced by the fact that it was borne by three kings of England, in particular  Richard I  (  1157–99 ). He was king for only ten years (  1189–99 ), most of which he spent in warfare abroad, taking part in the Third Crusade and costing the people of England considerable sums in taxes. Nevertheless, he achieved the status of a folk hero, and was never in England long enough to disappoint popular faith in his goodness and justice. He was also Duke of Aquitaine and Normandy and Count of Anjou, fiefs which he held at a time of maximum English expansion in France. His exploits as a leader of the Third Crusade earned him the nickname ‘Coeur de Lion’ or ‘Lionheart’ and a permanent place in popular imagination, in which he was even more firmly enshrined by  Sir Walter Scott's  novel Ivanhoe (  1820 )."]},{"name":"Rickert","meanings":["One of the most enduringly successful of the Old French personal names introduced into Britain by the Normans. It is of Germanic (Frankish) origin, derived from <i>rīc</i> ‘power’ + <i>hard</i> ‘strong, hardy’. It has enjoyed continuous popularity in England from the Conquest to the present day, influenced by the fact that it was borne by three kings of England, in particular  Richard I  (  1157–99 ). He was king for only ten years (  1189–99 ), most of which he spent in warfare abroad, taking part in the Third Crusade and costing the people of England considerable sums in taxes. Nevertheless, he achieved the status of a folk hero, and was never in England long enough to disappoint popular faith in his goodness and justice. He was also Duke of Aquitaine and Normandy and Count of Anjou, fiefs which he held at a time of maximum English expansion in France. His exploits as a leader of the Third Crusade earned him the nickname ‘Coeur de Lion’ or ‘Lionheart’ and a permanent place in popular imagination, in which he was even more firmly enshrined by  Sir Walter Scott's  novel Ivanhoe (  1820 )."]}]}],"historicEvents":[{"id":1705201,"age":59,"year":"1549","julianDay":2286821,"title":"Book of Common Prayer","description":"Book of Common Prayer, a product of the English Reformation, was published in 1549 for assistance in the administration of the sacraments and other rites and ceremonies of the church according to the use of the Church of England. The book outlined morning, evening, and communion prayers and orders for baptism and marriage, thus making England a truly Protestant state.","url":"https://en.wikipedia.org/wiki/Book_of_Common_Praye