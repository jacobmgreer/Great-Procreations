1205":"1205","1215":"1215","1224":"1224","1157":"1157","1233":"1233","1155":"1155","about 1157":"circa 1157","about 1179":"circa 1179","1219":"1219","Wakerley, Northamptonshire, England":"Wakerley, Northamptonshire, England","Great Bromley, Essex, England":"Great Bromley, Essex, England","Buckland, Hertfordshire, England":"Buckland, Hertfordshire, England","Wakerley, Northamptonshire, England, United Kingdom":"Wakerley, Northamptonshire, Engeland, Verenigd Koninkrijk"},"en":{"about 1157–19 July 1233":"about 1157–19 July 1233","1155–1205":"1155–1205","1180–1217":"1180–1217","1190–1219":"1190–1219","1157–1233":"1157–1233","1190":"1190","18 May 1205":"18 May 1205","1180":"1180","1217":"1217","19 July 1233":"19 July 1233","1205":"1205","1215":"1215","1224":"1224","1157":"1157","1233":"1233","1155":"1155","about 1157":"about 1157","about 1179":"about 1179","1219":"1219","Wakerley, Northamptonshire, England":"Wakerley, Northamptonshire, England","Great Bromley, Essex, England":"Great Bromley, Essex, England","Buckland, Hertfordshire, England":"Buckland, Hertfordshire, England","Wakerley, Northamptonshire, England, United Kingdom":"Wakerley, Northamptonshire, England, United Kingdom","nameMeanings":[{"name":"Bocland","type":"LAST","attribution":"Dictionary of American Family Names © Patrick Hanks 2003, 2006.","meanings":["Some characteristic forenames:  German Ernst, Frieda, Jurgen.","Irish: variant of   Boland   2.","English: habitational name from Bulland or Bolland, in the parish of Parkham (Devon), or from an unidentified site (perhaps in Essex) similarly named, all of which probably have the original sense ‘bull's land’."],"variants":[{"name":"Boland","meanings":["Some characteristic forenames:  Irish Brendan, Aidan, Bridie, Caitlin, Donal, Finbar, Maeve.","English: habitational name from the district of Bowland (Forest) in North Yorkshire and Lancashire. Robert <i>of Bowland</i> was a member of the garrison of Stirling castle in Scotland in 1339–40, and was presumably a Yorkshireman or a Lancastrian.","Irish: Anglicized form of Gaelic <b>Ó Beólláin</b> ‘descendant of <i>Beóllán</i>’, an old Irish name of uncertain origin. See   Bolan   1."]},{"name":"Bowlan","meanings":["English: variant of   Bolland  . This form of the surname is now more common in the US than in Britain or Ireland.","Irish: possibly an Anglicized form of Gaelic <b>Ó Beólláin</b> ‘descendant of <i>Bjolan</i>’, a Norse personal name."]}]},{"name":"Hawise","type":"FIRST","meanings":["This female name (which has been corrupted down to Avice and Avis) is from Hadewisa, formed from the German name Hedvig, same as Edwig, which Wachter translates 'propugnator felicitatis;' say, 'fortunate soldier.'"],"variants":[]}],"historicEvents":[{"id":1705187,"age":58,"year":"1215","julianDay":2164830,"title":"Magna Carta","description":"King John of England agreed to a charter of rights called the Magna Carta. The document was originally drafted by the Archbishop of Canterbury to establish peace between King John and a group of rebel barons. The Magna Carta was completed in 1215 and is now considered to be one of the greatest constitutional documents of all time.","url":"https://www.nationalarchives.gov.uk/education/medieval/magna-carta/","urlTitle":"National Archives - Magna Carta","jurisdictionLevel":2},{"id":1705188,"age":67,"year":"1224","julianDay":2168117,"title":"France Declares War on England","description":"France declared war on England as Louis VIII of France attacked Poitou and northern Gascony.","jurisdictionLevel":2}],"lifeSummary":"Hawise Bocland was born about 1157, in Buckland, Hertfordshire, England. She married William de Lanvallei II about 1179, in Wakerley, Northamptonshire, England. They were the parents of at least 1 son and 1 daughter. She died on 19 July 1233, in Great Bromley, Essex, England, at the age of 77."},"et":{"about 1157–19 July 1233":"umbes 1157–19. juuli 1233","1155–1205":"1155–1205","1180–1217":"1180–1217","1190–1219":"1190–1219","1157–1233