gs":[{"name":"Copley","type":"LAST","attribution":"Dictionary of American Family Names © Patrick Hanks 2003, 2006.","meanings":["English (Yorkshire): habitational name from any of various places called Copley, for example in County Durham, Staffordshire, and Yorkshire, from the Old English personal name <i>Coppa</i> (apparently a byname for a tall man) or from <i>copp</i> ‘hilltop’ + <i>lēah</i> ‘woodland clearing’."],"variants":[]},{"name":"Robert","type":"FIRST","attribution":"Dictionary of First Names © Patrick Hanks and Flavia Hodges 1990, 2003, 2006.","meanings":["One of the many French names of Germanic origin that were introduced into Britain by the Normans; it has since remained in continuous use. It is derived from the nearly synonymous elements <i>hrōd</i> ‘fame’ + <i>berht</i> ‘bright, famous’, and had a native Old English predecessor of similar form (<i>Hreodbeorht</i>), which was supplanted by the Norman name. Two dukes of Normandy in the 11th century bore the name: the father of  William the Conqueror  (sometimes identified with the legendary Robert the Devil), and his eldest son. It was borne also by three kings of Scotland, notably  Robert the Bruce  (  1274–1329 ), who freed Scotland from English domination. The altered short form <i>Bob</i> is very common, but <i>Hob</i> and <i>Dob</i>, which were common in the Middle Ages and gave rise to surnames, are extinct.  See also  Rupert ."],"variants":[]}],"historicEvents":[{"id":1705189,"age":9,"year":"1259","julianDay":2180901,"title":"100 Years of Conflict Between England and France Ends","description":"Treaty of Paris was signed on December 4, 1259, which ended 100 years of conflict between England and France.","url":"https://en.wikipedia.org/wiki/Treaty_of_Paris_(1259)","urlTitle":"Wikipedia - Treaty of Paris 1259","jurisdictionLevel":1},{"id":1705190,"age":40,"year":"1290","julianDay":2192224,"title":"Jews Expelled From England","description":"After years of anti-Semitic behavior, King Edward I expelled Jews from England in 1290.","jurisdictionLevel":1}],"lifeSummary":"Robert Copley was born about 1250, in Yorkshire, England as the son of Thomas Copley and wife of Copley. He married Maud Batley before 1280. They were the parents of at least 3 sons. He died before 1303."},"et":{"circa 1250–vóór 1303":"umbes 1250–enne 1303","1250–1303":"1250–1303","–Male":"Surnud","1250–Female":"1250–Surnud","–Female":"Surnud","1280–Male":"1280–Surnud","–1346":"–1346","1270–1317":"1270–1317","1225–1304":"1225–1304","circa 1280":"umbes 1280","1250":"1250","1270":"1270","1280":"1280","1290":"1290","1304":"1304","1259":"1259","1303":"1303","1225":"1225","1346":"1346","circa 1250":"umbes 1250","circa 1270":"umbes 1270","before 1250":"enne 1250","before 1280":"enne 1280","vóór 1303":"enne 1303","1317":"1317","Yorkshire, England":"Yorkshire, England","Halifax, Yorkshire, England":"Halifax, Yorkshire, England"},"fi":{"circa 1250–vóór 1303":"noin 1250–ennen vuotta 1303","1250–1303":"1250–1303","–Male":"Kuollut","1250–Female":"1250–Kuollut","–Female":"Kuollut","1280–Male":"1280–Kuollut","–1346":"–1346","1270–1317":"1270–1317","1225–1304":"1225–1304","circa 1280":"noin 1280","1250":"1250","1270":"1270","1280":"1280","1290":"1290","1304":"1304","1259":"1259","1303":"1303","1225":"1225","1346":"1346","circa 1250":"noin 1250","circa 1270":"noin 1270","before 1250":"ennen vuotta 1250","before 1280":"ennen vuotta 1280","vóór 1303":"ennen vuotta 1303","1317":"1317","Yorkshire, England":"Yorkshire, England","Halifax, Yorkshire, England":"Halifax, Yorkshire, England"},"fr":{"circa 1250–vóór 1303":"environ 1250–avant 1303","1250–1303":"1250–1303","–Male":"Décédé","1250–Female":"1250–Décédée","–Female":"Décédée","1280–Male":"1280–Décédé","–1346":"–1346","1270–1317":"1270–1317","1225–1304":"1225–1304","circa 1280":"environ 1280","1250":"1250","1270":"1270","1280":"1280","1290":"1290","1304":"1304","1259":"1259","1303":"1303","1225":"1225","1346":"1346","circa 1250":"environ 1250","circa 1270":"envir