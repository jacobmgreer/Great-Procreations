ustria-Hungary":"Østrig","Withyford, Shropshire, England":"Shropshire, England","Apley, Shropshire, England":"Shropshire, England","Apley Castle, Shropshire, England":"Castle-Pulverbatch, Shropshire, England"},"nl":{"2 Feb 1296–9 July 1328":"2 februari 1296–9 juli 1328","1296–1328":"1296–1328","1293–Female":"1293–Overleden","1314–1349":"1314–1349","1263–1313":"1263–1313","1265–1316":"1265–1316","9 July 1328":"9 juli 1328","1263":"1263","1296":"1296","1284":"1284","2 Feb 1296":"2 februari 1296","1293":"1293","4 April 1314":"4 april 1314","1316":"1316","1349":"1349","1314":"1314","1313":"1313","1321":"1321","1265":"1265","1328":"1328","Albrighton, Shropshire, England":"Albrighton, Shropshire, Engeland, Verenigd Koninkrijk","Shropshire, England":"Shropshire, Engeland, Verenigd Koninkrijk","Austria-Hungary":"Oostenrijk","Withyford, Shropshire, England":"Shropshire, England","Apley, Shropshire, England":"Shropshire, England","Apley Castle, Shropshire, England":"Castle-Pulverbatch, Shropshire, England"},"en":{"2 Feb 1296–9 July 1328":"2 February 1296–9 July 1328","1296–1328":"1296–1328","1293–Female":"1293–Deceased","1314–1349":"1314–1349","1263–1313":"1263–1313","1265–1316":"1265–1316","9 July 1328":"9 July 1328","1263":"1263","1296":"1296","1284":"1284","2 Feb 1296":"2 February 1296","1293":"1293","4 April 1314":"4 April 1314","1316":"1316","1349":"1349","1314":"1314","1313":"1313","1321":"1321","1265":"1265","1328":"1328","Albrighton, Shropshire, England":"Albrighton, Shropshire, England, United Kingdom","Shropshire, England":"Shropshire, England, United Kingdom","Austria-Hungary":"Austria","Withyford, Shropshire, England":"Shropshire, England","Apley, Shropshire, England":"Shropshire, England","Apley Castle, Shropshire, England":"Castle-Pulverbatch, Shropshire, England","nameMeanings":[{"name":"Aer","type":"LAST","attribution":"Dictionary of American Family Names © Patrick Hanks 2003, 2006.","meanings":["Flemish, Dutch, and German (Lower Saxony): from the personal name <i>Aper</i>, a variant of   Albert  ."],"variants":[{"name":"Albert","meanings":["Some characteristic forenames:  French Camille, Fernand, Lucien, Marcel, Normand, Cecile, Adrien, Armand, Henri, Jacques, Alban, Andre.","French, English, German, Catalan, Hungarian, Romanian, Dutch, Slovak, Czech, Croatian, Slovenian, West Indian (mainly Haiti), and Mauritian: from the personal name <i>Albert</i>, composed of the ancient Germanic elements <i>adal</i> ‘noble’ + <i>berht</i> ‘bright, famous’. The standard German form is   Albrecht  . The name was borne by several Christian saints, notably Saint Albert of Prague, a Bohemian prince who died a martyr in 997 attempting to convert the Prussians to Christianity, and Saint Albert the Great (<i>c.</i> 1193–1280), an Aristotelian theologian and tutor of Thomas Aquinas. In more recent times it has been adopted as a Jewish surname."]}]},{"name":"Thomas","type":"FIRST","attribution":"Dictionary of First Names © Patrick Hanks and Flavia Hodges 1990, 2003, 2006.","meanings":["New Testament name, borne by one of Christ's twelve apostles, referred to as ‘Thomas, called Didymus’ (John 11:16; 20:24). <i>Didymos</i> is the Greek word for ‘twin’, and the name is the Greek form of an Aramaic byname meaning ‘twin’. The given name has always been popular throughout Christendom, in part because St Thomas's doubts have made him seem a very human character."],"variants":[]},{"name":"Fitz","type":"FIRST","attribution":"Dictionary of First Names © Patrick Hanks and Flavia Hodges 1990, 2003, 2006.","meanings":["Either a short form of any of the numerous names representing a transferred use of a surname formed with the Anglo-Norman French prefix <i>fi(t)z</i> ‘son of ’, as for example   Fitzgerald  ,   Fitzroy  , or a transferred use of the surname <i>Fitz</i>, which may be of the same derivation, but applied originally to distinguish a son from a father bearing the same given name, or a local name from Fitz in Shropshire, named with the Old English personal name <i>Fitt</i> + <i>hōh</i> ‘hill spur’."],"variants":[]}],"lifeSummary":"When Thomas Fitz Aer was born on 2 February 1296, in Albrighton, Shropshire, England, United Kingdom, his father, HUGH FITZ AER, was 33 and his mother, ALINA OLIVA MOULTON, was 31. He married Ayeris de Whitiford in 1321, in Shropshire, England. They were the parents of at least 1 daughter. He died on 9 July 1328, in Shropshire, England, United Kingdom, at the age of 32."},"et":{"2 Feb 1296–9 July 1328":"2. veebruar 1296–9. juuli 1328","1296–1328":"1296–1328","1293–Female":"1293–Surnud","1314–1349":"1314–1349","1263–1313":"1263–1313","1265–1316":"1265–1316","9 July 1328":"9. juuli 1328","1263":"1263","1296":"1296","1284":"1284","2 Feb 1296":"2. veebruar 1296","1293":"1293","4 April 1314":"4. aprill 1314","1316":"1316","1349":"1349","1314":"1314","1313":"1313","1321":"1321","1265":"1265","1328":"1328","Albrighton, Shropshire, England":"Albrighton, Shropshire, Inglismaa, United Kingdom","Shropshire, England":"Shropshire, Inglismaa, United Kingdom","Austria-Hungary":"Austria","Withyford, Shropshire, England":"Shropshire, England","Apley, Shropshire, England":"Shropshire, England","Apley Castle, Shropshire, England":"Castle-Pulverbatch, Shropshire, England"},"fi":{"2 Feb 1296–9 July 1328":"2. helmikuuta 1296–9. heinäkuuta 1328","1296–1328":"1296–1328","1293–Female":"1293–Kuollut","1314–1349":"1314–1349","1263–1313":"1263–1313","1265–1316":"1265–1316","9 July 1328":"9. heinäkuuta 1328","1263":"1263","1296":"1296","1284":"1284","2 Feb 1296":"2. helmikuuta 1296","1293":"1293","4 April 1314":"4. huhtikuuta 1314","1316":"1316","1349":"1349","1314":"1314","1313":"1313","1321":"1321","1265":"1265","1328":"1328","Albrighton, Shropshire, England":"Albrighton, Shropshire, Englanti, Yhdistynyt kuningaskunta","Shropshire, England":"Shropshire, Englanti, Yhdistynyt kuningaskunta","Austria-Hungary":"Itävalta","Withyford, Shropshire, England":"Shropshire, England","Apley, Shropshire, England":"Shrop