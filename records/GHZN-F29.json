riants":[]}],"lifeSummary":"When Dorothea Apulderfield was born in 1240, in County Westmeath, Ireland, her father, Richard Tuitt, was 41 and her mother, Lady Richard Tuitt, was 35. She married Nicholas Carew II in 1263, in Carew, Pembrokeshire, Wales, United Kingdom. They were the parents of at least 1 son. She died on 16 August 1286, in Pembrokeshire, Wales, United Kingdom, at the age of 46."},"et":{"1240–16 August 1286":"1240–16. august 1286","1240–1286":"1240–1286","1240–1297":"1240–1297","1265–1311":"1265–1311","1199–1269":"1199–1269","1205–Female":"1205–Surnud","1205":"1205","1269":"1269","1311":"1311","1199":"1199","1265":"1265","1297":"1297","1286":"1286","1263":"1263","16 August 1286":"16. august 1286","1240":"1240","about 1265":"umbes 1265","Marsta, Westmeath, Ireland":"County Westmeath, Iirimaa","Moulsford, Berkshire, England":"Moulsford, Berkshire, England","Diocese of Meath, Leinster, Ireland":"Diocese of Meath, Iirimaa","Pembrokeshire, Wales, United Kingdom":"Pembrokeshire, Wales, United Kingdom","Carew, Pembrokeshire, Wales":"Carew, Pembrokeshire, Wales, United Kingdom"},"fi":{"1240–16 August 1286":"1240–16. elokuuta 1286","1240–1286":"1240–1286","1240–1297":"1240–1297","1265–1311":"1265–1311","1199–1269":"1199–1269","1205–Female":"1205–Kuollut","1205":"1205","1269":"1269","1311":"1311","1199":"1199","1265":"1265","1297":"1297","1286":"1286","1263":"1263","16 August 1286":"16. elokuuta 1286","1240":"1240","about 1265":"noin 1265","Marsta, Westmeath, Ireland":"County Westmeath, Irlanti","Moulsford, Berkshire, England":"Moulsford, Berkshire, England","Diocese of Meath, Leinster, Ireland":"Diocese of Meath, Irlanti","Pembrokeshire, Wales, United Kingdom":"Pembrokeshire, Wales, Yhdistynyt kuningaskunta","Carew, Pembrokeshire, Wales":"Carew, Pembrokeshire, Wales, Yhdistynyt kuningaskunta"},"fr":{"1240–16 August 1286":"1240–16 août 1286","1240–1286":"1240–1286","1240–1297":"1240–1297","1265–1311":"1265–1311","1199–1269":"1199–1269","1205–Female":"1205–Décédé