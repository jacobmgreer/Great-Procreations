land"},"en":{"–":"Deceased","1210–Male":"1210–Deceased","1240–Male":"1240–Deceased","–Female":"Deceased","1210":"1210","abt 1240":"about 1240","1240":"1240","Netherwitton, Northumberlandshire, England":"Netherwitton, Northumberland, England","nameMeanings":[{"name":"Margereta","type":"FIRST","attribution":"Dictionary of First Names © Patrick Hanks and Flavia Hodges 1990, 2003, 2006.","meanings":["From the Latin form of Greek <i>Margarītēs</i>.  See  <b>Margaret</b>   ."],"variants":[{"name":"Margaret","meanings":["An extremely common given name from the Middle Ages onwards, derived via Old French <i>Marguerite</i> and Latin <i>Margarita</i> from Greek <i>Margarītēs</i>, from <i>margaron</i> ‘pearl’, a word ultimately of Hebrew origin. The name was always understood to mean ‘pearl’ throughout the Middle Ages. The first  St Margaret  was martyred at Antioch in Pisidia during the persecution instigated by the  Emperor Diocletian  in the early 4th century. However, there is some doubt about her name, as the same saint is venerated in the Orthodox Church as   Marina .  There were several other saintly bearers of the name, including St Margaret of Scotland (  d. 1093 ), wife of  King Malcolm Canmore  and daughter of Edmund Ironside of England. It was also the name of the wife of  Henry VI  of England,  Margaret of Anjou  (  1430–82 ), and of  Margaret Tudor  (  1489–1541 ), sister of  Henry VIII , who married James IV of Scotland and ruled as regent there after his death.  See also  Margery  ,   Marjorie ."]},{"name":"Margarete","meanings":["from Greek.  See  <b>Margaret</b>   ."]},{"name":"Margrethe","meanings":["An extremely common given name from the Middle Ages onwards, derived via Old French <i>Marguerite</i> and Latin <i>Margarita</i> from Greek <i>Margarītēs</i>, from <i>margaron</i> ‘pearl’, a word ultimately of Hebrew origin. The name was always understood to mean ‘pearl’ throughout the Middle Ages. The first  St Margaret  was martyred at Antioch in Pisidia during the persecution instigated by the  Emperor Diocletian  in the early 4th century. However, there is some doubt about her name, as the same saint is venerated in the Orthodox Church as   Marina .  There were several other saintly bearers of the name, including St Margaret of Scotland (  d. 1093 ), wife of  King Malcolm Canmore  and daughter of Edmund Ironside of England. It was also the name of the wife of  Henry VI  of England,  Margaret of Anjou  (  1430–82 ), and of  Margaret Tudor  (  1489–1541 ), sister of  Henry VIII , who married James IV of Scotland and ruled as regent there after his death.  See also  Margery  ,   Marjorie ."]},{"name":"Margaretha","meanings":["from Greek.  See  <b>Margaret</b>   ."]}]}],"lifeSummary":"Margereta Redeware had at least 1 son with Thomas Redeware."},"et":{"–":"Surnud","1210–Male":"1210–Surnud","1240–Male":"1240–Surnud","–Female":"Surnud","1210":"1210","abt 1240":"umbes 1240","1240":"1240","Netherwitton, Northumberlandshire, England":"Netherwitton, Northumberland, England"},"fi":{"–":"Kuollut","1210–Male":"1210–Kuollut","1240–Male":"1240–Kuollut","–Female":"Kuollut","1210":"1210","abt 1240":"noin 1240","1240":"1240","Netherwitton, Northumberlandshire, England":"Netherwitton, Northumberland, England"},"fr":{"–":"Décédée","1210–Male":"1210–Décédé","1240–Male":"1240–Décédé","–Female":"Décédée","1210":"1210","abt 1240":"environ 1240","1240":"1240","Netherwitton, Northumberlandshire, England":"Netherwitton, Northumberland, Angleterre","lifeSummary":"Margereta Redeware a eu au moins 1 fils avec Thomas Redeware."},"de":{"–":"Verstorben","1210–Male":"1210–Verstorben","1240–Male":"1240–Verstorben","–Female":"Verstorben","1210":"1210","abt 1240":"um 1240","1240":"1240","Netherwitton, Northumberlandshire, England":"Netherwitton, Northumberland, England","lifeSummary":"Margereta Redeware hatte mit Thomas Redeware mindestens 1 Sohn."},"ht":{"–":"Desede","1210–Male":"1210–Desede","1240–Male":"1240–Desede","–Female":"Desede","1210":"1210","ab