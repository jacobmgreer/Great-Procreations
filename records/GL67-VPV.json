18–Female":"1118–Overleden","1118":"1118","1215":"1215","about 1118":"circa 1118","1224":"1224","1232":"1232","1122":"1122","1142":"1142","Greystoke, Cumberland, England":"Greystoke, Cumberland, England","Fonthill Gifford, Salisbury, Wiltshire, England, United Kingdom":"Salisbury, Wiltshire, England"},"en":{"about 1118–":"about 1118–Deceased","1122–1232":"1122–1232","1142–Female":"1142–Deceased","1118–Female":"1118–Deceased","1118":"1118","1215":"1215","about 1118":"about 1118","1224":"1224","1232":"1232","1122":"1122","1142":"1142","Greystoke, Cumberland, England":"Greystoke, Cumberland, England","Fonthill Gifford, Salisbury, Wiltshire, England, United Kingdom":"Salisbury, Wiltshire, England","nameMeanings":[{"name":"Greystoke","type":"LAST","attribution":"Dictionary of Family Names in Britain and Ireland © University of the West of England 2016","meanings":["English:  see  Graystock  ."],"variants":[{"name":"Graystock","meanings":["English: locative name, from Greystoke (Cumb), recorded as  <i>Graystock</i> in 1291."]}]},{"name":"Alice","type":"FIRST","attribution":"Dictionary of First Names © Patrick Hanks and Flavia Hodges 1990, 2003, 2006.","meanings":["Originally a variant of   Adelaide  , representing an Old French spelling of a reduced form of Germanic <i>Adalheidis</i>. <i>Alice</i> and <i>Adelaide</i> were already regarded as distinct names in English during the medieval period. <i>Alice</i> enjoyed a surge of popularity in the 19th century and periods of favour ever since. It was the name of the central character of  Lewis Carroll's  Alice's Adventures in Wonderland (  1865 ) and Through the Looking Glass (  1872 ), who was based on his child friend  Alice Liddell , daughter of the Dean of Christ Church, Oxford."],"variants":[{"name":"Alys","meanings":["Variant spelling of   Alice ."]},{"name":"Alis","meanings":["equivalent of <b>Alice</b> ."]}]},{"name":"FitzHugh","type":"LAST","attribution":"Dictionary of American Family Names © Patrick Hanks 2003, 2006.","meanings":["English (Northamptonshire): from Anglo-Norman French <i>fi(t)z</i> ‘son’ (see   Fitz  ) + the personal name <i>Hugh</i> (see   Hugh  ), ‘son of <i>Hugh</i>’.","History: William Fitzhugh (1651–1701), from Bedford, England, emigrated to VA <i>c.</i> 1670 and established himself on the Potomac River in what was then Stafford County, VA, as a planter and exporter. He also practiced law, was a member of the Virginia House of Burgesses, and served in 1687 as lieutenant colonel of the county militia."],"variants":[{"name":"Fitz","meanings":["Either a short form of any of the numerous names representing a transferred use of a surname formed with the Anglo-Norman French prefix <i>fi(t)z</i> ‘son of ’, as for example   Fitzgerald  ,   Fitzroy  , or a transferred use of the surname <i>Fitz</i>, which may be of the same derivation, but applied originally to distinguish a son from a father bearing the same given name, or a local name from Fitz in Shropshire, named with the Old English personal name <i>Fitt</i> + <i>hōh</i> ‘hill spur’."]}]},{"name":"of","type":"FIRST","attribution":"Dictionary of First Names © Patrick Hanks and Flavia Hodges 1990, 2003, 2006.","meanings":["Short form of   Oswald   or any of the various other names beginning with <i>Os-</i>."],"variants":[]}],"historicEvents":[{"id":1705187,"age":97,"year":"1215","julianDay":2164830,"title":"Magna Carta","description":"King John of England agreed to a charter of rights called the Magna Carta. The document was originally drafted by the Archbishop of Canterbury to establish peace between King John and a group of rebel barons. The Magna Carta was completed in 1215 and is now considered to be one of the greatest constitutional documents of all time.","url":"https://www.nationalarchives.gov.uk/education/medieval/magna-carta/","urlTitle":"National Archives - Magna Carta","jurisdictionLevel":2},{"id":1705188,"age":106,"year":"1224","julianDay":2168117,"title":"France Declares War on England","description":"France declared war on England as Louis VIII of France attacked Poitou and northern Gascony.","jurisdictionLevel":2}],"lifeSummary":"Alice FitzHugh of Greystoke was born about 1118, in Greystoke, Cumberland, England. She had at least 1 daughter with Richard Giffard."},"et":{"about 1118–":"umbes 1118–Surnud","1122–1232":"1122–1232","1142–Female":"1142–Surnud","1118–Female":"1118–Surnud","1118":"1118","1215":"1215","about 1118":"umbes 1118","1224":"1224","1232":"1232","1122":"1122","1142":"1142","Greystoke, Cumberland, England":"Greystoke, Cumberland, England","Fonthill Gifford, Salisbury, Wiltshire, England, United Kingdom":"Salisbury, Wiltshire, England"},"fi":{"about 1118–":"noin 1118–Kuollut","1122–1232":"1122–1232","1142–Female":"1142–Kuollut","1118–Female":"1118–Kuollut","1118":"1118","1215":"1215","about 1118":"noin 1118","1224":"1224","1232":"1232","1122":"1122","1142":"1142","Greystoke, Cumberland, England":"Greystoke, Cumberland, England","Fonthill Gifford, Salisbury, Wiltshire, England, United Kingdom":"Salisbury, Wiltshire, England"},"fr":{"about 1118–":"environ 1118–Décédée","1122–1232":"1122–1232","1142–Female":"1142–Décédée","1118–Female":"1118–Décédée","1118":"1118","1215":"1215","about 1118":"environ 1118","1224":"1224","1232":"1232","1122":"1122","1142":"1142","Greystoke, Cumberland, England":"Greystoke, Cumberland, Angleterre","Fonthill Gifford, Salisbury, Wiltshire, England, United Kingdom":"Salisbury, Wiltshire, Angleterre","lifeSummary":"Alice FitzHugh of Greystoke est née environ 1118, à Greystoke, Cumberland, Angleterre. Elle a eu au moins 1 fille avec Richard Giffard."},"de":{"about 1118–":"um 1118–Verstorben","1122–1232":"1122–1232","1142–Female":"1142–Verstorben","1118–Female":"1118–Verstorben","1118":"1118","1215":"1215","about 1118":"um 1118","1224":"1224","1232":"1232","1122":"1122","1142":"1142","Greystoke, Cumberland, England":"Greystoke, Cumberland, England","Fonthill Gifford, Salisbury, Wiltshire, England, United Kingdom":"Salisbur