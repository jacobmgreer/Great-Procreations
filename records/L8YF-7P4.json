y 1184–":"8. januar 1184–Afdød","1184–Female":"1184–Afdød","1298–1349":"1298–1349","1328–1380":"1328–1380","1270–Male":"1270–Afdød","1240–Female":"1240–Afdød","1240":"1240","1184":"1184","1270":"1270","1380":"1380","before 1328":"før 1328","1290":"1290","1349":"1349","8 January 1184":"8. januar 1184","1259":"1259","1215":"1215","1224":"1224","1298":"1298","1328":"1328","England":"England","Devon, England":"Devon, England","Compton, Devon, England":"Compton, Devon, England"},"nl":{"8 January 1184–":"8 januari 1184–Overleden","1184–Female":"1184–Overleden","1298–1349":"1298–1349","1328–1380":"1328–1380","1270–Male":"1270–Overleden","1240–Female":"1240–Overleden","1240":"1240","1184":"1184","1270":"1270","1380":"1380","before 1328":"vóór 1328","1290":"1290","1349":"1349","8 January 1184":"8 januari 1184","1259":"1259","1215":"1215","1224":"1224","1298":"1298","1328":"1328","England":"England","Devon, England":"Devon, England","Compton, Devon, England":"Compton, Devon, England"},"en":{"8 January 1184–":"8 January 1184–Deceased","1184–Female":"1184–Deceased","1298–1349":"1298–1349","1328–1380":"1328–1380","1270–Male":"1270–Deceased","1240–Female":"1240–Deceased","1240":"1240","1184":"1184","1270":"1270","1380":"1380","before 1328":"before 1328","1290":"1290","1349":"1349","8 January 1184":"8 January 1184","1259":"1259","1215":"1215","1224":"1224","1298":"1298","1328":"1328","England":"England","Devon, England":"Devon, England","Compton, Devon, England":"Compton, Devon, England","nameMeanings":[{"name":"Compton","type":"LAST","attribution":"Dictionary of American Family Names © Patrick Hanks 2003, 2006.","meanings":["English: habitational name from any of numerous places throughout England (but especially in the southwest) named Compton, from Old English <i>cumb</i> ‘short, straight valley’ + <i>tūn</i> ‘enclosure, settlement’."],"variants":[{"name":"Cumpton","meanings":["English (Herefordshire and Worcestershire): variant of   Compton  ."]}]},{"name":"Joan","type":"FIRST","attribution":"Dictionary of First Names © Patrick Hanks and Flavia Hodges 1990, 2003, 2006.","meanings":["Contracted form of Old French <i>Jo(h)anne</i>, from Latin <i>Io(h)anna</i> (  see  Joanna  ). In England this was the usual feminine form of   John   from the Middle English period onwards and was extremely popular, but in the 16th and 17th centuries it steadily lost ground to   Jane .  It was strongly revived in the first part of the 20th century, partly under the influence of  George Bernard Shaw's  play St Joan (  1923 ), based on the life of  Joan of Arc  (  1412–31 ). Claiming to be guided by the voices of the saints, she persuaded the French dauphin to defy the occupying English forces and have himself crowned, and she led the French army that raised the siege of Orleans in  1429 . The following year she was captured by the Burgundians and sold to the English, and a year later she was burned at the stake for witchcraft at the age of 18 or 19. Her story has captured the imagination of many writers, and she is variously portrayed as a national and political hero, a model of apolitical straightforwardness and honesty, and a religious heroine. She was canonized in  1920 . More recent influences have included the American film actress  Joan Crawford  (  1908–77 , born  Lucille le Sueur ), the British actress  Joan Collins  (  b. 1933 ), the American comedienne  Joan Rivers  (  b. 1933 ), and the West Indian pop singer  Joan Armatrading  (  b. 1950 )."],"variants":[{"name":"John","meanings":["Contracted form of Old French <i>Jo(h)anne</i>, from Latin <i>Io(h)anna</i> (  see  Joanna  ). In England this was the usual feminine form of   John   from the Middle English period onwards and was extremely popular, but in the 16th and 17th centuries it steadily lost ground to   Jane .  It was strongly revived in the first part of the 20th century, partly under the influence of  George Bernard Shaw's  play St Joan (  1923 ), based on the life of  Joan of Arc  (  1412–31 ). Claiming to be guided by the voices of the saints, she persuaded the French dauphin to defy the occupying English forces and have himself crowned, and she led the French army that raised the siege of Orleans in  1429 . The following year she was captured by the Burgundians and sold to the English, and a year later she was burned at the stake for witchcraft at the age of 18 or 19. Her story has captured the imagination of many writers, and she is variously portrayed as a national and political hero, a model of apolitical straightforwardness and honesty, and a religious heroine. She was canonized in  1920 . More recent influences have included the American film actress  Joan Crawford  (  1908–77 , born  Lucille le Sueur ), the British actress  Joan Collins  (  b. 1933 ), the American comedienne  Joan Rivers  (  b. 1933 ), and the West Indian pop singer  Joan Armatrading  (  b. 1950 )."]}]}],"historicEvents":[{"id":1705187,"age":30,"year":"1215","julianDay":2164830,"title":"Magna Carta","description":"King John of England agreed to a charter of rights called the Magna Carta. The document was originally drafted by the Archbishop of Canterbury to establish peace between King John and a group of rebel barons. The Magna Carta was completed in 1215 and is now considered to be one of the greatest constitutional documents of all time.","url":"https://www.nationalarchives.gov.uk/education/medieval/magna-carta/","urlTitle":"National Archives - Magna Carta","jurisdictionLevel":2},{"id":1705188,"age":39,"year":"1224","julianDay":2168117,"title":"France Declares War on England","description":"France declared war on England as Louis VIII of France attacked Poitou and northern Gascony.","jurisdictionLevel":2},{"id":1705189,"age":74,"year":"1259","julianDay":2180901,"title":"100 Years of Conflict Between England and France Ends","description":"Treaty of Paris was signed on December 4, 1259, which ended 100 years of conflict between England and France.","url":"https://en.wikipedia.org/wiki/Treaty_of_Paris_(1259)","urlTitle":"Wikipedia - Treaty of Paris 1259","jurisdictionLevel":2},{"id":1705190,"age":105,"year":"1290","julianDay":2192224,"title":"Jews Expelled From England","description":"After years of anti-Semitic behavior, King Edward I expelled Jews from England in 1290.","jurisdictionLevel":2}],"lifeSummary":"When Joan Compton was born on 8 January 1184, in Devon, England, her father, William De Compton, was -86 and her mother, Amicia Norris, was -56. She married Sir Galfrid Geoffrey Gilbert II before 1328, in England. They were the parents of at least 1 son. She died in Compton, Devon, England."},"et":{"8 January 1184–":"8. jaanuar 1184–Surnud","1184–Female":"1184–Surnud","1298–1349":"1298–1349","1328–1380":"1328–1380","1270–Male":"1270–Surnud","1240–Female":"1240–Surnud","1240":"1240","1184":"1184","1270":"1270","1380":"1380","before 1328":"enne 1328","1290":"1290","1349":"1349","8 January 1184":"8. jaanuar 1184","1259":"1259","1215":"1215","1224":"1224","1298":"1298","1328":"1328","England":"England","Devon, England":"Devon, England","Compton, Devon, England":"Compton, Devon, England"},"fi":{"8 January 1184–":"8. tammikuuta 1184–Kuollut","1184–Female":"1184–Kuollut","1298–1349":"1298–1349","1328–1380":"1328–1380","1270–Male":"1270–Kuollut","1240–Female":"1240–Kuollut","1240":"1240","1184":"1184","1270":"1270","1380":"1380","before 1328":"ennen vuotta 1328","1290":"1290","1349":"1349","8 January 1184":"8. tammikuuta 1184","1259":"1259","1215":"1215","1224":"1224","1298":"1298","1328":"1328","England":"England","Devon, England":"Devon, England","Compton, Devon, England":"Compton, Devon, England"},"fr":{"8 January 1184–":"8 janvier 1184–Décédée","1184–Female":"1184–Décédée","1298–1349":"1298–1349","1328–1380":"1328–1380","1270–Male":"1270–Décédé","1240–Female":"1240–Décédée","1240":"1240","1184":"1184","1270":"1270","1380":"1380","before 1328":"avant 1328","1290":"1290","1349":"1349","8 January 1184":"8 janvier 1184","1259":"1259","121