 1166":"okolo 1166","1202":"1202","environ 1197":"okolo 1197","1166":"1166","environ 1150":"okolo 1150","1120":"1120","1197":"1197","1183":"1183","1150":"1150","1180":"1180"},"da":{"environ 1150–environ 1197":"omkring 1150–omkring 1197","1150–1197":"1150–1197","1183–Female":"1183–Afdød","1202–Male":"1202–Afdød","1180–1217":"1180–1217","1180–Female":"1180–Afdød","1120–1166":"1120–1166","1128–Female":"1128–Afdød","1217":"1217","1128":"1128","environ 1166":"omkring 1166","1202":"1202","environ 1197":"omkring 1197","1166":"1166","environ 1150":"omkring 1150","1120":"1120","1197":"1197","1183":"1183","1150":"1150","1180":"1180"},"nl":{"environ 1150–environ 1197":"circa 1150–circa 1197","1150–1197":"1150–1197","1183–Female":"1183–Overleden","1202–Male":"1202–Overleden","1180–1217":"1180–1217","1180–Female":"1180–Overleden","1120–1166":"1120–1166","1128–Female":"1128–Overleden","1217":"1217","1128":"1128","environ 1166":"circa 1166","1202":"1202","environ 1197":"circa 1197","1166":"1166","environ 1150":"circa 1150","1120":"1120","1197":"1197","1183":"1183","1150":"1150","1180":"1180"},"en":{"environ 1150–environ 1197":"about 1150–about 1197","1150–1197":"1150–1197","1183–Female":"1183–Deceased","1202–Male":"1202–Deceased","1180–1217":"1180–1217","1180–Female":"1180–Deceased","1120–1166":"1120–1166","1128–Female":"1128–Deceased","1217":"1217","1128":"1128","environ 1166":"about 1166","1202":"1202","environ 1197":"about 1197","1166":"1166","environ 1150":"about 1150","1120":"1120","1197":"1197","1183":"1183","1150":"1150","1180":"1180","nameMeanings":[{"name":"VON","type":"LAST","attribution":"Dictionary of American Family Names © Patrick Hanks 2003, 2006.","meanings":["Altered form of Welsh   Vaughan  .","Chinese: variant of   Wong  .","Cambodian: written វ៉ុន, unexplained."],"variants":[{"name":"Vaughan","meanings":["Welsh: from <i>fychan</i>, a lenited form of <i>bychan</i>, a diminutive of <i>bach</i> ‘little’. This was often used to distinguish the younger of two bearers of the same personal name, typically the son of a father with the same name."]}]},{"name":"OBERSTEIN","type":"LAST","attribution":"Dictionary of American Family Names © Patrick Hanks 2003, 2006.","meanings":["German: topographic name from Middle High German <i>ober</i> ‘upper’ + <i>stein</i> ‘rock, stone’, also ‘castle’, hence a habitational or topographic name from the place Idar-Oberstein in Rhineland-Palatinate with the latter part of the name taken from a rock above the town."],"variants":[]},{"name":"Wilhelm","type":"FIRST","attribution":"Dictionary of First Names © Patrick Hanks and Flavia Hodges 1990, 2003, 2006.","meanings":["from <i>wil</i> ‘will’ + <i>helm</i> ‘helmet’; an ancient royal name.  See also  <b>William</b> ."],"variants":[{"name":"William","meanings":["Probably the most successful of all the Old French names of Germanic origin that were introduced to England by the Normans. It is derived from Germanic <i>wil</i> ‘will, desire’ + <i>helm</i> ‘helmet, protection’. The fact that it was borne by the Conqueror himself does not seem to have inhibited its favour with the ‘conquered’ population: in the first century after the Conquest it was the commonest male name of all, and not only among the Normans. In the later Middle Ages it was overtaken by   John  , but continued to run second to that name until the 20th century, when the picture became more fragmented."]}]},{"name":"Ier","type":"FIRST","attribution":"Dictionary of First Names © Patrick Hanks and Flavia Hodges 1990, 2003, 2006.","meanings":["and Norwegian vernacular form of   Peter ."],"variants":[{"name":"Peter","meanings":["form of the name of the best-known of all Christ's apostles, traditionally regarded as the founder of the Christian Church. The name derives, via Latin, from Greek <i>petros</i> ‘stone, rock’. This is used as a translation of the Aramaic byname <i>Cephas</i>, given to the apostle  Simon  son of Jona, to distinguish him from another of the same name (  Simon Zelotes ). ‘When Jesus beheld him, he said, Thou art Simon the son of Jona: thou shalt be called Cephas, which is by interpretation, A stone’ (John 1:42). According to Matthew 16:17–18, Christ says more explicitly, ‘Blessed art thou, Simon Bar-jona … thou art Peter, and upon this rock I will build my church’. The name has been in continuous use since the Middle Ages."]}]}],"lifeSummary":"When Wilhelm Ier VON OBERSTEIN was born about 1150, his father, Eberhard II VON OBERSTEIN VON STEIN, was 32 and his mother, Ponzetta, was 24. He had at least 1 son with Mathilde DE  SANPIGNY. He died about 1197, at the age of 49."},"et":{"environ 1150–environ 1197":"umbes 1150–umbes 1197","1150–1197":"1150–1197","1183–Female":"1183–Surnud","1202–Male":"1202–Surnud","1180–1217":"1180–1217","1180–Female":"1180–Surnud","1120–1166":"1120–1166","1128–Female":"1128–Surnud","1217":"1217","1128":"1128","environ 1166":"umbes 1166","1202":"1202","environ 1197":"umbes 1197","1166":"1166","environ 1150":"umbes 1150","1120":"1120","1197":"1197","1183":"1183","1150":"1150","1180":"1180"},"fi":{"environ 1150–environ 1197":"noin 1150–noin 1197","1150–1197":"1150–1197","1183–Female":"1183–Kuollut","1202–Male":"1202–Kuollut","1180–1217":"1180–1217","1180–Female":"1180–Kuollut","1120–1166":"1120–1166","1128–Female":"1128–Kuollut","1217":"1217","1128":"1128","environ 1166":"noin 1166","1202":"1202","environ 1197":"noin 1197","1166":"1166","environ 1150":"noin 1150","1120":"1120","1197":"1197","1183":"1183","1150":"1150","1180":"1180"},"fr":{"environ 1150–environ 1197":"environ 1150–environ 1197","1150–1197":"1150–1197","1183–Female":"1183–Décédée","1202–Male":"1202–Décédé","1180–1217":"1180–1217","1180–Female":"1180–Décédée","1120–1166":"1120–1166","1128–Female":"1128–Décédée","1217":"1217","1128":"1128","environ 1166":"environ 1166","1202":"1202","environ 1197":"environ 1197","1166":"1166","environ 1150":"environ 1150","1120":"1120","1197":"1197","1183":"1183","1150":"1150","1180":"1180","lifeSummary":"Lorsque Wi