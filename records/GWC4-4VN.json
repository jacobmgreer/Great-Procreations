":"英国英格兰諾薩普頓史爾艾可頓","England":"英国英格兰","lifeSummary":"当Nicholas Montgomery Lord of Cubley于1356年出生在英国德比夏爾时，他的父亲Walter Montgomery42岁，母亲Matilda Furnival33岁。他与Margaret Foljambe结婚。他们至少是2个儿子和1个女儿的父母。他去世于1424年在他的家乡享年68岁。"},"hr":{"1356–1424":"1356.–1424.","1365–1453":"1365–1453","1338–Female":"1338–preminula","1365–1374":"1365–1374","1380–1456":"1380–1456","1380–1465":"1380–1465","1314–1374":"1314–1374","1323–1385":"1323–1385.","about 1380":"oko 1380.","1385":"1385.","1374":"1374","1382":"1382","1380":"1380","1338":"1338","1424":"1424.","1314":"1314","1456":"1456","1356":"1356.","1323":"1323","September 1374":"rujan 1374.","1465":"1465","1453":"1453","1365":"1365","about 1365":"oko 1365.","before 29 September 1374":"prije 29. rujna 1374.","Cubley, Uttoxeter, Derbyshire, England":"Derbyshire, England","Cubley, Derbyshire, England":"Little Cubley, Derbyshire, Engleska, United Kingdom","Derbyshire, England":"Derbyshire, England","Ecton, Northamptonshire, England":"Ecton, Northamptonshire, Engleska, United Kingdom","England":"Engleska, United Kingdom"},"cs":{"1356–1424":"1356–1424","1365–1453":"1365–1453","1338–Female":"1338–Zesnulá","1365–1374":"1365–1374","1380–1456":"1380–1456","1380–1465":"1380–1465","1314–1374":"1314–1374","1323–1385":"1323–1385","about 1380":"okolo 1380","1385":"1385","1374":"1374","1382":"1382","1380":"1380","1338":"1338","1424":"1424","1314":"1314","1456":"1456","1356":"1356","1323":"1323","September 1374":"září 1374","1465":"1465","1453":"1453","1365":"1365","about 1365":"okolo 1365","before 29 September 1374":"před 29. září 1374","Cubley, Uttoxeter, Derbyshire, England":"Derbyshire, Anglie","Cubley, Derbyshire, England":"Little Cubley, Derbyshire, Anglie, United Kingdom","Derbyshire, England":"Derbyshire, Anglie","Ecton, Northamptonshire, England":"Ecton, Northamptonshire, Anglie, United Kingdom","England":"Anglie, United Kingdom"},"da":{"1356–1424":"1356–1424","1365–1453":"1365–1453","1338–Female":"1338–Afdød","1365–1374":"1365–1374","1380–1456":"1380–