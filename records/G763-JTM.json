–1125":"1040–1125","1066":"1066","1044":"1044","1120":"1120","1098":"1098","1131":"1131","1097":"1097","1086":"1086","1064":"1064","1096":"1096","1040":"1040","Cir 1064":"1064","1060":"1060","1105":"1105","1059":"1059","1125":"1125","1111":"1111","1067":"1067","Nottinghamshire, England, United Kingdom":"Nottinghamshire, Engeland, Verenigd Koninkrijk","Normandy, Plouigneau, Brittany, France":"Plouigneau, Bretagne, Frankrijk","Willoughby, Lincolnshire, , England":"Willoughby, Lincolnshire, England"},"en":{"Cir 1064–1097":"1064–1097","1060–Male":"1060–Deceased","1064–1097":"1064–1097","1067–1131":"1067–1131","–Female":"Deceased","1097–1111":"1097–1111","1098–Male":"1098–Deceased","1105–Female":"1105–Deceased","1044–1120":"1044–1120","1040–1125":"1040–1125","1066":"1066","1044":"1044","1120":"1120","1098":"1098","1131":"1131","1097":"1097","1086":"1086","1064":"1064","1096":"1096","1040":"1040","Cir 1064":"1064","1060":"1060","1105":"1105","1059":"1059","1125":"1125","1111":"1111","1067":"1067","Nottinghamshire, England, United Kingdom":"Nottinghamshire, England, United Kingdom","Normandy, Plouigneau, Brittany, France":"Plouigneau, Brittany, France","Willoughby, Lincolnshire, , England":"Willoughby, Lincolnshire, England","nameMeanings":[{"name":"de","type":"LAST","attribution":"Dictionary of American Family Names © Patrick Hanks 2003, 2006.","meanings":["Some characteristic forenames:  Indian Dilip, Anirban, Gopal, Alok, Anindya, Arunava, Asit, Asok, Dibyendu, Goutam, Indra, Indranil.","Indian: variant of   Dey  ."],"variants":[{"name":"Dey","meanings":["Some characteristic forenames:  Indian Ashit, Indu, Naina, Partha, Soumya, Ajit, Anjan, Anjana, Anup, Arjun, Arun, Ashim.","English, Scottish, and Welsh: variant of   Day  .","German: topographic name from a field name in North Rhine-Westphalia, denoting a sizeable piece of land, from Middle Low German <i>dē</i> ‘thigh’ (referring to the shape of the property)."]}]},{"name":"Muschamp","type":"LAST","attribution":"Dictionary of Family Names in Britain and Ireland © University of the West of England 2016","meanings":["English: locative name from North and South Muskham (Notts), recorded in gallicized forms such as  <i>Muscamp</i> and  <i>Muschamp</i> from the 12th century onwards."],"variants":[]},{"name":"Roger","type":"FIRST","attribution":"Dictionary of First Names © Patrick Hanks and Flavia Hodges 1990, 2003, 2006.","meanings":["From an Old French personal name, <i>Rog(i)er</i>, of Germanic (Frankish) origin, from <i>hrōd</i> ‘fame’ + <i>gār</i>, <i>gēr</i> ‘spear’. This was adopted by the Normans and introduced by them to Britain, replacing the native Old English form <i>Hrōðgār</i>. <i>Roger</i> was one of the most popular boys' names throughout the medieval period, but less so after the Reformation, though it has continued in regular use to the present day.  Roger, Count of Sicily  (  <i>c.</i>1031–1101 ), son of Tancred, recovered Sicily from the Arabs. His son, also called Roger, ruled Sicily as king, presiding over a court noted for its splendour and patronage of the arts."],"variants":[{"name":"Rodger","meanings":["Variant spelling of   Roger  , in part from the surname derived from the given name in the Middle Ages."]}]}],"historicEvents":[{"id":1705182,"age":2,"year":"1066","julianDay":2110409,"title":"Battle of Hastings","description":"Battle of Hastings was fought between the Norman-French army and the battle-wary English army on October 14, 1066. Duke William of Normandy believed he was the rightful king rather than Harold, who had been crowned king several months earlier. Harold was killed in battle and William was crowned king on Christmas Day 1066.","url":"https://www.english-heritage.org.uk/learn/1066-and-the-norman-conquest/what-happened-battle-hastings/","urlTitle":"English Heritage - Battle of Hastings","jurisdictionLevel":2},{"id":1705183,"age":22,"year":"1086","julianDay":2117714,"title":"Domesday Book","description":"Domesday Book is Britain's earliest extant public record with information containing land surveys and landholdings commissioned by William I. The book was completed in 1086.","url":"https://www.nationalarchives.gov.uk/domesday/","urlTitle":"National Archives - Domesday","jurisdictionLevel":2},{"id":1705184,"age":32,"year":"1096","julianDay":2121366,"title":"The Crusades","description":"A series of religious wars between Christians and Muslims, known as the Crusades, occurred between 1096 and 1291, and played a large role in European Christian dominance in the Middle East.","url":"https://www.history.com/topics/middle-ages/crusades","urlTitle":"History - The Crusades","jurisdictionLevel":2}],"lifeSummary":"When Roger de Muschamp was born in 1064, in Plouigneau, Brittany, France, his father, Roger de Muschamp, was 20 and his mother, Beatrice Herrera, was 24. He had at least 2 sons and 1 daughter with Lady Willoughby. He died in 1097, in Willoughby, Lincolnshire, England, at the age of 33."},"et":{"Cir 1064–1097":"1064–1097","1060–Male":"1060–Surnud","1064–1097":"1064–1097","1067–1131":"1067–1131","–Female":"Surnud","1097–1111":"1097–1111","1098–Male":"1098–Surnud","1105–Female":"1105–Surnud","1044–1120":"1044–1120","1040–1125":"1040–1125","1066":"1066","1044":"1044","1120":"1120","1098":"1098","1131":"1131","1097":"1097","1086":"1086","1064":"1064","1096":"1096","1040":"1040","Cir 1064":"1064","1060":"1060","1105":"1105","1059":"1059","1125":"1125","1111":"1111","1067":"1067","Nottinghamshire, England, United Kingdom":"Nottinghamshire, Inglismaa, United Kingdom","Normandy, Plouigneau, Brittany, France":"Plouigneau, Bretagne, Prantsusmaa","Willoughby, Lincolnshire, , England":"Willoughby, Lincolnshire, England"},"fi":{"Cir 1064–1097":"1064–1097","1060–Male":"1060–Kuollut","1064–1097":"1064–1097","1067–1131":"1067–1131","–Female":"Kuollut","1097–1111":"1097–1111","1098–Male":"1098–Kuollut","1105–Female":"1105–Kuollut","1044–1120":"1044–1120","1040–1125":"1040–1125","1066":"1066","1044":"1044","1120":"1120","