and":"Yorkshire, England","Saint-Pierre and Miquelon, New France":"Saint-Pierre, Acadie, Nouvelle-France","Lichfield, Staffordshire, England":"Lichfield, Staffordshire, England","Upholland, Lancashire, England":"Up Holland, Lancashire, England","Notton, Yorkshire, England":"Notton, Yorkshire, England","West Derby, Lancashire, England":"West Derby, Lancashire, England"},"en":{"1315–21 November 1341":"1315–21 November 1341","1322–1356":"1322–1356","1394–1467":"1394–1467","–1416":"–1416","1315–1341":"1315–1341","Cir 1327":"1327","1341":"1341","November 1341":"November 1341","1394":"1394","ABT 1327":"about 1327","1316":"1316","1315":"1315","1337":"1337","1467":"1467","about 1338":"about 1338","1356":"1356","1322":"1322","21 November 1341":"21 November 1341","Aft 21 November 1341":"after 21 November 1341","1453":"1453","1317":"1317","1328":"1328","1416":"1416","Yorkshire, England":"Yorkshire, England","Saint-Pierre and Miquelon, New France":"Saint-Pierre, Acadia, New France","Lichfield, Staffordshire, England":"Lichfield, Staffordshire, England","Upholland, Lancashire, England":"Up Holland, Lancashire, England","Notton, Yorkshire, England":"Notton, Yorkshire, England","West Derby, Lancashire, England":"West Derby, Lancashire, England","nameMeanings":[{"name":"de","type":"LAST","attribution":"Dictionary of American Family Names © Patrick Hanks 2003, 2006.","meanings":["Some characteristic forenames:  Indian Dilip, Anirban, Gopal, Alok, Anindya, Arunava, Asit, Asok, Dibyendu, Goutam, Indra, Indranil.","Indian: variant of   Dey  ."],"variants":[{"name":"Dey","meanings":["Some characteristic forenames:  Indian Ashit, Indu, Naina, Partha, Soumya, Ajit, Anjan, Anjana, Anup, Arjun, Arun, Ashim.","English, Scottish, and Welsh: variant of   Day  .","German: topographic name from a field name in North Rhine-Westphalia, denoting a sizeable piece of land, from Middle Low German <i>dē</i> ‘thigh’ (referring to the shape of the property)."]}]},{"name":"Holand","type":"LAST","attribution":"Dictionary of American Family Names © Patrick Hanks 2003, 2006.","meanings":["English and Scottish: variant of   Holland  .","Norwegian: habitational name from about twenty farmsteads so named, composed of Old Norse <i>hár</i> ‘high’ + <i>land</i> ‘land, field’, denoting a high-lying farm."],"variants":[{"name":"Holland","meanings":["English, German, Dutch, Danish, Norwegian, Swedish, French, and Jewish (Ashkenazic): habitational name from <i>Holland</i>, a province of the Netherlands.","English: habitational name from Downholland or Upholland (Lancashire), Hulland (Derbyshire), the Parts of Holland, one of the three administrative subdivisions of Lincolnshire, any of the four places called Hoyland (southern Yorkshire), and possibly Great and Little Holland (Essex). The placenames all derive from Old English <i>hōh</i> ‘heel, spur of land’ + <i>land</i> ‘land’.","English: habitational name either from Hoeland (Farm) in Bury (Sussex), or from Holland's Barn in Albourne (Sussex). The placename in Bury has the same etymology as in 1 above, while the placename in Albourne may derive from Old English <i>hol</i> ‘hole, hollow’ + <i>land</i> ‘land’."]}]}],"historicEvents":[{"id":1705191,"age":0,"year":"1315","toYear":"1317","julianDay":2201354,"title":"Famine Strikes Europe","description":"A famine caused by cold winters and wet summers across Europe caused millions to die due to starvation. Desperation from hunger caused high levels of crime, stampedes in bread lines in London, infanticide, and even cannibalism throughout Europe.","jurisdictionLevel":2},{"id":1705192,"age":13,"year":"1328","julianDay":2206102,"title":"First War of Scottish Independence","description":"The First War of Scottish Independence began after England invaded Scotland in 1296. The Treaty of Edinburgh was signed in 1328 which declared peace between the two kingdoms and brought the war to an end.","jurisdictionLevel":2},{"id":1705193,"age":22,"year":"1337","toYear":"1453","julianDay":2209390,"title":"The Hundred Years' War","description":"The Hundred Years' War between France and England was largely due to the question of legitimate succession to the French crown.","jurisdictionLevel":2}],"lifeSummary":"Baroness Alianore de Holand was born in 1315, in Up Holland, Lancashire, England. She married John Darcy about 1338, in Yorkshire, England. They were the parents of at least 1 daughter. She died on 21 November 1341, in Saint-Pierre, Acadia, New France, at the age of 26, and was buried in Saint-Pierre, Acadia, New France."},"et":{"1315–21 November 1341":"1315–21. november 1341","1322–1356":"1322–1356","1394–1467":"1394–1467","–1416":"–1416","1315–1341":"1315–1341","Cir 1327":"1327","1341":"1341","November 1341":"november 1341","1394":"1394","ABT 1327":"umbes 1327","1316":"1316","1315":"1315","1337":"1337","1467":"1467","about 1338":"umbes 1338","1356":"1356","1322":"1322","21 November 1341":"21. november 1341","Aft 21 November 1341":"pärast 21. novembrit 1341","1453":"1453","1317":"1317","1328":"1328","1416":"1416","Yorkshire, England":"Yorkshire, England","Saint-Pierre and Miquelon, New France":"Saint-Pierre, Acadie, Nouvelle-France","Lichfield, Staffordshire, England":"Lichfield, Staffordshire, England","Upholland, Lancashire, England":"Up Holland, Lancashire, England","Notton, Yorkshire, England":"Notton, Yorkshire, England","West Derby, Lancashire, England":"West Derby, Lancashire, England"},"fi":{"1315–21 November 1341":"1315–21. marraskuuta 1341","1322–1356":"1322–1356","1394–1467":"1394–1467","–1416":"–1416","1315–1341":"1315–1341","Cir 1327":"1327","1341":"1341","November 1341":"marraskuu 1341","1394":"1394","ABT 1327":"noin 1327","1316":"1316","1315":"1315","1337":"1337","1467":"1467","about 1338":"noin 1338","1356":"1356","1322":"1322","21 November 1341":"21. marraskuuta 1341","Aft 21 November 1341":"21. marraskuuta 1341 jälkeen","1453":"1453","1317":"1317","1328":"1328","1416":"1416","Yorkshire, England":"Yorkshire, England","Saint-Pierre and Miq