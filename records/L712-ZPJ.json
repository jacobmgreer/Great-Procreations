. 1370":"omkring 1370","1370":"1370","about 1350":"omkring 1350","Warwickshire, England, United Kingdom":"Warwickshire, England, United Kingdom","of Newton, Cheshire, Eng.":"Newton, Cheshire, England, United Kingdom"},"nl":{"about 1350–":"circa 1350–Overleden","1350–Female":"1350–Overleden","1370–1433":"1370–1433","1350–Male":"1350–Overleden","1433":"1433","1350":"1350","abt. 1370":"circa 1370","1370":"1370","about 1350":"circa 1350","Warwickshire, England, United Kingdom":"Warwickshire, Engeland, Verenigd Koninkrijk","of Newton, Cheshire, Eng.":"Newton, Cheshire, Engeland, Verenigd Koninkrijk"},"en":{"about 1350–":"about 1350–Deceased","1350–Female":"1350–Deceased","1370–1433":"1370–1433","1350–Male":"1350–Deceased","1433":"1433","1350":"1350","abt. 1370":"about 1370","1370":"1370","about 1350":"about 1350","Warwickshire, England, United Kingdom":"Warwickshire, England, United Kingdom","of Newton, Cheshire, Eng.":"Newton, Cheshire, England, United Kingdom","nameMeanings":[{"name":"Holt","type":"LAST","attribution":"Dictionary of American Family Names © Patrick Hanks 2003, 2006.","meanings":["English, North German, Dutch, Danish, and Norwegian: topographic name for someone who lived in or by a small wood, from Middle English, Middle Low German, Danish, and Norwegian <i>holt</i>, or a habitational name from one of the many places called with this word. In England, the surname is widely distributed, but more common in Lancashire and Yorkshire than elsewhere."],"variants":[{"name":"Hohlt","meanings":["Some characteristic forenames:  Scandinavian Ordell.","North German: variant of   Holt   with the additional <i>h</i> reflecting the lengthened vowel or a variant of   Hohl   with the addition of excrescent <i>-t</i>.","Scandinavian: variant of   Holt  ."]},{"name":"Holten","meanings":["Some characteristic forenames:  Scandinavian Erik, Hjalmer, Lars, Nils.","Dutch (also <b>Van Holten</b>) and North German: habitational name from any of the places so called, from Low German <i>holt</i> ‘holt, copse, small wood’. There are two in the Dutch province of Overijssel and another near Oberhausen in the Rhineland.","Danish: variant of   Holt  ."]},{"name":"Holtan","meanings":["Norwegian: habitational name from any of numerous farmsteads so named, from the definite plural form of <i>holt</i> ‘small wood’ (see   Holt  )."]},{"name":"Holter","meanings":["Some characteristic forenames:  Scandinavian Erik, Selmer, Hilmar, Knute, Lars.","Norwegian: habitational name from any of several farmsteads in southeastern Norway, from the indefinite plural of <i>holt</i> ‘holt, small wood’ (see   Holt  ).","North German (also <b>Hölter</b>): habitational name for someone from any of several places in Westphalia called Hölt and Holt (see   Holt  ). Compare   Hoelter  ."]},{"name":"Holtman","meanings":["Dutch: variant of   Holt   + <i>man</i> ‘man’.","Americanized form of German   Holtmann  ."]},{"name":"Holtmann","meanings":["Some characteristic forenames:  German Udo, Aloys, Hans, Heinz.","North German: variant of   Holt  ."]},{"name":"Holte","meanings":["Some characteristic forenames:  Scandinavian Bjorg, Erik, Helmer, Hjalmer, Knute, Nels, Nordahl, Selmer, Swen, Thorvald.","North German: variant of   Holt  .","North German: habitational name from any of several places so named."]},{"name":"Hoult","meanings":["English: variant of   Holt  ."]}]},{"name":"Peter","type":"FIRST","attribution":"Dictionary of First Names © Patrick Hanks and Flavia Hodges 1990, 2003, 2006.","meanings":["form of the name of the best-known of all Christ's apostles, traditionally regarded as the founder of the Christian Church. The name derives, via Latin, from Greek <i>petros</i> ‘stone, rock’. This is used as a translation of the Aramaic byname <i>Cephas</i>, given to the apostle  Simon  son of Jona, to distinguish him from another of the same name (  Simon Zelotes ). ‘When Jesus beheld him, he said, Thou art Simon the son of Jona: thou shalt be called Cephas, which is by interpretation, A stone’ (John 1:42). According to Matthew 16:17–18, Christ says more explicitly, ‘Blessed art thou, Simon Bar-jona … thou art Peter, and upon this rock I will build my church’. The name has been in continuous use since the Middle Ages."],"variants":[]}],"lifeSummary":"Peter Holt was born about 1350, in Warwickshire, England, United Kingdom. He had at least 1 son with Mrs. Anne Holt."},"et":{"about 1350–":"umbes 1350–Surnud","1350–Female":"1350–Surnud","1370–1433":"1370–1433","1350–Male":"1350–Surnud","1433":"1433","1350":"1350","abt. 1370":"umbes 1370","1370":"1370","about 1350":"umbes 1350","Warwickshire, England, United Kingdom":"Warwickshire, Inglismaa, United Kingdom","of Newton, Cheshire, Eng.":"Newton, Cheshire, Inglismaa, United Kingdom"},"fi":{"about 1350–":"noin 1350–Kuollut","1350–Female":"1350–Kuollut","1370–1433":"1370–1433","1350–Male":"1350–Kuollut","1433":"1433","1350":"1350","abt. 1370":"noin 1370","1370":"1370","about 1350":"noin 1350","Warwickshire, England, United Kingdom":"Warwickshire, Englanti, Yhdistynyt kuningaskunta","of Newton, Cheshire, Eng.":"Newton, Cheshire, Englanti, Yhdistynyt kuningaskunta"},"fr":{"about 1350–":"environ 1350–Décédé","1350–Female":"1350–Décédée","1370–1433":"1370–1433","1350–Male":"1350–Décédé","1433":"1433","1350":"1350","abt. 1370":"environ 1370","1370":"1370","about 1350":"environ 1350","Warwickshire, England, United Kingdom":"Warwickshire, Angleterre, Royaume-Uni","of Newton, Cheshire, Eng.":"Newton, Cheshire, Angleterre, Royaume-Uni","lifeSummary":"Peter Holt est né environ 1350, à Warwickshire, Angleterre, Royaume-Uni. Il a eu au moins 1 fils avec Mrs. Anne Holt."},"de":{"about 1350–":"um 1350–Verstorben","1350–Female":"1350–Verstorben","1370–1433":"1370–1433","1350–Male":"1350–Verstorben","1433":"1433","1350":"1350","abt. 1370":"um 1370","1370":"1370","about 1350":"um 1350","Warwickshire, England, United Kingdom":"Warwickshire, England, United Kingdom","of Newton, Cheshire, Eng.":"Newton, Cheshire, En