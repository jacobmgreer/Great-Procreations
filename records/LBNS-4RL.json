"1340–1408":"1340–1408","1365–1404":"1365–1404","1370–1426":"1370–1426","1293–1405":"1293–1405","1293–Female":"1293–Overleden","Aft 15 July 1404":"na 15 juli 1404","after 15 July 1404":"na 15 juli 1404","1340":"1340","Abt 1335":"circa 1335","1382":"1382","1370":"1370","1293":"1293","1426":"1426","1404":"1404","1337":"1337","1357":"1357","about 1404":"circa 1404","1332":"circa 1332","1453":"1453","1365":"1365","about 1365":"circa 1365","1408":"1408","1405":"1405","Somerby, Lincolnshire, England":"Somerby, Lincolnshire, Engeland, Verenigd Koninkrijk","Flamborough, Yorkshire, England":"Flamborough, Yorkshire East Riding, Engeland, Verenigd Koninkrijk","England":"England","Lincolnshire, England":"Lincolnshire, England"},"en":{"1332–Aft 15 July 1404":"about 1332–after 15 July 1404","1332–1404":"about1332–1404","1340–1408":"1340–1408","1365–1404":"1365–1404","1370–1426":"1370–1426","1293–1405":"1293–1405","1293–Female":"1293–Deceased","Aft 15 July 1404":"after 15 July 1404","after 15 July 1404":"after 15 July 1404","1340":"1340","Abt 1335":"about 1335","1382":"1382","1370":"1370","1293":"1293","1426":"1426","1404":"1404","1337":"1337","1357":"1357","about 1404":"about 1404","1332":"about 1332","1453":"1453","1365":"1365","about 1365":"about 1365","1408":"1408","1405":"1405","Somerby, Lincolnshire, England":"Somerby, Lincolnshire, England, United Kingdom","Flamborough, Yorkshire, England":"Flamborough, Yorkshire East Riding, England, United Kingdom","England":"England","Lincolnshire, England":"Lincolnshire, England","nameMeanings":[{"name":"Cumberworth","type":"LAST","attribution":"Dictionary of American Family Names © Patrick Hanks 2003, 2006.","meanings":["English (Lincolnshire): habitational name from Cumberworth in Lincolnshire, named from an Old English personal name <i>Cumbre</i> + <i>worth</i> ‘enclosure’. There is also a Lower and an Upper Cumberworth in Yorkshire but these appear not to have contributed significantly to the modern surname, which is concentrated in Lincolnshire."],"variants":[]},{"name":"Robert","type":"FIRST","attribution":"Dictionary of First Names © Patrick Hanks and Flavia Hodges 1990, 2003, 2006.","meanings":["One of the many French names of Germanic origin that were introduced into Britain by the Normans; it has since remained in continuous use. It is derived from the nearly synonymous elements <i>hrōd</i> ‘fame’ + <i>berht</i> ‘bright, famous’, and had a native Old English predecessor of similar form (<i>Hreodbeorht</i>), which was supplanted by the Norman name. Two dukes of Normandy in the 11th century bore the name: the father of  William the Conqueror  (sometimes identified with the legendary Robert the Devil), and his eldest son. It was borne also by three kings of Scotland, notably  Robert the Bruce  (  1274–1329 ), who freed Scotland from English domination. The altered short form <i>Bob</i> is very common, but <i>Hob</i> and <i>Dob</i>, which were common in the Middle Ages and gave rise to surnames, are extinct.  See also  Rupert ."],"variants":[]}],"historicEvents":[{"id":1705193,"age":5,"year":"1337","toYear":"1453","julianDay":2209390,"title":"The Hundred Years' War","description":"The Hundred Years' War between France and England was largely due to the question of legitimate succession to the French crown.","jurisdictionLevel":1},{"id":1705195,"age":50,"year":"1382","julianDay":2225826,"title":"Wycliffe's Bible","description":"John Wycliffe, English theologian and professor at the University of Oxford, completed a translation of the Bible from the Latin Vulgate into Middle English. This translation is known as Wycliffe's Bible and was completed around 1382.","url":"https://en.wikipedia.org/wiki/Wycliffe%27s_Bible","urlTitle":"Wikipedia - Wycliffe's Bible","jurisdictionLevel":1}],"lifeSummary":"When Robert Cumberworth was born about 1332, in Lincolnshire, England, his father, Robert Cumberworth, was 40 and his mother, Mrs Robert Cumberworth, was 40. He married Sibil Erghum in 1357, in Flamborough, Yorkshire East Riding, England, United Kingdom. They were the parents of at least 1 son and 1 daughter. He died after 15 July 1404, in Somerby, Lincolnshire, England, United Kingdom, and was buried in Somerby, Lincolnshire, England, United Kingdom."},"et":{"1332–Aft 15 July 1404":"umbes 1332–pärast 15. juulit 1404","1332–1404":"umbes1332–1404","1340–1408":"1340–1408","1365–1404":"1365–1404","1370–1426":"1370–1426","1293–1405":"1293–1405","1293–Female":"1293–Surnud","Aft 15 July 1404":"pärast 15. juulit 1404","after 15 July 1404":"pärast 15. juulit 1404","1340":"1340","Abt 1335":"umbes 1335","1382":"1382","1370":"1370","1293":"1293","1426":"1426","1404":"1404","1337":"1337","1357":"1357","about 1404":"umbes 1404","1332":"umbes 1332","1453":"1453","1365":"1365","about 1365":"umbes 1365","1408":"1408","1405":"1405","Somerby, Lincolnshire, England":"Somerby, Lincolnshire, Inglismaa, United Kingdom","Flamborough, Yorkshire, England":"Flamborough, Yorkshire East Riding, Inglismaa, United Kingdom","England":"England","Lincolnshire, England":"Lincolnshire, England"},"fi":{"1332–Aft 15 July 1404":"noin 1332–15. heinäkuuta 1404 jälkeen","1332–1404":"noin1332–1404","1340–1408":"1340–1408","1365–1404":"1365–1404","1370–1426":"1370–1426","1293–1405":"1293–1405","1293–Female":"1293–Kuollut","Aft 15 July 1404":"15. heinäkuuta 1404 jälkeen","after 15 July 1404":"15. heinäkuuta 1404 jälkeen","1340":"1340","Abt 1335":"noin 1335","1382":"1382","1370":"1370","1293":"1293","1426":"1426","1404":"1404","1337":"1337","1357":"1357","about 1404":"noin 1404","1332":"noin 1332","1453":"1453","1365":"1365","about 1365":"noin 1365","1408":"1408","1405":"1405","Somerby, Lincolnshire, England":"Somerby, Lincolnshire, Englanti, Yhdistynyt kuningaskunta","Flamborough, Yorkshire, England":"Flamborough, Yorkshire East Riding, Englanti, Yhdistynyt kuningaskunta","England":"England","Lincolnshire, England":"Lincolnshire, England"},"fr":{"1332–Aft 15 July 1404":"environ 1332–après 15 juillet 1404",