150–1244":"1150–1244","1172–1244":"1172–1244","1126–1210":"1126–1210","1170–1230":"1170–1230","1190":"1190","1220":"1220","1230":"1230","1172":"1172","1150":"1150","1160":"1160","1170":"1170","BEF 1172":"vóór 1172","1126":"1126","1244":"1244","1210":"1210","1155":"1155","ABT 1160":"circa 1160","Stourton, Cheshire, England":"Cheshire, Engeland, Verenigd Koninkrijk","Harpenden, Hertfordshire, England":"Harpenden, Hertfordshire, Engeland, Verenigd Koninkrijk","Kingsley, Cheshire, England":"Kingsley, Cheshire, Engeland, Verenigd Koninkrijk"},"en":{"ABT 1160–1190":"about 1160–1190","1155–1220":"1155–1220","1160–1190":"1160–1190","1150–1244":"1150–1244","1172–1244":"1172–1244","1126–1210":"1126–1210","1170–1230":"1170–1230","1190":"1190","1220":"1220","1230":"1230","1172":"1172","1150":"1150","1160":"1160","1170":"1170","BEF 1172":"before 1172","1126":"1126","1244":"1244","1210":"1210","1155":"1155","ABT 1160":"about 1160","Stourton, Cheshire, England":"Cheshire, England, United Kingdom","Harpenden, Hertfordshire, England":"Harpenden, Hertfordshire, England, United Kingdom","Kingsley, Cheshire, England":"Kingsley, Cheshire, England, United Kingdom","nameMeanings":[{"name":"de","type":"LAST","attribution":"Dictionary of American Family Names © Patrick Hanks 2003, 2006.","meanings":["Some characteristic forenames:  Indian Dilip, Anirban, Gopal, Alok, Anindya, Arunava, Asit, Asok, Dibyendu, Goutam, Indra, Indranil.","Indian: variant of   Dey  ."],"variants":[{"name":"Dey","meanings":["Some characteristic forenames:  Indian Ashit, Indu, Naina, Partha, Soumya, Ajit, Anjan, Anjana, Anup, Arjun, Arun, Ashim.","English, Scottish, and Welsh: variant of   Day  .","German: topographic name from a field name in North Rhine-Westphalia, denoting a sizeable piece of land, from Middle Low German <i>dē</i> ‘thigh’ (referring to the shape of the property)."]}]},{"name":"Stourton","type":"LAST","attribution":"Dictionary of Family Names in Britain and Ireland © University of the West of England 2016","meanings":["1  English: locative name from any of three places named Stourton (Staffs, Wilts, Warwicks).","2  English:  see  Sturton  .","3  English: locative name, perhaps occasionally from Storrington (Sussex), which is recorded as  <i>Storgetune</i> in 1086."],"variants":[{"name":"Storton","meanings":["English:  see  Stourton  ."]},{"name":"Sturton","meanings":["1  English: locative name from Sturton le Steeple (Notts), Great Sturton (Lincs), Sturton by Stow (Lincs), or possibly Sturton (Northumb), all of which place-names share the same etymology and early spellings as   Stratton  .","2  English:  see  Stourton  ."]}]},{"name":"Joan","type":"FIRST","attribution":"Dictionary of First Names © Patrick Hanks and Flavia Hodges 1990, 2003, 2006.","meanings":["Contracted form of Old French <i>Jo(h)anne</i>, from Latin <i>Io(h)anna</i> (  see  Joanna  ). In England this was the usual feminine form of   John   from the Middle English period onwards and was extremely popular, but in the 16th and 17th centuries it steadily lost ground to   Jane .  It was strongly revived in the first part of the 20th century, partly under the influence of  George Bernard Shaw's  play St Joan (  1923 ), based on the life of  Joan of Arc  (  1412–31 ). Claiming to be guided by the voices of the saints, she persuaded the French dauphin to defy the occupying English forces and have himself crowned, and she led the French army that raised the siege of Orleans in  1429 . The following year she was captured by the Burgundians and sold to the English, and a year later she was burned at the stake for witchcraft at the age of 18 or 19. Her story has captured the imagination of many writers, and she is variously portrayed as a national and political hero, a model of apolitical straightforwardness and honesty, and a religious heroine. She was canonized in  1920 . More recent influences have included the American film actress  Joan Crawford  (  1908–77 , born  Lucille le Sueur ), the British actress  Joan Collins  (  b. 1933 ), the American comedienne  Joan Rivers  (  b. 1933 ), and the West Indian pop singer  Joan Armatrading  (  b. 1950 )."],"variants":[{"name":"John","meanings":["As a boy's name this represents a revival of Middle English <i>Jan</i>, a by‐form of   John  , or an adoption of the common European form with this spelling. As a girl's name it is a short form of names such as   Janet   and   Janice ."]}]}],"lifeSummary":"When Joan de Stourton was born about 1160, in Cheshire, England, United Kingdom, her father, Alexander de Stourton, of the Wirral, was 35 and her mother, Amabilis De Sylvester, was -8. She had at least 1 daughter with Sir Richard de Kingsley 2nd Bailiff Delamere Forest. She died in 1190, in Harpenden, Hertfordshire, England, United Kingdom, at the age of 31."},"et":{"ABT 1160–1190":"umbes 1160–1190","1155–1220":"1155–1220","1160–1190":"1160–1190","1150–1244":"1150–1244","1172–1244":"1172–1244","1126–1210":"1126–1210","1170–1230":"1170–1230","1190":"1190","1220":"1220","1230":"1230","1172":"1172","1150":"1150","1160":"1160","1170":"1170","BEF 1172":"enne 1172","1126":"1126","1244":"1244","1210":"1210","1155":"1155","ABT 1160":"umbes 1160","Stourton, Cheshire, England":"Cheshire, Inglismaa, United Kingdom","Harpenden, Hertfordshire, England":"Harpenden, Hertfordshire, Inglismaa, United Kingdom","Kingsley, Cheshire, England":"Kingsley, Cheshire, Inglismaa, United Kingdom"},"fi":{"ABT 1160–1190":"noin 1160–1190","1155–1220":"1155–1220","1160–1190":"1160–1190","1150–1244":"1150–1244","1172–1244":"1172–1244","1126–1210":"1126–1210","1170–1230":"1170–1230","1190":"1190","1220":"1220","1230":"1230","1172":"1172","1150":"1150","1160":"1160","1170":"1170","BEF 1172":"ennen vuotta 1172","1126":"1126","1244":"1244","1210":"1210","1155":"1155","ABT 1160":"noin 1160","Stourton, Cheshire, England":"Cheshire, Englanti, Yhdistynyt kuningaskunta","Harpenden, Hertfordshire, England":"Harpenden, Hertfordshire, Englanti, Yhdistynyt kuningasku