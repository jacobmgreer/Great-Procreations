and":"England, United Kingdom"},"nl":{"1500–":"1500–Overleden","1500–Male":"1500–Overleden","1520–1603":"1520–1603","1500–Female":"1500–Overleden","1500":"1500","1520":"1520","1603":"1603","British Colonial America":"British Colonial America","England":"Engeland, Verenigd Koninkrijk"},"en":{"1500–":"1500–Deceased","1500–Male":"1500–Deceased","1520–1603":"1520–1603","1500–Female":"1500–Deceased","1500":"1500","1520":"1520","1603":"1603","British Colonial America":"British Colonial America","England":"England, United Kingdom","nameMeanings":[{"name":"Travis","type":"LAST","attribution":"Dictionary of American Family Names © Patrick Hanks 2003, 2006.","meanings":["English (mainly Lancashire and Yorkshire): from Old French and Middle English <i>travers</i>, also Middle English <i>travas</i>, <i>travis</i>, a word with several meanings. It may denote a toll paid for the right to cross a boundary or bridge, the surname perhaps being for someone who paid or collected such tolls. Alternatively, it may mean ‘crosswise, sideways’ or ‘dispute, disagreement’. The Old French word also had the sense ‘crossing, passage’, and it is more than likely that the surname is Norman in origin, for someone who lived at a crossing place or at a place so named (compare French   Travers   3). The presence of the preposition ‘de’ (and perhaps also ‘le’) in early forms of the surname appears to indicate a topographic or habitational explanation, but the French preposition and definite article were sometimes added gratuitously to Norman surnames as a sign of their high social status. See also   Travers   1.","Americanized form of German   Drewes  ."],"variants":[{"name":"Travers","meanings":["English (of Norman origin): variant of   Travis   1 and a cognate of 3 below, or a variant of <b>Trevors</b>, itself a variant of   Trevor  .","Irish (Leitrim and Donegal; of Anglo-Norman origin): variant of   Trower  .","French: topographic name for someone who lived at a crossing place, Old French <i>travers</i>, or a habitational name from (Le) Travers, the name of several places in various parts of France, named with this word."]},{"name":"Traverse","meanings":["English (Lancashire; of Norman origin): variant of   Travis  .","French: variant of   Travers  ."]}]}],"lifeSummary":"Travis was born in 1500, in British Colonial America. She had at least 1 son with Travis."},"et":{"1500–":"1500–Surnud","1500–Male":"1500–Surnud","1520–1603":"1520–1603","1500–Female":"1500–Surnud","1500":"1500","1520":"1520","1603":"1603","British Colonial America":"British Colonial America","England":"Inglismaa, United Kingdom"},"fi":{"1500–":"1500–Kuollut","1500–Male":"1500–Kuollut","1520–1603":"1520–1603","1500–Female":"1500–Kuollut","1500":"1500","1520":"1520","1603":"1603","British Colonial America":"British Colonial America","England":"Englanti, Yhdistynyt kuningaskunta"},"fr":{"1500–":"1500–Décédée","1500–Male":"1500–Décédé","1520–1603":"1520–1603","1500–Female":"1500–Décédée","1500":"1500","1520":"1520","1603":"1603","British Colonial America":"Amérique coloniale britannique","England":"Angleterre, Royaume-Uni","lifeSummary":"Travis est née en 1500, à Amérique coloniale britannique. Elle a eu au moins 1 fils avec Travis."},"de":{"1500–":"1500–Verstorben","1500–Male":"1500–Verstorben","1520–1603":"1520–1603","1500–Female":"1500–Verstorben","1500":"1500","1520":"1520","1603":"1603","British Colonial America":"British Colonial America","England":"England, United Kingdom","lifeSummary":"Travis wurde 1500 in British Colonial America geboren. Sie hatte mit Travis mindestens 1 Sohn."},"ht":{"1500–":"1500–Desede","1500–Male":"1500–Desede","1520–1603":"1520–1603","1500–Female":"1500–Desede","1500":"1500","1520":"1520","1603":"1603","British Colonial America":"British Colonial America","England":"Angletè, United Kingdom"},"hu":{"1500–":"1500–elhunyt","1500–Male":"1500–elhunyt","1520–1603":"1520–1603","1500–Female":"1500–elhunyt","1500":"1500","1520":"1520","1603":"1603","British Colonial Amer