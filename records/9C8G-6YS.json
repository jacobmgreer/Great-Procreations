i>Sinterklaas</i>)."],"variants":[{"name":"Nickolas","meanings":["Mainly U.S.: variant spelling of   Nicholas  , influenced by the short form   Nick ."]},{"name":"Nicolas","meanings":["From Late Greek.  See  <b>Nicholas</b> ."]}]}],"lifeSummary":"Mrs. Nicholas Deyvill was born about 1254, in Derbyshire, England, United Kingdom. She had at least 1 daughter with Nicholas Deyvill."},"et":{"ABT 1254–":"umbes 1254–Surnud","1245–Male":"1245–Surnud","1249–Male":"1249–Surnud","1324–Female":"1324–Surnud","1269–Female":"1269–Surnud","1254–Female":"1254–Surnud","1249":"1249","1269":"1269","1324":"1324","ABT 1254":"umbes 1254","1245":"1245","1254":"1254","about 1324":"umbes 1324","Abt 1269":"umbes 1269","(of, Herthull, Derbyshire, England)":"Derbyshire, Inglismaa, United Kingdom","Baginton &Pooley, Warwickshire, England":"Baginton, Warwickshire, Inglismaa, United Kingdom","Herthull, Derbyshire, England":"Derbyshire, England"},"fi":{"ABT 1254–":"noin 1254–Kuollut","1245–Male":"1245–Kuollut","1249–Male":"1249–Kuollut","1324–Female":"1324–Kuollut","1269–Female":"1269–Kuollut","1254–Female":"1254–Kuollut","1249":"1249","1269":"1269","1324":"1324","ABT 1254":"noin 1254","1245":"1245","1254":"1254","about 1324":"noin 1324","Abt 1269":"noin 1269","(of, Herthull, Derbyshire, England)":"Derbyshire, Englanti, Yhdistynyt kuningaskunta","Baginton &Pooley, Warwickshire, England":"Baginton, Warwickshire, Englanti, Yhdistynyt kuningaskunta","Herthull, Derbyshire, England":"Derbyshire, England"},"fr":{"ABT 1254–":"environ 1254–Décédée","1245–Male":"1245–Décédé","1249–Male":"1249–Décédé","1324–Female":"1324–Décédée","1269–Female":"1269–Décédée","1254–Female":"1254–Décédée","1249":"1249","1269":"1269","1324":"1324","ABT 1254":"environ 1254","1245":"1245","1254":"1254","about 1324":"environ 1324","Abt 1269":"environ 1269","(of, Herthull, Derbyshire, England)":"Derbyshire, Angleterre, Royaume-Uni","Baginton &Pooley, Warwickshire, England":"Baginton, Warwickshire, Angleterre, Royaume-Uni","Herthull