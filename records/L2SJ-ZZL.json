86","1052–1126":"1052–1126","1057–Female":"1057–Afdød","1126":"1126","before 1099":"før 1099","1156":"1156","1057":"1057","1099":"1099","1186":"1186","1087":"1087","1052":"1052","1082":"1082","Skye, Inverness-shire, Scotland":"Skye, Inverness-shire, Skotland","Scotland":"Skotland"},"nl":{"1082–1156":"1082–1156","1087–Female":"1087–Overleden","1099–1186":"1099–1186","1052–1126":"1052–1126","1057–Female":"1057–Overleden","1126":"1126","before 1099":"vóór 1099","1156":"1156","1057":"1057","1099":"1099","1186":"1186","1087":"1087","1052":"1052","1082":"1082","Skye, Inverness-shire, Scotland":"Skye, Inverness-shire, Schotland","Scotland":"Schotland"},"en":{"1082–1156":"1082–1156","1087–Female":"1087–Deceased","1099–1186":"1099–1186","1052–1126":"1052–1126","1057–Female":"1057–Deceased","1126":"1126","before 1099":"before 1099","1156":"1156","1057":"1057","1099":"1099","1186":"1186","1087":"1087","1052":"1052","1082":"1082","Skye, Inverness-shire, Scotland":"Skye, Inverness-shire, Scotland","Scotland":"Scotland","nameMeanings":[{"name":"MacKinnon","type":"LAST","attribution":"Dictionary of American Family Names © Patrick Hanks 2003, 2006.","meanings":["Scottish:  see  McKinnon  ."],"variants":[{"name":"McKinnon","meanings":["Scottish:","Anglicized form of Gaelic <b>Mac Fhionghuin</b>, a patronymic from a Gaelic personal name meaning ‘fair born’ or ‘fair son’ (compare   Kevin  ).","the name has also been ‘translated’ as   Love  , and has been taken as being from Gaelic <b>Mac Ionmhuinn</b> ‘son of the beloved one’."]},{"name":"Kinnon","meanings":["Scottish: shortened form of   McKinnon  ."]}]},{"name":"Kenneth","type":"FIRST","attribution":"Dictionary of First Names © Patrick Hanks and Flavia Hodges 1990, 2003, 2006.","meanings":["Of Scottish origin: Anglicized form of two different Gaelic names, <i>Cinaed</i> and <i>Cainnech</i>. The former was the Gaelic name of Kenneth mac Alpin (  d. 858 ), first king of the united Picts and Scots. The latter survives today in Scotland as the common Gaelic name Coinneach . Since early in the 20th century <i>Kenneth</i> has been in regular use and enjoyed great popularity as a given name well beyond the borders of Scotland."],"variants":[{"name":"Kennith","meanings":["Of Scottish origin: Anglicized form of two different Gaelic names, <i>Cinaed</i> and <i>Cainnech</i>. The former was the Gaelic name of Kenneth mac Alpin (  d. 858 ), first king of the united Picts and Scots. The latter survives today in Scotland as the common Gaelic name Coinneach . Since early in the 20th century <i>Kenneth</i> has been in regular use and enjoyed great popularity as a given name well beyond the borders of Scotland."]}]}],"lifeSummary":"When Kenneth MacKinnon was born in 1082, in Scotland, his father, Chief Lachlan Royal MacKinnon, was 30 and his mother, Chiefess Lachlan Royal MacKinnon, was 26. He married Mrs. Kenneth MacKinnon before 1099, in Scotland. They were the parents of at least 1 son. He died in 1156, in Skye, Inverness-shire, Scotland, at the age of 74."},"et":{"1082–1156":"1082–1156","1087–Female":"1087–Surnud","1099–1186":"1099–1186","1052–1126":"1052–1126","1057–Female":"1057–Surnud","1126":"1126","before 1099":"enne 1099","1156":"1156","1057":"1057","1099":"1099","1186":"1186","1087":"1087","1052":"1052","1082":"1082","Skye, Inverness-shire, Scotland":"Skye, Inverness-shire, Scotland","Scotland":"Scotland"},"fi":{"1082–1156":"1082–1156","1087–Female":"1087–Kuollut","1099–1186":"1099–1186","1052–1126":"1052–1126","1057–Female":"1057–Kuollut","1126":"1126","before 1099":"ennen vuotta 1099","1156":"1156","1057":"1057","1099":"1099","1186":"1186","1087":"1087","1052":"1052","1082":"1082","Skye, Inverness-shire, Scotland":"Skye, Inverness-shire, Scotland","Scotland":"Scotland"},"fr":{"1082–1156":"1082–1156","1087–Female":"1087–Décédée","1099–1186":"1099–1186","1052–1126":"1052–1126","1057–Female":"1057–Décédée","1126":"1126","before 1099":"avant 1099","1156":"1156","1057":"1057","1099":"1099","1186":"1186"