":"1270–preminula","1236–Male":"1236–preminuo","1264–1355":"1264–1355","1267–Male":"1267–preminuo","1252–Male":"1252–preminuo","about 1270":"oko 1270.","1236":"1236","1268":"1268","1267":"1267","1355":"1355","1264":"1264","1252":"1252","1351":"1351","1270":"1270","Cople, Bedfordshire, England, United Kingdom":"Cople, Bedfordshire, Engleska, United Kingdom"},"cs":{"about 1270–":"okolo 1270–Zesnulá","1268–1351":"1268–1351","1270–Female":"1270–Zesnulá","1236–Male":"1236–Zesnulý","1264–1355":"1264–1355","1267–Male":"1267–Zesnulý","1252–Male":"1252–Zesnulý","about 1270":"okolo 1270","1236":"1236","1268":"1268","1267":"1267","1355":"1355","1264":"1264","1252":"1252","1351":"1351","1270":"1270","Cople, Bedfordshire, England, United Kingdom":"Cople, Bedfordshire, Anglie, United Kingdom"},"da":{"about 1270–":"omkring 1270–Afdød","1268–1351":"1268–1351","1270–Female":"1270–Afdød","1236–Male":"1236–Afdød","1264–1355":"1264–1355","1267–Male":"1267–Afdød","1252–Male":"1252–Afdød","about 1270":"omkring 1270","1236":"1236","1268":"1268","1267":"1267","1355":"1355","1264":"1264","1252":"1252","1351":"1351","1270":"1270","Cople, Bedfordshire, England, United Kingdom":"Cople, Bedfordshire, England, United Kingdom"},"nl":{"about 1270–":"circa 1270–Overleden","1268–1351":"1268–1351","1270–Female":"1270–Overleden","1236–Male":"1236–Overleden","1264–1355":"1264–1355","1267–Male":"1267–Overleden","1252–Male":"1252–Overleden","about 1270":"circa 1270","1236":"1236","1268":"1268","1267":"1267","1355":"1355","1264":"1264","1252":"1252","1351":"1351","1270":"1270","Cople, Bedfordshire, England, United Kingdom":"Cople, Bedfordshire, Engeland, Verenigd Koninkrijk"},"en":{"about 1270–":"about 1270–Deceased","1268–1351":"1268–1351","1270–Female":"1270–Deceased","1236–Male":"1236–Deceased","1264–1355":"1264–1355","1267–Male":"1267–Deceased","1252–Male":"1252–Deceased","about 1270":"about 1270","1236":"1236","1268":"1268","1267":"1267","1355":"1355","1264":"1264","1252":"1252","1351":"1351","1270":"1270","Cople, Bedfordshire, England, United Kingdom":"Cople, Bedfordshire, England, United Kingdom","nameMeanings":[{"name":"Wake","type":"LAST","attribution":"Dictionary of American Family Names © Patrick Hanks 2003, 2006.","meanings":["English:","occupational name for ‘(man of) the watch’, from Middle English <i>wak</i>, <i>wake</i> ‘wake, vigil, watch, period of guard duty’ (Old English <i>wacu</i>, Old Norse <i>vaka</i>). It alternates with the synonymous Middle English <i>wache</i> (Old English <i>wacce</i>), hence the variant <b>Watch</b>. The surname was also interchangeable with   Waite   (the equivalent Old French term) which, like <i>Wake</i>, was sometimes translated as Latin <i>vigil</i> ‘(one who is) watchful, alert’. Compare the synonymous   Vail  . When the bearers had high social status, the surname probably denoted an officer with responsibility for the security of a castle, town, or royal person. Compare   Wakeman  .","variant of   Wack  ."],"variants":[{"name":"Vail","meanings":["English: occupational name from Old French <i>de la veille</i> ‘of the watch, watchman’, with loss of <i>de</i>; compare   Wake  . There has been some confusion with the topographic name   Vale   and the nickname   Veal  .","Scottish: shortened and altered form of   McPhail  , Anglicized form of Gaelic <b>Mac Phàil</b> ‘son of Paul’.","Irish: variant of   Veale  ."]},{"name":"Waite","meanings":["English (of Norman origin): occupational name for a watchman, either in a town or castle, from Anglo-Norman French <i>waite</i> ‘watchman, member of the watch’ (of ancient Germanic origin; compare   Wachter  ). In the Middle Ages the town waits typically combined the functions of watchmen and musicians through being trumpeters or pipers. There may also have been some late confusion with   White   or   Wheat  ."]}]},{"name":"Rose","type":"FIRST","attribution":"Dictionary of First Names © Patrick Hanks and Flavia Hodges 1990, 2003, 2006.","meanings":["Ostensibly from the vocabulary word denoting the flower (Latin <i>rosa</i>). However, the name was in use throughout the Middle Ages, long before any of the other girls' names derived from flowers, which are generally of 19th-century origin. In part it may refer to the flower as a symbol of the Virgin Mary, but it seems more likely that it also has a Germanic origin, probably as a short form of various girls' names based on <i>hros</i> ‘horse’ or <i>hrōd</i> ‘fame’. The Latinate form <i>Rohesia</i> is commonly found in documents of the Middle Ages. As well as being a name in its own right, it is currently used as a short form of   Rosemary   and, less often (because of their different pronunciation), of other names beginning <i>Ros-</i>, such as   Rosalind   and   Rosamund ."],"variants":[]}],"lifeSummary":"Rose Wake was born about 1270, in Cople, Bedfordshire, England, United Kingdom as the daughter of Sir Ralph Wake. She married William Mordaunt about 1266, in Turvey, Bedfordshire, England. They were the parents of at least 2 sons."},"et":{"about 1270–":"umbes 1270–Surnud","1268–1351":"1268–1351","1270–Female":"1270–Surnud","1236–Male":"1236–Surnud","1264–1355":"1264–1355","1267–Male":"1267–Surnud","1252–Male":"1252–Surnud","about 1270":"umbes 1270","1236":"1236","1268":"1268","1267":"1267","1355":"1355","1264":"1264","1252":"1252","1351":"1351","1270":"1270","Cople, Bedfordshire, England, United Kingdom":"Cople, Bedfordshire, Inglismaa, United Kingdom"},"fi":{"about 1270–":"noin 1270–Kuollut","1268–1351":"1268–1351","1270–Female":"1270–Kuollut","1236–Male":"1236–Kuollut","1264–1355":"1264–1355","1267–Male":"1267–Kuollut","1252–Male":"1252–Kuollut","about 1270":"noin 1270","1236":"1236","1268":"1268","1267":"1267","1355":"1355","1264":"1264","1252":"1252","1351":"1351","1270":"1270","Cople, Bedfordshire, England, United Kingdom":"Cople, Bedfordshire, Englanti, Yhdistynyt kuningaskunta"},"fr":{"about 1270–":"environ 1270–Décédée","1268–1351":"1268–1351","1270–Female":"1270–Décédée","1236–Male":