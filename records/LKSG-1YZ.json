bout 1167","1167":"1167","1134":"1134","1166":"1166","1164":"1164","about 1163":"about 1163","of,Swanleigh,Chesh,Engl":"Cheshire, England, United Kingdom","Swanleigh, Cheshire, England":"Cheshire, England, United Kingdom","Shavington cum Gresty, Cheshire, England":"Shavington cum Gresty, Cheshire, England","Swanlegh, Cheshire, England":"Cheshire, England, United Kingdom","nameMeanings":[{"name":"Woodnett","type":"LAST","meanings":["Anglo-Saxon: Wude, wood, and hnut, a nut, meaning a wood nut"],"variants":[]},{"name":"Roger","type":"FIRST","attribution":"Dictionary of First Names © Patrick Hanks and Flavia Hodges 1990, 2003, 2006.","meanings":["From an Old French personal name, <i>Rog(i)er</i>, of Germanic (Frankish) origin, from <i>hrōd</i> ‘fame’ + <i>gār</i>, <i>gēr</i> ‘spear’. This was adopted by the Normans and introduced by them to Britain, replacing the native Old English form <i>Hrōðgār</i>. <i>Roger</i> was one of the most popular boys' names throughout the medieval period, but less so after the Reformation, though it has continued in regular use to the present day.  Roger, Count of Sicily  (  <i>c.</i>1031–1101 ), son of Tancred, recovered Sicily from the Arabs. His son, also called Roger, ruled Sicily as king, presiding over a court noted for its splendour and patronage of the arts."],"variants":[{"name":"Rodger","meanings":["Variant spelling of   Roger  , in part from the surname derived from the given name in the Middle Ages."]}]}],"historicEvents":[{"id":1705187,"age":77,"year":"1215","julianDay":2164830,"title":"Magna Carta","description":"King John of England agreed to a charter of rights called the Magna Carta. The document was originally drafted by the Archbishop of Canterbury to establish peace between King John and a group of rebel barons. The Magna Carta was completed in 1215 and is now considered to be one of the greatest constitutional documents of all time.","url":"https://www.nationalarchives.gov.uk/education/medieval/magna-carta/","urlTitle":"National Archives - Magna Carta","jurisdictionLevel":2},{"id":1705188,"age":86,"year":"1224","julianDay":2168117,"title":"France Declares War on England","description":"France declared war on England as Louis VIII of France attacked Poitou and northern Gascony.","jurisdictionLevel":2}],"lifeSummary":"Mrs. Roger Woodnett was born in 1138, in Shavington cum Gresty, Cheshire, England. She married Roger Woodenoth about 1163, in Cheshire, England, United Kingdom. They were the parents of at least 3 sons."},"et":{"1138–":"1138–Surnud","1134–Male":"1134–Surnud","1164–Male":"1164–Surnud","1166–Male":"1166–Surnud","1167–Male":"1167–Surnud","1138–Female":"1138–Surnud","1138":"1138","1215":"1215","1224":"1224","ABT 1166":"umbes 1166","ABT 1167":"umbes 1167","1167":"1167","1134":"1134","1166":"1166","1164":"1164","about 1163":"umbes 1163","of,Swanleigh,Chesh,Engl":"Cheshire, Inglismaa, United Kingdom","Swanleigh, Cheshire, England":"Cheshire, Inglismaa, United Kingdom","Shavington cum Gresty, Cheshire, England":"Shavington cum Gresty, Cheshire, England","Swanlegh, Cheshire, England":"Cheshire, Inglismaa, United Kingdom"},"fi":{"1138–":"1138–Kuollut","1134–Male":"1134–Kuollut","1164–Male":"1164–Kuollut","1166–Male":"1166–Kuollut","1167–Male":"1167–Kuollut","1138–Female":"1138–Kuollut","1138":"1138","1215":"1215","1224":"1224","ABT 1166":"noin 1166","ABT 1167":"noin 1167","1167":"1167","1134":"1134","1166":"1166","1164":"1164","about 1163":"noin 1163","of,Swanleigh,Chesh,Engl":"Cheshire, Englanti, Yhdistynyt kuningaskunta","Swanleigh, Cheshire, England":"Cheshire, Englanti, Yhdistynyt kuningaskunta","Shavington cum Gresty, Cheshire, England":"Shavington cum Gresty, Cheshire, England","Swanlegh, Cheshire, England":"Cheshire, Englanti, Yhdistynyt kuningaskunta"},"fr":{"1138–":"1138–Décédée","1134–Male":"1134–Décédé","1164–Male":"1164–Décédé","1166–Male":"1166–Décédé","1167–Male":"1167–Décédé","1138–Female":"1138–Décédée","1138":"1138","1215":"1215","1224":"1224","ABT 1166":"envi