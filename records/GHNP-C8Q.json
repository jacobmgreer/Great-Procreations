le":"1265–Deceased","1181–Male":"1181–Deceased","1180–Female":"1180–Deceased","1264":"1264","1263":"1263","1181":"1181","1290":"1290","1180":"1180","1316":"1316","1315":"1315","1259":"1259","1215":"1215","1237":"1237","1302":"1302","1224":"1224","1200":"1200","Abt 1264":"about 1264","1265":"1265","about 1200":"about 1200","about 1265":"about 1265","1317":"1317","Somersetshire, England":"Somerset, England","Ashington, Somerset, England":"Ashington, Somerset, England, United Kingdom","Klive, Somerset, England":"Somerset, England, United Kingdom","nameMeanings":[{"name":"de","type":"LAST","attribution":"Dictionary of American Family Names © Patrick Hanks 2003, 2006.","meanings":["Some characteristic forenames:  Indian Dilip, Anirban, Gopal, Alok, Anindya, Arunava, Asit, Asok, Dibyendu, Goutam, Indra, Indranil.","Indian: variant of   Dey  ."],"variants":[{"name":"Dey","meanings":["Some characteristic forenames:  Indian Ashit, Indu, Naina, Partha, Soumya, Ajit, Anjan, Anjana, Anup, Arjun, Arun, Ashim.","English, Scottish, and Welsh: variant of   Day  .","German: topographic name from a field name in North Rhine-Westphalia, denoting a sizeable piece of land, from Middle Low German <i>dē</i> ‘thigh’ (referring to the shape of the property)."]}]},{"name":"Furneaux","type":"LAST","attribution":"Dictionary of American Family Names © Patrick Hanks 2003, 2006.","meanings":["English (of Norman origin): habitational name from either of two places in Normandy called Fourneaux ‘(the) furnaces’, one in Manche, the other in Calvados. Compare   Furnace   and   Furnell  ."],"variants":[{"name":"Furney","meanings":["English (of Norman origin): variant of   Furneaux  . It may sometimes have been confused with   Furness  ; the two names have variants in common (see   Furnace  )."]},{"name":"Fornell","meanings":["English: variant of   Furneaux  , or a nickname from Middle English <i>fornel</i> ‘small oven or furnace’."]},{"name":"Furnace","meanings":["English:","(Cumbria and Durham): variant of   Furness  .","(of Norman origin): sometimes a variant of   Furneaux  ."]},{"name":"Furnell","meanings":["English:","variant of   Furneaux  .","alternatively, perhaps a variant of   Farnell  . Compare   Funnell  ."]}]},{"name":"Matthew","type":"FIRST","attribution":"Dictionary of First Names © Patrick Hanks and Flavia Hodges 1990, 2003, 2006.","meanings":["form of the name of the Christian evangelist, author of the first gospel in the New Testament. His name is a form of the Hebrew name <i>Mattathia</i>, meaning ‘gift of God’, which is fairly common in the Old Testament, being rendered in the Authorized Version in a number of different forms: <i>Mattan(i)ah</i>, <i>Mattatha(h)</i>, <i>Mattithiah</i>, <i>Mattathias</i>, and so on. In the Authorized Version, the evangelist is regularly referred to as <i>Matthew</i>, while the apostle chosen to replace Judas Iscariot is distinguished as   Matthias .  A related name from the same Hebrew roots, but reversed, is   Jonathan .  Throughout the English-speaking world <i>Matthew</i> has been particularly popular since the 1970s."],"variants":[{"name":"Mathew","meanings":["Variant spelling of   Matthew ."]}]}],"historicEvents":[{"id":1705187,"age":15,"year":"1215","julianDay":2164830,"title":"Magna Carta","description":"King John of England agreed to a charter of rights called the Magna Carta. The document was originally drafted by the Archbishop of Canterbury to establish peace between King John and a group of rebel barons. The Magna Carta was completed in 1215 and is now considered to be one of the greatest constitutional documents of all time.","url":"https://www.nationalarchives.gov.uk/education/medieval/magna-carta/","urlTitle":"National Archives - Magna Carta","jurisdictionLevel":2},{"id":1705188,"age":24,"year":"1224","julianDay":2168117,"title":"France Declares War on England","description":"France declared war on England as Louis VIII of France attacked Poitou and northern Gascony.","jurisdictionLevel":2},{"id":1