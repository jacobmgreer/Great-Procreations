d":"Baconsthorpe, Norfolk, England","Baconsthorpe, North Norfolk District, Norfolk, England, United Kingdom":"Baconsthorpe, Norfolk, Engeland, Verenigd Koninkrijk"},"en":{"1288–1324":"1288–1324","1286–1324":"1286–1324","1310–1394":"1310–1394","1312–Male":"1312–Deceased","1314–Male":"1314–Deceased","1255–Male":"1255–Deceased","1315":"1315","1314":"1314","1324":"1324","1312":"1312","1288":"1288","1310":"1310","1255":"1255","1286":"1286","1394":"1394","1309":"1309","1317":"1317","1290":"1290","Baconsthorpe, Norfolk, England":"Baconsthorpe, Norfolk, England","Baconsthorpe, North Norfolk District, Norfolk, England, United Kingdom":"Baconsthorpe, Norfolk, England, United Kingdom","nameMeanings":[{"name":"Ludham","type":"LAST","attribution":"Dictionary of Family Names in Britain and Ireland © University of the West of England 2016","meanings":["English: locative name from Ludham (Norfolk)."],"variants":[]},{"name":"Margaret","type":"FIRST","attribution":"Dictionary of First Names © Patrick Hanks and Flavia Hodges 1990, 2003, 2006.","meanings":["An extremely common given name from the Middle Ages onwards, derived via Old French <i>Marguerite</i> and Latin <i>Margarita</i> from Greek <i>Margarītēs</i>, from <i>margaron</i> ‘pearl’, a word ultimately of Hebrew origin. The name was always understood to mean ‘pearl’ throughout the Middle Ages. The first  St Margaret  was martyred at Antioch in Pisidia during the persecution instigated by the  Emperor Diocletian  in the early 4th century. However, there is some doubt about her name, as the same saint is venerated in the Orthodox Church as   Marina .  There were several other saintly bearers of the name, including St Margaret of Scotland (  d. 1093 ), wife of  King Malcolm Canmore  and daughter of Edmund Ironside of England. It was also the name of the wife of  Henry VI  of England,  Margaret of Anjou  (  1430–82 ), and of  Margaret Tudor  (  1489–1541 ), sister of  Henry VIII , who married James IV of Scotland and ruled as regent there after his death.  See also  Margery  ,   Marjorie ."],"variants":[{"name":"Margareta","meanings":["From the Latin form of Greek <i>Margarītēs</i>.  See  <b>Margaret</b>   ."]},{"name":"Margaretta","meanings":["Formed from Margaret."]}]}],"historicEvents":[{"id":1705190,"age":2,"year":"1290","julianDay":2192224,"title":"Jews Expelled From England","description":"After years of anti-Semitic behavior, King Edward I expelled Jews from England in 1290.","jurisdictionLevel":2},{"id":1705191,"age":27,"year":"1315","toYear":"1317","julianDay":2201354,"title":"Famine Strikes Europe","description":"A famine caused by cold winters and wet summers across Europe caused millions to die due to starvation. Desperation from hunger caused high levels of crime, stampedes in bread lines in London, infanticide, and even cannibalism throughout Europe.","jurisdictionLevel":2}],"lifeSummary":"Margaret Ludham was born in 1288, in Baconsthorpe, Norfolk, England as the daughter of Henry Ludham. She married Henry Bacon in 1309, in Baconsthorpe, Norfolk, England. They were the parents of at least 3 sons. She died in 1324, in her hometown, at the age of 36."},"et":{"1288–1324":"1288–1324","1286–1324":"1286–1324","1310–1394":"1310–1394","1312–Male":"1312–Surnud","1314–Male":"1314–Surnud","1255–Male":"1255–Surnud","1315":"1315","1314":"1314","1324":"1324","1312":"1312","1288":"1288","1310":"1310","1255":"1255","1286":"1286","1394":"1394","1309":"1309","1317":"1317","1290":"1290","Baconsthorpe, Norfolk, England":"Baconsthorpe, Norfolk, England","Baconsthorpe, North Norfolk District, Norfolk, England, United Kingdom":"Baconsthorpe, Norfolk, Inglismaa, United Kingdom"},"fi":{"1288–1324":"1288–1324","1286–1324":"1286–1324","1310–1394":"1310–1394","1312–Male":"1312–Kuollut","1314–Male":"1314–Kuollut","1255–Male":"1255–Kuollut","1315":"1315","1314":"1314","1324":"1324","1312":"1312","1288":"1288","1310":"1310","1255":"1255","1286":"1286","1394":"1394","1309":"1309","1317":"1317","1290":"1290","B