75","1130":"1130","1174":"1174","1163":"1163","1150":"1150","1160":"1160","1238":"1238","1115":"1115","1145":"1145","1100":"1100","before 1175":"před 1175","1229":"1229","Glenorchy, Argyll, Scotland":"Glenorchy, Argyll, Skotsko, United Kingdom","Scotland":"Scotland"},"da":{"1130–before 1175":"1130–før 1175","1130–1175":"1130–1175","1163–Male":"1163–Afdød","1145–Male":"1145–Afdød","1132–1220":"1132–1220","1150–1220":"1150–1220","1160–1229":"1160–1229","1175–1238":"1175–1238","1100–1174":"1100–1174","1115–Female":"1115–Afdød","about 1160":"omkring 1160","1220":"1220","1132":"1132","1175":"1175","1130":"1130","1174":"1174","1163":"1163","1150":"1150","1160":"1160","1238":"1238","1115":"1115","1145":"1145","1100":"1100","before 1175":"før 1175","1229":"1229","Glenorchy, Argyll, Scotland":"Glenorchy, Argyll, Skotland, United Kingdom","Scotland":"Skotland"},"nl":{"1130–before 1175":"1130–vóór 1175","1130–1175":"1130–1175","1163–Male":"1163–Overleden","1145–Male":"1145–Overleden","1132–1220":"1132–1220","1150–1220":"1150–1220","1160–1229":"1160–1229","1175–1238":"1175–1238","1100–1174":"1100–1174","1115–Female":"1115–Overleden","about 1160":"circa 1160","1220":"1220","1132":"1132","1175":"1175","1130":"1130","1174":"1174","1163":"1163","1150":"1150","1160":"1160","1238":"1238","1115":"1115","1145":"1145","1100":"1100","before 1175":"vóór 1175","1229":"1229","Glenorchy, Argyll, Scotland":"Glenorchy, Argyll, Schotland, Verenigd Koninkrijk","Scotland":"Schotland"},"en":{"1130–before 1175":"1130–before 1175","1130–1175":"1130–1175","1163–Male":"1163–Deceased","1145–Male":"1145–Deceased","1132–1220":"1132–1220","1150–1220":"1150–1220","1160–1229":"1160–1229","1175–1238":"1175–1238","1100–1174":"1100–1174","1115–Female":"1115–Deceased","about 1160":"about 1160","1220":"1220","1132":"1132","1175":"1175","1130":"1130","1174":"1174","1163":"1163","1150":"1150","1160":"1160","1238":"1238","1115":"1115","1145":"1145","1100":"1100","before 1175":"before 1175","1229":"1229","Glenorchy, Argyll, Scotland":"Glenorchy, Argyll, Scotland, United Kingdom","Scotland":"Scotland","nameMeanings":[{"name":"MacGregor","type":"LAST","attribution":"Dictionary of American Family Names © Patrick Hanks 2003, 2006.","meanings":["Scottish:  see  McGregor  ."],"variants":[{"name":"McGregor","meanings":["Scottish: Anglicized form of Gaelic <b>Mac Griogair</b> or <b>Mac Greagair</b> ‘son of <i>Griogar</i>’, Gaelic form of the personal name   Gregory  . Compare   Grierson  .","History: The Scottish Highland clan McGregor claims descent from the king of Picts and Scots Kenneth MacAlpin (Cináed mac Ailpín; 810–858  AD ). The origins of the clan are unclear. In the 13th century it was established on lands on the shores of Loch Awe and already in conflict with its neighbors of Clan Campbell. By the 16th century the McGregors had retreated deep into Glen Strae and acquired the nickname ‘Children of the Mist’. In 1603 the clan was abolished by royal edict and many members of the clan changed their surname. A year later, the chief of Clan McGregor and eleven of his followers were hanged in Edinburgh. Despite the proscription, the clan survived and supported the king in the Scottish Civil War (1644–51). The exploits of the Jacobite leader Rob Roy McGregor (1671–1734) were romanticized in a novel by Sir Walter Scott. The proscription was eventually repealed in 1774."]}]},{"name":"William","type":"FIRST","attribution":"Dictionary of First Names © Patrick Hanks and Flavia Hodges 1990, 2003, 2006.","meanings":["Probably the most successful of all the Old French names of Germanic origin that were introduced to England by the Normans. It is derived from Germanic <i>wil</i> ‘will, desire’ + <i>helm</i> ‘helmet, protection’. The fact that it was borne by the Conqueror himself does not seem to have inhibited its favour with the ‘conquered’ population: in the first century after the Conquest it was the commonest male name of all, and not only among the Normans. In the later Middle Ages it was overtaken by   John  , but continued to run second to that name until the 20th century, when the picture became more fragmented."],"variants":[]}],"lifeSummary":"When Lord William Gillefealan MacGregor was born in 1130, in Glenorchy, Argyll, Scotland, United Kingdom, his father, Sir Malcolm MacGregor 8th Lord of Glenorchy, was 30 and his mother, Marjory FitzWilliam, was 16. He had at least 1 son with Margaret De Lindsay. He died before 1175."},"et":{"1130–before 1175":"1130–enne 1175","1130–1175":"1130–1175","1163–Male":"1163–Surnud","1145–Male":"1145–Surnud","1132–1220":"1132–1220","1150–1220":"1150–1220","1160–1229":"1160–1229","1175–1238":"1175–1238","1100–1174":"1100–1174","1115–Female":"1115–Surnud","about 1160":"umbes 1160","1220":"1220","1132":"1132","1175":"1175","1130":"1130","1174":"1174","1163":"1163","1150":"1150","1160":"1160","1238":"1238","1115":"1115","1145":"1145","1100":"1100","before 1175":"enne 1175","1229":"1229","Glenorchy, Argyll, Scotland":"Glenorchy, Argyll, Šotimaa, United Kingdom","Scotland":"Scotland"},"fi":{"1130–before 1175":"1130–ennen vuotta 1175","1130–1175":"1130–1175","1163–Male":"1163–Kuollut","1145–Male":"1145–Kuollut","1132–1220":"1132–1220","1150–1220":"1150–1220","1160–1229":"1160–1229","1175–1238":"1175–1238","1100–1174":"1100–1174","1115–Female":"1115–Kuollut","about 1160":"noin 1160","1220":"1220","1132":"1132","1175":"1175","1130":"1130","1174":"1174","1163":"1163","1150":"1150","1160":"1160","1238":"1238","1115":"1115","1145":"1145","1100":"1100","before 1175":"ennen vuotta 1175","1229":"1229","Glenorchy, Argyll, Scotland":"Glenorchy, Argyll, Skotlanti, Yhdistynyt kuningaskunta","Scotland":"Scotland"},"fr":{"1130–before 1175":"1130–avant 1175","1130–1175":"1130–1175","1163–Male":"1163–Décédé","1145–Male":"1145–Décédé","1132–1220":"1132–1220","1150–1220":"1150–1220","1160–1229":"1160–1229","1175–1238":"1175–1238","1100–1174":"1100–1174","1115–Female":"1115–Décédée","about 1160":"environ 1160","1220":"1220","1132":"11