eden","1311–1388":"1311–1388","–1350":"–1350","1250–1286":"1250–1286","Abt 1311":"circa 1311","Abt 1388":"circa 1388","1388":"1388","1311":"1311","1310":"1310","1286":"1286","1285":"1285","1350":"1350","1250":"1250","Abt 1280":"circa 1280","1280":"1280","Buckinghamshire, England":"Buckinghamshire, Engeland, Verenigd Koninkrijk","England":"Engeland, Verenigd Koninkrijk","Hampden, Buckinghamshire, England":"Buckinghamshire, England","Sussex, England":"Sussex, England"},"en":{"Abt 1280–1388":"about 1280–1388","1280–1388":"1280–1388","1285–Female":"1285–Deceased","1311–1388":"1311–1388","–1350":"–1350","1250–1286":"1250–1286","Abt 1311":"about 1311","Abt 1388":"about 1388","1388":"1388","1311":"1311","1310":"1310","1286":"1286","1285":"1285","1350":"1350","1250":"1250","Abt 1280":"about 1280","1280":"1280","Buckinghamshire, England":"Buckinghamshire, England, United Kingdom","England":"England, United Kingdom","Hampden, Buckinghamshire, England":"Buckinghamshire, England","Sussex, England":"Sussex, England","nameMeanings":[{"name":"Dakeney","type":"LAST","attribution":"Dictionary of Family Names in Britain and Ireland © University of the West of England 2016","meanings":["English:  see  Hackney  ."],"variants":[{"name":"Hackney","meanings":["English:","habitational name from Hackney in Greater London, named from an Old English personal name <i>Haca</i> (genitive <i>Hacan</i>) + <i>ēg</i> ‘island, dry ground in marshland’.","perhaps from Middle English <i>hakenei</i> (Old French <i>haquenée</i>), an ambling horse or mare, especially one considered suitable for women to ride; perhaps therefore a metonymic occupational name for a breeder or keeper of such horses and short for <i>Hakeneyman</i>. This surname has also been found in Scotland since medieval times."]}]},{"name":"Roger","type":"FIRST","attribution":"Dictionary of First Names © Patrick Hanks and Flavia Hodges 1990, 2003, 2006.","meanings":["From an Old French personal name, <i>Rog(i)er</i>, of Germanic (Frankish) origin, from <i>hrōd</i> ‘fame’ + <i>gār</i>, <i>gēr</i> ‘spear’. This was adopted by the Normans and introduced by them to Britain, replacing the native Old English form <i>Hrōðgār</i>. <i>Roger</i> was one of the most popular boys' names throughout the medieval period, but less so after the Reformation, though it has continued in regular use to the present day.  Roger, Count of Sicily  (  <i>c.</i>1031–1101 ), son of Tancred, recovered Sicily from the Arabs. His son, also called Roger, ruled Sicily as king, presiding over a court noted for its splendour and patronage of the arts."],"variants":[{"name":"Rodger","meanings":["Variant spelling of   Roger  , in part from the surname derived from the given name in the Middle Ages."]}]}],"lifeSummary":"Roger Dakeney was born about 1280, in England, United Kingdom as the son of Roger Dakeny I. He married Joan Cave in 1310, in Buckinghamshire, England, United Kingdom. They were the parents of at least 2 daughters. He died in 1388, in Buckinghamshire, England, United Kingdom, at the age of 109."},"et":{"Abt 1280–1388":"umbes 1280–1388","1280–1388":"1280–1388","1285–Female":"1285–Surnud","1311–1388":"1311–1388","–1350":"–1350","1250–1286":"1250–1286","Abt 1311":"umbes 1311","Abt 1388":"umbes 1388","1388":"1388","1311":"1311","1310":"1310","1286":"1286","1285":"1285","1350":"1350","1250":"1250","Abt 1280":"umbes 1280","1280":"1280","Buckinghamshire, England":"Buckinghamshire, Inglismaa, United Kingdom","England":"Inglismaa, United Kingdom","Hampden, Buckinghamshire, England":"Buckinghamshire, England","Sussex, England":"Sussex, England"},"fi":{"Abt 1280–1388":"noin 1280–1388","1280–1388":"1280–1388","1285–Female":"1285–Kuollut","1311–1388":"1311–1388","–1350":"–1350","1250–1286":"1250–1286","Abt 1311":"noin 1311","Abt 1388":"noin 1388","1388":"1388","1311":"1311","1310":"1310","1286":"1286","1285":"1285","1350":"1350","1250":"1250","Abt 1280":"noin 1280","1280":"1280","Buckinghamshire, England":"Buckinghamshire, Englanti, Yh