le":"Afdød","1156–1214":"1156–1214","1080–1160":"1080–1160","1080":"1080","1214":"1214","1136":"1136","1156":"1156","before 1130":"før 1130","1130":"1130","1160":"1160","Lochiel, Inverness-shire, Scotland":"Inverness-shire, Skotland","Lochiel, Invernesshire, Scotland":"Inverness-shire, Skotland, United Kingdom","Scotland":"Skotland"},"nl":{"1136–1214":"1136–1214","1130–Female":"1130–Overleden","–Female":"Overleden","1156–1214":"1156–1214","1080–1160":"1080–1160","1080":"1080","1214":"1214","1136":"1136","1156":"1156","before 1130":"vóór 1130","1130":"1130","1160":"1160","Lochiel, Inverness-shire, Scotland":"Inverness-shire, Schotland","Lochiel, Invernesshire, Scotland":"Inverness-shire, Schotland, Verenigd Koninkrijk","Scotland":"Schotland"},"en":{"1136–1214":"1136–1214","1130–Female":"1130–Deceased","–Female":"Deceased","1156–1214":"1156–1214","1080–1160":"1080–1160","1080":"1080","1214":"1214","1136":"1136","1156":"1156","before 1130":"before 1130","1130":"1130","1160":"1160","Lochiel, Inverness-shire, Scotland":"Inverness-shire, Scotland","Lochiel, Invernesshire, Scotland":"Inverness-shire, Scotland, United Kingdom","Scotland":"Scotland","nameMeanings":[{"name":"Cameron","type":"LAST","attribution":"Dictionary of American Family Names © Patrick Hanks 2003, 2006.","meanings":["Scottish:","in the Highlands, it is usually a nickname from Gaelic <i>cam</i> ‘crooked, bent’ + <i>sròn</i> ‘nose’.","in the Lowlands it is also a habitational name from any of various places called Cameron, especially in Fife."],"variants":[{"name":"Camren","meanings":["Altered form of Scottish   Cameron  ."]},{"name":"Cambron","meanings":["Spanish (<b>Cambrón</b>): habitational name from any of several places in the provinces of Cáceres and Murcia called Cambrón.","Scottish: altered form of   Cameron  .","French: habitational name from any of the places in Somme and Aisne called Cambron. Alternatively, from a diminutive of <i>c(h)ambre</i> ‘room’ (see   Cambre  )."]},{"name":"Camron","meanings":["Scottish: variant of   Cameron  ."]}]},{"name":"Robert","type":"FIRST","attribution":"Dictionary of First Names © Patrick Hanks and Flavia Hodges 1990, 2003, 2006.","meanings":["One of the many French names of Germanic origin that were introduced into Britain by the Normans; it has since remained in continuous use. It is derived from the nearly synonymous elements <i>hrōd</i> ‘fame’ + <i>berht</i> ‘bright, famous’, and had a native Old English predecessor of similar form (<i>Hreodbeorht</i>), which was supplanted by the Norman name. Two dukes of Normandy in the 11th century bore the name: the father of  William the Conqueror  (sometimes identified with the legendary Robert the Devil), and his eldest son. It was borne also by three kings of Scotland, notably  Robert the Bruce  (  1274–1329 ), who freed Scotland from English domination. The altered short form <i>Bob</i> is very common, but <i>Hob</i> and <i>Dob</i>, which were common in the Middle Ages and gave rise to surnames, are extinct.  See also  Rupert ."],"variants":[]}],"lifeSummary":"Robert Cameron - Fourth Chief of Clan Cameron was born in 1136, in Inverness-shire, Scotland as the son of John Cameron 3rd Chief of Clan Cameron and Mrs. John Cameron. He had at least 1 son with Mrs. Cameron. He died in 1214, in his hometown, at the age of 78, and was buried in Inverness-shire, Scotland."},"et":{"1136–1214":"1136–1214","1130–Female":"1130–Surnud","–Female":"Surnud","1156–1214":"1156–1214","1080–1160":"1080–1160","1080":"1080","1214":"1214","1136":"1136","1156":"1156","before 1130":"enne 1130","1130":"1130","1160":"1160","Lochiel, Inverness-shire, Scotland":"Inverness-shire, Scotland","Lochiel, Invernesshire, Scotland":"Inverness-shire, Šotimaa, United Kingdom","Scotland":"Scotland"},"fi":{"1136–1214":"1136–1214","1130–Female":"1130–Kuollut","–Female":"Kuollut","1156–1214":"1156–1214","1080–1160":"1080–1160","1080":"1080","1214":"1214","1136":"1136","1156":"1156","before 1130":"ennen vuotta 1130","1130":