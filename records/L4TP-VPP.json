oton, Shropshire, England":"英国史洛普爾可托","Cotton, Cheshire, England":"英国爾科頓","lifeSummary":"当Sir William FitzSimmon de Cotton于大约1235年出生在英国史洛普爾可托时，他的父亲Sir Simon FitzWilliam de Cotton41岁，母亲Enid Grosvenor de Maatenloch46岁。他于大约1250年与Enid Grosvenor de Maatenloch在英国结婚。他们至少是1个儿子的父母。他去世于1290年在他的家乡享年56岁。"},"hr":{"about 1235–1290":"oko 1235.–1290.","1225–Male":"1225–preminuo","1233–Male":"1233–preminuo","1235–1290":"1235–1290.","1234–1302":"1234–1302","1190–1270":"1190–1270.","1255–1300":"1255.–1300","1265–1320":"1265.–1320","1195–Male":"1195–preminuo","1190":"1190","about 1250":"oko 1250.","1195":"1195","1270":"1270.","1290":"1290.","1259":"1259","1302":"1302","1225":"1225","about 1228":"oko 1228.","1235":"1235","1300":"1300","1234":"1234","1255":"1255.","1233":"1233","1265":"1265.","1320":"1320","about 1235":"oko 1235.","about 1265":"oko 1265.","Hodnet, Shropshire, England":"Hodnet, Shropshire, England","Northampton, Northamptonshire, England":"Northampton, Northamptonshire, England","England":"England","Coton, Shropshire, England":"Coton, Shropshire, England","Cotton, Cheshire, England":"Cotton, Cheshire, England"},"cs":{"about 1235–1290":"okolo 1235–1290","1225–Male":"1225–Zesnulý","1233–Male":"1233–Zesnulý","1235–1290":"1235–1290","1234–1302":"1234–1302","1190–1270":"1190–1270","1255–1300":"1255–1300","1265–1320":"1265–1320","1195–Male":"1195–Zesnulý","1190":"1190","about 1250":"okolo 1250","1195":"1195","1270":"1270","1290":"1290","1259":"1259","1302":"1302","1225":"1225","about 1228":"okolo 1228","1235":"1235","1300":"1300","1234":"1234","1255":"1255","1233":"1233","1265":"1265","1320":"1320","about 1235":"okolo 1235","about 1265":"okolo 1265","Hodnet, Shropshire, England":"Hodnet, Shropshire, Anglie","Northampton, Northamptonshire, England":"Northampton, Northamptonshire, Anglie","England":"Anglie","Coton, Shropshire, England":"Coton, Shropshire, Anglie","Cotton, Cheshire, England":"Cotton, Cheshire, Anglie"},"da":{"about 1235–1290":"omkring 1235–1290","1225–Male":"1225–