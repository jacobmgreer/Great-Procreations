, England Durham, England, United Kingdom":"Wynyard, Durham, Engeland, Verenigd Koninkrijk","Durham, England":"Durham, Durham, Engeland, Verenigd Koninkrijk"},"en":{"1300 –1342":"from 1300 to 1342–1342","1300–1356":"1300–1356","1340–1380":"1340–1380","1300–1342":"1300–1342","1300 ":"from 1300 to 1342","1356":"1356","1300":"1300","1342":"1342","1340":"1340","1380":"1380","1328":"1328","about 1340":"about 1340","Redmarshall, Durham, England, United Kingdom":"Redmarshall, Durham, England, United Kingdom","Wynyard,Durham, England Durham, England, United Kingdom":"Wynyard, Durham, England, United Kingdom","Durham, England":"Durham, Durham, England, United Kingdom","nameMeanings":[{"name":"Langton","type":"LAST","attribution":"Dictionary of American Family Names © Patrick Hanks 2003, 2006.","meanings":["English: habitational name from one or more of the many places called with Old English <i>lang</i> ‘long’ + <i>tūn</i> ‘farmstead, estate’, such as Langton Hall in Kirkby in Ashfield (Nottinghamshire), Langton Lodge in Hendon (Middlesex), Langton (Yorkshire), East and West Langton (Leicestershire), Langton by Horncastle, Langton by Spilsby, and Langton by Wragby (all in Lincolnshire), and Lanton (Northumb). Compare   Lankton  ,   Lanton  , and   Longton  ."],"variants":[{"name":"Lanton","meanings":["English: variant of   Langton  ."]},{"name":"Lankton","meanings":["English: variant of   Langton  .","History: Thomas Lankton, born <i>c.</i> 1714 in Hartford County, CT, died 1783 in Litchfield County, CT, was a son of Joseph Langton."]},{"name":"Longton","meanings":["habitational name from Longton in Lancashire. The placename derives from Old English <i>lang</i> ‘long’ + <i>tūn</i> ‘farmstead, estate’.","variant of   Langton  .","English:"]}]},{"name":"Henry","type":"FIRST","attribution":"Dictionary of First Names © Patrick Hanks and Flavia Hodges 1990, 2003, 2006.","meanings":["A perennially popular given name, of Continental Germanic origin, from <i>haim</i> ‘home’ + <i>rīc</i> ‘power, ruler’. It was an Old French name, adopted by the Normans and introduced by them to Britain. It has been borne by eight kings of England. Not until the 17th century did the form <i>Henry</i> (as opposed to   Harry  ) become the standard vernacular form, mainly under the influence of the Latin form <i>Henricus</i> and French <i>Henri</i>."],"variants":[]}],"lifeSummary":"Sir Henry Langton was born from 1300 to 1342, in Wynyard, Durham, England, United Kingdom. He married Margery De Fulthorpe in 1328. They were the parents of at least 1 son. He died in 1342, in Redmarshall, Durham, England, United Kingdom."},"et":{"1300 –1342":"1300 kuni 1342–1342","1300–1356":"1300–1356","1340–1380":"1340–1380","1300–1342":"1300–1342","1300 ":"1300 kuni 1342","1356":"1356","1300":"1300","1342":"1342","1340":"1340","1380":"1380","1328":"1328","about 1340":"umbes 1340","Redmarshall, Durham, England, United Kingdom":"Redmarshall, Durham, Inglismaa, United Kingdom","Wynyard,Durham, England Durham, England, United Kingdom":"Wynyard, Durham, Inglismaa, United Kingdom","Durham, England":"Durham, Durham, Inglismaa, United Kingdom"},"fi":{"1300 –1342":"vuodesta 1300 vuoteen 1342–1342","1300–1356":"1300–1356","1340–1380":"1340–1380","1300–1342":"1300–1342","1300 ":"vuodesta 1300 vuoteen 1342","1356":"1356","1300":"1300","1342":"1342","1340":"1340","1380":"1380","1328":"1328","about 1340":"noin 1340","Redmarshall, Durham, England, United Kingdom":"Redmarshall, Durham, Englanti, Yhdistynyt kuningaskunta","Wynyard,Durham, England Durham, England, United Kingdom":"Wynyard, Durham, Englanti, Yhdistynyt kuningaskunta","Durham, England":"Durham, Durham, Englanti, Yhdistynyt kuningaskunta"},"fr":{"1300 –1342":"du 1300 au 1342–1342","1300–1356":"1300–1356","1340–1380":"1340–1380","1300–1342":"1300–1342","1300 ":"du 1300 au 1342","1356":"1356","1300":"1300","1342":"1342","1340":"1340","1380":"1380","1328":"1328","about 1340":"environ 1340","Redmarshall, Durham, England, United Kingdom":"Red