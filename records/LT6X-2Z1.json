230":"1230","1173":"1173","1150":"1150","1226":"1226","1248":"1248","1225":"1225","1202":"1202","1224":"1224","1245":"1245","1222":"1222","1200":"1200","about 1222":"circa 1222","about 1212":"circa 1212","Arklow Castle, County Wicklow, Ireland":"Arklow Castle, County Wicklow, Ierland","Ireland":"Ierland","Arklow, County Wicklow, Ireland":"Arklow, County Wicklow, Ierland"},"en":{"1202–11 September 1225":"1202–11 September 1225","1202–1225":"1202–1225","1200–1230":"1200–1230","1222–Male":"1222–Deceased","1224–1248":"1224–1248","1225–Female":"1225–Deceased","1173–1245":"1173–1245","1150–1226":"1150–1226","11 September 1225":"11 September 1225","September 1225":"September 1225","1230":"1230","1173":"1173","1150":"1150","1226":"1226","1248":"1248","1225":"1225","1202":"1202","1224":"1224","1245":"1245","1222":"1222","1200":"1200","about 1222":"about 1222","about 1212":"about 1212","Arklow Castle, County Wicklow, Ireland":"Arklow Castle, County Wicklow, Ireland","Ireland":"Ireland","Arklow, County Wicklow, Ireland":"Arklow, County Wicklow, Ireland","nameMeanings":[{"name":"De","type":"LAST","attribution":"Dictionary of American Family Names © Patrick Hanks 2003, 2006.","meanings":["Some characteristic forenames:  Indian Dilip, Anirban, Gopal, Alok, Anindya, Arunava, Asit, Asok, Dibyendu, Goutam, Indra, Indranil.","Indian: variant of   Dey  ."],"variants":[{"name":"Dey","meanings":["Some characteristic forenames:  Indian Ashit, Indu, Naina, Partha, Soumya, Ajit, Anjan, Anjana, Anup, Arjun, Arun, Ashim.","English, Scottish, and Welsh: variant of   Day  .","German: topographic name from a field name in North Rhine-Westphalia, denoting a sizeable piece of land, from Middle Low German <i>dē</i> ‘thigh’ (referring to the shape of the property)."]}]},{"name":"Marisco","type":"LAST","attribution":"Dictionary of American Family Names © Patrick Hanks 2003, 2006.","meanings":["Some characteristic forenames:  Italian Carmine, Antonio, Gasper, Pasquale.","Italian (Sicily):","probably a habitational name from a place so called, named with <i>marisco</i>, a term denoting a species of reed (from Latin <i>mariscus</i>), or a topographic name for someone who lived by a reed bed."],"variants":[{"name":"Maresca","meanings":["Some characteristic forenames:  Italian Salvatore, Angelo, Luigi, Giuseppe, Pasquale, Rocco, Carmine, Aniello, Carlo, Ciro, Constantino, Sal.","Italian (southern): variant of   Maresco  ."]},{"name":"Scotto","meanings":["Some characteristic forenames:  Italian Salvatore, Sal, Aniello, Biagio, Ciro, Alessio, Antonio, Elvira, Gennaro, Mario, Marta, Angelo, Arturo, Biaggio, Biago, Geraldo, Gerardo, Liberta, Mariano.","Italian:","ethnic name for someone from Scotland or Ireland, from medieval Italian <i>scot(t)o</i> ‘Scot’."]}]},{"name":"Joan","type":"FIRST","attribution":"Dictionary of First Names © Patrick Hanks and Flavia Hodges 1990, 2003, 2006.","meanings":["Contracted form of Old French <i>Jo(h)anne</i>, from Latin <i>Io(h)anna</i> (  see  Joanna  ). In England this was the usual feminine form of   John   from the Middle English period onwards and was extremely popular, but in the 16th and 17th centuries it steadily lost ground to   Jane .  It was strongly revived in the first part of the 20th century, partly under the influence of  George Bernard Shaw's  play St Joan (  1923 ), based on the life of  Joan of Arc  (  1412–31 ). Claiming to be guided by the voices of the saints, she persuaded the French dauphin to defy the occupying English forces and have himself crowned, and she led the French army that raised the siege of Orleans in  1429 . The following year she was captured by the Burgundians and sold to the English, and a year later she was burned at the stake for witchcraft at the age of 18 or 19. Her story has captured the imagination of many writers, and she is variously portrayed as a national and political hero, a model of apolitical straightforwardness and honesty, and a religious heroine. She was canonized in  1920 . More recent influences have included the American film actress  Joan Crawford  (  1908–77 , born  Lucille le Sueur ), the British actress  Joan Collins  (  b. 1933 ), the American comedienne  Joan Rivers  (  b. 1933 ), and the West Indian pop singer  Joan Armatrading  (  b. 1950 )."],"variants":[{"name":"John","meanings":["Contracted form of Old French <i>Jo(h)anne</i>, from Latin <i>Io(h)anna</i> (  see  Joanna  ). In England this was the usual feminine form of   John   from the Middle English period onwards and was extremely popular, but in the 16th and 17th centuries it steadily lost ground to   Jane .  It was strongly revived in the first part of the 20th century, partly under the influence of  George Bernard Shaw's  play St Joan (  1923 ), based on the life of  Joan of Arc  (  1412–31 ). Claiming to be guided by the voices of the saints, she persuaded the French dauphin to defy the occupying English forces and have himself crowned, and she led the French army that raised the siege of Orleans in  1429 . The following year she was captured by the Burgundians and sold to the English, and a year later she was burned at the stake for witchcraft at the age of 18 or 19. Her story has captured the imagination of many writers, and she is variously portrayed as a national and political hero, a model of apolitical straightforwardness and honesty, and a religious heroine. She was canonized in  1920 . More recent influences have included the American film actress  Joan Crawford  (  1908–77 , born  Lucille le Sueur ), the British actress  Joan Collins  (  b. 1933 ), the American comedienne  Joan Rivers  (  b. 1933 ), and the West Indian pop singer  Joan Armatrading  (  b. 1950 )."]}]}],"lifeSummary":"When Joan De Marisco was born in 1202, in Arklow, County Wicklow, Ireland, her father, Geoffrey de Marisco Justiciar of Ireland, was 29 and her mother, Eve de Bermingham Valognes Lady of Offaly, was 52. She married Theobald Le Boteler 2nd Chief Butler of Ireland about 1222, in Ireland. They were the parents of at least 2 sons. She died on 11 September 1225, in Arklow Castle, County Wicklow, Ireland, at the age of 23, and was buried in Arklow Castle, County Wicklow, Ireland."},"et":{"1202–11 September 1225":"1202–11. september 1225","1202–1225":"1202–1225","1200–1230":"1200–1230","1222–Male":"1222–Surnud","1224–1248":"1224–1248","1225–Female":"1225–Surnud","1173–1245":"1173–1245","1150–1226":"1150–1226","11 September 1225":"11. september 1225","September 1225":"september 1225","1230":"1230","1173":"1173","1150":"1150","1226":"1226","1248":"1248","1225":"1225","1202":"1202","1224":"1224","1245":"1245","1222":"1222","1200":"1200","about 1222":"umbes 1222","about 1212":"umbes 1212","Arklow Castle, County Wicklow, Ireland":"Arklow Castle, County Wicklow, Iirimaa","Ireland":"Iirimaa","Arklow, County Wicklow, Ireland":"Arklow, County Wicklow, Iirimaa"},"fi":{"1202–11 September 1225":"1202–11. syyskuuta 1225","1202–1225":"1202–1225","1200–1230":"1200–1230","1222–Male":"1222–Kuollut","1224–1248":"1224–1248","1225–Female":"1225–Kuollut","1173–1245":"1173–1245","1150–1226":"1150–1226","11 September 1225":"11. syyskuuta 1225","September 1225":"syyskuu 1225","1230":"1230","1173":"1173","1150":"1150","1226":"1226","1248":"1248","1225":"1225","1202":"1202","1224":"1224","1245":"1245","1222":"1222","1200":"1200","about 1222":"noin 1222","about 1212":"noin 1212","Arklow Castle, County Wicklow, Ireland":"Arklow Castle, County Wicklow, Irlanti","Ireland":"Irlanti","Arklow, County Wicklow, Ireland":"Arklow, County Wicklow, Irlanti"},"fr":{"1202–11 September 1225":"1202–11 septembre 1225","1202–1225":"1202–1225","1200–1230":"1200–1230","1222–Male":"1222–Décédé","1224–1248":"1224–1248","1225–Female":"1225–Décédée","1173–1245":"1173–1245","1150–1226":"1150–1226","11 September 1225":"11 septembre 1225","September 1225":"septembre 1225","1230":"1230","1173":"1173","1150":"1150","1226":"1226","1248":"1248","1225":"1225","1202":"1202","1224":"1224","1245":"1245","122