ngland":"England, United Kingdom"},"nl":{"about 1330–Deceased":"circa 1330–Overleden","1325–Male":"1325–Overleden","1350–1420":"1350–1420","1330–Female":"1330–Overleden","1325":"1325","1420":"1420","1330":"1330","1350":"1350","about 1330":"circa 1330","England":"Engeland, Verenigd Koninkrijk"},"en":{"about 1330–Deceased":"about 1330–Deceased","1325–Male":"1325–Deceased","1350–1420":"1350–1420","1330–Female":"1330–Deceased","1325":"1325","1420":"1420","1330":"1330","1350":"1350","about 1330":"about 1330","England":"England, United Kingdom","nameMeanings":[{"name":"Joan","type":"FIRST","attribution":"Dictionary of First Names © Patrick Hanks and Flavia Hodges 1990, 2003, 2006.","meanings":["Contracted form of Old French <i>Jo(h)anne</i>, from Latin <i>Io(h)anna</i> (  see  Joanna  ). In England this was the usual feminine form of   John   from the Middle English period onwards and was extremely popular, but in the 16th and 17th centuries it steadily lost ground to   Jane .  It was strongly revived in the first part of the 20th century, partly under the influence of  George Bernard Shaw's  play St Joan (  1923 ), based on the life of  Joan of Arc  (  1412–31 ). Claiming to be guided by the voices of the saints, she persuaded the French dauphin to defy the occupying English forces and have himself crowned, and she led the French army that raised the siege of Orleans in  1429 . The following year she was captured by the Burgundians and sold to the English, and a year later she was burned at the stake for witchcraft at the age of 18 or 19. Her story has captured the imagination of many writers, and she is variously portrayed as a national and political hero, a model of apolitical straightforwardness and honesty, and a religious heroine. She was canonized in  1920 . More recent influences have included the American film actress  Joan Crawford  (  1908–77 , born  Lucille le Sueur ), the British actress  Joan Collins  (  b. 1933 ), the American comedienne  Joan Rivers  (  b. 1933 ), and the West Indian pop singer  Joan Armatrading  (  b. 1950 )."],"variants":[{"name":"John","meanings":["Greek: the Lord gave graciously; whom Jehovah gave; whom Jehovah bestowed."]}]}],"lifeSummary":"Joan was born about 1330, in England, United Kingdom. She had at least 1 son with John Tansley."},"et":{"about 1330–Deceased":"umbes 1330–Surnud","1325–Male":"1325–Surnud","1350–1420":"1350–1420","1330–Female":"1330–Surnud","1325":"1325","1420":"1420","1330":"1330","1350":"1350","about 1330":"umbes 1330","England":"Inglismaa, United Kingdom"},"fi":{"about 1330–Deceased":"noin 1330–Kuollut","1325–Male":"1325–Kuollut","1350–1420":"1350–1420","1330–Female":"1330–Kuollut","1325":"1325","1420":"1420","1330":"1330","1350":"1350","about 1330":"noin 1330","England":"Englanti, Yhdistynyt kuningaskunta"},"fr":{"about 1330–Deceased":"environ 1330–Décédée","1325–Male":"1325–Décédé","1350–1420":"1350–1420","1330–Female":"1330–Décédée","1325":"1325","1420":"1420","1330":"1330","1350":"1350","about 1330":"environ 1330","England":"Angleterre, Royaume-Uni","lifeSummary":"Joan est née environ 1330, à Angleterre, Royaume-Uni. Elle a eu au moins 1 fils avec John Tansley."},"de":{"about 1330–Deceased":"um 1330–Verstorben","1325–Male":"1325–Verstorben","1350–1420":"1350–1420","1330–Female":"1330–Verstorben","1325":"1325","1420":"1420","1330":"1330","1350":"1350","about 1330":"um 1330","England":"England, United Kingdom","lifeSummary":"Joan wurde um 1330 in England, United Kingdom geboren. Sie hatte mit John Tansley mindestens 1 Sohn."},"ht":{"about 1330–Deceased":"about 1330–Desede","1325–Male":"1325–Desede","1350–1420":"1350–1420","1330–Female":"1330–Desede","1325":"1325","1420":"1420","1330":"1330","1350":"1350","about 1330":"about 1330","England":"Angletè, United Kingdom"},"hu":{"about 1330–Deceased":"1330 körül–elhunyt","1325–Male":"1325–elhunyt","1350–1420":"1350–1420","1330–Female":"1330–elhunyt","1325":"1325","1420":"1420","1330":"1330","1350":"1350","about 1330":"1330 körü