–1476":"1390–1476","1390–Female":"1390–Afdød","1440":"1440","1490":"1490","1390":"1390","1415":"1415","1435":"1435","1479":"1479","1511":"1511","1455":"1455","1476":"1476","1452":"1452","about 1440":"omkring 1440","1419":"1419","1418":"1418","Sydmonton, Hampshire, England":"Sydmonton, Hampshire, England","Somme, Picardie, France":"Somme, Picardie, Frankrig","Basingstoke, Hampshire, England":"Basingstoke, Hampshire, England","England":"England","Barkham, Berkshire, England":"Barkham, Berkshire, England, United Kingdom"},"nl":{"1415–1479":"1415–1479","1419–Male":"1419–Overleden","1418–1479":"1418–1479","1440–1511":"1440–1511","1452–1490":"1452–1490","1390–1476":"1390–1476","1390–Female":"1390–Overleden","1440":"1440","1490":"1490","1390":"1390","1415":"1415","1435":"1435","1479":"1479","1511":"1511","1455":"1455","1476":"1476","1452":"1452","about 1440":"circa 1440","1419":"1419","1418":"1418","Sydmonton, Hampshire, England":"Sydmonton, Hampshire, England","Somme, Picardie, France":"Somme, Picardie, Frankrijk","Basingstoke, Hampshire, England":"Basingstoke, Hampshire, England","England":"England","Barkham, Berkshire, England":"Barkham, Berkshire, Engeland, Verenigd Koninkrijk"},"en":{"1415–1479":"1415–1479","1419–Male":"1419–Deceased","1418–1479":"1418–1479","1440–1511":"1440–1511","1452–1490":"1452–1490","1390–1476":"1390–1476","1390–Female":"1390–Deceased","1440":"1440","1490":"1490","1390":"1390","1415":"1415","1435":"1435","1479":"1479","1511":"1511","1455":"1455","1476":"1476","1452":"1452","about 1440":"about 1440","1419":"1419","1418":"1418","Sydmonton, Hampshire, England":"Sydmonton, Hampshire, England","Somme, Picardie, France":"Somme, Picardie, France","Basingstoke, Hampshire, England":"Basingstoke, Hampshire, England","England":"England","Barkham, Berkshire, England":"Barkham, Berkshire, England, United Kingdom","nameMeanings":[{"name":"Kingsmill","type":"LAST","attribution":"Dictionary of American Family Names © Patrick Hanks 2003, 2006.","meanings":["English: habitational name from any of various places known in Middle English as the ‘king's mill’, such as King's Mill in Marnhull (Dorset) or King's Mill in Barton (Oxfordshire)."],"variants":[]},{"name":"Richard","type":"FIRST","attribution":"Dictionary of First Names © Patrick Hanks and Flavia Hodges 1990, 2003, 2006.","meanings":["One of the most enduringly successful of the Old French personal names introduced into Britain by the Normans. It is of Germanic (Frankish) origin, derived from <i>rīc</i> ‘power’ + <i>hard</i> ‘strong, hardy’. It has enjoyed continuous popularity in England from the Conquest to the present day, influenced by the fact that it was borne by three kings of England, in particular  Richard I  (  1157–99 ). He was king for only ten years (  1189–99 ), most of which he spent in warfare abroad, taking part in the Third Crusade and costing the people of England considerable sums in taxes. Nevertheless, he achieved the status of a folk hero, and was never in England long enough to disappoint popular faith in his goodness and justice. He was also Duke of Aquitaine and Normandy and Count of Anjou, fiefs which he held at a time of maximum English expansion in France. His exploits as a leader of the Third Crusade earned him the nickname ‘Coeur de Lion’ or ‘Lionheart’ and a permanent place in popular imagination, in which he was even more firmly enshrined by  Sir Walter Scott's  novel Ivanhoe (  1820 )."],"variants":[{"name":"Rikert","meanings":["One of the most enduringly successful of the Old French personal names introduced into Britain by the Normans. It is of Germanic (Frankish) origin, derived from <i>rīc</i> ‘power’ + <i>hard</i> ‘strong, hardy’. It has enjoyed continuous popularity in England from the Conquest to the present day, influenced by the fact that it was borne by three kings of England, in particular  Richard I  (  1157–99 ). He was king for only ten years (  1189–99 ), most of which he spent in warfare abroad, taking part in the Third Crusade and costing the people of England considerable sums in taxes. Nevertheless, he achieved the status of a folk hero, and was never in England long enough to disappoint popular faith in his goodness and justice. He was also Duke of Aquitaine and Normandy and Count of Anjou, fiefs which he held at a time of maximum English expansion in France. His exploits as a leader of the Third Crusade earned him the nickname ‘Coeur de Lion’ or ‘Lionheart’ and a permanent place in popular imagination, in which he was even more firmly enshrined by  Sir Walter Scott's  novel Ivanhoe (  1820 )."]},{"name":"Rickert","meanings":["One of the most enduringly successful of the Old French personal names introduced into Britain by the Normans. It is of Germanic (Frankish) origin, derived from <i>rīc</i> ‘power’ + <i>hard</i> ‘strong, hardy’. It has enjoyed continuous popularity in England from the Conquest to the present day, influenced by the fact that it was borne by three kings of England, in particular  Richard I  (  1157–99 ). He was king for only ten years (  1189–99 ), most of which he spent in warfare abroad, taking part in the Third Crusade and costing the people of England considerable sums in taxes. Nevertheless, he achieved the status of a folk hero, and was never in England long enough to disappoint popular faith in his goodness and justice. He was also Duke of Aquitaine and Normandy and Count of Anjou, fiefs which he held at a time of maximum English expansion in France. His exploits as a leader of the Third Crusade earned him the nickname ‘Coeur de Lion’ or ‘Lionheart’ and a permanent place in popular imagination, in which he was even more firmly enshrined by  Sir Walter Scott's  novel Ivanhoe (  1820 )."]}]}],"historicEvents":[{"id":1705197,"age":40,"year":"1455","julianDay":2252488,"title":"Wars of the Roses","description":"Wars of the Roses was a series of English civil wars for control of the throne of England between the royal families House of Lancaster and the House of York. The name of the war was derived as the red rose was the symbol of the Lancastrians and the white rose was the symbol of the Yorks.","url":"https://www.history.com/topics/british-history/wars-of-the-roses","urlTitle":"History - Wars of the Roses","jurisdictionLevel":2}],"lifeSummary":"When Richard Kingsmill I was born in 1415, in Barkham, Berkshire, England, his father, William Kingsmill, was 25 and his mother, Anne Wilkes, was 26. He married Lady Amy Ingpen in 1435, in Barkham, Berkshire, England. They were the parents of at least 1 son and 1 daughter. In 1476, at the age of 61, his occupation is listed as landowner. He died in 1479, in Somme, Picardie, France, at the age of 64."},"et":{"1415–1479":"1415–1479","1419–Male":"1419–Surnud","1418–1479":"1418–1479","1440–1511":"1440–1511","1452–1490":"1452–1490","1390–1476":"1390–1476","1390–Female":"1390–Surnud","1440":"1440","1490":"1490","1390":"1390","1415":"1415","1435":"1435","1479":"1479","1511":"1511","1455":"1455","1476":"1476","1452":"1452","about 1440":"umbes 1440","1419":"1419","1418":"1418","Sydmonton, Hampshire, England":"Sydmonton, Hampshire, England","Somme, Picardie, France":"Somme, Picardie, Prantsusmaa","Basingstoke, Hampshire, England":"Basingstoke, Hampshire, England","England":"England","Barkham, Berkshire, England":"Barkham, Berkshire, Inglismaa, United Kingdom"},"fi":{"1415–1479":"1415–1479","1419–Male":"1419–Kuollut","1418–1479":"1418–1479","1440–1511":"1440–1511","1452–1490":"1452–1490","1390–1476":"1390–1476","1390–Female":"1390–Kuollut","1440":"1440","1490":"1490","1390":"1390","1415":"1415","1435":"1435","1479":"1479","1511":"1511","1455":"1455","1476":"1476","1452":"1452","about 1440":"noin 1440","1419":"1419","1418":"1418","Sydmonton, Hampshire, England":"Sydmonton, Hampshire, England","Somme, Picardie, France":"Somme, Picardie, Ranska","Basingstoke, Hampshire, England":"Basingstoke, Hampshire, England","England":"England","Barkham, Berkshire, England":"Barkham, Berkshire, Engla