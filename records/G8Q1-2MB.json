ants":[]}],"lifeSummary":"When Thomas Copley was born about 1340, in Copley, Yorkshire, England, United Kingdom, his father, Sir Hugh de Copley, was 42 and his mother, Ann Cromwelbotham, was 21. He married Joan Keighley about 1365, in Gnosall, Staffordshire, England, United Kingdom. They were the parents of at least 1 daughter. He died before 1370."},"et":{"about 1340–before 1370":"umbes 1340–enne 1370","1340–1370":"1340–1370","1370–Male":"1370–Surnud","–Male":"Surnud","1345–1370":"1345–1370","1370–Female":"1370–Surnud","1299–1375":"1299–1375","1320–Female":"1320–Surnud","1324":"1324","1345":"1345","Abt 1365":"umbes 1365","1299":"1299","1320":"1320","1375":"1375","1340":"1340","before 1370":"enne 1370","1370":"1370","about 1340":"umbes 1340","Copley, Yorkshire, England, United Kingdom":"Copley, Yorkshire, Inglismaa, United Kingdom","Boresford, Brampton Bryan, Herefordshire, England, United Kingdom":"Brampton Bryan, Herefordshire, Inglismaa, United Kingdom","Copley, Yorkshire, England":"Copley, Yorkshire, England","Gnosall, Stafford district, Staffordshire, England, United Kingdom":"Gnosall, Staffordshire, Inglismaa, United Kingdom"},"fi":{"about 1340–before 1370":"noin 1340–ennen vuotta 1370","1340–1370":"1340–1370","1370–Male":"1370–Kuollut","–Male":"Kuollut","1345–1370":"1345–1370","1370–Female":"1370–Kuollut","1299–1375":"1299–1375","1320–Female":"1320–Kuollut","1324":"1324","1345":"1345","Abt 1365":"noin 1365","1299":"1299","1320":"1320","1375":"1375","1340":"1340","before 1370":"ennen vuotta 1370","1370":"1370","about 1340":"noin 1340","Copley, Yorkshire, England, United Kingdom":"Copley, Yorkshire, Englanti, Yhdistynyt kuningaskunta","Boresford, Brampton Bryan, Herefordshire, England, United Kingdom":"Brampton Bryan, Herefordshire, Englanti, Yhdistynyt kuningaskunta","Copley, Yorkshire, England":"Copley, Yorkshire, England","Gnosall, Stafford district, Staffordshire, England, United Kingdom":"Gnosall, Staffordshire, Englanti, Yhdistynyt kuningaskunta"},"fr":{"