ter 1261":"po 1261","about 1225":"okolo 1225","after 1240":"po 1240","about 1223":"okolo 1223","1219":"1219","1318":"1318","1218":"1218","Bothal, Northumberland, England":"Bothal, Northumberland, Anglie, United Kingdom","Bothal, Nothumberland, England":"Bothal, Northumberland, Anglie, United Kingdom","England":"Anglie","Northumberland, England":"Northumberland, Anglie"},"da":{"1197–1263":"1197–1263","1193–1238":"1193–1238","1219–1262":"1219–1262","1223–1261":"1223–1261","1225–1240":"1225–1240","1227–1261":"1227–1261","1318–1400":"1318–1400","1197":"1197","1263":"1263","1262":"1262","1240":"1240","1261":"1261","1193":"1193","1227":"1227","1238":"1238","1225":"1225","1400":"1400","1223":"1223","about 1227":"omkring 1227","about 1238":"omkring 1238","after 1261":"efter 1261","about 1225":"omkring 1225","after 1240":"efter 1240","about 1223":"omkring 1223","1219":"1219","1318":"1318","1218":"1218","Bothal, Northumberland, England":"Bothal, Northumberland, England, United Kingdom","Bothal, Nothumberland, England":"Bothal, Northumberland, England, United Kingdom","England":"England","Northumberland, England":"Northumberland, England"},"nl":{"1197–1263":"1197–1263","1193–1238":"1193–1238","1219–1262":"1219–1262","1223–1261":"1223–1261","1225–1240":"1225–1240","1227–1261":"1227–1261","1318–1400":"1318–1400","1197":"1197","1263":"1263","1262":"1262","1240":"1240","1261":"1261","1193":"1193","1227":"1227","1238":"1238","1225":"1225","1400":"1400","1223":"1223","about 1227":"circa 1227","about 1238":"circa 1238","after 1261":"na 1261","about 1225":"circa 1225","after 1240":"na 1240","about 1223":"circa 1223","1219":"1219","1318":"1318","1218":"1218","Bothal, Northumberland, England":"Bothal, Northumberland, Engeland, Verenigd Koninkrijk","Bothal, Nothumberland, England":"Bothal, Northumberland, Engeland, Verenigd Koninkrijk","England":"England","Northumberland, England":"Northumberland, England"},"en":{"1197–1263":"1197–1263","1193–1238":"1193–1238","1219–1262":"1219–1262","1223–1261":"1223–1261","1225–1240":"1225–1240","1227–1261":"1227–1261","1318–1400":"1318–1400","1197":"1197","1263":"1263","1262":"1262","1240":"1240","1261":"1261","1193":"1193","1227":"1227","1238":"1238","1225":"1225","1400":"1400","1223":"1223","about 1227":"about 1227","about 1238":"about 1238","after 1261":"after 1261","about 1225":"about 1225","after 1240":"after 1240","about 1223":"about 1223","1219":"1219","1318":"1318","1218":"1218","Bothal, Northumberland, England":"Bothal, Northumberland, England, United Kingdom","Bothal, Nothumberland, England":"Bothal, Northumberland, England, United Kingdom","England":"England","Northumberland, England":"Northumberland, England","nameMeanings":[{"name":"Bertram","type":"LAST","attribution":"Dictionary of American Family Names © Patrick Hanks 2003, 2006.","meanings":["German, English (mainly in southeastern Scotland, of Norman origin), French, and Danish: from the ancient Germanic personal name <i>Bertram</i>, composed of the elements <i>berht</i> ‘bright, famous’ + <i>hramn</i> ‘raven’. The raven was the bird of Odin, king of the gods, in ancient Germanic mythology. The personal name was common in France throughout the Middle Ages (especially in the form   Bertrand  ), where its popularity was increased by the fame of the troubadour Bertrand de Born (<i>c.</i> 1140–1214). The name was taken to England by the Normans in the forms <i>Bertran(d)</i>, <i>Bertram</i>, and <i>Bartram</i>."],"variants":[{"name":"Beltrami","meanings":["Some characteristic forenames:  Italian Dante, Dino, Marco, Pio, Sal, Tullio.","Italian: patronymic or plural form of the personal name <i>Beltrame</i>, from an ancient Germanic name composed of the elements <i>berht</i> ‘bright, famous’ + <i>hramn</i> ‘raven’. See also   Bertram  ."]},{"name":"Bartram","meanings":["English (of Norman origin) and North German: variant of   Bertram  .","History: William Bartram, a Quaker, had a large farm near Darby, PA, when his eldest son, John, the first American botanist, was born in 1699. John conducted botanical experiments at his own farm in Kingsessing, PA, near Philadelphia."]},{"name":"Bertman","meanings":["Some characteristic forenames:  German Frieda, Wilhelm.","Americanized form of German <b>Bertmann</b>: altered form (by folk etymology) of   Bertram  ."]},{"name":"Bethke","meanings":["Some characteristic forenames:  German Kurt, Eldor, Ewald, Otto, Rudi, Wilhelmina.","North German: from a pet form of the ancient Germanic personal names   Bertram   or   Berthold  . See also   Beth  ."]},{"name":"Bertrand","meanings":["Some characteristic forenames:  French Marcel, Andre, Armand, Monique, Francois, Gilles, Raoul, Emile, Herve, Jacques, Jean-Marie, Odette.","French, Walloon, and West Indian (mainly Haiti): from the French personal name <i>Bertrand</i>, a variant of   Bertram  , coined by folk etymology under the influence of the present participle endings <i>-and</i>, <i>-ant</i>.","History: This surname is listed in the (US) National Huguenot Society's register of qualified Huguenot ancestors and also in the similar register of the Huguenot Society of America."]},{"name":"Beltran","meanings":["Some characteristic forenames:  Spanish Jose, Juan, Manuel, Carlos, Jesus, Luis, Pedro, Jorge, Mario, Ricardo, Francisco, Rafael.","Spanish (<b>Beltrán</b>), Catalan, and southern French: from a personal name composed of the ancient Germanic elements <i>berht</i> ‘bright, famous’ + <i>hramn</i> ‘raven’. See also   Bertram  ."]},{"name":"Beltramo","meanings":["Some characteristic forenames:  Italian Angelo.","Italian: from the medieval personal name <i>Beltramo</i>, of ancient Germanic origin (see   Bertram  )."]},{"name":"Bert","meanings":["Some characteristic forenames:  French Philibert, Pierre.","German, French, and Polish: from a short form of various compound personal names formed with ancient Germanic <i>berht</i> ‘bright, famous’ (see for example   Bertram  ).","English: from the Middle English female personal name <i>Berte</i> (Old French <i>Berte</i>, from ancient Germanic   Berta  )."]},{"name":"Battermann","meanings":["German:","possibly an occupational name for a merchant or peddler, from <i>Bartermann</i>.","alternatively, perhaps from a short form of the personal name   Bertram   + Middle High German <i>man</i> ‘man’."]},{"name":"Bertran","meanings":["Some characteristic forenames:  Spanish Jose, Jorge, Eduardo, Enrique, Joaquin, Ricardo, Aleida, Ana, Ana Maria, Elena, Felipe, Jeronimo.  French Andre.","French, Occitan, and Catalan: variant of   Bertram   or   Bertrand  ."]}]},{"name":"Sarah","type":"FIRST","attribution":"Dictionary of First Names © Patrick Hanks and Flavia Hodges 1990, 2003, 2006.","meanings":["Biblical name, borne by the wife of Abraham and mother of Isaac. According to the Book of Genesis, she was originally called <i>Sarai</i> (possibly meaning ‘contentious’ in Hebrew), but had her name changed by God to the more auspicious <i>Sarah</i> ‘princess’ in token of a greater blessing (Genesis 17:15, ‘And God said unto Abraham, As for Sarai thy wife, thou shalt not call her name Sarai, but Sarah shall her name be’). This has been one of the most enduringly popular girls' names."],"variants":[{"name":"Sara","meanings":["Variant of   Sarah .  This is the form used in the Greek of the New Testament (Hebrews 11:11)."]}]}],"lifeSummary":"Mrs Sarah Bertram was born in 1197, in Bothal, Northumberland, England, United Kingdom. She married Richard Bertram Baron of Bothal in 1218, in Northumberland, England. They were the parents of at least 4 sons. She died in 1263, at the age of 66."},"et":{"1197–1263":"1197–1263","1193–1238":"1193–1238","1219–1262":"1219–1262","1223–1261":"1223–1261","1225–1240":"1225–1240","1227–1261":"1227–1261","1318–1400":"1318–1400","1197":"1197","1263":"1263","1262":"1262","1240":"1240","1261":"1261","1193":"1193","1227":"1227","1238":"1238","1225":"1225","1400":"1400","1223":"1223","about 1227":"umbes 1227","about 1238":"umbes 1238","after 