 ."],"variants":[]}],"historicEvents":[{"id":1705195,"age":25,"year":"1382","julianDay":2225826,"title":"Wycliffe's Bible","description":"John Wycliffe, English theologian and professor at the University of Oxford, completed a translation of the Bible from the Latin Vulgate into Middle English. This translation is known as Wycliffe's Bible and was completed around 1382.","url":"https://en.wikipedia.org/wiki/Wycliffe%27s_Bible","urlTitle":"Wikipedia - Wycliffe's Bible","jurisdictionLevel":1}],"lifeSummary":"When Lucy Attelex was born in 1357, in Herefordshire, England, her father, Marcelli Attelex, was 27 and her mother, Mrs. Marcelli Attelex, was 22. She married John Norton in 1377, in Herefordshire, England. They were the parents of at least 1 son. She died about 1429, in Wales, at the age of 73."},"et":{"1357–about 1429":"1357–umbes 1429","1357–1429":"1357–1429","1364–Male":"1364–Surnud","1383–1429":"1383–1429","1330–Male":"1330–Surnud","1335–Female":"1335–Surnud","1357":"1357","about 1429":"umbes 1429","1335":"1335","1377":"1377","1355":"1355","1364":"1364","1330":"1330","1383":"1383","1382":"1382","1429":"1429","Wales":"Wales","England":"England","Herefordshire, England":"Herefordshire, England","Kent, Kent, England":"Kent, Kent, England"},"fi":{"1357–about 1429":"1357–noin 1429","1357–1429":"1357–1429","1364–Male":"1364–Kuollut","1383–1429":"1383–1429","1330–Male":"1330–Kuollut","1335–Female":"1335–Kuollut","1357":"1357","about 1429":"noin 1429","1335":"1335","1377":"1377","1355":"1355","1364":"1364","1330":"1330","1383":"1383","1382":"1382","1429":"1429","Wales":"Wales","England":"England","Herefordshire, England":"Herefordshire, England","Kent, Kent, England":"Kent, Kent, England"},"fr":{"1357–about 1429":"1357–environ 1429","1357–1429":"1357–1429","1364–Male":"1364–Décédé","1383–1429":"1383–1429","1330–Male":"1330–Décédé","1335–Female":"1335–Décédée","1357":"1357","about 1429":"environ 1429","1335":"1335","1377":"1377","1355":"1355","1364":"1364","1330":"133