":"–1414","1326–1398":"1326–1398","1346–Female":"1346–Zesnulá","1290–Male":"1290–Zesnulý","1294–Female":"1294–Zesnulá","1350":"1350","1382":"1382","1294":"1294","1290":"1290","1349":"1349","1337":"1337","1326":"1326","1414":"1414","1347":"1347","1346":"1346","1345":"1345","about 1349":"okolo 1349","1389":"1389","1378":"1378","about 1347":"okolo 1347","1453":"1453","1398":"1398","1320":"1320","1328":"1328","Letheringham, Suffolk, England":"Letheringham, Suffolk, Anglie"},"da":{"1328–":"1328–Afdød","1328–Female":"1328–Afdød","1320–1378":"1320–1378","1345–1389":"1345–1389","1347–Female":"1347–Afdød","1349–Female":"1349–Afdød","–1414":"–1414","1326–1398":"1326–1398","1346–Female":"1346–Afdød","1290–Male":"1290–Afdød","1294–Female":"1294–Afdød","1350":"1350","1382":"1382","1294":"1294","1290":"1290","1349":"1349","1337":"1337","1326":"1326","1414":"1414","1347":"1347","1346":"1346","1345":"1345","about 1349":"omkring 1349","1389":"1389","1378":"1378","about 1347":"omkring 1347","1453":"1453","1398":"1398","1320":"1320","1328":"1328","Letheringham, Suffolk, England":"Letheringham, Suffolk, England"},"nl":{"1328–":"1328–Overleden","1328–Female":"1328–Overleden","1320–1378":"1320–1378","1345–1389":"1345–1389","1347–Female":"1347–Overleden","1349–Female":"1349–Overleden","–1414":"–1414","1326–1398":"1326–1398","1346–Female":"1346–Overleden","1290–Male":"1290–Overleden","1294–Female":"1294–Overleden","1350":"1350","1382":"1382","1294":"1294","1290":"1290","1349":"1349","1337":"1337","1326":"1326","1414":"1414","1347":"1347","1346":"1346","1345":"1345","about 1349":"circa 1349","1389":"1389","1378":"1378","about 1347":"circa 1347","1453":"1453","1398":"1398","1320":"1320","1328":"1328","Letheringham, Suffolk, England":"Letheringham, Suffolk, England"},"en":{"1328–":"1328–Deceased","1328–Female":"1328–Deceased","1320–1378":"1320–1378","1345–1389":"1345–1389","1347–Female":"1347–Deceased","1349–Female":"1349–Deceased","–1414":"–1414","1326–1398":"1326–1398","1346–Female":"1346–Deceased","1290–Male":"1290–Deceased","1294–Female":"1294–Deceased","1350":"1350","1382":"1382","1294":"1294","1290":"1290","1349":"1349","1337":"1337","1326":"1326","1414":"1414","1347":"1347","1346":"1346","1345":"1345","about 1349":"about 1349","1389":"1389","1378":"1378","about 1347":"about 1347","1453":"1453","1398":"1398","1320":"1320","1328":"1328","Letheringham, Suffolk, England":"Letheringham, Suffolk, England","nameMeanings":[{"name":"Bovile","type":"LAST","attribution":"Dictionary of American Family Names © Patrick Hanks 2003, 2006.","meanings":["English (of Norman origin): habitational name from any of several places in Normandy whose medieval forms share a similar range of variants, such as Bouville (Seine-Maritime), any of several places called Biéville (Calvados, Manche) or Biville (Manche, Seine-Maritime), Beuzeville-la-Giffard (Seine-Maritime), Boiville (Orne), and perhaps Boudeville (Seine-Maritime). See also   Boswell   and   Beville  ."],"variants":[{"name":"Boswell","meanings":["English and Scottish (of Norman origin): habitational name from Beuzeville-la-Giffard in Seine-Maritime, France, named with the ancient Germanic personal name <i>Boso</i> + <i>ville</i> ‘settlement’. The final element has been altered as a result of association with the common placename ending <i>-well</i> ‘spring, stream’. Some instances of   Bovill   may have the same origin."]},{"name":"Beville","meanings":["English (Middlesex and Surrey; of Norman origin): variant of   Bovill  . Derivation from Beuville (Calvados) is also possible, though unproven.","French (also <b>Béville</b>): habitational name from Béville (Moselle) or Béville-le-Comte (Eure-et-Loir), or a variant of <b>Beuville</b>, a habitational name from Beuville (Calvados). The surname <i>Béville</i> is rare in France."]},{"name":"Buffalo","meanings":["English: apparently an American English nickname from <i>buffalo</i>, perhaps denoting a large, powerfully built man. Alternatively, perhaps an altered form of an unidentified surname, possibly English   Bovill  . Compare   Buffaloe   and   Buffalow  .","Native American: translation into English (and shortening) of a personal name based on a word, such as Lakota and Dakota Sioux <i>tataŋka</i> and Cheyenne <i>hotoa'e</i>, meaning ‘buffalo’ or ‘bull’. See also   Bull   5.","History: Majority of the Buffalos trace their origin to the brothers Arthur and William Buffelow, who were recorded in NC in 1750s. Their surname was (later) also spelled <i>Buffalow</i>, <i>Buffaloe</i>, and <i>Buffalo</i>. The word <i>buffalo</i> is even nowadays often misspelled <i>buffelow</i>."]}]},{"name":"Margaret","type":"FIRST","attribution":"Dictionary of First Names © Patrick Hanks and Flavia Hodges 1990, 2003, 2006.","meanings":["An extremely common given name from the Middle Ages onwards, derived via Old French <i>Marguerite</i> and Latin <i>Margarita</i> from Greek <i>Margarītēs</i>, from <i>margaron</i> ‘pearl’, a word ultimately of Hebrew origin. The name was always understood to mean ‘pearl’ throughout the Middle Ages. The first  St Margaret  was martyred at Antioch in Pisidia during the persecution instigated by the  Emperor Diocletian  in the early 4th century. However, there is some doubt about her name, as the same saint is venerated in the Orthodox Church as   Marina .  There were several other saintly bearers of the name, including St Margaret of Scotland (  d. 1093 ), wife of  King Malcolm Canmore  and daughter of Edmund Ironside of England. It was also the name of the wife of  Henry VI  of England,  Margaret of Anjou  (  1430–82 ), and of  Margaret Tudor  (  1489–1541 ), sister of  Henry VIII , who married James IV of Scotland and ruled as regent there after his death.  See also  Margery  ,   Marjorie ."],"variants":[{"name":"Margareta","meanings":["From the Latin form of Greek <i>Margarītēs</i>.  See  <b>Margaret</b>   ."]},{"name":"Margaretta","meanings":["An extremely common given name from the Middle Ages onwards, derived via Old French <i>Marguerite</i> and Latin <i>Margarita</i> from Greek <i>Margarītēs</i>, from <i>margaron</i> ‘pearl’, a word ultimately of Hebrew origin. The name was always understood to mean ‘pearl’ throughout the Middle Ages. The first  St Margaret  was martyred at Antioch in Pisidia during the persecution instigated by the  Emperor Diocletian  in the early 4th century. However, there is some doubt about her name, as the same saint is venerated in the Orthodox Church as   Marina .  There were several other saintly bearers of the name, including St Margaret of Scotland (  d. 1093 ), wife of  King Malcolm Canmore  and daughter of Edmund Ironside of England. It was also the name of the wife of  Henry VI  of England,  Margaret of Anjou  (  1430–82 ), and of  Margaret Tudor  (  1489–1541 ), sister of  Henry VIII , who married James IV of Scotland and ruled as regent there after his death.  See also  Margery  ,   Marjorie ."]}]}],"historicEvents":[{"id":1705192,"age":0,"year":"1328","julianDay":2206102,"title":"First War of Scottish Independence","description":"The First War of Scottish Independence began after England invaded Scotland in 1296. The Treaty of Edinburgh was signed in 1328 which declared peace between the two kingdoms and brought the war to an end.","jurisdictionLevel":2},{"id":1705193,"age":9,"year":"1337","toYear":"1453","julianDay":2209390,"title":"The Hundred Years' War","description":"The Hundred Years' War between France and England was largely due to the question of legitimate succession to the French crown.","jurisdictionLevel":2},{"id":1705195,"age":54,"year":"1382","julianDay":2225826,"title":"Wycliffe's Bible","description":"John Wycliffe, English theologian and professor at the University of Oxford, completed a translation of the Bible from the Latin Vulgate into Middle English. This translation is known as Wycliffe's Bible and was completed around 1382.","url":"https://en.wikipedia.org/wiki/Wycliffe%27s_Bible","urlTitle":"Wikipedia - Wycliffe's Bible","jurisdictionLevel":2}],"lifeSummary":"When Margaret Bovile was born in 1328, in Letheringham, Suffolk, England, her father, William Bovile, was 38 and her mother, Parnel de Scales, was 35. She married Thomas Wingfield in 1350, in Letheringham, Suffolk, England. They were the parents of at least 1 son and 3 daughters. She died in her hometown, and was buried in Letheringham, Suffolk, England."},"et":{"1328–":"1328–Surnud","1328–Female":"1328–Surnud","1320–1378":"1320–1378","1345–1389":"1345–1389","1347–Female":"1347–Surnud","1349–Female":"1349–Surnud","–1414":"–1414","1326–1398":"1326–1398","1346–Female":"1346–Surnud","1290–Male":"1290–Surnud","1294–Female":"1294–Surnud","1350":"1350","1382":"1382","1294":"1294","1290":"1290","1349":"1349","1337":"1337","1326":"1326","1414":"1414","1347":"1347","1346":"1346","1345":"1345","about 1349":"umbes 1349","1389":"1389","1378":"1378","about 1347":"umbes 1347","1453":"1453","1398":"1398","1320":"1320","1328":"1328","Letheringham, Suffolk, England":"Letheringham, Suffolk, England"},"fi":{"1328–":"1328–Kuollut","1328–Female":"1328–Kuollut","1320–1378":"1320–1378","1345–1389":"1345–1389","1347–Female":"1347–Kuollut","1349–Female":"1349–Kuollut","–1414":"–1414","1326–1398":"1326–1398","1346–Female":"1346–Kuollut","1290–Male":"1290–Kuollut","1294–Female":"1294–Kuollut","1350":"1350","1382":"1382","1294":"1294","1290":"1290","1349":"1349","1337":"1337","1326":"1326","1414":"1414","1347":"1347","1346":"1346","1345":"1345","about 1349":"noin 1349","1389":"1389","1378":"1378","about 1347":"noin 1347","1453":"1453","1398":"1398","1320":"1320","1328":"1328","Letheringham, Suffolk, England":"Letheringham, Suffolk, England"},"fr":{"1328–":"1328–Décédée","1328–Female":"1328–Décédée","1320–1378":"1320–1378","1345–1389":"1345–1389","1347–Female":"1347–Décédée","1349–Female":"1349–Décédée","–1414":"–1414","1326–1398":"1326–1398","1346–Female":"1346–Décédée","1290–Male":"1290–Décédé","1294–Female":"1294–Décédée","1350":"1350","1382":