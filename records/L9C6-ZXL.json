edia.org/wiki/Wycliffe%27s_Bible","urlTitle":"Wikipedia - Wycliffe's Bible","jurisdictionLevel":0}],"lifeSummary":"When Thomas Jenkes was born in 1382, in Wolverton, Buckinghamshire, England, his father, John Jenkes, was 30 and his mother, Alice Bowdler, was 26. He married Jacobina Middleton in 1403, in Wolverton, Buckinghamshire, England, United Kingdom. They were the parents of at least 1 son. He died in 1429, in his hometown, at the age of 47."},"et":{"1382–1429":"1382–1429","1382–Male":"1382–Surnud","1393–1435":"1393–1435","1382–Female":"1382–Surnud","1414–1459":"1414–1459","1352–1405":"1352–1405","1356–1384":"1356–1384","1459":"1459","1403":"1403","1414":"1414","1435":"1435","1356":"1356","1377":"1377","1352":"1352","1384":"1384","1382":"1382","1393":"1393","1429":"1429","1405":"1405","Wolverton, Buckinghamshire, England":"Wolverton, Buckinghamshire, England","England":"England","Church Stretton, Shropshire, England":"Church Stretton, Shropshire, Inglismaa, United Kingdom","Wolverton, Buckinghamshire, England, United Kingdom":"Wolverton, Buckinghamshire, England"},"fi":{"1382–1429":"1382–1429","1382–Male":"1382–Kuollut","1393–1435":"1393–1435","1382–Female":"1382–Kuollut","1414–1459":"1414–1459","1352–1405":"1352–1405","1356–1384":"1356–1384","1459":"1459","1403":"1403","1414":"1414","1435":"1435","1356":"1356","1377":"1377","1352":"1352","1384":"1384","1382":"1382","1393":"1393","1429":"1429","1405":"1405","Wolverton, Buckinghamshire, England":"Wolverton, Buckinghamshire, England","England":"England","Church Stretton, Shropshire, England":"Church Stretton, Shropshire, Englanti, Yhdistynyt kuningaskunta","Wolverton, Buckinghamshire, England, United Kingdom":"Wolverton, Buckinghamshire, England"},"fr":{"1382–1429":"1382–1429","1382–Male":"1382–Décédé","1393–1435":"1393–1435","1382–Female":"1382–Décédée","1414–1459":"1414–1459","1352–1405":"1352–1405","1356–1384":"1356–1384","1459":"1459","1403":"1403","1414":"1414","1435":"1435","1356":"1356","1377":"1377","1352