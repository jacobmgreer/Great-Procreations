{"version":"1.2","person":{"datePublished":"2023-12-20","name":"Ann Fitz Alan","nameForms":[{"lang":"en","fullText":"Ann Fitz Alan","parts":[{"type":"http://gedcomx.org/Given","value":"Ann"},{"type":"http://gedcomx.org/Surname","value":"Fitz Alan"}],"order":"EUROTYPIC"}],"gender":"Female","lifespan":"1527–1571","fullLifespan":"1527 –1571","birthDate":"+1527","birthPlace":{"address":"Hawkedon, St. Edmondsbury Borough, Suffolk, England","geo":{"latitude":52.1446,"longitude":0.6275,"@type":"GeoCoordinates"},"@type":"Place"},"deathDate":"+1571","deathPlace":{"address":"Hawkedon, St. Edmondsbury Borough, Suffolk, England","geo":{"latitude":52.1446,"longitude":0.6275,"@type":"GeoCoordinates"},"@type":"Place"},"events":[{"name":"Birth","sources":"0","year":"1527","date":"1527 ","place":"Hawkedon, St. Edmondsbury Borough, Suffolk, England"},{"name":"Death of Parent","sources":"0","year":"1531","date":"1531","place":"Arundel, Sussex, England","age":"4","id":"GHC8-JKT"},{"name":"Death of Parent","sources":"0","year":"1533","date":"20 February 1533","place":"Sussex, England","age":"6","id":"GHC8-FX9"},{"name":"Birth of Child","sources":"0","year":"1549","date":"23 May 1549","place":"Swanhall, Hawkedon, Suffolk, England","age":"22","id":"K88F-CYB"},{"name":"Death","sources":"0","year":"1571","date":"1571","place":"Hawkedon, St. Edmondsbury Borough, Suffolk, England","age":"44"}],"parent":[{"name":"Thomas Earl Drawbaugh","gender":"Male","lifespan":"1490–1531","birthDate":"+1490","deathDate":"+1531","age":41,"@type":"Person","identifier":"GHC8-JKT","url":"https://ancestors.familysearch.org/en/GHC8-JKT/thomas-earl-drawbaugh-1490-1531","published":true},{"name":"Katherine Dinham","gender":"Female","lifespan":"1486–1533","birthDate":"+1486","deathDate":"+1533-02-20","age":47,"@type":"Person","identifier":"GHC8-FX9","url":"https://ancestors.familysearch.org/en/GHC8-FX9/katherine-dinham-1486-1533","published":true}],"sibling":[{"name":"Ann Fitz Alan","gender":"Female","lifespan":"1527