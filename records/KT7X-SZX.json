dom":"Nocton, Lincolnshire, England, United Kingdom","Nocton, Lincolnshire, England":"Nocton, Lincolnshire, England","Lincoln, Lincolnshire, England":"Lincoln, Lincolnshire, England, United Kingdom","nameMeanings":[{"name":"d'Arcy","type":"LAST","attribution":"Dictionary of American Family Names © Patrick Hanks 2003, 2006.","meanings":["Some characteristic forenames:  Irish Eamon, Brendan, Eamonn, Maeve, Malachy, Niamh, Seamus.  French Gisele, Julien, Normand, Alain, Armand, Cecile, Clemence, Dominique, Emile, Gilles, Jean-Paul, Laure.","English (Lancashire) and Irish: of Norman origin, a habitational name from Arcy in Manche, France, with fused preposition <i>d(e)</i> ‘from’.","Irish: in Ireland, this is generally the Norman name (see 1 above), established in Meath by Sir William <i>D'Arcy</i> in the 1360s, but it was also adopted for <b>Ó Dorchaidhe</b> ‘descendant of the dark one’, from <i>dorcha</i> ‘dark, gloomy’, a Connacht name that fell together with the Norman surname, which was introduced by Sir William <i>D'Arcy</i> and Sir John <i>D'Arcy</i>, Chief Justiciar of Ireland in the 14th century."],"variants":[{"name":"Darsey","meanings":["Irish: variant of   Darcy   2.","Scottish: from Dairsie in Fife."]},{"name":"Darcey","meanings":["English (of Norman origin) and Irish (Tipperary): variant of   Darcy  ."]}]},{"name":"Thomas","type":"FIRST","attribution":"Dictionary of First Names © Patrick Hanks and Flavia Hodges 1990, 2003, 2006.","meanings":["New Testament name, borne by one of Christ's twelve apostles, referred to as ‘Thomas, called Didymus’ (John 11:16; 20:24). <i>Didymos</i> is the Greek word for ‘twin’, and the name is the Greek form of an Aramaic byname meaning ‘twin’. The given name has always been popular throughout Christendom, in part because St Thomas's doubts have made him seem a very human character."],"variants":[]}],"lifeSummary":"Thomas d'Arcy I, Lord of Nocton was born in 1118, in Nocton, Lincolnshire, England as the son of Sir Robert d’Arcy - Lord of Nocton and Lady Alice de Cauz. He had at least 1 son with Mrs Thomas d'Arcy. He died in 1178, at the age of 60."},"et":{"1118–1178":"1118–1178","1120–Male":"1120–Surnud","1125–Male":"1125–Surnud","1128–Male":"1128–Surnud","1130–Male":"1130–Surnud","1123–Female":"1123–Surnud","1143–1180":"1143–1180","1091–1163":"1091–1163","–1138":"–1138","1091":"1091","1143":"1143","1142":"1142","1120":"1120","1163":"1163","1130":"1130","1180":"1180","1118":"1118","1128":"1128","1138":"1138","1125":"1125","1178":"1178","1123":"1123","Nocton, Lincolnshire, England, United Kingdom":"Nocton, Lincolnshire, Inglismaa, United Kingdom","Nocton, Lincolnshire, England":"Nocton, Lincolnshire, England","Lincoln, Lincolnshire, England":"Lincoln, Lincolnshire, Inglismaa, United Kingdom"},"fi":{"1118–1178":"1118–1178","1120–Male":"1120–Kuollut","1125–Male":"1125–Kuollut","1128–Male":"1128–Kuollut","1130–Male":"1130–Kuollut","1123–Female":"1123–Kuollut","1143–1180":"1143–1180","1091–1163":"1091–1163","–1138":"–1138","1091":"1091","1143":"1143","1142":"1142","1120":"1120","1163":"1163","1130":"1130","1180":"1180","1118":"1118","1128":"1128","1138":"1138","1125":"1125","1178":"1178","1123":"1123","Nocton, Lincolnshire, England, United Kingdom":"Nocton, Lincolnshire, Englanti, Yhdistynyt kuningaskunta","Nocton, Lincolnshire, England":"Nocton, Lincolnshire, England","Lincoln, Lincolnshire, England":"Lincoln, Lincolnshire, Englanti, Yhdistynyt kuningaskunta"},"fr":{"1118–1178":"1118–1178","1120–Male":"1120–Décédé","1125–Male":"1125–Décédé","1128–Male":"1128–Décédé","1130–Male":"1130–Décédé","1123–Female":"1123–Décédée","1143–1180":"1143–1180","1091–1163":"1091–1163","–1138":"–1138","1091":"1091","1143":"1143","1142":"1142","1120":"1120","1163":"1163","1130":"1130","1180":"1180","1118":"1118","1128":"1128","1138":"1138","1125":"1125","1178":"1178","1123":"1123","Nocton, Lincolnshire, England, United Kingdom":"Nocton, Lincolnshire, Angleterre, Royaume-Uni","Nocton, Lincolnshire, England":"Noc