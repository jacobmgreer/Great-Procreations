{"version":"1.2","person":{"datePublished":"2023-12-20","name":"Robert Cole","nameForms":[{"lang":"en","fullText":"Robert Cole","parts":[{"type":"http://gedcomx.org/Given","value":"Robert"},{"type":"http://gedcomx.org/Surname","value":"Cole"}],"order":"EUROTYPIC"}],"alternateName":"Robert Coles","gender":"Male","lifespan":"1532–1572","fullLifespan":"about 1532–5 February 1572","memoryArtifacts":[{"memoryType":"DOCUMENT","url":"https://sg30p0.familysearch.org/service/records/storage/dascloud/patron/v2/TH-904-96482-2979-72/dist.png?ctx=ArtCtxPublic","memoryUrl":"https://www.familysearch.org/photos/artifacts/100600568","thumbnailUrl":"https://sg30p0.familysearch.org/service/records/storage/dascloud/patron/v2/TH-904-96482-2979-72/thumb200s.jpg?ctx=ArtCtxPublic","deepZoomUrl":"https://sg30p0.familysearch.org/service/records/storage/deepzoomcloud/dzpatron/v1/TH-904-96482-2979-72/scale?ctx=ArtCtxPublic","headline":"Cole Descent in \"The Peerage of Ireland\" p41","@type":"ImageObject"},{"memoryType":"DOCUMENT","url":"https://sg30p0.familysearch.org/service/records/storage/dascloud/patron/v2/TH-904-98928-3877-5/dist.png?ctx=ArtCtxPublic","memoryUrl":"https://www.familysearch.org/photos/artifacts/106534853","thumbnailUrl":"https://sg30p0.familysearch.org/service/records/storage/dascloud/patron/v2/TH-904-98928-3877-5/thumb200s.jpg?ctx=ArtCtxPublic","deepZoomUrl":"https://sg30p0.familysearch.org/service/records/storage/deepzoomcloud/dzpatron/v1/TH-904-98928-3877-5/scale?ctx=ArtCtxPublic","headline":"Thomas Cole of Slade, descent p214 in \"The visitations of the county of Devon\"","@type":"ImageObject"},{"memoryType":"DOCUMENT","url":"https://sg30p0.familysearch.org/service/records/storage/dascloud/patron/v2/TH-904-96479-1084-89/dist.png?ctx=ArtCtxPublic","memoryUrl":"https://www.familysearch.org/photos/artifacts/100592190","thumbnailUrl":"https://sg30p0.familysearch.org/service/records/storage/dascloud/patron/v2/TH-904-96479-1084-89/thumb200s.jpg?ctx=ArtCtxPublic","deepZoomUrl"