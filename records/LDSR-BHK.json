ton, Somerset, England":"Maperton, Somerset, Inglaterra","Wilton, Wiltshire, England":"Wilton, Wiltshire, Inglaterra, United Kingdom","lifeSummary":"Quando Lady Maud de Longchamp nasceu aproximadamente 1240, em Wilton, Herefordshire, Inglaterra, United Kingdom, seu pai, Sir Henry de Longchamp, tinha 31 anos e sua mãe, Joan of Wilton, tinha 77 anos. Ela casou-se com Reginald de Grey 1st Baron Grey de Wilton em 1258, em Wilton, Herefordshire, Inglaterra. Eles tiveram pelo menos 1 filho e 1 filha. Ela faleceu em 21 de novembro de 1302, em Wilton, Herefordshire, Inglaterra, com 63 anos."},"ro":{"about 1240–21 November 1302":"aproximativ 1240–21 noiembrie 1302","1240–1302":"1240–1302","1240–1308":"1240–1308","1258–1323":"1258–1323","1270–1298":"1270–1298","1210–1264":"1210–1264","1165–Female":"1165–Decedată","1264":"1264","1165":"1165","1240":"1240","21 November 1302":"21 noiembrie 1302","1270":"1270","1290":"1290","1259":"1259","1258":"1258","1302":"1302","1323":"1323","1298":"1298","1210":"1210","1308":"1308","about 1240":"aproximativ 1240","Wilton, Herefordshire, England":"Wilton, Herefordshire, England","Wilton Castle, Herefordshire, England":"Wilton, Herefordshire, Anglia, United Kingdom","Wilton, Herefordshire, Inglaterra, United Kingdom":"Wilton, Herefordshire, Anglia, United Kingdom","Maperton, Somerset, England":"Maperton, Somerset, England","Wilton, Wiltshire, England":"Wilton, Wiltshire, Anglia, United Kingdom"},"ru":{"about 1240–21 November 1302":"около 1240 г.–21 ноября 1302 г.","1240–1302":"1240г.–1302г.","1240–1308":"1240г.–1308г.","1258–1323":"1258г.–1323г.","1270–1298":"1270г.–1298г.","1210–1264":"1210г.–1264г.","1165–Female":"1165г.–Умершая","1264":"1264 г.","1165":"1165 г.","1240":"1240 г.","21 November 1302":"21 ноября 1302 г.","1270":"1270 г.","1290":"1290 г.","1259":"1259 г.","1258":"1258 г.","1302":"1302 г.","1323":"1323 г.","1298":"1298 г.","1210":"1210 г.","1308":"1308 г.","about 1240":"около 1240 г.","Wilton, Herefordshire, England":"уилтон, хир