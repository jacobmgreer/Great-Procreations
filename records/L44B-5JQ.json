ale":"1175–Afdød","1180–Female":"1180–Afdød","1175":"1175","1180":"1180","1290":"1290","1206":"1206","1315":"1315","1226":"1226","1259":"1259","1215":"1215","1224":"1224","1201":"1201","1200":"1200","1210":"1210","1229":"1229","1317":"1317","Paston, Norfolk, England":"Paston, Norfolk, England"},"nl":{"1201–":"1201–Overleden","1201–Male":"1201–Overleden","1210–Male":"1210–Overleden","1206–Female":"1206–Overleden","1229–Male":"1229–Overleden","1175–Male":"1175–Overleden","1180–Female":"1180–Overleden","1175":"1175","1180":"1180","1290":"1290","1206":"1206","1315":"1315","1226":"1226","1259":"1259","1215":"1215","1224":"1224","1201":"1201","1200":"1200","1210":"1210","1229":"1229","1317":"1317","Paston, Norfolk, England":"Paston, Norfolk, England"},"en":{"1201–":"1201–Deceased","1201–Male":"1201–Deceased","1210–Male":"1210–Deceased","1206–Female":"1206–Deceased","1229–Male":"1229–Deceased","1175–Male":"1175–Deceased","1180–Female":"1180–Deceased","1175":"1175","1180":"1180","1290":"1290","1206":"1206","1315":"1315","1226":"1226","1259":"1259","1215":"1215","1224":"1224","1201":"1201","1200":"1200","1210":"1210","1229":"1229","1317":"1317","Paston, Norfolk, England":"Paston, Norfolk, England","nameMeanings":[{"name":"Paston","type":"LAST","attribution":"Dictionary of American Family Names © Patrick Hanks 2003, 2006.","meanings":["English (Norfolk): habitational name, chiefly from Paston in Norfolk, probably derived from an Old English personal name <i>Pæcci</i> (genitive <i>Pæcces</i>) or Old English <i>pæsc(e)</i> (the source of northern English dialect <i>pash</i> ‘puddle’) + <i>tūn</i> ‘farmstead, estate’.","English (West Midlands): sometimes a variant of <b>Patstone</b>, a habitational name chiefly from the lost <i>Padston(e)</i> in Bromsgrove (Worcestershire), and occasionally from Padson in Inwardleigh (Devon). The Worcestershire placename derives from the Old English personal name <i>Padda</i> (genitive <i>Paddes</i>) + <i>tūn</i> ‘farmstead, estate’. The etymology of the Devon placename is uncertain due to a lack of medieval forms, though an early spelling suggests the final element is Old English <i>dūn</i> ‘hill’."],"variants":[]},{"name":"William","type":"FIRST","attribution":"Dictionary of First Names © Patrick Hanks and Flavia Hodges 1990, 2003, 2006.","meanings":["Probably the most successful of all the Old French names of Germanic origin that were introduced to England by the Normans. It is derived from Germanic <i>wil</i> ‘will, desire’ + <i>helm</i> ‘helmet, protection’. The fact that it was borne by the Conqueror himself does not seem to have inhibited its favour with the ‘conquered’ population: in the first century after the Conquest it was the commonest male name of all, and not only among the Normans. In the later Middle Ages it was overtaken by   John  , but continued to run second to that name until the 20th century, when the picture became more fragmented."],"variants":[]}],"historicEvents":[{"id":1705187,"age":14,"year":"1215","julianDay":2164830,"title":"Magna Carta","description":"King John of England agreed to a charter of rights called the Magna Carta. The document was originally drafted by the Archbishop of Canterbury to establish peace between King John and a group of rebel barons. The Magna Carta was completed in 1215 and is now considered to be one of the greatest constitutional documents of all time.","url":"https://www.nationalarchives.gov.uk/education/medieval/magna-carta/","urlTitle":"National Archives - Magna Carta","jurisdictionLevel":2},{"id":1705188,"age":23,"year":"1224","julianDay":2168117,"title":"France Declares War on England","description":"France declared war on England as Louis VIII of France attacked Poitou and northern Gascony.","jurisdictionLevel":2},{"id":1705189,"age":58,"year":"1259","julianDay":2180901,"title":"100 Years of Conflict Between England and France Ends","description":"Treaty of Paris was signed on December 4, 1259, which ended 100 years of conflict between England and France.","url":"https://en.wikipedia.org/wiki/Treaty_of_Paris_(1259)","urlTitle":"Wikipedia - Treaty of Paris 1259","jurisdictionLevel":2},{"id":1705190,"age":89,"year":"1290","julianDay":2192224,"title":"Jews Expelled From England","description":"After years of anti-Semitic behavior, King Edward I expelled Jews from England in 1290.","jurisdictionLevel":2},{"id":1705191,"age":114,"year":"1315","toYear":"1317","julianDay":2201354,"title":"Famine Strikes Europe","description":"A famine caused by cold winters and wet summers across Europe caused millions to die due to starvation. Desperation from hunger caused high levels of crime, stampedes in bread lines in London, infanticide, and even cannibalism throughout Europe.","jurisdictionLevel":2}],"lifeSummary":"When William Paston was born in 1201, in Paston, Norfolk, England, his father, William Paston, was 26 and his mother, Mrs. William Paston, was 21. He married Mrs. William Paston in 1226, in Paston, Norfolk, England. They were the parents of at least 1 son. He died in his hometown, and was buried in Paston, Norfolk, England."},"et":{"1201–":"1201–Surnud","1201–Male":"1201–Surnud","1210–Male":"1210–Surnud","1206–Female":"1206–Surnud","1229–Male":"1229–Surnud","1175–Male":"1175–Surnud","1180–Female":"1180–Surnud","1175":"1175","1180":"1180","1290":"1290","1206":"1206","1315":"1315","1226":"1226","1259":"1259","1215":"1215","1224":"1224","1201":"1201","1200":"1200","1210":"1210","1229":"1229","1317":"1317","Paston, Norfolk, England":"Paston, Norfolk, England"},"fi":{"1201–":"1201–Kuollut","1201–Male":"1201–Kuollut","1210–Male":"1210–Kuollut","1206–Female":"1206–Kuollut","1229–Male":"1229–Kuollut","1175–Male":"1175–Kuollut","1180–Female":"1180–Kuollut","1175":"1175","1180":"1180","1290":"1290","1206":"1206","1315":"1315","1226":"1226","1259":"1259","1215":"1215","1224":"1224","1201":"1201","1200":"1200","1210":"1210","1229":"1229","1317":"1317","Paston, Norfolk, England":"Paston, Norfolk, England"},"fr":{"1201–":"