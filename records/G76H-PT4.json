,"1197–Male":"1197–Overleden","1203–Female":"1203–Overleden","1233–Male":"1233–Overleden","1235–Female":"1235–Overleden","1237–Female":"1237–Overleden","1239–Female":"1239–Overleden","1243–Male":"1243–Overleden","1150–Male":"1150–Overleden","1169–Female":"1169–Overleden","1197":"1197","1150":"1150","1290":"1290","abt 1235":"circa 1235","1239":"1239","1315":"1315","abt 1237":"circa 1237","1259":"1259","1215":"1215","1237":"1237","1203":"1203","abt 1239":"circa 1239","1224":"1224","1169":"1169","1235":"1235","Abt 1233":"circa 1233","1233":"1233","1243":"1243","1317":"1317","England":"England","Devon, England":"Devon, England","Heale, Devon, Eng.":"Devon, Engeland, Verenigd Koninkrijk"},"en":{"1197–":"1197–Deceased","1197–Male":"1197–Deceased","1203–Female":"1203–Deceased","1233–Male":"1233–Deceased","1235–Female":"1235–Deceased","1237–Female":"1237–Deceased","1239–Female":"1239–Deceased","1243–Male":"1243–Deceased","1150–Male":"1150–Deceased","1169–Female":"1169–Deceased","1197":"1197","1150":"1150","1290":"1290","abt 1235":"about 1235","1239":"1239","1315":"1315","abt 1237":"about 1237","1259":"1259","1215":"1215","1237":"1237","1203":"1203","abt 1239":"about 1239","1224":"1224","1169":"1169","1235":"1235","Abt 1233":"about 1233","1233":"1233","1243":"1243","1317":"1317","England":"England","Devon, England":"Devon, England","Heale, Devon, Eng.":"Devon, England, United Kingdom","nameMeanings":[{"name":"Hele","type":"LAST","attribution":"Dictionary of Family Names in Britain and Ireland © University of the West of England 2016","meanings":["English:  see  Heal  ."],"variants":[{"name":"Heal","meanings":["English:","topographic or habitational name for someone who lived in or by a nook or hollow, or at a place called with this word (from Middle English <i>hele</i>, Old English <i>heale</i>, dative singular of <i>healh</i> ‘nook or hollow’). Hele in Somerset derives from this word, but the surname arises chiefly from one or more of the many minor localities named Heal(e) or Hele in Devon. In southwestern England and Kent this is an equivalent of   Hale  .","in the southeast Midlands of England, perhaps a variant of   Hell   1."]}]},{"name":"Roger","type":"FIRST","attribution":"Dictionary of First Names © Patrick Hanks and Flavia Hodges 1990, 2003, 2006.","meanings":["From an Old French personal name, <i>Rog(i)er</i>, of Germanic (Frankish) origin, from <i>hrōd</i> ‘fame’ + <i>gār</i>, <i>gēr</i> ‘spear’. This was adopted by the Normans and introduced by them to Britain, replacing the native Old English form <i>Hrōðgār</i>. <i>Roger</i> was one of the most popular boys' names throughout the medieval period, but less so after the Reformation, though it has continued in regular use to the present day.  Roger, Count of Sicily  (  <i>c.</i>1031–1101 ), son of Tancred, recovered Sicily from the Arabs. His son, also called Roger, ruled Sicily as king, presiding over a court noted for its splendour and patronage of the arts."],"variants":[{"name":"Rodger","meanings":["Variant spelling of   Roger  , in part from the surname derived from the given name in the Middle Ages."]}]}],"historicEvents":[{"id":1705187,"age":18,"year":"1215","julianDay":2164830,"title":"Magna Carta","description":"King John of England agreed to a charter of rights called the Magna Carta. The document was originally drafted by the Archbishop of Canterbury to establish peace between King John and a group of rebel barons. The Magna Carta was completed in 1215 and is now considered to be one of the greatest constitutional documents of all time.","url":"https://www.nationalarchives.gov.uk/education/medieval/magna-carta/","urlTitle":"National Archives - Magna Carta","jurisdictionLevel":1},{"id":1705188,"age":27,"year":"1224","julianDay":2168117,"title":"France Declares War on England","description":"France declared war on England as Louis VIII of France attacked Poitou and northern Gascony.","jurisdictionLevel":1},{"id":1705189,"age":62,"year":"1259","julianDay":2180901,"ti