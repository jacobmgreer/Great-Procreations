,"1032":"1032","1086":"1086","1095":"1095","1094":"1094","1008":"1008","1029":"1029","1049":"1049","1035":"1035","1012":"1012","1089":"1089","Normandie, France":"Normandie, Frankrig","Wiltshire, England":"Wiltshire, England","France":"Frankrig","Normandy, France":"Normandie, Frankrig"},"nl":{"1029–8 September 1089":"1029–8 september 1089","1029–1089":"1029–1089","1032–1094":"1032–1094","1049–1095":"1049–1095","1008–1076":"1008–1076","1012–1066":"1012–1066","8 September 1089":"8 september 1089","1066":"1066","1076":"1076","1032":"1032","1086":"1086","1095":"1095","1094":"1094","1008":"1008","1029":"1029","1049":"1049","1035":"1035","1012":"1012","1089":"1089","Normandie, France":"Normandie, Frankrijk","Wiltshire, England":"Wiltshire, England","France":"Frankrijk","Normandy, France":"Normandie, Frankrijk"},"en":{"1029–8 September 1089":"1029–8 September 1089","1029–1089":"1029–1089","1032–1094":"1032–1094","1049–1095":"1049–1095","1008–1076":"1008–1076","1012–1066":"1012–1066","8 September 1089":"8 September 1089","1066":"1066","1076":"1076","1032":"1032","1086":"1086","1095":"1095","1094":"1094","1008":"1008","1029":"1029","1049":"1049","1035":"1035","1012":"1012","1089":"1089","Normandie, France":"Normandy, France","Wiltshire, England":"Wiltshire, England","France":"France","Normandy, France":"Normandy, France","nameMeanings":[{"name":"de","type":"LAST","attribution":"Dictionary of American Family Names © Patrick Hanks 2003, 2006.","meanings":["Some characteristic forenames:  Indian Dilip, Anirban, Gopal, Alok, Anindya, Arunava, Asit, Asok, Dibyendu, Goutam, Indra, Indranil.","Indian: variant of   Dey  ."],"variants":[{"name":"Dey","meanings":["Some characteristic forenames:  Indian Ashit, Indu, Naina, Partha, Soumya, Ajit, Anjan, Anjana, Anup, Arjun, Arun, Ashim.","English, Scottish, and Welsh: variant of   Day  .","German: topographic name from a field name in North Rhine-Westphalia, denoting a sizeable piece of land, from Middle Low German <i>dē</i> ‘thigh’ (referring to the shape of the property)."]}]},{"name":"Robert","type":"FIRST","attribution":"Dictionary of First Names © Patrick Hanks and Flavia Hodges 1990, 2003, 2006.","meanings":["One of the many French names of Germanic origin that were introduced into Britain by the Normans; it has since remained in continuous use. It is derived from the nearly synonymous elements <i>hrōd</i> ‘fame’ + <i>berht</i> ‘bright, famous’, and had a native Old English predecessor of similar form (<i>Hreodbeorht</i>), which was supplanted by the Norman name. Two dukes of Normandy in the 11th century bore the name: the father of  William the Conqueror  (sometimes identified with the legendary Robert the Devil), and his eldest son. It was borne also by three kings of Scotland, notably  Robert the Bruce  (  1274–1329 ), who freed Scotland from English domination. The altered short form <i>Bob</i> is very common, but <i>Hob</i> and <i>Dob</i>, which were common in the Middle Ages and gave rise to surnames, are extinct.  See also  Rupert ."],"variants":[]}],"historicEvents":[{"id":1705181,"age":6,"year":"1035","julianDay":2099086,"title":"England Divided","description":"King Canute died in 1035 and England was divided between his three sons. His son Sweyn received Norway, Harthacanute received Denmark, and Harold Harefoot received North England.","jurisdictionLevel":1},{"id":1705182,"age":37,"year":"1066","julianDay":2110409,"title":"Battle of Hastings","description":"Battle of Hastings was fought between the Norman-French army and the battle-wary English army on October 14, 1066. Duke William of Normandy believed he was the rightful king rather than Harold, who had been crowned king several months earlier. Harold was killed in battle and William was crowned king on Christmas Day 1066.","url":"https://www.english-heritage.org.uk/learn/1066-and-the-norman-conquest/what-happened-battle-hastings/","urlTitle":"English Heritage - Battle of Hastings","jurisdictionLevel":1},{"id":1705183,"age":57,"year":"1086","julianDay":2117714,"title":"Domesday Book","description":"Domesday Book is Britain's earliest extant public record with information containing land surveys and landholdings commissioned by William I. The book was completed in 1086.","url":"https://www.nationalarchives.gov.uk/domesday/","urlTitle":"National Archives - Domesday","jurisdictionLevel":1}],"lifeSummary":"When Robert de Graegham was born in 1029, in France, his father, Comte William D'Eu, was 21 and his mother, Aelis ou Adelaide De Soissons, was 17. He married Nesta de Lacy in 1049, in Normandy, France. They were the parents of at least 1 son. He died on 8 September 1089, in Wiltshire, England, at the age of 60."},"et":{"1029–8 September 1089":"1029–8. september 1089","1029–1089":"1029–1089","1032–1094":"1032–1094","1049–1095":"1049–1095","1008–1076":"1008–1076","1012–1066":"1012–1066","8 September 1089":"8. september 1089","1066":"1066","1076":"1076","1032":"1032","1086":"1086","1095":"1095","1094":"1094","1008":"1008","1029":"1029","1049":"1049","1035":"1035","1012":"1012","1089":"1089","Normandie, France":"Normandie, Prantsusmaa","Wiltshire, England":"Wiltshire, England","France":"Prantsusmaa","Normandy, France":"Normandie, Prantsusmaa"},"fi":{"1029–8 September 1089":"1029–8. syyskuuta 1089","1029–1089":"1029–1089","1032–1094":"1032–1094","1049–1095":"1049–1095","1008–1076":"1008–1076","1012–1066":"1012–1066","8 September 1089":"8. syyskuuta 1089","1066":"1066","1076":"1076","1032":"1032","1086":"1086","1095":"1095","1094":"1094","1008":"1008","1029":"1029","1049":"1049","1035":"1035","1012":"1012","1089":"1089","Normandie, France":"Normandie, Ranska","Wiltshire, England":"Wiltshire, England","France":"Ranska","Normandy, France":"Normandie, Ranska"},"fr":{"1029–8 September 1089":"1029–8 septembre 1089","1029–1089":"1029–1089","1032–1094":"1032–1094","1049–1095":"1049–1095","1008–1076":"1008–1076","1012–1066":"1012–1066","8 September 1089":"8 septembre 1089","1066":"1066","1076":"1076","1032"