37","1315":"1315","1346":"1346","Abt 1322":"okolo 1322","1257":"1257","1453":"1453","1255":"1255","1331":"1331","1276":"1276","about 1331":"okolo 1331","1308":"1308","1328":"1328","1317":"1317","Stowford, Devon, England":"Stowford, Devon, Anglie","Bradfield,,Devon,England":"Bradfield, Devon, Anglie, United Kingdom","West Down Churchyard West Down, North Devon District, Devon, England PLOT Stowford Chapel":"West Down, Devon, Anglie, United Kingdom","Devon, England":"Devon, Anglie"},"da":{"1280–1359":"1280–1359","1276–1331":"1276–1331","1308–1346":"1308–1346","1255–Male":"1255–Afdød","1257–Female":"1257–Afdød","Abt 1308":"omkring 1308","1280":"1280","1290":"1290","1359":"1359","1337":"1337","1315":"1315","1346":"1346","Abt 1322":"omkring 1322","1257":"1257","1453":"1453","1255":"1255","1331":"1331","1276":"1276","about 1331":"omkring 1331","1308":"1308","1328":"1328","1317":"1317","Stowford, Devon, England":"Stowford, Devon, England","Bradfield,,Devon,England":"Bradfield, Devon, England, United Kingdom","West Down Churchyard West Down, North Devon District, Devon, England PLOT Stowford Chapel":"West Down, Devon, England, United Kingdom","Devon, England":"Devon, England"},"nl":{"1280–1359":"1280–1359","1276–1331":"1276–1331","1308–1346":"1308–1346","1255–Male":"1255–Overleden","1257–Female":"1257–Overleden","Abt 1308":"circa 1308","1280":"1280","1290":"1290","1359":"1359","1337":"1337","1315":"1315","1346":"1346","Abt 1322":"circa 1322","1257":"1257","1453":"1453","1255":"1255","1331":"1331","1276":"1276","about 1331":"circa 1331","1308":"1308","1328":"1328","1317":"1317","Stowford, Devon, England":"Stowford, Devon, England","Bradfield,,Devon,England":"Bradfield, Devon, Engeland, Verenigd Koninkrijk","West Down Churchyard West Down, North Devon District, Devon, England PLOT Stowford Chapel":"West Down, Devon, Engeland, Verenigd Koninkrijk","Devon, England":"Devon, England"},"en":{"1280–1359":"1280–1359","1276–1331":"1276–1331","1308–1346":"1308–1346","1255–Male":"1255–Deceased","1257–Female":"1257–Deceased","Abt 1308":"about 1308","1280":"1280","1290":"1290","1359":"1359","1337":"1337","1315":"1315","1346":"1346","Abt 1322":"about 1322","1257":"1257","1453":"1453","1255":"1255","1331":"1331","1276":"1276","about 1331":"about 1331","1308":"1308","1328":"1328","1317":"1317","Stowford, Devon, England":"Stowford, Devon, England","Bradfield,,Devon,England":"Bradfield, Devon, England, United Kingdom","West Down Churchyard West Down, North Devon District, Devon, England PLOT Stowford Chapel":"West Down, Devon, England, United Kingdom","Devon, England":"Devon, England","nameMeanings":[{"name":"Stowford","type":"LAST","attribution":"Dictionary of Family Names in Britain and Ireland © University of the West of England 2016","meanings":["English: locative name from Stockport (Cheshire), which is recorded as  <i>Stokeport</i> in 1188,  <i>Stockford</i> in 1283–8,  <i>Stopford</i> in 1347,  <i>Stoppord</i> in 1337, and  <i>Stapporte</i> in 1583."],"variants":[{"name":"Stockforth","meanings":["English:  see  Stopford  ."]},{"name":"Stopper","meanings":["Some characteristic forenames:  German Matthias.","English: perhaps a nickname for someone with a heavy stride or an awkward way of walking, from a conjectural Middle English word <i>stauper</i>, <i>stouper</i> or, with substitution of the pejorative suffix <i>-ard</i>, Middle English <i>staupard</i>, <i>stoupard</i>.","English: perhaps an occupational name for a maker of stoups, from Middle English <i>staupe</i>, <i>stoupe</i>, <i>stope</i> (Old Norse <i>staup</i>, reinforced by Middle Dutch <i>stoop</i>), ‘jug, often made of leather; measure for liquids; vessel or container for holy water’. Alternatively, the name may derive from an unrecorded Middle English <i>stopper</i>, perhaps ‘maker of pails, buckets, or jugs’, a derivative of Middle English <i>stoppe</i> (Old English <i>stoppa</i>)."]},{"name":"Stockport","meanings":["English:  see  Stopford  ."]},{"name":"Stobbart","meanings":["English: relationship name from the Middle English personal name  <i>Stubard</i>,  <i>Stobard</i>, late Old English * <i>Stubheard</i>, recorded only in E Anglia, so the surname in post-medieval NE England may be due to migration from there via the east coast trade route. The post-medieval surname may have been confused with   Stappard   and   Stopford  , and in E Anglia it may have been absorbed into   Stibbard  ."]},{"name":"Stopard","meanings":["English:  see  Stoppard  ."]},{"name":"Stopforth","meanings":["English:  see  Stopford  ."]},{"name":"Stoppard","meanings":["English: (i)  see  Stopford  . (ii)  see  Stappard  ."]},{"name":"Stappard","meanings":["English: (i) nickname, perhaps for someone with a heavy stride or an awkward way of walking, from a conjectural Middle English word * <i>stauper</i>, * <i>stouper</i> or, with substitution of the pejorative suffix  <i>-ard</i>, Middle English * <i>staupard</i>, * <i>stoupard</i>. Compare 19th-century Whitby (NR Yorks) dialect  <i>stauper</i> ‘a clumsy fellow, a clown’, from the dialect verb  <i>staup</i>,  <i>stowp</i>,  <i>stoop</i> ‘to walk clumsily and heavily’, which is recorded in   English Dialect Dictionary   from Northumb and Cumb southwards as far as Derbys and Lincs. The name was sometimes confused with   Stobbart   and perhaps with   Stopford  . (ii) occupational name, perhaps for a maker of stoups. * <i>Stauper</i>, * <i>Stouper</i>, and * <i>Stoper</i> would be unrecorded derivatives of Middle English * <i>staupe</i>,  <i>stoupe</i>,  <i>stope</i> (Old Scandinavian  <i>staup</i>, reinforced by Middle Dutch  <i>stoop</i>), ‘a jug, often made of leather; a measure for liquids; a vessel or container for holy water’. This explanation accounts for the variation between  <i>Stauper</i>,  <i>Stoper</i>,  <i>Stooper</i>, and possibly  <i>Stopper</i>, but not the forms with final  <i>-d</i>,  <i>-t</i> or  <i>-th</i>, unless through false association with other names, such as (1) above."]},{"name":"Stockford","meanings":["English (Oxfordshire): in northern England and the North Midlands, usually a variant of <i>Stockport</i>, a habitational name from Stockport (Cheshire), from Old English <i>stoc</i> ‘place, secondary settlement’ + <i>port</i> ‘town, market’; elsewhere it may have a different origin, such as Stokeford in East Stoke (Dorset), which takes its name from East Stoke + Old English <i>ford</i> ‘ford’, meaning ‘the ford near (East) Stoke’."]}]},{"name":"John","type":"FIRST","attribution":"Dictionary of First Names © Patrick Hanks and Flavia Hodges 1990, 2003, 2006.","meanings":["New Testament: ‘God is gracious’.  See  <b>John</b> ."],"variants":[]}],"historicEvents":[{"id":1705190,"age":10,"year":"1290","julianDay":2192224,"title":"Jews Expelled From England","description":"After years of anti-Semitic behavior, King Edward I expelled Jews from England in 1290.","jurisdictionLevel":1},{"id":1705191,"age":35,"year":"1315","toYear":"1317","julianDay":2201354,"title":"Famine Strikes Europe","description":"A famine caused by cold winters and wet summers across Europe caused millions to die due to starvation. Desperation from hunger caused high levels of crime, stampedes in bread lines in London, infanticide, and even cannibalism throughout Europe.","jurisdictionLevel":1},{"id":1705192,"age":48,"year":"1328","julianDay":2206102,"title":"First War of Scottish Independence","description":"The First War of Scottish Independence began after England invaded Scotland in 1296. The Treaty of Edinburgh was signed in 1328 which declared peace between the two kingdoms and brought the war to an end.","jurisdictionLevel":1},{"id":1705193,"age":57,"year":"1337","toYear":"1453","julianDay":2209390,"title":"The Hundred Years' War","description":"The Hundred Years' War between France and England was largely due to the question of legitimate succession to the French crown.","jurisdictionLevel":1}],"lifeSummary":"When John Stowford was born in 1280, in Devon, England, his father, John de Stowford, was 26 and his mother, Mrs. John de Stowford, was 24. He married Isabella DeTracy about 1322. They were the parents of at least 1 daughter. He died in 1359, in his hometown, at the age of 79, and was buried in West Down, Devon, England, United Kingdom."},"et":{"1280–1359":"1280–1359","1276–1331":"1276–1331","1308–1346":"1308–1346","1255–Male":"1255–Surnud","1257–Female":"1257–Surnud","Abt 1308":"umbes 1308","1280":"1280","1290":"1290","1359":"1359","1337":"1337","1315":"1315","1346":"1346","Abt 1322":"umbes 1322","1257":"1257","1453":"1453","1255":"1255","1331":"1331","1276":"1276","about 1331":"umbes 1331","1308":"1308","1328":"1328","1317":"1317","Stowford, Devon, England":"Stowford, Devon, England","Bradfield,,Devon,England":"Bradfield, Devon, Inglismaa, United Kingdom","West Down Churchyard West Down, North Devon District, Devon, England PLOT Stowford Chapel":"West Down, Devon, Inglismaa, United Kingdom","Devon, England":"Devon, England"},"fi":{"1280–1359":"1280–1359","1276–1331":"1276–1331","1308–1346":"1308–1346","1255–Male":"1255–Kuollut","1257–Female":"1257–Kuollut","Abt 1308":"noin 1308","1280":"1280","1290":"1290","1359":"1359","1337":"1337","1315":"1315","1346":"1346","Abt 1322":"noin 1322","1257":"1257","1453":"1453","1255":"1255","1331":"1331","1276":"1276","about 1331":"noin 1331","1308":"1308","1328":"1328","1317":"1317","Stowford, Devon, England":"Stowford, Devon, England","Bradfield,,Devon,England":"Bradfield, Devon, Englanti, Yhdistynyt kuningaskunta","West Down Churchyard West Down, North Devon District, Devon, England PLOT Stowford Chapel":"West Down, Devon, Englanti, Yhdistynyt kuningaskunta","Devon, England":"Devon, England"},"fr":{"1280–1359":"1280–1359","1276–1331":"1276–1331","1308–1346":"1308–1346","1255–Male":"1255–Décédé","1257–Female":"1257–Décédée","Abt 1308":"environ 1308","1280":"1280","1290":"1290","1359":"1359","1337":"1337","1315":"1315","1346":"1346","Abt 1322":"environ 1322","1257":"1257","1453":"1453","1255":"1255","1331