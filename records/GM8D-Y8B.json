ngland, United Kingdom":"Illington, Norfolk, England, United Kingdom","Suffolk, England, United Kingdom":"Suffolk, England, United Kingdom","Illington, Norfolk, England":"Illington, Norfolk, England","Stanningfield, Suffolk, England, United Kingdom":"Stanningfield, Suffolk, England, United Kingdom","nameMeanings":[{"name":"De","type":"LAST","attribution":"Dictionary of American Family Names © Patrick Hanks 2003, 2006.","meanings":["Some characteristic forenames:  Indian Dilip, Anirban, Gopal, Alok, Anindya, Arunava, Asit, Asok, Dibyendu, Goutam, Indra, Indranil.","Indian: variant of   Dey  ."],"variants":[{"name":"Dey","meanings":["Some characteristic forenames:  Indian Ashit, Indu, Naina, Partha, Soumya, Ajit, Anjan, Anjana, Anup, Arjun, Arun, Ashim.","English, Scottish, and Welsh: variant of   Day  .","German: topographic name from a field name in North Rhine-Westphalia, denoting a sizeable piece of land, from Middle Low German <i>dē</i> ‘thigh’ (referring to the shape of the property)."]}]},{"name":"Rookewood","type":"LAST","attribution":"Dictionary of American Family Names © Patrick Hanks 2003, 2006.","meanings":["English: habitational name from any of various places in Essex and Sussex named in Middle English with <i>rok(e)</i> ‘rook’ + <i>wod(e)</i> ‘wood’ (Old English <i>hrōc</i>, <i>wudu</i>)."],"variants":[]},{"name":"William","type":"FIRST","attribution":"Dictionary of First Names © Patrick Hanks and Flavia Hodges 1990, 2003, 2006.","meanings":["Probably the most successful of all the Old French names of Germanic origin that were introduced to England by the Normans. It is derived from Germanic <i>wil</i> ‘will, desire’ + <i>helm</i> ‘helmet, protection’. The fact that it was borne by the Conqueror himself does not seem to have inhibited its favour with the ‘conquered’ population: in the first century after the Conquest it was the commonest male name of all, and not only among the Normans. In the later Middle Ages it was overtaken by   John  , but continued to run second to that name until the 20th century, when the picture became more fragmented."],"variants":[]}],"lifeSummary":"When Sir William De Rookewood was born in 1371, in Stanningfield, Suffolk, England, United Kingdom, his father, Sir John De Rookewood, was 21 and his mother, Lady Joan de Swinborne, was 16. He had at least 1 son with Agnes Thorpe. He died on 26 April 1422, in Suffolk, England, United Kingdom, at the age of 51."},"et":{"1371–26 April 1422":"1371–26. aprill 1422","1371–1422":"1371–1422","1374–1436":"1374–1436","1380–Female":"1380–Surnud","1393–Male":"1393–Surnud","1351–Male":"1351–Surnud","1355–Female":"1355–Surnud","1436":"1436","1422":"1422","1355":"1355","1375":"1375","1374":"1374","1351":"1351","1371":"1371","1393":"1393","1380":"1380","26 April 1422":"26. aprill 1422","Illington, Norfolk, England, United Kingdom":"Illington, Norfolk, Inglismaa, United Kingdom","Suffolk, England, United Kingdom":"Suffolk, Inglismaa, United Kingdom","Illington, Norfolk, England":"Illington, Norfolk, England","Stanningfield, Suffolk, England, United Kingdom":"Stanningfield, Suffolk, Inglismaa, United Kingdom"},"fi":{"1371–26 April 1422":"1371–26. huhtikuuta 1422","1371–1422":"1371–1422","1374–1436":"1374–1436","1380–Female":"1380–Kuollut","1393–Male":"1393–Kuollut","1351–Male":"1351–Kuollut","1355–Female":"1355–Kuollut","1436":"1436","1422":"1422","1355":"1355","1375":"1375","1374":"1374","1351":"1351","1371":"1371","1393":"1393","1380":"1380","26 April 1422":"26. huhtikuuta 1422","Illington, Norfolk, England, United Kingdom":"Illington, Norfolk, Englanti, Yhdistynyt kuningaskunta","Suffolk, England, United Kingdom":"Suffolk, Englanti, Yhdistynyt kuningaskunta","Illington, Norfolk, England":"Illington, Norfolk, England","Stanningfield, Suffolk, England, United Kingdom":"Stanningfield, Suffolk, Englanti, Yhdistynyt kuningaskunta"},"fr":{"1371–26 April 1422":"1371–26 avril 1422","1371–1422":"1371–1422","1374–1436":"1374–1436","1380–Female":"1380–Décédée","1393