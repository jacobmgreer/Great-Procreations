os, Cardiganshire, Wales":"Cardiganshire, Wales","of,Is Coed,Cardiganshire,Wales":"Llys Y Coed, Flintshire, Wales, Verenigd Koninkrijk","Prestatyn, Flintshire, Wales":"Prestatyn, Flintshire, Wales"},"en":{"ABT    1365–":"about 1365–Deceased","1365–Female":"1365–Deceased","–Female":"Deceased","–Male":"Deceased","1326–Male":"1326–Deceased","1382–Male":"1382–Deceased","1387–Female":"1387–Deceased","1337–Male":"1337–Deceased","1334–Female":"1334–Deceased","about 1382":"about 1382","1337":"1337","1326":"1326","ABT    1365":"about 1365","1334":"1334","1387":"1387","1365":"1365","about 1387":"about 1387","1382":"1382","Caerwedros, Cardiganshire, Wales":"Cardiganshire, Wales","of,Is Coed,Cardiganshire,Wales":"Llys Y Coed, Flintshire, Wales, United Kingdom","Prestatyn, Flintshire, Wales":"Prestatyn, Flintshire, Wales","nameMeanings":[{"name":"Margred","type":"FIRST","attribution":"Dictionary of First Names © Patrick Hanks and Flavia Hodges 1990, 2003, 2006.","meanings":["equivalent of <b>Margaret</b> ."],"variants":[{"name":"Margaret","meanings":["An extremely common given name from the Middle Ages onwards, derived via Old French <i>Marguerite</i> and Latin <i>Margarita</i> from Greek <i>Margarītēs</i>, from <i>margaron</i> ‘pearl’, a word ultimately of Hebrew origin. The name was always understood to mean ‘pearl’ throughout the Middle Ages. The first  St Margaret  was martyred at Antioch in Pisidia during the persecution instigated by the  Emperor Diocletian  in the early 4th century. However, there is some doubt about her name, as the same saint is venerated in the Orthodox Church as   Marina .  There were several other saintly bearers of the name, including St Margaret of Scotland (  d. 1093 ), wife of  King Malcolm Canmore  and daughter of Edmund Ironside of England. It was also the name of the wife of  Henry VI  of England,  Margaret of Anjou  (  1430–82 ), and of  Margaret Tudor  (  1489–1541 ), sister of  Henry VIII , who married James IV of Scotland and ruled as regent there after his death.  See also  Margery  ,   Marjorie ."]},{"name":"Mared","meanings":["Simplified form of   Marged ."]}]},{"name":"ferch","type":"LAST","attribution":"Dictionary of American Family Names © Patrick Hanks 2003, 2006.","meanings":["German: variant of   Ferg  . Compare   Verch  .","Probably also an Americanized form of German <b>Förtsch</b> (see   Foertsch  ).","Probably also an Americanized form of German <b>Förch</b> (see   Foerch  )."],"variants":[{"name":"Ferg","meanings":["1  ‘Sharp blade’.","2  ‘Wind’."]}]}],"lifeSummary":"When Margred ferch Maredudd was born about 1365, in Llys Y Coed, Flintshire, Wales, United Kingdom, her father, Maredudd ap Thomas, was 30 and her mother, Elen ferch Llywelyn, was 33. She had at least 1 son and 1 daughter with Gruffudd ap Ieuan."},"et":{"ABT    1365–":"umbes 1365–Surnud","1365–Female":"1365–Surnud","–Female":"Surnud","–Male":"Surnud","1326–Male":"1326–Surnud","1382–Male":"1382–Surnud","1387–Female":"1387–Surnud","1337–Male":"1337–Surnud","1334–Female":"1334–Surnud","about 1382":"umbes 1382","1337":"1337","1326":"1326","ABT    1365":"umbes 1365","1334":"1334","1387":"1387","1365":"1365","about 1387":"umbes 1387","1382":"1382","Caerwedros, Cardiganshire, Wales":"Cardiganshire, Wales","of,Is Coed,Cardiganshire,Wales":"Llys Y Coed, Flintshire, Wales, United Kingdom","Prestatyn, Flintshire, Wales":"Prestatyn, Flintshire, Wales"},"fi":{"ABT    1365–":"noin 1365–Kuollut","1365–Female":"1365–Kuollut","–Female":"Kuollut","–Male":"Kuollut","1326–Male":"1326–Kuollut","1382–Male":"1382–Kuollut","1387–Female":"1387–Kuollut","1337–Male":"1337–Kuollut","1334–Female":"1334–Kuollut","about 1382":"noin 1382","1337":"1337","1326":"1326","ABT    1365":"noin 1365","1334":"1334","1387":"1387","1365":"1365","about 1387":"noin 1387","1382":"1382","Caerwedros, Cardiganshire, Wales":"Cardiganshire, Wales","of,Is Coed,Cardiganshire,Wales":"Llys Y Coed, Flintshire, Wales, Yhdistynyt kuningaskunta","Prestatyn, Flintshire, Wales":"Prest