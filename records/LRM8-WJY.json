":"1318–Afdød","1336–1387":"1336–1387","1268–1315":"1268–1315","1291–Female":"1291–Afdød","1291":"1291","1315":"1315","1337":"1337","1359":"1359","about 1307":"omkring 1307","1336":"1336","1334":"1334","1268":"1268","about 1336":"omkring 1336","1453":"1453","1387":"1387","about 1359":"omkring 1359","1308":"1308","1307":"1307","1318":"1318","1328":"1328","1317":"1317","Lancashire":"Lancashire, England, United Kingdom","Tunstall, Lancashire, England":"Tunstall, Lancashire, England, United Kingdom","Lancashire, England":"Lancashire, England","Cantsfield, Lancashire, England":"Cantsfield, Lancashire, England"},"nl":{"about 1307–about 1359":"circa 1307–circa 1359","1307–1359":"1307–1359","1308–1336":"1308–1336","1318–Female":"1318–Overleden","1336–1387":"1336–1387","1268–1315":"1268–1315","1291–Female":"1291–Overleden","1291":"1291","1315":"1315","1337":"1337","1359":"1359","about 1307":"circa 1307","1336":"1336","1334":"1334","1268":"1268","about 1336":"circa 1336","1453":"1453","1387":"1387","about 1359":"circa 1359","1308":"1308","1307":"1307","1318":"1318","1328":"1328","1317":"1317","Lancashire":"Lancashire, Engeland, Verenigd Koninkrijk","Tunstall, Lancashire, England":"Tunstall, Lancashire, Engeland, Verenigd Koninkrijk","Lancashire, England":"Lancashire, England","Cantsfield, Lancashire, England":"Cantsfield, Lancashire, England"},"en":{"about 1307–about 1359":"about 1307–about 1359","1307–1359":"1307–1359","1308–1336":"1308–1336","1318–Female":"1318–Deceased","1336–1387":"1336–1387","1268–1315":"1268–1315","1291–Female":"1291–Deceased","1291":"1291","1315":"1315","1337":"1337","1359":"1359","about 1307":"about 1307","1336":"1336","1334":"1334","1268":"1268","about 1336":"about 1336","1453":"1453","1387":"1387","about 1359":"about 1359","1308":"1308","1307":"1307","1318":"1318","1328":"1328","1317":"1317","Lancashire":"Lancashire, England, United Kingdom","Tunstall, Lancashire, England":"Tunstall, Lancashire, England, United Kingdom","Lancashire, England":"Lancashire, England","Cantsfield, Lancashire, England":"Cantsfield, Lancashire, England","nameMeanings":[{"name":"Tunstall","type":"LAST","attribution":"Dictionary of American Family Names © Patrick Hanks 2003, 2006.","meanings":["English (mainly Lancashire): habitational name from any of various places called with Old English <i>tūn-stall</i> ‘site of a farm, farmstead’, notably Tunstall (Lancashire) and one or more of many Staffordshire places (Tunstall near Stoke on Trent, Tunstall near Adbaston, and four places called Dunstall), but also Tunstall Farm in Mountfield (Sussex) and possibly also Tunstall (Durham, Kent, Norfolk, Shropshire, Suffolk, east and North Yorkshire), and Dunstall (Lincolnshire)."],"variants":[{"name":"Tunstill","meanings":["English (Lancashire and Yorkshire): variant of   Tunstall  ."]}]},{"name":"William","type":"FIRST","attribution":"Dictionary of First Names © Patrick Hanks and Flavia Hodges 1990, 2003, 2006.","meanings":["Probably the most successful of all the Old French names of Germanic origin that were introduced to England by the Normans. It is derived from Germanic <i>wil</i> ‘will, desire’ + <i>helm</i> ‘helmet, protection’. The fact that it was borne by the Conqueror himself does not seem to have inhibited its favour with the ‘conquered’ population: in the first century after the Conquest it was the commonest male name of all, and not only among the Normans. In the later Middle Ages it was overtaken by   John  , but continued to run second to that name until the 20th century, when the picture became more fragmented."],"variants":[]}],"historicEvents":[{"id":1705191,"age":8,"year":"1315","toYear":"1317","julianDay":2201354,"title":"Famine Strikes Europe","description":"A famine caused by cold winters and wet summers across Europe caused millions to die due to starvation. Desperation from hunger caused high levels of crime, stampedes in bread lines in London, infanticide, and even cannibalism throughout Europe.","jurisdictionLevel":2},{"id":1705192,"age":21,"year":"1328","julianDay":2206102,"title":"First War of Scottish Independence","description":"The First War of Scottish Independence began after England invaded Scotland in 1296. The Treaty of Edinburgh was signed in 1328 which declared peace between the two kingdoms and brought the war to an end.","jurisdictionLevel":2},{"id":1705193,"age":30,"year":"1337","toYear":"1453","julianDay":2209390,"title":"The Hundred Years' War","description":"The Hundred Years' War between France and England was largely due to the question of legitimate succession to the French crown.","jurisdictionLevel":2}],"lifeSummary":"When William Tunstall IV was born about 1307, in Cantsfield, Lancashire, England, his father, John Tunstall II, was 41 and his mother, Gundreda, was 18. He had at least 1 son with Amabilla. In 1334, at the age of 28, his occupation is listed as appointed one of the lancashire coroners for 4 years. in Lancashire, England, United Kingdom. He died about 1359, in his hometown, at the age of 54."},"et":{"about 1307–about 1359":"umbes 1307–umbes 1359","1307–1359":"1307–1359","1308–1336":"1308–1336","1318–Female":"1318–Surnud","1336–1387":"1336–1387","1268–1315":"1268–1315","1291–Female":"1291–Surnud","1291":"1291","1315":"1315","1337":"1337","1359":"1359","about 1307":"umbes 1307","1336":"1336","1334":"1334","1268":"1268","about 1336":"umbes 1336","1453":"1453","1387":"1387","about 1359":"umbes 1359","1308":"1308","1307":"1307","1318":"1318","1328":"1328","1317":"1317","Lancashire":"Lancashire, Inglismaa, United Kingdom","Tunstall, Lancashire, England":"Tunstall, Lancashire, Inglismaa, United Kingdom","Lancashire, England":"Lancashire, England","Cantsfield, Lancashire, England":"Cantsfield, Lancashire, England"},"fi":{"about 1307–about 1359":"noin 1307–noin 1359","1307–1359":"1307–1359","1308–1336":"1308–1336","1318–Female":"1318–Kuollut","1336–1387":"1336–1387","1268–1315":"1268–1315","1291–Female":"1291–Kuollut","1291":"1291","1315":"1315","1337":"1