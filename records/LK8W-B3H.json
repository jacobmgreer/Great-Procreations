"1317":"1317","Thorndon Manor; Pershore, Worcestershire, England":"Pershore, Worcestershire, England, United Kingdom","Worcestershire, England":"Worcestershire, England","Pershore, Worcestershire, England":"Pershore, Worcestershire, England, United Kingdom","Worcester, Worcestershire, England":"Worcester, Worcestershire, England","Thornden, Worcestershire, England":"Worcestershire, England, United Kingdom","England":"England","Besford, Worcestershire, England":"Besford, Worcestershire, England","nameMeanings":[{"name":"Perseval","type":"LAST","attribution":"Dictionary of Family Names in Britain and Ireland © University of the West of England 2016","meanings":["Norman, English:  see  Percival  ."],"variants":[{"name":"Percival","meanings":["English:","from the Middle English and Old French personal name <i>Perceval</i>, first found as the name of the hero of an epic poem by the 12th-century French poet Crestien de Troyes, describing the quest for the holy grail. The origin of the name is uncertain; it may be associated with the Gaulish personal name <i>Pritorīx</i> or it may be an altered form of the Celtic name <i>Peredur</i> (see   Priddy  ). It seems to have been altered as the result of folk etymological association with Old French <i>perce(r)</i> ‘to pierce or breach’ + <i>val</i> ‘valley’.","(of Norman origin): habitational name from either of two places called Perceval in Calvados, Normandy (France)."]}]},{"name":"Parnell","type":"FIRST","meanings":["A female name corrupted from Petronilla."],"variants":[]}],"historicEvents":[{"id":1705189,"age":4,"year":"1259","julianDay":2180901,"title":"100 Years of Conflict Between England and France Ends","description":"Treaty of Paris was signed on December 4, 1259, which ended 100 years of conflict between England and France.","url":"https://en.wikipedia.org/wiki/Treaty_of_Paris_(1259)","urlTitle":"Wikipedia - Treaty of Paris 1259","jurisdictionLevel":1},{"id":1705190,"age":35,"year":"1290","julianDay":2192224,"title":"