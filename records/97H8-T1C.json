sen wurde um 1090 in Sachsen, Deutschland geboren. Sie hat nach 1114 in Powiat szczeciński, Woiwodschaft Stettin, Polen Duke Wartislaw Swietoborzyc of Pomerania I geheiratet. Sie hatten mindestens 3 Söhne. Sie starb 1148 im Alter von 59 Jahren in Pommern, Freistaat Preußen, Deutschland."},"ht":{"um 1090–1148":"about 1090–1148","1091–1135":"1091–1135","1107–1150":"1107–1150","1127–1187":"1127–1187","1130–1177":"1130–1177","1090–1148":"1090–1148","1091":"1091","1090":"1090","1187":"1187","1130":"1130","1150":"1150","um 1090":"about 1090","1107":"1107","1127":"1127","1148":"1148","1135":"1135","about 1127":"about 1127","um 1130":"about 1130","9 August 1135":"9 August 1135","1177":"1177","nach 1114":"after 1114","Sachsen, Preußen, Deutschland":"Sachsen, Allemagne","Pommern, Preußen, Deutschland":"Pommern, Freistaat Preußen, Allemagne","Danzig, Pomorskie, Polen":"Gdańsk, pomorskie, Pologne","Gdańskie, Polen":"gdańskie, Pologne","Szczecin,Szczecenskiego,Poland":"Powiat szczeciński, szczecińskie, Pologne"},"hu":{"um 1090–1148":"1090 körül–1148","1091–1135":"1091–1135","1107–1150":"1107–1150","1127–1187":"1127–1187","1130–1177":"1130–1177","1090–1148":"1090–1148","1091":"1091","1090":"1090","1187":"1187","1130":"1130","1150":"1150","um 1090":"1090 körül","1107":"1107","1127":"1127","1148":"1148","1135":"1135","about 1127":"1127 körül","um 1130":"1130 körül","9 August 1135":"1135. augusztus 9.","1177":"1177","nach 1114":"1114 után","Sachsen, Preußen, Deutschland":"Sachsen, Németország","Pommern, Preußen, Deutschland":"Pommern, Freistaat Preußen, Németország","Danzig, Pomorskie, Polen":"Gdańsk, pomorskie, Lengyelország","Gdańskie, Polen":"gdańskie, Lengyelország","Szczecin,Szczecenskiego,Poland":"Powiat szczeciński, szczecińskie, Lengyelország"},"id":{"um 1090–1148":"sekitar 1090–1148","1091–1135":"1091–1135","1107–1150":"1107–1150","1127–1187":"1127–1187","1130–1177":"1130–1177","1090–1148":"1090–1148","1091":"1091","1090":"1090","1187":"1187","1130":"1130","1150":"1150","um