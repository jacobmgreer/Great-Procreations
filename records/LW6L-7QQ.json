1270":"1270","1328":"1328","1317":"1317","1290":"1290","Woolegh, Devonshire, England":"Devon, England","Arlington, Devon, England, United Kingdom":"Arlington, Devon, England, United Kingdom","Devon, England":"Devon, England","nameMeanings":[{"name":"Worlington","type":"LAST","attribution":"Dictionary of American Family Names © Patrick Hanks 2003, 2006.","meanings":["English (Worcestershire): habitational name from Wormington in Gloucestershire or Berry Wormington in Stanton (also Gloucestershire). Perhaps also from Warmington in Northamptonshire. The placenames derive from an Old English personal name <i>Wyrma</i> + Old English connective <i>-ing-</i> + <i>tūn</i> ‘farmstead, estate’."],"variants":[]},{"name":"Mathew","type":"FIRST","attribution":"Dictionary of First Names © Patrick Hanks and Flavia Hodges 1990, 2003, 2006.","meanings":["Variant spelling of   Matthew ."],"variants":[{"name":"Matthew","meanings":["form of the name of the Christian evangelist, author of the first gospel in the New Testament. His name is a form of the Hebrew name <i>Mattathia</i>, meaning ‘gift of God’, which is fairly common in the Old Testament, being rendered in the Authorized Version in a number of different forms: <i>Mattan(i)ah</i>, <i>Mattatha(h)</i>, <i>Mattithiah</i>, <i>Mattathias</i>, and so on. In the Authorized Version, the evangelist is regularly referred to as <i>Matthew</i>, while the apostle chosen to replace Judas Iscariot is distinguished as   Matthias .  A related name from the same Hebrew roots, but reversed, is   Jonathan .  Throughout the English-speaking world <i>Matthew</i> has been particularly popular since the 1970s."]}]}],"historicEvents":[{"id":1705190,"age":20,"year":"1290","julianDay":2192224,"title":"Jews Expelled From England","description":"After years of anti-Semitic behavior, King Edward I expelled Jews from England in 1290.","jurisdictionLevel":1},{"id":1705191,"age":45,"year":"1315","toYear":"1317","julianDay":2201354,"title":"Famine Strikes Europ