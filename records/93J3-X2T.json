nd, United Kingdom":"Blendon, London, England, United Kingdom","Nottingham, England":"Nottinghamshire, England, United Kingdom","Stokesley, Middlesbrough district, North Yorkshire, England, United Kingdom":"Stokesley, Jórvík, England, United Kingdom"},"nl":{"13 April 1549–21 June 1583":"13 april 1549–21 juni 1583","1549–1583":"1549–1583","1551–1635":"1551–1635","1570–1618":"1570–1618","1574–1634":"1574–1634","1500–Male":"1500–Overleden","1529–Female":"1529–Overleden","7 May 1570":"7 mei 1570","21 June 1583":"21 juni 1583","1583":"1583","1570":"1570","June 1574":"juni 1574","1635":"1635","1634":"1634","1500":"1500","1574":"1574","1551":"1551","1618":"1618","1529":"1529","1549":"1549","13 April 1549":"13 april 1549","London, City of London, Greater London, England, United Kingdom":"Blendon, London, Engeland, Verenigd Koninkrijk","Nottingham, England":"Nottinghamshire, Engeland, Verenigd Koninkrijk","Stokesley, Middlesbrough district, North Yorkshire, England, United Kingdom":"Stokesley, Yorkshire, Engeland, Verenigd Koninkrijk"},"en":{"13 April 1549–21 June 1583":"13 April 1549–21 June 1583","1549–1583":"1549–1583","1551–1635":"1551–1635","1570–1618":"1570–1618","1574–1634":"1574–1634","1500–Male":"1500–Deceased","1529–Female":"1529–Deceased","7 May 1570":"7 May 1570","21 June 1583":"21 June 1583","1583":"1583","1570":"1570","June 1574":"June 1574","1635":"1635","1634":"1634","1500":"1500","1574":"1574","1551":"1551","1618":"1618","1529":"1529","1549":"1549","13 April 1549":"13 April 1549","London, City of London, Greater London, England, United Kingdom":"Blendon, London, England, United Kingdom","Nottingham, England":"Nottinghamshire, England, United Kingdom","Stokesley, Middlesbrough district, North Yorkshire, England, United Kingdom":"Stokesley, Yorkshire, England, United Kingdom","nameMeanings":[{"name":"Overman","type":"LAST","attribution":"Dictionary of American Family Names © Patrick Hanks 2003, 2006.","meanings":["Dutch: status name from Middle Dutch <i>overman</i> ‘judge, arbitrator, go-between’.","Americanized form of German   Overmann  .","English (East Anglia): occupational name from Middle English <i>overman</i> ‘leader, ruler; supervisor, overseer’, perhaps also ‘judge, arbitrator’ (compare 1 above)."],"variants":[{"name":"Overland","meanings":["Some characteristic forenames:  Scandinavian Borge, Erik, Jan Erik, Nordahl, Tryg.","Norwegian (mainly <b>Øverland</b>): habitational name from any of some twenty farmsteads, mainly in Telemark and on the west coast, named Øverland, Overland, from <i>øver, over</i> ‘upper’ + <i>land</i> ‘(piece of) land, farmstead'.","English (Norfolk and Cambridgeshire): apparently a habitational name from Overland Farm in Ash next Sandwich (Kent), although the name is now strongly associated with northern East Anglia. The placename derives from Old English <i>ōfer</i> ‘bank’ + <i>land</i> ‘land’."]},{"name":"Overmann","meanings":["North German:","topographic name for someone who lived on the bank of a river, from Middle Low German <i>over</i> ‘river bank’ + <i>man</i> ‘man’.","status name for a judge or arbitrator (compare Dutch   Overman  )."]}]},{"name":"Elizabeth","type":"FIRST","attribution":"Dictionary of First Names © Patrick Hanks and Flavia Hodges 1990, 2003, 2006.","meanings":["The usual spelling of   Elisabeth   in English. It is recorded in the medieval period, but was made popular by being borne by  Queen Elizabeth I  of England (  1533–1603 ). In the 20th century it again became extremely fashionable, partly because it was the name of  Elizabeth Bowes-Lyon  (  1900–2002 ), who in  1936  became Queen Elizabeth as the wife of King George VI, and after his death in  1952  achieved great public affection as Queen Mother for nearly half a century. Even more influentially, it is the name of her daughter  Queen Elizabeth II  (  b. 1926 )."],"variants":[{"name":"Elisabeth","meanings":["The spelling of   Elizabeth   used in the Authorized Version of the New Testament, and in most modern European languages. This was the name of the mother of John the Baptist (Luke 1:60). Etymologically, the name means ‘God is my oath’, and is therefore identical with <i>Elisheba</i>, the name of the wife of Aaron according to the genealogy at Exodus 6:23. The final element seems to have been altered by association with Hebrew <i>shabbāth</i> ‘Sabbath’."]}]}],"lifeSummary":"When Elizabeth Overman was born on 13 April 1549, in Blendon, London, England, United Kingdom, her father, Lawrence Overman, was 49 and her mother, Mrs Lawrence Overman, was 20. She married Thomas Henry Rippon Ripley on 7 May 1570, in Nottinghamshire, England, United Kingdom. They were the parents of at least 2 sons. She died on 21 June 1583, at the age of 34."},"et":{"13 April 1549–21 June 1583":"13. aprill 1549–21. juuni 1583","1549–1583":"1549–1583","1551–1635":"1551–1635","1570–1618":"1570–1618","1574–1634":"1574–1634","1500–Male":"1500–Surnud","1529–Female":"1529–Surnud","7 May 1570":"7. mai 1570","21 June 1583":"21. juuni 1583","1583":"1583","1570":"1570","June 1574":"juuni 1574","1635":"1635","1634":"1634","1500":"1500","1574":"1574","1551":"1551","1618":"1618","1529":"1529","1549":"1549","13 April 1549":"13. aprill 1549","London, City of London, Greater London, England, United Kingdom":"Blendon, London, Inglismaa, United Kingdom","Nottingham, England":"Nottinghamshire, Inglismaa, United Kingdom","Stokesley, Middlesbrough district, North Yorkshire, England, United Kingdom":"Stokesley, Yorkshire, Inglismaa, United Kingdom"},"fi":{"13 April 1549–21 June 1583":"13. huhtikuuta 1549–21. kesäkuuta 1583","1549–1583":"1549–1583","1551–1635":"1551–1635","1570–1618":"1570–1618","1574–1634":"1574–1634","1500–Male":"1500–Kuollut","1529–Female":"1529–Kuollut","7 May 1570":"7. toukokuuta 1570","21 June 1583":"21. kesäkuuta 1583","1583":"1583","1570":"1570","June 1574":"kesäkuu 1574","1635":"1635","1634":"1634","1500":"1500","1574":"1574","1551":"1551","1618":"1618","1529":"1529","1549":"1549","13 Apri