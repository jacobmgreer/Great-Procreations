eden","1312–1379":"1312–1379","1330–1439":"1330–1439","1340–Male":"1340–Overleden","1289–1338":"1289–1338","1330":"1330","1340":"1340","1382":"1382","1338":"1338","1315":"1315","1379":"1379","1312":"1312","1289":"1289","1310":"1310","about 1330":"circa 1330","1439":"1439","about 1340":"circa 1340","1328":"1328","1317":"1317","Nottinghamshire, England":"Nottinghamshire, England","England":"England"},"en":{"1310–":"1310–Deceased","1310–Male":"1310–Deceased","1312–1379":"1312–1379","1330–1439":"1330–1439","1340–Male":"1340–Deceased","1289–1338":"1289–1338","1330":"1330","1340":"1340","1382":"1382","1338":"1338","1315":"1315","1379":"1379","1312":"1312","1289":"1289","1310":"1310","about 1330":"about 1330","1439":"1439","about 1340":"about 1340","1328":"1328","1317":"1317","Nottinghamshire, England":"Nottinghamshire, England","England":"England","nameMeanings":[{"name":"Staveley","type":"LAST","attribution":"Dictionary of American Family Names © Patrick Hanks 2003, 2006.","meanings":["English: habitational name from any of the four places called Staveley (in Lancashire, Yorkshire, Derbyshire, and Westmorland), or from Stalybridge in Greater Manchester, which was formerly known as Stavelegh. Compare   Staley  ."],"variants":[{"name":"Staley","meanings":["English: habitational name from Staveley in Derbyshire, Stayley in Lancashire (now called Stalybridge in Greater Manchester), or perhaps Staveley (Westmorland), Staveley (Lancashire), or Staveley (Yorkshire). The placenames all derive from Old English <i>stæf</i> ‘staff, stave, rod’ (genitive plural <i>stafa</i>) + <i>lēah</i> ‘woodland clearing’. Compare   Staveley  ."]},{"name":"Stabley","meanings":["English (Yorkshire): variant of   Staveley   and   Stabler  , two names of different origins but whose pronunciations were much confused from the 17th century onward."]},{"name":"Stavely","meanings":["English: variant of   Staveley  ."]}]},{"name":"Robert","type":"FIRST","attribution":"Dictionary of First Names © Patrick Hanks and Flavia Hodges 1990, 2003, 2006.","meanings":["One of the many French names of Germanic origin that were introduced into Britain by the Normans; it has since remained in continuous use. It is derived from the nearly synonymous elements <i>hrōd</i> ‘fame’ + <i>berht</i> ‘bright, famous’, and had a native Old English predecessor of similar form (<i>Hreodbeorht</i>), which was supplanted by the Norman name. Two dukes of Normandy in the 11th century bore the name: the father of  William the Conqueror  (sometimes identified with the legendary Robert the Devil), and his eldest son. It was borne also by three kings of Scotland, notably  Robert the Bruce  (  1274–1329 ), who freed Scotland from English domination. The altered short form <i>Bob</i> is very common, but <i>Hob</i> and <i>Dob</i>, which were common in the Middle Ages and gave rise to surnames, are extinct.  See also  Rupert ."],"variants":[]}],"historicEvents":[{"id":1705191,"age":5,"year":"1315","toYear":"1317","julianDay":2201354,"title":"Famine Strikes Europe","description":"A famine caused by cold winters and wet summers across Europe caused millions to die due to starvation. Desperation from hunger caused high levels of crime, stampedes in bread lines in London, infanticide, and even cannibalism throughout Europe.","jurisdictionLevel":0},{"id":1705192,"age":18,"year":"1328","julianDay":2206102,"title":"First War of Scottish Independence","description":"The First War of Scottish Independence began after England invaded Scotland in 1296. The Treaty of Edinburgh was signed in 1328 which declared peace between the two kingdoms and brought the war to an end.","jurisdictionLevel":0},{"id":1705195,"age":72,"year":"1382","julianDay":2225826,"title":"Wycliffe's Bible","description":"John Wycliffe, English theologian and professor at the University of Oxford, completed a translation of the Bible from the Latin Vulgate into Middle English. This translation is known as Wycliffe's Bible and was completed around 1382.","url":"https://en.wikipedia.org/wiki/Wycliffe%27s_Bible","urlTitle":"Wikipedia - Wycliffe's Bible","jurisdictionLevel":0}],"lifeSummary":"Robert Staveley was born in 1310, in England as the son of Sir Robert Stavely. He had at least 1 son and 1 daughter with Lady Joan Issabella Staveley."},"et":{"1310–":"1310–Surnud","1310–Male":"1310–Surnud","1312–1379":"1312–1379","1330–1439":"1330–1439","1340–Male":"1340–Surnud","1289–1338":"1289–1338","1330":"1330","1340":"1340","1382":"1382","1338":"1338","1315":"1315","1379":"1379","1312":"1312","1289":"1289","1310":"1310","about 1330":"umbes 1330","1439":"1439","about 1340":"umbes 1340","1328":"1328","1317":"1317","Nottinghamshire, England":"Nottinghamshire, England","England":"England"},"fi":{"1310–":"1310–Kuollut","1310–Male":"1310–Kuollut","1312–1379":"1312–1379","1330–1439":"1330–1439","1340–Male":"1340–Kuollut","1289–1338":"1289–1338","1330":"1330","1340":"1340","1382":"1382","1338":"1338","1315":"1315","1379":"1379","1312":"1312","1289":"1289","1310":"1310","about 1330":"noin 1330","1439":"1439","about 1340":"noin 1340","1328":"1328","1317":"1317","Nottinghamshire, England":"Nottinghamshire, England","England":"England"},"fr":{"1310–":"1310–Décédé","1310–Male":"1310–Décédé","1312–1379":"1312–1379","1330–1439":"1330–1439","1340–Male":"1340–Décédé","1289–1338":"1289–1338","1330":"1330","1340":"1340","1382":"1382","1338":"1338","1315":"1315","1379":"1379","1312":"1312","1289":"1289","1310":"1310","about 1330":"environ 1330","1439":"1439","about 1340":"environ 1340","1328":"1328","1317":"1317","Nottinghamshire, England":"Nottinghamshire, Angleterre","England":"Angleterre","lifeSummary":"Robert Staveley est né en 1310, à Angleterre, fils de Sir Robert Stavely. Il a eu au moins 1 fils et 1 fille avec Lady Joan Issabella Staveley."},"de":{"1310–":"1310–Verstorben","1310–Male":"1310–Verstorben","1312–1379":"1312–1379","1330–1439":"1330–1439","1340–Male":"1340–Verstorben","1289–1338":"1289–1338","1330":"1330","1340":"134