:"1480–1557","1489–1557":"1489–1557","1492–Female":"1492–Zesnulá","1495–1525":"1495–1525","1520–1600":"1520–1600","1524–1588":"1524–1588","1450–1504":"1450–1504","1464–1505":"1464–1505","before 1520":"před 1520","1495":"1495","1450":"1450","1492":"1492","1480":"1480","1569":"1569","1558":"1558","1525":"1525","1524":"1524","1557":"1557","1600":"1600","1588":"1588","1489":"1489","1587":"1587","1520":"1520","1585":"1585","1464":"1464","1549":"1549","1505":"1505","1504":"1504","Cockerham, Lancashire, , England":"Cockerham, Lancashire, Anglie, United Kingdom","Bocking, Essex, England":"Bocking, Essex, Anglie"},"da":{"1492–":"1492–Afdød","1480–1557":"1480–1557","1489–1557":"1489–1557","1492–Female":"1492–Afdød","1495–1525":"1495–1525","1520–1600":"1520–1600","1524–1588":"1524–1588","1450–1504":"1450–1504","1464–1505":"1464–1505","before 1520":"før 1520","1495":"1495","1450":"1450","1492":"1492","1480":"1480","1569":"1569","1558":"1558","1525":"1525","1524":"1524","1557":"1557","1600":"1600","1588":"1588","1489":"1489","1587":"1587","1520":"1520","1585":"1585","1464":"1464","1549":"1549","1505":"1505","1504":"1504","Cockerham, Lancashire, , England":"Cockerham, Lancashire, England, United Kingdom","Bocking, Essex, England":"Bocking, Essex, England"},"nl":{"1492–":"1492–Overleden","1480–1557":"1480–1557","1489–1557":"1489–1557","1492–Female":"1492–Overleden","1495–1525":"1495–1525","1520–1600":"1520–1600","1524–1588":"1524–1588","1450–1504":"1450–1504","1464–1505":"1464–1505","before 1520":"vóór 1520","1495":"1495","1450":"1450","1492":"1492","1480":"1480","1569":"1569","1558":"1558","1525":"1525","1524":"1524","1557":"1557","1600":"1600","1588":"1588","1489":"1489","1587":"1587","1520":"1520","1585":"1585","1464":"1464","1549":"1549","1505":"1505","1504":"1504","Cockerham, Lancashire, , England":"Cockerham, Lancashire, Engeland, Verenigd Koninkrijk","Bocking, Essex, England":"Bocking, Essex, England"},"en":{"1492–":"1492–Deceased","1480–1557":"1480–1557","1489–1557":"1489–1557","1492–Female":"1492–Deceased","1495–1525":"1495–1525","1520–1600":"1520–1600","1524–1588":"1524–1588","1450–1504":"1450–1504","1464–1505":"1464–1505","before 1520":"before 1520","1495":"1495","1450":"1450","1492":"1492","1480":"1480","1569":"1569","1558":"1558","1525":"1525","1524":"1524","1557":"1557","1600":"1600","1588":"1588","1489":"1489","1587":"1587","1520":"1520","1585":"1585","1464":"1464","1549":"1549","1505":"1505","1504":"1504","Cockerham, Lancashire, , England":"Cockerham, Lancashire, England, United Kingdom","Bocking, Essex, England":"Bocking, Essex, England","nameMeanings":[{"name":"Meade","type":"LAST","attribution":"Dictionary of American Family Names © Patrick Hanks 2003, 2006.","meanings":["Irish: habitational name from <b>Midheach</b>, the Gaelic name of County Meath in Ireland. Its Anglicized forms are now indistinguishable from those of the English name   Mead  .","English: variant of   Mead  ."],"variants":[{"name":"Mead","meanings":["English:","topographic name for someone who lived by a meadow, from Middle English <i>mede</i> ‘meadow’ (Old English <i>mǣd</i>), or a habitational name from one or more of the many places so named, such as Meads in Harford (Devon).","perhaps from Middle English <i>mede</i> ‘mead, alcoholic drink of fermented honey and water’, possibly denoting one who was fond of the drink or who made or sold mead. Compare   Meader  ."]}]},{"name":"Margaret","type":"FIRST","attribution":"Dictionary of First Names © Patrick Hanks and Flavia Hodges 1990, 2003, 2006.","meanings":["An extremely common given name from the Middle Ages onwards, derived via Old French <i>Marguerite</i> and Latin <i>Margarita</i> from Greek <i>Margarītēs</i>, from <i>margaron</i> ‘pearl’, a word ultimately of Hebrew origin. The name was always understood to mean ‘pearl’ throughout the Middle Ages. The first  St Margaret  was martyred at Antioch in Pisidia during the persecution instigated by the  Emperor Diocletian  in the early 4th century. However, there is some doubt about her name, as the same saint is venerated in the Orthodox Church as   Marina .  There were several other saintly bearers of the name, including St Margaret of Scotland (  d. 1093 ), wife of  King Malcolm Canmore  and daughter of Edmund Ironside of England. It was also the name of the wife of  Henry VI  of England,  Margaret of Anjou  (  1430–82 ), and of  Margaret Tudor  (  1489–1541 ), sister of  Henry VIII , who married James IV of Scotland and ruled as regent there after his death.  See also  Margery  ,   Marjorie ."],"variants":[{"name":"Margareta","meanings":["From the Latin form of Greek <i>Margarītēs</i>.  See  <b>Margaret</b>   ."]},{"name":"Margaretta","meanings":["An extremely common given name from the Middle Ages onwards, derived via Old French <i>Marguerite</i> and Latin <i>Margarita</i> from Greek <i>Margarītēs</i>, from <i>margaron</i> ‘pearl’, a word ultimately of Hebrew origin. The name was always understood to mean ‘pearl’ throughout the Middle Ages. The first  St Margaret  was martyred at Antioch in Pisidia during the persecution instigated by the  Emperor Diocletian  in the early 4th century. However, there is some doubt about her name, as the same saint is venerated in the Orthodox Church as   Marina .  There were several other saintly bearers of the name, including St Margaret of Scotland (  d. 1093 ), wife of  King Malcolm Canmore  and daughter of Edmund Ironside of England. It was also the name of the wife of  Henry VI  of England,  Margaret of Anjou  (  1430–82 ), and of  Margaret Tudor  (  1489–1541 ), sister of  Henry VIII , who married James IV of Scotland and ruled as regent there after his death.  See also  Margery  ,   Marjorie ."]}]}],"historicEvents":[{"id":1705201,"age":57,"year":"1549","julianDay":2286821,"title":"Book of Common Prayer","description":"Book of Common Prayer, a product of the English Reformation, was published in 1549 for assistance in the administration of the sacraments and other rites and ceremonies of the church according to the use of the Church of England. The book outlined morning, evening, and communion prayers and orders for baptism and marriage, thus making England a truly Protestant state.","url":"https://en.wikipedia.org/wiki/Book_of_Common_Prayer","urlTitle":"Wikipedia - Book of Common Prayer","jurisdictionLevel":2},{"id":1705202,"age":66,"year":"1558","julianDay":2290108,"title":"Act of Uniformity","description":"The Act of Uniformity was passed by the Parliament of England and required all people to go to church once a week. The consequence of not attending church was a fine of 12 pence, which was a considerable amount for a poor person.","jurisdictionLevel":2},{"id":1705205,"age":77,"year":"1569","julianDay":2294126,"title":"State Lottery","description":"A State Lottery was recorded in 1569. The tickets were sold at St. Paul's Cathedral in London.","jurisdictionLevel":2},{"id":1705207,"age":93,"year":"1585","julianDay":2299970,"title":"The First English Colony is Established in America","description":"England established its first colony in North America in 1585 as a way to generate additional wealth. The colony was named Virginia, after the virgin Queen Elizabeth I.","jurisdictionLevel":2},{"id":1705208,"age":95,"year":"1587","julianDay":2300700,"title":"Elizabeth I Signs Death Warrant for Mary, Queen of Scots","description":"Elizabeth I signed the death warrant for Mary, Queen of Scots, on February 1, 1587, as she was found guilty of plotting to assasinate Elizabeth. Mary, Queen of Scots, was beheaded at Fotheringhay Castle in England on February 8, 1587.","url":"https://www.elizabethi.org/mary_queen_of_scots/","urlTitle":"Elizabeth I.org - Mary Queen of Scots","jurisdictionLevel":2}],"lifeSummary":"When Margaret Meade was born in 1492, in Bocking, Essex, England, her father, Thomas Meade IV, was 43 and her mother, Johanna, was 28. She married Thomas Fytche before 1520. They were the parents of at least 1 son and 1 daughter."},"et":