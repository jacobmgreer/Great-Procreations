ited Kingdom"},"nl":{"1451–":"1451–Overleden","1449–Male":"1449–Overleden","1451–Female":"1451–Overleden","–Female":"Overleden","1449–1494":"1449–1494","1470–1488":"1470–1488","1472–1503":"1472–1503","1475–1570":"1475–1570","1475–Female":"1475–Overleden","1390–1464":"1390–1464","1400–Female":"1400–Overleden","about 1470":"circa 1470","before 1420":"vóór 1420","1451":"1451","1472":"1472","1494":"1494","1570":"1570","1470":"1470","1390":"1390","1503":"1503","1477":"1477","1400":"1400","1488":"1488","1475":"1475","1464":"1464","1449":"1449","Sullington, Sussex, England":"Sullington, Sussex, England","Earl, Sussex, England":"Sussex, England","England":"Engeland, Verenigd Koninkrijk","Hascombe, Surrey, England":"Hascombe, Surrey, England","Slaugham, Sussex, England":"Slaugham, Sussex, England","Cumberland, England":"Cumberland, Engeland, Verenigd Koninkrijk"},"en":{"1451–":"1451–Deceased","1449–Male":"1449–Deceased","1451–Female":"1451–Deceased","–Female":"Deceased","1449–1494":"1449–1494","1470–1488":"1470–1488","1472–1503":"1472–1503","1475–1570":"1475–1570","1475–Female":"1475–Deceased","1390–1464":"1390–1464","1400–Female":"1400–Deceased","about 1470":"about 1470","before 1420":"before 1420","1451":"1451","1472":"1472","1494":"1494","1570":"1570","1470":"1470","1390":"1390","1503":"1503","1477":"1477","1400":"1400","1488":"1488","1475":"1475","1464":"1464","1449":"1449","Sullington, Sussex, England":"Sullington, Sussex, England","Earl, Sussex, England":"Sussex, England","England":"England, United Kingdom","Hascombe, Surrey, England":"Hascombe, Surrey, England","Slaugham, Sussex, England":"Slaugham, Sussex, England","Cumberland, England":"Cumberland, England, United Kingdom","nameMeanings":[{"name":"Fleming","type":"LAST","attribution":"Dictionary of American Family Names © Patrick Hanks 2003, 2006.","meanings":["English: ethnic name for someone from Flanders, from Middle English <i>fleming</i>. The word reflects a Norman French form of Old French <i>flamanc</i> ‘Fleming’, from the stem <i>flam-</i> + the ancient Germanic suffix <i>-ing</i>. In the Middle Ages there was considerable commercial intercourse between England and the Netherlands, particularly in the wool trade, and many Flemish weavers and dyers settled in England. This surname is also common in south and east Scotland and in Ireland, where it is sometimes found in the Gaelicized form <b>Pléamonn</b>.","German: variant of   Flemming  , cognate with 1 above."],"variants":[{"name":"Flemings","meanings":["English: plural form of   Fleming  .","Americanized form of Flemish <b>Vleminckx</b>: patronymic from <b>Vleminck</b>, an ethnic name for someone from Flanders, Middle Dutch <i>vleminc</i>."]},{"name":"Flanders","meanings":["English: ethnic name from Middle English <i>Fla(u)ndres</i> ‘Flanders’, denoting someone from Flanders, a historical region covering parts of modern-day Belgium, France, and the Netherlands. Compare   Fleming  ."]},{"name":"Fleeman","meanings":["English: variant of   Fleming  ."]},{"name":"Flemming","meanings":["German: ethnic name for someone from Flanders, Middle High German <i>vlaeminc</i>. People from Flanders spread throughout Germany, as well as England, in the Middle Ages as clothmakers and dyers.","English: variant of   Fleming  ."]},{"name":"Flamenco","meanings":["Spanish: ethnic name from <i>flamenco</i> ‘Fleming, Flemish person’ (see   Fleming  )."]}]},{"name":"Anne","type":"FIRST","attribution":"Dictionary of First Names © Patrick Hanks and Flavia Hodges 1990, 2003, 2006.","meanings":["variant of   Anne  , in common use as a given name in most European languages. Among people with a classical education, it has from time to time been associated with  Virgil's  Aeneid, where it is borne by the sister of  Dido , Queen of Carthage. This Phoenician name may ultimately be of Semitic origin, and thus related to the biblical <i>Anne</i>. However, the connection, if it exists, is indirect rather than direct."],"variants":[]}],"lifeSummary":"When