444":"after 1444","Cambridgeshire, England":"Cambridgeshire, England, United Kingdom","Cambridge, Cambridgeshire, England":"Cambridge, Cambridgeshire, England, United Kingdom","Little Eversden, Ipswich, Suffolk, England":"Ipswich, Suffolk, England","Oakington, Cambridgeshire, England":"Oakington, Cambridgeshire, England","nameMeanings":[{"name":"Leete","type":"LAST","attribution":"Dictionary of American Family Names © Patrick Hanks 2003, 2006.","meanings":["English: variant of   Leet  .","History: An early American bearer of this name was one of the founders ofGuilford, CT. William Leete (<i>c.</i> 1613–83), a colonial governorof New Haven colony and CT, was born at Dodington, Huntingtonshire,England. He converted to Puritanism and sailed for America to escapepersecution in May 1639."],"variants":[{"name":"Leet","meanings":["English: topographic name for someone who lived by a watercourse orroad junction, Old English <i>gelǣt</i>, or a habitational namefrom Leat in Devon, or The Leete in Essex, named with this element."]}]},{"name":"Thomas","type":"FIRST","attribution":"Dictionary of First Names © Patrick Hanks and Flavia Hodges 1990, 2003, 2006.","meanings":["New Testament name, borne by one of Christ's twelve apostles, referred to as ‘Thomas, called Didymus’ (John 11:16; 20:24). <i>Didymos</i> is the Greek word for ‘twin’, and the name is the Greek form of an Aramaic byname meaning ‘twin’. The given name has always been popular throughout Christendom, in part because St Thomas's doubts have made him seem a very human character."],"variants":[]}],"historicEvents":[{"id":1705197,"age":11,"year":"1455","julianDay":2252488,"title":"Wars of the Roses","description":"Wars of the Roses was a series of English civil wars for control of the throne of England between the royal families House of Lancaster and the House of York. The name of the war was derived as the red rose was the symbol of the Lancastrians and the white rose was the symbol of the Yorks.","url":"https://www.history.com/topics/british-history/wars-of-the-roses","urlTitle":"History - Wars of the Roses","jurisdictionLevel":2}],"lifeSummary":"When Thomas Leete was born in 1444, in Oakington, Cambridgeshire, England, his father, Thomas Leete, was 21 and his mother, Isabella Everston, was 18. He married Alse Huntington in 1474. They were the parents of at least 2 sons. He died on 3 February 1495, in his hometown, at the age of 51."},"et":{"1444–3 February 1495":"1444–3. veebruar 1495","1444–1495":"1444–1495","–1506":"–1506","1474–1554":"1474–1554","1508–1564":"1508–1564","1423–1454":"1423–1454","1426–1444":"1426–1444","before 1444":"enne 1444","1495":"1495","1426":"1426","1423":"1423","1444":"1444","1455":"1455","1554":"1554","1454":"1454","1564":"1564","1474":"1474","1508":"1508","about 1474":"umbes 1474","3 February 1495":"3. veebruar 1495","1506":"1506","after 1444":"pärast 1444","Cambridgeshire, England":"Cambridgeshire, Inglismaa, United Kingdom","Cambridge, Cambridgeshire, England":"Cambridge, Cambridgeshire, Inglismaa, United Kingdom","Little Eversden, Ipswich, Suffolk, England":"Ipswich, Suffolk, England","Oakington, Cambridgeshire, England":"Oakington, Cambridgeshire, England"},"fi":{"1444–3 February 1495":"1444–3. helmikuuta 1495","1444–1495":"1444–1495","–1506":"–1506","1474–1554":"1474–1554","1508–1564":"1508–1564","1423–1454":"1423–1454","1426–1444":"1426–1444","before 1444":"ennen vuotta 1444","1495":"1495","1426":"1426","1423":"1423","1444":"1444","1455":"1455","1554":"1554","1454":"1454","1564":"1564","1474":"1474","1508":"1508","about 1474":"noin 1474","3 February 1495":"3. helmikuuta 1495","1506":"1506","after 1444":"1444 jälkeen","Cambridgeshire, England":"Cambridgeshire, Englanti, Yhdistynyt kuningaskunta","Cambridge, Cambridgeshire, England":"Cambridge, Cambridgeshire, Englanti, Yhdistynyt kuningaskunta","Little Eversden, Ipswich, Suffolk, England":"Ipswich, Suffolk, England","Oakington, Cambridgeshire, England":"Oakington, Cambridgeshire, England"},"f