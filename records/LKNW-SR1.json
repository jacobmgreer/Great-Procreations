37","1315":"1315","1453":"1453","1332":"1332","1265":"1265","about 1265":"okolo 1265","1328":"1328","1317":"1317","Mudford, Somerset, England":"Mudford, Somerset, Anglie","England":"Anglie","Lincoln, England":"Lincoln, Lincolnshire, Anglie, United Kingdom","Ingoldsby, Lincolnshire, England":"Ingoldsby, Lincolnshire, Anglie"},"da":{"about 1265–":"omkring 1265–Afdød","1265–Male":"1265–Afdød","1264–Female":"1264–Afdød","1290–1332":"1290–1332","1250–Male":"1250–Afdød","–Female":"Afdød","about 1280":"omkring 1280","1264":"1264","1382":"1382","1250":"1250","1290":"1290","1337":"1337","1315":"1315","1453":"1453","1332":"1332","1265":"1265","about 1265":"omkring 1265","1328":"1328","1317":"1317","Mudford, Somerset, England":"Mudford, Somerset, England","England":"England","Lincoln, England":"Lincoln, Lincolnshire, England, United Kingdom","Ingoldsby, Lincolnshire, England":"Ingoldsby, Lincolnshire, England"},"nl":{"about 1265–":"circa 1265–Overleden","1265–Male":"1265–Overleden","1264–Female":"1264–Overleden","1290–1332":"1290–1332","1250–Male":"1250–Overleden","–Female":"Overleden","about 1280":"circa 1280","1264":"1264","1382":"1382","1250":"1250","1290":"1290","1337":"1337","1315":"1315","1453":"1453","1332":"1332","1265":"1265","about 1265":"circa 1265","1328":"1328","1317":"1317","Mudford, Somerset, England":"Mudford, Somerset, England","England":"England","Lincoln, England":"Lincoln, Lincolnshire, Engeland, Verenigd Koninkrijk","Ingoldsby, Lincolnshire, England":"Ingoldsby, Lincolnshire, England"},"en":{"about 1265–":"about 1265–Deceased","1265–Male":"1265–Deceased","1264–Female":"1264–Deceased","1290–1332":"1290–1332","1250–Male":"1250–Deceased","–Female":"Deceased","about 1280":"about 1280","1264":"1264","1382":"1382","1250":"1250","1290":"1290","1337":"1337","1315":"1315","1453":"1453","1332":"1332","1265":"1265","about 1265":"about 1265","1328":"1328","1317":"1317","Mudford, Somerset, England":"Mudford, Somerset, England","England":"England","Lincoln, England":"Lincoln, Lincolnshire, England, United Kingdom","Ingoldsby, Lincolnshire, England":"Ingoldsby, Lincolnshire, England","nameMeanings":[{"name":"Dawnay","type":"LAST","attribution":"Dictionary of Family Names in Britain and Ireland © University of the West of England 2016","meanings":["Norman, English: locative name from one of the many places in northern France named from an alder grove (Old French  <i>aulnai</i>,  <i>aulnoi</i>, latinized as  <i>alnetum</i>), such as Annay (Pas-de-Calais), Aulnay (Aube, Marne, Calvados), Aulnois (Aisne), and Aunay (Calvados, Eure-et-Loire, Seine-et-Oise). With fused preposition, Anglo-Norman French  <i>d'Aunai</i> became  <i>Dawnay</i>,  <i>Dawney</i> and (with loss of the final syllable)  <i>Dawn</i>.   Laney   is another form of this surname with fused definite article.  See also  Dando  , from Anglo-Norman French  <i>d'Aunou</i>, with which  <i>d'Aunai</i> may sometimes have been confused."],"variants":[{"name":"Dawney","meanings":["Norman, English:  See  Dawnay  ."]},{"name":"Laney","meanings":["Irish: probably a shortened and altered form of   McElhinney  .","English and Irish: habitational name introduced by the Normans originally deriving from any of the many places in northern France called L'Aunai (from Latin <i>alnetum</i> ‘alder grove’). It may also have developed to   Delaney  .","Variant of   Laine   2, a surname of French origin."]},{"name":"Dawn","meanings":["English (Derbyshire and Nottinghamshire): of Norman origin, probably a clipped form of <b>Dawnay</b> or <b>Dawney</b> (compare   Dana  ), habitational names from one of the many places in northern France named for an alder grove (Old French <i>aulnai</i>, <i>aulnoi</i>, Latinized as <i>alnetum</i>). With fused preposition <i>d(e)</i>, Anglo-Norman <i>d'Aunai</i> became <i>Dawnay</i>, <i>Dawney</i> and (with loss of the final syllable) <i>Dawn</i>.   Laney   is another form of this surname with fused definite article. See also   Dando  , from Anglo-Norman <i>d'Aunou</i>, with which <i>d'Aunai</i> may sometimes have been confused.","English: from Middle English <i>Dawen</i>, a variant of   Dawes   with the weak declension genitival suffix <i>-(e)n</i> (Old English <i>-an</i>) instead of the standard Middle English <i>-es</i>. The usage is mainly restricted to West Midlands dialects of Middle English.","Americanized form of German   Daun  ."]},{"name":"Doney","meanings":["English (Cornwall): of uncertain origin. There is a Richard <i>Donowe</i> recorded in 1451-64 as a tenant in Manuels, Saint Columb Minor, whose surname appears to be a pet form of an unidentified personal name with the Cornish hypocoristic suffix <i>-ow</i>. Formally this might have become <i>Doney</i> but <i>Donowe</i> itself seems not to have survived, unless it was altered to   Downey  . However, there is no evidence to suggest any connection of this west Cornwall surname with <i>Doney</i> in central and east Cornwall (Bodmin and Quethiock). Alternatively, perhaps it is a variant of the Devon name   Downey  , and with the main vowel shortened and lowered, but evidence for this is lacking.","Americanized form of French Canadian   Daunais   or   Donais  ."]},{"name":"Dando","meanings":["English (of Norman origin): habitational name for someone from Aunou-le-Faucon in Orne, Normandy, with fused preposition. Aunou was named for an alder grove, from Latin <i>alnus</i> ‘alder’ + the Gaulish suffix <i>-avum</i>. In medieval England <i>d'Aunou</i> developed an intrusive <i>-d-</i>, giving <i>Dando</i>. The surname was sometimes confused with <i>d'Aunay</i> or <i>d'Auney</i> (see   Delaney  )."]}]},{"name":"Edmund","type":"FIRST","attribution":"Dictionary of First Names © Patrick Hanks and Flavia Hodges 1990, 2003, 2006.","meanings":["From an Old English personal name derived from <i>ēad</i> ‘prosperity, riches’ + <i>mund</i> ‘protector’. It was borne by several early royal and saintly figures, including a 9th-century king of East Anglia killed by invading Danes, allegedly for his adherence to Christianity. In the 16th and 17th centuries, there was a good deal of interchange between <i>Edmund</i> and <i>Edward</i>."],"variants":[]}],"historicEvents":[{"id":1705190,"age":25,"year":"1290","julianDay":2192224,"title":"Jews Expelled From England","description":"After years of anti-Semitic behavior, King Edward I expelled Jews from England in 1290.","jurisdictionLevel":2},{"id":1705191,"age":50,"year":"1315","toYear":"1317","julianDay":2201354,"title":"Famine Strikes Europe","description":"A famine caused by cold winters and wet summers across Europe caused millions to die due to starvation. Desperation from hunger caused high levels of crime, stampedes in bread lines in London, infanticide, and even cannibalism throughout Europe.","jurisdictionLevel":2},{"id":1705192,"age":63,"year":"1328","julianDay":2206102,"title":"First War of Scottish Independence","description":"The First War of Scottish Independence began after England invaded Scotland in 1296. The Treaty of Edinburgh was signed in 1328 which declared peace between the two kingdoms and brought the war to an end.","jurisdictionLevel":2},{"id":1705193,"age":72,"year":"1337","toYear":"1453","julianDay":2209390,"title":"The Hundred Years' War","description":"The Hundred Years' War between France and England was largely due to the question of legitimate succession to the French crown.","jurisdictionLevel":2},{"id":1705195,"age":117,"year":"1382","julianDay":2225826,"title":"Wycliffe's Bible","description":"John Wycliffe, English theologian and professor at the University of Oxford, completed a translation of the Bible from the Latin Vulgate into Middle English. This translation is known as Wycliffe's Bible and was completed around 1382.","url":"https://en.wikipedia.org/wiki/Wycliffe%27s_Bible","urlTitle":"Wikipedia - Wycliffe's Bible","jurisdictionLevel":2}],"lifeSummary":"Edmund Dawnay was born about 1265, in Mudford, Somerset, England as the son of Nicholas Dawnay and Ann Seymo