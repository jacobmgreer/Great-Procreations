ale":"0925–Overleden","0925–Female":"0925–Overleden","0960":"0960","Abt 970":"circa 0970","0980":"0980","1023":"1023","1000":"1000","0925":"0925","0945":"0945","about 1000":"circa 1000","Wales":"Wales","Montgomeryshire, Wales":"Montgomeryshire, Wales","Rhuddlan, Flintshire, Wales":"Rhuddlan, Flintshire, Wales"},"en":{"0945–about 1000":"0945–about 1000","0945–1000":"0945–1000","0960–1023":"0960–1023","0980–1023":"0980–1023","0925–Male":"0925–Deceased","0925–Female":"0925–Deceased","0960":"0960","Abt 970":"about 0970","0980":"0980","1023":"1023","1000":"1000","0925":"0925","0945":"0945","about 1000":"about 1000","Wales":"Wales","Montgomeryshire, Wales":"Montgomeryshire, Wales","Rhuddlan, Flintshire, Wales":"Rhuddlan, Flintshire, Wales","nameMeanings":[{"name":"Turberville","type":"LAST","attribution":"Dictionary of American Family Names © Patrick Hanks 2003, 2006.","meanings":["English (of Norman origin): habitational name, probably from Thouberville (Eure), or possibly from Trubleville (Seine-Maritime), both in France. The two may have been confused in surname usage."],"variants":[{"name":"Torbet","meanings":["Scottish:","from the Anglo-Norman and Middle English personal name <i>T(h)urbert</i>, <i>T(h)orbert</i>, a hybrid of Old Norse <i>Thorr</i> ‘Thor’, the name of the god of thunder, + ancient Germanic <i>-berht</i> ‘bright, famous’. The name was probably formed on the Continent; see   Turberville  .","perhaps in some cases a nickname from Old French and Middle English <i>turbot</i>, <i>turbut</i> ‘turbot’, for someone who caught or sold or resembled this fish."]},{"name":"Turbyfill","meanings":["Altered form of English   Turberville  ."]},{"name":"Tuberville","meanings":["English (of Norman origin): variant of   Turberville  . This form of the surname is very rare in Britain and Ireland."]},{"name":"Turville","meanings":["English (Surrey and Hampshire; of Norman origin):","habitational name from Tourville‐la‐Campagne (Eure, France). The placename derives from the Old Norse personal name <i>Thórr</i> + Old French <i>ville</i> ‘farmstead, estate’ (from Latin <i>villa</i>).","occasionally a shortened form of   Turberville  ."]},{"name":"Turbeville","meanings":["English: variant of   Turberville  ."]},{"name":"Troublefield","meanings":["Probably an altered form of   Turberville  ."]}]},{"name":"Adam","type":"FIRST","attribution":"Dictionary of First Names © Patrick Hanks and Flavia Hodges 1990, 2003, 2006.","meanings":["Gaelic equivalent of <b>Adam</b> ."],"variants":[]},{"name":"ap","type":"FIRST","attribution":"Dictionary of First Names © Patrick Hanks and Flavia Hodges 1990, 2003, 2006.","meanings":["Short form of any of the names beginning with this syllable."],"variants":[{"name":"Alexander","meanings":["From the Latin form of the Greek name <i>Alexandros</i>, from <i>alexein</i> ‘to defend’ + <i>anēr</i> ‘man, warrior’ (genitive <i>andros</i>). The name became extremely popular in the post-classical period, and was borne by several individuals in the New Testament and some early Christian saints. Its use as a common given name throughout Europe, however, derives largely from the fame of  Alexander the Great , King of Macedon (  356–323  bc  ), around whom a large body of popular legend grew up in late antiquity, much of which came to be embodied in the medieval ‘Alexander romances’."]},{"name":"Alan","meanings":["Of Celtic origin and uncertain derivation (possibly a diminutive of a word meaning ‘rock’). It was introduced into England by  Breton  followers of  William the Conqueror , most notably  Alan , Earl of Brittany, who was rewarded for his services with vast estates in the newly conquered kingdom. In Britain the variants  <b>Allan</b>  and  <b>Allen</b>  are considerably less frequent, and generally represent transferred uses of surname forms, whereas in America all three forms of the name are approximately equally common.  See also  Alun ."]},{"name":"Albert","meanings":["From an Old French name, <i>Albert</i>, of Germanic (Frankish) origin, derived from <i>adal</i> ‘noble’ + <i>berht</i> ‘bright, famous’. This was adopted by the Normans and introduced by them to England, displacing the Old English form <i>Æþelbeorht</i>. The name is popular in a variety of forms in Western Europe, and has been traditional in a number of European princely families. It was out of favour in England for centuries, however, and the revival of its popularity in the 19th century was largely in honour of  Queen Victoria's  consort,  Prince Albert of Saxe-Coburg-Gotha ."]}]}],"lifeSummary":"When Adam ap Seisyll Turberville was born in 0945, in Montgomeryshire, Wales, his father, ap Brochwel, was 21 and his mother, ap Brochwel, was 21. He married Prawst verch Elise about 0970. They were the parents of at least 1 son. He died about 1000, in Wales, at the age of 56."},"et":{"0945–about 1000":"0945–umbes 1000","0945–1000":"0945–1000","0960–1023":"0960–1023","0980–1023":"0980–1023","0925–Male":"0925–Surnud","0925–Female":"0925–Surnud","0960":"0960","Abt 970":"umbes 0970","0980":"0980","1023":"1023","1000":"1000","0925":"0925","0945":"0945","about 1000":"umbes 1000","Wales":"Wales","Montgomeryshire, Wales":"Montgomeryshire, Wales","Rhuddlan, Flintshire, Wales":"Rhuddlan, Flintshire, Wales"},"fi":{"0945–about 1000":"0945–noin 1000","0945–1000":"0945–1000","0960–1023":"0960–1023","0980–1023":"0980–1023","0925–Male":"0925–Kuollut","0925–Female":"0925–Kuollut","0960":"0960","Abt 970":"noin 0970","0980":"0980","1023":"1023","1000":"1000","0925":"0925","0945":"0945","about 1000":"noin 1000","Wales":"Wales","Montgomeryshire, Wales":"Montgomeryshire, Wales","Rhuddlan, Flintshire, Wales":"Rhuddlan, Flintshire, Wales"},"fr":{"0945–about 1000":"0945–environ 1000","0945–1000":"0945–1000","0960–1023":"0960–1023","0980–1023":"0980–1023","0925–Male":"0925–Décédé","0925–Female":"0925–Décédée","0960":"0960","Abt 970":"environ 0970","0980":"0980","1023":"1023","1000":"1000","0925":"0925","0945":"0945","about 1000":"environ 