ngdom","Tullibardine, Perth, Scotland":"Tullibardine, Perthshire, Skotland","Gask, Perthshire, Scotland":"Findo Gask, Perthshire, Skotland, United Kingdom"},"nl":{"1220–Bef 1289":"1220–vóór 1289","1220–1289":"1220–1289","1225–Female":"1225–Overleden","1253–1289":"1253–1289","1255–1297":"1255–1297","1280–1320":"1280–1320","1190–Male":"1190–Overleden","1195–Female":"1195–Overleden","1190":"1190","about 1280":"circa 1280","1220":"1220","1297":"1297","1253":"1253","1195":"1195","1280":"1280","1225":"1225","Bef 1289":"vóór 1289","Abt 1255":"circa 1255","1289":"1289","1255":"1255","1320":"1320","about 1253":"circa 1253","Perth, Perthshire, Scotland":"Perth, Perthshire, Schotland, Verenigd Koninkrijk","Selkirkshire, Scotland, United Kingdom":"Selkirkshire, Schotland, Verenigd Koninkrijk","Tullibardine, Perth, Scotland":"Tullibardine, Perthshire, Schotland","Gask, Perthshire, Scotland":"Findo Gask, Perthshire, Schotland, Verenigd Koninkrijk"},"en":{"1220–Bef 1289":"1220–before 1289","1220–1289":"1220–1289","1225–Female":"1225–Deceased","1253–1289":"1253–1289","1255–1297":"1255–1297","1280–1320":"1280–1320","1190–Male":"1190–Deceased","1195–Female":"1195–Deceased","1190":"1190","about 1280":"about 1280","1220":"1220","1297":"1297","1253":"1253","1195":"1195","1280":"1280","1225":"1225","Bef 1289":"before 1289","Abt 1255":"about 1255","1289":"1289","1255":"1255","1320":"1320","about 1253":"about 1253","Perth, Perthshire, Scotland":"Perth, Perthshire, Scotland, United Kingdom","Selkirkshire, Scotland, United Kingdom":"Selkirkshire, Scotland, United Kingdom","Tullibardine, Perth, Scotland":"Tullibardine, Perthshire, Scotland","Gask, Perthshire, Scotland":"Findo Gask, Perthshire, Scotland, United Kingdom","nameMeanings":[{"name":"Murray","type":"LAST","attribution":"Dictionary of American Family Names © Patrick Hanks 2003, 2006.","meanings":["Scottish: habitational name from Moray in northeastern Scotland, which derives from Celtic <i>mori-</i> ‘sea’ + <i>treb-</i> ‘settlement’. The founder of the Scottish house of Murray was a Fleming named Freskin who was granted Strathbrock in West Lothian and Duffus in Moray by David I. The family took its name from the region in the late 12th century.","Irish and Scottish: shortened form of   McMurray  .","Irish: Anglicized form of Gaelic <b>Ó Muireadhaigh</b> ‘descendant of <i>Muireadhach</i>’ a personal name meaning ‘mariner’. Occasionally it may be a shortened form of   McMurray  ."],"variants":[{"name":"Murri","meanings":["Probably Scottish: variant of   Murray  ."]},{"name":"Murry","meanings":["Scottish and Irish: variant of   Murray  ."]},{"name":"Murrah","meanings":["Probably an altered form of Scottish   Murray  ."]},{"name":"Murie","meanings":["Some characteristic forenames:  French Michel.","Scottish: habitational name from Murie in Errol (Perthshire).","Scottish and Irish: variant of   Murray  ."]},{"name":"Merhi","meanings":["Arabic (mainly Lebanon and Syria): from a variant of the personal name <i>Mirhi</i> of unknown meaning. Bearers of this surname are both Muslims and Christians. Compare   Murray   5."]},{"name":"Murrey","meanings":["Irish: variant of   Murray  ."]},{"name":"McMurray","meanings":["Irish (northern) and Scottish: Anglicized form of Gaelic <b>Mac Muireadhaigh</b> or <b>Mac Muireadhaich</b>, a patronymic from the personal name <i>Muireadhach</i> ‘seafarer’ (see   Murdoch  ). Compare   McCurry   1."]},{"name":"Murra","meanings":["Italian (Sicily): topographic name from Sicilian <i>murra</i> ‘large rock, mass of rocks’ or a habitational name from a place called with this word.","East Frisian: unexplained.","Albanian: nickname from <i>murrë</i> (definite form <i>murra</i>) ‘dark gray cow’."]},{"name":"Murrie","meanings":["Scottish: variant of   Murray  ."]}]},{"name":"Malcolm","type":"FIRST","attribution":"Dictionary of First Names © Patrick Hanks and Flavia Hodges 1990, 2003, 2006.","meanings":["Anglicized form of the medieval Gaelic name <i>Mael Coluim</i> ‘devotee of St Columba’. Columba was a 6th-century monk of Irish origin who played a leading part in the conversion to Christianity of Scotland and northern England;  see also  Callum   and   Colm .  He has always been one of the most popular saints in Scotland, but in the Middle Ages it was felt to be presumptuous to give the names of saints directly to children; instead their blessing was invoked by prefixing the name with <i>mael</i> ‘devotee of’ or <i>gille</i> ‘servant of’. Since the 1930s the given name has been used widely in the English-speaking world, not just by those with Scottish connections."],"variants":[]}],"lifeSummary":"When Malcolm Murray Sheriff of Perth was born in 1220, in Perth, Perthshire, Scotland, United Kingdom, his father, John de Moravia, was 31 and his mother, Margaret Bruce, was 25. He had at least 3 sons with Mary Freskin. He died before 1289, in Findo Gask, Perthshire, Scotland, United Kingdom."},"et":{"1220–Bef 1289":"1220–enne 1289","1220–1289":"1220–1289","1225–Female":"1225–Surnud","1253–1289":"1253–1289","1255–1297":"1255–1297","1280–1320":"1280–1320","1190–Male":"1190–Surnud","1195–Female":"1195–Surnud","1190":"1190","about 1280":"umbes 1280","1220":"1220","1297":"1297","1253":"1253","1195":"1195","1280":"1280","1225":"1225","Bef 1289":"enne 1289","Abt 1255":"umbes 1255","1289":"1289","1255":"1255","1320":"1320","about 1253":"umbes 1253","Perth, Perthshire, Scotland":"Perth, Perthshire, Šotimaa, United Kingdom","Selkirkshire, Scotland, United Kingdom":"Selkirkshire, Šotimaa, United Kingdom","Tullibardine, Perth, Scotland":"Tullibardine, Perthshire, Scotland","Gask, Perthshire, Scotland":"Findo Gask, Perthshire, Šotimaa, United Kingdom"},"fi":{"1220–Bef 1289":"1220–ennen vuotta 1289","1220–1289":"1220–1289","1225–Female":"1225–Kuollut","1253–1289":"1253–1289","1255–1297":"1255–1297","1280–1320":"1280–1320","1190–Male":"1190–Kuollut","1195–Female":"1195–Kuollut","1190":"1190","about 1280":"noin 1280","1220":"1220","1297":"1297","1253":"1253","1195