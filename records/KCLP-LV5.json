abt 1263":"circa 1263","1291":"1291","1317":"1317","of Chetnoll, Dorset, Eng.":"Dorset, Engeland, Verenigd Koninkrijk","of Chetnoll, Dorset., Eng.":"Dorset, Engeland, Verenigd Koninkrijk"},"en":{"abt 1263–":"about 1263–Deceased","1256–1291":"1256–1291","–Male":"Deceased","1291–1317":"1291–1317","1263–Female":"1263–Deceased","1256":"1256","abt 1291":"about 1291","1263":"1263","abt 1263":"about 1263","1291":"1291","1317":"1317","of Chetnoll, Dorset, Eng.":"Dorset, England, United Kingdom","of Chetnoll, Dorset., Eng.":"Dorset, England, United Kingdom","nameMeanings":[{"name":"Richard","type":"FIRST","attribution":"Dictionary of First Names © Patrick Hanks and Flavia Hodges 1990, 2003, 2006.","meanings":["One of the most enduringly successful of the Old French personal names introduced into Britain by the Normans. It is of Germanic (Frankish) origin, derived from <i>rīc</i> ‘power’ + <i>hard</i> ‘strong, hardy’. It has enjoyed continuous popularity in England from the Conquest to the present day, influenced by the fact that it was borne by three kings of England, in particular  Richard I  (  1157–99 ). He was king for only ten years (  1189–99 ), most of which he spent in warfare abroad, taking part in the Third Crusade and costing the people of England considerable sums in taxes. Nevertheless, he achieved the status of a folk hero, and was never in England long enough to disappoint popular faith in his goodness and justice. He was also Duke of Aquitaine and Normandy and Count of Anjou, fiefs which he held at a time of maximum English expansion in France. His exploits as a leader of the Third Crusade earned him the nickname ‘Coeur de Lion’ or ‘Lionheart’ and a permanent place in popular imagination, in which he was even more firmly enshrined by  Sir Walter Scott's  novel Ivanhoe (  1820 )."],"variants":[{"name":"Rikert","meanings":["One of the most enduringly successful of the Old French personal names introduced into Britain by the Normans. It is of Germanic (Frankish) origin, derived from <i>rīc</i> ‘power’ + <i>hard</i> ‘strong, hardy’. It has enjoyed continuous popularity in England from the Conquest to the present day, influenced by the fact that it was borne by three kings of England, in particular  Richard I  (  1157–99 ). He was king for only ten years (  1189–99 ), most of which he spent in warfare abroad, taking part in the Third Crusade and costing the people of England considerable sums in taxes. Nevertheless, he achieved the status of a folk hero, and was never in England long enough to disappoint popular faith in his goodness and justice. He was also Duke of Aquitaine and Normandy and Count of Anjou, fiefs which he held at a time of maximum English expansion in France. His exploits as a leader of the Third Crusade earned him the nickname ‘Coeur de Lion’ or ‘Lionheart’ and a permanent place in popular imagination, in which he was even more firmly enshrined by  Sir Walter Scott's  novel Ivanhoe (  1820 )."]},{"name":"Rickert","meanings":["One of the most enduringly successful of the Old French personal names introduced into Britain by the Normans. It is of Germanic (Frankish) origin, derived from <i>rīc</i> ‘power’ + <i>hard</i> ‘strong, hardy’. It has enjoyed continuous popularity in England from the Conquest to the present day, influenced by the fact that it was borne by three kings of England, in particular  Richard I  (  1157–99 ). He was king for only ten years (  1189–99 ), most of which he spent in warfare abroad, taking part in the Third Crusade and costing the people of England considerable sums in taxes. Nevertheless, he achieved the status of a folk hero, and was never in England long enough to disappoint popular faith in his goodness and justice. He was also Duke of Aquitaine and Normandy and Count of Anjou, fiefs which he held at a time of maximum English expansion in France. His exploits as a leader of the Third Crusade earned him the nickname ‘Coeur de Lion’ or ‘Lionheart’ and a permanent place in popular imagination, in which he was even more firmly enshrined by  Sir Walter Scott's  novel Ivanhoe (  1820 )."]}]}],"lifeSummary":"Mrs. Richard Winterhay was born about 1263, in Dorset, England, United Kingdom. She had at least 1 son with Richard Wynterheigh."},"et":{"abt 1263–":"umbes 1263–Surnud","1256–1291":"1256–1291","–Male":"Surnud","1291–1317":"1291–1317","1263–Female":"1263–Surnud","1256":"1256","abt 1291":"umbes 1291","1263":"1263","abt 1263":"umbes 1263","1291":"1291","1317":"1317","of Chetnoll, Dorset, Eng.":"Dorset, Inglismaa, United Kingdom","of Chetnoll, Dorset., Eng.":"Dorset, Inglismaa, United Kingdom"},"fi":{"abt 1263–":"noin 1263–Kuollut","1256–1291":"1256–1291","–Male":"Kuollut","1291–1317":"1291–1317","1263–Female":"1263–Kuollut","1256":"1256","abt 1291":"noin 1291","1263":"1263","abt 1263":"noin 1263","1291":"1291","1317":"1317","of Chetnoll, Dorset, Eng.":"Dorset, Englanti, Yhdistynyt kuningaskunta","of Chetnoll, Dorset., Eng.":"Dorset, Englanti, Yhdistynyt kuningaskunta"},"fr":{"abt 1263–":"environ 1263–Décédée","1256–1291":"1256–1291","–Male":"Décédé","1291–1317":"1291–1317","1263–Female":"1263–Décédée","1256":"1256","abt 1291":"environ 1291","1263":"1263","abt 1263":"environ 1263","1291":"1291","1317":"1317","of Chetnoll, Dorset, Eng.":"Dorset, Angleterre, Royaume-Uni","of Chetnoll, Dorset., Eng.":"Dorset, Angleterre, Royaume-Uni","lifeSummary":"Mrs. Richard Winterhay est née environ 1263, à Dorset, Angleterre, Royaume-Uni. Elle a eu au moins 1 fils avec Richard Wynterheigh."},"de":{"abt 1263–":"um 1263–Verstorben","1256–1291":"1256–1291","–Male":"Verstorben","1291–1317":"1291–1317","1263–Female":"1263–Verstorben","1256":"1256","abt 1291":"um 1291","1263":"1263","abt 1263":"um 1263","1291":"1291","1317":"1317","of Chetnoll, Dorset, Eng.":"Dorset, England, United Kingdom","of Chetnoll, Dorset., Eng.":"Dorset, England, United Kingdom","lifeSummary":"Mrs. Richard Winterhay wurde um 1263 in Dorset, England, United Kingdom geboren. Sie hatte mit Ric