390":"circa 1390","1340":"1340","1372":"1372","1382":"1382","Abt 1407":"circa 1407","1370":"1370","1390":"1390","1455":"1455","1464":"1464","1364":"1364","1342":"1342","about 1363":"circa 1363","1407":"1407","Rydal, Westmorland, England":"Rydal, Westmorland, England","England":"England","Wath upon Dearne, Yorkshire, England":"Wath upon Dearne, Yorkshire, England"},"en":{"1364–":"1364–Deceased","1364–Male":"1364–Deceased","1372–Female":"1372–Deceased","–Female":"Deceased","1390–1464":"1390–1464","1407–Female":"1407–Deceased","1340–1370":"1340–1370","1342–Female":"1342–Deceased","about 1390":"about 1390","1340":"1340","1372":"1372","1382":"1382","Abt 1407":"about 1407","1370":"1370","1390":"1390","1455":"1455","1464":"1464","1364":"1364","1342":"1342","about 1363":"about 1363","1407":"1407","Rydal, Westmorland, England":"Rydal, Westmorland, England","England":"England","Wath upon Dearne, Yorkshire, England":"Wath upon Dearne, Yorkshire, England","nameMeanings":[{"name":"Fleming","type":"LAST","attribution":"Dictionary of American Family Names © Patrick Hanks 2003, 2006.","meanings":["English: ethnic name for someone from Flanders, from Middle English <i>fleming</i>. The word reflects a Norman French form of Old French <i>flamanc</i> ‘Fleming’, from the stem <i>flam-</i> + the ancient Germanic suffix <i>-ing</i>. In the Middle Ages there was considerable commercial intercourse between England and the Netherlands, particularly in the wool trade, and many Flemish weavers and dyers settled in England. This surname is also common in south and east Scotland and in Ireland, where it is sometimes found in the Gaelicized form <b>Pléamonn</b>.","German: variant of   Flemming  , cognate with 1 above."],"variants":[{"name":"Flemings","meanings":["English: plural form of   Fleming  .","Americanized form of Flemish <b>Vleminckx</b>: patronymic from <b>Vleminck</b>, an ethnic name for someone from Flanders, Middle Dutch <i>vleminc</i>."]},{"name":"Flanders","meanings":["English: ethnic name from Middle English <i>Fla(u)ndres</i> ‘Flanders’, denoting someone from Flanders, a historical region covering parts of modern-day Belgium, France, and the Netherlands. Compare   Fleming  ."]},{"name":"Fleeman","meanings":["English: variant of   Fleming  ."]},{"name":"Flemming","meanings":["German: ethnic name for someone from Flanders, Middle High German <i>vlaeminc</i>. People from Flanders spread throughout Germany, as well as England, in the Middle Ages as clothmakers and dyers.","English: variant of   Fleming  ."]},{"name":"Flamenco","meanings":["Spanish: ethnic name from <i>flamenco</i> ‘Fleming, Flemish person’ (see   Fleming  )."]}]},{"name":"Thomas","type":"FIRST","attribution":"Dictionary of First Names © Patrick Hanks and Flavia Hodges 1990, 2003, 2006.","meanings":["New Testament name, borne by one of Christ's twelve apostles, referred to as ‘Thomas, called Didymus’ (John 11:16; 20:24). <i>Didymos</i> is the Greek word for ‘twin’, and the name is the Greek form of an Aramaic byname meaning ‘twin’. The given name has always been popular throughout Christendom, in part because St Thomas's doubts have made him seem a very human character."],"variants":[]}],"historicEvents":[{"id":1705195,"age":18,"year":"1382","julianDay":2225826,"title":"Wycliffe's Bible","description":"John Wycliffe, English theologian and professor at the University of Oxford, completed a translation of the Bible from the Latin Vulgate into Middle English. This translation is known as Wycliffe's Bible and was completed around 1382.","url":"https://en.wikipedia.org/wiki/Wycliffe%27s_Bible","urlTitle":"Wikipedia - Wycliffe's Bible","jurisdictionLevel":2},{"id":1705197,"age":91,"year":"1455","julianDay":2252488,"title":"Wars of the Roses","description":"Wars of the Roses was a series of English civil wars for control of the throne of England between the royal families House of Lancaster and the House of York. The name of the war was derived as the red rose was the symbol of the Lancastrians and the white rose was the symbol of the Yorks.","url":"https://www.history.com/topics/british-history/wars-of-the-roses","urlTitle":"History - Wars of the Roses","jurisdictionLevel":2}],"lifeSummary":"When Thomas Fleming was born in 1364, in Wath upon Dearne, Yorkshire, England, his father, John Fleming, was 25 and his mother, Mrs. Alice Fleming, was 23. He married Isabel Delamere about 1390. They were the parents of at least 1 son."},"et":{"1364–":"1364–Surnud","1364–Male":"1364–Surnud","1372–Female":"1372–Surnud","–Female":"Surnud","1390–1464":"1390–1464","1407–Female":"1407–Surnud","1340–1370":"1340–1370","1342–Female":"1342–Surnud","about 1390":"umbes 1390","1340":"1340","1372":"1372","1382":"1382","Abt 1407":"umbes 1407","1370":"1370","1390":"1390","1455":"1455","1464":"1464","1364":"1364","1342":"1342","about 1363":"umbes 1363","1407":"1407","Rydal, Westmorland, England":"Rydal, Westmorland, England","England":"England","Wath upon Dearne, Yorkshire, England":"Wath upon Dearne, Yorkshire, England"},"fi":{"1364–":"1364–Kuollut","1364–Male":"1364–Kuollut","1372–Female":"1372–Kuollut","–Female":"Kuollut","1390–1464":"1390–1464","1407–Female":"1407–Kuollut","1340–1370":"1340–1370","1342–Female":"1342–Kuollut","about 1390":"noin 1390","1340":"1340","1372":"1372","1382":"1382","Abt 1407":"noin 1407","1370":"1370","1390":"1390","1455":"1455","1464":"1464","1364":"1364","1342":"1342","about 1363":"noin 1363","1407":"1407","Rydal, Westmorland, England":"Rydal, Westmorland, England","England":"England","Wath upon Dearne, Yorkshire, England":"Wath upon Dearne, Yorkshire, England"},"fr":{"1364–":"1364–Décédé","1364–Male":"1364–Décédé","1372–Female":"1372–Décédée","–Female":"Décédée","1390–1464":"1390–1464","1407–Female":"1407–Décédée","1340–1370":"1340–1370","1342–Female":"1342–Décédée","about 1390":"environ 1390","1340":"1340","1372":"1372","1382":"1382","Abt 1407":"environ 1407","1370":"1370","1390":"1390","1455":"1455","1464":"1464","1364":"1364","1342":"134