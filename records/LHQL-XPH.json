:"1367.","1398":"1398","before 1375":"prije 1375.","1375":"1375","1340":"1340","1383":"1383.","Patmer Hall, Albury, Hertfordshire, England, United Kingdom":"Albury, Hertfordshire, Engleska, United Kingdom","Sawbridgeworth, Hertfordshire, England":"Sawbridgeworth, Hertfordshire, England","England, United Kingdom":"England","Great Hyde Hall, Sawbridgeworth, Hertfordshire, England":"Sawbridgeworth, Hertfordshire, Engleska, United Kingdom"},"cs":{"Abt 1340–Abt 1383":"okolo 1340–okolo 1383","1340–1383":"1340–1383","1367–1425":"1367–1425","1375–1398":"1375–1398","Abt 1340":"okolo 1340","Abt 1383":"okolo 1383","1425":"1425","1367":"1367","1398":"1398","before 1375":"před 1375","1375":"1375","1340":"1340","1383":"1383","Patmer Hall, Albury, Hertfordshire, England, United Kingdom":"Albury, Hertfordshire, Anglie, United Kingdom","Sawbridgeworth, Hertfordshire, England":"Sawbridgeworth, Hertfordshire, Anglie","England, United Kingdom":"Anglie","Great Hyde Hall, Sawbridgeworth, Hertfordshire, England":"Sawbridgeworth, Hertfordshire, Anglie, United Kingdom"},"da":{"Abt 1340–Abt 1383":"omkring 1340–omkring 1383","1340–1383":"1340–1383","1367–1425":"1367–1425","1375–1398":"1375–1398","Abt 1340":"omkring 1340","Abt 1383":"omkring 1383","1425":"1425","1367":"1367","1398":"1398","before 1375":"før 1375","1375":"1375","1340":"1340","1383":"1383","Patmer Hall, Albury, Hertfordshire, England, United Kingdom":"Albury, Hertfordshire, England, United Kingdom","Sawbridgeworth, Hertfordshire, England":"Sawbridgeworth, Hertfordshire, England","England, United Kingdom":"England","Great Hyde Hall, Sawbridgeworth, Hertfordshire, England":"Sawbridgeworth, Hertfordshire, England, United Kingdom"},"nl":{"Abt 1340–Abt 1383":"circa 1340–circa 1383","1340–1383":"1340–1383","1367–1425":"1367–1425","1375–1398":"1375–1398","Abt 1340":"circa 1340","Abt 1383":"circa 1383","1425":"1425","1367":"1367","1398":"1398","before 1375":"vóór 1375","1375":"1375","1340":"1340","1383":"1383","Patmer Hall, Albury, Hertfordshire, England, United Kingdom":"Albury, Hertfordshire, Engeland, Verenigd Koninkrijk","Sawbridgeworth, Hertfordshire, England":"Sawbridgeworth, Hertfordshire, England","England, United Kingdom":"England","Great Hyde Hall, Sawbridgeworth, Hertfordshire, England":"Sawbridgeworth, Hertfordshire, Engeland, Verenigd Koninkrijk"},"en":{"Abt 1340–Abt 1383":"about 1340–about 1383","1340–1383":"1340–1383","1367–1425":"1367–1425","1375–1398":"1375–1398","Abt 1340":"about 1340","Abt 1383":"about 1383","1425":"1425","1367":"1367","1398":"1398","before 1375":"before 1375","1375":"1375","1340":"1340","1383":"1383","Patmer Hall, Albury, Hertfordshire, England, United Kingdom":"Albury, Hertfordshire, England, United Kingdom","Sawbridgeworth, Hertfordshire, England":"Sawbridgeworth, Hertfordshire, England","England, United Kingdom":"England","Great Hyde Hall, Sawbridgeworth, Hertfordshire, England":"Sawbridgeworth, Hertfordshire, England, United Kingdom","nameMeanings":[{"name":"Patner","type":"LAST","attribution":"Dictionary of American Family Names © Patrick Hanks 2003, 2006.","meanings":["German, Jewish (Ashkenazic), and Czech (<b>Platnéř</b>): occupational name for an armorer (see   Blattner   and   Plattner  )."],"variants":[{"name":"Plattner","meanings":["German (Tyrol, Bavaria): from <i>platte</i> (dative <i>platten</i>) ‘ledge’ + the suffix <i>-er</i> for an inhabitant, hence a topographic name denoting someone who lived at a farm on a mountain ledge.","German and Jewish (Ashkenazic): variant of   Platner  ."]},{"name":"Blattner","meanings":["South German and Swiss German: occupational name for an armorer, Middle High German <i>blatenaere</i>, a derivative of <i>blate</i> ‘armor, plate’."]}]},{"name":"Margaret","type":"FIRST","attribution":"Dictionary of First Names © Patrick Hanks and Flavia Hodges 1990, 2003, 2006.","meanings":["An extremely common given name from the Middle Ages onwards, derived via Old French <i>Marguerite</i> and Latin <i>Margarita</i> from Greek <i>Margarītēs</i>, from <i>margaron</i> ‘pearl’, a word ultimately of Hebrew origin. The name was always understood to mean ‘pearl’ throughout the Middle Ages. The first  St Margaret  was martyred at Antioch in Pisidia during the persecution instigated by the  Emperor Diocletian  in the early 4th century. However, there is some doubt about her name, as the same saint is venerated in the Orthodox Church as   Marina .  There were several other saintly bearers of the name, including St Margaret of Scotland (  d. 1093 ), wife of  King Malcolm Canmore  and daughter of Edmund Ironside of England. It was also the name of the wife of  Henry VI  of England,  Margaret of Anjou  (  1430–82 ), and of  Margaret Tudor  (  1489–1541 ), sister of  Henry VIII , who married James IV of Scotland and ruled as regent there after his death.  See also  Margery  ,   Marjorie ."],"variants":[{"name":"Margareta","meanings":["From the Latin form of Greek <i>Margarītēs</i>.  See  <b>Margaret</b>   ."]},{"name":"Margaretta","meanings":["An extremely common given name from the Middle Ages onwards, derived via Old French <i>Marguerite</i> and Latin <i>Margarita</i> from Greek <i>Margarītēs</i>, from <i>margaron</i> ‘pearl’, a word ultimately of Hebrew origin. The name was always understood to mean ‘pearl’ throughout the Middle Ages. The first  St Margaret  was martyred at Antioch in Pisidia during the persecution instigated by the  Emperor Diocletian  in the early 4th century. However, there is some doubt about her name, as the same saint is venerated in the Orthodox Church as   Marina .  There were several other saintly bearers of the name, including St Margaret of Scotland (  d. 1093 ), wife of  King Malcolm Canmore  and daughter of Edmund Ironside of England. It was also the name of the wife of  Henry VI  of England,  Margaret of Anjou  (  1430–82 ), and of  Margaret Tudor  (  1489–1541 ), sister of  Henry VIII , who married James IV of Scotland and ruled as regent there after his death.  See also  Margery  ,   Marjorie ."]}]}],"lifeSummary":"Margaret Patner was born about 1340, in Albury, Hertfordshire, England, United Kingdom. She had at least 2 sons with Ralph Josselyn. She died about 1383, in her hometown, at the age of 45."},"et":{"Abt 1340–Abt 1383":"umbes 1340–umbes 1383","1340–1383":"1340–1383","1367–1425":"1367–1425","1375–1398":"1375–1398","Abt 1340":"umbes 1340","Abt 1383":"umbes 1383","1425":"1425","1367":"1367","1398":"1398","before 1375":"enne 1375","1375":"1375","1340":"1340","1383":"1383","Patmer Hall, Albury, Hertfordshire, England, United Kingdom":"Albury, Hertfordshire, Inglismaa, United Kingdom","Sawbridgeworth, Hertfordshire, England":"Sawbridgeworth, Hertfordshire, England","England, United Kingdom":"England","Great Hyde Hall, Sawbridgeworth, Hertfordshire, England":"Sawbridgeworth, Hertfordshire, Inglismaa, United Kingdom"},"fi":{"Abt 1340–Abt 1383":"noin 1340–noin 1383","1340–1383":"1340–1383","1367–1425":"1367–1425","1375–1398":"1375–1398","Abt 1340":"noin 1340","Abt 1383":"noin 1383","1425":"1425","1367":"1367","1398":"1398","before 1375":"ennen vuotta 1375","1375":"1375","1340":"1340","1383":"1383","Patmer Hall, Albury, Hertfordshire, England, United Kingdom":"Albury, Hertfordshire, Englanti, Yhdistynyt kuningaskunta","Sawbridgeworth, Hertfordshire, England":"Sawbridgeworth, Hertfordshire, England","England, United Kingdom":"England","Great Hyde Hall, Sawbridgeworth, Hertfordshire, England":"Sawbridgeworth, Hertfordshire, Englanti, Yhdistynyt kuningaskunta"},"fr":{"Abt 1340–Abt 1383":"environ 1340–environ 1383","1340–1383":"1340–1383","1367–1425":"1367–1425","1375–1398":"1375–1398","Abt 1340":"environ 1340","Abt 1383":"environ 1383","1425":"1425","1367":"1367","1398":"1398","before 1375":"avant 1375","1375":"1375","1340":"1340","1383":"1383","Patmer Hall, Albury, Hertfordshire, England, United Kingdom":"Albury, Hertfordshire, Angleterre, Royaume-Uni","Sawbridgeworth, Hertfordshire, England":"Sawbridgeworth, Hertfordshire, Anglet