ber 1386","1350":"1350","1492":"1492","1382":"1382","1370":"1370","1380":"1380","1457":"1457","1455":"1455","1345":"1345","1378":"1378","1465":"1465","1431":"1431","1441":"1441","1386":"1386","1496":"1496","after 1389":"efter 1389","1405":"1405","Moulton, Lincolnshire, England":"Moulton, Lincolnshire, England","Pinchbeck, Lincolnshire, England":"Pinchbeck, Lincolnshire, England, United Kingdom","Lincolnshire, England":"Lincolnshire, England","Boston, Lincolnshire, England":"Boston, Lincolnshire, England","Whaplode, Lincolnshire, England":"Whaplode, Lincolnshire, England","England, United Kingdom":"England, United Kingdom"},"nl":{"1380–1492":"1380–1492","–1492":"–1492","–Male":"Overleden","1378–1465":"1378–1465","1405–1496":"1405–1496","1431–1457":"1431–1457","1345–1386":"1345–1386","1350–Female":"1350–Overleden","6 November 1386":"6 november 1386","1350":"1350","1492":"1492","1382":"1382","1370":"1370","1380":"1380","1457":"1457","1455":"1455","1345":"1345","1378":"1378","1465":"1465","1431":"1431","1441":"1441","1386":"1386","1496":"1496","after 1389":"na 1389","1405":"1405","Moulton, Lincolnshire, England":"Moulton, Lincolnshire, England","Pinchbeck, Lincolnshire, England":"Pinchbeck, Lincolnshire, Engeland, Verenigd Koninkrijk","Lincolnshire, England":"Lincolnshire, England","Boston, Lincolnshire, England":"Boston, Lincolnshire, England","Whaplode, Lincolnshire, England":"Whaplode, Lincolnshire, England","England, United Kingdom":"Engeland, Verenigd Koninkrijk"},"en":{"1380–1492":"1380–1492","–1492":"–1492","–Male":"Deceased","1378–1465":"1378–1465","1405–1496":"1405–1496","1431–1457":"1431–1457","1345–1386":"1345–1386","1350–Female":"1350–Deceased","6 November 1386":"6 November 1386","1350":"1350","1492":"1492","1382":"1382","1370":"1370","1380":"1380","1457":"1457","1455":"1455","1345":"1345","1378":"1378","1465":"1465","1431":"1431","1441":"1441","1386":"1386","1496":"1496","after 1389":"after 1389","1405":"1405","Moulton, Lincolnshire, England":"Moulton, Lincolnshire, England","Pinchbeck, Lincolnshire, England":"Pinchbeck, Lincolnshire, England, United Kingdom","Lincolnshire, England":"Lincolnshire, England","Boston, Lincolnshire, England":"Boston, Lincolnshire, England","Whaplode, Lincolnshire, England":"Whaplode, Lincolnshire, England","England, United Kingdom":"England, United Kingdom","nameMeanings":[{"name":"de","type":"LAST","attribution":"Dictionary of American Family Names © Patrick Hanks 2003, 2006.","meanings":["Some characteristic forenames:  Indian Dilip, Anirban, Gopal, Alok, Anindya, Arunava, Asit, Asok, Dibyendu, Goutam, Indra, Indranil.","Indian: variant of   Dey  ."],"variants":[{"name":"Dey","meanings":["Some characteristic forenames:  Indian Ashit, Indu, Naina, Partha, Soumya, Ajit, Anjan, Anjana, Anup, Arjun, Arun, Ashim.","English, Scottish, and Welsh: variant of   Day  .","German: topographic name from a field name in North Rhine-Westphalia, denoting a sizeable piece of land, from Middle Low German <i>dē</i> ‘thigh’ (referring to the shape of the property)."]}]},{"name":"Pinchbeck","type":"LAST","attribution":"Dictionary of American Family Names © Patrick Hanks 2003, 2006.","meanings":["English: habitational name from Pinchbeck in Lincolnshire. The placename derives from the name of a local stream, named with Old English <i>pinc</i> ‘minnow’ + Old Norse <i>bekkr</i> ‘stream’."],"variants":[]},{"name":"Richard","type":"FIRST","attribution":"Dictionary of First Names © Patrick Hanks and Flavia Hodges 1990, 2003, 2006.","meanings":["One of the most enduringly successful of the Old French personal names introduced into Britain by the Normans. It is of Germanic (Frankish) origin, derived from <i>rīc</i> ‘power’ + <i>hard</i> ‘strong, hardy’. It has enjoyed continuous popularity in England from the Conquest to the present day, influenced by the fact that it was borne by three kings of England, in particular  Richard I  (  1157–99 ). He was king for only ten years (  1189–99 ), most of which he spent in warfare abroad, taking part in the Third Crusade and costing the people of England considerable sums in taxes. Nevertheless, he achieved the status of a folk hero, and was never in England long enough to disappoint popular faith in his goodness and justice. He was also Duke of Aquitaine and Normandy and Count of Anjou, fiefs which he held at a time of maximum English expansion in France. His exploits as a leader of the Third Crusade earned him the nickname ‘Coeur de Lion’ or ‘Lionheart’ and a permanent place in popular imagination, in which he was even more firmly enshrined by  Sir Walter Scott's  novel Ivanhoe (  1820 )."],"variants":[{"name":"Rikert","meanings":["One of the most enduringly successful of the Old French personal names introduced into Britain by the Normans. It is of Germanic (Frankish) origin, derived from <i>rīc</i> ‘power’ + <i>hard</i> ‘strong, hardy’. It has enjoyed continuous popularity in England from the Conquest to the present day, influenced by the fact that it was borne by three kings of England, in particular  Richard I  (  1157–99 ). He was king for only ten years (  1189–99 ), most of which he spent in warfare abroad, taking part in the Third Crusade and costing the people of England considerable sums in taxes. Nevertheless, he achieved the status of a folk hero, and was never in England long enough to disappoint popular faith in his goodness and justice. He was also Duke of Aquitaine and Normandy and Count of Anjou, fiefs which he held at a time of maximum English expansion in France. His exploits as a leader of the Third Crusade earned him the nickname ‘Coeur de Lion’ or ‘Lionheart’ and a permanent place in popular imagination, in which he was even more firmly enshrined by  Sir Walter Scott's  novel Ivanhoe (  1820 )."]},{"name":"Rickert","meanings":["One of the most enduringly successful of the Old French personal names introduced into Britain by the Normans. It is of Germanic (Frankish) origin, derived from <i>rīc</i> ‘power’ + <i>hard</i> ‘strong, hardy’. It has enjoyed continuous popularity in England from the Conquest to the present day, influenced by the fact that it was borne by three kings of England, in particular  Richard I  (  1157–99 ). He was king for only ten years (  1189–99 ), most of which he spent in warfare abroad, taking part in the Third Crusade and costing the people of England considerable sums in taxes. Nevertheless, he achieved the status of a folk hero, and was never in England long enough to disappoint popular faith in his goodness and justice. He was also Duke of Aquitaine and Normandy and Count of Anjou, fiefs which he held at a time of maximum English expansion in France. His exploits as a leader of the Third Crusade earned him the nickname ‘Coeur de Lion’ or ‘Lionheart’ and a permanent place in popular imagination, in which he was even more firmly enshrined by  Sir Walter Scott's  novel Ivanhoe (  1820 )."]}]}],"historicEvents":[{"id":1705195,"age":2,"year":"1382","julianDay":2225826,"title":"Wycliffe's Bible","description":"John Wycliffe, English theologian and professor at the University of Oxford, completed a translation of the Bible from the Latin Vulgate into Middle English. This translation is known as Wycliffe's Bible and was completed around 1382.","url":"https://en.wikipedia.org/wiki/Wycliffe%27s_Bible","urlTitle":"Wikipedia - Wycliffe's Bible","jurisdictionLevel":2},{"id":1705197,"age":75,"year":"1455","julianDay":2252488,"title":"Wars of the Roses","description":"Wars of the Roses was a series of English civil wars for control of the throne of England between the royal families House of Lancaster and the House of York. The name of the war was derived as the red rose was the symbol of the Lancastrians and the white rose was the symbol of the Yorks.","url":"https://www.history.com/topics/british-history/wars-of-the-roses","urlTitle":"History - Wars of the Roses","jurisdictionLevel":2}],"lifeSummary":"When Richard Sarsonne de Pinchbeck was born in 1380, in P