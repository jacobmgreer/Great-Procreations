ingham, Gloucestershire, England":"Arlingham, Gloucestershire, Engeland, Verenigd Koninkrijk"},"en":{"about 1335–":"about 1335–Deceased","1335–Male":"1335–Deceased","1335–Female":"1335–Deceased","1358–Male":"1358–Deceased","1360–1440":"1360–1440","1310–Male":"1310–Deceased","1312–Female":"1312–Deceased","about 1360":"about 1360","1358":"1358","1335":"1335","1312":"1312","about 1358":"about 1358","1310":"1310","1440":"1440","about 1335":"about 1335","1360":"1360","Arlingham, Gloucester, England":"Arlingham, Gloucestershire, England, United Kingdom","Charney Basset, Berkshire, England":"Charney Bassett, Berkshire, England, United Kingdom","Arlingham, Gloucestershire, England":"Arlingham, Gloucestershire, England, United Kingdom","nameMeanings":[{"name":"Yate","type":"LAST","attribution":"Dictionary of Family Names in Britain and Ireland © University of the West of England 2016","meanings":["English: (i) locative name, occupational name for someone who lived by a gate (Middle English  <i>yat</i>, Old English  <i>geat</i>), in some cases because they acted as the gatekeeper or porter to a hall, a monastery, or some other important building.   Redmonds, Dictionary of Yorks Surnames   mentions a witness to a set of deeds who is variously named as John  <i>ad portam</i>, John  <i>le Porter</i>, and John  <i>atteyate</i>, 1322–6 in   Yorks Deeds   (Wadworth, WR Yorks).  Compare  Yeatman  ,   Gate   locative name for someone who lived at or came from Yate (Gloucs)."],"variants":[{"name":"Yorks Deeds","meanings":["Norman, English: nickname from Anglo-Norman French  <i>dobler</i>,  <i>dubler</i> ‘a kind of dish’ (Old French  <i>doblier, doublier</i>), probably used to denote a maker of plates or dishes; compare Adam le Dublerwrite, 1249 in   Assize Rolls   (Wilts), Hugh le dublerwrith, 14th cent.   Yorks Deeds   I."]},{"name":"Yeatman","meanings":["English (southern): occupational name for a gate-keeper, from Middle English <i>yate</i> + <i>man</i>. Compare   Yates  ."]},{"name":"Gate","meanings":["Anglo-Saxon: Geat, a gate"]},{"name":"Redmonds, Dictionary of Yorks Surnames","meanings":["English: locative name, probably from Gilderdale (Forest) in Alston (Cumb), as suggested by   Redmonds, Dictionary of Yorks Surnames  , rather than from Gildersdale in Warter (ER Yorks), as suggested by   Reaney and Wilson  ."]},{"name":"Yates","meanings":["English: from Middle English <i>yates</i> ‘gates’, plural of <i>yate</i>, Old English <i>geat</i> ‘gate’, hence a topographic or occupational name for someone who lived by the gates of a town or castle and who probably acted as the gatekeeper or porter. Compare   Gates  . Alternatively, a variant of the singular form <b>Yate</b>, with post-medieval excrescent <i>-s</i>."]}]},{"name":"John","type":"FIRST","attribution":"Dictionary of First Names © Patrick Hanks and Flavia Hodges 1990, 2003, 2006.","meanings":["form of   John  , also used quite frequently in the English-speaking world. In Northern Ireland it is sometimes found as a variant of   Ewan ."],"variants":[]}],"lifeSummary":"When John Yate I was born about 1335, in Arlingham, Gloucestershire, England, United Kingdom, his father, Robert Yates, was 27 and his mother, Mrs. Robert Yate, was 24. He married Margaret de Berkeley. They were the parents of at least 2 sons."},"et":{"about 1335–":"umbes 1335–Surnud","1335–Male":"1335–Surnud","1335–Female":"1335–Surnud","1358–Male":"1358–Surnud","1360–1440":"1360–1440","1310–Male":"1310–Surnud","1312–Female":"1312–Surnud","about 1360":"umbes 1360","1358":"1358","1335":"1335","1312":"1312","about 1358":"umbes 1358","1310":"1310","1440":"1440","about 1335":"umbes 1335","1360":"1360","Arlingham, Gloucester, England":"Arlingham, Gloucestershire, Inglismaa, United Kingdom","Charney Basset, Berkshire, England":"Charney Bassett, Berkshire, Inglismaa, United Kingdom","Arlingham, Gloucestershire, England":"Arlingham, Gloucestershire, Inglismaa, United Kingdom"},"fi":{"about 1335–":"noin 1335–Kuollut","1335–Male":"1