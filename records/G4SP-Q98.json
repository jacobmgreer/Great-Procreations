9":"1279","1266":"1266","1244":"1244","about 1246":"omkring 1246","1275":"1275","about 1275":"omkring 1275","1270":"1270","Markeaton, Derbyshire, England":"Markeaton, Derbyshire, England","England":"England","Whitley, Cheshire, England":"Whitley, Cheshire, England","Mackworth, Derbyshire, England":"Mackworth, Derbyshire, England"},"nl":{"about 1246–about 1275":"circa 1246–circa 1275","1244–1314":"1244–1314","1266–Male":"1266–Overleden","1270–Male":"1270–Overleden","1275–1337":"1275–1337","1279–1337":"1279–1337","1246–1275":"1246–1275","1337":"1337","1259":"1259","1314":"1314","about 1270":"circa 1270","1246":"1246","1279":"1279","1266":"1266","1244":"1244","about 1246":"circa 1246","1275":"1275","about 1275":"circa 1275","1270":"1270","Markeaton, Derbyshire, England":"Markeaton, Derbyshire, England","England":"England","Whitley, Cheshire, England":"Whitley, Cheshire, England","Mackworth, Derbyshire, England":"Mackworth, Derbyshire, England"},"en":{"about 1246–about 1275":"about 1246–about 1275","1244–1314":"1244–1314","1266–Male":"1266–Deceased","1270–Male":"1270–Deceased","1275–1337":"1275–1337","1279–1337":"1279–1337","1246–1275":"1246–1275","1337":"1337","1259":"1259","1314":"1314","about 1270":"about 1270","1246":"1246","1279":"1279","1266":"1266","1244":"1244","about 1246":"about 1246","1275":"1275","about 1275":"about 1275","1270":"1270","Markeaton, Derbyshire, England":"Markeaton, Derbyshire, England","England":"England","Whitley, Cheshire, England":"Whitley, Cheshire, England","Mackworth, Derbyshire, England":"Mackworth, Derbyshire, England","nameMeanings":[{"name":"Margaret","type":"FIRST","attribution":"Dictionary of First Names © Patrick Hanks and Flavia Hodges 1990, 2003, 2006.","meanings":["An extremely common given name from the Middle Ages onwards, derived via Old French <i>Marguerite</i> and Latin <i>Margarita</i> from Greek <i>Margarītēs</i>, from <i>margaron</i> ‘pearl’, a word ultimately of Hebrew origin. The name was always understood to mean ‘pearl’ throughout the Middle Ages. The first  St Margaret  was martyred at Antioch in Pisidia during the persecution instigated by the  Emperor Diocletian  in the early 4th century. However, there is some doubt about her name, as the same saint is venerated in the Orthodox Church as   Marina .  There were several other saintly bearers of the name, including St Margaret of Scotland (  d. 1093 ), wife of  King Malcolm Canmore  and daughter of Edmund Ironside of England. It was also the name of the wife of  Henry VI  of England,  Margaret of Anjou  (  1430–82 ), and of  Margaret Tudor  (  1489–1541 ), sister of  Henry VIII , who married James IV of Scotland and ruled as regent there after his death.  See also  Margery  ,   Marjorie ."],"variants":[{"name":"Margareta","meanings":["From the Latin form of Greek <i>Margarītēs</i>.  See  <b>Margaret</b>   ."]},{"name":"Margaretta","meanings":["An extremely common given name from the Middle Ages onwards, derived via Old French <i>Marguerite</i> and Latin <i>Margarita</i> from Greek <i>Margarītēs</i>, from <i>margaron</i> ‘pearl’, a word ultimately of Hebrew origin. The name was always understood to mean ‘pearl’ throughout the Middle Ages. The first  St Margaret  was martyred at Antioch in Pisidia during the persecution instigated by the  Emperor Diocletian  in the early 4th century. However, there is some doubt about her name, as the same saint is venerated in the Orthodox Church as   Marina .  There were several other saintly bearers of the name, including St Margaret of Scotland (  d. 1093 ), wife of  King Malcolm Canmore  and daughter of Edmund Ironside of England. It was also the name of the wife of  Henry VI  of England,  Margaret of Anjou  (  1430–82 ), and of  Margaret Tudor  (  1489–1541 ), sister of  Henry VIII , who married James IV of Scotland and ruled as regent there after his death.  See also  Margery  ,   Marjorie ."]}]}],"historicEvents":[{"id":1705189,"age":13,"year":"1259","julianDay":2180901,"title":"100 Yea