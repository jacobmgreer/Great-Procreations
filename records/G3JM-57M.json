leden","1182–Female":"1182–Overleden","Cir 1207":"1207","1240":"1240","1162":"1162","1182":"1182","1228":"1228","1217":"1217","1215":"1215","1204":"1204","1203":"1203","about 1217":"circa 1217","1234":"1234","1267":"1267","1207":"1207","Pentyrch, Cardiff, Wales":"Pentyrch, Cardiff, South Glamorgan, Wales, Verenigd Koninkrijk","Wales":"Wales, Verenigd Koninkrijk","Of Senghennydd Ctf, Glamorganshire, Wales":"Senghenydd, Glamorgan, Wales","Glamorgan, Wales":"Glamorgan, Wales"},"en":{"Cir 1207–":"1207–Deceased","1204–1267":"1204–1267","1207–Female":"1207–Deceased","1203–1234":"1203–1234","1217–Female":"1217–Deceased","1228–Female":"1228–Deceased","1240–Female":"1240–Deceased","1215–Female":"1215–Deceased","1162–Male":"1162–Deceased","1182–Female":"1182–Deceased","Cir 1207":"1207","1240":"1240","1162":"1162","1182":"1182","1228":"1228","1217":"1217","1215":"1215","1204":"1204","1203":"1203","about 1217":"about 1217","1234":"1234","1267":"1267","1207":"1207","Pentyrch, Cardiff, Wales":"Pentyrch, Cardiff, South Glamorgan, Wales, United Kingdom","Wales":"Wales, United Kingdom","Of Senghennydd Ctf, Glamorganshire, Wales":"Senghenydd, Glamorgan, Wales","Glamorgan, Wales":"Glamorgan, Wales","nameMeanings":[{"name":"Joan","type":"FIRST","attribution":"Dictionary of First Names © Patrick Hanks and Flavia Hodges 1990, 2003, 2006.","meanings":["Contracted form of Old French <i>Jo(h)anne</i>, from Latin <i>Io(h)anna</i> (  see  Joanna  ). In England this was the usual feminine form of   John   from the Middle English period onwards and was extremely popular, but in the 16th and 17th centuries it steadily lost ground to   Jane .  It was strongly revived in the first part of the 20th century, partly under the influence of  George Bernard Shaw's  play St Joan (  1923 ), based on the life of  Joan of Arc  (  1412–31 ). Claiming to be guided by the voices of the saints, she persuaded the French dauphin to defy the occupying English forces and have himself crowned, and she led the French army that raised the siege of Orleans in  1429 . The following year she was captured by the Burgundians and sold to the English, and a year later she was burned at the stake for witchcraft at the age of 18 or 19. Her story has captured the imagination of many writers, and she is variously portrayed as a national and political hero, a model of apolitical straightforwardness and honesty, and a religious heroine. She was canonized in  1920 . More recent influences have included the American film actress  Joan Crawford  (  1908–77 , born  Lucille le Sueur ), the British actress  Joan Collins  (  b. 1933 ), the American comedienne  Joan Rivers  (  b. 1933 ), and the West Indian pop singer  Joan Armatrading  (  b. 1950 )."],"variants":[{"name":"John","meanings":["form of   John  , also used quite frequently in the English-speaking world. In Northern Ireland it is sometimes found as a variant of   Ewan ."]}]},{"name":"Ferch","type":"LAST","attribution":"Dictionary of American Family Names © Patrick Hanks 2003, 2006.","meanings":["German: variant of   Ferg  . Compare   Verch  .","Probably also an Americanized form of German <b>Förtsch</b> (see   Foertsch  ).","Probably also an Americanized form of German <b>Förch</b> (see   Foerch  )."],"variants":[{"name":"Ferg","meanings":["1  ‘Sharp blade’.","2  ‘Wind’."]}]},{"name":"Rhys","type":"FIRST","attribution":"Dictionary of First Names © Patrick Hanks and Flavia Hodges 1990, 2003, 2006.","meanings":["Traditional name meaning ‘ardour’; borne in the Middle Ages by various rulers in south-west Wales, including  Rhys ap Tewdur  (  d. 1093 ) and  Rhys ap Gruffudd  (  1132–97 )."],"variants":[{"name":"Reece","meanings":["Anglicized spelling of Rhys . The name is now in widespread and frequent use outside Wales, in many cases representing a transferred use of the surname so spelled, which is derived from the given name."]},{"name":"Rees","meanings":["Anglicized spelling of Welsh Rhys, in some cases representing a transferred use of the surname so spelled, which is derived from the Welsh given name."]}]}],"lifeSummary":"When Lady Joan Ferch Rhys was born in 1207, in Senghenydd, Glamorgan, Wales, her father, Rhys ap Gruffudd, was 46 and her mother, Gwerfyl verch Hywel, was 26. She had at least 3 daughters with Sir Ralph Maelog."},"et":{"Cir 1207–":"1207–Surnud","1204–1267":"1204–1267","1207–Female":"1207–Surnud","1203–1234":"1203–1234","1217–Female":"1217–Surnud","1228–Female":"1228–Surnud","1240–Female":"1240–Surnud","1215–Female":"1215–Surnud","1162–Male":"1162–Surnud","1182–Female":"1182–Surnud","Cir 1207":"1207","1240":"1240","1162":"1162","1182":"1182","1228":"1228","1217":"1217","1215":"1215","1204":"1204","1203":"1203","about 1217":"umbes 1217","1234":"1234","1267":"1267","1207":"1207","Pentyrch, Cardiff, Wales":"Pentyrch, Cardiff, South Glamorgan, Wales, United Kingdom","Wales":"Wales, United Kingdom","Of Senghennydd Ctf, Glamorganshire, Wales":"Senghenydd, Glamorgan, Wales","Glamorgan, Wales":"Glamorgan, Wales"},"fi":{"Cir 1207–":"1207–Kuollut","1204–1267":"1204–1267","1207–Female":"1207–Kuollut","1203–1234":"1203–1234","1217–Female":"1217–Kuollut","1228–Female":"1228–Kuollut","1240–Female":"1240–Kuollut","1215–Female":"1215–Kuollut","1162–Male":"1162–Kuollut","1182–Female":"1182–Kuollut","Cir 1207":"1207","1240":"1240","1162":"1162","1182":"1182","1228":"1228","1217":"1217","1215":"1215","1204":"1204","1203":"1203","about 1217":"noin 1217","1234":"1234","1267":"1267","1207":"1207","Pentyrch, Cardiff, Wales":"Pentyrch, Cardiff, South Glamorgan, Wales, Yhdistynyt kuningaskunta","Wales":"Wales, Yhdistynyt kuningaskunta","Of Senghennydd Ctf, Glamorganshire, Wales":"Senghenydd, Glamorgan, Wales","Glamorgan, Wales":"Glamorgan, Wales"},"fr":{"Cir 1207–":"1207–Décédée","1204–1267":"1204–1267","1207–Female":"1207–Décédée","1203–1234":"1203–1234","1217–Female":"1217–Décédée","1228–Female":"1228–Décédée","1240–Female":"1240–Décédée","1215–Female":"1215–Décédée","1162–Male":"1162–Décédé","1182–Femal