041–1102":"1041–1102","1014–Female":"1014–Deceased","1014":"1014","1102":"1102","1012":"1012","Abt. 1014":"about 1014","1088":"1088","1041":"1041","Aquitane, France":"France","Caen, Calvados, Basse-Normandie, France":"Caen, Calvados, Lower Normandy, France","France":"France","nameMeanings":[{"name":"Lawes","type":"LAST","attribution":"Dictionary of American Family Names © Patrick Hanks 2003, 2006.","meanings":["English (mainly southern): see   Laws  ."],"variants":[{"name":"Laws","meanings":["English: variant of   Law   (pet form of   Lawrence  ), with genitival or post-medieval excrescent <i>-s</i>.","Perhaps a shortened form of Scottish or Irish   McLeish  . Compare   McLaws  ."]}]},{"name":"Judith","type":"FIRST","attribution":"Dictionary of First Names © Patrick Hanks and Flavia Hodges 1990, 2003, 2006.","meanings":["Biblical name, meaning ‘Jewess’ or ‘woman from Judea’, borne by a Jewish heroine whose story is recorded in the Book of Judith in the Apocrypha. Judith is portrayed as a beautiful widow who delivers her people from the invading Assyrians by gaining the confidence of their commander, Holofernes, and cutting off his head while he is asleep; without their commander, the Assyrians are duly routed. This has been a perennially popular Jewish name. In the English-speaking world it was taken up in the 16th century, having been in occasional use among Gentiles before this: for example, it was borne by a niece of William the Conqueror. It enjoyed great popularity between the 1940s and the 1960s. Today's notable bearers include the American novelist  Judith Krantz  (  b. 1928 ) and the Scottish composer  Judith Weir  (  b. 1954 )."],"variants":[]},{"name":"Marie","type":"FIRST","attribution":"Dictionary of First Names © Patrick Hanks and Flavia Hodges 1990, 2003, 2006.","meanings":["form of   Maria .  When first introduced to England in the Middle Ages, it was Anglicized in pronunciation and respelled   Mary .  This French form was reintroduced into the English-speaking world as a separate name in the 19th century, and is still pronounced more or less in the French manner, although sometimes with the stress on the first syllable. It is now often used in combination with other names such as <i>Ellie</i>, <i>Chloe</i>, and <i>Lisa</i>."],"variants":[]}],"lifeSummary":"Judith Marie Lawes was born about 1014, in France. She married Symon de Lutre in 1041, in France. They were the parents of at least 1 son."},"et":{"Abt. 1014–":"umbes 1014–Surnud","1012–1088":"1012–1088","1041–1102":"1041–1102","1014–Female":"1014–Surnud","1014":"1014","1102":"1102","1012":"1012","Abt. 1014":"umbes 1014","1088":"1088","1041":"1041","Aquitane, France":"Prantsusmaa","Caen, Calvados, Basse-Normandie, France":"Caen, Calvados, Basse-Normandie, Prantsusmaa","France":"Prantsusmaa"},"fi":{"Abt. 1014–":"noin 1014–Kuollut","1012–1088":"1012–1088","1041–1102":"1041–1102","1014–Female":"1014–Kuollut","1014":"1014","1102":"1102","1012":"1012","Abt. 1014":"noin 1014","1088":"1088","1041":"1041","Aquitane, France":"Ranska","Caen, Calvados, Basse-Normandie, France":"Caen, Calvados, Basse-Normandie, Ranska","France":"Ranska"},"fr":{"Abt. 1014–":"environ 1014–Décédée","1012–1088":"1012–1088","1041–1102":"1041–1102","1014–Female":"1014–Décédée","1014":"1014","1102":"1102","1012":"1012","Abt. 1014":"environ 1014","1088":"1088","1041":"1041","Aquitane, France":"France","Caen, Calvados, Basse-Normandie, France":"Caen, Calvados, Basse-Normandie, France","France":"France","lifeSummary":"Judith Marie Lawes est née environ 1014, à France. Elle a épousé Symon de Lutre en 1041, à France. Ils ont eu au moins 1 fils."},"de":{"Abt. 1014–":"um 1014–Verstorben","1012–1088":"1012–1088","1041–1102":"1041–1102","1014–Female":"1014–Verstorben","1014":"1014","1102":"1102","1012":"1012","Abt. 1014":"um 1014","1088":"1088","1041":"1041","Aquitane, France":"Frankreich","Caen, Calvados, Basse-Normandie, France":"Caen, Calvados, Basse-Normandie, Frankreich","France":"Frankreich","life