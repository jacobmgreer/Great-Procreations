–1229":"1185–1229","1215":"1215","1224":"1224","about 1229":"omkring 1229","1220":"1220","1185":"1185","about 1220":"omkring 1220","about 1185":"omkring 1185","1229":"1229","1180":"1180","England":"England","Hebburn, Northumberland, England":"Hebburn, Northumberland, England"},"nl":{"about 1185–about 1229":"circa 1185–circa 1229","1180–Male":"1180–Overleden","1220–Male":"1220–Overleden","1185–1229":"1185–1229","1215":"1215","1224":"1224","about 1229":"circa 1229","1220":"1220","1185":"1185","about 1220":"circa 1220","about 1185":"circa 1185","1229":"1229","1180":"1180","England":"England","Hebburn, Northumberland, England":"Hebburn, Northumberland, England"},"en":{"about 1185–about 1229":"about 1185–about 1229","1180–Male":"1180–Deceased","1220–Male":"1220–Deceased","1185–1229":"1185–1229","1215":"1215","1224":"1224","about 1229":"about 1229","1220":"1220","1185":"1185","about 1220":"about 1220","about 1185":"about 1185","1229":"1229","1180":"1180","England":"England","Hebburn, Northumberland, England":"Hebburn, Northumberland, England","nameMeanings":[{"name":"MacNeill","type":"LAST","attribution":"Dictionary of American Family Names © Patrick Hanks 2003, 2006.","meanings":["Irish and Scottish:  see  McNeil  ."],"variants":[{"name":"McNeil","meanings":["Scottish and Irish: Anglicized form of Gaelic <b>Mac Néill</b>, a patronymic from the personal name <i>Niall</i> (genitive <i>Néill</i>), see   Neil   and also <i>Neilson</i>, which was sometimes substituted for <i>McNeil</i> in Lowland Scotland.","History: The Scottish Clan McNeil claims descent from the early Irish king Niall of the Nine Hostages (see   O'Neill  ), and the name is associated in particular with the island of Barra in the Hebrides, having been brought there from Ireland in 1049. Some members of this clan later migrated to Antrim and Derry in Ireland. A different Scottish Clan MacNeill (spelled with two l's) has a traditional ancestral home on the island of Gigha."]}]},{"name":"Margaret","type":"FIRST","attribution":"Dictionary of First Names © Patrick Hanks and Flavia Hodges 1990, 2003, 2006.","meanings":["An extremely common given name from the Middle Ages onwards, derived via Old French <i>Marguerite</i> and Latin <i>Margarita</i> from Greek <i>Margarītēs</i>, from <i>margaron</i> ‘pearl’, a word ultimately of Hebrew origin. The name was always understood to mean ‘pearl’ throughout the Middle Ages. The first  St Margaret  was martyred at Antioch in Pisidia during the persecution instigated by the  Emperor Diocletian  in the early 4th century. However, there is some doubt about her name, as the same saint is venerated in the Orthodox Church as   Marina .  There were several other saintly bearers of the name, including St Margaret of Scotland (  d. 1093 ), wife of  King Malcolm Canmore  and daughter of Edmund Ironside of England. It was also the name of the wife of  Henry VI  of England,  Margaret of Anjou  (  1430–82 ), and of  Margaret Tudor  (  1489–1541 ), sister of  Henry VIII , who married James IV of Scotland and ruled as regent there after his death.  See also  Margery  ,   Marjorie ."],"variants":[{"name":"Margareta","meanings":["From the Latin form of Greek <i>Margarītēs</i>.  See  <b>Margaret</b>   ."]},{"name":"Margaretta","meanings":["Formed from Margaret."]}]}],"historicEvents":[{"id":1705187,"age":30,"year":"1215","julianDay":2164830,"title":"Magna Carta","description":"King John of England agreed to a charter of rights called the Magna Carta. The document was originally drafted by the Archbishop of Canterbury to establish peace between King John and a group of rebel barons. The Magna Carta was completed in 1215 and is now considered to be one of the greatest constitutional documents of all time.","url":"https://www.nationalarchives.gov.uk/education/medieval/magna-carta/","urlTitle":"National Archives - Magna Carta","jurisdictionLevel":0},{"id":1705188,"age":39,"year":"1224","julianDay":2168117,"title":"France Declares War on England","description":"France declared war on England as Louis VIII of France attacked Poitou and northern Gascony.","jurisdictionLevel":0}],"lifeSummary":"Margaret MacNeill was born about 1185, in England. She had at least 1 son with John de Hyburne. She died about 1229, in her hometown, at the age of 46."},"et":{"about 1185–about 1229":"umbes 1185–umbes 1229","1180–Male":"1180–Surnud","1220–Male":"1220–Surnud","1185–1229":"1185–1229","1215":"1215","1224":"1224","about 1229":"umbes 1229","1220":"1220","1185":"1185","about 1220":"umbes 1220","about 1185":"umbes 1185","1229":"1229","1180":"1180","England":"England","Hebburn, Northumberland, England":"Hebburn, Northumberland, England"},"fi":{"about 1185–about 1229":"noin 1185–noin 1229","1180–Male":"1180–Kuollut","1220–Male":"1220–Kuollut","1185–1229":"1185–1229","1215":"1215","1224":"1224","about 1229":"noin 1229","1220":"1220","1185":"1185","about 1220":"noin 1220","about 1185":"noin 1185","1229":"1229","1180":"1180","England":"England","Hebburn, Northumberland, England":"Hebburn, Northumberland, England"},"fr":{"about 1185–about 1229":"environ 1185–environ 1229","1180–Male":"1180–Décédé","1220–Male":"1220–Décédé","1185–1229":"1185–1229","1215":"1215","1224":"1224","about 1229":"environ 1229","1220":"1220","1185":"1185","about 1220":"environ 1220","about 1185":"environ 1185","1229":"1229","1180":"1180","England":"Angleterre","Hebburn, Northumberland, England":"Hebburn, Northumberland, Angleterre","lifeSummary":"Margaret MacNeill est née environ 1185, à Angleterre. Elle a eu au moins 1 fils avec John de Hyburne. Elle est décédée environ 1229, dans sa ville natale, à l’âge de 46 ans."},"de":{"about 1185–about 1229":"um 1185–um 1229","1180–Male":"1180–Verstorben","1220–Male":"1220–Verstorben","1185–1229":"1185–1229","1215":"1215","1224":"1224","about 1229":"um 1229","1220":"1220","1185":"1185","about 1220":"um 1220","about 1185":"um 1185","1229":"1229","1180":"1180","England":"England","Hebburn, Northumberland, England":"Hebburn, Northu