":"1029–preminuo","–1089":"–1089","1029–Female":"1029–preminula","1050–1080":"1050.–1080.","1000–1074":"1000–1074","1000–1047":"1000–1047.","1080":"1080.","1029":"1029","after 24 December 1089":"nakon 24. prosinca 1089.","1047":"1047.","1025":"1025","1089":"1089","after 1074":"nakon 1074.","1000":"1000","um 1025":"oko 1025.","1074":"1074","1050":"1050.","Glane, France":"Glane, Overijssel, Nizozemska","Arconciel, Sarine, Fribourg, Suisse":"Arconciel, Freiburg, Švicarska","Aarberg, Seeland, Bern, Suisse":"Aarberg, Bern, Švicarska","Germany":"Njemačka"},"cs":{"um 1025–after 24 December 1089":"okolo 1025–po 24. prosince 1089","1025–1089":"1025–1089","1029–Male":"1029–Zesnulý","–1089":"–1089","1029–Female":"1029–Zesnulá","1050–1080":"1050–1080","1000–1074":"1000–1074","1000–1047":"1000–1047","1080":"1080","1029":"1029","after 24 December 1089":"po 24. prosince 1089","1047":"1047","1025":"1025","1089":"1089","after 1074":"po 1074","1000":"1000","um 1025":"okolo 1025","1074":"1074","1050":"1050","Glane, France":"Glane, Overijssel, Nizozemsko","Arconciel, Sarine, Fribourg, Suisse":"Arconciel, Freiburg, Švýcarsko","Aarberg, Seeland, Bern, Suisse":"Aarberg, Bern, Švýcarsko","Germany":"Německo"},"da":{"um 1025–after 24 December 1089":"omkring 1025–efter 24. december 1089","1025–1089":"1025–1089","1029–Male":"1029–Afdød","–1089":"–1089","1029–Female":"1029–Afdød","1050–1080":"1050–1080","1000–1074":"1000–1074","1000–1047":"1000–1047","1080":"1080","1029":"1029","after 24 December 1089":"efter 24. december 1089","1047":"1047","1025":"1025","1089":"1089","after 1074":"efter 1074","1000":"1000","um 1025":"omkring 1025","1074":"1074","1050":"1050","Glane, France":"Glane, Overijssel, Nederlandene","Arconciel, Sarine, Fribourg, Suisse":"Arconciel, Freiburg, Schweiz","Aarberg, Seeland, Bern, Suisse":"Aarberg, Bern, Schweiz","Germany":"Tyskland"},"nl":{"um 1025–after 24 December 1089":"circa 1025–na 24 december 1089","1025–1089":"1025–1089","1029–Male":"1029–Overleden","–1089":"–1089","1029–Female":"1029–Overleden","1050–1080":"1050–1080","1000–1074":"1000–1074","1000–1047":"1000–1047","1080":"1080","1029":"1029","after 24 December 1089":"na 24 december 1089","1047":"1047","1025":"1025","1089":"1089","after 1074":"na 1074","1000":"1000","um 1025":"circa 1025","1074":"1074","1050":"1050","Glane, France":"Glane, Overijssel, Nederland","Arconciel, Sarine, Fribourg, Suisse":"Arconciel, Freiburg, Zwitserland","Aarberg, Seeland, Bern, Suisse":"Aarberg, Bern, Zwitserland","Germany":"Duitsland"},"en":{"um 1025–after 24 December 1089":"about 1025–after 24 December 1089","1025–1089":"1025–1089","1029–Male":"1029–Deceased","–1089":"–1089","1029–Female":"1029–Deceased","1050–1080":"1050–1080","1000–1074":"1000–1074","1000–1047":"1000–1047","1080":"1080","1029":"1029","after 24 December 1089":"after 24 December 1089","1047":"1047","1025":"1025","1089":"1089","after 1074":"after 1074","1000":"1000","um 1025":"about 1025","1074":"1074","1050":"1050","Glane, France":"Glane, Overijssel, Netherlands","Arconciel, Sarine, Fribourg, Suisse":"Arconciel, Fribourg, Switzerland","Aarberg, Seeland, Bern, Suisse":"Aarberg, Bern, Switzerland","Germany":"Germany","nameMeanings":[{"name":"Graf","type":"LAST","attribution":"Dictionary of American Family Names © Patrick Hanks 2003, 2006.","meanings":["Some characteristic forenames:  German Hans, Kurt, Otto, Erwin, Ernst, Fritz, Gerhard, Hermann, Horst, Manfred, Udo, Alois.","German (also <b>Gräf</b>): status name from Middle High German <i>grāve</i>, <i>grābe</i>, which was used as a title denoting various more or less aristocratic dignitaries and officials. In later times it became established as a title of nobility equivalent to the Romance count. The vocabulary word also denoted a variety of different minor local functionaries in different parts of Germany. In the Grand Duchy of Hesse, for example, it was used for the holder of the comparatively humble office of village headman (compare   Mayer  ,   Schulz  , and   Vogt  ). The surname could have originated from any of these senses or be a metonymic occupational or status name for a servant or retainer of a count, or a nickname for someone who gave himself airs and graces. This surname is also found in many other European countries, for example in France (Alsace and Lorraine), Hungary, Poland, Czechia, Slovakia, Croatia, and Slovenia, often as a translation into German of the corresponding Hungarian and Slavic surnames <b>Gróf</b> and   Grof  . Compare   Graef  .","Jewish (Ashkenazic): artificial name selected, like   Herzog   and other words denoting titles, because of their aristocratic connotations."],"variants":[{"name":"Grebe","meanings":["Some characteristic forenames:  German Kurt, Erwin, Fritz, Hans, Willi.","German (Hesse): variant of   Graf  ."]},{"name":"De Graaf","meanings":["Some characteristic forenames:  Dutch Gerrit, Adriaan, Bastiaan, Cornelis, Dirk, Geert.","Dutch: from <i>graaf</i> ‘count’ (see   Graf  ), with the addition of the definite article <i>de</i> ‘the’, hence a nickname for the servant of a count or for someone supposedly resembling one, and also a topographic or habitational name referring to a house or inn named with this word."]},{"name":"Graefe","meanings":["Some characteristic forenames:  German Armin, Arno, Goetz, Horst, Johannes.","German (North Rhine-Westphalia; also <b>Gräfe</b>): variant of   Graf   1."]},{"name":"Grefe","meanings":["Some characteristic forenames:  German Erhardt, Gerhard, Gerhart, Kurt.","North German: variant of   Graf  ."]},{"name":"Greve","meanings":["Some characteristic forenames:  German Gerhard, Otto, Reinhold, Bernhardt, Claus, Erna, Erwin, Ewald, Fritz, Kurt.","North German and Scandinavian: status name from Middle Low German and Danish <i>greve</i> ‘count’, equivalent to German   Graf  .","Dutch: vowel variant of   Grave   ‘count’, or a topographic name from Middle Dutch <i>greve</i> ‘ditch, moat, channel’."]},{"name":"Croff","meanings":["Altered form of German   Graf   or   Graff  . Or of Dutch   Kroft  ."]},{"name":"Mayer","meanings":["Some characteristic forenames:  German Kurt, Otto, Hans, Franz, Helmut, Wilhelm, Erwin, Gerhard, Heinz, Ilse, Lorenz, Wolfgang.","English (Staffordshire): post-medieval form of <b>Mear</b>, which is either a topographic name, from Middle English <i>mere</i> ‘pond, pool’ (Old English <i>mere</i>) or Middle English <i>mere</i> ‘boundary’ (Old English <i>(ge)mǣre</i>), or a habitational name from one or more of the many places with names derived from these terms, such as Mere (Cheshire, Lincolnshire, Wiltshire), Meir in Caverswall (Staffordshire), and Meare (Somerset).","English: occupational name for a physician, from Old French <i>mire</i>, Middle English <i>mire</i>, <i>meir</i>, <i>meyre</i>, originally synonymous with   Myer  ."]},{"name":"Grafe","meanings":["Some characteristic forenames:  German Fritz, Ralf.","German (also <b>Gräfe</b>): variant of   Graf   1."]},{"name":"Graef","meanings":["Some characteristic forenames:  German Egon, Lothar, Otto, Armin, Claus, Erwin, Franz, Friedrich, Hans, Helmut, Hermann, Jochen.","German (also <b>Gräf</b>): see   Graf  .","Dutch: variant of <b>Graaf</b>, see   De Graaf  ."]},{"name":"Graff","meanings":["German and Jewish (Ashkenazic) (also <b>Gräff</b>): variant of   Graf  . Compare   Graeff  .","English (London): metonymic occupational name for a clerk or scribe, from Old French <i>grafe</i> ‘stylus, pencil’, a derivative of Old French <i>grafer</i> ‘to write’ (from Late Latin <i>grafare</i>, from Greek <i>graphein</i>). It is uncertain whether the English name survived the medieval period or whether the early 17th century bearers in Britain were in fact of German origin."]}]},{"name":"von","type":"LAST","attribution":"Dictionary of American Family Names © Patrick Hanks 2003, 2006.","meanings":["Altered form of Welsh   Vaughan  .","Chinese: variant of   Wong  .","Cambodian: written វ៉ុន, unexplained."],"variants":[{"name":"Vaughan","meanings":["Welsh: from <i>fychan</i>, a lenited form of <i>bychan</i>, a diminutive of <i>bach</i> ‘little’. This was often used to distinguish the younger of two bearers of the same personal name, typically the son of a father with the same name."]}]},{"name":"Kuno","type":"FIRST","attribution":"Dictionary of First Names © Patrick Hanks and Flavia Hodges 1990, 2003, 2006.","meanings":["Anglicized form of the Irish name Úna , assimilated to the name of the Roman goddess <i>Juno</i>, consort of Jupiter."],"variants":[]}],"lifeSummary":"When Kuno Graf von Oltingen was born about 1025, in Arconciel, Fribourg, Switzerland, his father, Graft Burkhard von Oltingen, was 27 and his mother, Arcenciel of Italy, was 26. He had at least 1 son with Sophie de Luxembourg. He died after 24 December 1089."},"et":{"um 1025–after 24 December 1089":"umbes 1025–pärast 24. detsembrit 1089","1025–1089":"1025–1089","1029–Male":"1029–Surnud","–1089":"–1089","1029–Female":"1029–Surnud","1050–1080":"1050–1080","1000–1074":"1000–1074","1000–1047":"1000–1047","1080":"1080","1029":"1029","after 24 December 1089":"pärast 24. detsembrit 1089","1047":"1047","1025":"1025","1089":"1089","after 1074":"pärast 1074","1000":"1000","um 1025":"umbes 1025","1074":"1074","1050":"1050","Glane, France":"Glane, Overijssel, Madalmaad","Arconciel, Sarine, Fribourg, Suisse":"Arconciel, Freiburg, Šveits","Aarberg, Seeland, Bern, Suisse":"Aarberg, Bern, Šveits","Germany":"Saksamaa"},"fi":{"um 1025–after 24 December 1089":"noin 1025–24. joulukuuta 1089 jälkeen","1025–1089":"1025–1089","1029–Male":"1029–Kuollut","–1089":"–1089","1029–Female":"1029–Kuollut","1050–1080":"1050–1080","1000–1074":"1000–1074","1000–1047":"1000–1047","1080":"1080","1029":"1029","after 24 December 1089":"24. joulukuuta 1089 jälkeen","1047":"1047","1025":"1025","1089":"1089","after 1074":"1074 jälkeen","1000":"1000","um 1025":"noin 1025","1074":"1074","1050":"1050","Glane, France":"Glane, Overijssel, Alankomaat","Arconciel, Sarine, Fribourg, Suisse":"Arconciel, F