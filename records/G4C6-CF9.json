0","1030":"1030","1040":"1040","1071":"1071","Leslie, Fifeshire, Scotland":"Leslie, Fife, Skotsko, United Kingdom","Hungary":"Maďarsko","Rathes,Moray,Scotland":"Rothes, Moray, Skotsko, United Kingdom","Scotland":"Scotland"},"da":{"1040–1121":"1040–1121","1030–1121":"1030–1121","1035–Female":"1035–Afdød","1071–1176":"1071–1176","1020–Male":"1020–Afdød","1010–Female":"1010–Afdød","about 1071":"omkring 1071","1057":"1057","1035":"1035","1121":"1121","1176":"1176","1010":"1010","before 1040":"før 1040","1020":"1020","1030":"1030","1040":"1040","1071":"1071","Leslie, Fifeshire, Scotland":"Leslie, Fife, Skotland, United Kingdom","Hungary":"Ungarn","Rathes,Moray,Scotland":"Rothes, Moray, Skotland, United Kingdom","Scotland":"Skotland"},"nl":{"1040–1121":"1040–1121","1030–1121":"1030–1121","1035–Female":"1035–Overleden","1071–1176":"1071–1176","1020–Male":"1020–Overleden","1010–Female":"1010–Overleden","about 1071":"circa 1071","1057":"1057","1035":"1035","1121":"1121","1176":"1176","1010":"1010","before 1040":"vóór 1040","1020":"1020","1030":"1030","1040":"1040","1071":"1071","Leslie, Fifeshire, Scotland":"Leslie, Fife, Schotland, Verenigd Koninkrijk","Hungary":"Hongarije","Rathes,Moray,Scotland":"Rothes, Moray, Schotland, Verenigd Koninkrijk","Scotland":"Schotland"},"en":{"1040–1121":"1040–1121","1030–1121":"1030–1121","1035–Female":"1035–Deceased","1071–1176":"1071–1176","1020–Male":"1020–Deceased","1010–Female":"1010–Deceased","about 1071":"about 1071","1057":"1057","1035":"1035","1121":"1121","1176":"1176","1010":"1010","before 1040":"before 1040","1020":"1020","1030":"1030","1040":"1040","1071":"1071","Leslie, Fifeshire, Scotland":"Leslie, Fife, Scotland, United Kingdom","Hungary":"Hungary","Rathes,Moray,Scotland":"Rothes, Moray, Scotland, United Kingdom","Scotland":"Scotland","nameMeanings":[{"name":"Leslie","type":"LAST","attribution":"Dictionary of American Family Names © Patrick Hanks 2003, 2006.","meanings":["Scottish: habitational name from a barony in Aberdeenshire, which is first recorded <i>c.</i> 1180 in the form <i>Lesslyn</i>, of obscure origin. Leslie in Fife is said to be named for this place; in some cases the surname may come from there.","English: from the Middle English female personal name <i>Lecelin</i>, a double diminutive of <i>Lece</i>. See   Leece   and   Lesley  .","History: The Scottish Clan Leslie claims descent from Bartolf, a Hungarian nobleman who came to Scotland in 1068 or 1070 in the retinue of Queen Margaret. She was an English princess who had been born and brought up in Hungary and who went on to marry King Malcolm III of Scotland. Members of the clan have held several titles in the peerage of Scotland, including Earl of Rothes (from 1437)."],"variants":[{"name":"Leece","meanings":["English: from a medieval female personal name, <i>Lece</i>, a short form of <i>Lettice</i> (from Latin <i>Laetitia</i>, meaning ‘happiness, gaiety’).","English: variant of   Lees  .","Irish: shortened form of Gaelic <i>Mac Giolla Íosa</i>, Manx <i>Mac Guilley Yeesey</i> ‘son of <i>Giolla Íosa</i> (devotee or servant of Jesus)’. Ballaleece (‘Leece's farm’) in Kirk German was the family's main seat."]},{"name":"Lesslie","meanings":["Scottish: variant of   Leslie  ."]},{"name":"Lesley","meanings":["Scottish and northern Irish: variant of   Leslie  ."]},{"name":"Laslie","meanings":["Scottish: variant of   Leslie  ."]},{"name":"Lessley","meanings":["English (Norfolk): variant of   Leslie  ."]},{"name":"Lasley","meanings":["Scottish: variant of   Leslie  ."]}]},{"name":"Bartholomew","type":"FIRST","attribution":"Dictionary of First Names © Patrick Hanks and Flavia Hodges 1990, 2003, 2006.","meanings":["Of New Testament origin, the name of an apostle mentioned in all the synoptic gospels (Matthew, Mark, and Luke) and in the Acts of the Apostles. It is an Aramaic formation meaning ‘son of Talmai’, and has been assumed by many scholars to be a byname of the apostle   Nathaniel .  <i>Talmai</i> is a Hebrew name, said to mean ‘abounding in furrows’ (Numbers 13:22)."],"variants":[]}],"lifeSummary":"When Bartholomew Leslie Governor of Edinburgh Castle was born in 1040, in Hungary, his father, Norman de Leslie, was 21 and his mother, Maurick de Pollok, was 31. He had at least 1 son with Beatrix Princess of Scotland. In 1057, at the age of 17, his occupation is listed as baron of beanley. He died in 1121, in Leslie, Fife, Scotland, United Kingdom, at the age of 81."},"et":{"1040–1121":"1040–1121","1030–1121":"1030–1121","1035–Female":"1035–Surnud","1071–1176":"1071–1176","1020–Male":"1020–Surnud","1010–Female":"1010–Surnud","about 1071":"umbes 1071","1057":"1057","1035":"1035","1121":"1121","1176":"1176","1010":"1010","before 1040":"enne 1040","1020":"1020","1030":"1030","1040":"1040","1071":"1071","Leslie, Fifeshire, Scotland":"Leslie, Fife, Šotimaa, United Kingdom","Hungary":"Ungari","Rathes,Moray,Scotland":"Rothes, Moray, Šotimaa, United Kingdom","Scotland":"Scotland"},"fi":{"1040–1121":"1040–1121","1030–1121":"1030–1121","1035–Female":"1035–Kuollut","1071–1176":"1071–1176","1020–Male":"1020–Kuollut","1010–Female":"1010–Kuollut","about 1071":"noin 1071","1057":"1057","1035":"1035","1121":"1121","1176":"1176","1010":"1010","before 1040":"ennen vuotta 1040","1020":"1020","1030":"1030","1040":"1040","1071":"1071","Leslie, Fifeshire, Scotland":"Leslie, Fife, Skotlanti, Yhdistynyt kuningaskunta","Hungary":"Unkari","Rathes,Moray,Scotland":"Rothes, Moray, Skotlanti, Yhdistynyt kuningaskunta","Scotland":"Scotland"},"fr":{"1040–1121":"1040–1121","1030–1121":"1030–1121","1035–Female":"1035–Décédée","1071–1176":"1071–1176","1020–Male":"1020–Décédé","1010–Female":"1010–Décédée","about 1071":"environ 1071","1057":"1057","1035":"1035","1121":"1121","1176":"1176","1010":"1010","before 1040":"avant 1040","1020":"1020","1030":"1030","1040":"1040","1071":"1071","Leslie, Fifeshire, Scotland":"Leslie, Fife, Écosse, Royaume-Uni","Hungary":"Hongrie","Rathes,Moray,Scotland":"Rothes, Moray, Écosse, Royaume-Uni","Scotland":"Écosse","lifeSummary":"Lorsque Bartholomew Leslie Governor of Edinburgh Castle est né en 1040, à Hongrie, son père, Norman de Leslie, avait 21 ans et sa mère, Maurick de Pollok, avait 31 ans. Il a eu au moins 1 fils avec Beatrix Princess of Scotland. En 1057, à l’âge de 17 ans, sa profession de son indiquée est baron of beanley. Il est décédé en 1121, à Leslie, Fife, Écosse, Royaume-Uni, à l’âge de 81 ans."},"de":{"1040–1121":"1040–1121","1030–1121":"1030–1121","1035–Female":"1035–Verstorben","1071–1176":"1071–1176","1020–Male":"1020–Verstorben","1010–Female":"1010–Verstorben","about 1071":"um 1071","1057":"1057","1035":"1035","1121":"1121","1176":"1176","1010":"1010","before 1040":"vor 1040","1020":"1020","1030":"1030","1040":"1040","1071":"1071","Leslie, Fifeshire, Scotland":"Leslie, Fife, Schottland, United Kingdom","Hungary":"Ungarn","Rathes,Moray,Scotland":"Rothes, Moray, Schottland, United Kingdom","Scotland":"Scotland","lifeSummary":"Als Bartholomew Leslie Governor of Edinburgh Castle 1040 in Ungarn geboren wurde, war sein Vater Norman de Leslie 21 und seine Mutter Maurick de Pollok 31. Er hatte mit Beatrix Princess of Scotland mindestens 1 Sohn. 1057, als er 17 Jahre alt war, war sein Beruf als baron of beanley aufgeführt. Er starb 1121 im Alter von 81 Jahren in Leslie, Fife, Schottland, United Kingdom."},"ht":{"1040–1121":"1040–1121","1030–1121":"1030–1121","1035–Female":"1035–Desede","1071–1176":"1071–1176","1020–Male":"1020–Desede","1010–Female":"1010–Desede","about 1071":"about 1071","1057":"1057","1035":"1035","1121":"1121","1176":"1176","1010":"1010","before 1040":"before 1040","1020":"1020","1030":"1030","1040":"1040","1071":"1071","Leslie, Fifeshire, Scotland":"Leslie, Fife, Ecosse, United Kingdom","Hungary":"Hongrie","Rathes,Moray,Scotland":"Rothes, Moray, Ecosse, United Kingdom","Scotland":"Scotland"},"hu":{"1040–1121":"1040–1121","1030–1121":"1030–1121","1035–Female":"1035–elhunyt","1071–1176":"1071–1176","1020–Male":"1020–elhunyt","1