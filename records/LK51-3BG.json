7–Male":"1197–Overleden","1210–Male":"1210–Overleden","1223–1197":"1223–1197","–Male":"Overleden","1230–Male":"1230–Overleden","1160–Male":"1160–Overleden","1165–Female":"1165–Overleden","1165":"1165","1230":"1230","1197":"1197","1160":"1160","1290":"1290","1315":"1315","1259":"1259","1215":"1215","1224":"1224","1223":"1223","1211":"1211","1210":"1210","1185 to 1210":"van 1185 to 1210","1328":"1328","1317":"1317","Goudhurst, Kent, England":"Goudhurst, Kent, England","Scotland orKent England":"Schotland, Verenigd Koninkrijk"},"en":{"1210–":"1210–Deceased","1197–Male":"1197–Deceased","1210–Male":"1210–Deceased","1223–1197":"1223–1197","–Male":"Deceased","1230–Male":"1230–Deceased","1160–Male":"1160–Deceased","1165–Female":"1165–Deceased","1165":"1165","1230":"1230","1197":"1197","1160":"1160","1290":"1290","1315":"1315","1259":"1259","1215":"1215","1224":"1224","1223":"1223","1211":"1211","1210":"1210","1185 to 1210":"from 1185 to 1210","1328":"1328","1317":"1317","Goudhurst, Kent, England":"Goudhurst, Kent, England","Scotland orKent England":"Scotland, United Kingdom","nameMeanings":[{"name":"De","type":"LAST","attribution":"Dictionary of American Family Names © Patrick Hanks 2003, 2006.","meanings":["Some characteristic forenames:  Indian Dilip, Anirban, Gopal, Alok, Anindya, Arunava, Asit, Asok, Dibyendu, Goutam, Indra, Indranil.","Indian: variant of   Dey  ."],"variants":[{"name":"Dey","meanings":["Some characteristic forenames:  Indian Ashit, Indu, Naina, Partha, Soumya, Ajit, Anjan, Anjana, Anup, Arjun, Arun, Ashim.","English, Scottish, and Welsh: variant of   Day  .","German: topographic name from a field name in North Rhine-Westphalia, denoting a sizeable piece of land, from Middle Low German <i>dē</i> ‘thigh’ (referring to the shape of the property)."]}]},{"name":"Robert","type":"FIRST","attribution":"Dictionary of First Names © Patrick Hanks and Flavia Hodges 1990, 2003, 2006.","meanings":["One of the many French names of Germanic origin that were introduced into Britain by the Normans; it has since remained in continuous use. It is derived from the nearly synonymous elements <i>hrōd</i> ‘fame’ + <i>berht</i> ‘bright, famous’, and had a native Old English predecessor of similar form (<i>Hreodbeorht</i>), which was supplanted by the Norman name. Two dukes of Normandy in the 11th century bore the name: the father of  William the Conqueror  (sometimes identified with the legendary Robert the Devil), and his eldest son. It was borne also by three kings of Scotland, notably  Robert the Bruce  (  1274–1329 ), who freed Scotland from English domination. The altered short form <i>Bob</i> is very common, but <i>Hob</i> and <i>Dob</i>, which were common in the Middle Ages and gave rise to surnames, are extinct.  See also  Rupert ."],"variants":[]}],"historicEvents":[{"id":1705187,"age":5,"year":"1215","julianDay":2164830,"title":"Magna Carta","description":"King John of England agreed to a charter of rights called the Magna Carta. The document was originally drafted by the Archbishop of Canterbury to establish peace between King John and a group of rebel barons. The Magna Carta was completed in 1215 and is now considered to be one of the greatest constitutional documents of all time.","url":"https://www.nationalarchives.gov.uk/education/medieval/magna-carta/","urlTitle":"National Archives - Magna Carta","jurisdictionLevel":2},{"id":1705188,"age":14,"year":"1224","julianDay":2168117,"title":"France Declares War on England","description":"France declared war on England as Louis VIII of France attacked Poitou and northern Gascony.","jurisdictionLevel":2},{"id":1705189,"age":49,"year":"1259","julianDay":2180901,"title":"100 Years of Conflict Between England and France Ends","description":"Treaty of Paris was signed on December 4, 1259, which ended 100 years of conflict between England and France.","url":"https://en.wikipedia.org/wiki/Treaty_of_Paris_(1259)","urlTitle":"Wikipedia - Treaty of Paris 1259","jurisdictionLevel":2},{"id":1705190,"age":80,"year":"1290","julianDay":2192224,"title":"Jews Expelled From England","description":"After years of anti-Semitic behavior, King Edward I expelled Jews from England in 1290.","jurisdictionLevel":2},{"id":1705191,"age":105,"year":"1315","toYear":"1317","julianDay":2201354,"title":"Famine Strikes Europe","description":"A famine caused by cold winters and wet summers across Europe caused millions to die due to starvation. Desperation from hunger caused high levels of crime, stampedes in bread lines in London, infanticide, and even cannibalism throughout Europe.","jurisdictionLevel":2},{"id":1705192,"age":118,"year":"1328","julianDay":2206102,"title":"First War of Scottish Independence","description":"The First War of Scottish Independence began after England invaded Scotland in 1296. The Treaty of Edinburgh was signed in 1328 which declared peace between the two kingdoms and brought the war to an end.","jurisdictionLevel":2}],"lifeSummary":"When Robert De Rookehurst I was born in 1210, in Goudhurst, Kent, England, his father, William ROKEHURSTE, was 51 and his mother, Gwenillian Ferch Aaron, was 45. He had at least 1 son. He died in his hometown."},"et":{"1210–":"1210–Surnud","1197–Male":"1197–Surnud","1210–Male":"1210–Surnud","1223–1197":"1223–1197","–Male":"Surnud","1230–Male":"1230–Surnud","1160–Male":"1160–Surnud","1165–Female":"1165–Surnud","1165":"1165","1230":"1230","1197":"1197","1160":"1160","1290":"1290","1315":"1315","1259":"1259","1215":"1215","1224":"1224","1223":"1223","1211":"1211","1210":"1210","1185 to 1210":"1185 kuni 1210","1328":"1328","1317":"1317","Goudhurst, Kent, England":"Goudhurst, Kent, England","Scotland orKent England":"Šotimaa, United Kingdom"},"fi":{"1210–":"1210–Kuollut","1197–Male":"1197–Kuollut","1210–Male":"1210–Kuollut","1223–1197":"1223–1197","–Male":"Kuollut","1230–Male":"1230–Kuollut","1160–Male":"1160–Kuollut","1165–Female":"1165–Kuollut","1165":"1165","1230":"1230","1197":"1197","1160":"1160","1290":"1290","1315"