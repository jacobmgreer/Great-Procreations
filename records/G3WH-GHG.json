, Somerset, England":"Somerset, Inglaterra, United Kingdom","Llanwinio, Carmarthenshire, Wales":"Llanwinio, Carmarthenshire, Gales, United Kingdom","lifeSummary":"Quando Sir Jean Perout Proute Prute nasceu em 1046, em Morbihan, Bretagne, França, seu pai, Sir Richard Seignuer De Perrot, tinha 51 anos e sua mãe, Blanche de Aragon, tinha 27 anos. Ele casou-se com Marged Verch Cadivor Vawr em 1091, em Llanwinio, Carmarthenshire, Gales, United Kingdom. Eles tiveram pelo menos 1 filho. Ele faleceu antes 1120, em Somerset, Inglaterra, United Kingdom."},"ro":{"1046–BEF 1120":"1046–înainte de 1120","1038–1085":"1038–1085","1040–Male":"1040–Decedat","1042–Male":"1042–Decedat","1044–Male":"1044–Decedat","1046–1120":"1046–1120","1070–Female":"1070–Decedată","1090–1185":"1090–1185","1089–Male":"1089–Decedat","0995–Male":"0995–Decedat","1019–Female":"1019–Decedată","1091":"1091","1090":"1090","1044":"1044","1120":"1120","1185":"1185","1042":"1042","1085":"1085","1040":"1040","1070":"1070","1019":"1019","BEF 1120":"înainte de 1120","0995":"0995","1038":"1038","1046":"1046","1089":"1089","Somerset, England":"Somerset, Anglia, United Kingdom","Brittany, Morbihan, France":"Morbihan, Bretagne, Franţa","Perrot, Somerset, England":"Somerset, Anglia, United Kingdom","Llanwinio, Carmarthenshire, Wales":"Llanwinio, Carmarthenshire, Țara Galilor, United Kingdom"},"ru":{"1046–BEF 1120":"1046 г.–перед 1120 г.","1038–1085":"1038г.–1085г.","1040–Male":"1040г.–Умерший","1042–Male":"1042г.–Умерший","1044–Male":"1044г.–Умерший","1046–1120":"1046г.–1120г.","1070–Female":"1070г.–Умершая","1090–1185":"1090г.–1185г.","1089–Male":"1089г.–Умерший","0995–Male":"0995г.–Умерший","1019–Female":"1019г.–Умершая","1091":"1091 г.","1090":"1090 г.","1044":"1044 г.","1120":"1120 г.","1185":"1185 г.","1042":"1042 г.","1085":"1085 г.","1040":"1040 г.","1070":"1070 г.","1019":"1019 г.","BEF 1120":"перед 1120 г.","0995":"0995 г.","1038":"1038 г.","1046":"1046 г.","1089":"1089 г.","Somerset, England":"сомирсет, Англия