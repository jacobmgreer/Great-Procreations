d Kingdom","Barnard Castle, Durham, England":"Barnard Castle, Durham, Inglaterra","Furness, Cumbria, England":"Barrow in Furness, Cumbria, Inglaterra, United Kingdom","lifeSummary":"Quando William Greystoke nasceu aproximadamente 1158, em Lincolnshire, Inglaterra, seu pai, Ranulph Greystoke, tinha 30 anos e sua mãe, Amabel Balliol, tinha 25 anos. Ele casou-se com Helawise de Stuteville aproximadamente 1180, em Inglaterra, United Kingdom. Eles tiveram pelo menos 1 filho. Ele faleceu em 1209, em Greystoke, Cumberland, Inglaterra, com 52 anos, e foi sepultado em Barrow in Furness, Cumbria, Inglaterra, United Kingdom."},"ro":{"about 1158–1209":"aproximativ 1158–1209","1158–1209":"1158–1209","1161–Male":"1161–Decedat","1162–1213":"1162–1213","1142–1226":"1142–1226","1190–1247":"1190–1247","1205–Female":"1205–Decedată","1130–1190":"1130–1190","1135–1204":"1135–1204","1190":"1190","1142":"1142","1130":"1130","1162":"1162","1161":"1161","about 1190 date fits better":"aproximativ 1190","1205":"1205","1204":"1204","1226":"1226","31 March 1204":"31 martie 1204","1247":"1247","1213":"1213","1158":"1158","1135":"1135","about 1158":"aproximativ 1158","about 1157":"aproximativ 1157","1209":"1209","Abt 1180":"aproximativ 1180","Greystoke, Cumberland, England":"Greystoke, Cumberland, England","England":"Anglia, United Kingdom","Lincolnshire, England":"Lincolnshire, England",", , , England":"Anglia, United Kingdom","Barnard Castle, Durham, England":"Barnard Castle, Durham, England","Furness, Cumbria, England":"Barrow in Furness, Cumbria, Anglia, United Kingdom"},"ru":{"about 1158–1209":"около 1158 г.–1209 г.","1158–1209":"1158г.–1209г.","1161–Male":"1161г.–Умерший","1162–1213":"1162г.–1213г.","1142–1226":"1142г.–1226г.","1190–1247":"1190г.–1247г.","1205–Female":"1205г.–Умершая","1130–1190":"1130г.–1190г.","1135–1204":"1135г.–1204г.","1190":"1190 г.","1142":"1142 г.","1130":"1130 г.","1162":"1162 г.","1161":"1161 г.","about 1190 date fits better":"около 1190 г.","1205":"1205 г.","1204