0","1340–1390":"1340–1390","1351–1390":"1351–1390","1374–1450":"1374–1450","1300–1370":"1300–1370","1319–1350":"1319–1350","1374":"1374","1373":"1373","1450":"1450","1351":"1351","1340":"1340","1350":"1350","1370":"1370","1390":"1390","Abt 1340":"about 1340","Abt 1370":"about 1370","about 1338":"about 1338","1300":"1300","Abt 1390":"about 1390","1319":"1319","Worcestershire, England":"Worcestershire, England","Warnedon, Worcester, England":"Warndon, Worcestershire, England","Madresfield, Worcestershire, England":"Madresfield, Worcestershire, England, United Kingdom","nameMeanings":[{"name":"Brace","type":"LAST","attribution":"Dictionary of American Family Names © Patrick Hanks 2003, 2006.","meanings":["English (of Norman origin): nickname from Old French <i>braz</i>, <i>brace</i>, <i>brase</i> ‘arm’, probably used of someone with a strong arm or with a deformity of the arm."],"variants":[{"name":"Brass","meanings":["Scottish: habitational name from Birse in Aberdeenshire, metathesized to <i>Brass</i>.","English (Northumberland): variant of   Brace  .","North German: nickname from Middle Low German <i>brās</i> ‘noise, pomp’, a related form of <i>brāsch</i> (see   Braasch  )."]}]},{"name":"William","type":"FIRST","attribution":"Dictionary of First Names © Patrick Hanks and Flavia Hodges 1990, 2003, 2006.","meanings":["Probably the most successful of all the Old French names of Germanic origin that were introduced to England by the Normans. It is derived from Germanic <i>wil</i> ‘will, desire’ + <i>helm</i> ‘helmet, protection’. The fact that it was borne by the Conqueror himself does not seem to have inhibited its favour with the ‘conquered’ population: in the first century after the Conquest it was the commonest male name of all, and not only among the Normans. In the later Middle Ages it was overtaken by   John  , but continued to run second to that name until the 20th century, when the picture became more fragmented."],"variants":[]}],"lifeSummary":"When William Brace was born about 1340, his father, Robert Brace, was 11338 and his mother, Juliana, was 22. He married Joan in 1373, in Worcestershire, England. They were the parents of at least 1 son. He died about 1390, in Madresfield, Worcestershire, England, United Kingdom, at the age of 52, and was buried in Madresfield, Worcestershire, England, United Kingdom."},"et":{"Abt 1340–Abt 1390":"umbes 1340–umbes 1390","1340–1390":"1340–1390","1351–1390":"1351–1390","1374–1450":"1374–1450","1300–1370":"1300–1370","1319–1350":"1319–1350","1374":"1374","1373":"1373","1450":"1450","1351":"1351","1340":"1340","1350":"1350","1370":"1370","1390":"1390","Abt 1340":"umbes 1340","Abt 1370":"umbes 1370","about 1338":"umbes 1338","1300":"1300","Abt 1390":"umbes 1390","1319":"1319","Worcestershire, England":"Worcestershire, England","Warnedon, Worcester, England":"Warndon, Worcestershire, England","Madresfield, Worcestershire, England":"Madresfield, Worcestershire, Inglismaa, United Kingdom"},"fi":{"Abt 1340–Abt 1390":"noin 1340–noin 1390","1340–1390":"1340–1390","1351–1390":"1351–1390","1374–1450":"1374–1450","1300–1370":"1300–1370","1319–1350":"1319–1350","1374":"1374","1373":"1373","1450":"1450","1351":"1351","1340":"1340","1350":"1350","1370":"1370","1390":"1390","Abt 1340":"noin 1340","Abt 1370":"noin 1370","about 1338":"noin 1338","1300":"1300","Abt 1390":"noin 1390","1319":"1319","Worcestershire, England":"Worcestershire, England","Warnedon, Worcester, England":"Warndon, Worcestershire, England","Madresfield, Worcestershire, England":"Madresfield, Worcestershire, Englanti, Yhdistynyt kuningaskunta"},"fr":{"Abt 1340–Abt 1390":"environ 1340–environ 1390","1340–1390":"1340–1390","1351–1390":"1351–1390","1374–1450":"1374–1450","1300–1370":"1300–1370","1319–1350":"1319–1350","1374":"1374","1373":"1373","1450":"1450","1351":"1351","1340":"1340","1350":"1350","1370":"1370","1390":"1390","Abt 1340":"environ 1340","Abt 1370":"environ 1370","about 1338":"environ 1338","1300":"1300","Abt 1390":"en